---
import SiteLayout from '../layouts/SiteLayout.astro';

interface Props {
  data: any;
}

const { data } = Astro.props;

const score = data.overallScore || 0;
const pillars = data.pillars || {};
const pillarList = [pillars.competitiveMomentum, pillars.moatDurability, pillars.sentimentCatalyst].filter(Boolean);

// Score color
function scoreColor(s: number, max: number): string {
  const pct = s / max * 100;
  if (pct >= 70) return '#22c55e';
  if (pct >= 50) return '#eab308';
  if (pct >= 30) return '#f97316';
  return '#ef4444';
}

function scoreBg(s: number, max: number): string {
  const pct = s / max * 100;
  if (pct >= 70) return 'rgba(34, 197, 94, 0.1)';
  if (pct >= 50) return 'rgba(234, 179, 8, 0.1)';
  if (pct >= 30) return 'rgba(249, 115, 22, 0.1)';
  return 'rgba(239, 68, 68, 0.1)';
}

function verdictClass(s: number): string {
  if (s >= 70) return 'strong';
  if (s >= 50) return 'moderate';
  if (s >= 30) return 'weak';
  return 'poor';
}

const schema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": data.title,
  "description": data.description,
  "datePublished": data.published || "2026-03-19",
  "dateModified": data.published || "2026-03-19",
  "author": { "@type": "Organization", "name": "Westmount Research", "url": "https://westmountfundamentals.com" },
  "publisher": { "@type": "Organization", "name": "Westmount Research", "url": "https://westmountfundamentals.com" },
  "mainEntityOfPage": { "@type": "WebPage", "@id": `https://westmountfundamentals.com/${data.slug}` }
};
---
<SiteLayout
  site="westmount"
  title={data.title}
  description={data.description}
  canonical={`https://westmountfundamentals.com/${data.slug}`}
  schema={schema}
>
<div class="ps-page">
  <div class="ps-container">

    <!-- HEADER -->
    <div class="ps-header">
      <div class="ps-badge">ECONOMIC PROSPECT ANALYSIS</div>
      <h1>{data.companyName} ({data.ticker})</h1>
      <p class="ps-subtitle">Forward-looking competitive assessment — compiled by Gemini 3.1</p>
    </div>

    <!-- SCORE CARD -->
    <div class="score-card">
      <div class="score-ring-wrap">
        <svg class="score-ring" viewBox="0 0 120 120">
          <circle cx="60" cy="60" r="50" fill="none" stroke="#152040" stroke-width="10" />
          <circle
            cx="60" cy="60" r="50" fill="none"
            stroke={scoreColor(score, 100)}
            stroke-width="10"
            stroke-dasharray={`${score * 3.14} ${(100 - score) * 3.14}`}
            stroke-dashoffset="78.5"
            stroke-linecap="round"
          />
        </svg>
        <div class="score-number" style={`color: ${scoreColor(score, 100)}`}>{score}</div>
      </div>
      <div class="score-meta">
        <span class={`verdict-tag ${verdictClass(score)}`}>{data.verdict}</span>
        <p class="score-detail">{data.verdictDetail}</p>
        {data.ivSlug && (
          <a href={`/${data.ivSlug}`} class="iv-link">View DCF Intrinsic Value Analysis →</a>
        )}
      </div>
    </div>

    <!-- PILLAR BREAKDOWN -->
    {pillarList.map((pillar: any) => (
      <section class="pillar-section">
        <div class="pillar-header">
          <h2>{pillar.title}</h2>
          <div class="pillar-score" style={`color: ${scoreColor(pillar.score, pillar.maxScore)}; background: ${scoreBg(pillar.score, pillar.maxScore)}`}>
            {pillar.score}<span class="pillar-max">/{pillar.maxScore}</span>
          </div>
        </div>
        <p class="pillar-summary">{pillar.summary}</p>

        <div class="factors-grid">
          {pillar.factors.map((f: any) => (
            <div class="factor-card">
              <div class="factor-top">
                <span class="factor-name">{f.name}</span>
                <span class="factor-score" style={`color: ${scoreColor(f.score, f.maxScore)}`}>
                  {f.score}/{f.maxScore}
                </span>
              </div>
              <div class="factor-bar-bg">
                <div class="factor-bar-fill" style={`width: ${(f.score / f.maxScore) * 100}%; background: ${scoreColor(f.score, f.maxScore)}`} />
              </div>
              <p class="factor-rationale">{f.rationale}</p>
            </div>
          ))}
        </div>
      </section>
    ))}

    <!-- CATALYSTS & RISKS -->
    <div class="dual-section">
      {data.keyCatalysts?.length > 0 && (
        <section class="catalyst-risk-card catalysts">
          <h2>🚀 Key Catalysts</h2>
          <ul>
            {data.keyCatalysts.map((c: string) => <li>{c}</li>)}
          </ul>
        </section>
      )}
      {data.keyRisks?.length > 0 && (
        <section class="catalyst-risk-card risks">
          <h2>⚠️ Key Risks</h2>
          <ul>
            {data.keyRisks.map((r: string) => <li>{r}</li>)}
          </ul>
        </section>
      )}
    </div>

    <!-- METHODOLOGY -->
    {data.methodology && (
      <section class="method-section">
        <h2>Methodology</h2>
        <p>{data.methodology}</p>
      </section>
    )}

    <!-- DISCLAIMER -->
    <section class="ps-disclaimer">
      <p><strong>Disclaimer:</strong> This economic prospect score is for educational purposes only. It is generated by an AI model (Gemini 3.1) based on publicly available data and may not reflect all material factors. This does not constitute investment advice. Always conduct your own due diligence.</p>
    </section>
  </div>
</div>

<style>
  .ps-page {
    background: #060a12;
    color: #c8d0de;
    font-family: 'Inter', -apple-system, sans-serif;
    min-height: 100vh;
  }
  .ps-container {
    max-width: 900px;
    margin: 0 auto;
    padding: 2rem 1.5rem;
  }
  .ps-header {
    text-align: center;
    margin-bottom: 2.5rem;
  }
  .ps-badge {
    display: inline-block;
    background: linear-gradient(135deg, #f59e0b, #d97706);
    color: #0a0e17;
    font-size: 0.7rem;
    font-weight: 800;
    padding: 0.35rem 1rem;
    border-radius: 20px;
    letter-spacing: 0.12em;
    margin-bottom: 1rem;
  }
  .ps-header h1 {
    font-size: 2.2rem;
    font-weight: 800;
    color: #e2e8f0;
    margin: 0.5rem 0;
    line-height: 1.2;
  }
  .ps-subtitle {
    color: #94a3b8;
    font-size: 1rem;
  }

  /* Score Card */
  .score-card {
    background: #0a1020;
    border: 1px solid #152040;
    border-radius: 16px;
    padding: 2rem;
    display: flex;
    align-items: center;
    gap: 2rem;
    margin-bottom: 2rem;
  }
  .score-ring-wrap {
    position: relative;
    width: 120px;
    height: 120px;
    flex-shrink: 0;
  }
  .score-ring {
    transform: rotate(-90deg);
    width: 120px;
    height: 120px;
  }
  .score-number {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: 'JetBrains Mono', monospace;
    font-size: 2.2rem;
    font-weight: 800;
  }
  .score-meta {
    flex: 1;
  }
  .verdict-tag {
    display: inline-block;
    padding: 0.3rem 0.8rem;
    border-radius: 6px;
    font-weight: 700;
    font-size: 0.8rem;
    letter-spacing: 0.05em;
    margin-bottom: 0.75rem;
  }
  .verdict-tag.strong { background: rgba(34, 197, 94, 0.15); color: #22c55e; border: 1px solid rgba(34, 197, 94, 0.3); }
  .verdict-tag.moderate { background: rgba(234, 179, 8, 0.15); color: #eab308; border: 1px solid rgba(234, 179, 8, 0.3); }
  .verdict-tag.weak { background: rgba(249, 115, 22, 0.15); color: #f97316; border: 1px solid rgba(249, 115, 22, 0.3); }
  .verdict-tag.poor { background: rgba(239, 68, 68, 0.15); color: #ef4444; border: 1px solid rgba(239, 68, 68, 0.3); }
  .score-detail {
    color: #94a3b8;
    font-size: 0.9rem;
    line-height: 1.6;
    margin: 0;
  }
  .iv-link {
    display: inline-block;
    margin-top: 0.75rem;
    color: #4a8fe7;
    font-size: 0.85rem;
    font-weight: 600;
  }
  .iv-link:hover { text-decoration: underline; }

  /* Pillar Sections */
  .pillar-section {
    background: #0a1020;
    border: 1px solid #152040;
    border-radius: 12px;
    padding: 1.75rem;
    margin-bottom: 1.5rem;
  }
  .pillar-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 0.75rem;
  }
  .pillar-header h2 {
    color: #e2e8f0;
    font-size: 1.2rem;
    font-weight: 700;
    margin: 0;
  }
  .pillar-score {
    font-family: 'JetBrains Mono', monospace;
    font-size: 1.3rem;
    font-weight: 800;
    padding: 0.3rem 0.8rem;
    border-radius: 8px;
  }
  .pillar-max {
    font-size: 0.8rem;
    font-weight: 500;
    opacity: 0.6;
  }
  .pillar-summary {
    color: #94a3b8;
    font-size: 0.9rem;
    line-height: 1.6;
    margin-bottom: 1.25rem;
  }

  /* Factor Cards */
  .factors-grid {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .factor-card {
    background: #0d1528;
    border: 1px solid #1e293b;
    border-radius: 10px;
    padding: 1.25rem;
  }
  .factor-top {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 0.5rem;
  }
  .factor-name {
    color: #e2e8f0;
    font-size: 0.9rem;
    font-weight: 600;
  }
  .factor-score {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.9rem;
    font-weight: 700;
  }
  .factor-bar-bg {
    height: 4px;
    background: #152040;
    border-radius: 2px;
    margin-bottom: 0.75rem;
    overflow: hidden;
  }
  .factor-bar-fill {
    height: 100%;
    border-radius: 2px;
    transition: width 0.3s;
  }
  .factor-rationale {
    color: #7a8a9e;
    font-size: 0.85rem;
    line-height: 1.6;
    margin: 0;
  }

  /* Catalysts & Risks */
  .dual-section {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
    margin-bottom: 1.5rem;
  }
  .catalyst-risk-card {
    background: #0a1020;
    border: 1px solid #152040;
    border-radius: 12px;
    padding: 1.5rem;
  }
  .catalyst-risk-card h2 {
    font-size: 1.05rem;
    font-weight: 700;
    color: #e2e8f0;
    margin: 0 0 1rem;
  }
  .catalyst-risk-card ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .catalyst-risk-card li {
    color: #94a3b8;
    font-size: 0.85rem;
    line-height: 1.6;
    padding: 0.5rem 0;
    border-bottom: 1px solid #152040;
  }
  .catalyst-risk-card li:last-child { border-bottom: none; }
  .catalysts li::before { content: '↗ '; color: #22c55e; font-weight: 700; }
  .risks li::before { content: '↘ '; color: #ef4444; font-weight: 700; }

  /* Method */
  .method-section {
    background: #0a1020;
    border: 1px solid #152040;
    border-radius: 12px;
    padding: 1.5rem;
    margin-bottom: 1.5rem;
  }
  .method-section h2 {
    color: #e2e8f0;
    font-size: 1.1rem;
    font-weight: 700;
    margin: 0 0 0.75rem;
  }
  .method-section p {
    color: #7a8a9e;
    font-size: 0.85rem;
    line-height: 1.7;
    margin: 0;
  }

  /* Disclaimer */
  .ps-disclaimer {
    background: #0a1020;
    border: 1px solid #152040;
    border-radius: 12px;
    padding: 1.5rem;
    margin-top: 2rem;
  }
  .ps-disclaimer p {
    color: #64748b;
    font-size: 0.8rem;
    line-height: 1.6;
    margin: 0;
  }

  @media (max-width: 640px) {
    .ps-container { padding: 1rem; }
    .ps-header h1 { font-size: 1.5rem; }
    .score-card { flex-direction: column; text-align: center; }
    .dual-section { grid-template-columns: 1fr; }
  }
</style>
</SiteLayout>
