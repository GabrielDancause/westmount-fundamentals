---
import SiteLayout from '../layouts/SiteLayout.astro';

interface Props {
  data: any;
}

const { data } = Astro.props;

// --- USE PRE-COMPUTED VALUES ---
const intrinsicValuePerShare = data.computedIV || 0;
const currentPrice = data.currentPrice || 0;
const marginOfSafety = currentPrice > 0 ? ((intrinsicValuePerShare - currentPrice) / currentPrice) * 100 : 0;
const isUndervalued = intrinsicValuePerShare > currentPrice;

const fcfGrowthRate = data.fcfGrowthRate || 0;
const discountRate = data.discountRate || 0;
const terminalGrowthRate = data.terminalGrowthRate || 0;

// Sensitivity matrix (generate from rates if not provided)
const sensDiscountRates = data.sensitivityDiscountRates || [
  discountRate - 0.02, discountRate - 0.01, discountRate,
  discountRate + 0.01, discountRate + 0.02
];
const sensGrowthRates = data.sensitivityGrowthRates || [
  terminalGrowthRate - 0.01, terminalGrowthRate - 0.005, terminalGrowthRate,
  terminalGrowthRate + 0.005, terminalGrowthRate + 0.01
];

// Build sensitivity matrix using Gordon Growth approximation
// Scale from the known IV point
const sensitivityMatrix = sensGrowthRates.map(g => {
  return {
    growthRate: g,
    values: sensDiscountRates.map(d => {
      if (d <= g || d <= 0) return intrinsicValuePerShare; // avoid division by zero
      const baseSpread = discountRate - terminalGrowthRate;
      const newSpread = d - g;
      if (baseSpread <= 0 || newSpread <= 0) return intrinsicValuePerShare;
      // Terminal value scales inversely with spread
      const scaleFactor = baseSpread / newSpread;
      return intrinsicValuePerShare * scaleFactor;
    })
  };
});

// Helpers
function formatMoney(n: number): string {
  if (n === null || n === undefined || isNaN(n)) return 'N/A';
  return '$' + n.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
}
function formatPercent(n: number): string {
  if (n === null || n === undefined || isNaN(n)) return 'N/A';
  return (n * 100).toFixed(1) + '%';
}

const schema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": data.title,
  "description": data.description,
  "datePublished": data.published || "2026-03-18",
  "dateModified": data.published || "2026-03-18",
  "author": { "@type": "Organization", "name": "Westmount Research", "url": "https://westmountfundamentals.com" },
  "publisher": { "@type": "Organization", "name": "Westmount Research", "url": "https://westmountfundamentals.com" },
  "mainEntityOfPage": { "@type": "WebPage", "@id": `https://westmountfundamentals.com/${data.slug}` }
};

const faqSchema = data.faq?.length ? {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": data.faq.map((f: any) => ({
    "@type": "Question",
    "name": f.question,
    "acceptedAnswer": { "@type": "Answer", "text": f.answer.replace(/<[^>]+>/g, '') }
  }))
} : null;

const assumptions = data.assumptions || {};
const risks = data.risks || { items: [] };
const faq = data.faq || [];
const thesisParagraphs = data.thesisParagraphs || [];
const thesisTitle = data.thesisTitle || '';
---
<SiteLayout
  site="westmount"
  title={data.title}
  description={data.description}
  canonical={`https://westmountfundamentals.com/${data.slug}`}
  schema={faqSchema ? [schema, faqSchema] : schema}
>
<div class="iv-page">
  <div class="iv-container">
    <!-- HEADER -->
    <div class="gemini-header">
      <div class="gemini-badge">COMPILED BY GEMINI 3.1</div>
      <h1>{data.companyName} ({data.ticker}) Intrinsic Value</h1>
      <p class="subtitle">An independent two-stage DCF analysis by a frontier AI model.</p>
    </div>

    <!-- VERDICT CARD -->
    <div class="verdict-card">
      <div class="verdict-header">
        <h2>Fair Value Estimate</h2>
      </div>
      <div class="verdict-body">
        <span class="verdict-value">{formatMoney(intrinsicValuePerShare)}</span>
        <span class="verdict-label">per share</span>
      </div>
      <div class="verdict-comparison">
        <div class="comparison-row">
          <span>Current Price</span>
          <span>{formatMoney(currentPrice)}</span>
        </div>
        <div class="comparison-row">
          <span>Margin of Safety</span>
          <span class={marginOfSafety >= 0 ? 'text-green' : 'text-red'}>{marginOfSafety.toFixed(1)}%</span>
        </div>
      </div>
      <div class={`verdict-badge ${isUndervalued ? 'undervalued' : 'overvalued'}`}>
        {isUndervalued ? 'UNDERVALUED' : 'OVERVALUED'}
      </div>
      <p class="verdict-footer">{data.verdictFooter || 'Based on FY2025 actuals.'}</p>
    </div>

    <!-- THESIS -->
    {thesisTitle && (
      <section class="content-section">
        <h2>{thesisTitle}</h2>
        {thesisParagraphs.map((p: string) => <p set:html={p} />)}
      </section>
    )}

    <!-- ASSUMPTIONS -->
    {Object.keys(assumptions).length > 0 && (
      <section class="content-section">
        <h2>My Assumptions &amp; Rationale</h2>
        <div class="assumptions-grid">
          {[assumptions.fcfGrowth, assumptions.discountRate, assumptions.terminalGrowth].filter(Boolean).map((a: any) => (
            <div class="assumption-card">
              <div class="assumption-label">{a.title}</div>
              <div class="assumption-value">{formatPercent(a.rate)}</div>
              {a.rationale && <p class="assumption-rationale">{a.rationale}</p>}
            </div>
          ))}
        </div>
      </section>
    )}

    <!-- SENSITIVITY MATRIX -->
    {discountRate > 0 && terminalGrowthRate > 0 && (
      <section class="content-section">
        <h2>Sensitivity Analysis</h2>
        <p>Intrinsic value per share under varying discount rate and terminal growth rate assumptions.</p>
        <div class="table-wrapper">
          <table class="sensitivity-table">
            <thead>
              <tr>
                <th>WACC ↓ / Terminal →</th>
                {sensGrowthRates.map((g: number) => <th>{formatPercent(g)}</th>)}
              </tr>
            </thead>
            <tbody>
              {sensitivityMatrix.map((row: any) => (
                <tr>
                  <td class="row-header"><strong>{formatPercent(row.growthRate)}</strong></td>
                  {row.values.map((val: number) => (
                    <td class={val > currentPrice ? 'cell-green' : 'cell-red'}>
                      {formatMoney(val)}
                    </td>
                  ))}
                </tr>
              ))}
            </tbody>
          </table>
        </div>
        <p class="matrix-legend">
          <span class="legend-green">■</span> Undervalued vs current price
          <span class="legend-red">■</span> Overvalued vs current price
        </p>
      </section>
    )}

    <!-- RISKS -->
    {risks.items?.length > 0 && (
      <section class="content-section">
        <h2>Key Risks</h2>
        {risks.introText && <p>{risks.introText}</p>}
        {risks.items.map((risk: any) => (
          <div class="risk-item">
            <h3>{risk.title}</h3>
            <p set:html={risk.description} />
          </div>
        ))}
      </section>
    )}

    <!-- FAQ -->
    {faq.length > 0 && (
      <section class="content-section faq-section">
        <h2>Frequently Asked Questions</h2>
        {faq.map((f: any) => (
          <div class="faq-item">
            <h3>{f.question}</h3>
            <p set:html={f.answer} />
          </div>
        ))}
      </section>
    )}

    <!-- DISCLAIMER -->
    <section class="disclaimer">
      <p><strong>Disclaimer:</strong> The numbers presented on this page are for educational and entertainment purposes only. They are the result of a deterministic mathematical model fed with assumptions generated by an Artificial Intelligence (Gemini 3.1). This does not constitute investment advice. Always conduct your own due diligence before investing in the stock market.</p>
    </section>
  </div>
</div>

<style>
  .iv-page {
    background: #060a12;
    color: #c8d0de;
    font-family: 'Inter', -apple-system, sans-serif;
    min-height: 100vh;
  }
  .iv-container {
    max-width: 860px;
    margin: 0 auto;
    padding: 2rem 1.5rem;
  }
  .gemini-header {
    text-align: center;
    margin-bottom: 2.5rem;
  }
  .gemini-badge {
    display: inline-block;
    background: linear-gradient(135deg, #4a8fe7, #6c63ff);
    color: white;
    font-size: 0.75rem;
    font-weight: 700;
    padding: 0.35rem 1rem;
    border-radius: 20px;
    letter-spacing: 0.1em;
    margin-bottom: 1rem;
  }
  .gemini-header h1 {
    font-size: 2rem;
    font-weight: 800;
    color: #e2e8f0;
    margin: 0.5rem 0;
    line-height: 1.2;
  }
  .subtitle {
    color: #94a3b8;
    font-size: 1rem;
  }
  .verdict-card {
    background: #0a1020;
    border: 1px solid #152040;
    border-radius: 16px;
    padding: 2rem;
    text-align: center;
    margin-bottom: 2.5rem;
  }
  .verdict-header h2 {
    color: #94a3b8;
    font-size: 0.9rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin: 0 0 1rem;
  }
  .verdict-value {
    font-family: 'JetBrains Mono', monospace;
    font-size: 3rem;
    font-weight: 800;
    color: #4a8fe7;
    display: block;
  }
  .verdict-label {
    color: #64748b;
    font-size: 0.9rem;
    display: block;
    margin-bottom: 1.5rem;
  }
  .verdict-comparison {
    display: flex;
    justify-content: center;
    gap: 2rem;
    margin-bottom: 1.5rem;
    flex-wrap: wrap;
  }
  .comparison-row {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    font-size: 0.9rem;
  }
  .comparison-row span:first-child {
    color: #64748b;
    font-size: 0.8rem;
  }
  .text-green { color: #22c55e; font-weight: 700; font-family: 'JetBrains Mono', monospace; }
  .text-red { color: #ef4444; font-weight: 700; font-family: 'JetBrains Mono', monospace; }
  .verdict-badge {
    display: inline-block;
    padding: 0.4rem 1.2rem;
    border-radius: 8px;
    font-weight: 700;
    font-size: 0.85rem;
    letter-spacing: 0.05em;
  }
  .verdict-badge.undervalued {
    background: rgba(34, 197, 94, 0.15);
    color: #22c55e;
    border: 1px solid rgba(34, 197, 94, 0.3);
  }
  .verdict-badge.overvalued {
    background: rgba(239, 68, 68, 0.15);
    color: #ef4444;
    border: 1px solid rgba(239, 68, 68, 0.3);
  }
  .verdict-footer {
    color: #475569;
    font-size: 0.8rem;
    margin-top: 1rem;
  }
  .content-section {
    background: #0a1020;
    border: 1px solid #152040;
    border-radius: 12px;
    padding: 2rem;
    margin-bottom: 1.5rem;
  }
  .content-section h2 {
    color: #e2e8f0;
    font-size: 1.3rem;
    font-weight: 700;
    margin: 0 0 1rem;
  }
  .content-section p {
    color: #94a3b8;
    line-height: 1.7;
    margin-bottom: 0.75rem;
  }
  .assumptions-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 1rem;
    margin-top: 1rem;
  }
  .assumption-card {
    background: #0d1528;
    border: 1px solid #1e293b;
    border-radius: 10px;
    padding: 1.25rem;
  }
  .assumption-label {
    color: #64748b;
    font-size: 0.8rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 0.5rem;
  }
  .assumption-value {
    font-family: 'JetBrains Mono', monospace;
    font-size: 1.8rem;
    font-weight: 700;
    color: #4a8fe7;
    margin-bottom: 0.75rem;
  }
  .assumption-rationale {
    color: #94a3b8;
    font-size: 0.85rem;
    line-height: 1.6;
  }
  .table-wrapper {
    overflow-x: auto;
    margin: 1rem 0;
  }
  .sensitivity-table {
    width: 100%;
    border-collapse: collapse;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.85rem;
  }
  .sensitivity-table th, .sensitivity-table td {
    padding: 0.6rem 0.8rem;
    text-align: center;
    border: 1px solid #1e293b;
  }
  .sensitivity-table th {
    background: #0d1528;
    color: #94a3b8;
    font-weight: 600;
  }
  .sensitivity-table .row-header {
    background: #0d1528;
    text-align: left;
    color: #94a3b8;
  }
  .cell-green { color: #22c55e; background: rgba(34, 197, 94, 0.05); }
  .cell-red { color: #ef4444; background: rgba(239, 68, 68, 0.05); }
  .matrix-legend {
    text-align: center;
    font-size: 0.8rem;
    color: #64748b;
  }
  .legend-green { color: #22c55e; }
  .legend-red { color: #ef4444; }
  .risk-item { margin-bottom: 1rem; }
  .risk-item h3 {
    color: #e2e8f0;
    font-size: 1rem;
    font-weight: 600;
    margin: 0 0 0.4rem;
  }
  .faq-item { margin-bottom: 1.25rem; }
  .faq-item h3 {
    color: #e2e8f0;
    font-size: 1rem;
    font-weight: 600;
    margin: 0 0 0.4rem;
  }
  .disclaimer {
    background: #0a1020;
    border: 1px solid #152040;
    border-radius: 12px;
    padding: 1.5rem;
    margin-top: 2rem;
  }
  .disclaimer p {
    color: #64748b;
    font-size: 0.8rem;
    line-height: 1.6;
    margin: 0;
  }
  @media (max-width: 640px) {
    .iv-container { padding: 1rem; }
    .gemini-header h1 { font-size: 1.5rem; }
    .verdict-value { font-size: 2.2rem; }
    .verdict-comparison { flex-direction: column; gap: 0.5rem; }
  }
</style>
</SiteLayout>
