    font-family: 'JetBrains Mono', monospace;
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    margin-bottom: 1rem;
    text-transform: uppercase;
  }

  .gemini-header h1 {
    font-size: 2.5rem;
    color: #4a8fe7;
    margin-bottom: 1rem;
  }

  .gemini-header .subtitle {
    font-size: 1.2rem;
    color: #c8d0de;
    opacity: 0.9;
    margin-bottom: 1rem;
