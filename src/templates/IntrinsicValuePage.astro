  }

  .sensitivity-table table {
    text-align: center;
  }

  .sensitivity-table th, .sensitivity-table td {
    text-align: center;
    padding: 0.75rem;
  }

  .sensitivity-table .header-cell {
    border-bottom: 2px solid #1e293b;
  }

