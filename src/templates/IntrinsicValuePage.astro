    overflow: hidden;
    margin-bottom: 3rem;
  }

  .verdict-header {
    background-color: rgba(74, 143, 231, 0.1);
    padding: 1.5rem;
    border-bottom: 1px solid #1e293b;
    text-align: center;
  }

  .verdict-header h2 {
