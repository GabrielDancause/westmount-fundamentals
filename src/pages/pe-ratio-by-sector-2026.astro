    <!-- Chart.js from CDN -->
  <script is:inline src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>
  <script is:inline>
// Inject real data
      window.__INITIAL_DATA__ = {"sp500":{"name":"S&P 500","ticker":"SPY","trailingPE":26.42,"forwardPE":27.85},"sectors":[{"name":"Information Technology","ticker":"XLK","trailingPE":33.96,"forwardPE":23.58,"avg10Y":null,"premiumDiscount":null},{"name":"Health Care","ticker":"XLV","trailingPE":26.25,"forwardPE":19.07,"avg10Y":null,"premiumDiscount":null},{"name":"Financials","ticker":"XLF","trailingPE":16.33,"forwardPE":16.27,"avg10Y":null,"premiumDiscount":null},{"name":"Consumer Discretionary","ticker":"XLY","trailingPE":29.72,"forwardPE":54.72,"avg10Y":null,"premiumDiscount":null},{"name":"Industrials","ticker":"XLI","trailingPE":29.2,"forwardPE":28.36,"avg10Y":null,"premiumDiscount":null},{"name":"Communication Services","ticker":"XLC","trailingPE":17.9,"forwardPE":17.56,"avg10Y":null,"premiumDiscount":null},{"name":"Consumer Staples","ticker":"XLP","trailingPE":26.78,"forwardPE":26.64,"avg10Y":null,"premiumDiscount":null},{"name":"Energy","ticker":"XLE","trailingPE":22.1,"forwardPE":18.71,"avg10Y":null,"premiumDiscount":null},{"name":"Utilities","ticker":"XLU","trailingPE":23.02,"forwardPE":19.03,"avg10Y":null,"premiumDiscount":null},{"name":"Real Estate","ticker":"XLRE","trailingPE":32.42,"forwardPE":45.56,"avg10Y":null,"premiumDiscount":null},{"name":"Materials","ticker":"XLB","trailingPE":26.52,"forwardPE":19.94,"avg10Y":null,"premiumDiscount":null}]};

      const state = {
        data: window.__INITIAL_DATA__.sectors,
        sp500: window.__INITIAL_DATA__.sp500,
        sortCol: 'trailingPE',
        sortAsc: false,
        searchQuery: ''
      };

      // Initialize UI
      document.addEventListener('DOMContentLoaded', () => {
        // Set stats
        document.getElementById('sp500-pe').textContent = state.sp500.trailingPE ? state.sp500.trailingPE.toFixed(2) + 'x' : 'N/A';
        document.getElementById('sp500-fpe').textContent = state.sp500.forwardPE ? state.sp500.forwardPE.toFixed(2) + 'x' : 'N/A';

        const validSectors = state.data.filter(s => s.trailingPE !== null);
        if(validSectors.length > 0) {
            const highest = validSectors.reduce((max, obj) => obj.trailingPE > max.trailingPE ? obj : max, validSectors[0]);
            document.getElementById('highest-pe-sector').textContent = highest.name;
            document.getElementById('highest-pe-val').textContent = highest.trailingPE.toFixed(2) + 'x Trailing P/E';
        }

        initTable();
        initChart();

        // Search listener
        document.getElementById('searchInput').addEventListener('input', (e) => {
          state.searchQuery = e.target.value.toLowerCase();
          renderTable();
        });

        // Sort listeners
        document.querySelectorAll('th[data-sort]').forEach(th => {
          th.addEventListener('click', () => {
            const col = th.dataset.sort;
            if (state.sortCol === col) {
              state.sortAsc = !state.sortAsc;
            } else {
              state.sortCol = col;
              state.sortAsc = col === 'name' ? true : false; // Default numeric to descending, alpha to ascending
            }
            renderTable();
          });
        });
      });

      function initTable() {
        renderTable();
      }

      function renderTable() {
        let filtered = state.data.filter(row => {
          return row.name.toLowerCase().includes(state.searchQuery) || row.ticker.toLowerCase().includes(state.searchQuery);
        });

        filtered.sort((a, b) => {
          let valA = a[state.sortCol];
          let valB = b[state.sortCol];

          if (valA === null) valA = -999999;
          if (valB === null) valB = -999999;

          if (typeof valA === 'string') {
            return state.sortAsc ? valA.localeCompare(valB) : valB.localeCompare(valA);
          }
          return state.sortAsc ? valA - valB : valB - valA;
        });

        const tbody = document.getElementById('tableBody');
        tbody.innerHTML = '';

        filtered.forEach(row => {
          const tr = document.createElement('tr');

          // Name cell
          const tdName = document.createElement('td');
          tdName.innerHTML = `${row.name} <span class="ticker-badge">${row.ticker}</span>`;
          tr.appendChild(tdName);

          // Helper to format numeric or null
          const fmt = (val, suffix='') => {
            if (val === null) return '<span class="null-val">N/A</span>';
            return val.toFixed(2) + suffix;
          };

          tr.innerHTML += `
            <td class="numeric">${fmt(row.trailingPE, 'x')}</td>
            <td class="numeric">${fmt(row.forwardPE, 'x')}</td>
            <td class="numeric">${fmt(row.avg10Y, 'x')}</td>
            <td class="numeric">${fmt(row.premiumDiscount, '%')}</td>
          `;

          tbody.appendChild(tr);
        });
      }

      function initChart() {
        const ctx = document.getElementById('valuationChart').getContext('2d');

        // Prepare data - sort by Trailing PE for nice chart
        const sortedData = [...state.data].sort((a,b) => (b.trailingPE || 0) - (a.trailingPE || 0));

        const labels = sortedData.map(d => d.name);
        const trailingData = sortedData.map(d => d.trailingPE);
        const forwardData = sortedData.map(d => d.forwardPE);

        Chart.defaults.color = '#8a9bb3';
        Chart.defaults.font.family = "'Inter', sans-serif";

        new Chart(ctx, {
          type: 'bar',
          data: {
            labels: labels,
            datasets: [
              {
                label: 'Trailing P/E',
                data: trailingData,
                backgroundColor: 'rgba(74, 143, 231, 0.8)',
                borderColor: '#4a8fe7',
                borderWidth: 1,
                borderRadius: 4
              },
              {
                label: 'Forward P/E',
                data: forwardData,
                backgroundColor: 'rgba(231, 143, 74, 0.8)',
                borderColor: '#e78f4a',
                borderWidth: 1,
                borderRadius: 4
              }
            ]
          },
          options: {
            responsive: true,
            maintainAspectRatio: false,
            plugins: {
              legend: {
                position: 'top',
                labels: { color: '#c8d0de', usePointStyle: true, boxWidth: 8 }
              },
              tooltip: {
                backgroundColor: 'rgba(10, 16, 32, 0.9)',
                titleColor: '#fff',
                bodyColor: '#c8d0de',
                borderColor: '#152040',
                borderWidth: 1,
                padding: 12,
                callbacks: {
                  label: function(context) {
                    let label = context.dataset.label || '';
                    if (label) label += ': ';
                    if (context.parsed.y !== null) {
                      label += context.parsed.y.toFixed(2) + 'x';
                    } else {
                      label += 'N/A';
                    }
                    return label;
                  }
                }
              }
            },
            scales: {
              y: {
                beginAtZero: true,
                grid: { color: 'rgba(21, 32, 64, 0.5)' },
                ticks: {
                  callback: function(value) { return value + 'x'; }
                }
              },
              x: {
                grid: { display: false },
                ticks: {
                  maxRotation: 45,
                  minRotation: 45
                }
              }
            }
          }
        });
      }
  </script>

  
