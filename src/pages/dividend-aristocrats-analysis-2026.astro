  <style is:global>
*, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
body { font-family: 'Inter', -apple-system, sans-serif; background: #060a12; color: #c8d0de; line-height: 1.6; }
a { color: #4a8fe7; text-decoration: none; }
a:hover { text-decoration: underline; }

.container { max-width: 1200px; margin: 0 auto; padding: 0 24px; }

/* Header */
.header { text-align: center; padding: 80px 24px 60px; background: linear-gradient(180deg, #0a1628 0%, #060a12 100%); position: relative; border-bottom: 1px solid #152040; }
.header::before { content: ''; position: absolute; inset: 0; background: radial-gradient(circle at 50% 40%, rgba(74,143,231,0.06) 0%, transparent 60%); }
.header-content { position: relative; z-index: 1; }
.tag { display: inline-block; background: rgba(74,143,231,0.12); color: #4a8fe7; font-size: 0.75rem; font-weight: 800; padding: 6px 16px; border-radius: 20px; letter-spacing: 1.5px; text-transform: uppercase; margin-bottom: 16px; }
h1 { font-size: 3rem; font-weight: 900; color: #fff; letter-spacing: -1.2px; margin-bottom: 16px; line-height: 1.1; }
.subtitle { color: #5a6a80; font-size: 1.1rem; max-width: 700px; margin: 0 auto 16px; }
.date { color: #3a4a60; font-size: 0.85rem; font-weight: 600; letter-spacing: 1px; }

/* Stats grid */
.stats-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 20px; margin: 60px auto; max-width: 1000px; }
.stat-card { background: linear-gradient(135deg, #0a1020 0%, #0d1428 100%); border: 1px solid #152040; border-radius: 16px; padding: 30px 20px; text-align: center; box-shadow: 0 4px 20px rgba(0,0,0,0.2); }
.stat-value { font-family: 'JetBrains Mono', monospace; font-size: 2.5rem; font-weight: 700; color: #4a8fe7; line-height: 1.1; margin-bottom: 8px; }
.stat-label { font-size: 0.85rem; color: #6a7a90; font-weight: 600; text-transform: uppercase; letter-spacing: 0.5px; }

/* Section Title */
h2 { font-size: 2rem; font-weight: 800; color: #fff; margin: 60px 0 24px; letter-spacing: -0.5px; border-bottom: 2px solid #152040; padding-bottom: 12px; }

/* Controls */
.controls { display: flex; gap: 16px; margin-bottom: 24px; flex-wrap: wrap; background: #0a1020; padding: 16px; border-radius: 12px; border: 1px solid #152040; }
.search-input, .filter-select { background: #060a12; border: 1px solid #1a2332; color: #fff; padding: 12px 16px; border-radius: 8px; font-family: 'Inter', sans-serif; font-size: 0.95rem; outline: none; transition: border-color 0.2s; }
.search-input:focus, .filter-select:focus { border-color: #4a8fe7; }
.search-input { flex: 1; min-width: 200px; }
.filter-select { min-width: 160px; cursor: pointer; }

/* Table */
.table-container { overflow-x: auto; background: #0a1020; border: 1px solid #152040; border-radius: 16px; box-shadow: 0 10px 30px rgba(0,0,0,0.3); }
table { width: 100%; border-collapse: collapse; text-align: left; }
th { background: #0d1428; padding: 16px; font-size: 0.8rem; font-weight: 700; color: #5a6a80; text-transform: uppercase; letter-spacing: 1px; cursor: pointer; user-select: none; border-bottom: 2px solid #152040; white-space: nowrap; transition: color 0.2s; }
th:hover { color: #fff; }
th::after { content: '↕'; margin-left: 6px; opacity: 0.3; }
th.sorted-asc::after { content: '↑'; opacity: 1; color: #4a8fe7; }
th.sorted-desc::after { content: '↓'; opacity: 1; color: #4a8fe7; }
td { padding: 16px; border-bottom: 1px solid #152040; font-size: 0.95rem; }
tr:last-child td { border-bottom: none; }
tr:hover td { background: rgba(74,143,231,0.04); }
.ticker { font-family: 'JetBrains Mono', monospace; font-weight: 700; color: #4a8fe7; }
.company-name { font-weight: 600; color: #fff; }
.sector-tag { display: inline-block; background: rgba(255,255,255,0.05); padding: 4px 10px; border-radius: 4px; font-size: 0.8rem; color: #a0b0c0; white-space: nowrap; }
