.sector-card { background: #0a1020; border: 1px solid #152040; border-radius: 12px; padding: 20px; text-align: center; }
.sector-name { font-size: 0.9rem; font-weight: 700; color: #fff; margin-bottom: 8px; }
.sector-count { font-family: 'JetBrains Mono', monospace; font-size: 2rem; color: #4a8fe7; font-weight: 700; line-height: 1; margin-bottom: 4px; }
