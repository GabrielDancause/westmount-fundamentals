// Utility for precise currency and large numbers
function formatVal(val, isCurrency = false, isBillion = false, isInteger = false) {
    if (val === null || val === undefined) return '<span class="null-val">—</span>';
    if (typeof val !== 'number') return val;
    if (isInteger) return Math.round(val).toString();
    let res = val.toFixed(2);
    if (isCurrency && isBillion) {
        return '$' + (val).toLocaleString('en-US', { minimumFractionDigits: 1, maximumFractionDigits: 1 }) + 'B';
    }
    return res;
}

// Build Yield Chart (Top 20)
function buildYieldChart() {
    const sorted = [...DATA.results].filter(r => r.currentYield !== null).sort((a, b) => b.currentYield - a.currentYield).slice(0, 20);
    if (sorted.length === 0) return;
    const maxYield = sorted[0].currentYield;
    const container = document.getElementById('yieldChart');
    let html = '';
    sorted.forEach(s => {
        const pct = (s.currentYield / maxYield) * 100;
        html += '<div class="chart-bar-row">';
        html += '<span class="chart-label">' + s.ticker + '</span>';
        html += '<div class="chart-bar-wrapper">';
        html += '<div class="chart-bar" style="width:' + pct + '%" title="' + s.company + ': ' + s.currentYield.toFixed(2) + '%">';
        html += '<span class="chart-bar-val">' + s.currentYield.toFixed(2) + '%</span>';
        html += '</div></div></div>';
    });
    html += '<div class="chart-note">Dividend yield as of March 2026</div>';
    container.innerHTML = html;
}

// Build Sector Grid
function buildSectorGrid() {
    const sectors = DATA.sectorBreakdown;
    const container = document.getElementById('sectorGrid');
    const total = DATA.totalCompanies;
    let html = '';
    let selectHtml = '<option value="">All Sectors</option>';

    // Sort sectors by count
    const sortedSectors = Object.entries(sectors).sort((a, b) => b[1] - a[1]);

    sortedSectors.forEach(([name, count]) => {
        if(!name) return;
        html += '<div class="sector-card">';
        html += '<div class="sector-name">' + name + '</div>';
        html += '<div class="sector-count">' + count + '</div>';
        html += '<div class="sector-pct">' + ((count/total)*100).toFixed(0) + '% of total</div>';
        html += '</div>';

        selectHtml += '<option value="' + name + '">' + name + '</option>';
    });
    container.innerHTML = html;
    document.getElementById('sectorFilter').innerHTML = selectHtml;
}

// Table logic
let currentSort = { col: 'yearsIncreasing', dir: 'desc' };
let filteredData = [...DATA.results];

function renderTable() {
    const tbody = document.getElementById('tableBody');
    let html = '';
    filteredData.forEach(r => {
        const yieldClass = r.currentYield && r.currentYield >= 4 ? 'yield-high' : (r.currentYield && r.currentYield < 1 ? 'yield-low' : '');
        html += '<tr>';
        html += '<td class="ticker">' + r.ticker + '</td>';
        html += '<td class="company-name">' + r.company + '</td>';
        html += '<td><span class="sector-tag">' + (r.sector || '—') + '</span></td>';
        html += '<td class="num">' + formatVal(r.yearsIncreasing, false, false, true) + '</td>';
        html += '<td class="num ' + yieldClass + '">' + (r.currentYield !== null ? formatVal(r.currentYield) + '%' : '<span class="null-val">—</span>') + '</td>';
        html += '<td class="num">' + (r.payoutRatio !== null ? formatVal(r.payoutRatio) + '%' : '<span class="null-val">—</span>') + '</td>';
        html += '<td class="num">' + formatVal(r.peRatio) + '</td>';
        html += '<td class="num">' + formatVal(r.forwardPe) + '</td>';
        html += '<td class="num">' + formatVal(r.marketCapB, true, true) + '</td>';
        html += '<td class="num">' + (r.healthScore !== null ? r.healthScore + '/10' : '<span class="null-val">—</span>') + '</td>';
        html += '</tr>';
    });
    // InnerHTML is generally okay here since we escaped data during build, but we should be careful
    tbody.innerHTML = html;
    document.getElementById('resultCount').textContent = filteredData.length + ' companies';
}

function sortTable(col) {
    if (currentSort.col === col) {
        currentSort.dir = currentSort.dir === 'asc' ? 'desc' : 'asc';
    } else {
        currentSort = { col, dir: 'desc' };
    }
    filteredData.sort((a, b) => {
        let va = a[col], vb = b[col];
        if (va === null || va === undefined) return 1;
        if (vb === null || vb === undefined) return -1;
        if (typeof va === 'string') return currentSort.dir === 'asc' ? va.localeCompare(vb) : vb.localeCompare(va);
        return currentSort.dir === 'asc' ? va - vb : vb - va;
    });

    document.querySelectorAll('th').forEach(th => {
        th.classList.remove('sorted-asc', 'sorted-desc');
        if (th.dataset.col === col) th.classList.add(currentSort.dir === 'asc' ? 'sorted-asc' : 'sorted-desc');
    });
    renderTable();
}

function applyFilters() {
    const search = document.getElementById('searchInput').value.toLowerCase();
    const sector = document.getElementById('sectorFilter').value;
    const yieldRange = document.getElementById('yieldFilter').value;

    filteredData = DATA.results.filter(r => {
        if (search && !r.ticker.toLowerCase().includes(search) && !r.company.toLowerCase().includes(search)) return false;
        if (sector && r.sector !== sector) return false;
        if (yieldRange) {
            const y = r.currentYield;
            if (y === null) return false;
            if (yieldRange === '4+' && y < 4) return false;
            if (yieldRange === '3-4' && (y < 3 || y >= 4)) return false;
            if (yieldRange === '2-3' && (y < 2 || y >= 3)) return false;
            if (yieldRange === '1-2' && (y < 1 || y >= 2)) return false;
            if (yieldRange === '<1' && y >= 1) return false;
        }
        return true;
    });

    sortTable(currentSort.col);
}

// Setup Event Listeners
document.querySelectorAll('th[data-col]').forEach(th => {
    th.addEventListener('click', () => sortTable(th.dataset.col));
});
document.getElementById('searchInput').addEventListener('input', applyFilters);
document.getElementById('sectorFilter').addEventListener('change', applyFilters);
document.getElementById('yieldFilter').addEventListener('change', applyFilters);

// Initialize
buildYieldChart();
buildSectorGrid();
sortTable('yearsIncreasing');
  </script>

  
