---
import SiteLayout from "../layouts/SiteLayout.astro";
import registry from "../data/pages-registry.json";

const page = (registry as any)["dividend-aristocrats-analysis-2026"];
export const meta = { title: "Dividend Aristocrats Analysis 2026: Yield, Payout & Growth", description: "68 companies have raised dividends for 25+ consecutive years. But not all Aristocrats are created equal — some yield 5x more than others.", category: "study", published: "2026-03-15" };

const schema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": "Dividend Aristocrats Analysis 2026: Yield, Payout & Growth",
  "description": "Complete analysis of S&P 500 Dividend Aristocrats — companies with 25+ consecutive years of dividend increases. Current yields, P/E ratios, market caps, and sector breakdown.",
  "datePublished": "2026-03-09",
  "dateModified": "2026-03-09",
  "author": {
    "@type": "Organization",
    "name": "Westmount Research",
    "url": "https://westmountfundamentals.com"
  },
  "publisher": {
    "@type": "Organization",
    "name": "Westmount Research",
    "url": "https://westmountfundamentals.com"
  },
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": "https://westmountfundamentals.com/dividend-aristocrats-analysis-2026"
  }
};

