  <script is:inline>
document.addEventListener('DOMContentLoaded', () => {
            const elInv = document.getElementById('calc-investment');
            const elYears = document.getElementById('calc-years');
            const elRet = document.getElementById('calc-return');
            const elEr = document.getElementById('calc-er');

            const resFees = document.getElementById('res-fees');
            const resGross = document.getElementById('res-gross');
            const resNet = document.getElementById('res-net');

            function updateCalc() {
                const p = parseFloat(elInv.value) || 0;
                const t = parseFloat(elYears.value) || 0;
                const rGross = (parseFloat(elRet.value) || 0) / 100;
                const er = (parseFloat(elEr.value) || 0) / 100;

                const rNet = rGross - er;

                // FV = P(1+r)^t
                const fvGross = p * Math.pow(1 + rGross, t);
                const fvNet = p * Math.pow(1 + rNet, t);
                const totalFees = fvGross - fvNet;

                const formatter = new Intl.NumberFormat('en-US', {
                    style: 'currency',
                    currency: 'USD',
                    minimumFractionDigits: 0,
                    maximumFractionDigits: 0
                });

                resFees.textContent = formatter.format(totalFees);
                resGross.textContent = formatter.format(fvGross);
                resNet.textContent = formatter.format(fvNet);
            }

            [elInv, elYears, elRet, elEr].forEach(el => {
                el.addEventListener('input', updateCalc);
            });

            updateCalc();
        });
  </script>
