const page = (registry as any)["dividend-investing-guide"];
export const meta = { title: "What is Dividend Investing? A Complete Guide to Income Investing", description: "Want to get paid just for owning a stock? Discover the mechanics behind dividend investing, how it works in practice, and why the strategy goes deeper than...", category: "guide", published: "2026-03-17" };

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Article",
      "headline": page.title,
      "description": page.description,
      "datePublished": page.published,
      "author": {
        "@type": "Organization",
        "name": "Westmount Fundamentals"
      },
      "publisher": {
        "@type": "Organization",
        "name": "Westmount Fundamentals",
        "logo": {
          "@type": "ImageObject",
          "url": "https://westmountfundamentals.com/logo.png"
        }
      }
    },
    {
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "What is dividend investing?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Dividend investing is a strategy where investors buy shares of companies that regularly distribute a portion of their earnings to shareholders as cash payments. The goal is to build a portfolio that generates a steady, passive income stream over time."
          }
        },
        {
          "@type": "Question",
          "name": "How often are dividends paid?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "In the United States, most companies pay dividends quarterly (four times a year). However, some companies pay monthly, semi-annually, or annually depending on their regional location and corporate policies."
          }
        },
        {
          "@type": "Question",
          "name": "Is dividend investing good for beginners?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Yes, dividend investing can be excellent for beginners. It often involves investing in established, stable companies with a history of consistent profitability, which can be less volatile than high-growth tech stocks."
          }
        },
        {
          "@type": "Question",
          "name": "What is a good dividend yield?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "A good dividend yield typically falls between 2% and 6%. Yields significantly higher than 6% or 7% can sometimes indicate that the company is in financial distress and the dividend may be cut, a scenario known as a 'yield trap'."
          }
        },
        {
          "@type": "Question",
          "name": "Do I have to pay taxes on dividends?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Yes, unless you hold your investments in a tax-advantaged account like an IRA or Roth IRA (or RRSP/TFSA in Canada), dividend income is taxable. 'Qualified' dividends are typically taxed at a lower capital gains rate, while 'ordinary' dividends are taxed as regular income."
          }
        }
      ]
    }
  ]
};
