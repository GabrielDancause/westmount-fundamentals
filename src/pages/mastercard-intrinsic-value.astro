---
import SiteLayout from "../layouts/SiteLayout.astro";

// --- METADATA ---
export const meta = {
  title: "Mastercard Incorporated (MA) Intrinsic Value - Gemini's DCF Analysis",
  description: "An independent discounted cash flow (DCF) intrinsic value analysis of Mastercard Incorporated (MA) compiled entirely by Gemini 3.1.",
  category: "study",
  published: "2026-03-18",
};

// --- DATA & ASSUMPTIONS (FY2025 Actuals) ---
// Assumptions generated by Gemini 3.1
// FCF Growth (Y1-Y5): 12%. Mastercard benefits from the global shift from cash to digital payments, consistent pricing power, and high-margin value-added services (cybersecurity, fraud prevention). 12% is sustainable for a high-moat duopoly member.
// Discount Rate (WACC): 8.5%. Very low risk profile. With a 4.18% risk-free rate, low beta (0.836), and massive cash generation, the cost of equity is relatively low. The slight debt load is easily manageable.
// Terminal Growth: 3.5%. Mastercard's toll-bridge model scales with global GDP and inflation natively. 3.5% slightly exceeds standard GDP growth, reflecting its permanent inflation-hedging characteristics.

const baseFCF = 16269; // in Millions
const sharesOut = 885.2; // in Millions
const currentPrice = 491.37;
const netCash = 10898 - 19833; // Cash & ST investments - Total Debt (in Millions), resulting in Net Debt

const fcfGrowthRate = 0.12;
const discountRate = 0.085;
const terminalGrowthRate = 0.035;

// --- YEAR 1 TO 5 PROJECTIONS ---
const projections = [];
let prevFCF = baseFCF;

for (let i = 1; i <= 5; i++) {
  const projectedFCF = prevFCF * (1 + fcfGrowthRate);
  const discountFactor = Math.pow(1 + discountRate, i);
  const pvOfFCF = projectedFCF / discountFactor;

  projections.push({
    year: `Year ${i}`,
    fcf: projectedFCF,
    pv: pvOfFCF
  });

  prevFCF = projectedFCF;
}

const sumPvFcf = projections.reduce((sum, p) => sum + p.pv, 0);

// --- TERMINAL VALUE ---
const year5FCF = projections[4].fcf;
const terminalValue = (year5FCF * (1 + terminalGrowthRate)) / (discountRate - terminalGrowthRate);
const pvTerminalValue = terminalValue / Math.pow(1 + discountRate, 5);

// --- INTRINSIC VALUE CALCULATION ---
const enterpriseValue = sumPvFcf + pvTerminalValue;
const totalEquityValue = enterpriseValue + netCash;
const intrinsicValuePerShare = totalEquityValue / sharesOut;

// Value vs Current Price
const marginOfSafety = ((intrinsicValuePerShare - currentPrice) / currentPrice) * 100;
const isUndervalued = intrinsicValuePerShare > currentPrice;

// --- SENSITIVITY MATRIX ---
const sensitivityDiscountRates = [0.075, 0.080, 0.085, 0.090, 0.095];
const sensitivityGrowthRates = [0.025, 0.030, 0.035, 0.040, 0.045];

const sensitivityMatrix = sensitivityGrowthRates.map(g => {
  return {
    growthRate: g,
    values: sensitivityDiscountRates.map(d => {
      // Re-calculate TV and PV with new rates
      const currentTerminalValue = (year5FCF * (1 + g)) / (d - g);
      const currentPvTerminalValue = currentTerminalValue / Math.pow(1 + d, 5);

      // Re-calculate PV of FCFs with new discount rate
      let currentSumPvFcf = 0;
      let tempFcf = baseFCF;
      for (let i = 1; i <= 5; i++) {
        tempFcf = tempFcf * (1 + fcfGrowthRate);
        currentSumPvFcf += tempFcf / Math.pow(1 + d, i);
      }

      const currentEV = currentSumPvFcf + currentPvTerminalValue;
      const currentEquity = currentEV + netCash;
      const currentIV = currentEquity / sharesOut;

      return currentIV;
    })
  };
});

// Formatting helpers
const formatMoney = (val) => new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD', minimumFractionDigits: 2, maximumFractionDigits: 2 }).format(val);
const formatMillions = (val) => '$' + new Intl.NumberFormat('en-US', { maximumFractionDigits: 0 }).format(val) + 'M';
const formatPercent = (val) => (val * 100).toFixed(1) + '%';

// --- SCHEMA ---
const schema = [
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": meta.title,
    "description": meta.description,
    "author": {
      "@type": "Organization",
      "name": "Gemini 3.1"
    },
    "publisher": {
      "@type": "Organization",
      "name": "Westmount Fundamentals",
      "logo": {
        "@type": "ImageObject",
        "url": "https://westmountfundamentals.com/logo.png"
      }
    },
    "mainEntityOfPage": {
      "@type": "WebPage",
      "@id": "https://westmountfundamentals.com/mastercard-intrinsic-value"
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "Why did Gemini pick a 12% growth rate for Mastercard?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Gemini projects continued secular tailwinds from the global transition to digital payments. Additionally, Mastercard's high-margin Value-Added Services and Solutions (cybersecurity, fraud, data analytics) segment is growing faster than its core network business, defending long-term margin expansion."
        }
      },
      {
        "@type": "Question",
        "name": "What discount rate was used for Mastercard's DCF?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "An 8.5% discount rate was selected. Despite a 4.18% 10-year treasury yield, Mastercard's low beta (0.836), extremely predictable cash flows, and global duopoly position warrant a lower cost of equity. Its debt is easily serviceable given its nearly 60% operating margin."
        }
      },
      {
        "@type": "Question",
        "name": "Why is Mastercard's terminal growth rate 3.5%?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "As a global payments network charging basis points on transaction volume, Mastercard inherently benefits from inflation. As the cost of goods rises, network volume rises natively. A 3.5% terminal growth rate slightly outpaces long-term GDP, reflecting this permanent inflation-hedging nature."
        }
      }
    ]
  }
];
---
<SiteLayout site="westmount" title={meta.title} description={meta.description} canonical="https://westmountfundamentals.com/mastercard-intrinsic-value" schema={schema}>
  <div class="page-content">
    <div class="container">

      <div class="gemini-header">
        <div class="gemini-badge">COMPILED BY GEMINI 3.1</div>
        <h1>Mastercard (MA) Intrinsic Value</h1>
        <p class="subtitle">An independent two-stage DCF analysis by a frontier AI model.</p>
      </div>

      <div class="verdict-card">
        <div class="verdict-header">
          <h2>Fair Value Estimate</h2>
        </div>
        <div class="verdict-body">
          <div class="verdict-main">
            <span class="iv-value">{formatMoney(intrinsicValuePerShare)}</span>
            <span class="iv-label">per share</span>
          </div>
          <div class="verdict-stats">
            <div class="stat">
              <span class="stat-label">Current Price</span>
              <span class="stat-value">{formatMoney(currentPrice)}</span>
            </div>
            <div class="stat">
              <span class="stat-label">Margin of Safety</span>
              <span class={`stat-value ${isUndervalued ? 'positive' : 'negative'}`}>
                {isUndervalued ? '+' : ''}{marginOfSafety.toFixed(2)}%
              </span>
            </div>
            <div class="stat">
              <span class="stat-label">Verdict</span>
              <span class={`badge ${isUndervalued ? 'positive' : 'negative'}`}>
                {isUndervalued ? 'UNDERVALUED' : 'OVERVALUED'}
              </span>
            </div>
          </div>
        </div>
        <div class="verdict-footer">
          <p>Based on FY2025 actuals. Data via S&P Global (Mar 18, 2026).</p>
        </div>
      </div>

      <section class="content-section">
        <h2>The AI Thesis: The Ultimate Toll Bridge</h2>
        <p>Mastercard operates one of the most impenetrable moats in global finance. Alongside Visa, it forms a duopoly over global payment routing. Mastercard doesn't take credit risk; it simply charges a toll for data transmission and network access every time a card is swiped.</p>
        <p>This business model is extraordinarily capital-light, generating operating margins nearing 60% and converting almost all net income into Free Cash Flow. Furthermore, its rapidly growing Value-Added Services segment—providing cybersecurity, fraud management, and data analytics to banks and merchants—is defending its pricing power against regulatory headwinds.</p>
      </section>

      <section class="content-section">
        <h2>My Assumptions & Rationale</h2>

        <div class="assumption-grid">
          <div class="assumption-card">
            <div class="card-title">FCF Growth Rate (Y1-Y5)</div>
            <div class="card-value">{formatPercent(fcfGrowthRate)}</div>
            <p><strong>Rationale:</strong> 12% is sustainable and historically grounded. The shift from cash to digital is not over in emerging markets. Meanwhile, cross-border volume growth remains robust. Crucially, the "Value-Added Services" division is expanding faster than the core network, ensuring blended margin expansion and cash flow accretion.</p>
          </div>

          <div class="assumption-card">
            <div class="card-title">Discount Rate (WACC)</div>
            <div class="card-value">{formatPercent(discountRate)}</div>
            <p><strong>Rationale:</strong> An 8.5% discount rate reflects the asset-light nature and massive defensive moat. With the 10-year treasury at 4.18%, the cost of equity is kept low by a beta of 0.836. Mastercard carries debt ($19.8B), but its immense FCF generation makes leverage a strategic capital-return tool, not a balance-sheet risk.</p>
          </div>

          <div class="assumption-card">
            <div class="card-title">Terminal Growth Rate</div>
            <div class="card-value">{formatPercent(terminalGrowthRate)}</div>
            <p><strong>Rationale:</strong> Mastercard is a natural inflation hedge. Because network fees are largely basis points taken on nominal transaction volume, inflation mechanically drives revenue. A 3.5% terminal growth rate accounts for long-term global GDP expansion plus built-in inflation capture.</p>
          </div>
        </div>
      </section>

      <section class="content-section">
        <h2>Discounted Cash Flow (DCF) Projections</h2>
        <p>Starting with the FY2025 base FCF of {formatMillions(baseFCF)}, the table below outlines the 5-year projection discounted back to Present Value (PV) using the {formatPercent(discountRate)} WACC.</p>

        <div class="table-container">
          <table>
            <thead>
              <tr>
                <th>Period</th>
                <th>Projected FCF</th>
                <th>PV Factor ({formatPercent(discountRate)})</th>
                <th>Present Value</th>
              </tr>
            </thead>
            <tbody>
              {projections.map((p, index) => (
                <tr>
                  <td>{p.year}</td>
                  <td>{formatMillions(p.fcf)}</td>
                  <td>{(1 / Math.pow(1 + discountRate, index + 1)).toFixed(4)}</td>
                  <td>{formatMillions(p.pv)}</td>
                </tr>
              ))}
              <tr class="highlight-row">
                <td colspan="3"><strong>Sum of PV of FCFs (Years 1-5)</strong></td>
                <td><strong>{formatMillions(sumPvFcf)}</strong></td>
              </tr>
            </tbody>
          </table>
        </div>
      </section>

      <section class="content-section">
        <h2>Terminal & Final Valuation Math</h2>
        <p>The Terminal Value accounts for all cash flows from Year 6 into perpetuity, calculated using the Gordon Growth Model.</p>

        <div class="math-card">
          <div class="math-row">
            <span>Year 5 FCF</span>
            <span>{formatMillions(year5FCF)}</span>
          </div>
          <div class="math-row">
            <span>Terminal Value (TV) Calculation</span>
            <span>({formatMillions(year5FCF)} * {1 + terminalGrowthRate}) / ({discountRate} - {terminalGrowthRate})</span>
          </div>
          <div class="math-row">
            <span>Terminal Value</span>
            <span>{formatMillions(terminalValue)}</span>
          </div>
          <div class="math-row highlight">
            <span>PV of Terminal Value</span>
            <span>{formatMillions(pvTerminalValue)}</span>
          </div>
        </div>

        <p style="margin-top: 2rem;">Adding it all together with Net Cash (in MA's case, Net Debt):</p>

        <div class="math-card">
          <div class="math-row">
            <span>Sum of PV of FCFs (Years 1-5)</span>
            <span>{formatMillions(sumPvFcf)}</span>
          </div>
          <div class="math-row">
            <span>+ PV of Terminal Value</span>
            <span>{formatMillions(pvTerminalValue)}</span>
          </div>
          <div class="math-row">
            <span><strong>= Enterprise Value</strong></span>
            <span><strong>{formatMillions(enterpriseValue)}</strong></span>
          </div>
          <div class="math-row">
            <span>+ Net Cash (Cash - Debt)</span>
            <span>{formatMillions(netCash)}</span>
          </div>
          <div class="math-row highlight">
            <span><strong>= Total Equity Value</strong></span>
            <span><strong>{formatMillions(totalEquityValue)}</strong></span>
          </div>
          <div class="math-row">
            <span>÷ Shares Outstanding</span>
            <span>{sharesOut.toLocaleString()}M</span>
          </div>
          <div class="math-row result">
            <span><strong>Intrinsic Value Per Share</strong></span>
            <span><strong>{formatMoney(intrinsicValuePerShare)}</strong></span>
          </div>
        </div>
      </section>

      <section class="content-section">
        <h2>Sensitivity Matrix</h2>
        <p>A single intrinsic value relies on rigid assumptions. The sensitivity matrix below demonstrates how the intrinsic value changes when we adjust the Discount Rate (WACC) and the Terminal Growth Rate.</p>

        <div class="table-container sensitivity-table">
          <table>
            <thead>
              <tr>
                <th rowspan="2" class="corner-cell">Terminal<br/>Growth</th>
                <th colspan="5" class="header-cell">Discount Rate (WACC)</th>
              </tr>
              <tr>
                {sensitivityDiscountRates.map(d => <th>{formatPercent(d)}</th>)}
              </tr>
            </thead>
            <tbody>
              {sensitivityMatrix.map(row => (
                <tr>
                  <th class="row-header">{formatPercent(row.growthRate)}</th>
                  {row.values.map(val => (
                    <td class={
                      val > currentPrice * 1.15 ? "cell-undervalued" :
                      val < currentPrice * 0.85 ? "cell-overvalued" :
                      "cell-neutral"
                    }>
                      {formatMoney(val)}
                    </td>
                  ))}
                </tr>
              ))}
            </tbody>
          </table>
          <div class="matrix-legend">
            <span class="legend-item"><span class="color-box cell-undervalued"></span> Undervalued (>15% Margin)</span>
            <span class="legend-item"><span class="color-box cell-neutral"></span> Fair Value</span>
            <span class="legend-item"><span class="color-box cell-overvalued"></span> Overvalued (&lt;-15% Margin)</span>
          </div>
        </div>
      </section>

      <section class="content-section risks-section">
        <h2>Risks & Bear Case</h2>
        <p>While my valuation is highly confident in Mastercard's network moat, a balanced analysis requires identifying the vectors that could disrupt these assumptions:</p>
        <div class="risk-grid">
          <div class="risk-card">
            <h3>1. Regulatory Capping (CCA)</h3>
            <p>The Credit Card Competition Act (CCCA) and ongoing global regulatory pressure aim to force merchants to have a choice in routing credit card transactions over alternative networks, explicitly targeting the Visa/Mastercard duopoly. Any mandate capping interchange fees directly threatens network yields.</p>
          </div>
          <div class="risk-card">
            <h3>2. Closed-Loop Alternatives & Central Bank Digital Currencies (CBDCs)</h3>
            <p>The rise of account-to-account (A2A) payment schemes like FedNow in the US, PIX in Brazil, and potential widespread adoption of retail CBDCs could eventually bypass traditional card rails entirely, acting as a deflationary force on Mastercard's transaction volume.</p>
          </div>
          <div class="risk-card">
            <h3>3. Consumer Credit Cycle Deterioration</h3>
            <p>Although Mastercard bears no credit risk (the issuing banks do), its transaction volume is tied to consumer spending health. A deep, prolonged global recession leading to credit contraction would stall the nominal volume growth assumptions built into the near-term cash flow projections.</p>
          </div>
        </div>
      </section>

      <section class="content-section faq-section">
        <h2>Frequently Asked Questions</h2>

        <div class="faq-item">
          <h3>Why did Gemini pick a 12% growth rate for Mastercard?</h3>
          <p>Gemini projects continued secular tailwinds from the global transition to digital payments. Additionally, Mastercard's high-margin Value-Added Services and Solutions (cybersecurity, fraud, data analytics) segment is growing faster than its core network business, defending long-term margin expansion.</p>
        </div>

        <div class="faq-item">
          <h3>What discount rate was used for Mastercard's DCF?</h3>
          <p>An 8.5% discount rate was selected. Despite a 4.18% 10-year treasury yield, Mastercard's low beta (0.836), extremely predictable cash flows, and global duopoly position warrant a lower cost of equity. Its debt is easily serviceable given its nearly 60% operating margin.</p>
        </div>

        <div class="faq-item">
          <h3>Why is Mastercard's terminal growth rate 3.5%?</h3>
          <p>As a global payments network charging basis points on transaction volume, Mastercard inherently benefits from inflation. As the cost of goods rises, network volume rises natively. A 3.5% terminal growth rate slightly outpaces long-term GDP, reflecting this permanent inflation-hedging nature.</p>
        </div>

        <div class="faq-item">
          <h3>Is it safe to rely on AI for stock valuation?</h3>
          <p>No. This analysis is a demonstration of AI reasoning based on a specific set of inputs and rigid formulas. It is not financial advice. AI models cannot predict regulatory actions (like the Credit Card Competition Act), macroeconomic shifts, or black swan events.</p>
        </div>
      </section>

      <div class="disclaimer-box">
        <p><strong>Disclaimer:</strong> The numbers presented on this page are for educational and entertainment purposes only. They are the result of a deterministic mathematical model fed with assumptions generated by an Artificial Intelligence (Gemini 3.1). This does not constitute investment advice. Always conduct your own due diligence before investing in the stock market.</p>
      </div>

    </div>
  </div>
</SiteLayout>

