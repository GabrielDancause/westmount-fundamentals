  <script is:inline>
const btn = document.getElementById('calc-btn');
        const loader = document.getElementById('loader');
        const errorMsg = document.getElementById('error-msg');
        const matrixContainer = document.getElementById('matrix-container');
        const matrixHead = document.getElementById('matrix-head');
        const matrixBody = document.getElementById('matrix-body');

        function getCellColor(val) {
            if (val === 1) return '#0a1020';
            if (val > 0.8) return 'rgba(74, 143, 231, 0.4)';
            if (val > 0.5) return 'rgba(74, 143, 231, 0.2)';
            if (val > 0.2) return 'rgba(74, 143, 231, 0.1)';
            if (val < -0.8) return 'rgba(255, 82, 82, 0.4)';
            if (val < -0.5) return 'rgba(255, 82, 82, 0.2)';
            if (val < -0.2) return 'rgba(255, 82, 82, 0.1)';
            return 'transparent';
        }

        async function fetchYahooData(ticker) {
            // Using a generic CORS proxy to access Yahoo API from browser
            const proxy = 'https://corsproxy.io/?';
            const url = `https://query1.finance.yahoo.com/v8/finance/chart/${encodeURIComponent(ticker)}?interval=1d&range=1y`;
            const res = await fetch(proxy + encodeURIComponent(url));
            if (!res.ok) throw new Error(`Failed to fetch ${ticker}`);
            const data = await res.json();

            const result = data.chart?.result?.[0];
            if (!result || !result.indicators.quote[0].close) {
                throw new Error(`Invalid data for ${ticker}`);
            }

            const timestamps = result.timestamp;
            const closes = result.indicators.quote[0].close;

            // Clean out nulls
            const cleanData = [];
            for (let i = 0; i < timestamps.length; i++) {
                if (closes[i] != null) {
                    cleanData.push({ t: timestamps[i], c: closes[i] });
                }
            }
            return cleanData;
        }

        function calculateReturns(prices) {
            const returns = [];
            for (let i = 1; i < prices.length; i++) {
                // Log return: ln(P_t / P_{t-1})
                returns.push(Math.log(prices[i] / prices[i-1]));
            }
            return returns;
        }

        function pearsonCorrelation(x, y) {
            const n = Math.min(x.length, y.length);
            if (n === 0) return 0;

            // Align arrays (assuming they cover the same exact period)
            // In a more robust implementation, we would align by timestamp.
            // For this simple 1-year trailing tool, we just take the last N items.
            const xAligned = x.slice(-n);
            const yAligned = y.slice(-n);

            let sumX = 0, sumY = 0, sumXY = 0, sumX2 = 0, sumY2 = 0;

            for (let i = 0; i < n; i++) {
                const xi = xAligned[i];
                const yi = yAligned[i];
                sumX += xi;
                sumY += yi;
                sumXY += xi * yi;
                sumX2 += xi * xi;
                sumY2 += yi * yi;
            }

            const numerator = (n * sumXY) - (sumX * sumY);
            const denom = Math.sqrt((n * sumX2 - sumX * sumX) * (n * sumY2 - sumY * sumY));
            if (denom === 0) return 0;
            return numerator / denom;
        }

        async function calculateMatrix() {
            btn.disabled = true;
            loader.style.display = 'block';
            errorMsg.style.display = 'none';
            matrixContainer.style.display = 'none';
            matrixHead.innerHTML = '';
            matrixBody.innerHTML = '';

            try {
                const inputVal = document.getElementById('tickers').value;
                const tickers = inputVal.split(',')
                    .map(t => t.trim().toUpperCase())
                    .filter(t => t.length > 0);

                if (tickers.length < 2) {
                    throw new Error("Please enter at least 2 tickers.");
                }
                if (tickers.length > 10) {
                    throw new Error("Please enter a maximum of 10 tickers.");
                }

                // Fetch data
                const returnsMap = {};
                for (const ticker of tickers) {
                    const data = await fetchYahooData(ticker);
                    const prices = data.map(d => d.c);
                    returnsMap[ticker] = calculateReturns(prices);
                }

                // Build Matrix
                matrixHead.appendChild(document.createElement('th')); // empty corner
                tickers.forEach(t => {
                    const th = document.createElement('th');
                    th.textContent = t;
                    matrixHead.appendChild(th);
                });

                for (let i = 0; i < tickers.length; i++) {
                    const tr = document.createElement('tr');
                    const tCol = document.createElement('td');
                    tCol.className = 'ticker-col';
                    tCol.textContent = tickers[i];
                    tr.appendChild(tCol);

                    for (let j = 0; j < tickers.length; j++) {
                        const td = document.createElement('td');
                        if (i === j) {
                            td.textContent = '1.00';
                            td.style.background = getCellColor(1);
                        } else {
                            const r = pearsonCorrelation(returnsMap[tickers[i]], returnsMap[tickers[j]]);
                            td.textContent = r.toFixed(2);
                            td.style.background = getCellColor(r);
                            if (Math.abs(r) > 0.8) td.style.color = '#fff';
                        }
                        tr.appendChild(td);
                    }
                    matrixBody.appendChild(tr);
                }

                matrixContainer.style.display = 'block';

            } catch (err) {
                errorMsg.textContent = err.message || "An error occurred fetching data.";
                errorMsg.style.display = 'block';
            } finally {
                btn.disabled = false;
                loader.style.display = 'none';
            }
        }

        btn.addEventListener('click', calculateMatrix);
  </script>

  
