---
import SiteLayout from "../layouts/SiteLayout.astro";

const schema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What does a stock correlation of 1.0 mean?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "A correlation of 1.0 means perfect positive correlation. It indicates that two assets move in the exact same direction, in perfect proportion. This is typically only seen when comparing an asset to itself, or to an ETF that strictly tracks it."
      }
    },
    {
      "@type": "Question",
      "name": "Why is negative correlation important for a portfolio?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Negative correlation (values between 0 and -1) means that when one asset goes up, the other tends to go down. Holding negatively correlated assets can reduce overall portfolio volatility and mitigate losses during market downturns, a core principle of modern portfolio theory."
      }
    },
    {
      "@type": "Question",
      "name": "How frequently does stock correlation change?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Correlation is not static; it changes continuously based on market conditions, economic cycles, and sector-specific news. During a severe market crash or panic, the correlation of almost all equities tends to converge toward 1.0 as assets are sold off simultaneously."
      }
    },
    {
      "@type": "Question",
      "name": "Does a correlation of 0 mean two stocks are unrelated?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "A correlation of 0 (or near zero) indicates that there is no linear relationship between the price movements of the two stocks. While their daily returns don't move together in a predictable pattern, they may still be exposed to different, non-linear macroeconomic risks."
      }
    },
    {
      "@type": "Question",
      "name": "What is the Pearson correlation coefficient?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "The Pearson correlation coefficient is a statistical measure that calculates the linear relationship between two variables. In finance, it measures how closely the daily returns of two assets move together, mapped on a scale from -1.0 to 1.0."
      }
    }
  ]
};

export const meta = {
  title: "Stock Correlation Matrix | Westmount Fundamentals",
  description: "Calculate real-time stock correlations across any mix of tickers. See how assets move together to optimize portfolio diversification and lower risk.",
  category: "tool",
  published: "2026-03-15",
};
