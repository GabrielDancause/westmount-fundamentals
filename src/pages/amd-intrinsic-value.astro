---
import SiteLayout from "../layouts/SiteLayout.astro";

// --- METADATA ---
export const meta = {
  title: "Advanced Micro Devices, Inc. (AMD) Intrinsic Value",
  description: "An independent discounted cash flow (DCF) intrinsic value analysis of Advanced Micro Devices (AMD) compiled entirely by Gemini 2.5 Pro.",
  category: "study",
  published: "2026-03-18",
};

// --- DATA & ASSUMPTIONS (FY2025 Actuals) ---
// FCF Growth (Y1-Y5): 25%. AMD is perfectly positioned to capture the #2 spot in the explosive AI accelerator market. As supply constraints ease and the MI300X/MI400 series ramp, FCF margins will expand significantly faster than revenue.
// Discount Rate (WACC): 10.5%. AMD has higher execution risk than Nvidia and operates in inherently cyclical end-markets (PCs, Gaming), necessitating a higher discount rate than the broader market despite a strong balance sheet.
// Terminal Growth: 3.5%. AI infrastructure becomes foundational, but semiconductor cyclicality persists long-term.

const baseFCF = 6735; // in Millions
const sharesOut = 1630.41; // in Millions
const currentPrice = 199.52;
const netCash = 6705; // Cash & ST investments - Total Debt

const fcfGrowthRate = 0.25;
const discountRate = 0.105;
const terminalGrowthRate = 0.035;

// --- YEAR 1 TO 5 PROJECTIONS ---
const projections = [];
let prevFCF = baseFCF;

for (let i = 1; i <= 5; i++) {
  const projectedFCF = prevFCF * (1 + fcfGrowthRate);
  const discountFactor = Math.pow(1 + discountRate, i);
  const pvOfFCF = projectedFCF / discountFactor;

  projections.push({
    year: `Year ${i}`,
    fcf: projectedFCF,
    pv: pvOfFCF
  });

  prevFCF = projectedFCF;
}

const sumPvFcf = projections.reduce((sum, p) => sum + p.pv, 0);

// --- TERMINAL VALUE ---
const year5FCF = projections[4].fcf;
const terminalValue = (year5FCF * (1 + terminalGrowthRate)) / (discountRate - terminalGrowthRate);
const pvTerminalValue = terminalValue / Math.pow(1 + discountRate, 5);

// --- INTRINSIC VALUE CALCULATION ---
const enterpriseValue = sumPvFcf + pvTerminalValue;
const totalEquityValue = enterpriseValue + netCash;
const intrinsicValuePerShare = totalEquityValue / sharesOut;

// Value vs Current Price
const marginOfSafety = ((intrinsicValuePerShare - currentPrice) / currentPrice) * 100;
const isUndervalued = intrinsicValuePerShare > currentPrice;

// --- SENSITIVITY MATRIX ---
const sensitivityDiscountRates = [0.085, 0.095, 0.105, 0.115, 0.125];
const sensitivityGrowthRates = [0.025, 0.030, 0.035, 0.040, 0.045];

const sensitivityMatrix = sensitivityGrowthRates.map(g => {
  return {
    growthRate: g,
    values: sensitivityDiscountRates.map(d => {
      // Re-calculate TV and PV with new rates
      const currentTerminalValue = (year5FCF * (1 + g)) / (d - g);
      const currentPvTerminalValue = currentTerminalValue / Math.pow(1 + d, 5);

      // Re-calculate PV of FCFs with new discount rate
      let currentSumPvFcf = 0;
      let tempFcf = baseFCF;
      for (let i = 1; i <= 5; i++) {
        tempFcf = tempFcf * (1 + fcfGrowthRate);
        currentSumPvFcf += tempFcf / Math.pow(1 + d, i);
      }

      const currentEV = currentSumPvFcf + currentPvTerminalValue;
      const currentEquity = currentEV + netCash;
      const currentIV = currentEquity / sharesOut;

      return currentIV;
    })
  };
});

// Formatting helpers
const formatMoney = (val) => new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD', minimumFractionDigits: 2, maximumFractionDigits: 2 }).format(val);
const formatMillions = (val) => '$' + new Intl.NumberFormat('en-US', { maximumFractionDigits: 0 }).format(val) + 'M';
const formatPercent = (val) => (val * 100).toFixed(1) + '%';

// --- SCHEMA ---
const schema = [
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": meta.title,
    "description": meta.description,
    "author": {
      "@type": "Organization",
      "name": "Gemini 2.5 Pro"
    },
    "publisher": {
      "@type": "Organization",
      "name": "Westmount Fundamentals",
      "logo": {
        "@type": "ImageObject",
        "url": "https://westmountfundamentals.com/logo.png"
      }
    },
    "mainEntityOfPage": {
      "@type": "WebPage",
      "@id": "https://westmountfundamentals.com/amd-intrinsic-value"
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "Why did Gemini pick a 25% growth rate for AMD?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Gemini projects that AMD's data center revenue will explode as they capture the #2 spot in the AI accelerator market behind Nvidia. This massive revenue growth, combined with margin expansion as initial R&D and supply chain bottlenecks ease, justifies a 25% FCF CAGR over the next 5 years."
        }
      },
      {
        "@type": "Question",
        "name": "What discount rate was used for AMD's DCF?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "A 10.5% discount rate was selected. This reflects the 4.18% risk-free rate and AMD's relatively high beta. It accounts for the inherent cyclicality of the semiconductor industry and the execution risk of competing directly with a dominant incumbent (Nvidia)."
        }
      },
      {
        "@type": "Question",
        "name": "Why is AMD considered overvalued according to the model?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Despite aggressive 25% FCF growth projections, the current market price of $199.52 implies even higher, potentially unsustainable growth expectations into perpetuity. The math simply shows the current price has outpaced the realistic cash flows AMD can generate."
        }
      }
    ]
  }
];
---
<SiteLayout site="westmount" title={meta.title} description={meta.description} canonical="https://westmountfundamentals.com/amd-intrinsic-value" schema={schema}>
  <div class="page-content">
    <div class="container">

      <div class="gemini-header">
        <div class="gemini-badge">COMPILED BY GEMINI 2.5 PRO</div>
        <h1>Advanced Micro Devices (AMD) Intrinsic Value</h1>
        <p class="subtitle">An independent two-stage DCF analysis by a frontier AI model.</p>
        <p class="claude-link">Compare with <a href="/amd-intrinsic-value-claude">Claude Opus 4.6's Analysis</a></p>
      </div>

      <div class="verdict-card">
        <div class="verdict-header">
          <h2>Fair Value Estimate</h2>
        </div>
        <div class="verdict-body">
          <div class="verdict-main">
            <span class="iv-value">{formatMoney(intrinsicValuePerShare)}</span>
            <span class="iv-label">per share</span>
          </div>
          <div class="verdict-stats">
            <div class="stat">
              <span class="stat-label">Current Price</span>
              <span class="stat-value">{formatMoney(currentPrice)}</span>
            </div>
            <div class="stat">
              <span class="stat-label">Margin of Safety</span>
              <span class={`stat-value ${isUndervalued ? 'positive' : 'negative'}`}>
                {isUndervalued ? '+' : ''}{marginOfSafety.toFixed(2)}%
              </span>
            </div>
            <div class="stat">
              <span class="stat-label">Verdict</span>
              <span class={`badge ${isUndervalued ? 'positive' : 'negative'}`}>
                {isUndervalued ? 'UNDERVALUED' : 'OVERVALUED'}
              </span>
            </div>
          </div>
        </div>
        <div class="verdict-footer">
          <p>Based on FY2025 actuals. Data via S&P Global (Mar 17, 2026).</p>
        </div>
      </div>

      <section class="content-section">
        <h2>The AI Thesis: The Essential Second Source</h2>
        <p>Advanced Micro Devices is operating at the epicenter of the most significant compute cycle in history. While Nvidia dominates the high-end training market, hyperscalers (Microsoft, Meta, Google, AWS) desperately need a viable second source to maintain pricing leverage and supply chain security. AMD's MI300 and subsequent MI400 accelerator families are perfectly positioned to fulfill this role.</p>
        <p>The market has aggressively priced in AMD's potential to capture 15-20% of the AI accelerator market. My valuation model heavily weights the massive revenue growth this implies, but strictly anchors it to the actual cash flow generation required to justify the current stock price. I see a company executing flawlessly, but a stock priced for perfection.</p>
      </section>

      <section class="content-section">
        <h2>My Assumptions & Rationale</h2>

        <div class="assumption-grid">
          <div class="assumption-card">
            <div class="card-title">FCF Growth Rate (Y1-Y5)</div>
            <div class="card-value">{formatPercent(fcfGrowthRate)}</div>
            <p><strong>Rationale:</strong> 25% represents hypergrowth. AMD's data center segment is exploding. As the supply chain scales and initial R&D investments yield, FCF margins will expand rapidly. This assumes AMD successfully captures the #2 spot and holds a structural 15-20% share in the accelerator market.</p>
          </div>

          <div class="assumption-card">
            <div class="card-title">Discount Rate (WACC)</div>
            <div class="card-value">{formatPercent(discountRate)}</div>
            <p><strong>Rationale:</strong> A 10.5% discount rate reflects significant execution risk. Despite a strong balance sheet ($6.7B net cash), AMD operates in inherently cyclical markets (Client CPUs, Gaming) and competes directly with a dominant incumbent (Nvidia). This risk demands a higher return threshold than the broader market.</p>
          </div>

          <div class="assumption-card">
            <div class="card-title">Terminal Growth Rate</div>
            <div class="card-value">{formatPercent(terminalGrowthRate)}</div>
            <p><strong>Rationale:</strong> 3.5% aligns slightly above historical GDP. While AI is a permanent paradigm shift, semiconductor demand remains fundamentally cyclical over long horizons. Growth will eventually revert to global economic expansion rates.</p>
          </div>
        </div>
      </section>

      <section class="content-section">
        <h2>Discounted Cash Flow (DCF) Projections</h2>
        <p>Starting with the FY2025 base FCF of {formatMillions(baseFCF)}, the table below outlines the 5-year projection discounted back to Present Value (PV) using the {formatPercent(discountRate)} WACC.</p>

        <div class="table-container">
          <table>
            <thead>
              <tr>
                <th>Period</th>
                <th>Projected FCF</th>
                <th>PV Factor ({formatPercent(discountRate)})</th>
                <th>Present Value</th>
              </tr>
            </thead>
            <tbody>
              {projections.map((p, index) => (
                <tr>
                  <td>{p.year}</td>
                  <td>{formatMillions(p.fcf)}</td>
                  <td>{(1 / Math.pow(1 + discountRate, index + 1)).toFixed(4)}</td>
                  <td>{formatMillions(p.pv)}</td>
                </tr>
              ))}
              <tr class="highlight-row">
                <td colspan="3"><strong>Sum of PV of FCFs (Years 1-5)</strong></td>
                <td><strong>{formatMillions(sumPvFcf)}</strong></td>
              </tr>
            </tbody>
          </table>
        </div>
      </section>

      <section class="content-section">
        <h2>Terminal & Final Valuation Math</h2>
        <p>The Terminal Value accounts for all cash flows from Year 6 into perpetuity, calculated using the Gordon Growth Model.</p>

        <div class="math-card">
          <div class="math-row">
            <span>Year 5 FCF</span>
            <span>{formatMillions(year5FCF)}</span>
          </div>
          <div class="math-row">
            <span>Terminal Value (TV) Calculation</span>
            <span>({formatMillions(year5FCF)} * {1 + terminalGrowthRate}) / ({discountRate} - {terminalGrowthRate})</span>
          </div>
          <div class="math-row">
            <span>Terminal Value</span>
            <span>{formatMillions(terminalValue)}</span>
          </div>
          <div class="math-row highlight">
            <span>PV of Terminal Value</span>
            <span>{formatMillions(pvTerminalValue)}</span>
          </div>
        </div>

        <p style="margin-top: 2rem;">Adding it all together with Net Cash:</p>

        <div class="math-card">
          <div class="math-row">
            <span>Sum of PV of FCFs (Years 1-5)</span>
            <span>{formatMillions(sumPvFcf)}</span>
          </div>
          <div class="math-row">
            <span>+ PV of Terminal Value</span>
            <span>{formatMillions(pvTerminalValue)}</span>
          </div>
          <div class="math-row">
            <span><strong>= Enterprise Value</strong></span>
            <span><strong>{formatMillions(enterpriseValue)}</strong></span>
          </div>
          <div class="math-row">
            <span>+ Net Cash (Cash - Debt)</span>
            <span>{formatMillions(netCash)}</span>
          </div>
          <div class="math-row highlight">
            <span><strong>= Total Equity Value</strong></span>
            <span><strong>{formatMillions(totalEquityValue)}</strong></span>
          </div>
          <div class="math-row">
            <span>÷ Shares Outstanding</span>
            <span>{sharesOut.toLocaleString()}M</span>
          </div>
          <div class="math-row result">
            <span><strong>Intrinsic Value Per Share</strong></span>
            <span><strong>{formatMoney(intrinsicValuePerShare)}</strong></span>
          </div>
        </div>
      </section>

      <section class="content-section">
        <h2>Sensitivity Matrix</h2>
        <p>A single intrinsic value relies on rigid assumptions. The sensitivity matrix below demonstrates how the intrinsic value changes when we adjust the Discount Rate (WACC) and the Terminal Growth Rate.</p>

        <div class="table-container sensitivity-table">
          <table>
            <thead>
              <tr>
                <th rowspan="2" class="corner-cell">Terminal<br/>Growth</th>
                <th colspan="5" class="header-cell">Discount Rate (WACC)</th>
              </tr>
              <tr>
                {sensitivityDiscountRates.map(d => <th>{formatPercent(d)}</th>)}
              </tr>
            </thead>
            <tbody>
              {sensitivityMatrix.map(row => (
                <tr>
                  <th class="row-header">{formatPercent(row.growthRate)}</th>
                  {row.values.map(val => (
                    <td class={
                      val > currentPrice * 1.15 ? "cell-undervalued" :
                      val < currentPrice * 0.85 ? "cell-overvalued" :
                      "cell-neutral"
                    }>
                      {formatMoney(val)}
                    </td>
                  ))}
                </tr>
              ))}
            </tbody>
          </table>
          <div class="matrix-legend">
            <span class="legend-item"><span class="color-box cell-undervalued"></span> Undervalued (>15% Margin)</span>
            <span class="legend-item"><span class="color-box cell-neutral"></span> Fair Value</span>
            <span class="legend-item"><span class="color-box cell-overvalued"></span> Overvalued (&lt;-15% Margin)</span>
          </div>
        </div>
      </section>

      <section class="content-section risks-section">
        <h2>Risks & Bear Case</h2>
        <p>While my valuation is grounded in massive growth, a balanced analysis requires identifying the key vectors that could disrupt these assumptions:</p>
        <div class="risk-grid">
          <div class="risk-card">
            <h3>1. The Nvidia Moat (CUDA)</h3>
            <p>Nvidia's software ecosystem (CUDA) is deeply entrenched among developers. While AMD's ROCm is improving, a failure to attract developers at scale could permanently limit AMD's market share, stalling the projected cash flow growth.</p>
          </div>
          <div class="risk-card">
            <h3>2. Custom Silicon Competition</h3>
            <p>Hyperscalers (Google TPU, AWS Inferentia) are aggressively designing their own custom chips. If these internal solutions capture the majority of inference workloads, AMD's total addressable market shrinks dramatically.</p>
          </div>
          <div class="risk-card">
            <h3>3. PC Market Cyclicality</h3>
            <p>While data centers dominate the narrative, client CPUs still drive significant cash flow. A prolonged macroeconomic downturn impacting PC refreshes would directly compress the near-term cash generation needed to fund aggressive AI R&D.</p>
          </div>
        </div>
      </section>

      <section class="content-section faq-section">
        <h2>Frequently Asked Questions</h2>

        <div class="faq-item">
          <h3>Why did Gemini pick a 25% growth rate for AMD?</h3>
          <p>Gemini projects that AMD's data center revenue will explode as they capture the #2 spot in the AI accelerator market behind Nvidia. This massive revenue growth, combined with margin expansion as initial R&D and supply chain bottlenecks ease, justifies a 25% FCF CAGR over the next 5 years.</p>
        </div>

        <div class="faq-item">
          <h3>What discount rate was used for AMD's DCF?</h3>
          <p>A 10.5% discount rate was selected. This reflects the 4.18% risk-free rate and AMD's relatively high beta. It accounts for the inherent cyclicality of the semiconductor industry and the execution risk of competing directly with a dominant incumbent (Nvidia).</p>
        </div>

        <div class="faq-item">
          <h3>Why is AMD considered overvalued according to the model?</h3>
          <p>Despite aggressive 25% FCF growth projections, the current market price of $199.52 implies even higher, potentially unsustainable growth expectations into perpetuity. The math simply shows the current price has outpaced the realistic cash flows AMD can generate.</p>
        </div>
      </section>

      <div class="disclaimer-box">
        <p><strong>Disclaimer:</strong> The numbers presented on this page are for educational and entertainment purposes only. They are the result of a deterministic mathematical model fed with assumptions generated by an Artificial Intelligence (Gemini 2.5 Pro). This does not constitute investment advice. Always conduct your own due diligence before investing in the stock market.</p>
      </div>

    </div>
  </div>
