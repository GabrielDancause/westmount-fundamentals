<SiteLayout site="westmount" title="Complete RRSP Season Checklist" description="Contribution room, deadline, strategies, tax optimization." canonical="https://westmountfundamentals.com/rrsp-season-checklist" schema={schema}>
  <div class="page-content">
    <div class="hero"><h1>Complete RRSP Season Checklist</h1><p>Contribution room, deadline, strategies, tax optimization.</p></div>
    <div class="card">
      <h2>Related Guides</h2>
      <ul>
        <li><a href="/rrsp-contribution-calculator">Rrsp Contribution Calculator</a></li>
        <li><a href="/rrsp-vs-tfsa-decision">Rrsp Vs Tfsa Decision</a></li>
        <li><a href="/spousal-rrsp-guide">Spousal Rrsp Guide</a></li>
        <li><a href="/rrsp-home-buyers-plan">Rrsp Home Buyers Plan</a></li>
