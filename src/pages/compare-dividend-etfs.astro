const schema = [
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "How do covered call ETFs like JEPI and JEPQ generate such high yields?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Covered call ETFs generate high yields by combining a portfolio of equities with an options strategy. They sell (write) call options on an index or their holdings, collecting premiums which are distributed as income, often trading upside capital appreciation for immediate yield."
        }
      },
      {
        "@type": "Question",
        "name": "What is the difference between dividend growth and high dividend yield strategies?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Dividend growth strategies (like SCHD or DGRO) focus on companies with a history of consistently increasing their payouts, emphasizing long-term total return and dividend safety. High dividend yield strategies (like VYM or HDV) target companies currently paying the highest absolute dividends, prioritizing immediate income over future growth."
        }
      },
      {
        "@type": "Question",
        "name": "Why is the expense ratio important when comparing ETFs?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "The expense ratio represents the annual fee charged by the fund managers, expressed as a percentage of your investment. It directly reduces your overall return and effective dividend yield, making low-cost funds crucial for long-term compound growth."
        }
      },
      {
        "@type": "Question",
        "name": "Does the number of holdings in an ETF matter?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes, the number of holdings indicates the fund's level of diversification. A broader fund with hundreds of stocks minimizes single-company risk, while a concentrated fund with fewer holdings relies more heavily on the performance of its top positions."
        }
      },
      {
        "@type": "Question",
        "name": "Can I hold multiple dividend ETFs in the same portfolio?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Absolutely. Many investors hold multiple dividend ETFs to blend strategies, such as pairing a core dividend growth fund for capital appreciation with a covered call ETF for enhanced monthly income, achieving a balanced mix of yield and growth."
        }
      }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": "Compare Dividend ETFs: SCHD, VYM, JEPI & More",
