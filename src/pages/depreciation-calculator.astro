---
import SiteLayout from '../layouts/SiteLayout.astro';

export const meta = {
  title: 'Depreciation Calculator — Straight-Line, Declining Balance & MACRS | Westmount Fundamentals',
  description: 'Free depreciation calculator with straight-line, double declining balance, and MACRS methods. Generate depreciation schedules, charts, and compare methods side-by-side.',
  category: 'study',
  published: '2026-03-20',
};

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": meta.title,
    "description": meta.description,
    "datePublished": meta.published,
    "publisher": {
      "@type": "Organization",
      "name": "Westmount Fundamentals",
      "url": "https://westmountfundamentals.com"
    },
    "mainEntityOfPage": {
      "@type": "WebPage",
      "@id": "https://westmountfundamentals.com/depreciation-calculator/"
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "What is depreciation in accounting?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Depreciation is the systematic allocation of an asset's cost over its useful life. It reflects the decline in value of tangible assets like equipment, vehicles, and buildings due to wear, age, or obsolescence. Depreciation is recorded as an expense on the income statement and reduces the book value of assets on the balance sheet."
        }
      },
      {
        "@type": "Question",
        "name": "What is the straight-line depreciation formula?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "The straight-line depreciation formula is: Annual Depreciation = (Asset Cost − Salvage Value) ÷ Useful Life in Years. This method spreads the depreciable amount evenly across each year of the asset's useful life, making it the simplest and most commonly used depreciation method."
        }
      },
      {
        "@type": "Question",
        "name": "How does MACRS depreciation work?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "MACRS (Modified Accelerated Cost Recovery System) is the tax depreciation method required by the IRS for most business assets. It assigns assets to property classes (3, 5, 7, 10, 15, or 20 years) and uses predetermined percentages to calculate depreciation each year. MACRS front-loads depreciation, providing larger deductions in earlier years."
        }
      },
      {
        "@type": "Question",
        "name": "What is the difference between straight-line and declining balance depreciation?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Straight-line depreciation allocates an equal amount each year, while double declining balance (DDB) applies a fixed rate (2 ÷ useful life) to the remaining book value each year. DDB results in higher depreciation expense in early years and lower amounts later. Straight-line is simpler for financial reporting; DDB better matches assets that lose value quickly."
        }
      },
      {
        "@type": "Question",
        "name": "What is accumulated depreciation?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Accumulated depreciation is the total depreciation expense recorded against an asset from the time it was placed in service. It is a contra-asset account on the balance sheet that reduces the asset's gross cost to arrive at net book value. For example, if equipment cost $100,000 and has $40,000 in accumulated depreciation, its book value is $60,000."
        }
      }
    ]
  }
];
---

