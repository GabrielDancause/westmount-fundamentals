---
import SiteLayout from "../layouts/SiteLayout.astro";

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "YoY Growth Calculator",
    "operatingSystem": "Web",
    "applicationCategory": "BusinessApplication",
    "offers": {
      "@type": "Offer",
      "price": "0",
      "priceCurrency": "USD"
    },
    "description": "Calculate your Year-over-Year (YoY) growth rate quickly. Discover how much your revenue, users, or stock portfolio has grown from the previous period.",
    "publisher": {
      "@type": "Organization",
      "name": "Westmount Fundamentals"
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "How is Year-over-Year (YoY) growth calculated?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "YoY growth is calculated using the formula: ((Current Period Value - Previous Period Value) / Previous Period Value) × 100. This provides the percentage increase or decrease over the same time frame in the prior year."
        }
      },
      {
        "@type": "Question",
        "name": "Why is YoY growth important for businesses?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Year-over-Year growth smooths out seasonal volatility. For example, retail businesses often see spikes during holidays. Comparing a quarter to the same quarter last year gives a more accurate picture of true growth."
        }
      },
      {
        "@type": "Question",
        "name": "Can YoY growth be negative?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes. If the current period's value is lower than the previous period's value, the resulting percentage will be negative, indicating a decline or contraction in the metric being measured."
        }
      },
      {
        "@type": "Question",
        "name": "What is the difference between YoY and MoM growth?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "YoY compares a period to the exact same period one year ago (e.g., Q1 2024 vs Q1 2023). Month-over-Month (MoM) compares a month to the immediately preceding month (e.g., February vs January), which can be heavily skewed by seasonality."
        }
      },
      {
        "@type": "Question",
        "name": "What metrics are commonly evaluated using YoY growth?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Investors and businesses frequently use YoY calculations for revenue, net income, user acquisition, website traffic, earnings per share (EPS), and stock price appreciation."
        }
      }
    ]
  }
];

export const meta = {
  title: "YoY Growth Calculator | Westmount Fundamentals",
  description: "Calculate your Year-over-Year (YoY) growth rate quickly. Discover how much your revenue, users, or stock portfolio has grown from the previous period.",
  category: "tool",
  published: "2024-03-15",
};
---

<SiteLayout
  site="westmount"
  title={meta.title}
  description={meta.description}
  canonical="https://westmountfundamentals.com/yoy-growth-calculator"
  schema={schema}
>
  <style is:inline>
    .page-content {
      max-width: 1000px;
      margin: 0 auto;
      padding: 0 24px 40px;
    }

    .hero {
      padding: 40px 0;
      text-align: center;
      border-bottom: 1px solid var(--border-color);
      margin-bottom: 40px;
    }

    .hero h1 {
      font-size: 2.5rem;
      font-weight: 900;
      color: var(--text-primary);
      margin-bottom: 16px;
      letter-spacing: -1px;
    }

    .hero p {
      color: var(--text-secondary);
      max-width: 600px;
      margin: 0 auto;
      font-size: 1.05rem;
    }

    .card {
      background: var(--card-bg);
      border: 1px solid var(--border-color);
      border-radius: 16px;
      padding: 24px;
    }

    .calc-grid {
      display: grid;
      grid-template-columns: 1fr;
