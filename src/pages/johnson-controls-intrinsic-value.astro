      border-color: rgba(239, 68, 68, 0.3);
      font-size: 0.85rem;
      color: #94a3b8;
    }

    .disclaimer h4 {
      color: #f87171;
      margin-top: 0;
      margin-bottom: 0.5rem;
    }

    .methodology-box {
      background: rgba(74, 143, 231, 0.05);
