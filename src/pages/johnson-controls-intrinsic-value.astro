---
import SiteLayout from "../layouts/SiteLayout.astro";
import * as cheerio from 'cheerio';

export const meta = {
  title: "Johnson Controls (JCI) Intrinsic Value - DCF Analysis",
  description: "A comprehensive two-stage discounted cash flow (DCF) valuation for Johnson Controls International plc (JCI) including assumptions, sensitivity analysis, and risks. Compiled by Gemini 3.1.",
  canonical: "https://westmountfundamentals.com/johnson-controls-intrinsic-value"
};

const schema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": meta.title,
  "description": meta.description,
  "author": {
    "@type": "Organization",
    "name": "Westmount Research"
  },
  "publisher": {
    "@type": "Organization",
    "name": "Westmount Research",
    "logo": {
      "@type": "ImageObject",
      "url": "https://westmountfundamentals.com/logo.png"
    }
  },
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": meta.canonical
  },
  "datePublished": "2026-03-24T00:00:00Z",
  "dateModified": "2026-03-24T00:00:00Z"
};

// --- DATA FETCHING ---
async function fetchHtml(url: string) {
  try {
    const response = await fetch(url, {
      headers: {
        'User-Agent': 'Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36'
      }
    });
    if (!response.ok) return null;
    return await response.text();
  } catch (e) {
    return null;
  }
}

const incomeHtml = await fetchHtml('https://stockanalysis.com/stocks/jci/financials/');
const cashHtml = await fetchHtml('https://stockanalysis.com/stocks/jci/financials/cash-flow-statement/');
const balanceHtml = await fetchHtml('https://stockanalysis.com/stocks/jci/financials/balance-sheet/');

function getRowData(html: string | null, rowName: string): (number | null)[] {
  if (!html) return [];
  const $ = cheerio.load(html);
  let data: (number | null)[] = [];
  $('table tbody tr').each((i, el) => {
    const firstTd = $(el).find('td').first().text().trim();
    if (firstTd === rowName || firstTd.includes(rowName)) {
      $(el).find('td').each((j, td) => {
        if (j > 0) {
          const valStr = $(td).text().trim().replace(/,/g, '');
          if (valStr === '-' || valStr === '') {
            data.push(null);
          } else {
            const valNum = parseFloat(valStr);
            data.push(isNaN(valNum) ? null : valNum);
          }
        }
      });
    }
  });
  return data;
}

// Extract historical data
const revData = getRowData(incomeHtml, "Revenue");
const sharesData = getRowData(incomeHtml, "Shares Outstanding (Diluted)");
const fcfData = getRowData(cashHtml, "Free Cash Flow");
const ocfData = getRowData(cashHtml, "Operating Cash Flow");
const cashData = getRowData(balanceHtml, "Cash & Equivalents");
const debtData = getRowData(balanceHtml, "Total Debt");

// Safely get latest values
const latestRev = revData.length > 0 ? revData[0] : null;
const latestShares = sharesData.length > 0 ? sharesData[0] : null;
const latestFcf = fcfData.length > 0 ? fcfData[0] : null;
const latestOcf = ocfData.length > 0 ? ocfData[0] : null;
const latestCash = cashData.length > 0 ? cashData[0] : null;
const latestDebt = debtData.length > 0 ? debtData[0] : null;

let price: number | null = null;
if (incomeHtml) {
  const priceMatch = incomeHtml.match(/<div class="[^"]*text-4xl[^"]*"[^>]*>([\d\.,]+)<\/div>/);
  if (priceMatch && priceMatch[1]) {
    price = parseFloat(priceMatch[1].replace(/,/g, ''));
  }
}

// --- CONSTANTS ---
const treasury10Y = 0.0418; // 4.18%
const erp = 0.055; // 5.5% Equity Risk Premium
const beta = 1.15; // JCI roughly matches cyclical industrials
const wacc = treasury10Y + beta * erp; // Discount Rate ~10.5%
const discountRate = parseFloat(wacc.toFixed(3));

// --- DCF ASSUMPTIONS ---
// JCI is undergoing restructuring (selling HVAC residential, ADT).
// FCF has been volatile. We will use the latest FCF as base, but if it's very low,
// average of last 3 years might be better, or just use the extracted latest FCF.
// Extracted FCF for JCI often reflects large capex or restructuring.
const baseFcf = latestFcf !== null ? latestFcf : 1365; // fallback strictly if null
const currentShares = latestShares !== null ? latestShares : 641;
const currentCash = latestCash !== null ? latestCash : 552;
const currentDebt = latestDebt !== null ? latestDebt : 9705;
const currentPrice = price !== null ? price : null;

const growthRatePhase1 = 0.08; // 8% growth for years 1-5 (building efficiency trends, Data centers cooling)
const growthRatePhase2 = 0.04; // 4% growth for years 6-10
const terminalGrowthRate = 0.025; // 2.5% terminal growth rate

// --- DCF PROJECTIONS ---
let projectedFcf = [];
let pvFcf = [];
let fcfTotalPv = 0;
let previousFcf = baseFcf;

for (let i = 1; i <= 10; i++) {
  let g = i <= 5 ? growthRatePhase1 : growthRatePhase2;
  let currentVal = previousFcf * (1 + g);
  projectedFcf.push({ year: i, value: currentVal, growth: g });

  let pv = currentVal / Math.pow(1 + discountRate, i);
  pvFcf.push(pv);
  fcfTotalPv += pv;

  previousFcf = currentVal;
}

// Terminal Value
const finalYearFcf = projectedFcf[9].value;
const terminalValue = (finalYearFcf * (1 + terminalGrowthRate)) / (discountRate - terminalGrowthRate);
const pvTerminalValue = terminalValue / Math.pow(1 + discountRate, 10);

// Enterprise Value to Equity Value
const enterpriseValue = fcfTotalPv + pvTerminalValue;
const equityValue = enterpriseValue + currentCash - currentDebt;
const intrinsicValuePerShare = equityValue / currentShares;

// Verdict
let verdictStr = "N/A";
let marginOfSafety = 0;
let isUndervalued = false;
if (currentPrice !== null) {
  marginOfSafety = (intrinsicValuePerShare - currentPrice) / intrinsicValuePerShare;
  if (currentPrice < intrinsicValuePerShare * 0.8) {
    verdictStr = "Significantly Undervalued";
    isUndervalued = true;
  } else if (currentPrice < intrinsicValuePerShare) {
    verdictStr = "Undervalued";
    isUndervalued = true;
  } else if (currentPrice < intrinsicValuePerShare * 1.1) {
    verdictStr = "Fairly Valued";
  } else {
    verdictStr = "Overvalued";
  }
}

// --- SENSITIVITY TABLE ---
const sensitivityDiscountRates = [discountRate - 0.02, discountRate - 0.01, discountRate, discountRate + 0.01, discountRate + 0.02];
const sensitivityGrowthRates = [growthRatePhase1 - 0.04, growthRatePhase1 - 0.02, growthRatePhase1, growthRatePhase1 + 0.02, growthRatePhase1 + 0.04];

let sensitivityGrid = [];
for (let i = 0; i < sensitivityDiscountRates.length; i++) {
  let dr = sensitivityDiscountRates[i];
  let row = { dr: dr, values: [] as number[] };

  for (let j = 0; j < sensitivityGrowthRates.length; j++) {
    let gr1 = sensitivityGrowthRates[j];
    let gr2 = gr1 / 2; // phase 2 is half of phase 1 growth

    let tempTotalPv = 0;
    let tempPrevFcf = baseFcf;
    for (let k = 1; k <= 10; k++) {
      let g = k <= 5 ? gr1 : gr2;
      let tempFcf = tempPrevFcf * (1 + g);
      tempTotalPv += tempFcf / Math.pow(1 + dr, k);
      tempPrevFcf = tempFcf;
    }

    let tempTv = (tempPrevFcf * (1 + terminalGrowthRate)) / (dr - terminalGrowthRate);
    let tempPvTv = tempTv / Math.pow(1 + dr, 10);

    let tempEv = tempTotalPv + tempPvTv;
    let tempEq = tempEv + currentCash - currentDebt;
    let tempIv = tempEq / currentShares;

    row.values.push(parseFloat(tempIv.toFixed(2)));
  }
  sensitivityGrid.push(row);
}
---

<SiteLayout site="westmount" title={meta.title} description={meta.description} canonical={meta.canonical} schema={schema}>
  <style is:global>
    @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;700&display=swap');

    /* Theme constants embedded in values */
    body {
      background-color: #060a12;
      color: #e2e8f0;
      font-family: 'Inter', sans-serif;
      margin: 0;
      padding: 0;
      line-height: 1.6;
    }

    .dcf-wrapper {
      max-width: 900px;
      margin: 0 auto;
      padding: 40px 20px;
    }

    h1 {
      font-size: 2.5rem;
      font-weight: 700;
      margin-bottom: 0.5rem;
      color: #ffffff;
      line-height: 1.2;
    }

    .subtitle {
      font-size: 1.125rem;
      color: #94a3b8;
      margin-bottom: 2rem;
      display: flex;
      align-items: center;
      gap: 12px;
      flex-wrap: wrap;
    }

    .badge {
      background: rgba(74, 143, 231, 0.15);
      color: #4a8fe7;
      padding: 4px 10px;
      border-radius: 4px;
      font-size: 0.85rem;
      font-weight: 600;
      letter-spacing: 0.5px;
      text-transform: uppercase;
    }

    h2 {
      font-size: 1.75rem;
      color: #ffffff;
      margin-top: 3rem;
      margin-bottom: 1.5rem;
      border-bottom: 1px solid #1e293b;
      padding-bottom: 0.5rem;
    }

    h3 {
      font-size: 1.25rem;
      color: #cbd5e1;
      margin-top: 2rem;
      margin-bottom: 1rem;
    }

    p {
      margin-bottom: 1.25rem;
      color: #cbd5e1;
    }

    /* Verdict Card */
    .verdict-card {
      background: #0f172a;
      border: 1px solid #1e293b;
      border-radius: 12px;
      padding: 2rem;
      display: flex;
      flex-direction: column;
      align-items: center;
      text-align: center;
      margin: 2rem 0 3rem;
      box-shadow: 0 10px 30px rgba(0,0,0,0.5);
    }

    .verdict-header {
      font-size: 1rem;
      color: #94a3b8;
      text-transform: uppercase;
      letter-spacing: 1px;
      margin-bottom: 0.5rem;
    }

    .iv-number {
      font-family: 'JetBrains Mono', monospace;
      font-size: 4.5rem;
      font-weight: 700;
      color: #4a8fe7;
      line-height: 1;
      margin-bottom: 0.5rem;
      text-shadow: 0 0 20px rgba(74, 143, 231, 0.3);
    }

    .current-price {
      font-size: 1.25rem;
      color: #94a3b8;
      margin-bottom: 1.5rem;
      font-family: 'JetBrains Mono', monospace;
    }

    .verdict-pill {
      display: inline-block;
      padding: 8px 16px;
      border-radius: 20px;
      font-weight: 600;
      font-size: 1rem;
    }

    .verdict-pill.undervalued {
      background: rgba(34, 197, 94, 0.2);
      color: #4ade80;
      border: 1px solid rgba(34, 197, 94, 0.3);
    }

    .verdict-pill.overvalued {
      background: rgba(239, 68, 68, 0.2);
      color: #f87171;
      border: 1px solid rgba(239, 68, 68, 0.3);
