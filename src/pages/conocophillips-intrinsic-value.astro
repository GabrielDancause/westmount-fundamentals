---
import SiteLayout from "../layouts/SiteLayout.astro";

const schema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": "ConocoPhillips (COP) Intrinsic Value: A Two-Stage DCF Analysis",
  "description": "A step-by-step two-stage discounted cash flow valuation of ConocoPhillips using actual financials.",
  "datePublished": new Date().toISOString().split('T')[0],
  "dateModified": new Date().toISOString().split('T')[0],
  "author": {
    "@type": "Organization",
    "name": "Westmount Research",
    "url": "https://westmountfundamentals.com"
  },
  "publisher": {
    "@type": "Organization",
    "name": "Westmount Research",
    "url": "https://westmountfundamentals.com"
  },
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": "https://westmountfundamentals.com/conocophillips-intrinsic-value"
  }
};

export const meta = {
  title: "ConocoPhillips (COP) Intrinsic Value: A Two-Stage DCF Analysis",
  description: "A step-by-step two-stage discounted cash flow valuation of ConocoPhillips. One number. Every assumption disclosed.",
  category: "study",
  published: new Date().toISOString().split('T')[0],
};

/* ═══════════════════════════════════════════════════════════════
   DATA FETCHING
   ═══════════════════════════════════════════════════════════════ */

const getHtml = async (url) => {
  try {
    const res = await fetch(url, {
      headers: {
        'User-Agent': 'Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36'
      }
    });
    if (!res.ok) return null;
    return await res.text();
  } catch (err) {
    console.error("Fetch error for", url, err);
    return null;
  }
};

const extractData = (html) => {
  if (!html) return null;
  const match = html.match(/financialData:(\{.*?\})/);
  if (match) {
    try {
      return eval('(' + match[1] + ')');
    } catch(e) { return null; }
  }
  return null;
};

// Data sets
const financialsHtml = await getHtml('https://stockanalysis.com/stocks/cop/financials/');
const cashFlowHtml = await getHtml('https://stockanalysis.com/stocks/cop/cash-flow-statement/');
const balanceSheetHtml = await getHtml('https://stockanalysis.com/stocks/cop/financials/balance-sheet/');

const finData = extractData(financialsHtml);
const cfData = extractData(cashFlowHtml);
const bsData = extractData(balanceSheetHtml);

// ═══════════════════════════════════════════════════════════════
// EXTRACT HISTORICAL SERIES
// ═══════════════════════════════════════════════════════════════
let revenueHistory = [];
let epsHistory = [];
let marginHistory = [];
let fcfHistory = [];

if (finData && finData.fiscalYear) {
  for (let i = 0; i < Math.min(5, finData.fiscalYear.length); i++) {
    const yr = finData.fiscalYear[i];
    revenueHistory.push({ year: parseInt(yr), value: (finData.revenue[i] || 0) / 1000000 });
    epsHistory.push({ year: parseInt(yr), value: finData.epsDiluted[i] || 0 });
    marginHistory.push({
      year: parseInt(yr),
      operating: ((finData.operatingMargin[i] || 0) * 100).toFixed(2),
      profit: ((finData.profitMargin[i] || 0) * 100).toFixed(2),
      fcfMargin: ((finData.fcfMargin[i] || 0) * 100).toFixed(2)
    });
    fcfHistory.push({ year: parseInt(yr), value: (finData.fcf[i] || 0) / 1000000 });
  }
}
revenueHistory.reverse();
epsHistory.reverse();
marginHistory.reverse();
fcfHistory.reverse();

// ═══════════════════════════════════════════════════════════════
// DCF MODEL — ALL INPUTS AND CALCULATIONS
// ═══════════════════════════════════════════════════════════════

const fcf2024 = (finData && finData.fcf && finData.fcf[0]) ? (finData.fcf[0] / 1000000) : 8000;
const sharesOutstanding = (finData && finData.sharesDiluted && finData.sharesDiluted[0]) ? (finData.sharesDiluted[0] / 1000000) : 1180;
const cashAndInvestments = (bsData && bsData.totalcash && bsData.totalcash[0]) ? (bsData.totalcash[0] / 1000000) : 6981;
const totalDebt = (bsData && bsData.debt && bsData.debt[0]) ? (bsData.debt[0] / 1000000) : 23444;
const netCash = cashAndInvestments - totalDebt;

// ASSUMPTIONS
// 10Y Treasury is 4.18%. For an O&G company, we apply a higher equity risk premium and conservative growth.
const treasuryYield = 0.0418;
const discountRate = 0.10; // Base WACC (10%)
const growthRatePhase1 = 0.05; // 5% FCF growth, Years 1-5 (derived historically from mature O&G slow growth averages)
const growthRateTerminal = 0.02; // 2% terminal growth

// --- PHASE 1: PROJECT FCF FOR YEARS 1-5 ---
const projectedFCF = [];
let fcf = fcf2024;
for (let yr = 1; yr <= 5; yr++) {
  fcf = fcf * (1 + growthRatePhase1);
  projectedFCF.push({ year: yr, fcf: Math.round(fcf), pvFactor: 1 / Math.pow(1 + discountRate, yr) });
}
projectedFCF.forEach(p => { p.pvFCF = Math.round(p.fcf * p.pvFactor); });

// --- PHASE 2: TERMINAL VALUE (Gordon Growth Model) ---
const fcfYear6 = projectedFCF[4].fcf * (1 + growthRateTerminal);
const terminalValue = Math.round(fcfYear6 / (discountRate - growthRateTerminal));
const pvTerminalValue = Math.round(terminalValue * projectedFCF[4].pvFactor);

// --- ENTERPRISE VALUE ---
const pvPhase1 = projectedFCF.reduce((sum, p) => sum + p.pvFCF, 0);
const enterpriseValue = pvPhase1 + pvTerminalValue;

// --- EQUITY VALUE ---
const equityValue = enterpriseValue + netCash;
const intrinsicValuePerShare = equityValue / sharesOutstanding;
const roundedIV = Math.round(intrinsicValuePerShare * 100) / 100;

// Market comparison
const currentPrice = 110.00; // Static fallback for live price
const marginOfSafety = ((roundedIV - currentPrice) / currentPrice * 100).toFixed(1);
const verdictText = roundedIV > currentPrice ? "Undervalued" : "Overvalued";
const verdictColor = roundedIV > currentPrice ? "#10b981" : "#ef4444";

// Sensitivity analysis
const sensitivityRates = [0.08, 0.09, 0.10, 0.11, 0.12];
const sensitivityGrowth = [0.03, 0.04, 0.05, 0.06, 0.07];
const sensitivityTable = sensitivityRates.map(dr => {
  return {
    dr,
    values: sensitivityGrowth.map(gr => {
      let f = fcf2024;
      let pvSum = 0;
      for (let y = 1; y <= 5; y++) {
        f = f * (1 + gr);
        pvSum += f / Math.pow(1 + dr, y);
      }
      let tv = (f * (1 + growthRateTerminal)) / (dr - growthRateTerminal);
      let pvTv = tv / Math.pow(1 + dr, 5);
      let eqVal = pvSum + pvTv + netCash;
      return Math.round(eqVal / sharesOutstanding);
    })
  };
});
