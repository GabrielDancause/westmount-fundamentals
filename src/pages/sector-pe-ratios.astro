  .header-brand a { color: #4a8fe7; }
  .research-tag { display: inline-block; background: rgba(74,143,231,0.12); color: #4a8fe7; font-size: 0.62rem; font-weight: 800; padding: 4px 14px; border-radius: 20px; letter-spacing: 1.5px; margin-bottom: 16px; }
