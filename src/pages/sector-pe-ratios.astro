<div class="header">
  <div class="header-brand"><a href="/">Westmount Research</a></div>
  <span class="research-tag">ORIGINAL RESEARCH</span>
  <h1>GICS Sector P/E Ratios 2026</h1>
  <p class="subtitle">Which sectors are overvalued? Current vs 10-year historical P/E for all 11 sectors.</p>
  <p class="date">Data as of March 9, 2026 · Source: Finviz, Multpl.com, S&P Global</p>
</div>

<div class="container">

  <!-- Big Stats -->
  <div class="stats-row">
    <div class="stat-card">
      <div class="num">11</div>
      <div class="lbl">GICS Sectors</div>
    </div>
    <div class="stat-card">
      <div class="num">28.95</div>
      <div class="lbl">S&P 500 P/E</div>
    </div>
    <div class="stat-card">
      <div class="num">16.92</div>
      <div class="lbl">Lowest Sector P/E</div>
    </div>
    <div class="stat-card">
      <div class="num">37.47</div>
      <div class="lbl">Highest Sector P/E</div>
    </div>
    <div class="stat-card">
      <div class="num">1</div>
      <div class="lbl">Sector Below Avg</div>
    </div>
  </div>

  <!-- Key Findings -->
  <div class="findings">
    <h2 class="section-title">Key Findings</h2>
    <div class="finding"><p><strong>10 of 11 sectors trade above their 10-year average P/E.</strong> Only Real Estate trades below its historical norm (-12%), pressured by elevated interest rates.</p></div>
    <div class="finding"><p><strong>Communication Services is the most stretched</strong> at 89% above its 10-year average (37.47 vs 19.8), driven by Alphabet and Meta's dominance and AI-era re-rating.</p></div>
    <div class="finding"><p><strong>Financials offer the lowest absolute P/E (16.92)</strong> and the second-best growth-adjusted value (PEG 1.44). Technology has the best PEG at 1.34 despite its elevated P/E.</p></div>
    <div class="finding"><p><strong>Consumer Staples has the worst PEG ratio (2.95)</strong> — investors pay a steep safety premium for single-digit earnings growth. The defensive trade is expensive.</p></div>
    <div class="finding"><p><strong>Materials are the stealth performer.</strong> Best 1-year return (+45%), lowest PEG alongside Tech (1.40), and forward P/E of just 14.9. Commodity supercycle tailwinds are real.</p></div>
  </div>

  <!-- P/E Bar Chart -->
  <div class="chart-section">
    <h2 class="section-title">Current P/E vs Historical Average</h2>
    <div class="chart-container">
      <div id="peChart"></div>
      <div class="legend">
        <div class="legend-item"><div class="legend-swatch" style="background:#4a8fe7;"></div> Current Trailing P/E</div>
        <div class="legend-item"><div class="legend-swatch" style="background:#ff6b6b;"></div> Forward P/E</div>
        <div class="legend-item"><div class="legend-swatch" style="border:2px dashed #fbbf24; background:transparent;"></div> 10-Year Historical Avg</div>
      </div>
    </div>
  </div>

  <!-- Premium/Discount Chart -->
  <div class="chart-section">
    <h2 class="section-title">Premium / Discount vs 10-Year Average</h2>
    <div class="chart-container premium-chart">
      <div id="pdChart"></div>
    </div>
  </div>

  <!-- Table -->
  <div class="table-section">
    <h2 class="section-title">Full Sector Comparison</h2>
    <div class="table-wrap">
      <table id="sectorTable">
        <thead>
          <tr>
            <th data-col="sector">Sector</th>
            <th data-col="currentPe" data-type="num">P/E</th>
            <th data-col="forwardPe" data-type="num">Fwd P/E</th>
            <th data-col="historicalAvgPe" data-type="num">10yr Avg</th>
            <th data-col="premiumDiscountPct" data-type="num">vs Avg</th>
            <th data-col="peg" data-type="num">PEG</th>
            <th data-col="earningsGrowth5yr" data-type="num">EPS 5yr</th>
            <th data-col="earningsGrowthFwd5yr" data-type="num">Fwd EPS</th>
            <th data-col="marketCapT" data-type="num">Mkt Cap</th>
            <th data-col="sp500WeightPct" data-type="num">Weight</th>
            <th data-col="ytdReturn" data-type="num">YTD</th>
          </tr>
        </thead>
        <tbody id="tableBody"></tbody>
      </table>
    </div>
  </div>

  <!-- FAQ -->
  <div class="faq-section">
    <h2 class="section-title">Frequently Asked Questions</h2>
    <div id="faqList"></div>
  </div>

  <!-- Methodology -->
  <div class="methodology">
    <h2>Methodology</h2>
    <p>This study analyzes the price-to-earnings ratios of all 11 GICS (Global Industry Classification Standard) sectors as represented in the U.S. equity market.</p>
    <ul>
      <li><strong>Current P/E:</strong> Trailing twelve-month aggregate earnings, sourced from Finviz sector screener.</li>
      <li><strong>Forward P/E:</strong> Based on sell-side analyst consensus estimates for the next 12 months.</li>
      <li><strong>Historical 10-Year Average:</strong> Compiled from S&P Global sector valuation archives and Fidelity research (2016–2025 average).</li>
      <li><strong>PEG Ratio:</strong> P/E divided by forward 5-year EPS growth estimate — adjusts for growth differences between sectors.</li>
      <li><strong>Market Cap Weights:</strong> Calculated from aggregate market capitalization of all publicly listed companies in each sector.</li>
      <li><strong>Premium/Discount:</strong> Percentage difference between current trailing P/E and 10-year historical average P/E.</li>
    </ul>
    <p style="margin-top: 12px;">P/E ratios for different sectors are not directly comparable. Capital-intensive sectors (Utilities, Real Estate) traditionally trade at different multiples than asset-light sectors (Technology, Communication Services). This study provides both absolute and relative-to-history comparisons.</p>
    <p style="margin-top: 8px;">Data refreshed: March 9, 2026.</p>
  </div>

  <!-- Citation -->
  <div class="citation">
    <div class="citation-title">📋 Cite This Research</div>
    <div class="citation-text">
      Westmount Research. "Sector P/E Ratios 2026 — Which Sectors Are Overvalued?" March 9, 2026.<br>
      https://westmountfundamentals.com/sector-pe-ratios
    </div>
  </div>

</div>


  <div class="disclaimer">This site provides data and analysis for informational purposes only. Nothing here constitutes investment advice. Do your own research.</div>
</div>
  <script is:inline>
const data = [
  { sector: "Communication Services", currentPe: 37.47, forwardPe: 29.19, historicalAvgPe: 19.8, premiumDiscountPct: 89.2, peg: 2.44, earningsGrowth5yr: 24.75, earningsGrowthFwd5yr: 15.33, marketCapT: 11.81, sp500WeightPct: 13.1, ytdReturn: -2.63 },
  { sector: "Information Technology", currentPe: 34.96, forwardPe: 24.96, historicalAvgPe: 27.5, premiumDiscountPct: 27.1, peg: 1.34, earningsGrowth5yr: 33.44, earningsGrowthFwd5yr: 26.09, marketCapT: 24.95, sp500WeightPct: 27.6, ytdReturn: -4.51 },
  { sector: "Real Estate", currentPe: 32.72, forwardPe: 29.15, historicalAvgPe: 37.0, premiumDiscountPct: -11.6, peg: 3.19, earningsGrowth5yr: 10.61, earningsGrowthFwd5yr: 10.25, marketCapT: 1.74, sp500WeightPct: 1.9, ytdReturn: 5.39 },
  { sector: "Industrials", currentPe: 31.78, forwardPe: 22.48, historicalAvgPe: 21.5, premiumDiscountPct: 47.8, peg: 1.89, earningsGrowth5yr: 17.96, earningsGrowthFwd5yr: 16.80, marketCapT: 7.37, sp500WeightPct: 8.1, ytdReturn: 9.79 },
  { sector: "Consumer Discretionary", currentPe: 29.68, forwardPe: 20.40, historicalAvgPe: 23.5, premiumDiscountPct: 26.3, peg: 1.71, earningsGrowth5yr: 27.29, earningsGrowthFwd5yr: 17.31, marketCapT: 8.89, sp500WeightPct: 9.8, ytdReturn: -6.01 },
  { sector: "Health Care", currentPe: 28.99, forwardPe: 17.30, historicalAvgPe: 22.0, premiumDiscountPct: 31.8, peg: 2.16, earningsGrowth5yr: 11.78, earningsGrowthFwd5yr: 13.40, marketCapT: 8.50, sp500WeightPct: 9.4, ytdReturn: -1.38 },
  { sector: "Consumer Staples", currentPe: 27.70, forwardPe: 20.45, historicalAvgPe: 21.5, premiumDiscountPct: 28.8, peg: 2.95, earningsGrowth5yr: 8.41, earningsGrowthFwd5yr: 9.40, marketCapT: 4.50, sp500WeightPct: 5.0, ytdReturn: 9.36 },
  { sector: "Materials", currentPe: 26.20, forwardPe: 14.92, historicalAvgPe: 20.0, premiumDiscountPct: 31.0, peg: 1.40, earningsGrowth5yr: 16.53, earningsGrowthFwd5yr: 18.68, marketCapT: 2.89, sp500WeightPct: 3.2, ytdReturn: 14.13 },
  { sector: "Utilities", currentPe: 22.40, forwardPe: 16.15, historicalAvgPe: 18.5, premiumDiscountPct: 21.1, peg: 1.84, earningsGrowth5yr: 11.90, earningsGrowthFwd5yr: 12.19, marketCapT: 1.93, sp500WeightPct: 2.1, ytdReturn: 8.66 },
  { sector: "Energy", currentPe: 19.27, forwardPe: 15.31, historicalAvgPe: 18.0, premiumDiscountPct: 7.1, peg: 1.88, earningsGrowth5yr: 23.39, earningsGrowthFwd5yr: 10.26, marketCapT: 4.42, sp500WeightPct: 4.9, ytdReturn: 24.61 },
  { sector: "Financials", currentPe: 16.92, forwardPe: 13.43, historicalAvgPe: 14.5, premiumDiscountPct: 16.7, peg: 1.44, earningsGrowth5yr: 18.48, earningsGrowthFwd5yr: 11.79, marketCapT: 13.45, sp500WeightPct: 14.9, ytdReturn: -6.30 }
];

// Sort by current P/E desc for chart
const sorted = [...data].sort((a, b) => b.currentPe - a.currentPe);
const maxPe = 42;

// P/E Bar Chart
const peChart = document.getElementById('peChart');
sorted.forEach(d => {
  const pct = (d.currentPe / maxPe) * 100;
  const fwdPct = (d.forwardPe / maxPe) * 100;
  const histPct = (d.historicalAvgPe / maxPe) * 100;
  peChart.innerHTML += `
    <div class="bar-row">
      <div class="bar-label">${d.sector}</div>
      <div class="bar-track">
        <div class="bar-fill" style="width:${pct}%;background:linear-gradient(90deg,#1a3a6e,#4a8fe7);position:relative;z-index:1;">
          <span>${d.currentPe.toFixed(1)}</span>
        </div>
        <div class="bar-hist" style="left:${histPct}%;">
          <div class="bar-hist-label">${d.historicalAvgPe.toFixed(1)}</div>
        </div>
      </div>
    </div>`;
});

// Premium/Discount Chart
const pdChart = document.getElementById('pdChart');
const pdSorted = [...data].sort((a, b) => b.premiumDiscountPct - a.premiumDiscountPct);
const maxPD = 100;
pdSorted.forEach(d => {
  const val = d.premiumDiscountPct;
  const isNeg = val < 0;
  const barWidth = Math.abs(val) / maxPD * 50;
  const left = isNeg ? (50 - barWidth) : 50;
  const color = isNeg ? '#4ade80' : (val > 40 ? '#ff6b6b' : '#4a8fe7');
  pdChart.innerHTML += `
    <div class="pd-row">
      <div class="pd-label">${d.sector}</div>
      <div class="pd-track" style="background:#0d1428;border-radius:4px;">
        <div class="pd-center"></div>
        <div class="pd-bar" style="left:${left}%;width:${barWidth}%;background:${color};border-radius:4px;">
          <span>${val > 0 ? '+' : ''}${val.toFixed(1)}%</span>
        </div>
      </div>
    </div>`;
});

// Table
const tbody = document.getElementById('tableBody');
function renderTable(d) {
  tbody.innerHTML = '';
  d.forEach(r => {
    const pdClass = r.premiumDiscountPct > 0 ? 'premium' : r.premiumDiscountPct < 0 ? 'discount' : 'neutral';
    const pdSign = r.premiumDiscountPct > 0 ? '+' : '';
    const ytdClass = r.ytdReturn >= 0 ? 'discount' : 'premium';
    tbody.innerHTML += `<tr>
      <td class="sector-name">${r.sector}</td>
      <td>${r.currentPe.toFixed(2)}</td>
      <td>${r.forwardPe.toFixed(2)}</td>
      <td>${r.historicalAvgPe.toFixed(1)}</td>
      <td class="${pdClass}">${pdSign}${r.premiumDiscountPct.toFixed(1)}%</td>
      <td>${r.peg.toFixed(2)}</td>
      <td>${r.earningsGrowth5yr.toFixed(1)}%</td>
      <td>${r.earningsGrowthFwd5yr.toFixed(1)}%</td>
      <td>$${r.marketCapT.toFixed(2)}T</td>
      <td>${r.sp500WeightPct.toFixed(1)}%</td>
      <td class="${ytdClass}">${r.ytdReturn > 0 ? '+' : ''}${r.ytdReturn.toFixed(2)}%</td>
    </tr>`;
  });
}
renderTable(sorted);

// Sorting
let sortCol = 'currentPe', sortDir = 'desc';
document.querySelectorAll('#sectorTable th').forEach(th => {
  th.addEventListener('click', () => {
    const col = th.dataset.col;
    const isNum = th.dataset.type === 'num';
    if (sortCol === col) sortDir = sortDir === 'asc' ? 'desc' : 'asc';
    else { sortCol = col; sortDir = isNum ? 'desc' : 'asc'; }
    document.querySelectorAll('#sectorTable th').forEach(t => t.classList.remove('sorted-asc', 'sorted-desc'));
    th.classList.add(sortDir === 'asc' ? 'sorted-asc' : 'sorted-desc');
    const s = [...data].sort((a, b) => {
      let va = a[col], vb = b[col];
      if (typeof va === 'string') return sortDir === 'asc' ? va.localeCompare(vb) : vb.localeCompare(va);
      return sortDir === 'asc' ? va - vb : vb - va;
    });
    renderTable(s);
  });
});

// FAQ
const faqs = [
  { q: "Which stock market sector has the highest P/E ratio?", a: "As of March 2026, Communication Services has the highest trailing P/E ratio at 37.47, driven by mega-cap platforms like Alphabet and Meta. Information Technology follows at 34.96, and Real Estate is third at 32.72. However, when adjusted for growth (PEG ratio), Technology actually appears more reasonably valued at 1.34 PEG vs Communication Services at 2.44." },
  { q: "Is the tech sector overvalued?", a: "The Information Technology sector trades at a trailing P/E of 34.96 — a 27% premium to its 10-year average of 27.5. However, the sector's PEG ratio of 1.34 (the lowest of all sectors) suggests the elevated P/E is partly justified by exceptional 33% 5-year earnings growth. The forward P/E of 24.96 narrows the gap further. Expensive on an absolute basis, but reasonably priced when growth-adjusted." },
  { q: "What is the average P/E ratio of the S&P 500?", a: "The S&P 500 trailing P/E ratio is 28.95 as of March 2026. The historical mean P/E is 16.20 and the median is 15.06, meaning the current market trades at roughly 79% above its long-term average. Elevated earnings growth expectations and mega-cap tech concentration contribute to this above-average multiple." },
