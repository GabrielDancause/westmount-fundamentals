  "description": "A transparent, step-by-step discounted cash flow valuation of The Boeing Company. Using a normalized base FCF due to turnaround conditions to arrive at a fair value estimate.",
  "datePublished": "2026-03-18",
  "dateModified": "2026-03-18",
  "author": {
    "@type": "Organization",
    "name": "Westmount Research",
    "url": "https://westmountfundamentals.com"
  },
  "publisher": {
    "@type": "Organization",
    "name": "Westmount Research",
