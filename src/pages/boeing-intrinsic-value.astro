    "@type": "WebPage",
    "@id": "https://westmountfundamentals.com/boeing-intrinsic-value"
  }
};

export const meta = {
  title: "Boeing (BA) Intrinsic Value: A DCF Analysis",
  description: "We ran a full discounted cash flow on Boeing modeling a turnaround scenario. One number. Every assumption disclosed.",
  category: "study",
  published: "2026-03-18",
};

/* ═══════════════════════════════════════════════════════════════
   DCF MODEL — ALL INPUTS AND CALCULATIONS
   Data sourced from FY2025 financials.
   Since Boeing's FY2025 FCF is negative (-$1.877B), a standard DCF fails.
   We model a normalized "turnaround" base FCF for Year 0.
   ═══════════════════════════════════════════════════════════════ */

// --- ACTUAL REPORTED INPUTS (FY2025, in millions USD unless noted) ---
const actualFCF2025 = -1877;           // Reported FY2025 Free Cash Flow ($M)
const sharesOutstanding = 768.475;     // Shares outstanding ($M) — FY2025 Basic
const cashAndInvestments = 29400;      // Total Cash + Short-Term Investments ($M)
const totalDebt = 54098;               // Total debt ($M)
const netCash = cashAndInvestments - totalDebt; // -$24,698M (Net Debt)

// --- NORMALIZED INPUT FOR DCF ---
// We assume Boeing stabilizes operations and deliveries to achieve a normalized baseline FCF.
const normalizedBaseFCF = 6000;        // $6B normalized base FCF for modeling

// --- ASSUMPTIONS (fully disclosed below) ---
const growthRatePhase1 = 0.15;         // 15% FCF growth, Years 1-5 (recovery phase)
const growthRateTerminal = 0.03;       // 3.0% perpetuity growth (terminal)
const discountRate = 0.12;             // 12% WACC / required return (higher risk)

// --- PHASE 1: PROJECT FCF FOR YEARS 1-5 ---
const projectedFCF = [];
let fcf = normalizedBaseFCF;
for (let yr = 1; yr <= 5; yr++) {
  fcf = fcf * (1 + growthRatePhase1);
  projectedFCF.push({ year: yr, fcf: Math.round(fcf), pvFactor: 1 / Math.pow(1 + discountRate, yr) });
}
projectedFCF.forEach(p => { p.pvFCF = Math.round(p.fcf * p.pvFactor); });

// --- PHASE 2: TERMINAL VALUE (Gordon Growth Model) ---
const fcfYear6 = projectedFCF[4].fcf * (1 + growthRateTerminal);
const terminalValue = Math.round(fcfYear6 / (discountRate - growthRateTerminal));
const pvTerminalValue = Math.round(terminalValue * projectedFCF[4].pvFactor);

// --- ENTERPRISE VALUE ---
const pvPhase1 = projectedFCF.reduce((sum, p) => sum + p.pvFCF, 0);
const enterpriseValue = pvPhase1 + pvTerminalValue;

// --- EQUITY VALUE ---
const equityValue = enterpriseValue + netCash;
const intrinsicValuePerShare = equityValue / sharesOutstanding;
const roundedIV = Math.round(intrinsicValuePerShare * 100) / 100;

// Market comparison
const currentPrice = 207.22;
const marginOfSafety = ((roundedIV - currentPrice) / currentPrice * 100).toFixed(1);
const verdictText = roundedIV > currentPrice ? "Undervalued" : "Overvalued";
const verdictColor = roundedIV > currentPrice ? "#10b981" : "#ef4444";

// --- HISTORICAL DATA for charts ---
const revenueHistory = [
  { year: 2021, value: 62_286 },
  { year: 2022, value: 66_608 },
  { year: 2023, value: 77_794 },
  { year: 2024, value: 66_517 },
  { year: 2025, value: 89_463 },
];
const fcfHistory = [
  { year: 2021, value: -4_396 },
  { year: 2022, value: 2_290 },
  { year: 2023, value: 4_433 },
  { year: 2024, value: -14_310 },
  { year: 2025, value: -1_877 },
];
const epsHistory = [
  { year: 2021, value: -7.15 },
  { year: 2022, value: -8.30 },
  { year: 2023, value: -3.67 },
  { year: 2024, value: -18.36 },
  { year: 2025, value: 2.37 },
];
const marginHistory = [
  { year: 2021, operating: -4.61, profit: -6.89, fcfMargin: -7.06 },
  { year: 2022, operating: -5.28, profit: -7.59, fcfMargin: 3.44 },
  { year: 2023, operating: -0.99, profit: -2.88, fcfMargin: 5.70 },
  { year: 2024, operating: -16.10, profit: -17.78, fcfMargin: -21.51 },
  { year: 2025, operating: 4.79, profit: 2.50, fcfMargin: -2.10 },
];

// Sensitivity analysis
const sensitivityRates = [0.10, 0.11, 0.12, 0.13, 0.14];
const sensitivityGrowth = [0.10, 0.12, 0.15, 0.18, 0.20];
const sensitivityTable = sensitivityRates.map(dr => {
  return {
    dr,
    values: sensitivityGrowth.map(gr => {
      let f = normalizedBaseFCF;
      let pvSum = 0;
      for (let y = 1; y <= 5; y++) {
        f = f * (1 + gr);
        pvSum += f / Math.pow(1 + dr, y);
      }
      const f6 = f * (1 + growthRateTerminal);
      const tv = f6 / (dr - growthRateTerminal);
      const pvTV = tv / Math.pow(1 + dr, 5);
      return Math.round((pvSum + pvTV + netCash) / sharesOutstanding);
    })
  };
});
