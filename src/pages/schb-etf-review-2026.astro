  <script is:inline>
const schbData = {"symbol":"SCHB","name":"Schwab U.S. Broad Market ETF","price":25.65,"expenseRatio":0.029999999000000003,"aum":38703259648,"yield":1.1,"ytdReturn":0.99123,"oneYear":21.22511583464042,"threeYear":65.0259709381965,"fiveYear":61.76876415124697,"tenYear":264.4203653136134,"holdings":[{"symbol":"NVDA","name":"NVIDIA Corp","weight":0.0646417},{"symbol":"AAPL","name":"Apple Inc","weight":0.058604497},{"symbol":"MSFT","name":"Microsoft Corp","weight":0.04382},{"symbol":"AMZN","name":"Amazon.com Inc","weight":0.0306694},{"symbol":"GOOGL","name":"Alphabet Inc Class A","weight":0.0272304},{"symbol":"AVGO","name":"Broadcom Inc","weight":0.022653501},{"symbol":"GOOG","name":"Alphabet Inc Class C","weight":0.021739298},{"symbol":"META","name":"Meta Platforms Inc Class A","weight":0.0211919},{"symbol":"TSLA","name":"Tesla Inc","weight":0.0169801},{"symbol":"BRK-B","name":"Berkshire Hathaway Inc Class B","weight":0.0139036}],"inception":2009,"issuer":"Schwab ETFs"};
        const vtiData = {"symbol":"VTI","name":"Vanguard Total Stock Market Index Fund ETF Shares","price":327.92,"expenseRatio":0.029999999000000003,"aum":680014315520,"yield":1.11,"ytdReturn":1.04695,"oneYear":21.237414968212263,"threeYear":64.98128406103977,"fiveYear":61.54074086991871,"tenYear":264.6909698767932,"holdings":[{"symbol":"NVDA","name":"NVIDIA Corp","weight":0.0661532},{"symbol":"AAPL","name":"Apple Inc","weight":0.057487402},{"symbol":"MSFT","name":"Microsoft Corp","weight":0.0479509},{"symbol":"AMZN","name":"Amazon.com Inc","weight":0.034518298},{"symbol":"GOOGL","name":"Alphabet Inc Class A","weight":0.0294768},{"symbol":"AVGO","name":"Broadcom Inc","weight":0.0234558},{"symbol":"META","name":"Meta Platforms Inc Class A","weight":0.023395099},{"symbol":"GOOG","name":"Alphabet Inc Class C","weight":0.023333099},{"symbol":"TSLA","name":"Tesla Inc","weight":0.0182412},{"symbol":"LLY","name":"Eli Lilly and Co","weight":0.0132287005}],"inception":2001,"issuer":"Vanguard"};

        document.getElementById('current-date').textContent = new Date().toLocaleDateString('en-US', { month: 'long', year: 'numeric' });
        document.getElementById('year').textContent = new Date().getFullYear();

        // Format helpers
        const formatPct = (val) => val != null ? val.toFixed(2) + '%' : 'N/A';
        const formatMoney = (val) => {
            if (!val) return 'N/A';
            if (val >= 1e12) return '$' + (val / 1e12).toFixed(2) + 'T';
            if (val >= 1e9) return '$' + (val / 1e9).toFixed(2) + 'B';
            if (val >= 1e6) return '$' + (val / 1e6).toFixed(2) + 'M';
            return '$' + val.toLocaleString();
        };

        // Render Stats
        document.getElementById('stats-grid').innerHTML = `
            <div class="stat-card">
                <div class="stat-value">${formatPct(schbData.expenseRatio || 0.03)}</div>
                <div class="stat-label">Expense Ratio</div>
            </div>
            <div class="stat-card">
                <div class="stat-value">${formatPct(schbData.yield)}</div>
                <div class="stat-label">Dividend Yield</div>
            </div>
            <div class="stat-card">
                <div class="stat-value">${formatMoney(schbData.aum)}</div>
                <div class="stat-label">Assets Under Mgt</div>
            </div>
            <div class="stat-card">
                <div class="stat-value">${formatPct(schbData.fiveYear)}</div>
                <div class="stat-label">5-Year Return</div>
            </div>
        `;

        // Render Comparison Table
        document.getElementById('comparison-body').innerHTML = `
            <tr>
                <td>Expense Ratio</td>
                <td>${formatPct(schbData.expenseRatio || 0.03)}</td>
                <td>${formatPct(vtiData.expenseRatio || 0.03)}</td>
            </tr>
            <tr>
                <td>AUM</td>
                <td>${formatMoney(schbData.aum)}</td>
                <td>${formatMoney(vtiData.aum)}</td>
            </tr>
            <tr>
                <td>Dividend Yield</td>
                <td>${formatPct(schbData.yield)}</td>
                <td>${formatPct(vtiData.yield)}</td>
            </tr>
            <tr>
                <td>1-Year Return</td>
                <td>${formatPct(schbData.oneYear)}</td>
                <td>${formatPct(vtiData.oneYear)}</td>
            </tr>
            <tr>
                <td>3-Year Return</td>
                <td>${formatPct(schbData.threeYear)}</td>
                <td>${formatPct(vtiData.threeYear)}</td>
            </tr>
            <tr>
                <td>5-Year Return</td>
                <td>${formatPct(schbData.fiveYear)}</td>
                <td>${formatPct(vtiData.fiveYear)}</td>
            </tr>
        `;

        // Render Holdings
        let currentHoldings = schbData.holdings || [];
        let sortCol = 'weight';
        let sortDesc = true;

        const holdingsBody = document.getElementById('holdings-body');

        function renderHoldings() {
            if (currentHoldings.length > 0) {
                holdingsBody.innerHTML = currentHoldings.map(h => `
                    <tr>
                        <td><strong>${h.symbol}</strong></td>
                        <td>${h.name}</td>
                        <td class="text-right">${formatPct(h.weight * 100)}</td>
                    </tr>
                `).join('');
            } else {
                holdingsBody.innerHTML = '<tr><td colspan="3" class="text-center" style="text-align: center;">No holdings found matching criteria.</td></tr>';
            }
        }

        function sortHoldings(col) {
            if (sortCol === col) {
                sortDesc = !sortDesc;
            } else {
                sortCol = col;
                sortDesc = (col === 'weight'); // default to desc for weight, asc for text
            }

            currentHoldings.sort((a, b) => {
                let valA = a[col];
                let valB = b[col];

                if (typeof valA === 'string') valA = valA.toLowerCase();
                if (typeof valB === 'string') valB = valB.toLowerCase();

                if (valA < valB) return sortDesc ? 1 : -1;
                if (valA > valB) return sortDesc ? -1 : 1;
                return 0;
            });
            renderHoldings();
        }

        document.getElementById('holdings-search').addEventListener('input', (e) => {
            const term = e.target.value.toLowerCase();
            if (!term) {
                currentHoldings = schbData.holdings || [];
            } else {
                currentHoldings = (schbData.holdings || []).filter(h =>
                    h.symbol.toLowerCase().includes(term) ||
                    h.name.toLowerCase().includes(term)
                );
            }
            // re-apply sort
            const prevCol = sortCol;
            const prevDesc = sortDesc;
            sortCol = null;
            sortDesc = !prevDesc; // toggle so next call restores it
            sortHoldings(prevCol);
        });

        // Initial sort and render
        sortHoldings('weight');

        // Render Chart
        const ctx = document.getElementById('performanceChart').getContext('2d');
        new Chart(ctx, {
            type: 'bar',
            data: {
                labels: ['1-Year', '3-Year', '5-Year', '10-Year'],
                datasets: [
                    {
                        label: 'SCHB',
                        data: [schbData.oneYear, schbData.threeYear, schbData.fiveYear, schbData.tenYear],
                        backgroundColor: '#4a8fe7',
                        borderRadius: 4
                    },
                    {
                        label: 'VTI',
                        data: [vtiData.oneYear, vtiData.threeYear, vtiData.fiveYear, vtiData.tenYear],
                        backgroundColor: '#152040',
                        borderRadius: 4
                    }
                ]
            },
            options: {
                responsive: true,
                plugins: {
                    legend: {
                        labels: { color: '#e2e8f0', font: { family: 'Inter' } }
                    },
                    tooltip: {
                        callbacks: {
                            label: function(context) {
                                return context.dataset.label + ': ' + context.parsed.y.toFixed(2) + '%';
                            }
                        }
                    }
                },
                scales: {
                    y: {
                        ticks: { color: '#94a3b8', callback: (val) => val + '%' },
                        grid: { color: '#152040' }
                    },
                    x: {
                        ticks: { color: '#94a3b8', font: { family: 'Inter' } },
                        grid: { display: false }
                    }
                }
            }
        });
  </script>
