    {
      "@type": "Question",
      "name": "Why is the balance sheet important to investors?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "The balance sheet provides a snapshot of a company's financial health at a specific point in time. It helps investors assess liquidity, financial leverage, and the overall net worth of the business."
      }
    }
  ]
