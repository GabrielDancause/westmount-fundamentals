          <div style="margin-top:20px">
            <h3 style="color:#10b981;margin:0 0 8px">💰 Equity (Auto-calculated)</h3>
            <div class="builder-total" id="equity-display" style="border-color:#10b981;font-size:1.2em">Shareholders' Equity: $160,000,000</div>
          </div>
          <div class="input-group" style="margin-top:12px">
            <label for="b-shares">Shares Outstanding (for Book Value)</label>
            <div class="input-wrapper"><input type="number" id="b-shares" value="50000000" min="1" step="1000000"></div>
          </div>
        </div>
      </div>

      <div class="ratio-grid" id="ratio-grid">
        <div class="ratio-card">
          <div class="ratio-label">Current Ratio</div>
          <div class="ratio-value" id="r-current">2.00x</div>
          <div class="ratio-desc">Current Assets / Current Liab.</div>
        </div>
        <div class="ratio-card">
          <div class="ratio-label">Quick Ratio</div>
          <div class="ratio-value" id="r-quick">1.63x</div>
