          </div>
          <div class="input-group">
            <label for="b-ppe">Property, Plant & Equipment</label>
            <div class="input-wrapper"><span class="prefix">$</span><input type="number" id="b-ppe" value="100000000" min="0" step="1000000"></div>
          </div>
