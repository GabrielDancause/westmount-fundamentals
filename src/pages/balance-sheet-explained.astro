        <div class="bs-bar" style="background:linear-gradient(135deg,#a78bfa,#9775f0);height:33%" title="PP&E: $100M">
          <span>PP&E</span><span>$100M</span>
        </div>
        <div class="bs-bar" style="background:linear-gradient(135deg,#c4b5fd,#b3a3ec);height:14%;color:#1a1a2e" title="Intangibles & Other: $40M">
          <span>Intangibles</span><span>$40M</span>
        </div>
        <div class="bs-total">Total: $300M</div>
      </div>
      <div class="bs-diagram-equals">=</div>
      <div class="bs-diagram-col">
        <div class="bs-diagram-header">LIABILITIES + EQUITY</div>
