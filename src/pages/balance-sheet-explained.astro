          <tr class="subtotal"><td>Total Non-Current Assets</td><td style="text-align:right"><strong>$140.0</strong></td></tr>
          <tr class="grand-total"><td><strong>TOTAL ASSETS</strong></td><td style="text-align:right"><strong>$300.0</strong></td></tr>
        </tbody>
      </table>
      <table class="bs-table" style="margin-top:16px">
        <thead>
          <tr><th style="text-align:left">LIABILITIES & EQUITY</th><th style="text-align:right">Amount</th></tr>
        </thead>
        <tbody>
          <tr class="section-header"><td colspan="2">Current Liabilities</td></tr>
          <tr><td>Accounts Payable</td><td style="text-align:right">$35.0</td></tr>
          <tr><td>Short-term Debt</td><td style="text-align:right">$20.0</td></tr>
          <tr><td>Accrued Expenses & Other</td><td style="text-align:right">$25.0</td></tr>
          <tr class="subtotal"><td>Total Current Liabilities</td><td style="text-align:right"><strong>$80.0</strong></td></tr>
          <tr class="section-header"><td colspan="2">Non-Current Liabilities</td></tr>
          <tr><td>Long-term Debt</td><td style="text-align:right">$50.0</td></tr>
