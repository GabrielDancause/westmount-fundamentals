    <!-- ═══ INTERACTIVE BUILDER ═══ -->
    <h2 id="balance-sheet-builder">Interactive Balance Sheet Builder</h2>
    <p>Enter your own numbers below. The builder auto-calculates <strong>shareholders' equity</strong> and key financial ratios instantly. Use it as a <strong>balance sheet template</strong> to model any company.</p>

    <div class="builder-card">
      <div class="builder-grid">
        <div class="builder-section">
          <h3 style="color:#4a8fe7;margin:0 0 16px">📊 Assets</h3>
          <div class="input-group">
            <label for="b-cash">Cash & Equivalents</label>
