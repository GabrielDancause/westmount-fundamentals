          </div>
          <div class="input-group">
            <label for="b-lt-debt">Long-term Debt</label>
            <div class="input-wrapper"><span class="prefix">$</span><input type="number" id="b-lt-debt" value="60000000" min="0" step="1000000"></div>
          </div>
