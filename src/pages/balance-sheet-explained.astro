    .bs-total { text-align: center; font-weight: 700; color: #e6edf3; padding: 10px; border-top: 2px solid #4a8fe7; margin-top: 4px; }

    /* Builder */
    .builder-card { background: #0d1117; border: 1px solid #30363d; border-radius: 12px; padding: 28px; margin: 24px 0; }
    .builder-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 32px; }
    .builder-section { }
    .input-group { margin-bottom: 14px; }
    .input-group label { display: block; font-size: 0.85em; color: #94a3b8; margin-bottom: 4px; font-weight: 500; }
    .input-wrapper { display: flex; align-items: center; background: #161b22; border: 1px solid #30363d; border-radius: 8px; overflow: hidden; }
    .input-wrapper .prefix { padding: 8px 10px; color: #94a3b8; font-weight: 600; background: rgba(48,54,61,0.5); }
    .input-wrapper input { flex: 1; background: transparent; border: none; color: #e6edf3; padding: 10px; font-size: 1em; outline: none; }
    .input-wrapper input:focus { box-shadow: 0 0 0 2px rgba(74,143,231,0.3); }
    .builder-total { padding: 12px; border: 2px solid #4a8fe7; border-radius: 8px; text-align: center; font-weight: 700; color: #e6edf3; font-size: 1em; margin-top: 8px; }

    /* Ratios */
    .ratio-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 16px; margin-top: 24px; }
    .ratio-card { background: #161b22; border: 1px solid #30363d; border-radius: 10px; padding: 16px; text-align: center; }
    .ratio-label { font-size: 0.8em; color: #94a3b8; text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 4px; }
    .ratio-value { font-size: 1.6em; font-weight: 700; color: #10b981; }
    .ratio-desc { font-size: 0.75em; color: #6b7280; margin-top: 4px; }

    .balance-check { padding: 12px; border-radius: 8px; text-align: center; margin-top: 16px; font-weight: 600; }
    .balance-check.balanced { background: rgba(16,185,129,0.1); border: 1px solid rgba(16,185,129,0.3); color: #10b981; }
    .balance-check.negative { background: rgba(239,68,68,0.1); border: 1px solid rgba(239,68,68,0.3); color: #ef4444; }

    /* Charts */
    .chart-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 24px; margin: 24px 0; }
    .chart-container { background: #0d1117; border: 1px solid #30363d; border-radius: 12px; padding: 20px; min-height: 380px; }

    /* Sample balance sheet */
    .sample-bs { background: #0d1117; border: 1px solid #30363d; border-radius: 12px; padding: 28px; margin: 24px 0; }
    .sample-bs-header { font-size: 1.2em; font-weight: 700; color: #e6edf3; text-align: center; }
    .sample-bs-sub { font-size: 0.85em; color: #94a3b8; text-align: center; margin-bottom: 20px; }
    .bs-table { width: 100%; border-collapse: collapse; }
    .bs-table th { padding: 10px; border-bottom: 2px solid #30363d; color: #94a3b8; font-size: 0.85em; text-transform: uppercase; letter-spacing: 0.5px; }
    .bs-table td { padding: 8px 10px; border-bottom: 1px solid rgba(48,54,61,0.5); color: #c8d0de; font-size: 0.92em; }
    .bs-table .section-header td { color: #4a8fe7; font-weight: 700; font-size: 0.85em; text-transform: uppercase; padding-top: 16px; border-bottom: 1px solid rgba(74,143,231,0.3); }
    .bs-table .subtotal td { font-weight: 600; border-bottom: 1px solid #30363d; }
    .bs-table .grand-total td { font-weight: 700; border-top: 2px solid #30363d; border-bottom: 2px solid #30363d; font-size: 1em; background: rgba(74,143,231,0.05); }

    /* Comparison table */
    .comparison-table-wrap { overflow-x: auto; margin: 24px 0; }
    .comparison-table { width: 100%; border-collapse: collapse; background: #0d1117; border: 1px solid #30363d; border-radius: 12px; overflow: hidden; }
    .comparison-table th { padding: 12px 14px; background: rgba(74,143,231,0.1); color: #e6edf3; font-size: 0.85em; text-transform: uppercase; letter-spacing: 0.5px; border-bottom: 2px solid #30363d; text-align: left; }
    .comparison-table td { padding: 10px 14px; border-bottom: 1px solid rgba(48,54,61,0.5); color: #c8d0de; font-size: 0.9em; vertical-align: top; }
    .comparison-table tr:last-child td { border-bottom: none; }
    .comparison-table tr:hover td { background: rgba(74,143,231,0.05); }

    /* Ratios explained */
    .ratios-explained { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin: 24px 0; }
    .ratio-explain-card { background: #0d1117; border: 1px solid #30363d; border-radius: 12px; padding: 24px; }
    .ratio-explain-card h3 { color: #4a8fe7; margin: 0 0 10px; }
    .formula-box { background: #161b22; border: 1px solid #30363d; border-radius: 8px; padding: 10px 14px; font-family: 'Courier New', monospace; color: #e6edf3; font-weight: 600; margin-bottom: 12px; font-size: 0.9em; }
    .ratio-example { background: rgba(16,185,129,0.1); border: 1px solid rgba(16,185,129,0.2); border-radius: 6px; padding: 8px 12px; font-size: 0.85em; color: #10b981; }

    /* Steps */
    .steps-container { margin: 24px 0; }
    .step-card { display: flex; gap: 16px; align-items: flex-start; margin-bottom: 20px; background: #0d1117; border: 1px solid #30363d; border-radius: 12px; padding: 20px; }
    .step-number { min-width: 40px; height: 40px; background: linear-gradient(135deg, #4a8fe7, #6366f1); border-radius: 50%; display: flex; align-items: center; justify-content: center; font-weight: 700; font-size: 1.1em; color: #fff; }
    .step-content h3 { margin: 0 0 6px; color: #e6edf3; }
    .step-content p { margin: 0; color: #94a3b8; font-size: 0.92em; }

    /* Flags */
    .flags-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin: 24px 0; }
    .flag-card { border-radius: 12px; padding: 24px; }
    .flag-card.green { background: rgba(16,185,129,0.08); border: 1px solid rgba(16,185,129,0.25); }
    .flag-card.red { background: rgba(239,68,68,0.08); border: 1px solid rgba(239,68,68,0.25); }
    .flag-card h3 { margin: 0 0 12px; }
    .flag-card ul { margin: 0; padding-left: 20px; }
    .flag-card.green li { color: #10b981; }
    .flag-card.red li { color: #ef4444; }

    /* Insights */
    .insights-grid { display: grid; grid-template-columns: 1fr; gap: 16px; margin: 24px 0; }
    .insight-card { background: #0d1117; border: 1px solid #30363d; border-radius: 12px; padding: 24px; display: flex; gap: 16px; align-items: flex-start; }
    .insight-num { min-width: 36px; height: 36px; background: linear-gradient(135deg, #4a8fe7, #3b7dd8); border-radius: 8px; display: flex; align-items: center; justify-content: center; font-weight: 700; color: #fff; font-size: 1em; }
    .insight-card h3 { margin: 0 0 6px; color: #e6edf3; font-size: 1em; }
    .insight-card p { margin: 0; color: #94a3b8; font-size: 0.9em; }

    /* FAQ */
    .faq-list { margin: 24px 0; }
    .faq-item { background: #0d1117; border: 1px solid #30363d; border-radius: 10px; margin-bottom: 10px; overflow: hidden; }
    .faq-item summary { padding: 16px 20px; cursor: pointer; font-weight: 600; color: #e6edf3; font-size: 1em; list-style: none; display: flex; justify-content: space-between; align-items: center; }
    .faq-item summary::-webkit-details-marker { display: none; }
    .faq-item summary::after { content: '+'; font-size: 1.3em; color: #4a8fe7; font-weight: 300; transition: transform 0.2s; }
    .faq-item[open] summary::after { content: '−'; }
    .faq-item p { padding: 0 20px 16px; margin: 0; color: #94a3b8; font-size: 0.92em; line-height: 1.6; }

    /* Responsive */
    @media (max-width: 900px) {
      .stat-grid { grid-template-columns: repeat(2, 1fr); }
      .builder-grid { grid-template-columns: 1fr; }
      .ratio-grid { grid-template-columns: repeat(2, 1fr); }
      .chart-grid { grid-template-columns: 1fr; }
      .ratios-explained { grid-template-columns: 1fr; }
      .flags-grid { grid-template-columns: 1fr; }
      .bs-diagram { flex-direction: column; min-height: auto; }
      .bs-diagram-equals { padding: 10px 0; font-size: 2em; }
    }
    @media (max-width: 600px) {
