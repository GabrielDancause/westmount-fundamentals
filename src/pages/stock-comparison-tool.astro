---
import SiteLayout from "../layouts/SiteLayout.astro";
import registry from "../data/pages-registry.json";

const page = (registry as any)["stock-comparison-tool"];
export const meta = { title: "Stock Comparison Tool: Compare Any Two Stocks", description: "Compare any two stocks side-by-side. Analyze P/E, dividend yield, market cap, ROE, revenue growth, and more with our interactive stock comparison tool.", category: "tool", published: "2026-03-15" };

const schema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "How do you compare two stocks side by side?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "To compare two stocks side by side, look at key financial metrics such as the Price-to-Earnings (P/E) ratio, Dividend Yield, Market Capitalization, Return on Equity (ROE), and Revenue Growth. Our stock comparison tool automatically aligns these metrics for any two tickers so you can evaluate their relative valuation and performance."
      }
    },
    {
      "@type": "Question",
      "name": "Which is better: high P/E or low P/E?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "A low P/E ratio may indicate that a stock is undervalued compared to its earnings, which appeals to value investors. A high P/E ratio often suggests that investors expect higher future growth, typical of growth stocks. The 'better' choice depends on your investment strategy and the industry average."
      }
    },
    {
      "@type": "Question",
      "name": "How to choose between two similar stocks?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "When choosing between two similar stocks, compare their valuation (P/E, P/B), profitability (Profit Margin, ROE), growth (Revenue Growth), and risk (Beta). Additionally, consider their dividend yield if you are seeking income, and review their historical 52-week price range."
      }
    },
    {
      "@type": "Question",
      "name": "What is a good ROE for a stock?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "A good Return on Equity (ROE) is typically around 15% to 20%, though it varies significantly by industry. A higher ROE indicates that a company is more efficient at generating profit from its shareholders' equity."
      }
    },
    {
      "@type": "Question",
      "name": "Why compare stock market caps?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Comparing market capitalization helps you understand the size and stability of the companies. Large-cap stocks are generally more stable and often pay dividends, while small-cap stocks might offer higher growth potential but come with greater risk and volatility."
      }
    }
  ]
};

---

<SiteLayout
  site="westmount"
  title={page.title}
  description={page.description}
  canonical={`https://westmountfundamentals.com/${page.slug}`} schema={schema}
>
  <style>
@import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&family=JetBrains+Mono:wght@400;700&display=swap');

    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      font-family: 'Inter', -apple-system, sans-serif;
      background: #060a12;
      color: #c8d0de;
      line-height: 1.6;
    }

    /* Nav */
    nav {
      position: sticky;
      top: 0;
      z-index: 1000;
      background: rgba(6, 10, 18, 0.85);
      backdrop-filter: blur(12px);
      border-bottom: 1px solid #152040;
      padding: 16px 24px;
      display: flex;
      justify-content: space-between;
      align-items: center;
    }
    .nav-brand {
      color: #fff;
      font-weight: 800;
      font-size: 1.1rem;
      text-decoration: none;
      letter-spacing: -0.5px;
    }
    .nav-links a {
      color: #8a9cbd;
      text-decoration: none;
      font-size: 0.9rem;
      font-weight: 600;
      margin-left: 24px;
      transition: color 0.2s;
    }
    .nav-links a:hover { color: #4a8fe7; }

    /* Layout */
    .container {
      max-width: 1200px;
      margin: 0 auto;
      padding: 60px 24px;
    }

    /* Header */
    .header { text-align: center; margin-bottom: 50px; }
    h1 {
      font-size: 3rem;
      font-weight: 900;
      letter-spacing: -1.5px;
      margin-bottom: 16px;
      background: linear-gradient(90deg, #fff, #8a9cbd);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
    }
    .subtitle { color: #8a9cbd; font-size: 1.1rem; max-width: 600px; margin: 0 auto; }

    /* Controls */
    .controls {
      display: flex;
      gap: 16px;
      justify-content: center;
      margin-bottom: 40px;
      flex-wrap: wrap;
    }
    .input-group {
      display: flex;
      flex-direction: column;
      gap: 8px;
    }
    .input-group label {
      font-size: 0.85rem;
      font-weight: 600;
      color: #8a9cbd;
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }
    .controls input {
      background: #0a1020;
      border: 1px solid #152040;
      color: #fff;
      padding: 12px 16px;
      border-radius: 8px;
      font-family: 'JetBrains Mono', monospace;
      font-size: 1rem;
      width: 150px;
      text-transform: uppercase;
      outline: none;
      transition: border-color 0.2s;
    }
    .controls input:focus { border-color: #4a8fe7; }
    .controls button {
      background: #4a8fe7;
      color: #fff;
      border: none;
      padding: 12px 24px;
      border-radius: 8px;
      font-weight: 600;
      font-size: 1rem;
      cursor: pointer;
      align-self: flex-end;
      transition: background 0.2s;
    }
    .controls button:hover { background: #3a75c4; }

    /* Comparison Area */
    .comparison-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 24px;
      margin-bottom: 40px;
    }

    .stock-card {
      background: #0a1020;
      border: 1px solid #152040;
      border-radius: 12px;
      padding: 32px;
      text-align: center;
      display: none;
    }
    .stock-card.active { display: block; }

    .ticker { font-size: 2.5rem; font-weight: 900; color: #fff; font-family: 'JetBrains Mono', monospace; margin-bottom: 8px; }
    .company-name { color: #8a9cbd; font-size: 1.1rem; margin-bottom: 24px; }

    .metrics-list { text-align: left; }
    .metric-item {
      display: flex;
      justify-content: space-between;
      padding: 12px 0;
      border-bottom: 1px solid #152040;
    }
    .metric-item:last-child { border-bottom: none; }
    .metric-label { color: #8a9cbd; font-size: 0.9rem; font-weight: 500; }
    .metric-value { color: #fff; font-family: 'JetBrains Mono', monospace; font-weight: 700; }

    /* Winner highlighting */
    .metric-value.winner { color: #4ae78f; }
    .metric-value.loser { color: #e74a6b; }

    /* Chart Area */
    .chart-container {
      background: #0a1020;
      border: 1px solid #152040;
      border-radius: 12px;
      padding: 32px;
      margin-bottom: 60px;
      display: none;
      height: 400px;
    }
    .chart-container.active { display: block; }

    /* Error Message */
    .error-message {
      color: #e74a6b;
      text-align: center;
      margin-bottom: 20px;
      font-weight: 600;
      display: none;
    }

    /* Table fallback or detailed view */
    .table-container {
      background: #0a1020;
      border: 1px solid #152040;
      border-radius: 12px;
      overflow-x: auto;
      margin-bottom: 60px;
      display: none;
    }
    .table-container.active { display: block; }
    table { width: 100%; border-collapse: collapse; text-align: left; }
    th {
      background: #0d1428;
      padding: 16px 20px;
      font-size: 0.85rem;
      font-weight: 700;
      color: #8a9cbd;
      text-transform: uppercase;
      letter-spacing: 0.5px;
      border-bottom: 1px solid #152040;
    }
    td {
      padding: 16px 20px;
      border-bottom: 1px solid #152040;
      color: #e0e8f0;
    }
    td.mono { font-family: 'JetBrains Mono', monospace; }
    tr:last-child td { border-bottom: none; }

    /* Sections */
    .content-section { margin-bottom: 60px; }
    .content-section h2 { font-size: 2rem; color: #fff; margin-bottom: 24px; letter-spacing: -0.5px; }
    .content-section p { margin-bottom: 16px; color: #8a9cbd; }

    /* FAQ */
    .faq-item { margin-bottom: 24px; }
    .faq-item h3 { font-size: 1.2rem; color: #fff; margin-bottom: 8px; }
    .faq-item p { color: #8a9cbd; }

    /* Footer */
    footer {
      text-align: center;
      padding: 40px 24px;
      border-top: 1px solid #152040;
      color: #5a6a80;
      font-size: 0.85rem;
    }

    @media (max-width: 768px) {
      .comparison-grid { grid-template-columns: 1fr; }
      h1 { font-size: 2.2rem; }
      .nav-links { display: none; }
    }
  </style>

<div class="container">
  <div style="max-width:1280px;margin:0 auto;padding:16px 24px 0;display:flex;justify-content:space-between;align-items:center;font-size:13px;color:var(--text-dim,#94a3b8)">
    <nav aria-label="Breadcrumb"><a href="/" style="color:var(--text-dim,#94a3b8);text-decoration:none">Home</a> <span style="margin:0 6px;opacity:0.5">›</span> <a href="/tools/" style="color:var(--text-dim,#94a3b8);text-decoration:none">Tools</a> <span style="margin:0 6px;opacity:0.5">›</span> <span style="color:var(--text-primary,#c8d0de)">Stock Comparison Tool: Compare Any Two Stocks</span></nav>
    <span>8 min read</span>
  </div>
    <div class="header">
      <h1>{page.h1}</h1>
      <p class="subtitle">Instantly compare any two stocks side-by-side. Analyze valuation, profitability, growth, and risk metrics to make data-driven investment decisions.</p>
    </div>

    <div class="controls">
      <div class="input-group">
        <label for="ticker1">Stock A</label>
        <input type="text" id="ticker1" placeholder="e.g. AAPL" value="AAPL">
      </div>
      <div class="input-group">
        <label for="ticker2">Stock B</label>
        <input type="text" id="ticker2" placeholder="e.g. MSFT" value="MSFT">
      </div>
      <button id="compareBtn">Compare Stocks</button>
    </div>

    <div id="errorMsg" class="error-message"></div>

    <div class="comparison-grid">
      <div id="card1" class="stock-card">
        <div class="ticker" id="t1-ticker">--</div>
        <div class="company-name" id="t1-name">--</div>
        <div class="metrics-list">
          <div class="metric-item"><span class="metric-label">P/E Ratio</span><span class="metric-value" id="t1-pe">--</span></div>
          <div class="metric-item"><span class="metric-label">P/B Ratio</span><span class="metric-value" id="t1-pb">--</span></div>
          <div class="metric-item"><span class="metric-label">Dividend Yield</span><span class="metric-value" id="t1-div">--</span></div>
          <div class="metric-item"><span class="metric-label">Market Cap</span><span class="metric-value" id="t1-mcap">--</span></div>
          <div class="metric-item"><span class="metric-label">Revenue Growth</span><span class="metric-value" id="t1-rev">--</span></div>
          <div class="metric-item"><span class="metric-label">Profit Margin</span><span class="metric-value" id="t1-margin">--</span></div>
          <div class="metric-item"><span class="metric-label">ROE</span><span class="metric-value" id="t1-roe">--</span></div>
          <div class="metric-item"><span class="metric-label">Beta</span><span class="metric-value" id="t1-beta">--</span></div>
          <div class="metric-item"><span class="metric-label">52-Wk Range</span><span class="metric-value" id="t1-range" style="font-size: 0.85rem;">--</span></div>
        </div>
      </div>

      <div id="card2" class="stock-card">
        <div class="ticker" id="t2-ticker">--</div>
        <div class="company-name" id="t2-name">--</div>
        <div class="metrics-list">
          <div class="metric-item"><span class="metric-label">P/E Ratio</span><span class="metric-value" id="t2-pe">--</span></div>
          <div class="metric-item"><span class="metric-label">P/B Ratio</span><span class="metric-value" id="t2-pb">--</span></div>
          <div class="metric-item"><span class="metric-label">Dividend Yield</span><span class="metric-value" id="t2-div">--</span></div>
          <div class="metric-item"><span class="metric-label">Market Cap</span><span class="metric-value" id="t2-mcap">--</span></div>
          <div class="metric-item"><span class="metric-label">Revenue Growth</span><span class="metric-value" id="t2-rev">--</span></div>
          <div class="metric-item"><span class="metric-label">Profit Margin</span><span class="metric-value" id="t2-margin">--</span></div>
          <div class="metric-item"><span class="metric-label">ROE</span><span class="metric-value" id="t2-roe">--</span></div>
          <div class="metric-item"><span class="metric-label">Beta</span><span class="metric-value" id="t2-beta">--</span></div>
          <div class="metric-item"><span class="metric-label">52-Wk Range</span><span class="metric-value" id="t2-range" style="font-size: 0.85rem;">--</span></div>
        </div>
      </div>
    </div>

    <div id="chartSection" class="chart-container">
      <canvas id="radarChart"></canvas>
    </div>

    <div class="table-container" id="tableSection">
      <div style="padding: 16px 20px; display: flex; justify-content: space-between; align-items: center; border-bottom: 1px solid #152040;">
        <h3 style="color: #fff; font-size: 1.1rem; margin: 0;">All Stocks Data</h3>
        <input type="text" id="tableSearch" placeholder="Search ticker or name..." style="background: #060a12; border: 1px solid #152040; color: #fff; padding: 8px 12px; border-radius: 6px; font-family: 'Inter', sans-serif; font-size: 0.9rem; outline: none;">
      </div>
      <table id="dataTable">
        <thead>
          <tr>
            <th style="cursor: pointer;" onclick="sortTable(0)">Ticker ↕</th>
            <th style="cursor: pointer;" onclick="sortTable(1)">Name ↕</th>
            <th style="cursor: pointer;" onclick="sortTable(2)">P/E ↕</th>
            <th style="cursor: pointer;" onclick="sortTable(3)">P/B ↕</th>
            <th style="cursor: pointer;" onclick="sortTable(4)">Yield ↕</th>
            <th style="cursor: pointer;" onclick="sortTable(5)">Mkt Cap ↕</th>
            <th style="cursor: pointer;" onclick="sortTable(6)">Rev Gr ↕</th>
            <th style="cursor: pointer;" onclick="sortTable(7)">Margin ↕</th>
            <th style="cursor: pointer;" onclick="sortTable(8)">ROE ↕</th>
          </tr>
        </thead>
        <tbody id="tableBody">
          <!-- Rows injected via JS -->
        </tbody>
      </table>
    </div>

    <div class="content-section">
      <h2>Methodology</h2>
      <p>This stock comparison tool leverages fundamental financial data to provide a side-by-side analysis of two publicly traded companies. The data is pre-compiled for major US equities, covering key valuation metrics (Price-to-Earnings, Price-to-Book), profitability metrics (Return on Equity, Profit Margin), growth indicators (Revenue Growth), and risk factors (Beta).</p>
      <p>Metrics are calculated based on the most recent trailing twelve months (TTM) data where applicable. Market capitalization is represented in billions or millions for readability. When comparing two stocks, 'better' values are highlighted contextually (e.g., lower P/E may be highlighted as a value metric, while higher ROE is highlighted for profitability). This tool is designed for educational purposes to help investors quickly screen and compare equities.</p>
    </div>

    <div class="content-section">
      <h2>Frequently Asked Questions</h2>

      <div class="faq-item">
        <h3>How do you compare two stocks side by side?</h3>
        <p>To compare two stocks side by side, look at key financial metrics such as the Price-to-Earnings (P/E) ratio, Dividend Yield, Market Capitalization, Return on Equity (ROE), and Revenue Growth. Our stock comparison tool automatically aligns these metrics for any two tickers so you can evaluate their relative valuation and performance.</p>
      </div>

      <div class="faq-item">
        <h3>Which is better: high P/E or low P/E?</h3>
        <p>A low P/E ratio may indicate that a stock is undervalued compared to its earnings, which appeals to value investors. A high P/E ratio often suggests that investors expect higher future growth, typical of growth stocks. The 'better' choice depends on your investment strategy and the industry average.</p>
      </div>

      <div class="faq-item">
        <h3>How to choose between two similar stocks?</h3>
        <p>When choosing between two similar stocks, compare their valuation (P/E, P/B), profitability (Profit Margin, ROE), growth (Revenue Growth), and risk (Beta). Additionally, consider their dividend yield if you are seeking income, and review their historical 52-week price range.</p>
      </div>

      <div class="faq-item">
        <h3>What is a good ROE for a stock?</h3>
        <p>A good Return on Equity (ROE) is typically around 15% to 20%, though it varies significantly by industry. A higher ROE indicates that a company is more efficient at generating profit from its shareholders' equity.</p>
      </div>

      <div class="faq-item">
        <h3>Why compare stock market caps?</h3>
        <p>Comparing market capitalization helps you understand the size and stability of the companies. Large-cap stocks are generally more stable and often pay dividends, while small-cap stocks might offer higher growth potential but come with greater risk and volatility.</p>
      </div>
    </div>
  </div>
