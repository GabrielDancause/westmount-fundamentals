    let chartInstance = null;

    function formatNumber(num, isPercent = false, isCurrency = false, isCap = false) {
      if (num === null || num === undefined || isNaN(num)) return 'N/A';

      if (isCap) {
        if (num >= 1e12) return '$' + (num / 1e12).toFixed(2) + 'T';
        if (num >= 1e9) return '$' + (num / 1e9).toFixed(2) + 'B';
        if (num >= 1e6) return '$' + (num / 1e6).toFixed(2) + 'M';
        return '$' + num.toLocaleString();
      }

      if (isPercent) return num.toFixed(2) + '%';
      if (isCurrency) return '$' + num.toFixed(2);

      return num.toLocaleString(undefined, { maximumFractionDigits: 2 });
    }

    function highlightWinner(el1, el2, val1, val2, lowerIsBetter = false) {
      el1.classList.remove('winner', 'loser');
      el2.classList.remove('winner', 'loser');

      if (val1 === null || val2 === null || isNaN(val1) || isNaN(val2)) return;

      if (val1 === val2) return;

      const v1Wins = lowerIsBetter ? (val1 < val2) : (val1 > val2);

      if (v1Wins) {
        el1.classList.add('winner');
        el2.classList.add('loser');
      } else {
        el1.classList.add('loser');
        el2.classList.add('winner');
      }
    }

    function compareStocks() {
      const t1 = document.getElementById('ticker1').value.toUpperCase().trim();
      const t2 = document.getElementById('ticker2').value.toUpperCase().trim();
      const errorMsg = document.getElementById('errorMsg');

      if (!t1 || !t2) {
        errorMsg.textContent = 'Please enter two valid ticker symbols.';
        errorMsg.style.display = 'block';
        return;
      }

      const data1 = stockData[t1];
      const data2 = stockData[t2];

      if (!data1 || !data2) {
        const missing = [];
        if (!data1) missing.push(t1);
        if (!data2) missing.push(t2);
        errorMsg.textContent = `Data not found for: ${missing.join(', ')}. Please try major US equities.`;
        errorMsg.style.display = 'block';
        return;
      }

      errorMsg.style.display = 'none';

      // Populate Card 1
      document.getElementById('t1-ticker').textContent = t1;
      document.getElementById('t1-name').textContent = data1.name || t1;

      const pe1 = document.getElementById('t1-pe');
      const pb1 = document.getElementById('t1-pb');
      const div1 = document.getElementById('t1-div');
      const mcap1 = document.getElementById('t1-mcap');
      const rev1 = document.getElementById('t1-rev');
      const margin1 = document.getElementById('t1-margin');
      const roe1 = document.getElementById('t1-roe');
      const beta1 = document.getElementById('t1-beta');
      const range1 = document.getElementById('t1-range');

      pe1.textContent = formatNumber(data1.pe);
      pb1.textContent = formatNumber(data1.pb);
      div1.textContent = formatNumber(data1.div, true);
      mcap1.textContent = formatNumber(data1.mcap, false, false, true);
      rev1.textContent = formatNumber(data1.revGrowth, true);
      margin1.textContent = formatNumber(data1.profitMargin, true);
      roe1.textContent = formatNumber(data1.roe, true);
      beta1.textContent = formatNumber(data1.beta);
      range1.textContent = `${formatNumber(data1.low52, false, true)} - ${formatNumber(data1.high52, false, true)}`;

      // Populate Card 2
      document.getElementById('t2-ticker').textContent = t2;
      document.getElementById('t2-name').textContent = data2.name || t2;

      const pe2 = document.getElementById('t2-pe');
      const pb2 = document.getElementById('t2-pb');
      const div2 = document.getElementById('t2-div');
      const mcap2 = document.getElementById('t2-mcap');
      const rev2 = document.getElementById('t2-rev');
      const margin2 = document.getElementById('t2-margin');
      const roe2 = document.getElementById('t2-roe');
      const beta2 = document.getElementById('t2-beta');
      const range2 = document.getElementById('t2-range');

      pe2.textContent = formatNumber(data2.pe);
      pb2.textContent = formatNumber(data2.pb);
      div2.textContent = formatNumber(data2.div, true);
      mcap2.textContent = formatNumber(data2.mcap, false, false, true);
      rev2.textContent = formatNumber(data2.revGrowth, true);
      margin2.textContent = formatNumber(data2.profitMargin, true);
      roe2.textContent = formatNumber(data2.roe, true);
      beta2.textContent = formatNumber(data2.beta);
      range2.textContent = `${formatNumber(data2.low52, false, true)} - ${formatNumber(data2.high52, false, true)}`;

      // Highlight winners (skip market cap, beta, range as they are subjective)
      highlightWinner(pe1, pe2, data1.pe, data2.pe, true); // Lower PE better
      highlightWinner(pb1, pb2, data1.pb, data2.pb, true); // Lower PB better
      highlightWinner(div1, div2, data1.div, data2.div, false); // Higher Div better
      highlightWinner(rev1, rev2, data1.revGrowth, data2.revGrowth, false); // Higher Rev Growth better
      highlightWinner(margin1, margin2, data1.profitMargin, data2.profitMargin, false); // Higher Margin better
      highlightWinner(roe1, roe2, data1.roe, data2.roe, false); // Higher ROE better

      // Show cards
      document.getElementById('card1').classList.add('active');
      document.getElementById('card2').classList.add('active');

      updateChart(t1, t2, data1, data2);
    }

    function normalize(val, max) {
      if (val === null || val === undefined || max === null || max === 0) return 0;
      return Math.max(0, Math.min(100, (val / max) * 100));
    }

    function updateChart(t1, t2, d1, d2) {
      document.getElementById('chartSection').classList.add('active');

      const ctx = document.getElementById('radarChart').getContext('2d');

      // Calculate relative scores (0-100) for radar chart
      // For PE/PB, lower is better, so we invert.

      const maxDiv = Math.max(d1.div || 0.1, d2.div || 0.1);
      const maxRev = Math.max(d1.revGrowth || 0.1, d2.revGrowth || 0.1);
      const maxMargin = Math.max(d1.profitMargin || 0.1, d2.profitMargin || 0.1);
      const maxRoe = Math.max(d1.roe || 0.1, d2.roe || 0.1);

      // Invert valuation metrics: score = (min / val) * 100
      const minPe = Math.min(d1.pe || 100, d2.pe || 100);
      const minPb = Math.min(d1.pb || 100, d2.pb || 100);

      const s1 = [
        d1.pe ? (minPe / d1.pe) * 100 : 0,
        d1.pb ? (minPb / d1.pb) * 100 : 0,
        normalize(d1.div, maxDiv),
        normalize(d1.revGrowth, maxRev),
        normalize(d1.profitMargin, maxMargin),
        normalize(d1.roe, maxRoe)
      ];

      const s2 = [
        d2.pe ? (minPe / d2.pe) * 100 : 0,
        d2.pb ? (minPb / d2.pb) * 100 : 0,
        normalize(d2.div, maxDiv),
        normalize(d2.revGrowth, maxRev),
        normalize(d2.profitMargin, maxMargin),
        normalize(d2.roe, maxRoe)
      ];

      if (chartInstance) {
        chartInstance.destroy();
      }

      Chart.defaults.color = '#8a9cbd';
      Chart.defaults.font.family = "'Inter', sans-serif";

      chartInstance = new Chart(ctx, {
        type: 'radar',
        data: {
          labels: ['Value (P/E)', 'Value (P/B)', 'Yield', 'Growth', 'Margin', 'ROE'],
          datasets: [
            {
              label: t1,
              data: s1,
              backgroundColor: 'rgba(74, 143, 231, 0.2)',
              borderColor: '#4a8fe7',
              pointBackgroundColor: '#4a8fe7',
              borderWidth: 2
            },
            {
              label: t2,
              data: s2,
              backgroundColor: 'rgba(231, 74, 107, 0.2)',
              borderColor: '#e74a6b',
              pointBackgroundColor: '#e74a6b',
              borderWidth: 2
            }
          ]
        },
        options: {
          responsive: true,
          maintainAspectRatio: false,
          scales: {
            r: {
              angleLines: { color: '#152040' },
              grid: { color: '#152040' },
              pointLabels: { color: '#c8d0de', font: { size: 12, weight: '600' } },
              ticks: { display: false, min: 0, max: 100 }
            }
          },
          plugins: {
            legend: {
              position: 'top',
              labels: { color: '#fff', font: { size: 14, weight: '700' } }
            },
            tooltip: {
              callbacks: {
                label: function(context) {
                  return context.dataset.label + ' Relative Score: ' + Math.round(context.raw);
                }
              }
            }
          }
        }
      });
    }

    document.getElementById('compareBtn').addEventListener('click', compareStocks);
    document.getElementById('ticker1').addEventListener('keypress', (e) => { if(e.key === 'Enter') compareStocks(); });
    document.getElementById('ticker2').addEventListener('keypress', (e) => { if(e.key === 'Enter') compareStocks(); });

    // Table Functionality
    let currentSortColumn = -1;
    let sortAscending = true;

    function initTable() {
      const tbody = document.getElementById('tableBody');
      const searchInput = document.getElementById('tableSearch');

      if (!tbody || typeof stockData !== 'object' || Object.keys(stockData).length === 0) return;

      document.getElementById('tableSection').classList.add('active');

      const rowsHTML = Object.entries(stockData).map(([ticker, data]) => {
        return `
          <tr data-ticker="${ticker}" data-name="${data.name || ''}">
            <td class="mono" style="color: #4a8fe7; cursor: pointer;" onclick="setCompareTicker('${ticker}')">${ticker}</td>
            <td>${data.name || 'N/A'}</td>
            <td class="mono" data-val="${data.pe || 99999}">${formatNumber(data.pe)}</td>
            <td class="mono" data-val="${data.pb || 99999}">${formatNumber(data.pb)}</td>
            <td class="mono" data-val="${data.div || -99999}">${formatNumber(data.div, true)}</td>
            <td class="mono" data-val="${data.mcap || -99999}">${formatNumber(data.mcap, false, false, true)}</td>
            <td class="mono" data-val="${data.revGrowth || -99999}">${formatNumber(data.revGrowth, true)}</td>
            <td class="mono" data-val="${data.profitMargin || -99999}">${formatNumber(data.profitMargin, true)}</td>
            <td class="mono" data-val="${data.roe || -99999}">${formatNumber(data.roe, true)}</td>
          </tr>
        `;
      }).join('');

      tbody.innerHTML = rowsHTML;

      searchInput.addEventListener('input', function(e) {
        const term = e.target.value.toLowerCase();
        const rows = tbody.querySelectorAll('tr');
        rows.forEach(row => {
          const ticker = row.getAttribute('data-ticker').toLowerCase();
          const name = row.getAttribute('data-name').toLowerCase();
          if (ticker.includes(term) || name.includes(term)) {
            row.style.display = '';
          } else {
            row.style.display = 'none';
          }
        });
      });
    }

    function sortTable(colIndex) {
      const table = document.getElementById("dataTable");
      const tbody = document.getElementById("tableBody");
      const rows = Array.from(tbody.querySelectorAll("tr"));

      if (currentSortColumn === colIndex) {
        sortAscending = !sortAscending;
      } else {
        sortAscending = true;
        currentSortColumn = colIndex;
      }

      rows.sort((a, b) => {
        let valA, valB;

        if (colIndex === 0 || colIndex === 1) { // Text columns
          valA = a.cells[colIndex].textContent.trim().toLowerCase();
          valB = b.cells[colIndex].textContent.trim().toLowerCase();
        } else { // Numeric data-val
          valA = parseFloat(a.cells[colIndex].getAttribute('data-val'));
          valB = parseFloat(b.cells[colIndex].getAttribute('data-val'));

          if (isNaN(valA)) valA = sortAscending ? 999999 : -999999;
          if (isNaN(valB)) valB = sortAscending ? 999999 : -999999;
        }

        if (valA < valB) return sortAscending ? -1 : 1;
        if (valA > valB) return sortAscending ? 1 : -1;
        return 0;
      });

      rows.forEach(row => tbody.appendChild(row));
    }

    function setCompareTicker(ticker) {
      const t1 = document.getElementById('ticker1');
      const t2 = document.getElementById('ticker2');
      if (t1.value === '') {
        t1.value = ticker;
      } else if (t2.value === '') {
        t2.value = ticker;
      } else {
        t1.value = t2.value;
        t2.value = ticker;
      }
      compareStocks();
      window.scrollTo({ top: 0, behavior: 'smooth' });
    }

    // Initial setup if data exists and is not just a string placeholder
    if (typeof stockData === 'object' && Object.keys(stockData).length > 0) {
      initTable();
    }
  </script>

  
