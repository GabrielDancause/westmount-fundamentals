  <!-- ═══ SENSITIVITY ANALYSIS ═══ -->
  <h2>Sensitivity Analysis</h2>
  <p>A standard DCF struggles with highly leveraged companies because enterprise value variations cause massive swings in equity value. See how sensitive the intrinsic value is to growth and discount rates below.</p>

  <div class="table-wrap">
    <table class="sensitivity-table">
      <thead>
        <tr>
          <th style="text-align:left">Discount Rate ↓ / Growth →</th>
          {sensitivityGrowth.map(g => (
            <th class={g === growthRatePhase1 ? 'current' : ''}>{(g * 100).toFixed(0)}%</th>
          ))}
        </tr>
      </thead>
      <tbody>
        {sensitivityTable.map(row => (
          <tr>
            <td>{(row.dr * 100).toFixed(1)}%</td>
            {row.values.map((v, i) => (
