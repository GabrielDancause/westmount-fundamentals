---
import SiteLayout from "../layouts/SiteLayout.astro";
import * as cheerio from "cheerio";

export const meta = {
  title: "Western Digital (WDC) Intrinsic Value: A DCF Analysis",
  description: "A transparent, step-by-step discounted cash flow valuation of Western Digital Corp. Using TTM financials to arrive at a single fair value estimate for WDC shares.",
  category: "study",
  published: "2026-03-18",
};

const schema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": "Western Digital (WDC) Intrinsic Value: A DCF Analysis",
  "description": "A transparent, step-by-step discounted cash flow valuation of Western Digital Corp. Using TTM financials to arrive at a single fair value estimate for WDC shares.",
  "datePublished": "2026-03-18",
  "dateModified": "2026-03-18",
  "author": {
    "@type": "Organization",
    "name": "Westmount Research",
    "url": "https://westmountfundamentals.com"
  },
  "publisher": {
    "@type": "Organization",
    "name": "Westmount Research",
    "url": "https://westmountfundamentals.com"
  },
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": "https://westmountfundamentals.com/western-digital-intrinsic-value"
  }
};

/* ═══════════════════════════════════════════════════════════════
   DATA FETCHING & PARSING
   ═══════════════════════════════════════════════════════════════ */

async function fetchHTML(url) {
  try {
    const res = await fetch(url, {
      headers: { 'User-Agent': 'Mozilla/5.0 (Windows NT 10.0; Win64; x64)' }
    });
    if (!res.ok) return null;
    return await res.text();
  } catch (e) {
    return null;
  }
}

const incHtml = await fetchHTML('https://stockanalysis.com/stocks/wdc/financials/');
const cfHtml = await fetchHTML('https://stockanalysis.com/stocks/wdc/financials/cash-flow-statement/');
const bsHtml = await fetchHTML('https://stockanalysis.com/stocks/wdc/financials/balance-sheet/');

let fcfTTM = null;
let sharesOut = null;
let cashEq = null;
let totalDebt = null;
let currentPrice = null;

if (incHtml) {
  const $inc = cheerio.load(incHtml);
  const extractRow = ($, rowName) => {
    let vals = [];
    $('table tbody tr').each((i, el) => {
      const firstTd = $(el).find('td').first().text().trim();
      if (firstTd === rowName) {
        $(el).find('td').each((j, td) => {
          if (j > 0) vals.push($(td).text().trim().replace(/,/g, ''));
        });
      }
    });
    return vals;
  };

  const sharesArr = extractRow($inc, 'Shares Outstanding (Diluted)');
  if (sharesArr.length > 0 && sharesArr[0] !== '-') {
    sharesOut = parseFloat(sharesArr[0]);
  }

  const priceMatches = incHtml.match(/<div class="[^"]*text-4xl[^"]*"[^>]*>([\d\.,]+)<\/div>/);
  if (priceMatches && priceMatches[1]) {
    currentPrice = parseFloat(priceMatches[1].replace(/,/g, ''));
  }
}

if (cfHtml) {
  const $cf = cheerio.load(cfHtml);
  const extractRow = ($, rowName) => {
    let vals = [];
    $('table tbody tr').each((i, el) => {
      const firstTd = $(el).find('td').first().text().trim();
      if (firstTd === rowName) {
        $(el).find('td').each((j, td) => {
          if (j > 0) vals.push($(td).text().trim().replace(/,/g, ''));
        });
      }
    });
    return vals;
  };

  const fcfArr = extractRow($cf, 'Free Cash Flow');
  if (fcfArr.length > 0 && fcfArr[0] !== '-') {
    fcfTTM = parseFloat(fcfArr[0]);
  }
}

if (bsHtml) {
  const $bs = cheerio.load(bsHtml);
  const extractRow = ($, rowName) => {
    let vals = [];
    $('table tbody tr').each((i, el) => {
      const firstTd = $(el).find('td').first().text().trim();
      if (firstTd === rowName) {
        $(el).find('td').each((j, td) => {
          if (j > 0) vals.push($(td).text().trim().replace(/,/g, ''));
        });
      }
    });
    return vals;
  };

  const cashArr = extractRow($bs, 'Cash & Equivalents');
  if (cashArr.length > 0 && cashArr[0] !== '-') {
    cashEq = parseFloat(cashArr[0]);
  }

  const debtArr = extractRow($bs, 'Total Debt');
  if (debtArr.length > 0 && debtArr[0] !== '-') {
    totalDebt = parseFloat(debtArr[0]);
  }
}

const hasData = fcfTTM !== null && sharesOut !== null && cashEq !== null && totalDebt !== null && currentPrice !== null;
const netCash = hasData ? cashEq - totalDebt : 0;

// ASSUMPTIONS
const growthRatePhase1 = 0.08;         // 8% FCF growth, Years 1-5
const growthRateTerminal = 0.03;       // 3% perpetuity growth (terminal)
const discountRate = 0.10;             // 10% WACC / required return (10Y Treasury 4.18%)

const projectedFCF = [];
let pvPhase1 = 0;
let fcfYear6 = 0;
let terminalValue = 0;
let pvTerminalValue = 0;
let enterpriseValue = 0;
let equityValue = 0;
let roundedIV = 0;
let marginOfSafety = 0;
let verdictText = "N/A";
let verdictColor = "#888";

let sensitivityTable = [];
const sensitivityRates = [0.08, 0.09, 0.10, 0.11, 0.12];
const sensitivityGrowth = [0.04, 0.06, 0.08, 0.10, 0.12];

if (hasData) {
  let fcf = fcfTTM;
  for (let yr = 1; yr <= 5; yr++) {
    fcf = fcf * (1 + growthRatePhase1);
    const pvFactor = 1 / Math.pow(1 + discountRate, yr);
    const pvFCF = Math.round(fcf * pvFactor);
    projectedFCF.push({ year: yr, fcf: Math.round(fcf), pvFactor, pvFCF });
    pvPhase1 += pvFCF;
  }

  fcfYear6 = projectedFCF[4].fcf * (1 + growthRateTerminal);
  terminalValue = Math.round(fcfYear6 / (discountRate - growthRateTerminal));
  pvTerminalValue = Math.round(terminalValue * projectedFCF[4].pvFactor);

  enterpriseValue = pvPhase1 + pvTerminalValue;
  equityValue = enterpriseValue + netCash;
  const intrinsicValuePerShare = equityValue / sharesOut;
  roundedIV = Math.round(intrinsicValuePerShare * 100) / 100;

  marginOfSafety = ((roundedIV - currentPrice) / currentPrice * 100).toFixed(1);
  verdictText = roundedIV > currentPrice ? "Undervalued" : "Overvalued";
  verdictColor = roundedIV > currentPrice ? "#10b981" : "#ef4444";

  sensitivityTable = sensitivityRates.map(dr => {
    return {
      dr,
      values: sensitivityGrowth.map(gr => {
        let f = fcfTTM;
        let pSum = 0;
        for (let y = 1; y <= 5; y++) {
          f = f * (1 + gr);
          pSum += f / Math.pow(1 + dr, y);
        }
        const f6 = f * (1 + growthRateTerminal);
        const tv = f6 / (dr - growthRateTerminal);
        const pTV = tv / Math.pow(1 + dr, 5);
        return Math.round((pSum + pTV + netCash) / sharesOut);
      })
    };
  });
}
---

<SiteLayout
  site="westmount"
  title="Western Digital (WDC) Intrinsic Value: A DCF Analysis"
  description="A transparent, step-by-step discounted cash flow valuation of Western Digital Corp. Using TTM financials to arrive at a single fair value estimate for WDC shares."
  canonical="https://westmountfundamentals.com/western-digital-intrinsic-value"
  schema={schema}
>
<style is:global>
@import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800;900&family=JetBrains+Mono:wght@400;700;800&display=swap');
*, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
body { font-family: 'Inter', -apple-system, sans-serif; background: #060a12; color: #c8d0de; line-height: 1.7; }
a { color: #4a8fe7; text-decoration: none; }
a:hover { text-decoration: underline; }
.dcf-wrapper { max-width: 900px; margin: 0 auto; padding: 0 24px; }

/* Header */
.dcf-header { text-align: center; padding: 80px 24px 60px; background: linear-gradient(180deg, #0a1628 0%, #060a12 100%); position: relative; border-bottom: 1px solid #152040; }
.dcf-header::before { content: ''; position: absolute; inset: 0; background: radial-gradient(circle at 50% 40%, rgba(74,143,231,0.06) 0%, transparent 60%); }
.dcf-header-content { position: relative; z-index: 1; }
.dcf-tag { display: inline-block; background: rgba(74,143,231,0.12); color: #4a8fe7; font-size: 0.75rem; font-weight: 800; padding: 6px 16px; border-radius: 20px; letter-spacing: 1.5px; text-transform: uppercase; margin-bottom: 16px; }
.dcf-header h1 { font-size: 2.8rem; font-weight: 900; color: #fff; letter-spacing: -1.2px; margin-bottom: 16px; line-height: 1.1; }
@media (max-width: 640px) { .dcf-header h1 { font-size: 2rem; } }
.dcf-subtitle { color: #7a8a9e; font-size: 1.1rem; max-width: 700px; margin: 0 auto 16px; }
.dcf-date { color: #3a4a60; font-size: 0.85rem; font-weight: 600; letter-spacing: 1px; }
.gemini-credit { color: #4a8fe7; font-size: 0.75rem; font-weight: 700; text-transform: uppercase; letter-spacing: 1px; margin-top: 12px; display: block; }

/* Big verdict */
.verdict-card { max-width: 560px; margin: 60px auto 0; background: linear-gradient(135deg, #0a1628 0%, #0d1830 100%); border: 2px solid #152040; border-radius: 20px; padding: 48px 32px; text-align: center; box-shadow: 0 20px 60px rgba(0,0,0,0.4); position: relative; overflow: hidden; }
.verdict-card::before { content: ''; position: absolute; top: -60%; left: -20%; width: 140%; height: 120%; background: radial-gradient(ellipse, rgba(74,143,231,0.04) 0%, transparent 70%); }
.verdict-label { font-size: 0.8rem; color: #5a6a80; font-weight: 700; text-transform: uppercase; letter-spacing: 2px; margin-bottom: 12px; position: relative; }
.verdict-price { font-family: 'JetBrains Mono', monospace; font-size: 4.5rem; font-weight: 800; color: #fff; line-height: 1; margin-bottom: 8px; position: relative; }
@media (max-width: 640px) { .verdict-price { font-size: 3rem; } }
.verdict-vs { font-size: 0.95rem; color: #5a6a80; margin-bottom: 20px; position: relative; }
.verdict-badge { display: inline-block; padding: 8px 24px; border-radius: 30px; font-weight: 800; font-size: 0.9rem; letter-spacing: 1px; text-transform: uppercase; position: relative; }

/* Sections */
.dcf-wrapper h2 { font-size: 1.8rem; font-weight: 800; color: #fff; margin: 60px 0 20px; letter-spacing: -0.5px; border-bottom: 2px solid #152040; padding-bottom: 12px; }
.dcf-wrapper h3 { font-size: 1.3rem; font-weight: 700; color: #e0e6f0; margin: 32px 0 12px; }
.dcf-wrapper p, .dcf-wrapper li { color: #a0aab8; font-size: 1rem; margin-bottom: 16px; }
.dcf-wrapper ul, .dcf-wrapper ol { padding-left: 24px; }
.dcf-wrapper li { margin-bottom: 8px; }
.dcf-wrapper strong { color: #e0e6f0; }
.highlight { color: #4a8fe7; font-weight: 700; }

/* Methodology */
.method-step { display: flex; gap: 16px; margin-bottom: 24px; padding: 20px; background: #0a1020; border: 1px solid #152040; border-radius: 14px; }
.step-num { width: 40px; height: 40px; background: rgba(74,143,231,0.12); color: #4a8fe7; font-weight: 800; font-size: 1.1rem; border-radius: 50%; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
.step-content { flex: 1; }
.step-content h4 { color: #e0e6f0; font-size: 1rem; margin-bottom: 6px; }
.step-content p { margin-bottom: 0; font-size: 0.9rem; }

/* Assumption cards */
.assumption-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); gap: 16px; margin: 24px 0 40px; }
.assumption-card { background: #0a1020; border: 1px solid #152040; border-radius: 14px; padding: 24px; }
.assumption-card .label { font-size: 0.75rem; color: #5a6a80; font-weight: 700; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 8px; }
.assumption-card .value { font-family: 'JetBrains Mono', monospace; font-size: 2rem; font-weight: 700; color: #fff; margin-bottom: 8px; }
.assumption-card .rationale { font-size: 0.85rem; color: #7a8a9e; line-height: 1.5; }

/* Tables */
.table-wrap { overflow-x: auto; margin: 24px 0 40px; border-radius: 14px; border: 1px solid #152040; background: #0a1020; }
.dcf-wrapper table { width: 100%; border-collapse: collapse; }
.dcf-wrapper th { background: #0d1428; padding: 14px 16px; font-size: 0.75rem; color: #5a6a80; font-weight: 700; text-transform: uppercase; letter-spacing: 1px; text-align: right; border-bottom: 2px solid #152040; white-space: nowrap; }
.dcf-wrapper th:first-child { text-align: left; }
.dcf-wrapper td { padding: 14px 16px; font-size: 0.9rem; color: #c8d0de; text-align: right; border-bottom: 1px solid #0d1428; font-family: 'JetBrains Mono', monospace; }
.dcf-wrapper td:first-child { text-align: left; font-family: 'Inter', sans-serif; color: #a0aab8; font-weight: 600; }
.dcf-wrapper tr:hover td { background: rgba(74,143,231,0.03); }
.row-total td { font-weight: 800; color: #fff; border-top: 2px solid #1a2a40; background: rgba(74,143,231,0.04); }
.dcf-wrapper td.highlight-cell { color: #4a8fe7; font-weight: 700; }

/* Sensitivity */
.sensitivity-table th.current { background: rgba(74,143,231,0.15); color: #4a8fe7; }
.sensitivity-table td.current { background: rgba(74,143,231,0.08); color: #4a8fe7; font-weight: 700; }

/* FAQ */
.faq { margin: 40px 0; }
.faq details { background: #0a1020; border: 1px solid #152040; border-radius: 14px; margin-bottom: 12px; overflow: hidden; }
.faq summary { padding: 18px 20px; cursor: pointer; font-weight: 700; color: #e0e6f0; font-size: 1rem; list-style: none; display: flex; justify-content: space-between; align-items: center; }
.faq summary::after { content: '+'; font-size: 1.2rem; color: #4a8fe7; transition: transform 0.2s; }
.faq details[open] summary::after { content: '−'; }
.faq .faq-answer { padding: 0 20px 18px; font-size: 0.9rem; color: #a0aab8; }

/* Disclaimer */
.disclaimer { margin: 60px 0 60px; padding: 24px; background: rgba(239,68,68,0.05); border: 1px solid rgba(239,68,68,0.15); border-radius: 14px; }
.disclaimer h4 { color: #ef4444; margin-bottom: 8px; font-size: 0.85rem; text-transform: uppercase; letter-spacing: 1px; }
.disclaimer p { font-size: 0.85rem; color: #7a8a9e; margin-bottom: 0; }
.error-state { padding: 60px 24px; text-align: center; color: #ef4444; background: rgba(239,68,68,0.1); border-radius: 14px; margin-top: 40px; }
</style>

<div class="dcf-header">
  <div class="dcf-header-content">
    <div class="dcf-tag">Original Research</div>
    <h1>Western Digital (WDC)<br/>Intrinsic Value</h1>
    <p class="dcf-subtitle">A transparent, two-stage discounted cash flow valuation of Western Digital Corp. using TTM actuals, disclosed assumptions, and one final number.</p>
    <p class="dcf-date">Updated {new Date().toLocaleDateString('en-US', {month: 'long', day: 'numeric', year: 'numeric'})} · Data: TTM Financials</p>
    <span class="gemini-credit">Compiled by Gemini 3.1</span>
  </div>
</div>

<div class="dcf-wrapper">
  {hasData ? (
    <>
      <!-- ═══ THE VERDICT ═══ -->
      <div class="verdict-card">
        <div class="verdict-label">Estimated Intrinsic Value Per Share</div>
        <div class="verdict-price">${roundedIV.toFixed(2)}</div>
        <div class="verdict-vs">vs. market price of ${currentPrice.toFixed(2)} ({marginOfSafety}%)</div>
        <div class="verdict-badge" style={`background: ${verdictColor}22; color: ${verdictColor}; border: 1px solid ${verdictColor}44;`}>
          {verdictText}
        </div>
      </div>

      <!-- ═══ METHODOLOGY ═══ -->
      <h2>Methodology: Two-Stage DCF</h2>
      <p>We use a <strong>two-stage discounted cash flow (DCF)</strong> model — projecting the cash flows of the business and discounting them back to today's value.</p>

      <div class="method-step">
        <div class="step-num">1</div>
        <div class="step-content">
          <h4>Start with actual Free Cash Flow</h4>
          <p>We begin with the Trailing Twelve Months (TTM) Free Cash Flow. For Western Digital, this sits at <strong>${fcfTTM.toLocaleString()} million</strong>.</p>
        </div>
      </div>

      <div class="method-step">
        <div class="step-num">2</div>
        <div class="step-content">
          <h4>Project FCF growth for 5 years (Phase 1)</h4>
          <p>We project FCF to grow at <strong>{(growthRatePhase1 * 100).toFixed(0)}% per year</strong> for the next 5 years, reflecting near-term growth in data storage demands.</p>
        </div>
      </div>

      <div class="method-step">
        <div class="step-num">3</div>
        <div class="step-content">
          <h4>Calculate terminal value (Phase 2)</h4>
          <p>After Year 5, we assume FCF grows at a terminal rate of <strong>{(growthRateTerminal * 100).toFixed(0)}% forever</strong> using the Gordon Growth Model.</p>
        </div>
      </div>

      <div class="method-step">
        <div class="step-num">4</div>
        <div class="step-content">
          <h4>Discount everything to present value</h4>
          <p>All future cash flows are discounted at <strong>{(discountRate * 100).toFixed(0)}%</strong>, factoring in the current 4.18% 10-year Treasury yield and equity risk premiums.</p>
        </div>
      </div>

      <div class="method-step">
        <div class="step-num">5</div>
        <div class="step-content">
          <h4>Add net cash, divide by shares</h4>
          <p>Enterprise Value plus Net Cash (${netCash.toLocaleString()}M) equals Equity Value. We then divide by {sharesOut} million shares outstanding.</p>
        </div>
      </div>

      <!-- ═══ ASSUMPTIONS ═══ -->
      <h2>The Three Assumptions</h2>
      <p>A DCF relies on judgment calls. Here are the three key assumptions driving this valuation.</p>

      <div class="assumption-grid">
        <div class="assumption-card">
          <div class="label">FCF Growth Rate (Years 1-5)</div>
          <div class="value">{(growthRatePhase1 * 100).toFixed(0)}%</div>
          <div class="rationale">
            Western Digital is navigating a cyclical memory market. A growth rate of 8% assumes continued demand recovery in flash and HDD segments as hyperscalers build out infrastructure, balancing historical volatility.
          </div>
        </div>
        <div class="assumption-card">
          <div class="label">Discount Rate (WACC)</div>
          <div class="value">{(discountRate * 100).toFixed(0)}%</div>
          <div class="rationale">
            Using a risk-free rate from the 10Y Treasury (4.18%) plus an equity risk premium suitable for the highly cyclical semiconductor storage space, an elevated 10% WACC demands a rigorous hurdle rate.
          </div>
        </div>
        <div class="assumption-card">
          <div class="label">Terminal Growth Rate</div>
          <div class="value">{(growthRateTerminal * 100).toFixed(0)}%</div>
          <div class="rationale">
            Data storage needs will grow perpetually, but pricing power is limited due to commoditization. A 3% terminal growth rate assumes they expand roughly in line with global long-term GDP.
          </div>
        </div>
      </div>

      <!-- ═══ FCF PROJECTIONS TABLE ═══ -->
      <h2>Projected Free Cash Flows</h2>
      <div class="table-wrap">
        <table>
          <thead>
            <tr>
              <th style="text-align:left">Year</th>
              <th>FCF ($M)</th>
              <th>PV Factor</th>
              <th>Present Value ($M)</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td>Base (TTM)</td>
              <td>${fcfTTM.toLocaleString()}</td>
              <td>—</td>
              <td>—</td>
            </tr>
            {projectedFCF.map(p => (
              <tr>
                <td>Year {p.year}</td>
                <td>${p.fcf.toLocaleString()}</td>
                <td>{p.pvFactor.toFixed(4)}</td>
                <td>${p.pvFCF.toLocaleString()}</td>
              </tr>
            ))}
            <tr class="row-total">
              <td colspan="3">Sum of Phase 1 PV</td>
              <td class="highlight-cell">${pvPhase1.toLocaleString()}</td>
            </tr>
          </tbody>
        </table>
      </div>

      <!-- ═══ TERMINAL VALUE ═══ -->
      <h3>Terminal Value Calculation</h3>
      <div class="table-wrap">
        <table>
          <thead>
            <tr>
              <th style="text-align:left">Component</th>
              <th>Value ($M)</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td>Year 6 FCF (Year 5 × {(1 + growthRateTerminal).toFixed(2)})</td>
              <td>${Math.round(fcfYear6).toLocaleString()}</td>
            </tr>
            <tr>
              <td>Terminal Value (FCF₆ ÷ (WACC − Terminal Growth))</td>
              <td>${terminalValue.toLocaleString()}</td>
            </tr>
            <tr class="row-total">
              <td>PV of Terminal Value</td>
              <td class="highlight-cell">${pvTerminalValue.toLocaleString()}</td>
            </tr>
          </tbody>
        </table>
      </div>

      <!-- ═══ FINAL CALCULATION ═══ -->
      <h3>Final Valuation</h3>
      <div class="table-wrap">
        <table>
          <thead>
            <tr>
              <th style="text-align:left">Component</th>
              <th>Value ($M)</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td>PV of Phase 1 Cash Flows</td>
              <td>${pvPhase1.toLocaleString()}</td>
            </tr>
            <tr>
              <td>PV of Terminal Value</td>
              <td>${pvTerminalValue.toLocaleString()}</td>
            </tr>
            <tr>
              <td>= Enterprise Value</td>
              <td>${enterpriseValue.toLocaleString()}</td>
            </tr>
            <tr>
              <td>+ Net Cash (Cash − Debt)</td>
              <td>${netCash.toLocaleString()}</td>
            </tr>
            <tr>
              <td>= Equity Value</td>
              <td>${equityValue.toLocaleString()}</td>
            </tr>
            <tr>
              <td>÷ Shares Outstanding</td>
              <td>{sharesOut.toLocaleString()}</td>
            </tr>
            <tr class="row-total">
              <td>Intrinsic Value Per Share</td>
              <td class="highlight-cell">${roundedIV.toFixed(2)}</td>
            </tr>
          </tbody>
        </table>
      </div>

      <!-- ═══ SENSITIVITY ANALYSIS ═══ -->
      <h2>Sensitivity Analysis</h2>
      <p>Values change significantly based on our assumptions. Below is a 5x5 matrix showing Intrinsic Value across different Discount Rates (WACC) and Phase 1 Growth Rates.</p>

      <div class="table-wrap">
        <table class="sensitivity-table">
          <thead>
            <tr>
              <th style="text-align:left">Discount Rate ↓ / Growth →</th>
              {sensitivityGrowth.map(g => (
                <th class={g === growthRatePhase1 ? 'current' : ''}>{(g * 100).toFixed(0)}%</th>
              ))}
            </tr>
          </thead>
          <tbody>
            {sensitivityTable.map(row => (
              <tr>
                <td>{(row.dr * 100).toFixed(0)}%</td>
                {row.values.map((v, i) => (
                  <td class={row.dr === discountRate && sensitivityGrowth[i] === growthRatePhase1 ? 'current' : ''}>
                    ${v}
                  </td>
                ))}
              </tr>
            ))}
          </tbody>
        </table>
      </div>

      <!-- ═══ RISKS ═══ -->
      <h2>Risks to this Valuation</h2>
      <ul>
        <li><strong>Cyclicality:</strong> Memory and storage markets are notoriously boom-and-bust. If a downturn arrives faster than anticipated, TTM FCF could overstate long-term normalized cash generation.</li>
        <li><strong>Capex Requirements:</strong> Transitioning to new NAND layers or HDD technologies requires immense capital expenditures which directly eat into Free Cash Flow.</li>
        <li><strong>Competition:</strong> WDC faces aggressive competition from Samsung, SK Hynix, and Micron, which can lead to pricing pressure.</li>
        <li><strong>Spinoff Uncertainty:</strong> Structural changes to the business (e.g., splitting flash and HDD) could dramatically alter cash flow profiles and terminal value assumptions.</li>
      </ul>

