    };

    const managedEl = document.getElementById('managedValue');
    const diyEl = document.getElementById('diyValue');
    const diffEl = document.getElementById('feeDifference');

    if (managedEl) managedEl.textContent = formatCurrency(managedBalance);
    if (diyEl) diyEl.textContent = formatCurrency(diyBalance);
    if (diffEl) diffEl.textContent = formatCurrency(feeDifference);
  }

  function initCalculator() {
    const inputs = ['initialInvestment', 'annualContribution', 'years', 'annualReturn', 'pmFee', 'diyFee'];
    inputs.forEach(id => {
      const el = document.getElementById(id);
      if (el) {
        el.addEventListener('input', calculateFees);
      }
    });
    calculateFees();
  }

  // Initialize on load and on Astro view transitions
  document.addEventListener('astro:page-load', initCalculator);
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initCalculator);
  } else {
    initCalculator();
  }
</script>
