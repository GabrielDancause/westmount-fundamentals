/* ═══════════════════════════════════════════════════════════════
   DATA FETCHING BLOCK - YFINANCE (Bypassing 403 Forbidden on stockanalysis.com)
   ═══════════════════════════════════════════════════════════════ */
const pythonScript = `
import json
import subprocess
import sys
import logging

logging.disable(logging.CRITICAL)

def install_and_import(package):
    try:
        __import__(package)
    except ImportError:
        subprocess.check_call([sys.executable, "-m", "pip", "install", package, "--quiet"])

install_and_import('yfinance')
import yfinance as yf

ticker = yf.Ticker("EMR")
info = ticker.info

try:
    df_fin = ticker.financials
    df_cf = ticker.cashflow
    df_bs = ticker.balance_sheet

    years = df_fin.columns.strftime('%Y').tolist() if not df_fin.empty else []

    def get_row(df, row_name):
        try:
            return df.loc[row_name].tolist()
        except KeyError:
            return []

    data = {
        'price': info.get('currentPrice'),
        'sharesOutstanding': info.get('sharesOutstanding'),
        'totalCash': info.get('totalCash'),
        'totalDebt': info.get('totalDebt'),
        'beta': info.get('beta'),
        'years': years,
        'revenue': get_row(df_fin, 'Total Revenue'),
        'netIncome': get_row(df_fin, 'Net Income'),
        'operatingIncome': get_row(df_fin, 'Operating Income'),
        'fcf': get_row(df_cf, 'Free Cash Flow'),
        'operatingCashFlow': get_row(df_cf, 'Operating Cash Flow'),
        'eps': get_row(df_fin, 'Diluted EPS')
    }

    # Clean nan to None
    for key in data:
        if isinstance(data[key], list):
            data[key] = [None if str(x) == 'nan' else x for x in data[key]]

    print(json.dumps(data))
except Exception as e:
    print(json.dumps({"error": str(e)}))
`;

let fetchedData: any = {};
try {
  const result = execSync(`python3 -c "${pythonScript.replace(/"/g, '\\"')}"`, { stdio: ['pipe', 'pipe', 'ignore'] });
  fetchedData = JSON.parse(result.toString());
} catch (e) {
  console.error("Failed to fetch EMR data using yfinance:", e);
}

// Fallbacks "null over fake data"
const currentPrice = fetchedData.price !== undefined ? fetchedData.price : null;
const sharesOutstandingRaw = fetchedData.sharesOutstanding !== undefined ? fetchedData.sharesOutstanding : null;
const cashAndInvestmentsRaw = fetchedData.totalCash !== undefined ? fetchedData.totalCash : null;
const totalDebtRaw = fetchedData.totalDebt !== undefined ? fetchedData.totalDebt : null;
const beta = fetchedData.beta !== undefined ? fetchedData.beta : null;

// Extracted historical arrays
const yearsRaw = fetchedData.years || [];
const revArray = fetchedData.revenue || [];
const fcfArray = fetchedData.fcf || [];
const epsArray = fetchedData.eps || [];
const opIncArray = fetchedData.operatingIncome || [];

// Convert scale to Millions for consistency with our calculations
const sharesOutstanding = sharesOutstandingRaw !== null ? sharesOutstandingRaw / 1e6 : null;
const cashAndInvestments = cashAndInvestmentsRaw !== null ? cashAndInvestmentsRaw / 1e6 : null;
const totalDebt = totalDebtRaw !== null ? totalDebtRaw / 1e6 : null;

// Base FCF for DCF Model
// We take the most recent full year FCF
let fcfBaseRaw = fcfArray.length > 0 ? fcfArray[0] : null;
// If the most recent is null, try the next one
if (fcfBaseRaw === null && fcfArray.length > 1) {
  fcfBaseRaw = fcfArray[1];
}
const fcfBase = fcfBaseRaw !== null ? fcfBaseRaw / 1e6 : null;

// Net Cash
const netCash = cashAndInvestments !== null && totalDebt !== null ? cashAndInvestments - totalDebt : null;

/* ═══════════════════════════════════════════════════════════════
   DCF MODEL — ALL INPUTS AND CALCULATIONS
   We use a two-stage DCF: high-growth phase (Years 1-5) then terminal value.
   ═══════════════════════════════════════════════════════════════ */

// --- ASSUMPTIONS ---
const riskFreeRate = 0.0418; // 10Y Treasury: 4.18%
const equityRiskPremium = 0.055; // 5.5% ERP
const costOfEquity = riskFreeRate + (beta !== null ? beta * equityRiskPremium : 1.2 * equityRiskPremium);
const discountRate = Math.round(costOfEquity * 100) / 100; // Expected to be ~11% (4.18 + 1.24*5.5 = 11.0%)

const growthRatePhase1 = 0.08;         // 8% FCF growth, Years 1-5 (Conservative estimate for an industrial tech leader)
const growthRateTerminal = 0.025;      // 2.5% perpetuity growth (terminal - modest for mature industrial)

// --- PHASE 1: PROJECT FCF FOR YEARS 1-5 ---
const projectedFCF = [];
let fcf = fcfBase;
if (fcf !== null && fcf > 0) {
  for (let yr = 1; yr <= 5; yr++) {
    fcf = fcf * (1 + growthRatePhase1);
    projectedFCF.push({ year: yr, fcf: Math.round(fcf), pvFactor: 1 / Math.pow(1 + discountRate, yr) });
  }
  projectedFCF.forEach(p => { p.pvFCF = Math.round(p.fcf * p.pvFactor); });
} else {
    // If fcf is negative or null, model breaks. We populate with nulls.
    for (let yr = 1; yr <= 5; yr++) {
        projectedFCF.push({ year: yr, fcf: null, pvFactor: 1 / Math.pow(1 + discountRate, yr), pvFCF: null });
    }
}

// --- PHASE 2: TERMINAL VALUE (Gordon Growth Model) ---
let fcfYear6 = null;
let terminalValue = null;
let pvTerminalValue = null;
if (projectedFCF.length > 4 && projectedFCF[4].fcf !== null) {
    fcfYear6 = projectedFCF[4].fcf * (1 + growthRateTerminal);
    terminalValue = Math.round(fcfYear6 / (discountRate - growthRateTerminal));
    pvTerminalValue = Math.round(terminalValue * projectedFCF[4].pvFactor);
}

// --- ENTERPRISE VALUE ---
let pvPhase1 = null;
if (projectedFCF.length > 0 && projectedFCF[0].pvFCF !== null) {
    pvPhase1 = projectedFCF.reduce((sum, p) => sum + p.pvFCF, 0);
}
const enterpriseValue = pvPhase1 !== null && pvTerminalValue !== null ? pvPhase1 + pvTerminalValue : null;

// --- EQUITY VALUE ---
const equityValue = enterpriseValue !== null && netCash !== null ? enterpriseValue + netCash : null;
const intrinsicValuePerShare = equityValue !== null && sharesOutstanding !== null ? equityValue / sharesOutstanding : null;
const roundedIV = intrinsicValuePerShare !== null ? Math.round(intrinsicValuePerShare * 100) / 100 : null;

// Market comparison
const marginOfSafety = (roundedIV !== null && currentPrice !== null) ? (((roundedIV - currentPrice) / currentPrice) * 100).toFixed(1) : null;
const verdictText = roundedIV !== null && currentPrice !== null ? (roundedIV > currentPrice ? "Undervalued" : "Overvalued") : "N/A";
const verdictColor = verdictText === "Undervalued" ? "#10b981" : (verdictText === "Overvalued" ? "#ef4444" : "#7a8a9e");

// --- HISTORICAL DATA for charts ---
const revenueHistory = [];
const fcfHistory = [];
const epsHistory = [];
const marginHistory = [];

if (yearsRaw.length > 0) {
    // reverse to get chronological order
    const numYears = Math.min(yearsRaw.length, 5);
    for (let i = numYears - 1; i >= 0; i--) {
        revenueHistory.push({
            year: yearsRaw[i],
            value: revArray[i] !== null ? revArray[i] / 1e6 : null
        });
        fcfHistory.push({
            year: yearsRaw[i],
            value: fcfArray[i] !== null ? fcfArray[i] / 1e6 : null
        });
        epsHistory.push({
            year: yearsRaw[i],
            value: epsArray[i] !== null ? epsArray[i] : null
        });

        // margins
        const rev = revArray[i];
        const opInc = opIncArray[i];
        const fcfVal = fcfArray[i];

        const opMargin = rev !== null && rev > 0 && opInc !== null ? ((opInc / rev) * 100).toFixed(1) : null;
        const fcfMargin = rev !== null && rev > 0 && fcfVal !== null ? ((fcfVal / rev) * 100).toFixed(1) : null;

        marginHistory.push({
            year: yearsRaw[i],
            operating: opMargin,
            fcfMargin: fcfMargin
        });
    }
}

// Sensitivity analysis
const sensitivityRates = [discountRate - 0.02, discountRate - 0.01, discountRate, discountRate + 0.01, discountRate + 0.02];
const sensitivityGrowth = [growthRatePhase1 - 0.04, growthRatePhase1 - 0.02, growthRatePhase1, growthRatePhase1 + 0.02, growthRatePhase1 + 0.04];
const sensitivityTable = sensitivityRates.map(dr => {
  return {
    dr: Math.round(dr * 100) / 100,
    values: sensitivityGrowth.map(gr => {
      if (fcfBase === null || sharesOutstanding === null || netCash === null) return null;
      let f = fcfBase;
      let pvSum = 0;
      for (let y = 1; y <= 5; y++) {
        f = f * (1 + gr);
        pvSum += f / Math.pow(1 + dr, y);
      }
      const f6 = f * (1 + growthRateTerminal);
      const tv = f6 / (dr - growthRateTerminal);
      const pvTV = tv / Math.pow(1 + dr, 5);
      return Math.round((pvSum + pvTV + netCash) / sharesOutstanding);
    })
  };
});

// Most recent revenue for chart scaling
const maxRev = revenueHistory.length > 0 ? Math.max(...revenueHistory.filter(r => r.value !== null).map(r => r.value)) : 100000;
const maxFcf = fcfHistory.length > 0 ? Math.max(...fcfHistory.filter(r => r.value !== null).map(r => r.value)) : 10000;
const maxEps = epsHistory.length > 0 ? Math.max(...epsHistory.filter(r => r.value !== null).map(r => r.value)) : 10;
const latestYearRev = revenueHistory.length > 0 && revenueHistory[revenueHistory.length - 1].value !== null ? revenueHistory[revenueHistory.length - 1].value : 0;
const latestYearFcf = fcfHistory.length > 0 && fcfHistory[fcfHistory.length - 1].value !== null ? fcfHistory[fcfHistory.length - 1].value : 0;
const latestYearEps = epsHistory.length > 0 && epsHistory[epsHistory.length - 1].value !== null ? epsHistory[epsHistory.length - 1].value : 0;
