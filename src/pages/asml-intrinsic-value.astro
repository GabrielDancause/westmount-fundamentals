---
import SiteLayout from '../layouts/SiteLayout.astro';

// --- METADATA ---
export const meta = {
  title: "ASML Holding N.V. (ASML) Intrinsic Value",
  description: "An independent discounted cash flow (DCF) intrinsic value analysis of ASML Holding N.V. (ASML) compiled entirely by Gemini 2.5 Pro.",
  category: "study",
  published: "2026-03-18",
};

// --- DATA & ASSUMPTIONS (Most recent fiscal year actuals) ---
// The prompt requires me to make bold assumptions as Gemini 2.5 Pro.
// FCF Growth (Y1-Y5): 16%. ASML holds a functional monopoly on EUV lithography.
// Discount Rate (WACC): 8.8%. Reflecting slight geographical/political risk (China export controls) offset by their absolute dominance in advanced semiconductor manufacturing equipment.
// Terminal Growth: 3.5%. Semiconductors are a secular growth trend, but tied to GDP over the longest term.

const baseFCF = 10854.94; // in Millions, based on $10,854,937,600 from yfinance
const sharesOut = 385.42; // in Millions, based on 385,417,665
const currentPrice = 1376.30; // yfinance
const netCash = 8631.70; // Cash & ST investments (13322) - Total Debt (4690) in millions

const fcfGrowthRate = 0.16;
const discountRate = 0.088;
const terminalGrowthRate = 0.035;

// --- YEAR 1 TO 5 PROJECTIONS ---
const projections = [];
let prevFCF = baseFCF;

for (let i = 1; i <= 5; i++) {
  const projectedFCF = prevFCF * (1 + fcfGrowthRate);
  const discountFactor = Math.pow(1 + discountRate, i);
  const pvOfFCF = projectedFCF / discountFactor;

  projections.push({
    year: `Year ${i}`,
    fcf: projectedFCF,
    pv: pvOfFCF
  });

  prevFCF = projectedFCF;
}

const sumPvFcf = projections.reduce((sum, p) => sum + p.pv, 0);

// --- TERMINAL VALUE ---
const year5FCF = projections[4].fcf;
const terminalValue = (year5FCF * (1 + terminalGrowthRate)) / (discountRate - terminalGrowthRate);
const pvTerminalValue = terminalValue / Math.pow(1 + discountRate, 5);

// --- INTRINSIC VALUE CALCULATION ---
const enterpriseValue = sumPvFcf + pvTerminalValue;
const totalEquityValue = enterpriseValue + netCash;
const intrinsicValuePerShare = totalEquityValue / sharesOut;

// Value vs Current Price
const marginOfSafety = ((intrinsicValuePerShare - currentPrice) / currentPrice) * 100;
const isUndervalued = intrinsicValuePerShare > currentPrice;

// --- SENSITIVITY MATRIX ---
const sensitivityDiscountRates = [0.078, 0.083, 0.088, 0.093, 0.098];
const sensitivityGrowthRates = [0.025, 0.030, 0.035, 0.040, 0.045];

const sensitivityMatrix = sensitivityGrowthRates.map(g => {
  return {
    growthRate: g,
    values: sensitivityDiscountRates.map(d => {
      // Re-calculate TV and PV with new rates
      const currentTerminalValue = (year5FCF * (1 + g)) / (d - g);
      const currentPvTerminalValue = currentTerminalValue / Math.pow(1 + d, 5);

      // Re-calculate PV of FCFs with new discount rate
      let currentSumPvFcf = 0;
      let tempFcf = baseFCF;
      for (let i = 1; i <= 5; i++) {
        tempFcf = tempFcf * (1 + fcfGrowthRate);
        currentSumPvFcf += tempFcf / Math.pow(1 + d, i);
      }

      const currentEV = currentSumPvFcf + currentPvTerminalValue;
      const currentEquity = currentEV + netCash;
      const currentIV = currentEquity / sharesOut;

      return currentIV;
    })
  };
});

// Formatting helpers
const formatMoney = (val) => new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD', minimumFractionDigits: 2, maximumFractionDigits: 2 }).format(val);
const formatMillions = (val) => '$' + new Intl.NumberFormat('en-US', { maximumFractionDigits: 0 }).format(val) + 'M';
const formatPercent = (val) => (val * 100).toFixed(1) + '%';

// --- SCHEMA ---
const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Article",
      "headline": meta.title,
      "description": meta.description,
      "author": {
        "@type": "Organization",
        "name": "Gemini 2.5 Pro"
      },
      "publisher": {
        "@type": "Organization",
        "name": "Westmount Fundamentals",
        "logo": {
          "@type": "ImageObject",
          "url": "https://westmountfundamentals.com/logo.png"
        }
      },
      "mainEntityOfPage": {
        "@type": "WebPage",
        "@id": "https://westmountfundamentals.com/asml-intrinsic-value"
      }
    },
    {
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "Why did Gemini project a 16% FCF growth rate for ASML?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "ASML operates a functional monopoly in EUV lithography. With the explosion of AI data center needs, fabs worldwide are required to purchase ASML's cutting-edge machines (High-NA EUV) regardless of price. A 16% free cash flow expansion conservatively prices in this guaranteed demand over the next half-decade."
          }
        },
        {
          "@type": "Question",
          "name": "What discount rate was used for ASML's valuation?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "An 8.8% discount rate was selected. This is slightly elevated compared to a completely dominant U.S. tech giant, reflecting some geopolitical risk regarding export bans to China, balanced against their technological monopoly and solid balance sheet."
          }
        },
        {
          "@type": "Question",
          "name": "Is ASML overvalued according to the AI DCF model?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Based on Gemini 2.5 Pro's model, it calculates a specific intrinsic value indicating whether the current market price of $1,376 is overvalued or undervalued relative to its expected cash flows."
          }
        }
      ]
    }
  ]
};
---
<SiteLayout site="westmount" title={meta.title} description={meta.description} canonical="https://westmountfundamentals.com/asml-intrinsic-value" schema={schema}>
  <div class="page-content">
    <div class="container">

      <div class="gemini-header">
        <div class="gemini-badge">COMPILED BY GEMINI 2.5 PRO</div>
        <h1>ASML Holding N.V. (ASML) Intrinsic Value</h1>
        <p class="subtitle">An independent two-stage DCF analysis of the EUV monopoly.</p>
      </div>

      <div class="verdict-card">
        <div class="verdict-header">
          <h2>Fair Value Estimate</h2>
        </div>
        <div class="verdict-body">
          <div class="verdict-main">
            <span class="iv-value">{formatMoney(intrinsicValuePerShare)}</span>
            <span class="iv-label">per share</span>
          </div>
          <div class="verdict-stats">
            <div class="stat">
              <span class="stat-label">Current Price</span>
              <span class="stat-value">{formatMoney(currentPrice)}</span>
            </div>
            <div class="stat">
              <span class="stat-label">Margin of Safety</span>
              <span class={`stat-value ${isUndervalued ? 'positive' : 'negative'}`}>
                {isUndervalued ? '+' : ''}{marginOfSafety.toFixed(2)}%
              </span>
            </div>
            <div class="stat">
              <span class="stat-label">Verdict</span>
              <span class={`badge ${isUndervalued ? 'positive' : 'negative'}`}>
                {isUndervalued ? 'UNDERVALUED' : 'OVERVALUED'}
              </span>
            </div>
          </div>
        </div>
        <div class="verdict-footer">
          <p>Based on most recent fiscal year actuals. Market data via Yahoo Finance (Mar 18, 2026).</p>
        </div>
      </div>

      <section class="content-section">
        <h2>The AI Thesis: Why ASML is the True Pick-and-Shovel</h2>
        <p>While the market endlessly debates the margins of cloud providers and the longevity of Nvidia's hardware dominance, they consistently overlook the foundational layer of the entire technological pyramid: ASML. No AI chips, no smartphones, and no advanced data centers exist without Extreme Ultraviolet (EUV) lithography. <strong>ASML does not have a competitive advantage; it has an absolute, functional monopoly on this technology.</strong></p>
        <p>As the world scrambles to build localized semiconductor supply chains (via the CHIPS Act globally) and compute density demands surge into the High-NA EUV era, TSMC, Samsung, and Intel are forced to buy ASML's machines regardless of their multi-hundred-million-dollar price tags. This valuation is built not on hopeful revenue expansion, but on inevitable, trapped demand.</p>
      </section>

      <section class="content-section">
        <h2>My Assumptions & Rationale</h2>

        <div class="assumption-grid">
          <div class="assumption-card">
            <div class="card-title">FCF Growth Rate (Y1-Y5)</div>
            <div class="card-value">{formatPercent(fcfGrowthRate)}</div>
            <p><strong>Rationale:</strong> 16% free cash flow growth is a conservative baseline for a monopoly during a capital expenditure supercycle. The transition to High-NA EUV systems (costing $350M+ each) combined with immense installed-base management services ensures sticky, high-margin revenue that drops directly to the bottom line.</p>
          </div>

          <div class="assumption-card">
            <div class="card-title">Discount Rate (WACC)</div>
            <div class="card-value">{formatPercent(discountRate)}</div>
            <p><strong>Rationale:</strong> An 8.8% discount rate balances their pricing power against macro-political friction. While their balance sheet is pristine (net cash positive), the constant threat of U.S. and Dutch export controls regarding legacy DUV equipment sales to China introduces an unquantifiable tail-risk that requires a slight premium over pure U.S. domestic tech.</p>
          </div>

          <div class="assumption-card">
            <div class="card-title">Terminal Growth Rate</div>
            <div class="card-value">{formatPercent(terminalGrowthRate)}</div>
            <p><strong>Rationale:</strong> 3.5% slightly outpaces global GDP growth. The semiconductor industry is cyclical, but secularly expanding as computation becomes a basic utility akin to electricity. Over the longest timeframe, ASML will grow slightly faster than the global economy they power.</p>
          </div>
        </div>
      </section>

      <section class="content-section">
        <h2>Discounted Cash Flow (DCF) Projections</h2>
        <p>Starting with a base FCF of {formatMillions(baseFCF)}, the table below projects the next 5 years, discounting the cash flows back to Present Value (PV) using the {formatPercent(discountRate)} WACC.</p>

        <div class="table-container">
          <table>
            <thead>
              <tr>
                <th>Period</th>
                <th>Projected FCF</th>
                <th>PV Factor ({formatPercent(discountRate)})</th>
                <th>Present Value</th>
              </tr>
            </thead>
            <tbody>
              {projections.map((p, index) => (
                <tr>
                  <td>{p.year}</td>
                  <td>{formatMillions(p.fcf)}</td>
                  <td>{(1 / Math.pow(1 + discountRate, index + 1)).toFixed(4)}</td>
                  <td>{formatMillions(p.pv)}</td>
                </tr>
              ))}
              <tr class="highlight-row">
                <td colspan="3"><strong>Sum of PV of FCFs (Years 1-5)</strong></td>
                <td><strong>{formatMillions(sumPvFcf)}</strong></td>
              </tr>
            </tbody>
          </table>
        </div>
      </section>

      <section class="content-section">
        <h2>Terminal & Final Valuation Math</h2>
        <p>The Terminal Value accounts for cash flows into perpetuity past Year 5, calculated via the Gordon Growth Model.</p>

        <div class="math-card">
          <div class="math-row">
            <span>Year 5 FCF</span>
            <span>{formatMillions(year5FCF)}</span>
          </div>
          <div class="math-row">
            <span>Terminal Value Calculation</span>
            <span>({formatMillions(year5FCF)} * {1 + terminalGrowthRate}) / ({discountRate} - {terminalGrowthRate})</span>
          </div>
          <div class="math-row">
            <span>Terminal Value</span>
            <span>{formatMillions(terminalValue)}</span>
          </div>
          <div class="math-row highlight">
            <span>PV of Terminal Value</span>
            <span>{formatMillions(pvTerminalValue)}</span>
          </div>
        </div>

        <p style="margin-top: 2rem;">Synthesizing the Enterprise Value and Equity Value:</p>

        <div class="math-card">
          <div class="math-row">
            <span>Sum of PV of FCFs (Years 1-5)</span>
            <span>{formatMillions(sumPvFcf)}</span>
          </div>
          <div class="math-row">
            <span>+ PV of Terminal Value</span>
            <span>{formatMillions(pvTerminalValue)}</span>
          </div>
          <div class="math-row">
            <span><strong>= Enterprise Value</strong></span>
            <span><strong>{formatMillions(enterpriseValue)}</strong></span>
          </div>
          <div class="math-row">
            <span>+ Net Cash (Cash - Debt)</span>
            <span>{formatMillions(netCash)}</span>
          </div>
          <div class="math-row highlight">
            <span><strong>= Total Equity Value</strong></span>
            <span><strong>{formatMillions(totalEquityValue)}</strong></span>
          </div>
          <div class="math-row">
            <span>÷ Shares Outstanding</span>
            <span>{sharesOut.toLocaleString()}M</span>
          </div>
          <div class="math-row result">
            <span><strong>Intrinsic Value Per Share</strong></span>
            <span><strong>{formatMoney(intrinsicValuePerShare)}</strong></span>
          </div>
        </div>
      </section>

      <section class="content-section">
        <h2>Sensitivity Matrix</h2>
        <p>Below is a stress test of my assumptions. The intrinsic value fluctuates based on the discount rate required by an investor and the terminal growth rate at the end of the 5-year high-growth period.</p>

        <div class="table-container sensitivity-table">
          <table>
            <thead>
              <tr>
                <th rowspan="2" class="corner-cell">Terminal<br/>Growth</th>
                <th colspan="5" class="header-cell">Discount Rate (WACC)</th>
              </tr>
              <tr>
                {sensitivityDiscountRates.map(d => <th>{formatPercent(d)}</th>)}
              </tr>
            </thead>
            <tbody>
              {sensitivityMatrix.map(row => (
                <tr>
                  <th class="row-header">{formatPercent(row.growthRate)}</th>
                  {row.values.map(val => (
                    <td class={
                      val > currentPrice * 1.15 ? "cell-undervalued" :
                      val < currentPrice * 0.85 ? "cell-overvalued" :
                      "cell-neutral"
                    }>
                      {formatMoney(val)}
                    </td>
                  ))}
                </tr>
              ))}
            </tbody>
          </table>
          <div class="matrix-legend">
            <span class="legend-item"><span class="color-box cell-undervalued"></span> Undervalued (>15% Margin)</span>
            <span class="legend-item"><span class="color-box cell-neutral"></span> Fair Value</span>
            <span class="legend-item"><span class="color-box cell-overvalued"></span> Overvalued (&lt;-15% Margin)</span>
          </div>
        </div>
      </section>

      <section class="content-section risks-section">
        <h2>Key Risks & Bear Case</h2>
        <p>Even monopolies have vulnerabilities. My bullish valuation faces three primary threats:</p>
        <div class="risk-grid">
          <div class="risk-card">
            <h3>1. Geopolitical Export Bans</h3>
            <p>ASML is heavily restricted from selling its most advanced EUV tech to China. If the US or Dutch governments expand these restrictions to legacy DUV equipment or spare parts, it could rapidly destroy a significant margin of their trailing revenue base.</p>
          </div>
          <div class="risk-card">
            <h3>2. Foundry Capital Expenditure Cycles</h3>
            <p>While demand is secularly up, TSMC, Intel, and Samsung occasionally pause their fab build-outs due to short-term oversupply of memory or logic chips. A unified delay in orders from the "Big 3" would crash cash flows for a fiscal year.</p>
          </div>
          <div class="risk-card">
            <h3>3. The Law of Large Numbers</h3>
            <p>Scaling a machine that costs $350 million is inherently difficult. Supply chain bottlenecks for highly specialized lenses (Zeiss) and lasers could cap ASML's ability to actually fulfill the 16% growth order backlog.</p>
          </div>
        </div>
      </section>

      <section class="content-section faq-section">
        <h2>Frequently Asked Questions</h2>

        <div class="faq-item">
          <h3>Why did Gemini project a 16% FCF growth rate for ASML?</h3>
          <p>ASML operates a functional monopoly in EUV lithography. With the explosion of AI data center needs, fabs worldwide are required to purchase ASML's cutting-edge machines (High-NA EUV) regardless of price. A 16% free cash flow expansion conservatively prices in this guaranteed demand over the next half-decade.</p>
        </div>

        <div class="faq-item">
          <h3>What discount rate was used for ASML's valuation?</h3>
          <p>An 8.8% discount rate was selected. This is slightly elevated compared to a completely dominant U.S. tech giant, reflecting some geopolitical risk regarding export bans to China, balanced against their technological monopoly and solid balance sheet.</p>
        </div>

        <div class="faq-item">
          <h3>Is ASML overvalued according to the AI DCF model?</h3>
          <p>Based on Gemini 2.5 Pro's model, it calculates a specific intrinsic value of {formatMoney(intrinsicValuePerShare)}, which indicates that relative to the current market price of {formatMoney(currentPrice)}, the stock is {isUndervalued ? 'undervalued' : 'overvalued'} by {Math.abs(marginOfSafety).toFixed(2)}%.</p>
        </div>
      </section>

      <div class="disclaimer-box">
        <p><strong>Disclaimer:</strong> The financial modeling and commentary on this page are generated by an Artificial Intelligence (Gemini 2.5 Pro) for educational and entertainment purposes. This is purely theoretical mathematical output and does not constitute financial or investment advice. Always consult a certified professional before allocating capital.</p>
      </div>

    </div>
  </div>
</SiteLayout>
