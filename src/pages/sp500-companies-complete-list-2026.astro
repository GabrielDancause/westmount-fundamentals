        let filteredData = [...SP500_COMPANIES];
        let sortCol = 'weight';
        let sortDesc = true;
        let currentPage = 1;
        const rowsPerPage = 50;

        // Initialize
        function init() {
            // Populate sectors
            const sectors = [...new Set(SP500_COMPANIES.map(c => c.sector).filter(Boolean))].sort();
            const sectorSelect = document.getElementById('sectorFilter');
            sectors.forEach(s => {
                const opt = document.createElement('option');
                opt.value = s;
                opt.textContent = s;
                sectorSelect.appendChild(opt);
            });

            // Event listeners
            document.getElementById('searchInput').addEventListener('input', applyFilters);
            document.getElementById('searchInput').addEventListener('keyup', applyFilters);
            document.getElementById('sectorFilter').addEventListener('change', applyFilters);

            document.getElementById('prevBtn').addEventListener('click', () => {
                if (currentPage > 1) { currentPage--; renderTable(); }
            });
            document.getElementById('nextBtn').addEventListener('click', () => {
                const maxPage = Math.ceil(filteredData.length / rowsPerPage);
                if (currentPage < maxPage) { currentPage++; renderTable(); }
            });

            document.querySelectorAll('th[data-sort]').forEach(th => {
                th.addEventListener('click', () => {
                    const col = th.getAttribute('data-sort');
                    if (sortCol === col) {
                        sortDesc = !sortDesc;
                    } else {
                        sortCol = col;
                        sortDesc = (col === 'ticker' || col === 'company' || col === 'sector') ? false : true;
                    }
                    updateSortHeaders();
                    applyFilters();
                });
            });

            updateSortHeaders();
            applyFilters();
        }

        function updateSortHeaders() {
            document.querySelectorAll('th').forEach(th => {
                th.classList.remove('sort-asc', 'sort-desc');
                if (th.getAttribute('data-sort') === sortCol) {
                    th.classList.add(sortDesc ? 'sort-desc' : 'sort-asc');
                }
            });
        }

        function applyFilters() {
            const query = document.getElementById('searchInput').value.toLowerCase();
            const sector = document.getElementById('sectorFilter').value;

            filteredData = SP500_COMPANIES.filter(c => {
                const matchesSearch = c.ticker.toLowerCase().includes(query) ||
                                      (c.company && c.company.toLowerCase().includes(query));
                const matchesSector = sector === 'all' || c.sector === sector;
                return matchesSearch && matchesSector;
            });

            // Sort
            filteredData.sort((a, b) => {
                let valA = a[sortCol];
                let valB = b[sortCol];

                // Handle nulls
                if (valA === null || valA === undefined) valA = sortDesc ? -Infinity : Infinity;
                if (valB === null || valB === undefined) valB = sortDesc ? -Infinity : Infinity;

                if (typeof valA === 'string' && typeof valB === 'string') {
                    return sortDesc ? valB.localeCompare(valA) : valA.localeCompare(valB);
                }

                return sortDesc ? valB - valA : valA - valB;
            });

            currentPage = 1;
            renderTable();
        }

        function formatBillion(num) {
            if (num === null || num === undefined) return '-';
            if (num >= 1e9) return '$' + (num / 1e9).toFixed(1) + 'B';
            if (num >= 1e6) return '$' + (num / 1e6).toFixed(1) + 'M';
            return '$' + num.toLocaleString();
        }

        function formatPercent(num) {
            if (num === null || num === undefined) return '-';
            return num.toFixed(2) + '%';
        }

        function formatNumber(num, decimals = 2) {
            if (num === null || num === undefined) return '-';
            return num.toFixed(decimals);
        }

        // 🛡️ Sentinel: Escape HTML to prevent XSS in table rendering
        function escapeHTML(str) {
            if (str === null || str === undefined) return '';
            return String(str).replace(/[&<>'"]/g, tag => ({
                '&': '&amp;',
                '<': '<',
                '>': '>',
                "'": '&#39;',
                '"': '&quot;'
            }[tag] || tag));
        }

        function renderTable() {
            const tbody = document.getElementById('tableBody');
            tbody.innerHTML = '';

            const start = (currentPage - 1) * rowsPerPage;
            const end = start + rowsPerPage;
            const pageData = filteredData.slice(start, end);

            if (pageData.length === 0) {
                tbody.innerHTML = '<tr><td colspan="8" style="text-align: center;">No companies found.</td></tr>';
            } else {
                pageData.forEach(c => {
                    const tr = document.createElement('tr');

                    let ytdClass = 'neutral';
                    if (c.ytdReturn > 0) ytdClass = 'pos';
                    else if (c.ytdReturn < 0) ytdClass = 'neg';

                    let ytdStr = c.ytdReturn !== null ? (c.ytdReturn > 0 ? '+' : '') + c.ytdReturn.toFixed(2) + '%' : '-';

                    tr.innerHTML = `
                        <td class="text-left ticker">${escapeHTML(c.ticker)}</td>
                        <td class="text-left" style="white-space: normal; min-width: 200px;">${c.company ? escapeHTML(c.company) : '-'}</td>
                        <td class="text-left">${c.sector ? escapeHTML(c.sector) : '-'}</td>
                        <td>${c.weight ? c.weight.toFixed(3) + '%' : '-'}</td>
                        <td>${formatBillion(c.marketCap)}</td>
                        <td>${formatNumber(c.peRatio)}</td>
                        <td>${formatPercent(c.dividendYield)}</td>
                        <td class="${ytdClass}">${ytdStr}</td>
                    `;
                    tbody.appendChild(tr);
                });
            }

            // Pagination UI
            const maxPage = Math.max(1, Math.ceil(filteredData.length / rowsPerPage));
            document.getElementById('pageInfo').textContent = `Page ${currentPage} of ${maxPage}`;
            document.getElementById('prevBtn').disabled = currentPage === 1;
            document.getElementById('nextBtn').disabled = currentPage === maxPage;
        }

        function renderCharts() {
            // Sector Chart
            const sectorWeights = {};
            SP500_COMPANIES.forEach(c => {
                if (c.sector && c.weight) {
                    sectorWeights[c.sector] = (sectorWeights[c.sector] || 0) + c.weight;
                }
            });

            const sortedSectors = Object.entries(sectorWeights).sort((a, b) => b[1] - a[1]).slice(0, 10);

            new Chart(document.getElementById('sectorChart'), {
                type: 'doughnut',
                data: {
                    labels: sortedSectors.map(s => s[0]),
                    datasets: [{
                        data: sortedSectors.map(s => s[1]),
                        backgroundColor: [
                            '#3b82f6', '#8b5cf6', '#ec4899', '#f43f5e', '#f97316',
                            '#eab308', '#22c55e', '#14b8a6', '#0ea5e9', '#64748b'
                        ],
                        borderWidth: 0,
                        hoverOffset: 4
                    }]
                },
                options: {
                    responsive: true,
                    plugins: {
                        legend: { position: 'right', labels: { color: '#94a3b8', font: { family: 'Inter' } } }
                    }
                }
            });

            // Top Companies Chart
            const topCompanies = [...SP500_COMPANIES].sort((a, b) => (b.weight || 0) - (a.weight || 0)).slice(0, 10);

            new Chart(document.getElementById('topCompaniesChart'), {
                type: 'bar',
                data: {
                    labels: topCompanies.map(c => c.ticker),
                    datasets: [{
                        label: 'Index Weight (%)',
                        data: topCompanies.map(c => c.weight),
                        backgroundColor: '#4a8fe7',
                        borderRadius: 4
                    }]
                },
                options: {
                    responsive: true,
                    scales: {
                        y: {
                            beginAtZero: true,
                            grid: { color: '#152040' },
                            ticks: { color: '#94a3b8', callback: function(value) { return value + '%'; } }
                        },
                        x: {
                            grid: { display: false },
                            ticks: { color: '#94a3b8', font: { family: 'JetBrains Mono' } }
                        }
                    },
                    plugins: {
                        legend: { display: false }
                    }
                }
            });
        }

        // Call renderCharts after init
        const oldInit = init;
        init = function() {
            oldInit();
            renderCharts();
        };

        // Run
        init();
  </script>
