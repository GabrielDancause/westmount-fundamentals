    <span>6 min read</span>
  </div>
        <h1>{page.h1}</h1>
        <p class="subtitle">Search, filter, and analyze all 503 constituents of the S&P 500 index.</p>

        <div class="stats-grid">
            <div class="stat-card">
                <div class="label">Total Companies</div>
                <div class="value">503</div>
            </div>
            <div class="stat-card">
                <div class="label">Total Market Cap</div>
                <div class="value">$64.5T</div>
