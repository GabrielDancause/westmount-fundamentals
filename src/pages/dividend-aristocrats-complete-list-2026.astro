        function formatMoney(value) {
            if (!value) return '-';
            if (value >= 1e12) return '$' + (value / 1e12).toFixed(1) + 'T';
            if (value >= 1e9) return '$' + (value / 1e9).toFixed(1) + 'B';
            if (value >= 1e6) return '$' + (value / 1e6).toFixed(1) + 'M';
            return '$' + value.toLocaleString();
        }

        const tbody = document.getElementById('tableBody');
        const searchInput = document.getElementById('searchInput');
        const sortSelect = document.getElementById('sortSelect');
        const sectorFilter = document.getElementById('sectorFilter');

        function renderTable() {
            let data = [...window.__INITIAL_DATA__];
            const q = searchInput.value.toLowerCase();
            const sec = sectorFilter.value;

            if (q) {
                data = data.filter(a => a.ticker.toLowerCase().includes(q) || a.company.toLowerCase().includes(q));
            }
            if (sec !== 'all') {
                data = data.filter(a => a.sector === sec);
            }

            const sortVal = sortSelect.value;
            data.sort((a, b) => {
                if (sortVal === 'ticker') return a.ticker.localeCompare(b.ticker);
                if (sortVal === 'yield-desc') return (b.yield || 0) - (a.yield || 0);
                if (sortVal === 'yield-asc') return (a.yield || 0) - (b.yield || 0);
                if (sortVal === 'years-desc') return (b.years || 0) - (a.years || 0);
                if (sortVal === 'marketcap-desc') return (b.marketCap || 0) - (a.marketCap || 0);
                return 0;
            });

            tbody.innerHTML = '';
            data.forEach(a => {
                const tr = document.createElement('tr');

                let yieldStr = a.yield ? a.yield.toFixed(2) + '%' : '-';
                let cagrStr = a.cagr5y ? a.cagr5y.toFixed(2) + '%' : '-';
                let prStr = a.payoutRatio ? a.payoutRatio.toFixed(2) + '%' : '-';

                tr.innerHTML = `
                    <td class="ticker-col">${a.ticker}</td>
                    <td style="font-weight: 500;">${a.company}</td>
                    <td><span class="sector-tag">${a.sector}</span></td>
                    <td class="number-col">${yieldStr}</td>
                    <td class="number-col">${a.years}</td>
                    <td class="number-col">${cagrStr}</td>
                    <td class="number-col">${prStr}</td>
                    <td class="number-col">${formatMoney(a.marketCap)}</td>
                `;
                tbody.appendChild(tr);
            });
        }

        searchInput.addEventListener('input', renderTable);
        sortSelect.addEventListener('change', renderTable);
        sectorFilter.addEventListener('change', renderTable);

        // Render initial
        renderTable();

        // Chart
        const sectorData = [["Consumer Defensive",16],["Industrials",14],["Financial Services",9],["Healthcare",7],["Basic Materials",7],["Consumer Cyclical",4],["Utilities",4],["Technology",3],["Real Estate",3],["Energy",2]];
        const ctx = document.getElementById('sectorChart').getContext('2d');
        new Chart(ctx, {
            type: 'bar',
            data: {
                labels: sectorData.map(d => d[0]),
                datasets: [{
                    label: 'Number of Aristocrats',
                    data: sectorData.map(d => d[1]),
                    backgroundColor: '#4a8fe7',
                    borderRadius: 4
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: { display: false }
                },
                scales: {
                    y: {
                        beginAtZero: true,
                        grid: { color: '#152040' },
                        ticks: { color: '#94a3b8' }
                    },
                    x: {
                        grid: { display: false },
                        ticks: {
                            color: '#94a3b8',
                            maxRotation: 45,
                            minRotation: 45
                        }
                    }
                }
            }
        });
  </script>

  
