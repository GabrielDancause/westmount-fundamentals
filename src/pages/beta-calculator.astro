  /* Bar: Sector Betas */
  var sectorCtx = document.getElementById("sectorChart").getContext("2d");
  var sectorLabels = ["Technology", "Financials", "Energy", "Industrials", "Healthcare", "Cons. Disc.", "Comm. Svc.", "Materials", "Real Estate", "Cons. Staples", "Utilities"];
  var sectorBetas = [1.20, 1.10, 1.10, 1.05, 0.80, 1.15, 0.95, 1.00, 0.75, 0.60, 0.40];
  var sectorColors = sectorBetas.map(function(b) {
    if (b >= 1.2) return "rgba(239,68,68,0.7)";
    if (b >= 1.0) return "rgba(249,115,22,0.7)";
