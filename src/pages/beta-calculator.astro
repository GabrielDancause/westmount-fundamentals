      </div>
      <div class="form-group">
        <label for="market-returns">Market Monthly Returns (%)</label>
        <textarea id="market-returns" placeholder="e.g. 1.5, -0.9, 3.1, -0.4, 2.0, -1.5, 1.0, 0.6, -2.2, 1.8, 0.8, -0.3" rows="3">1.5, -0.9, 3.1, -0.4, 2.0, -1.5, 1.0, 0.6, -2.2, 1.8, 0.8, -0.3</textarea>
      </div>
