<script is:inline>
/* ============ UTILITY FUNCTIONS ============ */
function parseCsv(str) {
  var parts = str.split(",");
  var arr = [];
  for (var i = 0; i < parts.length; i++) {
    var v = parseFloat(parts[i].trim());
    if (!isNaN(v)) arr.push(v);
  }
  return arr;
}

function mean(arr) {
  var s = 0;
  for (var i = 0; i < arr.length; i++) s += arr[i];
  return s / arr.length;
}

function covariance(a, b, ma, mb) {
  var s = 0;
  for (var i = 0; i < a.length; i++) s += (a[i] - ma) * (b[i] - mb);
  return s / (a.length - 1);
}

function variance(arr, m) {
  var s = 0;
  for (var i = 0; i < arr.length; i++) s += (arr[i] - m) * (arr[i] - m);
  return s / (arr.length - 1);
}

function interpretBeta(b) {
  if (b < 0) return "Inverse / Negative";
  if (b < 0.5) return "Low Volatility";
  if (b < 1.0) return "Defensive";
  if (b < 1.01 && b > 0.99) return "Market";
  if (b < 1.5) return "Aggressive";
  return "High Volatility";
}

/* ============ STOCK BETA CALCULATOR ============ */
function calcStockBeta() {
  var stockR = parseCsv(document.getElementById("stock-returns").value);
  var mktR = parseCsv(document.getElementById("market-returns").value);
  if (stockR.length < 3 || mktR.length < 3) { alert("Please enter at least 3 return values for each."); return; }
  var n = Math.min(stockR.length, mktR.length);
  stockR = stockR.slice(0, n);
  mktR = mktR.slice(0, n);

  var ms = mean(stockR);
  var mm = mean(mktR);
  var cov = covariance(stockR, mktR, ms, mm);
  var varM = variance(mktR, mm);
  var varS = variance(stockR, ms);
  var beta = cov / varM;

  var corr = cov / (Math.sqrt(varS) * Math.sqrt(varM));
  var r2 = corr * corr;
  var alpha = (ms - beta * mm) * 12;

  document.getElementById("res-beta").textContent = beta.toFixed(4);
  document.getElementById("res-r2").textContent = (r2 * 100).toFixed(2) + "%";
  document.getElementById("res-alpha").textContent = (alpha >= 0 ? "+" : "") + alpha.toFixed(2) + "%";
  document.getElementById("res-stock-avg").textContent = ms.toFixed(3) + "%";
  document.getElementById("res-mkt-avg").textContent = mm.toFixed(3) + "%";
  document.getElementById("res-obs").textContent = n;

  var box = document.getElementById("stock-beta-result");
  box.style.display = "block";
  box.style.opacity = "1";

  document.getElementById("res-alpha").style.color = alpha >= 0 ? "#10b981" : "#ef4444";
}

/* ============ QUICK BETA ESTIMATE ============ */
function calcQuickBeta() {
  var ss = parseFloat(document.getElementById("quick-stock-sd").value);
  var sm = parseFloat(document.getElementById("quick-mkt-sd").value);
  var corr = parseFloat(document.getElementById("quick-corr").value);
  if (isNaN(ss) || isNaN(sm) || isNaN(corr) || sm === 0) { alert("Please enter valid values."); return; }

  var ratio = ss / sm;
  var beta = ratio * corr;

  document.getElementById("quick-beta").textContent = beta.toFixed(4);
  document.getElementById("quick-ratio").textContent = ratio.toFixed(3);
  document.getElementById("quick-interp").textContent = interpretBeta(beta);

  var box = document.getElementById("quick-result");
  box.style.display = "block";
  box.style.opacity = "1";
}

/* ============ PORTFOLIO BETA CALCULATOR ============ */
function addRow() {
  var container = document.getElementById("portfolio-rows");
  if (container.children.length >= 10) { alert("Maximum 10 stocks."); return; }
  var row = document.createElement("div");
  row.className = "portfolio-row";
  row.innerHTML = '<input type="text" placeholder="Ticker"><input type="number" placeholder="Weight %" step="0.1"><input type="number" placeholder="Beta" step="0.01"><button class="remove-btn" onclick="removeRow(this)">×</button>';
  container.appendChild(row);
}

function removeRow(btn) {
  var container = document.getElementById("portfolio-rows");
  if (container.children.length <= 1) return;
  btn.parentElement.remove();
}

function calcPortfolioBeta() {
  var rows = document.getElementById("portfolio-rows").children;
  var totalW = 0, totalBeta = 0, count = 0;
  for (var i = 0; i < rows.length; i++) {
    var inputs = rows[i].querySelectorAll("input");
    var w = parseFloat(inputs[1].value);
    var b = parseFloat(inputs[2].value);
    if (!isNaN(w) && !isNaN(b)) {
      totalW += w;
      totalBeta += (w / 100) * b;
      count++;
    }
  }
  if (count === 0) { alert("Please enter at least one stock."); return; }

  var adjBeta = totalW > 0 ? totalBeta / (totalW / 100) : 0;

  document.getElementById("pf-beta").textContent = adjBeta.toFixed(4);
  document.getElementById("pf-weight").textContent = totalW.toFixed(1) + "%";
  document.getElementById("pf-interp").textContent = interpretBeta(adjBeta);
  document.getElementById("pf-count").textContent = count;

  document.getElementById("pf-beta").style.color = adjBeta > 1.0 ? "#f97316" : (adjBeta < 0.8 ? "#10b981" : "#4a8fe7");

  var box = document.getElementById("portfolio-result");
  box.style.display = "block";
  box.style.opacity = "1";
}

/* ============ GAUGE ============ */
function updateGauge() {
  var val = parseFloat(document.getElementById("gauge-input").value);
  if (isNaN(val)) return;
  var label = interpretBeta(val);
  document.getElementById("gauge-label").textContent = label;

  var pct;
  if (val < 0) pct = Math.max(0, (1 + val) * 18.87);
  else if (val < 0.5) pct = 18.87 + (val / 0.5) * 18.87;
  else if (val < 1.0) pct = 37.74 + ((val - 0.5) / 0.5) * 18.87;
  else if (val < 1.0001 && val > 0.9999) pct = 61.5;
  else if (val < 1.5) pct = 62.0 + ((val - 1.0) / 0.5) * 18.87;
  else pct = Math.min(100, 80.87 + ((val - 1.5) / 1.0) * 19.13);

  document.getElementById("main-gauge-ptr").style.left = pct + "%";
}

document.getElementById("gauge-input").addEventListener("input", updateGauge);

/* ============ FAQ TOGGLE ============ */
function toggleFaq(el) {
  var item = el.parentElement;
  var isOpen = item.className.indexOf("open") !== -1;
  item.className = isOpen ? "faq-item" : "faq-item open";
}

