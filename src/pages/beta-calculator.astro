        <div class="result-row"><span class="label">Beta (β)</span><span class="value" id="res-beta">—</span></div>
        <div class="result-row"><span class="label">R-squared</span><span class="value" id="res-r2">—</span></div>
        <div class="result-row"><span class="label">Alpha (annualized)</span><span class="value" id="res-alpha">—</span></div>
        <div class="result-row"><span class="label">Stock Avg Return</span><span class="value" id="res-stock-avg">—</span></div>
