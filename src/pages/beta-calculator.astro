  .remove-btn:hover { background: rgba(239,68,68,0.1); border-color: #ef4444; }
  .add-stock-btn { background: rgba(74,143,231,0.1); border: 1px dashed var(--accent); border-radius: 8px; padding: 0.5rem; color: var(--accent); cursor: pointer; font-size: 0.9rem; width: 100%; margin-top: 0.5rem; }
