      </div>
      <div class="form-group">
        <label for="quick-mkt-sd">Market Std Deviation (%)</label>
        <input type="number" id="quick-mkt-sd" placeholder="e.g. 15" step="0.1" value="15">
      </div>
      <div class="form-group">
        <label for="quick-corr">Correlation (ρ)</label>
        <input type="number" id="quick-corr" placeholder="e.g. 0.75" step="0.01" min="-1" max="1" value="0.75">
