  .chart-container { background: var(--bg-card); border: 1px solid var(--border); border-radius: 12px; padding: 1.5rem; margin: 1.5rem 0; }
  .chart-container h3 { color: #e8eaed; margin: 0 0 1rem; font-size: 1.1rem; }
