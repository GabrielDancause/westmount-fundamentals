  .form-group input, .form-group select, .form-group textarea { width: 100%; background: rgba(255,255,255,0.06); border: 1px solid var(--border); border-radius: 8px; padding: 0.65rem 0.8rem; color: #e8eaed; font-size: 0.95rem; box-sizing: border-box; font-family: inherit; }
  .form-group textarea { resize: vertical; min-height: 60px; }
  .form-group input:focus, .form-group select:focus, .form-group textarea:focus { outline: none; border-color: var(--accent); box-shadow: 0 0 0 2px rgba(74,143,231,0.2); }

