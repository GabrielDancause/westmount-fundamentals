<script is:inline>
  function formatCurrency(num) {
    return new Intl.NumberFormat('en-US', {
      style: 'currency',
      currency: 'USD',
      maximumFractionDigits: 0
    }).format(num);
  }

  function formatPercent(num) {
    return new Intl.NumberFormat('en-US', {
      style: 'percent',
      minimumFractionDigits: 1,
      maximumFractionDigits: 1
    }).format(num);
  }

  function calculateInvestment() {
    const initialRaw = parseFloat(document.getElementById('initialInvestment').value);
    const monthlyRaw = parseFloat(document.getElementById('monthlyContribution').value);
    const yearsRaw = parseFloat(document.getElementById('years').value);
    const rateRaw = parseFloat(document.getElementById('annualReturn').value);

    // Handle edge cases
    const initial = isNaN(initialRaw) || initialRaw < 0 ? 0 : initialRaw;
    const monthly = isNaN(monthlyRaw) || monthlyRaw < 0 ? 0 : monthlyRaw;
    const years = isNaN(yearsRaw) || yearsRaw <= 0 ? 1 : (yearsRaw > 100 ? 100 : yearsRaw);
    const rate = isNaN(rateRaw) ? 0 : rateRaw;

    const r = rate / 100;
    const n = 12; // Monthly compounding
    const t = years;

    let futureValue = 0;
    let fvInitial = 0;
    let fvContributions = 0;

    if (r === 0) {
      fvInitial = initial;
      fvContributions = monthly * 12 * t;
      futureValue = fvInitial + fvContributions;
    } else {
      const rn = r / n;
      const nt = n * t;
      fvInitial = initial * Math.pow(1 + rn, nt);
      fvContributions = monthly * ((Math.pow(1 + rn, nt) - 1) / rn);
      futureValue = fvInitial + fvContributions;
    }

    const totalContributions = monthly * 12 * t;
    const totalPrincipal = initial + totalContributions;
    const totalInterest = Math.max(0, futureValue - totalPrincipal);

    // Update DOM
    document.getElementById('futureValueResult').textContent = formatCurrency(futureValue);
    document.getElementById('totalPrincipalResult').textContent = formatCurrency(totalPrincipal);
    document.getElementById('totalInterestResult').textContent = formatCurrency(totalInterest);

    // Table updates
    document.getElementById('tableInitial').textContent = formatCurrency(initial);
    document.getElementById('tableContributions').textContent = formatCurrency(totalContributions);
    document.getElementById('tableInterest').textContent = formatCurrency(totalInterest);
    document.getElementById('tableTotal').innerHTML = `<strong>${formatCurrency(futureValue)}</strong>`;

    document.getElementById('tableInitialNoInvest').textContent = formatCurrency(initial);
    document.getElementById('tableContributionsNoInvest').textContent = formatCurrency(totalContributions);
    document.getElementById('tableTotalNoInvest').innerHTML = `<strong>${formatCurrency(totalPrincipal)}</strong>`;
  }

  function initCalculator() {
    const inputs = ['initialInvestment', 'monthlyContribution', 'years', 'annualReturn'];
    inputs.forEach(id => {
      const el = document.getElementById(id);
      if (el) {
        el.addEventListener('input', calculateInvestment);
      }
    });

    // Initial calculation
    calculateInvestment();
  }

  // Handle View Transitions
  document.addEventListener('astro:page-load', initCalculator);

  // Fallback for direct loads
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initCalculator);
  } else {
    initCalculator();
  }
</script>
