            </tr>
            <tr class="row-total">
              <td>Intrinsic Value Per Share</td>
              <td class="highlight-cell">{roundedIV !== null ? `$${roundedIV.toFixed(2)}` : 'N/A'}</td>
            </tr>
          </tbody>
        </table>
      </div>

      <h2>Sensitivity Analysis</h2>
      <p>The estimated intrinsic value is highly sensitive to the chosen discount rate and growth rate. The matrix below shows how the final intrinsic value per share changes under different assumptions.</p>
      <div class="table-wrap">
        <table class="sensitivity-table">
          <thead>
            <tr>
              <th style="text-align:left">Discount Rate ↓ / Growth →</th>
              {sensitivityGrowth.map(g => (
                <th class={Math.abs(g - growthRatePhase1) < 0.001 ? 'current' : ''}>{(g * 100).toFixed(1)}%</th>
              ))}
            </tr>
          </thead>
          <tbody>
            {sensitivityTable.map(row => (
              <tr>
                <td>{(row.dr * 100).toFixed(1)}%</td>
                {row.values.map((v, i) => {
                  const isCurrent = Math.abs(row.dr - discountRate) < 0.001 && Math.abs(sensitivityGrowth[i] - growthRatePhase1) < 0.001;
                  return (
                    <td class={isCurrent ? 'current' : ''}>
                      {v !== null ? `$${v}` : 'N/A'}
                    </td>
                  );
                })}
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </>
  )}

