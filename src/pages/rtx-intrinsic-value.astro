---
import SiteLayout from "../layouts/SiteLayout.astro";

// --- METADATA ---
export const meta = {
  title: "RTX Corporation (RTX) Intrinsic Value - Gemini's DCF Analysis",
  description: "An independent discounted cash flow (DCF) intrinsic value analysis of RTX Corporation (RTX) compiled entirely by Gemini 3.1.",
  category: "study",
  published: "2026-03-18",
};

// --- DATA & ASSUMPTIONS (Recent Actuals) ---
// Compiled by Gemini 3.1
// FCF Growth (Y1-Y5): 12%. Defense spending tailwinds, massive commercial aerospace backlog, and margin expansion post-Pratt & Whitney engine issues will drive strong FCF growth.
// Discount Rate (WACC): 8.0%. Low beta of 0.406, 10-Year treasury at 4.18%, and reliable defense cash flows warrant a lower discount rate.
// Terminal Growth: 2.5%. Stable long-term GDP growth and perpetual defense contracts provide a solid floor.

const baseFCF = 6456; // in Millions
const sharesOut = 1346; // in Millions
const currentPrice = 206.39;
const netCash = 7435 - 39956; // Total Cash - Total Debt (in Millions)

const fcfGrowthRate = 0.12;
const discountRate = 0.080;
const terminalGrowthRate = 0.025;

// --- YEAR 1 TO 5 PROJECTIONS ---
const projections = [];
let prevFCF = baseFCF;

for (let i = 1; i <= 5; i++) {
  const projectedFCF = prevFCF * (1 + fcfGrowthRate);
  const discountFactor = Math.pow(1 + discountRate, i);
  const pvOfFCF = projectedFCF / discountFactor;

  projections.push({
    year: `Year ${i}`,
    fcf: projectedFCF,
    pv: pvOfFCF
  });

  prevFCF = projectedFCF;
}

const sumPvFcf = projections.reduce((sum, p) => sum + p.pv, 0);

// --- TERMINAL VALUE ---
const year5FCF = projections[4].fcf;
const terminalValue = (year5FCF * (1 + terminalGrowthRate)) / (discountRate - terminalGrowthRate);
const pvTerminalValue = terminalValue / Math.pow(1 + discountRate, 5);

// --- INTRINSIC VALUE CALCULATION ---
const enterpriseValue = sumPvFcf + pvTerminalValue;
const totalEquityValue = enterpriseValue + netCash;
const intrinsicValuePerShare = totalEquityValue / sharesOut;

// Value vs Current Price
const marginOfSafety = ((intrinsicValuePerShare - currentPrice) / currentPrice) * 100;
const isUndervalued = intrinsicValuePerShare > currentPrice;

// --- SENSITIVITY MATRIX ---
const sensitivityDiscountRates = [0.070, 0.075, 0.080, 0.085, 0.090];
const sensitivityGrowthRates = [0.015, 0.020, 0.025, 0.030, 0.035];

const sensitivityMatrix = sensitivityGrowthRates.map(g => {
  return {
    growthRate: g,
    values: sensitivityDiscountRates.map(d => {
      // Re-calculate TV and PV with new rates
      const currentTerminalValue = (year5FCF * (1 + g)) / (d - g);
      const currentPvTerminalValue = currentTerminalValue / Math.pow(1 + d, 5);

      // Re-calculate PV of FCFs with new discount rate
      let currentSumPvFcf = 0;
      let tempFcf = baseFCF;
      for (let i = 1; i <= 5; i++) {
        tempFcf = tempFcf * (1 + fcfGrowthRate);
        currentSumPvFcf += tempFcf / Math.pow(1 + d, i);
      }

      const currentEV = currentSumPvFcf + currentPvTerminalValue;
      const currentEquity = currentEV + netCash;
      const currentIV = currentEquity / sharesOut;

      return currentIV;
    })
  };
});

// Formatting helpers
const formatMoney = (val) => new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD', minimumFractionDigits: 2, maximumFractionDigits: 2 }).format(val);
const formatMillions = (val) => '$' + new Intl.NumberFormat('en-US', { maximumFractionDigits: 0 }).format(val) + 'M';
const formatPercent = (val) => (val * 100).toFixed(1) + '%';

// --- SCHEMA ---
const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Article",
      "headline": meta.title,
      "description": meta.description,
      "author": {
        "@type": "Organization",
        "name": "Gemini 3.1"
      },
      "publisher": {
        "@type": "Organization",
        "name": "Westmount Fundamentals",
        "logo": {
          "@type": "ImageObject",
          "url": "https://westmountfundamentals.com/logo.png"
        }
      },
      "mainEntityOfPage": {
        "@type": "WebPage",
        "@id": "https://westmountfundamentals.com/rtx-intrinsic-value"
      }
    },
    {
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "Why did Gemini pick a 12% growth rate for RTX?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Gemini projects that RTX's massive commercial aerospace backlog, ongoing global defense spending tailwinds, and margin expansion following the resolution of the Pratt & Whitney GTF engine issues will drive strong free cash flow growth."
          }
        },
        {
          "@type": "Question",
          "name": "What discount rate was used for RTX's DCF?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "An 8.0% discount rate was selected. This reflects RTX's remarkably low beta (0.406), a 4.18% risk-free rate, and the highly reliable nature of its long-term defense and aerospace contracts."
          }
        },
        {
          "@type": "Question",
          "name": "What is the terminal growth rate assumption for RTX?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "A 2.5% terminal growth rate is used, aligning with long-term GDP growth expectations and the stable, perpetual nature of defense spending."
          }
        }
      ]
    }
  ]
};
---
<SiteLayout site="westmount" title={meta.title} description={meta.description} canonical="https://westmountfundamentals.com/rtx-intrinsic-value" schema={schema}>
  <div class="page-content">
    <div class="container">

      <div class="gemini-header">
        <div class="gemini-badge">COMPILED BY GEMINI 2.5 PRO</div>
        <h1>RTX Corporation (RTX) Intrinsic Value</h1>
        <p class="subtitle">An independent two-stage DCF analysis by a frontier AI model.</p>
      </div>

      <div class="verdict-card">
        <div class="verdict-header">
          <h2>Fair Value Estimate</h2>
        </div>
        <div class="verdict-body">
          <div class="verdict-main">
            <span class="iv-value">{formatMoney(intrinsicValuePerShare)}</span>
            <span class="iv-label">per share</span>
          </div>
          <div class="verdict-stats">
            <div class="stat">
              <span class="stat-label">Current Price</span>
              <span class="stat-value">{formatMoney(currentPrice)}</span>
            </div>
            <div class="stat">
              <span class="stat-label">Margin of Safety</span>
              <span class={`stat-value ${isUndervalued ? 'positive' : 'negative'}`}>
                {isUndervalued ? '+' : ''}{marginOfSafety.toFixed(2)}%
              </span>
            </div>
            <div class="stat">
              <span class="stat-label">Verdict</span>
              <span class={`badge ${isUndervalued ? 'positive' : 'negative'}`}>
                {isUndervalued ? 'UNDERVALUED' : 'OVERVALUED'}
              </span>
            </div>
          </div>
        </div>
        <div class="verdict-footer">
          <p>Based on most recent financials. Data via S&P Global Market Intelligence.</p>
        </div>
      </div>

      <section class="content-section">
        <h2>The AI Thesis: Why I'm Modeling Robust Growth for RTX</h2>
        <p>RTX Corporation operates uniquely at the intersection of commercial aerospace recovery and escalating global defense budgets. Following the significant cash flow impact of the Pratt & Whitney GTF engine powder metal issue, RTX is poised for a massive free cash flow rebound. <strong>I see this as a powerful inflection point.</strong></p>
        <p>The record commercial backlog at Collins Aerospace and Pratt & Whitney, combined with Raytheon's critical role in modern air defense systems (Patriot, AMRAAM), creates unparalleled revenue visibility. As exceptional charges fade and production scales to meet demand, operating leverage will drive outsized cash generation.</p>
      </section>

      <section class="content-section">
        <h2>My Assumptions & Rationale</h2>

        <div class="assumption-grid">
          <div class="assumption-card">
            <div class="card-title">FCF Growth Rate (Y1-Y5)</div>
            <div class="card-value">{formatPercent(fcfGrowthRate)}</div>
            <p><strong>Rationale:</strong> 12% is a confident projection. While base defense spending grows in the mid-single digits, margin expansion is the key driver here. As the expensive GTF engine remediation program concludes, and high-margin aftermarket service revenues accelerate alongside global flight hours, FCF will expand significantly from its current $6.45B base.</p>
          </div>

          <div class="assumption-card">
            <div class="card-title">Discount Rate (WACC)</div>
            <div class="card-value">{formatPercent(discountRate)}</div>
            <p><strong>Rationale:</strong> An 8.0% discount rate is justified by the extremely defensive nature of RTX's cash flows. A beta of 0.406 indicates the stock is far less volatile than the broader market. Even with the 10-year treasury at 4.18%, the visibility provided by multi-year Department of Defense contracts significantly reduces the equity risk premium.</p>
          </div>

          <div class="assumption-card">
            <div class="card-title">Terminal Growth Rate</div>
            <div class="card-value">{formatPercent(terminalGrowthRate)}</div>
            <p><strong>Rationale:</strong> 2.5% is a standard, conservative estimate aligning with long-term global GDP and inflation. Given the perpetual need for national security and the massive duopoly structure of commercial aviation suppliers, RTX's terminal growth is virtually guaranteed to match macroeconomic expansion.</p>
          </div>
        </div>
      </section>

      <section class="content-section">
        <h2>Discounted Cash Flow (DCF) Projections</h2>
        <p>Starting with the current base FCF of {formatMillions(baseFCF)}, the table below outlines the 5-year projection discounted back to Present Value (PV) using the {formatPercent(discountRate)} WACC.</p>

        <div class="table-container">
          <table>
            <thead>
              <tr>
                <th>Period</th>
                <th>Projected FCF</th>
                <th>PV Factor ({formatPercent(discountRate)})</th>
                <th>Present Value</th>
              </tr>
            </thead>
            <tbody>
              {projections.map((p, index) => (
                <tr>
                  <td>{p.year}</td>
                  <td>{formatMillions(p.fcf)}</td>
                  <td>{(1 / Math.pow(1 + discountRate, index + 1)).toFixed(4)}</td>
                  <td>{formatMillions(p.pv)}</td>
                </tr>
              ))}
              <tr class="highlight-row">
                <td colspan="3"><strong>Sum of PV of FCFs (Years 1-5)</strong></td>
                <td><strong>{formatMillions(sumPvFcf)}</strong></td>
              </tr>
            </tbody>
          </table>
        </div>
      </section>

      <section class="content-section">
        <h2>Terminal & Final Valuation Math</h2>
        <p>The Terminal Value accounts for all cash flows from Year 6 into perpetuity, calculated using the Gordon Growth Model.</p>

        <div class="math-card">
          <div class="math-row">
            <span>Year 5 FCF</span>
            <span>{formatMillions(year5FCF)}</span>
          </div>
          <div class="math-row">
            <span>Terminal Value (TV) Calculation</span>
            <span>({formatMillions(year5FCF)} * {1 + terminalGrowthRate}) / ({discountRate} - {terminalGrowthRate})</span>
          </div>
          <div class="math-row">
            <span>Terminal Value</span>
            <span>{formatMillions(terminalValue)}</span>
          </div>
          <div class="math-row highlight">
            <span>PV of Terminal Value</span>
            <span>{formatMillions(pvTerminalValue)}</span>
          </div>
        </div>

        <p style="margin-top: 2rem;">Adding it all together with Net Cash (Note: RTX carries significant debt relative to cash, resulting in negative net cash):</p>

        <div class="math-card">
          <div class="math-row">
            <span>Sum of PV of FCFs (Years 1-5)</span>
            <span>{formatMillions(sumPvFcf)}</span>
          </div>
          <div class="math-row">
            <span>+ PV of Terminal Value</span>
            <span>{formatMillions(pvTerminalValue)}</span>
          </div>
          <div class="math-row">
            <span><strong>= Enterprise Value</strong></span>
            <span><strong>{formatMillions(enterpriseValue)}</strong></span>
          </div>
          <div class="math-row">
            <span>+ Net Cash (Cash - Debt)</span>
            <span>{formatMillions(netCash)}</span>
          </div>
          <div class="math-row highlight">
            <span><strong>= Total Equity Value</strong></span>
            <span><strong>{formatMillions(totalEquityValue)}</strong></span>
          </div>
          <div class="math-row">
            <span>÷ Shares Outstanding</span>
            <span>{sharesOut.toLocaleString()}M</span>
          </div>
          <div class="math-row result">
            <span><strong>Intrinsic Value Per Share</strong></span>
            <span><strong>{formatMoney(intrinsicValuePerShare)}</strong></span>
          </div>
        </div>
      </section>

      <section class="content-section">
        <h2>Sensitivity Matrix</h2>
        <p>A single intrinsic value relies on rigid assumptions. The sensitivity matrix below demonstrates how the intrinsic value changes when we adjust the Discount Rate (WACC) and the Terminal Growth Rate.</p>

        <div class="table-container sensitivity-table">
          <table>
            <thead>
              <tr>
                <th rowspan="2" class="corner-cell">Terminal<br/>Growth</th>
                <th colspan="5" class="header-cell">Discount Rate (WACC)</th>
              </tr>
              <tr>
                {sensitivityDiscountRates.map(d => <th>{formatPercent(d)}</th>)}
              </tr>
            </thead>
            <tbody>
              {sensitivityMatrix.map(row => (
                <tr>
                  <th class="row-header">{formatPercent(row.growthRate)}</th>
                  {row.values.map(val => (
                    <td class={
                      val > currentPrice * 1.15 ? "cell-undervalued" :
                      val < currentPrice * 0.85 ? "cell-overvalued" :
                      "cell-neutral"
                    }>
                      {formatMoney(val)}
                    </td>
                  ))}
                </tr>
              ))}
            </tbody>
          </table>
          <div class="matrix-legend">
            <span class="legend-item"><span class="color-box cell-undervalued"></span> Undervalued (>15% Margin)</span>
            <span class="legend-item"><span class="color-box cell-neutral"></span> Fair Value</span>
            <span class="legend-item"><span class="color-box cell-overvalued"></span> Overvalued (&lt;-15% Margin)</span>
          </div>
        </div>
      </section>

      <section class="content-section risks-section">
        <h2>Risks & Bear Case</h2>
        <p>While my valuation is robust, a comprehensive analysis requires identifying the key vectors that could disrupt these assumptions:</p>
        <div class="risk-grid">
          <div class="risk-card">
            <h3>1. Geopolitical Shifts & Defense Budgets</h3>
            <p>While defense spending is currently rising, political shifts or unexpected resolutions to major global conflicts could lead to stagnant or declining defense budgets, impacting Raytheon's growth trajectory.</p>
          </div>
          <div class="risk-card">
            <h3>2. Supply Chain & Execution Risks</h3>
            <p>The aerospace sector relies on highly complex, global supply chains. Further disruptions in titanium supply, skilled labor shortages, or recurring quality control issues (similar to the GTF engine recall) could severely compress margins and delay cash flows.</p>
          </div>
          <div class="risk-card">
            <h3>3. Debt Burden & Rising Interest Rates</h3>
            <p>RTX carries nearly $40B in debt. If interest rates remain elevated for longer than anticipated, the cost of servicing this debt will increase upon refinancing, directly reducing Free Cash Flow available to shareholders.</p>
          </div>
        </div>
      </section>

      <section class="content-section faq-section">
        <h2>Frequently Asked Questions</h2>

        <div class="faq-item">
          <h3>Why did Gemini pick a 12% growth rate for RTX?</h3>
          <p>Gemini projects that RTX's massive commercial aerospace backlog, ongoing global defense spending tailwinds, and margin expansion following the resolution of the Pratt & Whitney GTF engine issues will drive strong free cash flow growth.</p>
        </div>

        <div class="faq-item">
          <h3>What discount rate was used for RTX's DCF?</h3>
          <p>An 8.0% discount rate was selected. This reflects RTX's remarkably low beta (0.406), a 4.18% risk-free rate, and the highly reliable nature of its long-term defense and aerospace contracts.</p>
        </div>

        <div class="faq-item">
          <h3>What is the terminal growth rate assumption for RTX?</h3>
          <p>A 2.5% terminal growth rate is used, aligning with long-term GDP growth expectations and the stable, perpetual nature of defense spending.</p>
        </div>

        <div class="faq-item">
          <h3>Is it safe to rely on AI for stock valuation?</h3>
          <p>No. This analysis is a demonstration of AI reasoning based on a specific set of inputs and rigid formulas. It is not financial advice. AI models cannot predict geopolitical events, supply chain crises, or management changes.</p>
        </div>
      </section>

      <div class="disclaimer-box">
        <p><strong>Disclaimer:</strong> The numbers presented on this page are for educational and entertainment purposes only. They are the result of a deterministic mathematical model fed with assumptions generated by an Artificial Intelligence (Gemini 3.1). This does not constitute investment advice. Always conduct your own due diligence before investing in the stock market.</p>
      </div>

    </div>
  </div>
</SiteLayout>
