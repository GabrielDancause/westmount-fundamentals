const schema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": "Northrop Grumman (NOC) Intrinsic Value: A DCF Analysis",
  "description": "A transparent, step-by-step discounted cash flow valuation of Northrop Grumman Corporation. Using actual financials to arrive at a single fair value estimate for NOC shares.",
  "datePublished": new Date().toISOString().split('T')[0],
  "dateModified": new Date().toISOString().split('T')[0],
  "author": {
    "@type": "Organization",
    "name": "Compiled by Gemini 3.1",
    "url": "https://westmountfundamentals.com"
  },
  "publisher": {
    "@type": "Organization",
    "name": "Westmount Research",
    "url": "https://westmountfundamentals.com"
  },
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": "https://westmountfundamentals.com/northrop-grumman-intrinsic-value"
  }
};

export const meta = {
  title: "Northrop Grumman (NOC) Intrinsic Value: A DCF Analysis",
  description: "We ran a full discounted cash flow on Northrop Grumman. One number. Every assumption disclosed. Here's what NOC is really worth.",
  category: "study",
  published: new Date().toISOString().split('T')[0],
};

import * as cheerio from 'cheerio';

async function fetchFinancials() {
  const headers = {
    'User-Agent': 'Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36',
    'Accept': 'text/html,application/xhtml+xml,application/xml;q=0.9,image/webp,*/*;q=0.8',
    'Accept-Language': 'en-US,en;q=0.5'
  };

  try {
    const finRes = await fetch('https://stockanalysis.com/stocks/noc/financials/', { headers });
    const finHtml = await finRes.text();
    const $fin = cheerio.load(finHtml);

    let currentPrice = null;
    const priceMatch = finHtml.match(/<div class="[^"]*text-4xl[^"]*"[^>]*>([\d\.,]+)<\/div>/);
    if (priceMatch) currentPrice = parseFloat(priceMatch[1].replace(/,/g, ''));

    let revenueHistory = [];
    let epsHistory = [];
    let sharesBasicHistory = [];
    let operatingIncomeHistory = [];
    let netIncomeHistory = [];

    $fin('tbody tr').each((i, el) => {
      const rowHeader = $fin(el).find('td').first().text().trim();
      const cells = $fin(el).find('td').slice(1);

      const extractVals = () => {
        let vals = [];
        cells.each((j, cell) => {
            const val = parseFloat($fin(cell).text().trim().replace(/,/g, ''));
            if(!isNaN(val)) vals.push(val);
        });
        return vals;
      };

      if (rowHeader === 'Revenue') revenueHistory = extractVals();
      else if (rowHeader === 'EPS (Diluted)' || rowHeader === 'EPS (Basic)') epsHistory = extractVals();
      else if (rowHeader === 'Shares Outstanding (Diluted)' || rowHeader === 'Shares Outstanding (Basic)') sharesBasicHistory = extractVals();
      else if (rowHeader === 'Operating Income') operatingIncomeHistory = extractVals();
      else if (rowHeader === 'Net Income') netIncomeHistory = extractVals();
    });

    const cfRes = await fetch('https://stockanalysis.com/stocks/noc/financials/cash-flow-statement/', { headers });
    const cfHtml = await cfRes.text();
    const $cf = cheerio.load(cfHtml);

    let fcfHistory = [];
    $cf('tbody tr').each((i, el) => {
        const rowHeader = $cf(el).find('td').first().text().trim();
        const cells = $cf(el).find('td').slice(1);
        if (rowHeader === 'Free Cash Flow') {
          cells.each((j, cell) => {
              const val = parseFloat($cf(cell).text().trim().replace(/,/g, ''));
              if(!isNaN(val)) fcfHistory.push(val);
          });
        }
    });

    const bsRes = await fetch('https://stockanalysis.com/stocks/noc/financials/balance-sheet/', { headers });
    const bsHtml = await bsRes.text();
    const $bs = cheerio.load(bsHtml);

    let cashHistory = [];
    let debtHistory = [];

    $bs('tbody tr').each((i, el) => {
        const rowHeader = $bs(el).find('td').first().text().trim();
        const cells = $bs(el).find('td').slice(1);
        if (rowHeader === 'Cash & Equivalents') {
          cells.each((j, cell) => {
              const val = parseFloat($bs(cell).text().trim().replace(/,/g, ''));
              if(!isNaN(val)) cashHistory.push(val);
          });
        } else if (rowHeader === 'Total Debt') {
          cells.each((j, cell) => {
              const val = parseFloat($bs(cell).text().trim().replace(/,/g, ''));
              if(!isNaN(val)) debtHistory.push(val);
          });
        }
    });

    return { currentPrice, revenueHistory, epsHistory, sharesBasicHistory, operatingIncomeHistory, netIncomeHistory, fcfHistory, cashHistory, debtHistory };

  } catch(e) {
    console.error("Error fetching financials:", e);
    return { currentPrice: null, revenueHistory: [], epsHistory: [], sharesBasicHistory: [], operatingIncomeHistory: [], netIncomeHistory: [], fcfHistory: [], cashHistory: [], debtHistory: [] };
  }
}

const data = await fetchFinancials();

// Core variables for the DCF
// stockanalysis.com orders most recent first, so index 0 is TTM/latest year
const currentPrice = data.currentPrice;
const sharesOutstanding = data.sharesBasicHistory.length > 0 ? data.sharesBasicHistory[0] : null;
const cashAndEquivalents = data.cashHistory.length > 0 ? data.cashHistory[0] : null;
const totalDebt = data.debtHistory.length > 0 ? data.debtHistory[0] : null;

// Free Cash Flow can be lumpy. We will use the latest year FCF as the base.
// Note: NOC FCF was $3307M latest.
const fcfLatest = data.fcfHistory.length > 0 ? data.fcfHistory[0] : null;
const netCash = (cashAndEquivalents !== null && totalDebt !== null) ? cashAndEquivalents - totalDebt : null;

// Derived Assumptions
// 1. Discount Rate (WACC)
// 10Y Treasury is 4.18%. ERP usually ~5%. Let's use 4.18% + 5% = ~9.18% rounded to 9.2%.
const discountRate = 0.092;

// 2. Growth Rate (Phase 1: Years 1-5)
// Let's look at recent revenue growth or FCF growth to anchor.
// If revenue [41954, 41033, 39290, 36602, 35667], 5-yr CAGR is roughly 4%.
// We will use 5% for phase 1 growth.
const growthRatePhase1 = 0.05;

// 3. Terminal Growth Rate
// GDP-like, around 2.5% for a mature defense contractor.
const growthRateTerminal = 0.025;

// DCF Calculations
let projectedFCF = [];
let pvPhase1 = null;
let fcfYear6 = null;
let terminalValue = null;
let pvTerminalValue = null;
let enterpriseValue = null;
let equityValue = null;
let intrinsicValuePerShare = null;
let marginOfSafety = null;
let verdictText = "N/A";
let verdictColor = "#5a6a80";

if (fcfLatest !== null && sharesOutstanding !== null && netCash !== null && currentPrice !== null) {
  let fcf = fcfLatest;
  let pvSum = 0;
  for (let yr = 1; yr <= 5; yr++) {
    fcf = fcf * (1 + growthRatePhase1);
    let pvFactor = 1 / Math.pow(1 + discountRate, yr);
    let pvFCF = fcf * pvFactor;
    pvSum += pvFCF;
    projectedFCF.push({ year: yr, fcf: fcf, pvFactor: pvFactor, pvFCF: pvFCF });
  }
  pvPhase1 = pvSum;

  fcfYear6 = projectedFCF[4].fcf * (1 + growthRateTerminal);
  terminalValue = fcfYear6 / (discountRate - growthRateTerminal);
  pvTerminalValue = terminalValue * projectedFCF[4].pvFactor;

  enterpriseValue = pvPhase1 + pvTerminalValue;
  equityValue = enterpriseValue + netCash;
  intrinsicValuePerShare = equityValue / sharesOutstanding;

  if (currentPrice > 0) {
    marginOfSafety = ((intrinsicValuePerShare - currentPrice) / currentPrice * 100);
    verdictText = intrinsicValuePerShare > currentPrice ? "Undervalued" : "Overvalued";
    verdictColor = intrinsicValuePerShare > currentPrice ? "#10b981" : "#ef4444";
  }
}

// Prepare historical arrays for rendering
// stockanalysis is latest first. Let's reverse for chronological chart display.
const revenueHistoryRev = data.revenueHistory.length > 0 ? [...data.revenueHistory].reverse() : [];
const fcfHistoryRev = data.fcfHistory.length > 0 ? [...data.fcfHistory].reverse() : [];
const epsHistoryRev = data.epsHistory.length > 0 ? [...data.epsHistory].reverse() : [];

// Chart labels (years). Let's assume the array is 5 items. TTM is usually the most recent.
// We'll generate simple 'Year -4' to 'TTM' labels.
const yearLabels = ["Y-4", "Y-3", "Y-2", "Y-1", "TTM"];

// Sensitivity analysis
const sensitivityRates = [0.072, 0.082, 0.092, 0.102, 0.112];
const sensitivityGrowth = [0.03, 0.04, 0.05, 0.06, 0.07];
let sensitivityTable = [];

if (fcfLatest !== null && sharesOutstanding !== null && netCash !== null) {
  sensitivityTable = sensitivityRates.map(dr => {
    return {
      dr,
      values: sensitivityGrowth.map(gr => {
        let f = fcfLatest;
        let pSum = 0;
        for (let y = 1; y <= 5; y++) {
          f = f * (1 + gr);
          pSum += f / Math.pow(1 + dr, y);
        }
        const f6 = f * (1 + growthRateTerminal);
        const tv = f6 / (dr - growthRateTerminal);
        const pTV = tv / Math.pow(1 + dr, 5);
        return Math.round((pSum + pTV + netCash) / sharesOutstanding);
      })
    };
  });
}

