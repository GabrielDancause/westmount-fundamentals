    color: var(--text-bright, #fff);
  }

  .stat-value.accent { color: #4a8fe7; }
  .stat-value.positive { color: #10b981; }
  .stat-value.negative { color: #ef4444; }

  .stat-sub {
    font-size: 0.75rem;
    color: var(--text-dim, #94a3b8);
    margin-top: 0.25rem;
  }

  /* Calculator Cards */
  .calculator-card {
    background: #0d1117;
    border: 1px solid #30363d;
    border-radius: 16px;
    padding: 2rem;
    margin: 2rem 0;
  }

  .calculator-card h2 {
    margin-top: 0;
    font-size: 1.4rem;
  }

  .input-row {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 1rem;
  }

  .input-group {
    margin-bottom: 1rem;
  }

  .input-group label {
    display: block;
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--text-primary, #c8d0de);
    margin-bottom: 0.4rem;
  }

  .input-wrapper {
    display: flex;
    align-items: center;
    background: #161b22;
    border: 1px solid #30363d;
    border-radius: 8px;
    overflow: hidden;
  }

  .input-wrapper .prefix,
  .input-wrapper .suffix {
    padding: 0.6rem 0.75rem;
    color: var(--text-dim, #94a3b8);
    font-weight: 600;
    font-size: 0.9rem;
  }

  .input-wrapper input {
    flex: 1;
    background: transparent;
    border: none;
    color: var(--text-bright, #fff);
    font-size: 1rem;
    padding: 0.6rem;
    outline: none;
    width: 100%;
  }

  .input-group > input {
    background: #161b22;
    border: 1px solid #30363d;
    border-radius: 8px;
    color: var(--text-bright, #fff);
    font-size: 1rem;
    padding: 0.6rem 0.75rem;
    outline: none;
    width: 100%;
    box-sizing: border-box;
  }

  .calc-btn {
    display: block;
    width: 100%;
    padding: 0.85rem;
    background: #4a8fe7;
    color: #fff;
    font-weight: 700;
    font-size: 1rem;
    border: none;
    border-radius: 10px;
    cursor: pointer;
    margin-top: 0.5rem;
    transition: opacity 0.2s;
  }

  .calc-btn:hover { opacity: 0.85; }

  .result-box {
    margin-top: 1.5rem;
    padding: 1.5rem;
    background: #161b22;
    border: 1px solid #30363d;
    border-radius: 12px;
    text-align: center;
  }

  .result-label {
    font-size: 0.85rem;
    color: var(--text-dim, #94a3b8);
    text-transform: uppercase;
    letter-spacing: 0.5px;
    margin-bottom: 0.5rem;
  }

  .result-value {
    font-size: 2.5rem;
    font-weight: 800;
    color: #4a8fe7;
  }

  .result-detail {
    font-size: 0.9rem;
    color: var(--text-dim, #94a3b8);
    margin-top: 0.5rem;
  }

  /* Charts */
  .chart-container {
    background: #0d1117;
    border: 1px solid #30363d;
    border-radius: 12px;
    padding: 1.5rem;
    margin: 1rem 0;
  }

  /* Content Sections */
  .content-section {
    margin-top: 3rem;
  }

  /* Formula Box */
  .formula-box {
    background: #0d1117;
    border: 1px solid #30363d;
    border-radius: 10px;
    padding: 1.25rem;
    text-align: center;
    margin: 1rem 0;
  }

  .formula-box code {
    font-size: 1.1rem;
    color: #4a8fe7;
    font-weight: 600;
  }

  /* Insights Grid */
  .insights-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
    margin-top: 1rem;
  }

  .insight-card {
    background: #0d1117;
    border: 1px solid #30363d;
    border-radius: 12px;
    padding: 1.25rem 1.5rem;
    display: flex;
    gap: 1rem;
    align-items: flex-start;
  }

  .insight-num {
    flex-shrink: 0;
    width: 36px;
    height: 36px;
    background: #4a8fe7;
    color: #fff;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 800;
    font-size: 0.9rem;
  }

  .insight-card h3 {
    margin-top: 0;
    margin-bottom: 0.25rem;
    font-size: 1rem;
  }

  .insight-card p {
    margin: 0;
    font-size: 0.9rem;
  }

  /* Data Table */
  .table-wrapper {
    overflow-x: auto;
    border-radius: 12px;
    border: 1px solid #30363d;
  }

  .data-table {
    width: 100%;
    border-collapse: collapse;
    background: #0d1117;
  }

  .data-table th {
    background: #161b22;
    color: var(--text-primary, #c8d0de);
    padding: 0.75rem 1rem;
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    text-align: left;
    border-bottom: 1px solid #30363d;
  }

  .data-table td {
    padding: 0.6rem 1rem;
    color: var(--text-secondary, #b0bac9);
    border-bottom: 1px solid #30363d;
    font-size: 0.9rem;
  }

  .data-table tr:last-child td {
    border-bottom: none;
  }

  .data-table tr:hover td {
    background: #161b22;
  }

  /* FAQ */
  .faq-container {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .faq-details {
    background: #0d1117;
    border: 1px solid #30363d;
    border-radius: 12px;
    overflow: hidden;
  }

  .faq-summary {
    padding: 1.25rem;
    cursor: pointer;
    font-weight: 600;
    color: var(--text-bright, #fff);
    list-style: none;
    position: relative;
    padding-right: 3rem;
  }

  .faq-summary::-webkit-details-marker { display: none; }

  .faq-summary::after {
    content: '+';
    position: absolute;
    right: 1.25rem;
    top: 50%;
    transform: translateY(-50%);
    font-size: 1.5rem;
    color: #4a8fe7;
    transition: transform 0.2s;
  }

  .faq-details[open] .faq-summary::after {
    content: '−';
  }

  .faq-answer {
    padding: 0 1.25rem 1.25rem;
    color: var(--text-secondary, #b0bac9);
    border-top: 1px solid #30363d;
    margin-top: 1rem;
    padding-top: 1rem;
  }

  .faq-answer p:last-child { margin-bottom: 0; }

  @media (max-width: 768px) {
    .stats-grid {
      grid-template-columns: repeat(2, 1fr);
    }
    h1 { font-size: 1.8rem; }
    .stat-value { font-size: 1.5rem; }
    .result-value { font-size: 2rem; }
  }

  @media (max-width: 480px) {
    .stats-grid {
      grid-template-columns: 1fr;
    }
    .page-content { padding: 16px; }
    .calculator-card { padding: 1.25rem; }
    .input-row {
      grid-template-columns: 1fr;
    }
  }
</style>

<script is:inline src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script is:inline>
  // CPI index values (approximate, 1982-84=100)
  var cpiData = {
    1960: 29.6, 1961: 29.9, 1962: 30.2, 1963: 30.6, 1964: 31.0, 1965: 31.5,
    1966: 32.4, 1967: 33.4, 1968: 34.8, 1969: 36.7, 1970: 38.8, 1971: 40.5,
    1972: 41.8, 1973: 44.4, 1974: 49.3, 1975: 53.8, 1976: 56.9, 1977: 60.6,
    1978: 65.2, 1979: 72.6, 1980: 82.4, 1981: 90.9, 1982: 96.5, 1983: 99.6,
    1984: 103.9, 1985: 107.6, 1986: 109.6, 1987: 113.6, 1988: 118.3, 1989: 124.0,
    1990: 130.7, 1991: 136.2, 1992: 140.3, 1993: 144.5, 1994: 148.2, 1995: 152.4,
    1996: 156.9, 1997: 160.5, 1998: 163.0, 1999: 166.6, 2000: 172.2, 2001: 177.1,
    2002: 179.9, 2003: 184.0, 2004: 188.9, 2005: 195.3, 2006: 201.6, 2007: 207.3,
    2008: 215.3, 2009: 214.5, 2010: 218.1, 2011: 224.9, 2012: 229.6, 2013: 233.0,
    2014: 236.7, 2015: 237.0, 2016: 240.0, 2017: 245.1, 2018: 251.1, 2019: 255.7,
    2020: 258.8, 2021: 271.0, 2022: 292.7, 2023: 304.7, 2024: 313.5, 2025: 322.3
  };

  var inflationByYear = {
    1960:1.7,1961:1.0,1962:1.0,1963:1.3,1964:1.3,1965:1.6,1966:2.9,1967:3.1,1968:4.2,1969:5.5,
    1970:5.7,1971:4.4,1972:3.2,1973:6.2,1974:11.0,1975:9.1,1976:5.8,1977:6.5,1978:7.6,1979:11.3,
    1980:13.5,1981:10.3,1982:6.2,1983:3.2,1984:4.3,1985:3.6,1986:1.9,1987:3.6,1988:4.1,1989:4.8,
    1990:5.4,1991:4.2,1992:3.0,1993:3.0,1994:2.6,1995:2.8,1996:3.0,1997:2.3,1998:1.6,1999:2.2,
    2000:3.4,2001:2.8,2002:1.6,2003:2.3,2004:2.7,2005:3.4,2006:3.2,2007:2.8,2008:3.8,2009:-0.4,
    2010:1.6,2011:3.2,2012:2.1,2013:1.5,2014:1.6,2015:0.1,2016:1.3,2017:2.1,2018:2.4,2019:1.8,
    2020:1.2,2021:4.7,2022:8.0,2023:4.1,2024:2.9,2025:2.8
  };

  // Calculator 1: Inflation-Adjusted Value
  var adjForm = document.getElementById("adj-form");
  if (adjForm) {
    adjForm.addEventListener("submit", function(e) {
      e.preventDefault();
      var amount = parseFloat(document.getElementById("adj-amount").value);
      var startY = parseInt(document.getElementById("adj-start").value);
      var endY = parseInt(document.getElementById("adj-end").value);
      if (!cpiData[startY] || !cpiData[endY]) {
        alert("Please enter years between 1960 and 2025.");
        return;
      }
      var adjusted = amount * (cpiData[endY] / cpiData[startY]);
      var pctChange = ((cpiData[endY] - cpiData[startY]) / cpiData[startY]) * 100;
      document.getElementById("adj-value").textContent = "$" + adjusted.toLocaleString("en-US", {minimumFractionDigits: 2, maximumFractionDigits: 2});
      var direction = endY > startY ? "increased" : "changed";
      document.getElementById("adj-detail").textContent = "$" + amount.toLocaleString() + " in " + startY + " has the same purchasing power as $" + adjusted.toLocaleString("en-US", {minimumFractionDigits: 2, maximumFractionDigits: 2}) + " in " + endY + " (" + (pctChange >= 0 ? "+" : "") + pctChange.toFixed(1) + "% cumulative inflation)";
      document.getElementById("adj-result").style.display = "block";
    });
  }

  // Calculator 2: Real Return (Fisher Equation)
  var realForm = document.getElementById("real-form");
  if (realForm) {
    realForm.addEventListener("submit", function(e) {
      e.preventDefault();
      var nominal = parseFloat(document.getElementById("nominal-return").value) / 100;
      var infl = parseFloat(document.getElementById("inflation-input").value) / 100;
      var realReturn = ((1 + nominal) / (1 + infl)) - 1;
      var realPct = (realReturn * 100).toFixed(2);
      document.getElementById("real-value").textContent = realPct + "%";
      document.getElementById("real-value").style.color = realReturn >= 0 ? "#10b981" : "#ef4444";
      document.getElementById("real-detail").textContent = "Fisher equation: ((1 + " + (nominal * 100).toFixed(1) + "%) / (1 + " + (infl * 100).toFixed(1) + "%)) - 1 = " + realPct + "% real return";
      document.getElementById("real-result").style.display = "block";
    });
  }

  // Calculator 3: Purchasing Power
  var ppForm = document.getElementById("pp-form");
  if (ppForm) {
    ppForm.addEventListener("submit", function(e) {
      e.preventDefault();
      var amount = parseFloat(document.getElementById("pp-amount").value);
      var years = parseInt(document.getElementById("pp-years").value);
      var rate = parseFloat(document.getElementById("pp-rate").value) / 100;
      var futureValue = amount / Math.pow(1 + rate, years);
      var lostPct = ((amount - futureValue) / amount * 100).toFixed(1);
      document.getElementById("pp-value").textContent = "$" + futureValue.toLocaleString("en-US", {minimumFractionDigits: 2, maximumFractionDigits: 2});
      document.getElementById("pp-value").style.color = "#ef4444";
      document.getElementById("pp-detail").textContent = "In " + years + " years at " + (rate * 100).toFixed(1) + "% inflation, $" + amount.toLocaleString() + " will only buy what $" + futureValue.toLocaleString("en-US", {minimumFractionDigits: 2, maximumFractionDigits: 2}) + " buys today — a " + lostPct + "% loss in purchasing power.";
      document.getElementById("pp-result").style.display = "block";
    });
  }

  // Chart 1: Inflation Rate Over Time (Line Chart with recession shading)
  var lineCtx = document.getElementById("inflation-line-chart");
  if (lineCtx) {
    var years = [];
    var rates = [];
    for (var y = 1960; y <= 2025; y++) {
      years.push(y);
      rates.push(inflationByYear[y] || 0);
    }

    // US recession periods (approximate)
    var recessions = [
      {start: 1960, end: 1961}, {start: 1969, end: 1970}, {start: 1973, end: 1975},
      {start: 1980, end: 1980}, {start: 1981, end: 1982}, {start: 1990, end: 1991},
      {start: 2001, end: 2001}, {start: 2007, end: 2009}, {start: 2020, end: 2020}
    ];

    var recessionPlugin = {
      id: "recessionShading",
      beforeDraw: function(chart) {
        var ctx2 = chart.ctx;
        var xScale = chart.scales.x;
        var yScale = chart.scales.y;
        ctx2.save();
        ctx2.fillStyle = "rgba(239, 68, 68, 0.08)";
        for (var i = 0; i < recessions.length; i++) {
          var startIdx = recessions[i].start - 1960;
          var endIdx = recessions[i].end - 1960;
          if (startIdx < 0) startIdx = 0;
          if (endIdx >= years.length) endIdx = years.length - 1;
          var x1 = xScale.getPixelForValue(startIdx);
          var x2 = xScale.getPixelForValue(endIdx);
          ctx2.fillRect(x1, yScale.top, x2 - x1, yScale.bottom - yScale.top);
        }
        ctx2.restore();
      }
    };

    new Chart(lineCtx, {
      type: "line",
      data: {
        labels: years,
        datasets: [{
          label: "US Inflation Rate (%)",
          data: rates,
          borderColor: "#4a8fe7",
          backgroundColor: "rgba(74, 143, 231, 0.1)",
          fill: true,
          tension: 0.3,
          pointRadius: 0,
          pointHoverRadius: 5,
          borderWidth: 2
        }]
      },
      options: {
        responsive: true,
        plugins: {
          legend: { display: false },
          tooltip: {
            callbacks: {
              label: function(ctx) { return "Inflation: " + ctx.parsed.y + "%"; }
            }
          }
        },
        scales: {
          x: {
            grid: { color: "rgba(48,54,61,0.5)" },
            ticks: { color: "#94a3b8", maxTicksLimit: 14 }
          },
          y: {
            grid: { color: "rgba(48,54,61,0.5)" },
            ticks: { color: "#94a3b8", callback: function(v) { return v + "%"; } },
            suggestedMin: -2,
            suggestedMax: 15
          }
        }
      },
      plugins: [recessionPlugin]
    });
  }

  // Chart 2: Average Inflation by Decade (Bar Chart)
  var barCtx = document.getElementById("inflation-bar-chart");
  if (barCtx) {
    var decades = ["1960s", "1970s", "1980s", "1990s", "2000s", "2010s", "2020s"];
    var decadeRanges = [[1960,1969],[1970,1979],[1980,1989],[1990,1999],[2000,2009],[2010,2019],[2020,2025]];
    var decadeAvgs = [];
    for (var d = 0; d < decadeRanges.length; d++) {
      var sum = 0;
      var count = 0;
      for (var yr = decadeRanges[d][0]; yr <= decadeRanges[d][1]; yr++) {
        if (inflationByYear[yr] !== undefined) {
          sum += inflationByYear[yr];
          count++;
        }
      }
      decadeAvgs.push(parseFloat((sum / count).toFixed(1)));
    }

    var barColors = decadeAvgs.map(function(v) {
      if (v > 6) return "#ef4444";
      if (v > 4) return "#f59e0b";
      if (v > 2) return "#4a8fe7";
      return "#10b981";
    });

    new Chart(barCtx, {
      type: "bar",
      data: {
        labels: decades,
        datasets: [{
          label: "Avg. Inflation Rate (%)",
          data: decadeAvgs,
          backgroundColor: barColors,
          borderRadius: 6,
          borderSkipped: false
        }]
      },
      options: {
        responsive: true,
        plugins: {
          legend: { display: false },
          tooltip: {
            callbacks: {
              label: function(ctx) { return "Avg: " + ctx.parsed.y + "%"; }
            }
          }
        },
        scales: {
          x: {
            grid: { display: false },
            ticks: { color: "#94a3b8" }
          },
          y: {
            grid: { color: "rgba(48,54,61,0.5)" },
            ticks: { color: "#94a3b8", callback: function(v) { return v + "%"; } },
            suggestedMin: 0
          }
        }
      }
    });
  }
</script>
</SiteLayout>
