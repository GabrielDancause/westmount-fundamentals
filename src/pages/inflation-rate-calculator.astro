<SiteLayout site="westmount" title="Inflation Rate Calculator — CPI, Purchasing Power & Real Return" description="Calculate inflation-adjusted values, real returns, and purchasing power loss. Explore historical US inflation rates from 1960-2025 with interactive charts and CPI data." canonical="https://westmountfundamentals.com/inflation-rate-calculator/" schema={schema}>
  <div style="max-width:1280px;margin:0 auto;padding:16px 24px 0;display:flex;justify-content:space-between;align-items:center;font-size:13px;color:var(--text-dim,#94a3b8)">
    <nav aria-label="Breadcrumb"><a href="/" style="color:var(--text-dim,#94a3b8);text-decoration:none">Home</a> <span style="margin:0 6px;opacity:0.5">›</span> <a href="/tools/" style="color:var(--text-dim,#94a3b8);text-decoration:none">Tools</a> <span style="margin:0 6px;opacity:0.5">›</span> <span style="color:var(--text-primary,#c8d0de)">Inflation Rate Calculator</span></nav>
    <span>8 min read</span>
  </div>

  <div class="page-content">
    <h1>Inflation Rate Calculator</h1>
    <p>Understand how inflation erodes your purchasing power over time. Use our free calculators to compute inflation-adjusted values, real investment returns, and future purchasing power based on historical CPI data from 1960 to 2025.</p>

    <!-- Stat Cards -->
    <div class="stats-grid">
      <div class="stat-card">
        <div class="stat-label">Current US Inflation Rate</div>
        <div class="stat-value accent">2.8%</div>
        <div class="stat-sub">2025 (YoY CPI)</div>
      </div>
      <div class="stat-card">
        <div class="stat-label">Historical Average</div>
        <div class="stat-value">3.8%</div>
        <div class="stat-sub">1960–2025 mean</div>
      </div>
      <div class="stat-card">
        <div class="stat-label">Highest Recorded</div>
        <div class="stat-value negative">13.5%</div>
        <div class="stat-sub">1980 (oil crisis)</div>
      </div>
      <div class="stat-card">
        <div class="stat-label">Lowest Recorded</div>
        <div class="stat-value positive">0.1%</div>
        <div class="stat-sub">2015 (near deflation)</div>
      </div>
    </div>

    <!-- Calculator 1: Inflation-Adjusted Value -->
    <div class="calculator-card">
      <h2>💰 Inflation-Adjusted Value Calculator</h2>
      <p style="color:var(--text-dim,#94a3b8);margin-bottom:1.5rem">Calculate what an amount of money from a past year is worth in another year's dollars using historical CPI data.</p>
      <form id="adj-form">
        <div class="input-row">
          <div class="input-group">
            <label for="adj-amount">Dollar Amount</label>
            <div class="input-wrapper">
              <span class="prefix">$</span>
              <input type="number" id="adj-amount" min="0" step="100" value="1000" required>
            </div>
          </div>
          <div class="input-group">
            <label for="adj-start">Start Year</label>
            <input type="number" id="adj-start" min="1960" max="2025" value="2000" required>
          </div>
          <div class="input-group">
            <label for="adj-end">End Year</label>
            <input type="number" id="adj-end" min="1960" max="2025" value="2025" required>
          </div>
        </div>
        <button type="submit" class="calc-btn">Calculate Adjusted Value</button>
      </form>
      <div id="adj-result" class="result-box" style="display:none">
        <div class="result-label">Inflation-Adjusted Value</div>
        <div class="result-value" id="adj-value"></div>
        <div class="result-detail" id="adj-detail"></div>
      </div>
    </div>

    <!-- Calculator 2: Real Return -->
    <div class="calculator-card">
      <h2>📈 Real Return Calculator</h2>
      <p style="color:var(--text-dim,#94a3b8);margin-bottom:1.5rem">Calculate the real (inflation-adjusted) return on your investments using the Fisher equation.</p>
      <form id="real-form">
        <div class="input-row">
          <div class="input-group">
            <label for="nominal-return">Nominal Return (%)</label>
            <div class="input-wrapper">
              <input type="number" id="nominal-return" min="-50" max="200" step="0.1" value="10" required>
              <span class="suffix">%</span>
            </div>
          </div>
          <div class="input-group">
            <label for="inflation-input">Inflation Rate (%)</label>
            <div class="input-wrapper">
              <input type="number" id="inflation-input" min="-10" max="100" step="0.1" value="3" required>
              <span class="suffix">%</span>
            </div>
          </div>
        </div>
        <button type="submit" class="calc-btn">Calculate Real Return</button>
      </form>
      <div id="real-result" class="result-box" style="display:none">
        <div class="result-label">Real Return (Fisher Equation)</div>
        <div class="result-value" id="real-value"></div>
        <div class="result-detail" id="real-detail"></div>
      </div>
    </div>

    <!-- Calculator 3: Purchasing Power -->
    <div class="calculator-card">
      <h2>🛒 Purchasing Power Calculator</h2>
      <p style="color:var(--text-dim,#94a3b8);margin-bottom:1.5rem">See how much your money will be worth in the future given a constant inflation rate.</p>
      <form id="pp-form">
        <div class="input-row">
          <div class="input-group">
            <label for="pp-amount">Current Amount</label>
            <div class="input-wrapper">
              <span class="prefix">$</span>
              <input type="number" id="pp-amount" min="0" step="100" value="100000" required>
            </div>
          </div>
          <div class="input-group">
            <label for="pp-years">Years Into Future</label>
            <input type="number" id="pp-years" min="1" max="100" step="1" value="20" required>
          </div>
          <div class="input-group">
            <label for="pp-rate">Annual Inflation (%)</label>
            <div class="input-wrapper">
              <input type="number" id="pp-rate" min="0" max="50" step="0.1" value="3" required>
              <span class="suffix">%</span>
            </div>
