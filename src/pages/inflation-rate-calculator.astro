    "mainEntity": [
      { "@type": "Question", "name": "What is the current US inflation rate?", "acceptedAnswer": { "@type": "Answer", "text": "As of early 2025, the US inflation rate is approximately 2.8% year-over-year, measured by the Consumer Price Index (CPI). This is down significantly from the 2022 peak of 8.0% and is approaching the Federal Reserve's long-term target of 2%." } },
