  <script is:inline>
function calculateTaxSavings() {
            const gains = parseFloat(document.getElementById('realized-gains').value) || 0;
            const losses = parseFloat(document.getElementById('realized-losses').value) || 0;
            const stRate = parseFloat(document.getElementById('st-tax-rate').value) || 0;
            const ltRate = parseFloat(document.getElementById('lt-tax-rate').value) || 0;

            const net = gains - losses;

            let offsetAmount = 0;
            let incomeDeduct = 0;
            let carryForward = 0;
            let savings = 0;

            if (net < 0) {
                // Net loss
                const netLoss = Math.abs(net);
                offsetAmount = gains;
                incomeDeduct = Math.min(netLoss, 3000);
                carryForward = Math.max(0, netLoss - 3000);

                // Simplified savings calculation:
                // Savings from offsetting gains (assume ST for max illustration)
                const savingsFromGains = offsetAmount * stRate;
                // Savings from income deduction
                const savingsFromIncome = incomeDeduct * stRate;

                savings = savingsFromGains + savingsFromIncome;

            } else {
                // Net gain or 0
                offsetAmount = losses;
                incomeDeduct = 0;
                carryForward = 0;

                savings = offsetAmount * stRate;
            }

            const formatter = new Intl.NumberFormat('en-US', {
                style: 'currency',
                currency: 'USD',
                maximumFractionDigits: 0
            });

            document.getElementById('res-net').textContent = formatter.format(net);
            // Color net red if negative, green if positive
            document.getElementById('res-net').style.color = net < 0 ? '#ef4444' : (net > 0 ? '#22c55e' : 'var(--text-primary)');

            document.getElementById('res-offset').textContent = formatter.format(offsetAmount);
            document.getElementById('res-income-deduct').textContent = formatter.format(incomeDeduct);
            document.getElementById('res-carry').textContent = formatter.format(carryForward);
            document.getElementById('res-savings').textContent = formatter.format(savings);

            document.getElementById('calc-results').style.display = 'block';
        }
  </script>
