---
import SiteLayout from '../layouts/SiteLayout.astro';

// --- METADATA ---
export const meta = {
  title: "PepsiCo, Inc. (PEP) Intrinsic Value",
  description: "An independent discounted cash flow (DCF) intrinsic value analysis of PepsiCo (PEP) compiled entirely by Gemini 3.1.",
  category: "study",
  published: "2026-03-18",
};

// --- DATA & ASSUMPTIONS (FY2025 Actuals) ---
// The prompt requires me to make bold assumptions as Gemini.
// FCF Growth (Y1-Y5): 5.5%. PepsiCo operates a defensive, stable business. With investments in automation and pricing power covering inflation, mid-single-digit growth in cash flow is achievable while defending market share in snacks and beverages.
// Discount Rate (WACC): 7.2%. Given PepsiCo's extremely defensive nature, 0.375 beta, and reliable cash generation, the cost of equity is low. The 4.18% risk-free rate acts as a strong anchor, but PepsiCo warrants a modest ERP due to its defensive characteristics.
// Terminal Growth: 2.5%. Matching long-term inflation targets. A mature consumer staple giant cannot outpace global GDP indefinitely, but its pricing power ensures it won't fall behind.

const baseFCF = 8232; // in Millions (8.23B)
const sharesOut = 1366; // in Millions (1.366B)
const currentPrice = 155.14;
const netCash = 9530 - 53027; // in Millions (Cash 9.53B - Debt 53.0B)

const fcfGrowthRate = 0.055;
const discountRate = 0.072;
const terminalGrowthRate = 0.025;

// --- YEAR 1 TO 5 PROJECTIONS ---
const projections = [];
let prevFCF = baseFCF;

for (let i = 1; i <= 5; i++) {
  const projectedFCF = prevFCF * (1 + fcfGrowthRate);
  const discountFactor = Math.pow(1 + discountRate, i);
  const pvOfFCF = projectedFCF / discountFactor;

  projections.push({
    year: `Year ${i}`,
    fcf: projectedFCF,
    pv: pvOfFCF
  });

  prevFCF = projectedFCF;
}

const sumPvFcf = projections.reduce((sum, p) => sum + p.pv, 0);

// --- TERMINAL VALUE ---
const year5FCF = projections[4].fcf;
const terminalValue = (year5FCF * (1 + terminalGrowthRate)) / (discountRate - terminalGrowthRate);
const pvTerminalValue = terminalValue / Math.pow(1 + discountRate, 5);

// --- INTRINSIC VALUE CALCULATION ---
const enterpriseValue = sumPvFcf + pvTerminalValue;
const totalEquityValue = enterpriseValue + netCash;
const intrinsicValuePerShare = totalEquityValue / sharesOut;

// Value vs Current Price
const marginOfSafety = ((intrinsicValuePerShare - currentPrice) / currentPrice) * 100;
const isUndervalued = intrinsicValuePerShare > currentPrice;

// --- SENSITIVITY MATRIX ---
const sensitivityDiscountRates = [0.062, 0.067, 0.072, 0.077, 0.082];
const sensitivityGrowthRates = [0.015, 0.020, 0.025, 0.030, 0.035];

const sensitivityMatrix = sensitivityGrowthRates.map(g => {
  return {
    growthRate: g,
    values: sensitivityDiscountRates.map(d => {
      // Re-calculate TV and PV with new rates
      const currentTerminalValue = (year5FCF * (1 + g)) / (d - g);
      const currentPvTerminalValue = currentTerminalValue / Math.pow(1 + d, 5);

      // Re-calculate PV of FCFs with new discount rate
      let currentSumPvFcf = 0;
      let tempFcf = baseFCF;
      for (let i = 1; i <= 5; i++) {
        tempFcf = tempFcf * (1 + fcfGrowthRate);
        currentSumPvFcf += tempFcf / Math.pow(1 + d, i);
      }

      const currentEV = currentSumPvFcf + currentPvTerminalValue;
      const currentEquity = currentEV + netCash;
      const currentIV = currentEquity / sharesOut;

      return currentIV;
    })
  };
});

// Formatting helpers
const formatMoney = (val) => new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD', minimumFractionDigits: 2, maximumFractionDigits: 2 }).format(val);
const formatMillions = (val) => '$' + new Intl.NumberFormat('en-US', { maximumFractionDigits: 0 }).format(val) + 'M';
const formatPercent = (val) => (val * 100).toFixed(1) + '%';

// --- SCHEMA ---
const schema = [
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": meta.title,
    "description": meta.description,
    "author": {
      "@type": "Organization",
      "name": "Gemini 3.1"
    },
    "publisher": {
      "@type": "Organization",
      "name": "Westmount Fundamentals",
      "logo": {
        "@type": "ImageObject",
        "url": "https://westmountfundamentals.com/logo.png"
      }
    },
    "mainEntityOfPage": {
      "@type": "WebPage",
      "@id": "https://westmountfundamentals.com/pepsico-intrinsic-value"
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "Why did Gemini pick a 5.5% growth rate for PepsiCo?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Gemini projects that PepsiCo's defensive moat in global snacks (Frito-Lay) and beverages supports steady, inflation-beating cash flow growth. Pricing power and automation investments justify a mid-single-digit 5.5% Free Cash Flow expansion over the next 5 years."
        }
      },
      {
        "@type": "Question",
        "name": "What discount rate was used for PepsiCo's DCF?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "A 7.2% discount rate was selected. As a highly defensive consumer staple with a low beta (0.375), PepsiCo carries significantly less market risk than the average stock, allowing for a lower cost of equity relative to the 4.18% 10-year Treasury yield."
        }
      },
      {
        "@type": "Question",
        "name": "Is PepsiCo overvalued or undervalued based on Gemini's model?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": `Based on the DCF analysis using a 7.2% discount rate and 2.5% terminal growth rate, PepsiCo's estimated intrinsic value is ${formatMoney(intrinsicValuePerShare)}, meaning it is currently ${isUndervalued ? 'undervalued' : 'overvalued'} relative to its market price.`
        }
      }
    ]
  }
];
---
<SiteLayout site="westmount" title={meta.title} description={meta.description} canonical="https://westmountfundamentals.com/pepsico-intrinsic-value" schema={schema}>
  <div class="page-content">
    <div class="container">

      <div class="gemini-header">
        <div class="gemini-badge">COMPILED BY GEMINI 2.5 PRO</div>
        <h1>PepsiCo, Inc. (PEP) Intrinsic Value</h1>
        <p class="subtitle">An independent two-stage DCF analysis by a frontier AI model.</p>
        <p class="claude-link">Interested in Tech? See <a href="/google-intrinsic-value">Google's AI Intrinsic Value</a></p>
      </div>

      <div class="verdict-card">
        <div class="verdict-header">
          <h2>Fair Value Estimate</h2>
        </div>
        <div class="verdict-body">
          <div class="verdict-main">
            <span class="iv-value">{formatMoney(intrinsicValuePerShare)}</span>
            <span class="iv-label">per share</span>
          </div>
          <div class="verdict-stats">
            <div class="stat">
              <span class="stat-label">Current Price</span>
              <span class="stat-value">{formatMoney(currentPrice)}</span>
            </div>
            <div class="stat">
              <span class="stat-label">Margin of Safety</span>
              <span class={`stat-value ${isUndervalued ? 'positive' : 'negative'}`}>
                {isUndervalued ? '+' : ''}{marginOfSafety.toFixed(2)}%
              </span>
            </div>
            <div class="stat">
              <span class="stat-label">Verdict</span>
              <span class={`badge ${isUndervalued ? 'positive' : 'negative'}`}>
                {isUndervalued ? 'UNDERVALUED' : 'OVERVALUED'}
              </span>
            </div>
          </div>
        </div>
        <div class="verdict-footer">
          <p>Based on FY2025 actuals. Data via S&P Global (Mar 18, 2026).</p>
        </div>
      </div>

      <section class="content-section">
        <h2>The Thesis: Defensive Quality in a Volatile World</h2>
        <p>While the market chases AI narratives, PepsiCo (PEP) stands as a beacon of defensive, inflation-resistant cash generation. The underlying business is exceptionally resilient: Frito-Lay North America effectively operates as a high-margin monopoly in salty snacks, while the beverage division benefits from immense scale and distribution leverage.</p>
        <p>In valuing a mature consumer staple, predictability is paramount. Unlike high-growth tech where distant cash flows are discounted heavily, PepsiCo's near-term Free Cash Flow is highly visible. Management has demonstrated a consistent ability to pass input costs to the consumer via strategic pricing while investing heavily in automated supply chains to drive margin expansion. This creates a low-risk, compounding machine.</p>
      </section>

      <section class="content-section">
        <h2>My Assumptions & Rationale</h2>

        <div class="assumption-grid">
          <div class="assumption-card">
            <div class="card-title">FCF Growth Rate (Y1-Y5)</div>
            <div class="card-value">{formatPercent(fcfGrowthRate)}</div>
            <p><strong>Rationale:</strong> 5.5% represents steady mid-single-digit expansion. The $8.23B trailing FCF establishes a solid base. Through continuous "productivity initiatives" (automation) and pricing leverage, PepsiCo can realistically grow free cash flow slightly above long-term inflation targets without massive capital expenditures, as they rely on brand equity and entrenched shelf space.</p>
          </div>

          <div class="assumption-card">
            <div class="card-title">Discount Rate (WACC)</div>
            <div class="card-value">{formatPercent(discountRate)}</div>
            <p><strong>Rationale:</strong> A 7.2% discount rate recognizes PepsiCo's incredibly defensive posture. With a 0.375 beta and consumer staple demand inelasticity, market risk is minimal. The 4.18% risk-free rate acts as an anchor, and a modest equity risk premium properly prices the safety of their snacking and beverage oligopoly.</p>
          </div>

          <div class="assumption-card">
            <div class="card-title">Terminal Growth Rate</div>
            <div class="card-value">{formatPercent(terminalGrowthRate)}</div>
            <p><strong>Rationale:</strong> 2.5% matches global long-term inflation targets. PepsiCo cannot outpace global GDP indefinitely, but its pricing power guarantees it won't fall behind. People will continue buying Lay's, Doritos, and Pepsi into perpetuity, allowing the business to effectively pace nominal global economic expansion.</p>
          </div>
        </div>
      </section>

      <section class="content-section">
        <h2>Discounted Cash Flow (DCF) Projections</h2>
        <p>Starting with the FY2025 base FCF of {formatMillions(baseFCF)}, the table below outlines the 5-year projection discounted back to Present Value (PV) using the {formatPercent(discountRate)} WACC.</p>

        <div class="table-container">
          <table>
            <thead>
              <tr>
                <th>Period</th>
                <th>Projected FCF</th>
                <th>PV Factor ({formatPercent(discountRate)})</th>
                <th>Present Value</th>
              </tr>
            </thead>
            <tbody>
              {projections.map((p, index) => (
                <tr>
                  <td>{p.year}</td>
                  <td>{formatMillions(p.fcf)}</td>
                  <td>{(1 / Math.pow(1 + discountRate, index + 1)).toFixed(4)}</td>
                  <td>{formatMillions(p.pv)}</td>
                </tr>
              ))}
              <tr class="highlight-row">
                <td colspan="3"><strong>Sum of PV of FCFs (Years 1-5)</strong></td>
                <td><strong>{formatMillions(sumPvFcf)}</strong></td>
              </tr>
            </tbody>
          </table>
        </div>
      </section>

      <section class="content-section">
        <h2>Terminal & Final Valuation Math</h2>
        <p>The Terminal Value accounts for all cash flows from Year 6 into perpetuity, calculated using the Gordon Growth Model.</p>

        <div class="math-card">
          <div class="math-row">
            <span>Year 5 FCF</span>
            <span>{formatMillions(year5FCF)}</span>
          </div>
          <div class="math-row">
            <span>Terminal Value (TV) Calculation</span>
            <span>({formatMillions(year5FCF)} * {1 + terminalGrowthRate}) / ({discountRate} - {terminalGrowthRate})</span>
          </div>
          <div class="math-row">
            <span>Terminal Value</span>
            <span>{formatMillions(terminalValue)}</span>
          </div>
          <div class="math-row highlight">
            <span>PV of Terminal Value</span>
            <span>{formatMillions(pvTerminalValue)}</span>
          </div>
        </div>

        <p style="margin-top: 2rem;">Adding it all together and adjusting for the massive $53.0B debt load:</p>

        <div class="math-card">
          <div class="math-row">
            <span>Sum of PV of FCFs (Years 1-5)</span>
            <span>{formatMillions(sumPvFcf)}</span>
          </div>
          <div class="math-row">
            <span>+ PV of Terminal Value</span>
            <span>{formatMillions(pvTerminalValue)}</span>
          </div>
          <div class="math-row">
            <span><strong>= Enterprise Value</strong></span>
            <span><strong>{formatMillions(enterpriseValue)}</strong></span>
          </div>
          <div class="math-row">
            <span>+ Net Debt (Cash - Total Debt)</span>
            <span>{formatMillions(netCash)}</span>
          </div>
          <div class="math-row highlight">
            <span><strong>= Total Equity Value</strong></span>
            <span><strong>{formatMillions(totalEquityValue)}</strong></span>
          </div>
          <div class="math-row">
            <span>÷ Shares Outstanding</span>
            <span>{sharesOut.toLocaleString()}M</span>
          </div>
          <div class="math-row result">
            <span><strong>Intrinsic Value Per Share</strong></span>
            <span><strong>{formatMoney(intrinsicValuePerShare)}</strong></span>
          </div>
        </div>
      </section>

      <section class="content-section">
        <h2>Sensitivity Matrix</h2>
        <p>PepsiCo's valuation is highly sensitive to the discount rate due to the long-duration nature of its mature cash flows. The matrix below demonstrates how the intrinsic value shifts across varying terminal growth and WACC assumptions.</p>

        <div class="table-container sensitivity-table">
          <table>
            <thead>
              <tr>
                <th rowspan="2" class="corner-cell">Terminal<br/>Growth</th>
                <th colspan="5" class="header-cell">Discount Rate (WACC)</th>
              </tr>
              <tr>
                {sensitivityDiscountRates.map(d => <th>{formatPercent(d)}</th>)}
              </tr>
            </thead>
            <tbody>
              {sensitivityMatrix.map(row => (
                <tr>
                  <th class="row-header">{formatPercent(row.growthRate)}</th>
                  {row.values.map(val => (
                    <td class={
                      val > currentPrice * 1.10 ? "cell-undervalued" :
                      val < currentPrice * 0.90 ? "cell-overvalued" :
                      "cell-neutral"
                    }>
                      {formatMoney(val)}
                    </td>
                  ))}
                </tr>
              ))}
            </tbody>
          </table>
          <div class="matrix-legend">
            <span class="legend-item"><span class="color-box cell-undervalued"></span> Undervalued (>10% Margin)</span>
            <span class="legend-item"><span class="color-box cell-neutral"></span> Fair Value</span>
            <span class="legend-item"><span class="color-box cell-overvalued"></span> Overvalued (&lt;-10% Margin)</span>
          </div>
        </div>
      </section>

      <section class="content-section risks-section">
        <h2>Key Risks to the Model</h2>
        <p>Despite being a foundational portfolio holding, my DCF assumes a low risk premium. Any disruption to PepsiCo's core business lines could rapidly alter the margin of safety:</p>
        <div class="risk-grid">
          <div class="risk-card">
            <h3>1. GLP-1 and Consumer Health Trends</h3>
            <p>The widespread adoption of GLP-1 weight-loss drugs poses a structural threat to Frito-Lay and sugary beverage volumes. If overall caloric intake drops significantly or consumer preferences rapidly pivot to healthier options, revenue growth will stall.</p>
          </div>
          <div class="risk-card">
            <h3>2. Pricing Elasticity Breaking Point</h3>
            <p>PepsiCo has successfully relied on "shrinkflation" and direct price hikes to protect margins during inflationary periods. The primary risk is reaching a tipping point where consumers trade down to private-label brands, destroying the volume/mix equation.</p>
          </div>
          <div class="risk-card">
            <h3>3. Debt Load Sensitivity</h3>
            <p>Carrying over $53B in total debt acts as a massive anchor on equity value. In a prolonged "higher for longer" interest rate environment, refinancing this debt will increase interest expense and directly compress Free Cash Flow available to shareholders.</p>
          </div>
        </div>
      </section>

      <section class="content-section faq-section">
        <h2>Frequently Asked Questions</h2>

        <div class="faq-item">
          <h3>Why did Gemini pick a 5.5% growth rate for PepsiCo?</h3>
          <p>Gemini projects that PepsiCo's defensive moat in global snacks (Frito-Lay) and beverages supports steady, inflation-beating cash flow growth. Pricing power and automation investments justify a mid-single-digit 5.5% Free Cash Flow expansion over the next 5 years.</p>
        </div>

        <div class="faq-item">
          <h3>What discount rate was used for PepsiCo's DCF?</h3>
          <p>A 7.2% discount rate was selected. As a highly defensive consumer staple with a low beta (0.375), PepsiCo carries significantly less market risk than the average stock, allowing for a lower cost of equity relative to the 4.18% 10-year Treasury yield.</p>
        </div>

        <div class="faq-item">
          <h3>Why does PepsiCo's debt matter in the valuation?</h3>
          <p>Intrinsic value per share reflects the equity value. Since PepsiCo has over $53 Billion in debt compared to less than $10 Billion in cash, we must subtract this net debt from the total Enterprise Value. This significant debt load meaningfully reduces the final intrinsic value per share.</p>
        </div>
      </section>

      <div class="disclaimer-box">
        <p><strong>Disclaimer:</strong> The numbers presented on this page are for educational and entertainment purposes only. They are the result of a deterministic mathematical model fed with assumptions generated by an Artificial Intelligence (Gemini 3.1). This does not constitute investment advice. Always conduct your own due diligence before investing in the stock market.</p>
      </div>

    </div>
  </div>
</SiteLayout>
