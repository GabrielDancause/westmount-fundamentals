---
import SiteLayout from "../layouts/SiteLayout.astro";

// --- METADATA ---
export const meta = {
  title: "Lam Research Corporation (LRCX) Intrinsic Value - Gemini's DCF Analysis",
  description: "An independent discounted cash flow (DCF) intrinsic value analysis of Lam Research Corporation (LRCX) compiled entirely by Gemini 3.1.",
  category: "study",
  published: "2026-03-18",
};

// --- DATA & ASSUMPTIONS (FY2025 Actuals) ---
// Thesis:
// FCF Growth (Y1-Y5): 16%. Lam Research is a critical supplier of wafer fabrication equipment for semiconductor manufacturing. As AI drives demand for more advanced chips and HBM memory, LRCX's etch and deposition tools will see sustained high demand, leading to strong margin expansion and FCF growth.
// Discount Rate (WACC): 10.5%. Slightly higher beta given cyclicality of semis, 4.18% risk-free rate, plus equity risk premium, offset by strong balance sheet.
// Terminal Growth: 4.0%. Semi cap equipment is entering a "supercycle" where base-level demand grows faster than standard GDP due to the digitization of everything and structural AI tailwinds.

const baseFCF = 5414; // in Millions
const sharesOut = 1248.77; // in Millions
const currentPrice = 229.58;
const netCash = 6390.66 - 4484.51; // Cash - Debt

const fcfGrowthRate = 0.16;
const discountRate = 0.105;
const terminalGrowthRate = 0.04;

// --- YEAR 1 TO 5 PROJECTIONS ---
const projections = [];
let prevFCF = baseFCF;

for (let i = 1; i <= 5; i++) {
  const projectedFCF = prevFCF * (1 + fcfGrowthRate);
  const discountFactor = Math.pow(1 + discountRate, i);
  const pvOfFCF = projectedFCF / discountFactor;

  projections.push({
    year: `Year ${i}`,
    fcf: projectedFCF,
    pv: pvOfFCF
  });

  prevFCF = projectedFCF;
}

const sumPvFcf = projections.reduce((sum, p) => sum + p.pv, 0);

// --- TERMINAL VALUE ---
const year5FCF = projections[4].fcf;
const terminalValue = (year5FCF * (1 + terminalGrowthRate)) / (discountRate - terminalGrowthRate);
const pvTerminalValue = terminalValue / Math.pow(1 + discountRate, 5);

// --- INTRINSIC VALUE CALCULATION ---
const enterpriseValue = sumPvFcf + pvTerminalValue;
const totalEquityValue = enterpriseValue + netCash;
const intrinsicValuePerShare = totalEquityValue / sharesOut;

// Value vs Current Price
const marginOfSafety = ((intrinsicValuePerShare - currentPrice) / currentPrice) * 100;
const isUndervalued = intrinsicValuePerShare > currentPrice;

// --- SENSITIVITY MATRIX ---
const sensitivityDiscountRates = [0.095, 0.100, 0.105, 0.110, 0.115];
const sensitivityGrowthRates = [0.030, 0.035, 0.040, 0.045, 0.050];

const sensitivityMatrix = sensitivityGrowthRates.map(g => {
  return {
    growthRate: g,
    values: sensitivityDiscountRates.map(d => {
      // Re-calculate TV and PV with new rates
      const currentTerminalValue = (year5FCF * (1 + g)) / (d - g);
      const currentPvTerminalValue = currentTerminalValue / Math.pow(1 + d, 5);

      // Re-calculate PV of FCFs with new discount rate
      let currentSumPvFcf = 0;
      let tempFcf = baseFCF;
      for (let i = 1; i <= 5; i++) {
        tempFcf = tempFcf * (1 + fcfGrowthRate);
        currentSumPvFcf += tempFcf / Math.pow(1 + d, i);
      }

      const currentEV = currentSumPvFcf + currentPvTerminalValue;
      const currentEquity = currentEV + netCash;
      const currentIV = currentEquity / sharesOut;

      return currentIV;
    })
  };
});

// Formatting helpers
const formatMoney = (val) => new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD', minimumFractionDigits: 2, maximumFractionDigits: 2 }).format(val);
const formatMillions = (val) => '$' + new Intl.NumberFormat('en-US', { maximumFractionDigits: 0 }).format(val) + 'M';
const formatPercent = (val) => (val * 100).toFixed(1) + '%';

// --- SCHEMA ---
const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Article",
      "headline": meta.title,
      "description": meta.description,
      "author": {
        "@type": "Organization",
        "name": "Gemini 3.1"
      },
      "publisher": {
        "@type": "Organization",
        "name": "Westmount Fundamentals",
        "logo": {
          "@type": "ImageObject",
          "url": "https://westmountfundamentals.com/logo.png"
        }
      },
      "mainEntityOfPage": {
        "@type": "WebPage",
        "@id": "https://westmountfundamentals.com/lam-research-intrinsic-value"
      }
    },
    {
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "Why did Gemini pick a 16% growth rate for Lam Research?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Gemini projects that as AI drives demand for more advanced chips and HBM memory, LRCX's etch and deposition tools will see sustained high demand, leading to strong margin expansion and FCF growth."
          }
        },
        {
          "@type": "Question",
          "name": "What discount rate was used for Lam Research's DCF?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "A 10.5% discount rate was selected. This reflects a slightly higher beta given the cyclicality of semis, combined with a 4.18% risk-free rate, plus equity risk premium, offset by LRCX's strong balance sheet."
          }
        },
        {
          "@type": "Question",
          "name": "Is Lam Research cyclical?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Yes. Lam Research operates in the highly cyclical semiconductor capital equipment market, which means cash flow naturally ebbs and flows with the broader semi cycle. Valuations must account for these historical drawdowns."
          }
        }
      ]
    }
  ]
};
---
<SiteLayout site="westmount" title={meta.title} description={meta.description} canonical="https://westmountfundamentals.com/lam-research-intrinsic-value" schema={schema}>
  <div class="page-content">
    <div class="container">

      <div class="gemini-header">
        <div class="gemini-badge">COMPILED BY GEMINI 3.1</div>
        <h1>Lam Research (LRCX) Intrinsic Value</h1>
        <p class="subtitle">An independent two-stage DCF analysis by a frontier AI model.</p>
      </div>

      <div class="verdict-card">
        <div class="verdict-header">
          <h2>Fair Value Estimate</h2>
        </div>
        <div class="verdict-body">
          <div class="verdict-main">
            <span class="iv-value">{formatMoney(intrinsicValuePerShare)}</span>
            <span class="iv-label">per share</span>
          </div>
          <div class="verdict-stats">
            <div class="stat">
              <span class="stat-label">Current Price</span>
              <span class="stat-value">{formatMoney(currentPrice)}</span>
            </div>
            <div class="stat">
              <span class="stat-label">Margin of Safety</span>
              <span class={`stat-value ${isUndervalued ? 'positive' : 'negative'}`}>
                {isUndervalued ? '+' : ''}{marginOfSafety.toFixed(2)}%
              </span>
            </div>
            <div class="stat">
              <span class="stat-label">Verdict</span>
              <span class={`badge ${isUndervalued ? 'positive' : 'negative'}`}>
                {isUndervalued ? 'UNDERVALUED' : 'OVERVALUED'}
              </span>
            </div>
          </div>
        </div>
        <div class="verdict-footer">
          <p>Based on most recent actuals. Data via S&P Global (Mar 2026).</p>
        </div>
      </div>

      <section class="content-section">
        <h2>The AI Thesis: Why the Supercycle is Real</h2>
        <p>Lam Research is a critical supplier of wafer fabrication equipment (WFE) for semiconductor manufacturing. They hold an essential near-monopoly on certain etch and deposition tools required to make advanced memory (NAND/DRAM) and logic chips. As AI drives insatiable demand for HBM memory and smaller node architectures, LRCX's specialized tools are seeing sustained high demand, bypassing typical cyclic downturns.</p>
        <p>My valuation model assumes that the massive CapEx investments by leading foundries and memory makers are structural. This shifts Lam Research from a purely cyclical stock into a secular growth story, driving robust margin expansion and unparalleled Free Cash Flow (FCF) generation over the next five years.</p>
      </section>

      <section class="content-section">
        <h2>My Assumptions & Rationale</h2>

        <div class="assumption-grid">
          <div class="assumption-card">
            <div class="card-title">FCF Growth Rate (Y1-Y5)</div>
            <div class="card-value">{formatPercent(fcfGrowthRate)}</div>
            <p><strong>Rationale:</strong> 16% accounts for the booming demand for HBM and advanced packaging tools required for AI silicon. The current {formatMillions(baseFCF)} FCF base will compound rapidly as logic and memory makers undergo massive equipment upgrade cycles.</p>
          </div>

          <div class="assumption-card">
            <div class="card-title">Discount Rate (WACC)</div>
            <div class="card-value">{formatPercent(discountRate)}</div>
            <p><strong>Rationale:</strong> A 10.5% discount rate balances structural growth against inherent cyclicality. With the 10-year treasury at 4.18%, the premium reflects LRCX's vulnerability to global macroeconomic slow-downs and cyclical swings, though partially offset by its fortress balance sheet.</p>
          </div>

          <div class="assumption-card">
            <div class="card-title">Terminal Growth Rate</div>
            <div class="card-value">{formatPercent(terminalGrowthRate)}</div>
            <p><strong>Rationale:</strong> 4.0% outpaces global GDP growth. The semiconductor capital equipment sector is entering a "supercycle" where baseline semiconductor content in cars, data centers, and consumer electronics mandates higher perpetual growth.</p>
          </div>
        </div>
      </section>

      <section class="content-section">
        <h2>Discounted Cash Flow (DCF) Projections</h2>
        <p>Starting with the base FCF of {formatMillions(baseFCF)}, the table below outlines the 5-year projection discounted back to Present Value (PV) using the {formatPercent(discountRate)} WACC.</p>

        <div class="table-container">
          <table>
            <thead>
              <tr>
                <th>Period</th>
                <th>Projected FCF</th>
                <th>PV Factor ({formatPercent(discountRate)})</th>
                <th>Present Value</th>
              </tr>
            </thead>
            <tbody>
              {projections.map((p, index) => (
                <tr>
                  <td>{p.year}</td>
                  <td>{formatMillions(p.fcf)}</td>
                  <td>{(1 / Math.pow(1 + discountRate, index + 1)).toFixed(4)}</td>
                  <td>{formatMillions(p.pv)}</td>
                </tr>
              ))}
              <tr class="highlight-row">
                <td colspan="3"><strong>Sum of PV of FCFs (Years 1-5)</strong></td>
                <td><strong>{formatMillions(sumPvFcf)}</strong></td>
              </tr>
            </tbody>
          </table>
        </div>
      </section>

      <section class="content-section">
        <h2>Terminal & Final Valuation Math</h2>
        <p>The Terminal Value accounts for all cash flows from Year 6 into perpetuity, calculated using the Gordon Growth Model.</p>

        <div class="math-card">
          <div class="math-row">
            <span>Year 5 FCF</span>
            <span>{formatMillions(year5FCF)}</span>
          </div>
          <div class="math-row">
            <span>Terminal Value (TV) Calculation</span>
            <span>({formatMillions(year5FCF)} * {1 + terminalGrowthRate}) / ({discountRate} - {terminalGrowthRate})</span>
          </div>
          <div class="math-row">
            <span>Terminal Value</span>
            <span>{formatMillions(terminalValue)}</span>
          </div>
          <div class="math-row highlight">
            <span>PV of Terminal Value</span>
            <span>{formatMillions(pvTerminalValue)}</span>
          </div>
        </div>

        <p style="margin-top: 2rem;">Adding it all together with Net Cash:</p>

        <div class="math-card">
          <div class="math-row">
            <span>Sum of PV of FCFs (Years 1-5)</span>
            <span>{formatMillions(sumPvFcf)}</span>
          </div>
          <div class="math-row">
            <span>+ PV of Terminal Value</span>
            <span>{formatMillions(pvTerminalValue)}</span>
          </div>
          <div class="math-row">
            <span><strong>= Enterprise Value</strong></span>
            <span><strong>{formatMillions(enterpriseValue)}</strong></span>
          </div>
          <div class="math-row">
            <span>+ Net Cash (Cash - Debt)</span>
            <span>{formatMillions(netCash)}</span>
          </div>
          <div class="math-row highlight">
            <span><strong>= Total Equity Value</strong></span>
            <span><strong>{formatMillions(totalEquityValue)}</strong></span>
          </div>
          <div class="math-row">
            <span>÷ Shares Outstanding</span>
            <span>{sharesOut.toLocaleString()}M</span>
          </div>
          <div class="math-row result">
            <span><strong>Intrinsic Value Per Share</strong></span>
            <span><strong>{formatMoney(intrinsicValuePerShare)}</strong></span>
          </div>
        </div>
      </section>

      <section class="content-section">
        <h2>Sensitivity Matrix</h2>
        <p>A single intrinsic value relies on rigid assumptions. The sensitivity matrix below demonstrates how the intrinsic value changes when we adjust the Discount Rate (WACC) and the Terminal Growth Rate.</p>

        <div class="table-container sensitivity-table">
          <table>
            <thead>
              <tr>
                <th rowspan="2" class="corner-cell">Terminal<br/>Growth</th>
                <th colspan="5" class="header-cell">Discount Rate (WACC)</th>
              </tr>
              <tr>
                {sensitivityDiscountRates.map(d => <th>{formatPercent(d)}</th>)}
              </tr>
            </thead>
            <tbody>
              {sensitivityMatrix.map(row => (
                <tr>
                  <th class="row-header">{formatPercent(row.growthRate)}</th>
                  {row.values.map(val => (
                    <td class={
                      val > currentPrice * 1.15 ? "cell-undervalued" :
                      val < currentPrice * 0.85 ? "cell-overvalued" :
                      "cell-neutral"
                    }>
                      {formatMoney(val)}
                    </td>
                  ))}
                </tr>
              ))}
            </tbody>
          </table>
          <div class="matrix-legend">
            <span class="legend-item"><span class="color-box cell-undervalued"></span> Undervalued (>15% Margin)</span>
            <span class="legend-item"><span class="color-box cell-neutral"></span> Fair Value</span>
            <span class="legend-item"><span class="color-box cell-overvalued"></span> Overvalued (&lt;-15% Margin)</span>
          </div>
        </div>
      </section>

      <section class="content-section risks-section">
        <h2>Risks & Bear Case</h2>
        <p>While my valuation is bullish, a balanced analysis requires identifying the key vectors that could disrupt these assumptions:</p>
        <div class="risk-grid">
          <div class="risk-card">
            <h3>1. Geopolitical Export Controls</h3>
            <p>Lam Research relies heavily on global shipments, particularly to Asia. Strict US export restrictions on advanced semiconductor manufacturing equipment to China can severely cap LRCX's total addressable market and revenue growth.</p>
          </div>
          <div class="risk-card">
            <h3>2. Inherent Cyclicality</h3>
            <p>Despite AI tailwinds, the core semiconductor equipment market is notoriously cyclical. A rapid buildup of capacity followed by a demand slump could result in years of compressed earnings and free cash flow contractions.</p>
          </div>
          <div class="risk-card">
            <h3>3. Concentration Risk</h3>
            <p>A massive portion of revenue comes from a handful of dominant foundries and memory makers (e.g., TSMC, Samsung, SK Hynix). CapEx cuts from any single customer uniquely devastates quarterly projections.</p>
          </div>
        </div>
      </section>

      <section class="content-section faq-section">
        <h2>Frequently Asked Questions</h2>

        <div class="faq-item">
          <h3>Why did Gemini pick a 16% growth rate for Lam Research?</h3>
          <p>Gemini projects that as AI drives demand for more advanced chips and HBM memory, LRCX's etch and deposition tools will see sustained high demand, leading to strong margin expansion and FCF growth.</p>
        </div>

        <div class="faq-item">
          <h3>What discount rate was used for Lam Research's DCF?</h3>
          <p>A 10.5% discount rate was selected. This reflects a slightly higher beta given the cyclicality of semis, combined with a 4.18% risk-free rate, plus equity risk premium, offset by LRCX's strong balance sheet.</p>
        </div>

        <div class="faq-item">
          <h3>Is Lam Research cyclical?</h3>
          <p>Yes. Lam Research operates in the highly cyclical semiconductor capital equipment market, which means cash flow naturally ebbs and flows with the broader semi cycle. Valuations must account for these historical drawdowns.</p>
        </div>
      </section>

      <div class="disclaimer-box">
        <p><strong>Disclaimer:</strong> The numbers presented on this page are for educational and entertainment purposes only. They are the result of a deterministic mathematical model fed with assumptions generated by an Artificial Intelligence (Gemini 3.1). This does not constitute investment advice. Always conduct your own due diligence before investing in the stock market.</p>
      </div>

    </div>
  </div>
</SiteLayout>
