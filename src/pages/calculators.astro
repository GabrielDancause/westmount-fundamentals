---
import SiteLayout from "../layouts/SiteLayout.astro";

export const meta = {
  title: "Free Financial Calculators — 73 Tools for Investors",
  description: "The most comprehensive suite of free financial calculators on the web. 73 interactive tools for valuation, portfolio analysis, retirement planning, dividends, risk assessment, and more.",
  category: "study",
  published: "2026-03-20"
};

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Article",
      "headline": meta.title,
      "description": meta.description,
      "datePublished": "2026-03-20",
      "publisher": { "@type": "Organization", "name": "Westmount Fundamentals" }
    },
    {
      "@type": "FAQPage",
      "mainEntity": [
        { "@type": "Question", "name": "How many financial calculators does Westmount Fundamentals offer?", "acceptedAnswer": { "@type": "Answer", "text": "We offer 73 free financial calculators across 10 categories including valuation, portfolio analysis, retirement planning, dividends, options, risk metrics, and more. All tools are completely free with no signup required." } },
        { "@type": "Question", "name": "Are these financial calculators free to use?", "acceptedAnswer": { "@type": "Answer", "text": "Yes, all 73 calculators are 100% free with no registration, no ads, and no data collection. They run entirely in your browser." } },
        { "@type": "Question", "name": "What is the most popular financial calculator?", "acceptedAnswer": { "@type": "Answer", "text": "Our Intrinsic Value Calculator is the most comprehensive, pre-loaded with DCF analysis for 168 S&P 500 stocks. The Compound Interest Calculator and Amortization Schedule Calculator are also among the most visited." } },
        { "@type": "Question", "name": "Can I use these calculators for stock analysis?", "acceptedAnswer": { "@type": "Answer", "text": "Absolutely. Our valuation calculators (DCF, Graham Number, Margin of Safety, EV/EBITDA) are specifically designed for stock analysis. Many come pre-loaded with real S&P 500 data." } },
        { "@type": "Question", "name": "Do I need to create an account to use the calculators?", "acceptedAnswer": { "@type": "Answer", "text": "No account needed. All calculators work instantly in your browser. Your data stays on your device — we never store or transmit your inputs." } }
      ]
    }
  ]
};

const faqItems = schema["@graph"][1].mainEntity;
---

<SiteLayout site="westmount" title={meta.title} description={meta.description} canonical="https://westmountfundamentals.com/calculators/" schema={JSON.stringify(schema)}>

<style is:inline>
  .hub-hero { text-align:center; padding:3rem 1rem 2rem; background:linear-gradient(135deg,rgba(74,143,231,0.1),rgba(74,143,231,0.02)); border-bottom:1px solid rgba(74,143,231,0.15); }
  .hub-hero h1 { font-size:2.4rem; margin-bottom:0.5rem; color:#e8eaed; line-height:1.2; }
  .hub-hero .subtitle { color:#94a3b8; font-size:1.1rem; max-width:700px; margin:0 auto; }
  .hub-hero .total-badge { display:inline-block; background:rgba(74,143,231,0.15); color:#4a8fe7; padding:6px 16px; border-radius:20px; font-weight:700; font-size:1.3rem; margin-bottom:1rem; }
  
  .hub-container { max-width:1200px; margin:0 auto; padding:0 24px 3rem; }
  
  .search-bar { position:sticky; top:0; z-index:10; background:#060a12; padding:16px 0; border-bottom:1px solid #30363d; margin-bottom:2rem; }
  .search-input { width:100%; padding:12px 16px 12px 44px; background:#0d1117; border:1px solid #30363d; border-radius:8px; color:#e8eaed; font-size:1rem; outline:none; }
  .search-input:focus { border-color:#4a8fe7; }
  .search-icon { position:absolute; left:14px; top:50%; transform:translateY(-50%); color:#94a3b8; font-size:1.1rem; }
  
  .nav-pills { display:flex; flex-wrap:wrap; gap:8px; margin-bottom:2rem; }
  .nav-pill { display:inline-flex; align-items:center; gap:4px; padding:6px 14px; background:#0d1117; border:1px solid #30363d; border-radius:20px; color:#c8d0de; text-decoration:none; font-size:0.85rem; white-space:nowrap; transition:all 0.2s; }
  .nav-pill:hover { border-color:#4a8fe7; color:#4a8fe7; background:rgba(74,143,231,0.08); }
  .nav-count { background:rgba(148,163,184,0.15); padding:1px 7px; border-radius:10px; font-size:0.75rem; color:#94a3b8; }
  
  .cat-section { margin-bottom:2.5rem; }
  .cat-header { display:flex; align-items:flex-start; gap:12px; margin-bottom:1rem; padding-bottom:12px; border-bottom:1px solid #30363d; }
  .cat-icon { font-size:1.8rem; line-height:1; margin-top:2px; }
  .cat-title { font-size:1.3rem; color:#e8eaed; margin:0 0 4px; }
  .cat-desc { color:#94a3b8; font-size:0.9rem; margin:0; max-width:600px; }
  .cat-count { background:rgba(74,143,231,0.12); color:#4a8fe7; padding:4px 12px; border-radius:12px; font-weight:700; font-size:0.9rem; margin-left:auto; white-space:nowrap; }
  
  .calc-grid { display:grid; grid-template-columns:repeat(auto-fill, minmax(280px, 1fr)); gap:10px; }
  .calc-link { display:block; padding:14px 16px; background:#0d1117; border:1px solid #30363d; border-radius:8px; text-decoration:none; color:#c8d0de; transition:all 0.2s; }
  .calc-link:hover { border-color:#4a8fe7; background:rgba(74,143,231,0.05); transform:translateY(-1px); }
  .calc-link-title { font-size:0.95rem; font-weight:500; }
  
  .faq-section { max-width:800px; margin:2rem auto 0; }
  .faq-item { border:1px solid #30363d; border-radius:8px; margin-bottom:8px; overflow:hidden; }
  .faq-item summary { padding:14px 16px; cursor:pointer; color:#e8eaed; font-weight:500; background:#0d1117; }
  .faq-item summary:hover { background:rgba(74,143,231,0.05); }
  .faq-item p { padding:0 16px 14px; color:#94a3b8; margin:0; line-height:1.6; }
  
  @media (max-width:768px) {
    .hub-hero h1 { font-size:1.6rem; }
    .calc-grid { grid-template-columns:1fr 1fr; }
    .cat-header { flex-wrap:wrap; }
  }
  @media (max-width:480px) {
    .calc-grid { grid-template-columns:1fr; }
  }
</style>

