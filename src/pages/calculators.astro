<script is:inline>
  var searchInput = document.getElementById('calcSearch');
  if (searchInput) {
    searchInput.addEventListener('input', function() {
      var query = this.value.toLowerCase();
      var links = document.querySelectorAll('.calc-link');
      var sections = document.querySelectorAll('.cat-section');
      
      for (var i = 0; i < links.length; i++) {
        var title = links[i].textContent.toLowerCase();
        links[i].style.display = title.indexOf(query) !== -1 ? '' : 'none';
      }
      
      for (var j = 0; j < sections.length; j++) {
        var visible = sections[j].querySelectorAll('.calc-link[style=""],.calc-link:not([style])');
        var hasVisible = false;
        var sectionLinks = sections[j].querySelectorAll('.calc-link');
        for (var k = 0; k < sectionLinks.length; k++) {
          if (sectionLinks[k].style.display !== 'none') {
            hasVisible = true;
            break;
          }
        }
        sections[j].style.display = hasVisible ? '' : 'none';
      }
    });
  }
</script>

