---
import SiteLayout from "../layouts/SiteLayout.astro";
import * as cheerio from 'cheerio';

const schema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": "Parker-Hannifin (PH) Intrinsic Value: A DCF Analysis",
  "description": "A transparent, step-by-step discounted cash flow valuation of Parker-Hannifin Corporation. Using actual financials to arrive at a single fair value estimate for PH shares.",
  "datePublished": "2024-03-24",
  "dateModified": "2024-03-24",
  "author": {
    "@type": "Organization",
    "name": "Westmount Research",
    "url": "https://westmountfundamentals.com"
  },
  "publisher": {
    "@type": "Organization",
    "name": "Westmount Research",
    "url": "https://westmountfundamentals.com"
  },
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": "https://westmountfundamentals.com/parker-hannifin-intrinsic-value"
  }
};

export const meta = {
  title: "Parker-Hannifin (PH) Intrinsic Value: A DCF Analysis",
  description: "We ran a full discounted cash flow on Parker-Hannifin using actuals. One number. Every assumption disclosed. Here's what PH is really worth.",
  category: "study",
  published: "2024-03-24",
};

/* ═══════════════════════════════════════════════════════════════
   DATA FETCHING
   Scraping actual financials from stockanalysis.com
   ═══════════════════════════════════════════════════════════════ */
const headers = {
  'User-Agent': 'Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36',
  'Accept': 'text/html,application/xhtml+xml,application/xml;q=0.9,image/avif,image/webp,*/*;q=0.8',
  'Accept-Language': 'en-US,en;q=0.5',
  'Connection': 'keep-alive',
  'Upgrade-Insecure-Requests': '1'
};

async function fetchHtml(url) {
  try {
    const res = await fetch(url, { headers });
    if (!res.ok) throw new Error(`HTTP error! status: ${res.status}`);
    return await res.text();
  } catch (e) {
    console.error(`Failed to fetch ${url}:`, e.message);
    return null;
  }
}

// 1. Fetch current price
let currentPrice = null;
const quoteHtml = await fetchHtml('https://stockanalysis.com/stocks/ph/');
if (quoteHtml) {
  const $q = cheerio.load(quoteHtml);
  const pText = $q('.text-4xl.font-bold').text().trim().replace(/,/g, '');
  if (pText && !isNaN(parseFloat(pText))) currentPrice = parseFloat(pText);
}

// Helper to parse table row values
function parseRow($, rowTitleMatch) {
  let values = [];
  let found = false;
  $('table#main-table tbody tr').each((i, el) => {
    if (found) return;
    let title = $(el).find('td').first().text().trim() || $(el).find('th').first().text().trim();
    if (title === rowTitleMatch) {
      found = true;
      $(el).find('td').each((j, td) => {
        if (j > 0) {
          const valStr = $(td).text().trim().replace(/,/g, '');
          values.push(valStr === '-' ? 0 : parseFloat(valStr));
        }
      });
    }
  });
  return found ? values : null;
}

// 2. Fetch Income Statement (financials)
let revenueArr = null;
let opIncomeArr = null;
let epsArr = null;
let sharesArr = null;
let fcfArr = null;
const isHtml = await fetchHtml('https://stockanalysis.com/stocks/ph/financials/');
if (isHtml) {
  const $is = cheerio.load(isHtml);
  revenueArr = parseRow($is, 'Revenue');
  opIncomeArr = parseRow($is, 'Operating Income');
  epsArr = parseRow($is, 'EPS (Diluted)');
  sharesArr = parseRow($is, 'Shares Outstanding (Diluted)');
  fcfArr = parseRow($is, 'Free Cash Flow');
}

// 3. Fetch Cash Flow Statement
let opCfArr = null;
let capExArr = null;
const cfHtml = await fetchHtml('https://stockanalysis.com/stocks/ph/financials/cash-flow-statement/');
if (cfHtml) {
  const $cf = cheerio.load(cfHtml);
  opCfArr = parseRow($cf, 'Operating Cash Flow');
  capExArr = parseRow($cf, 'Capital Expenditures');
  if (!fcfArr) fcfArr = parseRow($cf, 'Free Cash Flow');
}

// 4. Fetch Balance Sheet
let cashArr = null;
let debtArr = null;
const bsHtml = await fetchHtml('https://stockanalysis.com/stocks/ph/financials/balance-sheet/');
if (bsHtml) {
  const $bs = cheerio.load(bsHtml);
  cashArr = parseRow($bs, 'Cash & Equivalents');
  debtArr = parseRow($bs, 'Total Debt');
}

/* ═══════════════════════════════════════════════════════════════
   DCF MODEL — ALL INPUTS AND CALCULATIONS
   ═══════════════════════════════════════════════════════════════ */

// Base inputs (use index 0, representing TTM/latest reported)
const fcfBase = fcfArr && fcfArr[0] ? fcfArr[0] : 3339;          // Fallback if null
const sharesOutstanding = sharesArr && sharesArr[0] ? sharesArr[0] : 130;
const cashAndInvestments = cashArr && cashArr[0] ? cashArr[0] : 427;
const totalDebt = debtArr && debtArr[0] ? debtArr[0] : 9870;

const netDebt = totalDebt - cashAndInvestments;

// Assumptions
const growthRatePhase1 = 0.08;         // 8% FCF growth, Years 1-5
const growthRateTerminal = 0.03;       // 3% perpetuity growth
const discountRate = 0.095;            // 9.5% WACC

// Phase 1: Project FCF for Years 1-5
const projectedFCF = [];
let fcf = fcfBase;
for (let yr = 1; yr <= 5; yr++) {
  fcf = fcf * (1 + growthRatePhase1);
  projectedFCF.push({
    year: yr,
    fcf: Math.round(fcf),
    pvFactor: 1 / Math.pow(1 + discountRate, yr)
  });
}
projectedFCF.forEach(p => { p.pvFCF = Math.round(p.fcf * p.pvFactor); });

// Phase 2: Terminal Value
const fcfYear6 = projectedFCF[4].fcf * (1 + growthRateTerminal);
const terminalValue = Math.round(fcfYear6 / (discountRate - growthRateTerminal));
const pvTerminalValue = Math.round(terminalValue * projectedFCF[4].pvFactor);

// Enterprise Value
const pvPhase1 = projectedFCF.reduce((sum, p) => sum + p.pvFCF, 0);
const enterpriseValue = pvPhase1 + pvTerminalValue;

// Equity Value
const equityValue = enterpriseValue - netDebt;
const intrinsicValuePerShare = equityValue / sharesOutstanding;
const roundedIV = Math.round(intrinsicValuePerShare * 100) / 100;

// Market comparison
const priceToUse = currentPrice || 550.00;
const marginOfSafety = ((roundedIV - priceToUse) / priceToUse * 100).toFixed(1);
const verdictText = roundedIV > priceToUse ? "Undervalued" : "Overvalued";
const verdictColor = roundedIV > priceToUse ? "#10b981" : "#ef4444";

// Sensitivity table
const sensitivityRates = [0.075, 0.085, 0.095, 0.105, 0.115];
const sensitivityGrowth = [0.06, 0.07, 0.08, 0.09, 0.10];
const sensitivityTable = sensitivityRates.map(dr => {
  return {
    dr,
    values: sensitivityGrowth.map(gr => {
      let f = fcfBase;
      let pvSum = 0;
      for (let y = 1; y <= 5; y++) {
        f = f * (1 + gr);
        pvSum += f / Math.pow(1 + dr, y);
      }
      const f6 = f * (1 + growthRateTerminal);
      const tv = f6 / (dr - growthRateTerminal);
      const pvTV = tv / Math.pow(1 + dr, 5);
      return Math.round((pvSum + pvTV - netDebt) / sharesOutstanding);
    })
  };
});

// Chart History Data
const startYear = new Date().getFullYear() - 5;
const revenueHistory = [];
const fcfHistory = [];
const epsHistory = [];
const marginHistory = [];

if (revenueArr && opIncomeArr && fcfArr && epsArr) {
  // We take the last 5 years up to TTM (indices 5 down to 1) or 4 down to 0, depending on availability.
  // stockanalysis.com puts TTM at index 0, FY at 1, 2, 3, 4, 5
  // We'll map indices 5 down to 1 for history.
  for (let i = 5; i >= 1; i--) {
      const year = startYear + (5 - i);
      const rev = revenueArr[i] || 0;
      const op = opIncomeArr[i] || 0;
      const f = fcfArr[i] || 0;
      const e = epsArr[i] || 0;

      revenueHistory.push({ year, value: rev });
      fcfHistory.push({ year, value: f });
      epsHistory.push({ year, value: e });

      const opMargin = rev > 0 ? ((op / rev) * 100).toFixed(1) : 0;
      const fcfMargin = rev > 0 ? ((f / rev) * 100).toFixed(1) : 0;
      marginHistory.push({ year, operating: opMargin, fcfMargin: fcfMargin });
  }
} else {
  // Fallbacks if scrape failed
  for (let i = 0; i < 5; i++) {
    revenueHistory.push({ year: startYear + i, value: 0 });
    fcfHistory.push({ year: startYear + i, value: 0 });
    epsHistory.push({ year: startYear + i, value: 0 });
    marginHistory.push({ year: startYear + i, operating: 0, fcfMargin: 0 });
  }
}

