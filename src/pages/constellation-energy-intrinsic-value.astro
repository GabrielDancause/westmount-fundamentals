    "@type": "WebPage",
    "@id": "https://westmountfundamentals.com/constellation-energy-intrinsic-value"
  }
};

export const meta = {
  title: "Constellation Energy (CEG) Intrinsic Value: A DCF Analysis",
  description: "We ran a full discounted cash flow on Constellation Energy using FY2025 actuals. One number. Every assumption disclosed.",
  category: "study",
  published: "2026-03-18",
};

/* ═══════════════════════════════════════════════════════════════
   DCF MODEL — ALL INPUTS AND CALCULATIONS
   Every number is sourced from Constellation Energy's FY2025 financials.
   We use a two-stage DCF: high-growth phase (Years 1-5) then terminal value.
   ═══════════════════════════════════════════════════════════════ */

// --- INPUTS (all in millions USD unless noted) ---
const fcf2025 = 1_288;                 // FY2025 Free Cash Flow ($M)
const sharesOutstanding = 314;          // Diluted shares outstanding ($M) — FY2025
const cashAndInvestments = 3_748;       // Cash + short-term investments ($M)
const totalDebt = 8_992;                // Total debt ($M)
const netCash = cashAndInvestments - totalDebt; // -$5,244M

// --- ASSUMPTIONS (fully disclosed below) ---
const growthRatePhase1 = 0.20;         // 20% FCF growth, Years 1-5
const growthRateTerminal = 0.025;      // 2.5% perpetuity growth (terminal)
const discountRate = 0.085;            // 8.5% WACC / required return

// --- PHASE 1: PROJECT FCF FOR YEARS 1-5 ---
const projectedFCF = [];
let fcf = fcf2025;
for (let yr = 1; yr <= 5; yr++) {
  fcf = fcf * (1 + growthRatePhase1);
  projectedFCF.push({ year: yr, fcf: Math.round(fcf), pvFactor: 1 / Math.pow(1 + discountRate, yr) });
}
projectedFCF.forEach(p => { p.pvFCF = Math.round(p.fcf * p.pvFactor); });

// --- PHASE 2: TERMINAL VALUE (Gordon Growth Model) ---
const fcfYear6 = projectedFCF[4].fcf * (1 + growthRateTerminal);
const terminalValue = Math.round(fcfYear6 / (discountRate - growthRateTerminal));
const pvTerminalValue = Math.round(terminalValue * projectedFCF[4].pvFactor);

// --- ENTERPRISE VALUE ---
const pvPhase1 = projectedFCF.reduce((sum, p) => sum + p.pvFCF, 0);
const enterpriseValue = pvPhase1 + pvTerminalValue;

// --- EQUITY VALUE ---
const equityValue = enterpriseValue + netCash;
const intrinsicValuePerShare = equityValue / sharesOutstanding;
const roundedIV = Math.round(intrinsicValuePerShare * 100) / 100;

// Market comparison
const currentPrice = 321.10;
const marginOfSafety = ((roundedIV - currentPrice) / currentPrice * 100).toFixed(1);
const verdictText = roundedIV > currentPrice ? "Undervalued" : "Overvalued";
const verdictColor = roundedIV > currentPrice ? "#10b981" : "#ef4444";

// --- HISTORICAL DATA for charts ---
const revenueHistory = [
  { year: 2021, value: 19_649 },
  { year: 2022, value: 24_440 },
  { year: 2023, value: 24_918 },
  { year: 2024, value: 23_568 },
  { year: 2025, value: 25_533 },
];
const fcfHistory = [
  { year: 2021, value: -2_667 },
  { year: 2022, value: -4_042 },
  { year: 2023, value: -7_723 },
  { year: 2024, value: -5_029 },
  { year: 2025, value: 1_288 },
];
const epsHistory = [
  { year: 2021, value: -0.65 },
  { year: 2022, value: -0.49 },
  { year: 2023, value: 5.01 },
  { year: 2024, value: 11.89 },
  { year: 2025, value: 7.40 },
];
const marginHistory = [
  { year: 2021, operating: -1.76, profit: -0.42, fcfMargin: -13.57 },
  { year: 2022, operating: 2.03, profit: -0.68, fcfMargin: -16.54 },
  { year: 2023, operating: 6.46, profit: 6.33, fcfMargin: -30.99 },
  { year: 2024, operating: 18.47, profit: 15.86, fcfMargin: -21.34 },
  { year: 2025, operating: 12.09, profit: 9.10, fcfMargin: 5.04 },
];

// Sensitivity analysis
const sensitivityRates = [0.065, 0.075, 0.085, 0.095, 0.105];
const sensitivityGrowth = [0.10, 0.15, 0.20, 0.25, 0.30];
const sensitivityTable = sensitivityRates.map(dr => {
  return {
    dr,
    values: sensitivityGrowth.map(gr => {
      let f = fcf2025;
      let pvSum = 0;
      for (let y = 1; y <= 5; y++) {
        f = f * (1 + gr);
        pvSum += f / Math.pow(1 + dr, y);
      }
      const f6 = f * (1 + growthRateTerminal);
      const tv = f6 / (dr - growthRateTerminal);
      const pvTV = tv / Math.pow(1 + dr, 5);
      return Math.round((pvSum + pvTV + netCash) / sharesOutstanding);
    })
  };
});
