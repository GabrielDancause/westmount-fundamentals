---
import SiteLayout from "../layouts/SiteLayout.astro";

const schema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What is the expense ratio for VCSH?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "VCSH has an ultra-low expense ratio of 0.03%, making it one of the most cost-effective short-term corporate bond ETFs available."
      }
    },
    {
      "@type": "Question",
      "name": "What is the yield of VCSH?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "As of our latest data, VCSH has a dividend yield of approximately 4.34%. Yields fluctuate based on interest rates and bond prices."
      }
    },
    {
      "@type": "Question",
      "name": "What is the duration of VCSH?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "VCSH has an average duration of around 2.7 years. This means the fund's price is relatively insulated from interest rate volatility compared to long-term bonds."
      }
    },
    {
      "@type": "Question",
      "name": "How does VCSH compare to IGSB and SPSB?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "VCSH, IGSB, and SPSB all target short-term investment-grade corporate bonds. VCSH generally has comparable yields and slightly lower or matching fees (VCSH: 0.03%, IGSB: 0.04%, SPSB: 0.04%)."
      }
    },
    {
      "@type": "Question",
      "name": "Is VCSH a good investment for conservative portfolios?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes, VCSH is often considered suitable for conservative allocations because it holds high-quality, investment-grade corporate bonds with short maturities, providing better yield than cash while minimizing interest rate and credit risk."
      }
    }
  ]
};

export const meta = {
  title: "VCSH ETF Review: Vanguard Short-Term Corp Bond",
  description: "Complete review of Vanguard Short-Term Corporate Bond ETF (VCSH). Covers expense ratio, yield, duration, vs IGSB & SPSB. Best for fixed-income allocations.",
  category: "tool",
  published: "2026-03-15",
};
---

<SiteLayout
  site="westmount"
  title="VCSH ETF Review: Vanguard Short-Term Corp Bond"
  description="Complete review of Vanguard Short-Term Corporate Bond ETF (VCSH). Covers expense ratio, yield, duration, vs IGSB & SPSB. Best for fixed-income allocations."
  canonical="https://westmountfundamentals.com/vcsh-etf-review-2026" schema={schema}
>
  <style>

    * { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: 'Inter', -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
      background-color: var(--bg-color);
      color: var(--text-main);
      line-height: 1.6;
    }

    a { color: var(--accent-color); text-decoration: none; }
    a:hover { text-decoration: underline; }

    nav {
      position: sticky;
      top: 0;
      z-index: 1000;
      background: rgba(6, 10, 18, 0.85);
      backdrop-filter: blur(12px);
      border-bottom: 1px solid var(--border-color);
      padding: 16px 24px;
      display: flex;
      justify-content: space-between;
      align-items: center;
    }
    nav .brand { font-weight: 800; color: #fff; font-size: 1.1rem; }
    nav .links { display: flex; gap: 20px; font-size: 0.9rem; font-weight: 500; }

    .container { max-width: 1000px; margin: 0 auto; padding: 60px 24px; }

    h1 {
      font-size: 2.8rem;
      font-weight: 900;
      letter-spacing: -1px;
      margin-bottom: 24px;
      background: linear-gradient(90deg, #fff, var(--accent-color));
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      line-height: 1.2;
    }

    .intro { font-size: 1.1rem; color: var(--text-muted); margin-bottom: 40px; max-width: 800px; }

    /* Stats Row */
    .stats-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
      gap: 20px;
      margin-bottom: 40px;
    }
    .stat-card {
      background: var(--card-bg);
      border: 1px solid var(--border-color);
      border-radius: 12px;
      padding: 24px;
      text-align: center;
    }
    .stat-value {
      font-family: 'JetBrains Mono', monospace;
      font-size: 2rem;
      font-weight: 700;
      color: var(--accent-color);
      margin-bottom: 8px;
    }
    .stat-label { font-size: 0.9rem; font-weight: 600; color: var(--text-muted); text-transform: uppercase; letter-spacing: 1px; }

    h2 { font-size: 1.8rem; font-weight: 800; color: #fff; margin: 48px 0 24px; }

    /* Table */
    .table-container { overflow-x: auto; margin-bottom: 40px; border-radius: 12px; border: 1px solid var(--border-color); }
    table { width: 100%; border-collapse: collapse; text-align: left; }
    th { background: #0d1428; padding: 16px; font-weight: 600; color: #fff; border-bottom: 2px solid var(--border-color); white-space: nowrap; }
    td { padding: 16px; border-bottom: 1px solid var(--border-color); font-family: 'JetBrains Mono', monospace; }
    tr:last-child td { border-bottom: none; }
    tr:hover { background: rgba(255,255,255,0.02); }
    .td-ticker { font-weight: 700; color: #fff; }

    /* Content Blocks */
    .content-box {
      background: var(--card-bg);
      border: 1px solid var(--border-color);
      border-radius: 12px;
      padding: 32px;
      margin-bottom: 40px;
    }
    .content-box p { margin-bottom: 16px; }
    .content-box p:last-child { margin-bottom: 0; }

    .chart-container { margin: 40px 0; padding: 20px; background: var(--card-bg); border: 1px solid var(--border-color); border-radius: 12px; }

    /* FAQ */
    .faq-item { margin-bottom: 24px; border-bottom: 1px solid var(--border-color); padding-bottom: 24px; }
    .faq-item:last-child { border-bottom: none; margin-bottom: 0; padding-bottom: 0; }
    .faq-q { font-size: 1.1rem; font-weight: 700; color: #fff; margin-bottom: 12px; }
    .faq-a { color: var(--text-muted); }

    /* Methodology */
    .methodology { font-size: 0.85rem; color: var(--text-muted); background: #0a1020; padding: 24px; border-radius: 8px; margin-top: 60px; border: 1px solid var(--border-color); }

    /* Footer */
    footer { text-align: center; padding: 40px 24px; font-size: 0.85rem; color: #4a5a70; border-top: 1px solid var(--border-color); margin-top: 60px; }

    @media (max-width: 768px) {
      h1 { font-size: 2rem; }
      nav .links { display: none; }
      .container { padding: 40px 20px; }
    }
  </style>

<div class="container">
  <div style="max-width:1280px;margin:0 auto;padding:16px 24px 0;display:flex;justify-content:space-between;align-items:center;font-size:13px;color:var(--text-dim,#94a3b8)">
    <nav aria-label="Breadcrumb"><a href="/" style="color:var(--text-dim,#94a3b8);text-decoration:none">Home</a> <span style="margin:0 6px;opacity:0.5">›</span> <a href="/tools/" style="color:var(--text-dim,#94a3b8);text-decoration:none">Tools</a> <span style="margin:0 6px;opacity:0.5">›</span> <span style="color:var(--text-primary,#c8d0de)">VCSH ETF Review: Vanguard Short-Term Corp Bond</span></nav>
    <span>2 min read</span>
  </div>
    <h1>VCSH ETF Review: Vanguard Short-Term Corporate Bond</h1>
    <p class="intro">An in-depth review of the Vanguard Short-Term Corporate Bond ETF (VCSH). We analyze its yield, duration, expense ratio, and see how it stacks up against competitors like IGSB and SPSB.</p>

    <div class="stats-grid">
      <div class="stat-card">
        <div class="stat-value" id="stat-expense">0.03%</div>
        <div class="stat-label">Expense Ratio</div>
      </div>
      <div class="stat-card">
        <div class="stat-value" id="stat-yield">4.34%</div>
        <div class="stat-label">Dividend Yield</div>
      </div>
      <div class="stat-card">
        <div class="stat-value" id="stat-duration">2.7 years</div>
        <div class="stat-label">Avg Duration</div>
      </div>
      <div class="stat-card">
        <div class="stat-value" id="stat-aum">$48.30B</div>
        <div class="stat-label">Assets (AUM)</div>
      </div>
    </div>

    <h2>Fund Overview</h2>
    <div class="content-box">
      <p>The <strong>Vanguard Short-Term Corporate Bond ETF (VCSH)</strong> is designed to provide conservative fixed-income investors with low-risk exposure to investment-grade corporate bonds. With a short average duration of roughly <strong>2.7 years</strong>, the fund is significantly less sensitive to interest rate fluctuations than intermediate or long-term bond funds.</p>
      <p>Given its extremely low expense ratio of <strong>0.03%</strong>, VCSH effectively minimizes cost drag, passing more of the underlying bond yields directly to investors.</p>
    </div>

    <h2>VCSH vs IGSB vs SPSB Comparison</h2>
    <p class="intro">How does VCSH compare to its direct peers in the short-term corporate bond category?</p>

    <div class="table-container">
      <table id="compTable">
        <thead>
          <tr>
            <th>Ticker</th>
            <th>Fund Name</th>
            <th>Yield</th>
            <th>Expense Ratio</th>
            <th>AUM ($B)</th>
          </tr>
        </thead>
        <tbody id="compBody">
          <!-- Populated by JS -->
        </tbody>
      </table>
    </div>

    <div class="chart-container">
      <canvas id="yieldChart"></canvas>
    </div>

    <h2>Frequently Asked Questions</h2>
    <div class="content-box" id="faq-section">
      <!-- Populated by JS -->
    </div>

    <div class="methodology">
      <strong>Methodology & Data Sources:</strong><br>
      Financial metrics (expense ratios, yields, and AUM) are sourced from the Yahoo Finance API via <code>yahoo-finance2</code>. Yields are presented on a trailing basis where available. Duration and credit quality estimates are based on general issuer guidelines for short-term corporate bond indexes. Data is updated as of 2026.
    </div>
  </div>
  <script is:inline src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>
  <script is:inline>
// Embed JSON data
    const pageData = {"ticker":"VCSH","name":"Vanguard Short-Term Corporate Bond Index Fund ETF Shares","price":79.16,"yield":"4.34","expenseRatio":"0.03","aum":"48.30","duration":"2.7 years","creditQuality":"Investment Grade (A/BBB)","comparison":[{"ticker":"IGSB","name":"iShares 1-5 Year Investment Gra","price":52.5,"yield":"4.44","expenseRatio":"0.04","aum":"22.61"},{"ticker":"SPSB","name":"State Street SPDR Portfolio Sho","price":30.02,"yield":"4.50","expenseRatio":"0.04","aum":"8.93"}]};
    const faqList = [{"question":"What is the expense ratio for VCSH?","answer":"VCSH has an ultra-low expense ratio of 0.03%, making it one of the most cost-effective short-term corporate bond ETFs available."},{"question":"What is the yield of VCSH?","answer":"As of our latest data, VCSH has a dividend yield of approximately 4.34%. Yields fluctuate based on interest rates and bond prices."},{"question":"What is the duration of VCSH?","answer":"VCSH has an average duration of around 2.7 years. This means the fund's price is relatively insulated from interest rate volatility compared to long-term bonds."},{"question":"How does VCSH compare to IGSB and SPSB?","answer":"VCSH, IGSB, and SPSB all target short-term investment-grade corporate bonds. VCSH generally has comparable yields and slightly lower or matching fees (VCSH: 0.03%, IGSB: 0.04%, SPSB: 0.04%)."},{"question":"Is VCSH a good investment for conservative portfolios?","answer":"Yes, VCSH is often considered suitable for conservative allocations because it holds high-quality, investment-grade corporate bonds with short maturities, providing better yield than cash while minimizing interest rate and credit risk."}];

    // Populate Comparison Table
    const tbody = document.getElementById('compBody');
    const allFunds = [
      { ticker: pageData.ticker, name: pageData.name, yield: pageData.yield, expense: pageData.expenseRatio, aum: pageData.aum },
      ...pageData.comparison.map(c => ({ ticker: c.ticker, name: c.name, yield: c.yield, expense: c.expenseRatio, aum: c.aum }))
    ];

    allFunds.forEach(fund => {
      const tr = document.createElement('tr');
      tr.innerHTML = `
        <td class="td-ticker">${fund.ticker}</td>
        <td style="font-family:'Inter', sans-serif;">${fund.name}</td>
        <td>${fund.yield}%</td>
        <td>${fund.expense}%</td>
        <td>${fund.aum === 'N/A' ? 'N/A' : '$' + fund.aum + 'B'}</td>
      `;
      tbody.appendChild(tr);
    });

    // Populate FAQ
    const faqContainer = document.getElementById('faq-section');
    faqList.forEach(item => {
      const div = document.createElement('div');
      div.className = 'faq-item';
      div.innerHTML = `
        <div class="faq-q">${item.question}</div>
        <div class="faq-a">${item.answer}</div>
      `;
      faqContainer.appendChild(div);
    });

    // Chart
    const ctx = document.getElementById('yieldChart').getContext('2d');
    new Chart(ctx, {
      type: 'bar',
      data: {
        labels: allFunds.map(f => f.ticker),
        datasets: [
          {
            label: 'Yield (%)',
            data: allFunds.map(f => parseFloat(f.yield) || 0),
            backgroundColor: '#4a8fe7',
            borderRadius: 4
          },
          {
            label: 'Expense Ratio (bps)',
            data: allFunds.map(f => (parseFloat(f.expense) || 0) * 100),
            backgroundColor: '#e78f4a',
            borderRadius: 4
          }
        ]
      },
      options: {
        responsive: true,
        plugins: {
          legend: { labels: { color: '#c8d0de', font: { family: 'Inter' } } },
          tooltip: {
            backgroundColor: '#0a1020',
            titleColor: '#fff',
            bodyColor: '#c8d0de',
            borderColor: '#152040',
            borderWidth: 1
          }
        },
        scales: {
          y: {
            grid: { color: '#152040' },
            ticks: { color: '#6a7a90', font: { family: 'JetBrains Mono' } }
          },
          x: {
            grid: { display: false },
            ticks: { color: '#c8d0de', font: { family: 'Inter', weight: 'bold' } }
          }
        }
      }
    });
  </script>

  <section style="max-width:800px;margin:40px auto;padding:0 24px">
    <h2 style="font-size:20px;color:var(--text-bright,#fff);margin-bottom:16px">Related Pages</h2>
    <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:12px">
      <a href="/xeqt-etf-review-2026/" style="display:block;padding:16px;background:var(--card-bg,#0a1020);border:1px solid var(--border-color,#152040);border-radius:8px;text-decoration:none;color:var(--text-primary,#c8d0de);transition:transform 0.2s" onmouseover="this.style.transform='translateY(-2px)'" onmouseout="this.style.transform='none'">XEQT ETF Review 2026: iShares All Equity ETF vs VEQT</a>
      <a href="/vti-etf-review-2026/" style="display:block;padding:16px;background:var(--card-bg,#0a1020);border:1px solid var(--border-color,#152040);border-radius:8px;text-decoration:none;color:var(--text-primary,#c8d0de);transition:transform 0.2s" onmouseover="this.style.transform='translateY(-2px)'" onmouseout="this.style.transform='none'">VTI ETF Review 2026: Vanguard Total Stock Market Analysis</a>
      <a href="/voo-etf-review-2026/" style="display:block;padding:16px;background:var(--card-bg,#0a1020);border:1px solid var(--border-color,#152040);border-radius:8px;text-decoration:none;color:var(--text-primary,#c8d0de);transition:transform 0.2s" onmouseover="this.style.transform='translateY(-2px)'" onmouseout="this.style.transform='none'">VOO ETF Review (2026): Vanguard S&P 500 Fees & Performance</a>
      <a href="/vgro-etf-review-2026/" style="display:block;padding:16px;background:var(--card-bg,#0a1020);border:1px solid var(--border-color,#152040);border-radius:8px;text-decoration:none;color:var(--text-primary,#c8d0de);transition:transform 0.2s" onmouseover="this.style.transform='translateY(-2px)'" onmouseout="this.style.transform='none'">VGRO ETF Review 2026: 80/20 Portfolio Canada</a>
    </div>
  </section>
</SiteLayout>
