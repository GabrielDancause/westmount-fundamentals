---
import SiteLayout from "../layouts/SiteLayout.astro";
import * as cheerio from 'cheerio';

const schema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": "Charles Schwab (SCHW) Intrinsic Value: A DCF Analysis",
  "description": "A transparent, step-by-step discounted cash flow valuation of The Charles Schwab Corporation. Using actual financials to arrive at a single fair value estimate for SCHW shares.",
  "datePublished": new Date().toISOString().split('T')[0],
  "dateModified": new Date().toISOString().split('T')[0],
  "author": {
    "@type": "Organization",
    "name": "Westmount Research",
    "url": "https://westmountfundamentals.com"
  },
  "publisher": {
    "@type": "Organization",
    "name": "Westmount Research",
    "url": "https://westmountfundamentals.com"
  },
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": "https://westmountfundamentals.com/charles-schwab-intrinsic-value"
  }
};

export const meta = {
  title: "Charles Schwab (SCHW) Intrinsic Value: A DCF Analysis",
  description: "We ran a full discounted cash flow on Charles Schwab using actuals. One number. Every assumption disclosed. Here's what SCHW is really worth.",
  category: "study",
  published: new Date().toISOString().split('T')[0],
};

// --- DATA FETCHING ---
const headers = { 'User-Agent': 'Mozilla/5.0 (Windows NT 10.0; Win64; x64)' };

const fetchFinancialData = async (url) => {
  try {
    const res = await fetch(url, { headers });
    const text = await res.text();
    const match = text.match(/financialData:\s*(\{[^]*?\})\s*,\s*[a-zA-Z0-9_]+:/);
    if (match) {
      return eval('(' + match[1] + ')');
    }
  } catch (e) {
    console.error("Failed to fetch data from", url, e);
  }
  return null;
};

const fetchPageData = async (url) => {
  try {
    const res = await fetch(url, { headers });
    const text = await res.text();
    const $ = cheerio.load(text);
    const sharesOutStr = $('td:contains("Shares Out")').next().text();
    const priceStr = $('div.text-4xl.font-bold').text();
    let shares = null;
    if (sharesOutStr) {
      if (sharesOutStr.includes('B')) shares = parseFloat(sharesOutStr) * 1000;
      else if (sharesOutStr.includes('M')) shares = parseFloat(sharesOutStr);
    }
    const price = priceStr ? parseFloat(priceStr.replace(/[^0-9.]/g, '')) : null;
    return { shares, price };
  } catch (e) {
    console.error("Failed to fetch page data from", url, e);
    return { shares: null, price: null };
  }
};

const [financials, cashFlow, balanceSheet, profile] = await Promise.all([
  fetchFinancialData('https://stockanalysis.com/stocks/schw/financials/'),
  fetchFinancialData('https://stockanalysis.com/stocks/schw/financials/cash-flow-statement/'),
  fetchFinancialData('https://stockanalysis.com/stocks/schw/financials/balance-sheet/'),
  fetchPageData('https://stockanalysis.com/stocks/schw/')
]);

// --- INPUTS (all in millions USD unless noted) ---
// Note: SCHW is a financial institution, so FCF can be noisy.
// For this model, we'll try to use FCF from the cash flow statement.
// If null, we fall back to defaults (null over fake data).
const latestYear = financials?.fiscalYear ? financials.fiscalYear[0] : null;

// The raw numbers from stockanalysis are in actual dollars.
const formatMillions = (val) => val != null ? Math.round(val / 1_000_000) : null;

const fcfRaw = cashFlow?.fcf ? cashFlow.fcf[0] : null;
const fcfCurrent = formatMillions(fcfRaw);

// Use shares from financials primarily, else from profile
const sharesRaw = financials?.sharesDiluted ? financials.sharesDiluted[0] : null;
const sharesOutstanding = formatMillions(sharesRaw) || (profile.shares ? Math.round(profile.shares) : null);

const cashRaw = balanceSheet?.totalcash ? balanceSheet.totalcash[0] : null;
const debtRaw = balanceSheet?.debt ? balanceSheet.debt[0] : null;
const netCashRaw = balanceSheet?.netCash ? balanceSheet.netCash[0] : null;

const cashAndInvestments = formatMillions(cashRaw);
const totalDebt = formatMillions(debtRaw);
const netCash = formatMillions(netCashRaw);

const revenueRaw = financials?.revenue ? financials.revenue[0] : null;
const revenueCurrent = formatMillions(revenueRaw);

const epsRaw = financials?.epsDiluted ? financials.epsDiluted[0] : null;
const epsCurrent = epsRaw;

const operatingMarginCurrent = financials?.operatingMargin ? financials.operatingMargin[0] * 100 : null;

// Market Comparison
const currentPrice = profile.price || 93.56;

// --- ASSUMPTIONS ---
const growthRatePhase1 = 0.08;         // 8% FCF growth, Years 1-5
const growthRateTerminal = 0.025;      // 2.5% perpetuity growth (terminal)
const discountRate = 0.095;            // 9.5% WACC / required return

// --- PHASE 1: PROJECT FCF FOR YEARS 1-5 ---
const projectedFCF = [];
let fcf = fcfCurrent || 0;
let pvPhase1 = 0;

for (let yr = 1; yr <= 5; yr++) {
  fcf = fcf * (1 + growthRatePhase1);
  const pvFactor = 1 / Math.pow(1 + discountRate, yr);
  const pvFCF = Math.round(fcf * pvFactor);
  projectedFCF.push({ year: yr, fcf: Math.round(fcf), pvFactor, pvFCF });
  pvPhase1 += pvFCF;
}

// --- PHASE 2: TERMINAL VALUE ---
const fcfYear6 = projectedFCF[4]?.fcf * (1 + growthRateTerminal) || 0;
const terminalValue = Math.round(fcfYear6 / (discountRate - growthRateTerminal));
const pvTerminalValue = Math.round(terminalValue * (projectedFCF[4]?.pvFactor || 0));

// --- ENTERPRISE VALUE ---
const enterpriseValue = pvPhase1 + pvTerminalValue;

// --- EQUITY VALUE ---
const equityValue = enterpriseValue + (netCash || 0);
const intrinsicValuePerShare = (sharesOutstanding && sharesOutstanding > 0) ? equityValue / sharesOutstanding : 0;
const roundedIV = Math.round(intrinsicValuePerShare * 100) / 100;

const marginOfSafety = currentPrice > 0 ? (((roundedIV - currentPrice) / currentPrice) * 100).toFixed(1) : "0.0";
const verdictText = roundedIV > currentPrice ? "Undervalued" : "Overvalued";
const verdictColor = roundedIV > currentPrice ? "#10b981" : "#ef4444";

// --- HISTORICAL DATA for charts ---
const getHistory = (arr, isEps = false) => {
  if (!arr) return [];
  return arr.slice(0, 5).reverse().map((val, i) => {
    const yr = financials?.fiscalYear ? financials.fiscalYear[4 - i] : "Year " + (i+1);
    return { year: yr, value: isEps ? val : formatMillions(val) };
  });
};

const revenueHistory = getHistory(financials?.revenue);
const fcfHistory = getHistory(cashFlow?.fcf);
const epsHistory = getHistory(financials?.epsDiluted, true);

const marginHistory = [];
if (financials?.fiscalYear) {
  for (let i = 4; i >= 0; i--) {
    marginHistory.push({
      year: financials.fiscalYear[i],
      operating: financials.operatingMargin ? (financials.operatingMargin[i] * 100).toFixed(1) : null,
      profit: financials.profitMargin ? (financials.profitMargin[i] * 100).toFixed(1) : null,
      fcfMargin: financials.fcfMargin ? (financials.fcfMargin[i] * 100).toFixed(1) : null,
    });
  }
}

// Sensitivity analysis
const sensitivityRates = [0.075, 0.085, 0.095, 0.105, 0.115];
const sensitivityGrowth = [0.04, 0.06, 0.08, 0.10, 0.12];
const sensitivityTable = sensitivityRates.map(dr => {
  return {
    dr,
    values: sensitivityGrowth.map(gr => {
      let f = fcfCurrent || 0;
      let pvSum = 0;
      for (let y = 1; y <= 5; y++) {
        f = f * (1 + gr);
        pvSum += f / Math.pow(1 + dr, y);
      }
      const f6 = f * (1 + growthRateTerminal);
      const tv = f6 / (dr - growthRateTerminal);
      const pvTV = tv / Math.pow(1 + dr, 5);
      return Math.round((pvSum + pvTV + (netCash || 0)) / (sharesOutstanding || 1));
    })
  };
});
