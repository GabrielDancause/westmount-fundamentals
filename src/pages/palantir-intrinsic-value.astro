---
import SiteLayout from "../layouts/SiteLayout.astro";

const schema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": "Palantir (PLTR) Intrinsic Value: A DCF Analysis",
  "description": "A transparent, step-by-step discounted cash flow valuation of Palantir Technologies Inc. Using actual FY2025 financials to arrive at a single fair value estimate for PLTR shares.",
  "datePublished": "2026-03-18",
  "dateModified": "2026-03-18",
  "author": {
    "@type": "Organization",
    "name": "Westmount Research",
    "url": "https://westmountfundamentals.com"
  },
  "publisher": {
    "@type": "Organization",
    "name": "Westmount Research",
    "url": "https://westmountfundamentals.com"
  },
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": "https://westmountfundamentals.com/palantir-intrinsic-value"
  }
};

export const meta = {
  title: "Palantir (PLTR) Intrinsic Value: A DCF Analysis",
  description: "We ran a full discounted cash flow on Palantir using FY2025 actuals. One number. Every assumption disclosed. Here's what PLTR is really worth.",
  category: "study",
  published: "2026-03-18",
};

import * as cheerio from "cheerio";

/* ═══════════════════════════════════════════════════════════════
   LIVE DATA INGESTION (Scraping StockAnalysis for PLTR)
   ═══════════════════════════════════════════════════════════════ */
const finUrl = 'https://stockanalysis.com/stocks/pltr/financials/';
const bsUrl = 'https://stockanalysis.com/stocks/pltr/financials/balance-sheet/';
const cfsUrl = 'https://stockanalysis.com/stocks/pltr/financials/cash-flow-statement/';

const [finRes, bsRes, cfsRes] = await Promise.all([fetch(finUrl), fetch(bsUrl), fetch(cfsUrl)]);
const finHtml = await finRes.text();
const bsHtml = await bsRes.text();
const cfsHtml = await cfsRes.text();

const extractRow = (html, label) => {
  let idx = html.indexOf(`>${label}</a>`);
  if (idx === -1) idx = html.indexOf(`>${label}<`);
  if (idx === -1) return [];

  const chunk = html.slice(idx, idx + 2000);
  const matches = [...chunk.matchAll(/<td[^>]*>([\s\S]*?)<\/td>/g)];
  const data = [];
  for (const m of matches) {
    const text = cheerio.load(m[1]).text().trim();
    if (text === '-') {
      data.push(0);
    } else {
      const val = parseFloat(text.replace(/,/g, '').replace(/%/g, ''));
      if (!isNaN(val)) data.push(val);
    }
  }
  return data;
};

const currentYear = new Date().getFullYear();
const fetchedFCF = extractRow(cfsHtml, "Free Cash Flow");
const fetchedShares = extractRow(finHtml, "Shares Outstanding (Diluted)");
const fetchedCash = extractRow(bsHtml, "Cash &amp; Short-Term Investments");
const fetchedDebt = extractRow(bsHtml, "Total Debt");
const fetchedRevenue = extractRow(finHtml, "Revenue");
const fetchedEPS = extractRow(finHtml, "EPS (Diluted)");
const opMargin = extractRow(finHtml, "Operating Margin");
const profitMargin = extractRow(finHtml, "Profit Margin");
const fcfMargin = extractRow(finHtml, "FCF Margin");

/* ═══════════════════════════════════════════════════════════════
   DCF MODEL — ALL INPUTS AND CALCULATIONS
   We use a two-stage DCF: high-growth phase (Years 1-5) then terminal value.
   ═══════════════════════════════════════════════════════════════ */

// --- INPUTS (all in millions USD unless noted) ---
const fcf2025 = fetchedFCF[0] || null;                 // FY2025 Free Cash Flow ($M)
const sharesOutstanding = fetchedShares[0] || null;    // Diluted shares outstanding ($M)
const cashAndInvestments = fetchedCash[0] || null;     // Cash + short-term investments ($M)
const totalDebt = fetchedDebt[0] || null;              // Total debt ($M)
const netCash = cashAndInvestments - totalDebt;

// --- ASSUMPTIONS (fully disclosed below) ---
const growthRatePhase1 = 0.25;         // 25% FCF growth, Years 1-5
const growthRateTerminal = 0.04;       // 4.0% perpetuity growth (terminal)
const discountRate = 0.09;             // 9% WACC / required return

// --- PHASE 1: PROJECT FCF FOR YEARS 1-5 ---
const projectedFCF = [];
let fcf = fcf2025;
for (let yr = 1; yr <= 5; yr++) {
  fcf = fcf * (1 + growthRatePhase1);
  projectedFCF.push({ year: yr, fcf: Math.round(fcf), pvFactor: 1 / Math.pow(1 + discountRate, yr) });
}
projectedFCF.forEach(p => { p.pvFCF = Math.round(p.fcf * p.pvFactor); });

// --- PHASE 2: TERMINAL VALUE (Gordon Growth Model) ---
const fcfYear6 = projectedFCF[4].fcf * (1 + growthRateTerminal);
const terminalValue = Math.round(fcfYear6 / (discountRate - growthRateTerminal));
const pvTerminalValue = Math.round(terminalValue * projectedFCF[4].pvFactor);

// --- ENTERPRISE VALUE ---
const pvPhase1 = projectedFCF.reduce((sum, p) => sum + p.pvFCF, 0);
const enterpriseValue = pvPhase1 + pvTerminalValue;

// --- EQUITY VALUE ---
const equityValue = enterpriseValue + netCash;
const intrinsicValuePerShare = equityValue / sharesOutstanding;
const roundedIV = Math.round(intrinsicValuePerShare * 100) / 100;

// Market comparison
const currentPrice = 154.07;
const marginOfSafety = ((roundedIV - currentPrice) / currentPrice * 100).toFixed(1);
const verdictText = roundedIV > currentPrice ? "Undervalued" : "Overvalued";
const verdictColor = roundedIV > currentPrice ? "#10b981" : "#ef4444";

// --- HISTORICAL DATA for charts ---
const revenueHistory = [
  { year: currentYear - 5, value: fetchedRevenue[4] || null },
  { year: currentYear - 4, value: fetchedRevenue[3] || null },
  { year: currentYear - 3, value: fetchedRevenue[2] || null },
  { year: currentYear - 2, value: fetchedRevenue[1] || null },
  { year: currentYear - 1, value: fetchedRevenue[0] || null },
];
const fcfHistory = [
  { year: currentYear - 5, value: fetchedFCF[4] || null },
  { year: currentYear - 4, value: fetchedFCF[3] || null },
  { year: currentYear - 3, value: fetchedFCF[2] || null },
  { year: currentYear - 2, value: fetchedFCF[1] || null },
  { year: currentYear - 1, value: fetchedFCF[0] || null },
];
const epsHistory = [
  { year: currentYear - 5, value: fetchedEPS[4] || null },
  { year: currentYear - 4, value: fetchedEPS[3] || null },
  { year: currentYear - 3, value: fetchedEPS[2] || null },
  { year: currentYear - 2, value: fetchedEPS[1] || null },
  { year: currentYear - 1, value: fetchedEPS[0] || null },
];
const marginHistory = [
  { year: currentYear - 5, operating: opMargin[4] || null, profit: profitMargin[4] || null, fcfMargin: fcfMargin[4] || null },
  { year: currentYear - 4, operating: opMargin[3] || null, profit: profitMargin[3] || null, fcfMargin: fcfMargin[3] || null },
  { year: currentYear - 3, operating: opMargin[2] || null, profit: profitMargin[2] || null, fcfMargin: fcfMargin[2] || null },
  { year: currentYear - 2, operating: opMargin[1] || null, profit: profitMargin[1] || null, fcfMargin: fcfMargin[1] || null },
  { year: currentYear - 1, operating: opMargin[0] || null, profit: profitMargin[0] || null, fcfMargin: fcfMargin[0] || null },
];

// Sensitivity analysis
const sensitivityRates = [0.07, 0.08, 0.09, 0.10, 0.11];
const sensitivityGrowth = [0.15, 0.20, 0.25, 0.30, 0.35];
const sensitivityTable = sensitivityRates.map(dr => {
  return {
    dr,
    values: sensitivityGrowth.map(gr => {
      let f = fcf2025;
      let pvSum = 0;
      for (let y = 1; y <= 5; y++) {
        f = f * (1 + gr);
        pvSum += f / Math.pow(1 + dr, y);
      }
      const f6 = f * (1 + growthRateTerminal);
      const tv = f6 / (dr - growthRateTerminal);
      const pvTV = tv / Math.pow(1 + dr, 5);
      return Math.round((pvSum + pvTV + netCash) / sharesOutstanding);
    })
  };
});
