            <td>${p.pvFCF.toLocaleString()}</td>
          </tr>
        )) : <tr><td colspan="4" style="text-align:center">Data unavailable</td></tr>}
        <tr class="row-total">
          <td colspan="3">Sum of Phase 1 PV</td>
          <td class="highlight-cell">{pvPhase1 > 0 ? `$${Math.round(pvPhase1).toLocaleString()}` : 'N/A'}</td>
        </tr>
      </tbody>
    </table>
  </div>

  <!-- ═══ TERMINAL VALUE ═══ -->
  <h3>Terminal Value</h3>
  <div class="table-wrap">
    <table>
      <thead>
        <tr>
          <th style="text-align:left">Component</th>
          <th>Value ($M)</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td>Year 6 FCF (Year 5 × 1.025)</td>
          <td>{fcfYear6 !== null ? `$${Math.round(fcfYear6).toLocaleString()}` : 'N/A'}</td>
        </tr>
        <tr>
          <td>Terminal Value (FCF₆ ÷ (8.5% − 2.5%))</td>
          <td>{terminalValue !== null ? `$${Math.round(terminalValue).toLocaleString()}` : 'N/A'}</td>
        </tr>
        <tr class="row-total">
          <td>PV of Terminal Value</td>
          <td class="highlight-cell">{pvTerminalValue !== null ? `$${Math.round(pvTerminalValue).toLocaleString()}` : 'N/A'}</td>
        </tr>
      </tbody>
    </table>
  </div>

  <!-- ═══ FINAL CALCULATION ═══ -->
  <h3>Final Valuation</h3>
  <div class="table-wrap">
    <table>
      <thead>
        <tr>
          <th style="text-align:left">Component</th>
