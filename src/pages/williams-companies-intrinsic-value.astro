  }
};

/* ═══════════════════════════════════════════════════════════════
   DATA FETCHING
   ═══════════════════════════════════════════════════════════════ */
async function fetchHtml(url) {
  try {
    const res = await fetch(url, {
      headers: {
        'User-Agent': 'Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/122.0.0.0 Safari/537.36',
        'Accept': 'text/html,application/xhtml+xml,application/xml;q=0.9,image/avif,image/webp,*/*;q=0.8',
        'Accept-Language': 'en-US,en;q=0.5',
      }
    });
    if (!res.ok) return null;
    return await res.text();
  } catch (e) {
    return null;
  }
}

function extractRow(html, rowName) {
  if (!html) return [];
  const $ = cheerio.load(html);
  let values = [];
  $('table tbody tr').each((i, el) => {
    const firstTd = $(el).find('td').first().text().trim();
    if (firstTd === rowName) {
      $(el).find('td').each((j, td) => {
        if (j > 0) {
          const valText = $(td).text().trim().replace(/,/g, '');
          if (valText === '-' || valText === '') {
            values.push(null);
          } else {
            values.push(parseFloat(valText));
          }
        }
      });
    }
  });
  return values;
}

const htmlIS = await fetchHtml('https://stockanalysis.com/stocks/wmb/financials/');
const htmlCF = await fetchHtml('https://stockanalysis.com/stocks/wmb/financials/cash-flow-statement/');
const htmlBS = await fetchHtml('https://stockanalysis.com/stocks/wmb/financials/balance-sheet/');

const fcfArr = extractRow(htmlCF, 'Free Cash Flow');
const ocfArr = extractRow(htmlCF, 'Operating Cash Flow');
const sharesArr = extractRow(htmlIS, 'Shares Outstanding (Diluted)');
const cashArr = extractRow(htmlBS, 'Cash & Equivalents');
const debtArr = extractRow(htmlBS, 'Total Debt');

// Parse current price
let currentPrice = null;
if (htmlIS) {
  const priceMatch = htmlIS.match(/<div class="[^"]*text-4xl[^"]*"[^>]*>([\d\.,]+)<\/div>/);
  if (priceMatch && priceMatch[1]) {
    currentPrice = parseFloat(priceMatch[1].replace(/,/g, ''));
  }
}

// Ensure we have current data; index 0 is TTM/latest year
const baseFcf = fcfArr[0] !== undefined ? fcfArr[0] : null;
const baseOcf = ocfArr[0] !== undefined ? ocfArr[0] : null;
const sharesOutstanding = sharesArr[0] !== undefined ? sharesArr[0] : null;
const cashAndInvestments = cashArr[0] !== undefined ? cashArr[0] : null;
const totalDebt = debtArr[0] !== undefined ? debtArr[0] : null;

// The Williams Companies (WMB) is an energy infrastructure operator (pipelines).
// Pipeline MLPs/C-corps often have very high ongoing growth capex which depresses traditional FCF.
// Operating Cash Flow (OCF) is typically used as a base cash proxy for energy infrastructure
// before deducting growth capex, or we use standard FCF if it's stable.
// However, looking at WMB, it generates solid positive FCF. We'll use FCF as the base.
let fcfBase = baseFcf;

let netCash = null;
if (cashAndInvestments !== null && totalDebt !== null) {
  netCash = cashAndInvestments - totalDebt;
}

/* ═══════════════════════════════════════════════════════════════
   DCF MODEL — ASSUMPTIONS & CALCULATIONS
   ═══════════════════════════════════════════════════════════════ */
// Base 10Y Treasury is 4.18%.
// WMB is an energy pipeline utility. Highly stable cash flows (toll road model).
// Cost of capital (WACC) for pipelines is typically 8.0% - 9.0%. We use 8.5%.
const discountRate = 0.085;

// Phase 1 Growth: Modest 5% growth reflecting pipeline expansions and inflation escalators.
const growthRatePhase1 = 0.05;

// Terminal Growth: 2.5%, slightly below GDP reflecting energy transition risks long-term.
const growthRateTerminal = 0.025;

let projectedFCF = [];
let pvPhase1 = 0;
let fcfYear6 = null;
let terminalValue = null;
let pvTerminalValue = null;
let enterpriseValue = null;
let equityValue = null;
let intrinsicValuePerShare = null;
let roundedIV = null;
let marginOfSafety = null;

if (fcfBase !== null && sharesOutstanding !== null && netCash !== null) {
  let fcf = fcfBase;
  for (let yr = 1; yr <= 5; yr++) {
    fcf = fcf * (1 + growthRatePhase1);
    const pvFactor = 1 / Math.pow(1 + discountRate, yr);
    const pvFCF = fcf * pvFactor;
    projectedFCF.push({ year: yr, fcf: Math.round(fcf), pvFactor, pvFCF: Math.round(pvFCF) });
    pvPhase1 += pvFCF;
  }

  fcfYear6 = projectedFCF[4].fcf * (1 + growthRateTerminal);
  terminalValue = fcfYear6 / (discountRate - growthRateTerminal);
  pvTerminalValue = terminalValue * projectedFCF[4].pvFactor;

  enterpriseValue = pvPhase1 + pvTerminalValue;
  equityValue = enterpriseValue + netCash; // netCash is usually deeply negative for pipelines

  intrinsicValuePerShare = equityValue / sharesOutstanding;
  roundedIV = Math.round(intrinsicValuePerShare * 100) / 100;

  if (currentPrice !== null) {
    marginOfSafety = ((roundedIV - currentPrice) / currentPrice * 100).toFixed(1);
  }
}

const verdictText = roundedIV !== null && currentPrice !== null
  ? (roundedIV > currentPrice ? "Undervalued" : "Overvalued")
  : "N/A";
const verdictColor = roundedIV !== null && currentPrice !== null
  ? (roundedIV > currentPrice ? "#10b981" : "#ef4444")
  : "#5a6a80";

// Sensitivity analysis
const sensitivityRates = [0.075, 0.080, 0.085, 0.090, 0.095];
const sensitivityGrowth = [0.03, 0.04, 0.05, 0.06, 0.07];
let sensitivityTable = [];

if (fcfBase !== null && sharesOutstanding !== null && netCash !== null) {
  sensitivityTable = sensitivityRates.map(dr => {
    return {
      dr,
      values: sensitivityGrowth.map(gr => {
        let f = fcfBase;
        let pvSum = 0;
        for (let y = 1; y <= 5; y++) {
          f = f * (1 + gr);
          pvSum += f / Math.pow(1 + dr, y);
        }
        const f6 = f * (1 + growthRateTerminal);
        const tv = f6 / (dr - growthRateTerminal);
        const pvTV = tv / Math.pow(1 + dr, 5);
        return Math.round((pvSum + pvTV + netCash) / sharesOutstanding);
      })
    };
  });
}
