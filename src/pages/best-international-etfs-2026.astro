        // Helper functions
        const formatPct = (val) => val != null ? `${(val * 100).toFixed(2)}%` : 'N/A';
        const formatCur = (val) => val != null ? `$${(val / 1e9).toFixed(1)}B` : 'N/A';
        const getNestedValue = (obj, path) => path.split('.').reduce((acc, part) => acc && acc[part], obj);

        // Populate dynamic stats cards
        const validFeeEtfs = etfData.filter(e => e.expenseRatio != null).sort((a,b) => a.expenseRatio - b.expenseRatio);
