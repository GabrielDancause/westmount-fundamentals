        }

        .table-container {
            overflow-x: auto;
            margin: 0 -2rem;
            padding: 0 2rem;
        }

        table {
            width: 100%;
            border-collapse: collapse;
            text-align: right;
            white-space: nowrap;
        }

        th, td {
            padding: 1rem;
            border-bottom: 1px solid var(--border-color);
        }

        th {
            text-align: right;
            color: var(--text-muted);
            font-size: 0.85rem;
            font-weight: 600;
            text-transform: uppercase;
