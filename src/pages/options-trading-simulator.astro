            <tr>
              <td>Account Value</td>
              <td id="tdBeforeValue">$10,000.00</td>
              <td id="tdExecValue">$10,000.00</td>
              <td id="tdExpValue" class="fw-bold">$0.00</td>
            </tr>
            <tr>
              <td>Available Cash</td>
              <td id="tdBeforeCash">$10,000.00</td>
              <td id="tdExecCash">$0.00</td>
              <td id="tdExpCash">$0.00</td>
            </tr>
            <tr>
              <td>Position Value</td>
              <td>$0.00</td>
