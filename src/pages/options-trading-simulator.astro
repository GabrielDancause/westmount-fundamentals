  <script is:inline>
    function calculateSimulation() {
      const balance = parseFloat(document.getElementById('initialBalance').value);
      const strategy = document.getElementById('strategy').value;
      const strike = parseFloat(document.getElementById('strikePrice').value);
      const premium = parseFloat(document.getElementById('premium').value);
      const contracts = parseInt(document.getElementById('contracts').value, 10);
      const target = parseFloat(document.getElementById('targetPrice').value);

      const errorMsg = document.getElementById('error-message');

      if (isNaN(balance) || isNaN(strike) || isNaN(premium) || isNaN(contracts) || isNaN(target) ||
          balance < 0 || strike < 0 || premium <= 0 || contracts < 1 || target < 0) {
        errorMsg.style.display = 'block';
        errorMsg.innerText = "Please enter valid numerical values.";
        resetDisplays();
        return;
      }

      const multiplier = 100 * contracts;
      const totalPremium = premium * multiplier;

      let breakeven, maxLoss, maxProfit, targetPL, capitalRequired;
      let day1Cash = balance;
      let day1Position = 0;
      let expCash = 0;
      let expPosition = 0;

      // Logic based on strategy
      if (strategy === 'buy_call') {
        capitalRequired = totalPremium;
        if (capitalRequired > balance) {
            showError("Insufficient funds to buy these calls. Lower contracts or increase balance.");
            return;
        }
        breakeven = strike + premium;
        maxLoss = totalPremium;
        maxProfit = Infinity;

        const intrinsicAtTarget = target > strike ? (target - strike) * multiplier : 0;
        targetPL = intrinsicAtTarget - totalPremium;

        day1Cash = balance - totalPremium;
        day1Position = totalPremium; // Value of the bought option
        expCash = day1Cash + intrinsicAtTarget; // Assuming closing or exercising and selling immediately
        expPosition = 0; // Position is resolved

      } else if (strategy === 'sell_call') {
         // Assuming naked/cash secured for margin simplification in this simulator. A truly naked call requires complex margin.
         // We'll simulate standard undefined risk margin loosely, but highlight the danger.
         capitalRequired = strike * 0.2 * multiplier; // Rough margin estimate

         breakeven = strike + premium;
         maxProfit = totalPremium;
         maxLoss = Infinity;

         const intrinsicAtTarget = target > strike ? (target - strike) * multiplier : 0;
         targetPL = totalPremium - intrinsicAtTarget;

         day1Cash = balance + totalPremium;
         day1Position = -totalPremium; // Short position liability
         expCash = day1Cash - intrinsicAtTarget; // Buying back or assigning
         expPosition = 0;

      } else if (strategy === 'buy_put') {
        capitalRequired = totalPremium;
        if (capitalRequired > balance) {
            showError("Insufficient funds to buy these puts. Lower contracts or increase balance.");
            return;
        }
        breakeven = strike - premium;
        maxLoss = totalPremium;
        maxProfit = (strike * multiplier) - totalPremium;

        const intrinsicAtTarget = target < strike ? (strike - target) * multiplier : 0;
        targetPL = intrinsicAtTarget - totalPremium;

        day1Cash = balance - totalPremium;
        day1Position = totalPremium;
        expCash = day1Cash + intrinsicAtTarget;
        expPosition = 0;

      } else if (strategy === 'sell_put') {
        // Cash Secured Put
        capitalRequired = strike * multiplier;
        if (capitalRequired > (balance + totalPremium)) {
             showError("Insufficient funds to cash-secure these puts. Required: $" + capitalRequired.toFixed(2));
             return;
        }
        breakeven = strike - premium;
        maxProfit = totalPremium;
        maxLoss = (strike * multiplier) - totalPremium;

        const intrinsicAtTarget = target < strike ? (strike - target) * multiplier : 0;
        targetPL = totalPremium - intrinsicAtTarget;

        day1Cash = balance + totalPremium;
        day1Position = -totalPremium;
        expCash = day1Cash - intrinsicAtTarget;
        expPosition = 0;
      }

      errorMsg.style.display = 'none';

      const formatCurrency = (val) => {
        return new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD' }).format(val);
      };

      document.getElementById('resBreakeven').innerText = formatCurrency(breakeven);

      if (maxLoss === Infinity) {
          document.getElementById('resMaxLoss').innerText = 'Infinite';
      } else {
          document.getElementById('resMaxLoss').innerText = '-' + formatCurrency(maxLoss);
      }

      if (maxProfit === Infinity) {
        document.getElementById('resMaxProfit').innerText = 'Infinite';
      } else {
        document.getElementById('resMaxProfit').innerText = formatCurrency(maxProfit);
      }

      const targetEl = document.getElementById('resTargetPL');
      targetEl.innerText = formatCurrency(targetPL);
      if (targetPL > 0) {
        targetEl.className = 'result-value positive';
      } else if (targetPL < 0) {
        targetEl.className = 'result-value negative';
      } else {
        targetEl.className = 'result-value';
      }

      // Update Table
      document.getElementById('tdBeforeValue').innerText = formatCurrency(balance);
      document.getElementById('tdBeforeCash').innerText = formatCurrency(balance);

      document.getElementById('tdExecValue').innerText = formatCurrency(day1Cash + day1Position);
      document.getElementById('tdExecCash').innerText = formatCurrency(day1Cash);
      document.getElementById('tdExecPos').innerText = formatCurrency(day1Position);

      const finalAccountValue = expCash + expPosition;
      const tdExpValueEl = document.getElementById('tdExpValue');
      tdExpValueEl.innerText = formatCurrency(finalAccountValue);

      if (finalAccountValue > balance) {
          tdExpValueEl.style.color = 'var(--buy-color)';
      } else if (finalAccountValue < balance) {
          tdExpValueEl.style.color = 'var(--sell-color)';
      } else {
          tdExpValueEl.style.color = 'var(--text-primary)';
      }

      document.getElementById('tdExpCash').innerText = formatCurrency(expCash);
      document.getElementById('tdExpPos').innerText = formatCurrency(expPosition);
    }

    function showError(msg) {
        const errorMsg = document.getElementById('error-message');
        errorMsg.style.display = 'block';
        errorMsg.innerText = msg;
        resetDisplays();
    }

    function resetDisplays() {
        document.getElementById('resBreakeven').innerText = '-';
        document.getElementById('resMaxLoss').innerText = '-';
        document.getElementById('resMaxProfit').innerText = '-';
        document.getElementById('resTargetPL').innerText = '-';

        const formatCurrency = (val) => new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD' }).format(val);
        const bal = parseFloat(document.getElementById('initialBalance').value) || 0;

        document.getElementById('tdBeforeValue').innerText = formatCurrency(bal);
        document.getElementById('tdBeforeCash').innerText = formatCurrency(bal);
        document.getElementById('tdExecValue').innerText = '-';
        document.getElementById('tdExecCash').innerText = '-';
        document.getElementById('tdExecPos').innerText = '-';
        document.getElementById('tdExpValue').innerText = '-';
        document.getElementById('tdExpCash').innerText = '-';
        document.getElementById('tdExpPos').innerText = '-';
    }

    // Attach listeners
    const inputs = ['initialBalance', 'strategy', 'strikePrice', 'premium', 'contracts', 'targetPrice'];
    inputs.forEach(id => {
      document.getElementById(id).addEventListener('input', calculateSimulation);
    });

    // Initial calculation
    calculateSimulation();
  </script>

