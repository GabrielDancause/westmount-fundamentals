  <!-- ═══ CHART.JS ═══ -->
  <script is:inline src="https://cdn.jsdelivr.net/npm/chart.js"></script>

  <!-- ═══ SCRIPTS ═══ -->
  <script is:inline>
  (function() {
    /* ── Waterfall Chart ── */
    var wCtx = document.getElementById('waterfallChart');
    if (wCtx) {
      var labels = ['Revenue', 'COGS', 'Gross Profit', 'SG&A', 'R&D', 'D&A', 'Operating Income', 'Interest', 'Taxes', 'Net Income'];
      var values = [500, -200, 300, -80, -50, -20, 150, -25, -50, 75];
      var baseVals = [];
      var posVals = [];
      var negVals = [];
      var running = 0;
      for (var i = 0; i < values.length; i++) {
        if (i === 0) {
          baseVals.push(0);
          posVals.push(500);
          negVals.push(0);
          running = 500;
        } else if (i === 2 || i === 6 || i === 9) {
          baseVals.push(0);
          posVals.push(values[i]);
          negVals.push(0);
        } else {
          var absVal = Math.abs(values[i]);
          running = running + values[i];
          baseVals.push(running);
          posVals.push(0);
          negVals.push(absVal);
        }
      }
      new Chart(wCtx, {
        type: 'bar',
        data: {
          labels: labels,
          datasets: [
            { label: 'Base', data: baseVals, backgroundColor: 'transparent', borderWidth: 0 },
            { label: 'Positive', data: posVals, backgroundColor: '#10b981', borderRadius: 4 },
            { label: 'Deduction', data: negVals, backgroundColor: '#ef4444', borderRadius: 4 }
          ]
        },
        options: {
          responsive: true,
          maintainAspectRatio: true,
          plugins: {
            legend: { display: false },
            tooltip: {
              callbacks: {
                label: function(ctx) {
                  if (ctx.datasetIndex === 0) return '';
                  return ctx.dataset.label + ': $' + ctx.raw + 'M';
                }
              }
            }
          },
          scales: {
            x: { stacked: true, ticks: { color: '#94a3b8', font: { size: 11 } }, grid: { display: false } },
            y: { stacked: true, ticks: { color: '#94a3b8', callback: function(v) { return '$' + v + 'M'; } }, grid: { color: 'rgba(48,54,61,0.5)' } }
          }
        }
      });
    }

    /* ── Sector Margin Chart ── */
    var sCtx = document.getElementById('sectorChart');
    if (sCtx) {
      var sectors = ['Technology', 'Healthcare', 'Financials', 'Industrials', 'Consumer Staples', 'Energy', 'Retail'];
      var grossData = [65, 55, 0, 35, 38, 42, 28];
      var opData = [30, 22, 35, 14, 12, 18, 6];
      var netData = [22, 15, 25, 9, 8, 10, 3];
      new Chart(sCtx, {
        type: 'bar',
        data: {
          labels: sectors,
          datasets: [
            { label: 'Gross Margin', data: grossData, backgroundColor: '#4a8fe7', borderRadius: 4 },
            { label: 'Operating Margin', data: opData, backgroundColor: '#f59e0b', borderRadius: 4 },
            { label: 'Net Margin', data: netData, backgroundColor: '#10b981', borderRadius: 4 }
          ]
        },
        options: {
          indexAxis: 'y',
          responsive: true,
          maintainAspectRatio: true,
          plugins: {
            legend: { position: 'top', labels: { color: '#94a3b8', usePointStyle: true, pointStyle: 'rectRounded', padding: 16 } },
            tooltip: { callbacks: { label: function(ctx) { return ctx.dataset.label + ': ' + ctx.raw + '%'; } } }
          },
          scales: {
            x: { ticks: { color: '#94a3b8', callback: function(v) { return v + '%'; } }, grid: { color: 'rgba(48,54,61,0.5)' }, max: 75 },
            y: { ticks: { color: '#c8d0de', font: { size: 12 } }, grid: { display: false } }
          }
        }
      });
    }

    /* ── Income Statement Builder ── */
    function fmt(n) {
      if (n >= 1e9 || n <= -1e9) return '$' + (n / 1e9).toFixed(2) + 'B';
      if (n >= 1e6 || n <= -1e6) return '$' + (n / 1e6).toFixed(1) + 'M';
      if (n >= 1e3 || n <= -1e3) return '$' + (n / 1e3).toFixed(1) + 'K';
      return '$' + n.toFixed(0);
    }
    function pct(num, den) {
      if (!den || den === 0) return '—';
      return (num / den * 100).toFixed(1) + '%';
    }
    function calc() {
      var rev = parseFloat(document.getElementById('is-revenue').value) || 0;
      var cogs = parseFloat(document.getElementById('is-cogs').value) || 0;
      var sga = parseFloat(document.getElementById('is-sga').value) || 0;
      var rd = parseFloat(document.getElementById('is-rd').value) || 0;
      var da = parseFloat(document.getElementById('is-da').value) || 0;
      var interest = parseFloat(document.getElementById('is-interest').value) || 0;
      var taxRate = parseFloat(document.getElementById('is-taxrate').value) || 0;

      var gp = rev - cogs;
      var opex = sga + rd + da;
      var oi = gp - opex;
      var ebitda = oi + da;
      var pti = oi - interest;
      var tax = pti > 0 ? pti * (taxRate / 100) : 0;
      var ni = pti - tax;

      document.getElementById('r-gp').textContent = fmt(gp);
      document.getElementById('r-gm').textContent = pct(gp, rev);
      document.getElementById('r-opex').textContent = fmt(opex);
      document.getElementById('r-ebitda').textContent = fmt(ebitda);
      document.getElementById('r-ebitdam').textContent = pct(ebitda, rev);
      document.getElementById('r-oi').textContent = fmt(oi);
      document.getElementById('r-om').textContent = pct(oi, rev);
      document.getElementById('r-pti').textContent = fmt(pti);
      document.getElementById('r-tax').textContent = fmt(tax);
      document.getElementById('r-ni').textContent = fmt(ni);
      document.getElementById('r-nm').textContent = pct(ni, rev);
    }

    var ids = ['is-revenue', 'is-cogs', 'is-sga', 'is-rd', 'is-da', 'is-interest', 'is-taxrate'];
    for (var i = 0; i < ids.length; i++) {
      var el = document.getElementById(ids[i]);
      if (el) el.addEventListener('input', calc);
    }
    calc();
  })();
  </script>

