  <script is:inline src="https://cdn.jsdelivr.net/npm/chart.js"></script>
  <script is:inline>
document.addEventListener('DOMContentLoaded', () => {
            const data = window.__INITIAL_DATA__;
            if (!data || data.length === 0) return;

            // Format helpers
            const formatPct = (val) => (val * 100).toFixed(2) + '%';
            const formatMoney = (val) => new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD', maximumFractionDigits: 0 }).format(val);

            // Calculate overall CAGRs
            const initialInvestment = 10000;
            const years = data.length / 12;

            const first = data[0];
            const last = data[data.length - 1];

            const spNomCagr = Math.pow(last.sp500_tr / first.sp500_tr, 1 / years) - 1;
            const goldNomCagr = Math.pow(last.gold_tr / first.gold_tr, 1 / years) - 1;
            const spRealCagr = Math.pow(last.sp500_real_tr / first.sp500_real_tr, 1 / years) - 1;
            const goldRealCagr = Math.pow(last.gold_real_tr / first.gold_real_tr, 1 / years) - 1;

            document.getElementById('stat-sp-nom').textContent = formatPct(spNomCagr);
            document.getElementById('stat-gold-nom').textContent = formatPct(goldNomCagr);
            document.getElementById('stat-sp-real').textContent = formatPct(spRealCagr);
            document.getElementById('stat-gold-real').textContent = formatPct(goldRealCagr);

            // Prepare Chart Data
            const labels = data.map(d => d.date);

            // Scale data to $10k initial investment
            const getScaled = (key) => {
                const base = data[0][key];
                return data.map(d => (d[key] / base) * initialInvestment);
            };

            const datasetsNominal = {
                sp500: getScaled('sp500_tr'),
                gold: getScaled('gold_tr')
            };

            const datasetsReal = {
                sp500: getScaled('sp500_real_tr'),
                gold: getScaled('gold_real_tr')
            };

            let currentMode = 'nominal';

            const ctx = document.getElementById('mainChart').getContext('2d');

            Chart.defaults.color = '#9ca3af';
            Chart.defaults.font.family = "'Inter', sans-serif";

            let chart = new Chart(ctx, {
                type: 'line',
                data: {
                    labels: labels,
                    datasets: [
                        {
                            label: 'S&P 500 (Total Return)',
                            data: datasetsNominal.sp500,
                            borderColor: '#4a8fe7',
                            backgroundColor: 'rgba(74, 143, 231, 0.2)',
                            fill: true,
                            borderWidth: 2,
                            pointRadius: 0,
                            pointHoverRadius: 4,
                            tension: 0.1
                        },
                        {
                            label: 'Gold',
                            data: datasetsNominal.gold,
                            borderColor: '#fbbf24',
                            backgroundColor: 'rgba(251, 191, 36, 0.2)',
                            fill: true,
                            borderWidth: 2,
                            pointRadius: 0,
                            pointHoverRadius: 4,
                            tension: 0.1
                        }
                    ]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    interaction: {
                        mode: 'index',
                        intersect: false,
                    },
                    plugins: {
                        legend: {
                            position: 'top',
                            labels: {
                                usePointStyle: true,
                                boxWidth: 8
                            }
                        },
                        tooltip: {
                            backgroundColor: 'rgba(10, 16, 32, 0.9)',
                            titleColor: '#fff',
                            bodyColor: '#e5e7eb',
                            borderColor: '#152040',
                            borderWidth: 1,
                            callbacks: {
                                label: function(context) {
                                    let label = context.dataset.label || '';
                                    if (label) {
                                        label += ': ';
                                    }
                                    if (context.parsed.y !== null) {
                                        label += formatMoney(context.parsed.y);
                                    }
                                    return label;
                                }
                            }
                        }
                    },
                    scales: {
                        x: {
                            grid: {
                                color: 'rgba(21, 32, 64, 0.5)',
                                drawBorder: false
                            },
                            ticks: {
                                maxTicksLimit: 10,
                                callback: function(val, index) {
                                    return labels[index].split('-')[0];
                                }
                            }
                        },
                        y: {
                            type: 'logarithmic',
                            grid: {
                                color: 'rgba(21, 32, 64, 0.5)',
                                drawBorder: false
                            },
                            ticks: {
                                callback: function(value, index, values) {
                                    if (value === 10000 || value === 100000 || value === 1000000 || value === 10000000) {
                                        return formatMoney(value);
                                    }
                                    return null;
                                }
                            }
                        }
                    }
                }
            });

            // Buttons logic
            document.querySelectorAll('.chart-btn').forEach(btn => {
                btn.addEventListener('click', (e) => {
                    document.querySelectorAll('.chart-btn').forEach(b => b.classList.remove('active'));
                    e.target.classList.add('active');

                    const mode = e.target.getAttribute('data-type');
                    if (mode === 'nominal') {
                        chart.data.datasets[0].data = datasetsNominal.sp500;
                        chart.data.datasets[1].data = datasetsNominal.gold;
                    } else {
                        chart.data.datasets[0].data = datasetsReal.sp500;
                        chart.data.datasets[1].data = datasetsReal.gold;
                    }
                    chart.update();
                });
            });

            // Rolling 10-year calculations
            // Pick some exact decades: 1975-1985, 1985-1995, 1995-2005, 2005-2015, 2015-2025
            const decades = [
                {start: '1975', end: '1985'},
                {start: '1985', end: '1995'},
                {start: '1995', end: '2005'},
                {start: '2005', end: '2015'},
                {start: '2015', end: '2025'}
            ];

            const tbody = document.getElementById('rolling-tbody');

            decades.forEach(dec => {
                // Find matching months
                const startIdx = data.findIndex(d => d.date.startsWith(dec.start));
                let endIdx = data.findIndex(d => d.date.startsWith(dec.end));
                if (endIdx === -1) endIdx = data.length - 1; // Fallback

                if (startIdx !== -1 && endIdx !== -1) {
                    const dStart = data[startIdx];
                    const dEnd = data[endIdx];

                    const yearsSpan = (new Date(dEnd.date) - new Date(dStart.date)) / (1000 * 60 * 60 * 24 * 365.25);

                    if (yearsSpan > 0) {
                        const spCagr = Math.pow(dEnd.sp500_tr / dStart.sp500_tr, 1 / yearsSpan) - 1;
                        const goldCagr = Math.pow(dEnd.gold_tr / dStart.gold_tr, 1 / yearsSpan) - 1;

                        const tr = document.createElement('tr');

                        const tdPeriod = document.createElement('td');
                        tdPeriod.textContent = `${dec.start} - ${dec.end}`;

                        const tdSp = document.createElement('td');
                        tdSp.textContent = formatPct(spCagr);

                        const tdGold = document.createElement('td');
                        tdGold.textContent = formatPct(goldCagr);

                        const tdWin = document.createElement('td');
                        if (spCagr > goldCagr) {
                            tdWin.textContent = 'S&P 500';
                            tdWin.className = 'winner-sp';
                        } else {
                            tdWin.textContent = 'Gold';
                            tdWin.className = 'winner-gold';
                        }

                        tr.appendChild(tdPeriod);
                        tr.appendChild(tdSp);
                        tr.appendChild(tdGold);
                        tr.appendChild(tdWin);

                        tbody.appendChild(tr);
                    }
                }
            });

        });
  </script>
