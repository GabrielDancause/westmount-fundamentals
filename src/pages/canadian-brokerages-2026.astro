import SiteLayout from "../layouts/SiteLayout.astro";

const schema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What is the best online brokerage in Canada?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "The best online brokerage in Canada depends heavily on your investing style. Wealthsimple is widely considered the best for beginners and those buying Canadian stocks or ETFs due to its zero-commission structure. Questrade offers a balanced approach with free ETF purchases, while Interactive Brokers is the top choice for active traders and those frequently trading US stocks."
      }
    },
    {
      "@type": "Question",
      "name": "Are Canadian brokerages safe to use?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes, major Canadian brokerages are safe and highly regulated. They must be members of the Canadian Investment Regulatory Organization (CIRO) and the Canadian Investor Protection Fund (CIPF), which protects your assets up to $1 million per account type in the rare event the brokerage becomes insolvent."
      }
    },
    {
      "@type": "Question",
      "name": "How do brokerages make money if they offer free trades?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Brokerages offering zero-commission trades, like Wealthsimple and National Bank, make money through other avenues. This includes foreign exchange (FX) fees when converting CAD to USD, interest earned on uninvested cash in client accounts, payment for order flow (though restricted in Canada, routing practices vary), and premium subscriptions or margin lending."
      }
    },
    {
      "@type": "Question",
      "name": "Can I hold USD in my Canadian brokerage account?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Most Canadian brokerages allow you to hold USD in registered and non-registered accounts, though policies differ. Questrade, Interactive Brokers, TD Direct Investing, BMO InvestorLine, and National Bank Direct Brokerage allow USD holding. Wealthsimple requires a premium subscription (Plus) to hold USD without forced conversions on every trade."
      }
    },
    {
      "@type": "Question",
      "name": "What is Norbert's Gambit and which brokers allow it?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Norbert's Gambit is a strategy used by Canadian investors to convert CAD to USD (and vice versa) without paying steep foreign exchange markups, typically by buying a dual-listed ETF in one currency and selling it in the other. It is easily executable on Questrade, BMO, TD Direct, and National Bank. Interactive Brokers offers FX conversions at spot rates, making the Gambit unnecessary. Wealthsimple does not support Norbert's Gambit."
      }
    }
  ]
};

export const meta = {
  title: "Best Canadian Brokerages (2026): Complete Comparison & Guide",
  description: "The ultimate comparison of Canadian online brokerages in 2026. We review Wealthsimple, Questrade, IBKR, TD Direct, BMO, National Bank, and Qtrade.",
  category: "tool",
  published: "2026-03-15",
};
