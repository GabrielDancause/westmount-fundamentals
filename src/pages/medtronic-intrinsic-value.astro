---
import SiteLayout from "../layouts/SiteLayout.astro";
import * as cheerio from 'cheerio';

const schema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": "Medtronic (MDT) Intrinsic Value: A DCF Analysis",
  "description": "A transparent, step-by-step discounted cash flow valuation of Medtronic plc. Using recent financials to arrive at a single fair value estimate for MDT shares.",
  "datePublished": new Date().toISOString().split('T')[0],
  "dateModified": new Date().toISOString().split('T')[0],
  "author": {
    "@type": "Organization",
    "name": "Westmount Research",
    "url": "https://westmountfundamentals.com"
  },
  "publisher": {
    "@type": "Organization",
    "name": "Westmount Research",
    "url": "https://westmountfundamentals.com"
  },
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": "https://westmountfundamentals.com/medtronic-intrinsic-value"
  }
};

export const meta = {
  title: "Medtronic (MDT) Intrinsic Value: A DCF Analysis",
  description: "We ran a full discounted cash flow on Medtronic plc. One number. Every assumption disclosed. Here's what MDT is really worth.",
  category: "study",
  published: new Date().toISOString().split('T')[0],
};

// ═══════════════════════════════════════════════════════════════
//   DATA FETCHING
// ═══════════════════════════════════════════════════════════════

async function fetchAndParse(url) {
  try {
    const res = await fetch(url, { headers: { 'User-Agent': 'Mozilla/5.0 (Windows NT 10.0; Win64; x64)' } });
    if (!res.ok) return { years: [], data: {} };
    const html = await res.text();
    const $ = cheerio.load(html);

    const years = [];
    $('table thead tr th').each((i, el) => {
      if (i > 0) years.push($(el).text().trim());
    });

    const data = {};
    $('table tbody tr').each((i, row) => {
      const rowName = $(row).find('td').first().text().trim();
      const values = [];
      $(row).find('td').each((j, col) => {
        if (j > 0) {
          let text = $(col).text().trim().replace(/,/g, '');
          let val = text === '-' ? null : parseFloat(text);
          values.push(val);
        }
      });
      data[rowName] = values;
    });
    return { years, data };
  } catch (e) {
    return { years: [], data: {} };
  }
}

const inc = await fetchAndParse('https://stockanalysis.com/stocks/mdt/financials/');
const cf = await fetchAndParse('https://stockanalysis.com/stocks/mdt/financials/cash-flow-statement/');
const bs = await fetchAndParse('https://stockanalysis.com/stocks/mdt/financials/balance-sheet/');

let currentPrice = null;
try {
  const priceRes = await fetch('https://stockanalysis.com/stocks/mdt/', { headers: { 'User-Agent': 'Mozilla/5.0' } });
  if (priceRes.ok) {
    const priceHtml = await priceRes.text();
    const price$ = cheerio.load(priceHtml);
    const pStr = price$('.text-4xl.font-bold').first().text().trim();
    currentPrice = pStr ? parseFloat(pStr) : null;
  }
} catch (e) {
  currentPrice = null;
}

// Extract TTM Data (index 0)
const fcfBase = cf.data['Free Cash Flow']?.[0] ?? null;
const sharesOutstanding = inc.data['Shares Outstanding (Diluted)']?.[0] ?? null;
const cashAndEquiv = bs.data['Cash & Equivalents']?.[0] ?? null;
const totalDebt = bs.data['Total Debt']?.[0] ?? null;
const ttmRevenue = inc.data['Revenue']?.[0] ?? null;
const ttmEPS = inc.data['EPS (Diluted)']?.[0] ?? null;
const ttmOpInc = inc.data['Operating Income']?.[0] ?? null;

// Historical Data Extraction
function extractHistory(dataObj, key, isPercentage = false) {
  if (!dataObj[key]) return [];
  const hist = [];
  // Use indices 1 to 5 to avoid TTM (index 0) if length > 5, otherwise fallback to available.
  const maxIdx = Math.min(6, dataObj[key].length);
  for(let i=1; i < maxIdx; i++) {
     hist.push({
       year: inc.years[i] || `Y-${i}`,
       value: dataObj[key][i]
     });
  }
  return hist.reverse();
}

const revenueHistory = extractHistory(inc.data, 'Revenue');
const fcfHistory = extractHistory(cf.data, 'Free Cash Flow');
const epsHistory = extractHistory(inc.data, 'EPS (Diluted)');

const marginHistory = [];
const revArr = inc.data['Revenue'] || [];
const opIncArr = inc.data['Operating Income'] || [];
const netIncArr = inc.data['Net Income'] || [];
const fcfArr = cf.data['Free Cash Flow'] || [];

for(let i=1; i < Math.min(6, revArr.length); i++) {
  const r = revArr[i];
  if(r) {
    marginHistory.push({
      year: inc.years[i] || `Y-${i}`,
      operating: opIncArr[i] ? ((opIncArr[i] / r) * 100).toFixed(1) : null,
      profit: netIncArr[i] ? ((netIncArr[i] / r) * 100).toFixed(1) : null,
      fcfMargin: fcfArr[i] ? ((fcfArr[i] / r) * 100).toFixed(1) : null
    });
  }
}
marginHistory.reverse();

// ═══════════════════════════════════════════════════════════════
//   DCF MODEL — ALL INPUTS AND CALCULATIONS
// ═══════════════════════════════════════════════════════════════

const netCash = (cashAndEquiv !== null && totalDebt !== null) ? cashAndEquiv - totalDebt : null;

// ASSUMPTIONS
const growthRatePhase1 = 0.05;         // 5% FCF growth, Years 1-5. Medtronic is a mature, low-growth dividend aristocrat.
const growthRateTerminal = 0.025;      // 2.5% perpetuity growth (terminal). Inline with long-term GDP growth.
const discountRate = 0.08;             // 8% WACC / required return. 10Y Treasury is 4.18%, MDT is low beta (~0.75).

// CALCULATIONS
const projectedFCF = [];
let fcf = fcfBase;
let pvPhase1 = 0;

if (fcfBase !== null) {
  for (let yr = 1; yr <= 5; yr++) {
    fcf = fcf * (1 + growthRatePhase1);
    const pvFactor = 1 / Math.pow(1 + discountRate, yr);
    const pvFCF = Math.round(fcf * pvFactor);
    projectedFCF.push({ year: yr, fcf: Math.round(fcf), pvFactor, pvFCF });
    pvPhase1 += pvFCF;
  }
}

let fcfYear6 = null;
let terminalValue = null;
let pvTerminalValue = null;
let enterpriseValue = null;
let equityValue = null;
let intrinsicValuePerShare = null;
let roundedIV = null;
let marginOfSafety = null;
let verdictText = "N/A";
let verdictColor = "#5a6a80";

if (projectedFCF.length === 5 && fcfBase !== null) {
  fcfYear6 = projectedFCF[4].fcf * (1 + growthRateTerminal);
  terminalValue = Math.round(fcfYear6 / (discountRate - growthRateTerminal));
  pvTerminalValue = Math.round(terminalValue * projectedFCF[4].pvFactor);

  enterpriseValue = pvPhase1 + pvTerminalValue;

  if (netCash !== null && sharesOutstanding !== null && sharesOutstanding > 0) {
    equityValue = enterpriseValue + netCash;
    intrinsicValuePerShare = equityValue / sharesOutstanding;
    roundedIV = Math.round(intrinsicValuePerShare * 100) / 100;

    if (currentPrice !== null) {
      marginOfSafety = ((roundedIV - currentPrice) / currentPrice * 100).toFixed(1);
      verdictText = roundedIV > currentPrice ? "Undervalued" : "Overvalued";
      verdictColor = roundedIV > currentPrice ? "#10b981" : "#ef4444";
    }
  }
}

// SENSITIVITY ANALYSIS
const sensitivityRates = [0.06, 0.07, 0.08, 0.09, 0.10];
const sensitivityGrowth = [0.01, 0.03, 0.05, 0.07, 0.09];
const sensitivityTable = sensitivityRates.map(dr => {
  return {
    dr,
    values: sensitivityGrowth.map(gr => {
      if (fcfBase === null || netCash === null || sharesOutstanding === null || sharesOutstanding === 0) return null;
      let f = fcfBase;
      let pvSum = 0;
      for (let y = 1; y <= 5; y++) {
        f = f * (1 + gr);
        pvSum += f / Math.pow(1 + dr, y);
      }
      const f6 = f * (1 + growthRateTerminal);
      const tv = f6 / (dr - growthRateTerminal);
      const pvTV = tv / Math.pow(1 + dr, 5);
      return Math.round((pvSum + pvTV + netCash) / sharesOutstanding);
    })
  };
});
---

