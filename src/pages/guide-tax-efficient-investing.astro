        }
  </style>

<main>

        <div class="stats-grid">
            <div class="stat-card">
                <div class="stat-value">20%</div>
                <div class="stat-label">Top Federal LTCG Rate</div>
            </div>
            <div class="stat-card">
                <div class="stat-value">37%</div>
                <div class="stat-label">Top Ordinary Income Rate</div>
            </div>
            <div class="stat-card">
                <div class="stat-value">3.8%</div>
                <div class="stat-label">Net Investment Income Tax</div>
            </div>
