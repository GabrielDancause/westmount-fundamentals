---
import SiteLayout from "../layouts/SiteLayout.astro";

const schema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What is tax-loss harvesting and how does it work?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Tax-loss harvesting involves selling securities at a loss to offset capital gains tax liability. If your losses exceed your gains, you can use up to $3,000 of those losses to offset ordinary income per year. It requires navigating the wash-sale rule, which prevents claiming the loss if you buy a substantially identical asset within 30 days."
      }
    },
    {
      "@type": "Question",
      "name": "What is asset location strategy?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Asset location is the strategy of placing different types of investments into specific accounts (taxable, tax-deferred, or tax-free) based on their tax efficiency. Highly taxed assets like REITs and bonds belong in tax-advantaged accounts, while tax-efficient index funds go in taxable accounts."
      }
    },
    {
      "@type": "Question",
      "name": "What are the wash sale rules?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "The IRS wash-sale rule prohibits you from claiming a loss on the sale of an investment if you purchase a 'substantially identical' stock or security within 30 days before or after the sale. If triggered, the loss is disallowed and added to the cost basis of the new purchase."
      }
    },
    {
      "@type": "Question",
      "name": "How are qualified dividends taxed?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Qualified dividends are taxed at long-term capital gains rates (0%, 15%, or 20% depending on income), which are lower than ordinary income tax rates. To qualify, the dividend must be paid by a U.S. corporation or qualifying foreign entity, and you must hold the stock for more than 60 days during the 121-day period surrounding the ex-dividend date."
      }
    },
    {
      "@type": "Question",
      "name": "Long-term vs short-term capital gains tax rates?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Short-term capital gains (assets held one year or less) are taxed as ordinary income, up to 37%. Long-term capital gains (assets held more than one year) benefit from lower tax rates of 0%, 15%, or 20%, depending on your taxable income and filing status."
      }
    }
  ]
};

export const meta = {
  title: "Tax-Efficient Investing: Complete Strategy Guide",
  description: "Discover proven tax-efficient investing strategies, asset location rules, and ways to minimize investment taxes in your portfolio.",
  category: "guide",
  published: "2026-03-15",
};
---

<SiteLayout
  site="westmount"
  title="Tax-Efficient Investing: Complete Strategy Guide"
  description="Discover proven tax-efficient investing strategies, asset location rules, and ways to minimize investment taxes in your portfolio."
  canonical="https://westmountfundamentals.com/guide-tax-efficient-investing" schema={schema}
>
  <style>

