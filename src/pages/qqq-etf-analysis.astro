<style is:inline>
  .qqq-hero {
    text-align: center;
    padding: 3rem 1.5rem 2rem;
    max-width: 900px;
    margin: 0 auto;
  }
  .qqq-hero h1 {
    font-size: 2.2rem;
    font-weight: 800;
    color: #f0f0f0;
    margin-bottom: 0.75rem;
    line-height: 1.2;
  }
  .qqq-hero .subtitle {
    font-size: 1.1rem;
    color: #94a3b8;
    max-width: 680px;
    margin: 0 auto;
  }
  .qqq-container {
    max-width: 960px;
    margin: 0 auto;
    padding: 0 1.5rem 3rem;
  }
  .qqq-section {
    margin-bottom: 3rem;
  }
  .qqq-section h2 {
    font-size: 1.6rem;
    font-weight: 700;
    color: #e2e8f0;
    margin-bottom: 1rem;
    padding-bottom: 0.5rem;
    border-bottom: 2px solid #1e40af;
  }
  .qqq-section h3 {
    font-size: 1.2rem;
    font-weight: 600;
    color: #cbd5e1;
    margin: 1.5rem 0 0.75rem;
  }
