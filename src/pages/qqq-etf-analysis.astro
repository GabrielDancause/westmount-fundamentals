<script is:inline>
  /* QQQ Growth Calculator */
  function calculateQQQGrowth() {
    var initial = parseFloat(document.getElementById("calcInitial").value) || 0;
    var monthly = parseFloat(document.getElementById("calcMonthly").value) || 0;
    var years = parseInt(document.getElementById("calcYears").value) || 20;
    var annualReturn = parseFloat(document.getElementById("calcReturn").value) || 14;
    var monthlyRate = annualReturn / 100 / 12;
    var months = years * 12;
    var total = initial;
    for (var i = 0; i < months; i++) {
      total = total * (1 + monthlyRate) + monthly;
    }
    var totalContributed = initial + (monthly * months);
    var growth = total - totalContributed;
    var el = document.getElementById("calcResult");
    el.style.display = "block";
    document.getElementById("calcTotal").textContent = "$" + Math.round(total).toLocaleString();
    document.getElementById("calcDetail").innerHTML =
      "Total contributed: <strong>$" + Math.round(totalContributed).toLocaleString() + "</strong> &nbsp;|&nbsp; " +
      "Investment growth: <strong>$" + Math.round(growth).toLocaleString() + "</strong> &nbsp;|&nbsp; " +
      "Return: <strong>" + ((total / totalContributed - 1) * 100).toFixed(0) + "%</strong>";
  }

