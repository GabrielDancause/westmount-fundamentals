    </table>
  </div>

  <!-- ═══ HISTORICAL CHARTS ═══ -->
  <h2>Financial Track Record</h2>
  <p>Before trusting a forward projection, look at where the company has been.</p>

  <h3>Revenue ($M)</h3>
  <div class="bar-chart">
    {revenueHistory.map(r => (
      <div class="bar-row">
        <div class="bar-label">{r.year}</div>
        <div class="bar-track">
          <div class="bar-fill revenue" style={`width: ${(r.value / latestRev) * 100}%`}>
            ${(r.value / 1000).toFixed(1)}B
          </div>
        </div>
      </div>
    ))}
  </div>

  <h3>Free Cash Flow ($M)</h3>
  <div class="bar-chart">
    {fcfHistory.map(r => (
      <div class="bar-row">
        <div class="bar-label">{r.year}</div>
        <div class="bar-track">
          <div class="bar-fill fcf" style={`width: ${(r.value / Math.max(...fcfHistory.map(f => f.value))) * 100}%`}>
            ${(r.value / 1000).toFixed(1)}B
          </div>
        </div>
      </div>
    ))}
