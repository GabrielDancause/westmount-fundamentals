---
export const meta = {
  title: "Cigna (CI) Intrinsic Value: A DCF Analysis",
  description: "We ran a full discounted cash flow on The Cigna Group using the latest actuals. One number. Every assumption disclosed.",
  category: "study",
  published: new Date().toISOString().split('T')[0],
};

import SiteLayout from "../layouts/SiteLayout.astro";
import * as cheerio from 'cheerio';



const schema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": "Cigna (CI) Intrinsic Value: A DCF Analysis",
  "description": "A transparent, step-by-step discounted cash flow valuation of The Cigna Group. Using the latest financials to arrive at a single fair value estimate for CI shares.",
  "datePublished": new Date().toISOString().split('T')[0],
  "dateModified": new Date().toISOString().split('T')[0],
  "author": {
    "@type": "Organization",
    "name": "Compiled by Gemini 3.1"
  },
  "publisher": {
    "@type": "Organization",
    "name": "Compiled by Gemini 3.1"
  },
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": "https://example.com/cigna-intrinsic-value"
  }
};


/* ═══════════════════════════════════════════════════════════════
   DATA FETCHING
   ═══════════════════════════════════════════════════════════════ */

async function fetchHTML(url) {
  try {
    const response = await fetch(url, {
      headers: { 'User-Agent': 'Mozilla/5.0 (Windows NT 10.0; Win64; x64)' }
    });
    if (!response.ok) return null;
    return await response.text();
  } catch (e) {
    return null;
  }
}

const parseNum = (str) => {
  if (!str || str === '-' || str === 'N/A') return null;
  return parseFloat(str.replace(/,/g, ''));
};

let currentPrice = 264.61;
let revenueHistory = [];
let fcfHistory = [];
let epsHistory = [];
let marginHistory = [];

let fcfBase = 8389;
let sharesOutstanding = 269;
let cashAndInvestments = 7676;
let totalDebt = 31463;
let latestRev = 274900;
let latestOp = 9200;

const htmlMain = await fetchHTML('https://stockanalysis.com/stocks/ci/');
if (htmlMain) {
  const priceMatch = htmlMain.match(/<div class="[^"]*text-4xl[^"]*"[^>]*>([\d\.,]+)<\/div>/);
  if (priceMatch) currentPrice = parseNum(priceMatch[1]);
}

const htmlFin = await fetchHTML('https://stockanalysis.com/stocks/ci/financials/');
if (htmlFin) {
  const $fin = cheerio.load(htmlFin);
  let revs = [];
  let ops = [];
  let eps = [];
  let shares = [];
  let netInc = [];

  $fin('table tbody tr').each((i, el) => {
    const header = $fin(el).find('td').first().text().trim();
    if (header === 'Revenue') {
      $fin(el).find('td').each((j, td) => { if (j > 0 && j <= 5) revs.push(parseNum($fin(td).text().trim())); });
    }
    if (header === 'Operating Income') {
      $fin(el).find('td').each((j, td) => { if (j > 0 && j <= 5) ops.push(parseNum($fin(td).text().trim())); });
    }
    if (header === 'Net Income') {
      $fin(el).find('td').each((j, td) => { if (j > 0 && j <= 5) netInc.push(parseNum($fin(td).text().trim())); });
    }
    if (header === 'EPS (Diluted)') {
      $fin(el).find('td').each((j, td) => { if (j > 0 && j <= 5) eps.push(parseNum($fin(td).text().trim())); });
    }
    if (header === 'Shares Outstanding (Diluted)') {
      $fin(el).find('td').each((j, td) => { if (j > 0 && j <= 5) shares.push(parseNum($fin(td).text().trim())); });
    }
  });

  if (revs.length > 0) latestRev = revs[0];
  if (ops.length > 0) latestOp = ops[0];
  if (shares.length > 0) sharesOutstanding = shares[0];

  let currentYear = new Date().getFullYear() - 1;
  for (let i = 0; i < Math.min(5, revs.length); i++) {
    let year = currentYear - i;
    if (revs[i] !== null) revenueHistory.push({ year, value: revs[i] });
    if (eps[i] !== null) epsHistory.push({ year, value: eps[i] });
  }
  revenueHistory.reverse();
  epsHistory.reverse();

  for (let i = 0; i < Math.min(5, revs.length); i++) {
    let year = currentYear - i;
    let opMargin = revs[i] ? ((ops[i] / revs[i]) * 100).toFixed(2) : 'N/A';
    let profitMargin = revs[i] ? ((netInc[i] / revs[i]) * 100).toFixed(2) : 'N/A';
    marginHistory.push({ year, operating: opMargin, profit: profitMargin, fcfMargin: null });
  }
  marginHistory.reverse();
}

const htmlCF = await fetchHTML('https://stockanalysis.com/stocks/ci/financials/cash-flow-statement/');
if (htmlCF) {
  const $cf = cheerio.load(htmlCF);
  let fcfs = [];
  $cf('table tbody tr').each((i, el) => {
    const header = $cf(el).find('td').first().text().trim();
    if (header === 'Free Cash Flow') {
      $cf(el).find('td').each((j, td) => { if (j > 0 && j <= 5) fcfs.push(parseNum($cf(td).text().trim())); });
    }
  });

  if (fcfs.length > 0 && fcfs[0] !== null) fcfBase = fcfs[0];

  let currentYear = new Date().getFullYear() - 1;
  for (let i = 0; i < Math.min(5, fcfs.length); i++) {
    let year = currentYear - i;
    if (fcfs[i] !== null) fcfHistory.push({ year, value: fcfs[i] });
  }
  fcfHistory.reverse();

  for (let i = 0; i < marginHistory.length; i++) {
     let year = marginHistory[i].year;
     let matchRev = revenueHistory.find(r => r.year === year);
     let matchFCF = fcfHistory.find(r => r.year === year);
     if (matchRev && matchFCF && matchRev.value) {
       marginHistory[i].fcfMargin = ((matchFCF.value / matchRev.value) * 100).toFixed(2);
     } else {
       marginHistory[i].fcfMargin = 'N/A';
     }
  }
}

const htmlBS = await fetchHTML('https://stockanalysis.com/stocks/ci/financials/balance-sheet/');
if (htmlBS) {
  const $bs = cheerio.load(htmlBS);
  let cash = [];
  let debt = [];
  $bs('table tbody tr').each((i, el) => {
    const header = $bs(el).find('td').first().text().trim();
    if (header === 'Cash & Short-Term Investments' || header === 'Cash & Equivalents') {
      $bs(el).find('td').each((j, td) => { if (j > 0 && j <= 5) cash.push(parseNum($bs(td).text().trim())); });
    }
    if (header === 'Total Debt') {
      $bs(el).find('td').each((j, td) => { if (j > 0 && j <= 5) debt.push(parseNum($bs(td).text().trim())); });
    }
  });

  if (cash.length > 0 && cash[0] !== null) cashAndInvestments = cash[0];
  if (debt.length > 0 && debt[0] !== null) totalDebt = debt[0];
}

/* ═══════════════════════════════════════════════════════════════
   DCF MODEL — ALL INPUTS AND CALCULATIONS
   ═══════════════════════════════════════════════════════════════ */

const netCash = cashAndInvestments - totalDebt;

// 10Y Treasury: 4.18%.
const growthRatePhase1 = 0.08;
const growthRateTerminal = 0.035;
const discountRate = 0.10;

const projectedFCF = [];
let fcf = fcfBase;
for (let yr = 1; yr <= 5; yr++) {
  fcf = fcf * (1 + growthRatePhase1);
  projectedFCF.push({ year: yr, fcf: Math.round(fcf), pvFactor: 1 / Math.pow(1 + discountRate, yr) });
}
projectedFCF.forEach(p => { p.pvFCF = Math.round(p.fcf * p.pvFactor); });

const fcfYear6 = projectedFCF[4].fcf * (1 + growthRateTerminal);
const terminalValue = Math.round(fcfYear6 / (discountRate - growthRateTerminal));
const pvTerminalValue = Math.round(terminalValue * projectedFCF[4].pvFactor);

const pvPhase1 = projectedFCF.reduce((sum, p) => sum + p.pvFCF, 0);
const enterpriseValue = pvPhase1 + pvTerminalValue;

const equityValue = enterpriseValue + netCash;
const intrinsicValuePerShare = equityValue / sharesOutstanding;
const roundedIV = Math.round(intrinsicValuePerShare * 100) / 100;

const marginOfSafety = currentPrice > 0 ? ((roundedIV - currentPrice) / currentPrice * 100).toFixed(1) : 'N/A';
const verdictText = roundedIV > currentPrice ? "Undervalued" : "Overvalued";
const verdictColor = roundedIV > currentPrice ? "#10b981" : "#ef4444";

const sensitivityRates = [0.08, 0.09, 0.10, 0.11, 0.12];
const sensitivityGrowth = [0.04, 0.06, 0.08, 0.10, 0.12];
const sensitivityTable = sensitivityRates.map(dr => {
  return {
    dr,
    values: sensitivityGrowth.map(gr => {
      let f = fcfBase;
      let pvSum = 0;
      for (let y = 1; y <= 5; y++) {
        f = f * (1 + gr);
        pvSum += f / Math.pow(1 + dr, y);
      }
      const f6 = f * (1 + growthRateTerminal);
      const tv = f6 / (dr - growthRateTerminal);
      const pvTV = tv / Math.pow(1 + dr, 5);
      return Math.round((pvSum + pvTV + netCash) / sharesOutstanding);
    })
  };
});
