                    <td>${item.name}</td>
                    <td>${formatPercent(item.shortPercent)}</td>
                    <td>${formatNumber(item.daysToCover)}</td>
                    <td>${formatCurrency(item.marketCap)}</td>
                    <td class="${wkClass}">${item.price1wk !== null ? wkPrefix + formatPercent(item.price1wk) : 'N/A'}</td>
                    <td class="${moClass}">${item.price1mo !== null ? moPrefix + formatPercent(item.price1mo) : 'N/A'}</td>
                    <td>${formatNumber(item.squeezeProbability)}</td>
                `;
                tbody.appendChild(tr);
            });

            // Update header classes
            document.querySelectorAll('th').forEach(th => {
                th.classList.remove('sort-asc', 'sort-desc');
            });

            // Find the th corresponding to current sort
            const columns = ['ticker', 'name', 'shortPercent', 'daysToCover', 'marketCap', 'price1wk', 'price1mo', 'squeezeProbability'];
            const idx = columns.indexOf(currentSort.column);
            if (idx !== -1) {
                const th = document.querySelectorAll('th')[idx];
                th.classList.add(currentSort.isAsc ? 'sort-asc' : 'sort-desc');
            }
        }

        function sortTable(column) {
            if (currentSort.column === column) {
                currentSort.isAsc = !currentSort.isAsc;
            } else {
                currentSort.column = column;
                currentSort.isAsc = false;
            }
            renderTable();
        }

        // Initial render
        document.addEventListener('DOMContentLoaded', () => {
            renderTable();
        });
