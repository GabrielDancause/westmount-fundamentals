  const avgSI = data.reduce((s, d) => s + d.shortPercent, 0) / data.length;
  const marketAvgSI = 0.05; // ~5% market average
  const siMultiple = (avgSI / marketAvgSI).toFixed(1);
  const maxDTC = data.reduce((best, d) => d.daysToCover > best.daysToCover ? d : best, data[0]);
  const highSqueezeCount = data.filter(d => d.squeezeScore >= 70).length;

  const insights = [
    { icon: '📈', text: `<strong>${positiveMomentum} of 11</strong> candidates have positive 1-month momentum — bullish for squeeze potential.` },
    { icon: '🎯', text: `Average short interest among candidates is <strong>${(avgSI * 100).toFixed(1)}%</strong> — <strong>${siMultiple}×</strong> the market average.` },
    { icon: '⏱', text: `Longest days-to-cover is <strong>${maxDTC.daysToCover}</strong> for <strong>${maxDTC.ticker}</strong>, meaning shorts would need ${maxDTC.daysToCover} days to fully exit.` },
    { icon: '🔥', text: `<strong>${highSqueezeCount} stock${highSqueezeCount !== 1 ? 's' : ''}</strong> score${highSqueezeCount === 1 ? 's' : ''} above 70 on our Squeeze Score — rated <strong>"High"</strong> probability.` }
  ];

  const grid = document.getElementById('insightsGrid');
  grid.innerHTML = insights.map(i => `<div class="insight-card"><div class="insight-icon">${i.icon}</div><p>${i.text}</p></div>`).join('');
}

// ─── Helpers ───
function formatCurrency(val) {
  if (val == null) return 'N/A';
  if (val >= 1e9) return '$' + (val / 1e9).toFixed(1) + 'B';
  if (val >= 1e6) return '$' + (val / 1e6).toFixed(1) + 'M';
  return '$' + val.toLocaleString();
}
function formatPercent(val) { return val == null ? 'N/A' : (val * 100).toFixed(2) + '%'; }
function formatNumber(val) { return val == null ? 'N/A' : val.toFixed(2); }
function getColorClass(val) { return val > 0 ? 'up' : val < 0 ? 'down' : ''; }
function squeezeBadge(score) {
  const cls = score >= 70 ? 'squeeze-high' : score >= 50 ? 'squeeze-mid' : 'squeeze-low';
  const label = score >= 70 ? 'High' : score >= 50 ? 'Mid' : 'Low';
  return `<span class="squeeze-badge ${cls}">${score} ${label}</span>`;
}

// ─── Sortable Table ───
let currentSort = { column: 'squeezeScore', isAsc: false };

function renderTable() {
  const tbody = document.getElementById('tableBody');
  tbody.innerHTML = '';
  const sorted = [...data].sort((a, b) => {
    let vA = a[currentSort.column], vB = b[currentSort.column];
    if (vA == null) vA = -Infinity;
    if (vB == null) vB = -Infinity;
    if (typeof vA === 'string') return currentSort.isAsc ? vA.localeCompare(vB) : vB.localeCompare(vA);
    return currentSort.isAsc ? vA - vB : vB - vA;
  });
  sorted.forEach(item => {
    const tr = document.createElement('tr');
    const wkC = getColorClass(item.price1wk), moC = getColorClass(item.price1mo);
    const wkP = item.price1wk > 0 ? '+' : '', moP = item.price1mo > 0 ? '+' : '';
    tr.innerHTML = `
      <td>${item.ticker}</td>
      <td>${item.name}</td>
      <td>${formatPercent(item.shortPercent)}</td>
      <td>${formatNumber(item.daysToCover)}</td>
      <td>${formatCurrency(item.marketCap)}</td>
      <td class="${wkC}">${item.price1wk != null ? wkP + formatPercent(item.price1wk) : 'N/A'}</td>
      <td class="${moC}">${item.price1mo != null ? moP + formatPercent(item.price1mo) : 'N/A'}</td>
      <td>${squeezeBadge(item.squeezeScore)}</td>
    `;
    tbody.appendChild(tr);
  });
  document.querySelectorAll('#screenerTable th').forEach(th => th.classList.remove('sort-asc', 'sort-desc'));
  const cols = ['ticker','name','shortPercent','daysToCover','marketCap','price1wk','price1mo','squeezeScore'];
  const idx = cols.indexOf(currentSort.column);
  if (idx !== -1) document.querySelectorAll('#screenerTable th')[idx].classList.add(currentSort.isAsc ? 'sort-asc' : 'sort-desc');
}

function sortTable(column) {
  if (currentSort.column === column) currentSort.isAsc = !currentSort.isAsc;
  else { currentSort.column = column; currentSort.isAsc = false; }
  renderTable();
}

// ─── Radar Chart (Top 5 by squeezeScore) ───
function renderRadar() {
  const top5 = [...data].sort((a, b) => b.squeezeScore - a.squeezeScore).slice(0, 5);
  // Normalize each dimension 0-100
  const maxSI = Math.max(...data.map(d => d.shortPercent));
  const maxDTC = Math.max(...data.map(d => d.daysToCover));
  const momRange = { min: Math.min(...data.map(d => d.price1mo)), max: Math.max(...data.map(d => d.price1mo)) };
  const mom3Range = { min: -0.5, max: 0.5 }; // Use fixed range since price3mo not in data

  function norm(val, min, max) { return max === min ? 50 : Math.round(((val - min) / (max - min)) * 100); }

  const colors = ['rgba(74,143,231,0.8)','rgba(0,200,83,0.8)','rgba(255,193,7,0.8)','rgba(255,61,0,0.8)','rgba(156,39,176,0.8)'];
  const bgColors = ['rgba(74,143,231,0.15)','rgba(0,200,83,0.15)','rgba(255,193,7,0.15)','rgba(255,61,0,0.15)','rgba(156,39,176,0.15)'];

  const datasets = top5.map((s, i) => ({
    label: s.ticker,
    data: [
      norm(s.shortPercent, 0, maxSI),
      norm(s.daysToCover, 0, maxDTC),
      norm(s.price1mo, momRange.min, momRange.max),
      s.squeezeScore
    ],
    borderColor: colors[i],
    backgroundColor: bgColors[i],
    borderWidth: 2,
    pointRadius: 4,
    pointBackgroundColor: colors[i]
  }));

  new Chart(document.getElementById('radarChart'), {
    type: 'radar',
    data: {
      labels: ['Short % of Float', 'Days to Cover', '1-Month Momentum', 'Squeeze Score'],
      datasets
    },
    options: {
      responsive: true,
      maintainAspectRatio: true,
      scales: {
        r: {
          beginAtZero: true,
          max: 100,
          ticks: { stepSize: 25, color: '#94a3b8', backdropColor: 'transparent', font: { size: 11 } },
          grid: { color: 'rgba(148,163,184,0.15)' },
          angleLines: { color: 'rgba(148,163,184,0.15)' },
          pointLabels: { color: '#c8d0de', font: { size: 13, weight: '600' } }
        }
      },
      plugins: {
        legend: { position: 'bottom', labels: { color: '#c8d0de', padding: 20, usePointStyle: true, font: { size: 13 } } },
        tooltip: {
          callbacks: { label: ctx => `${ctx.dataset.label}: ${ctx.raw}` }
        }
      }
    }
  });
}

// ─── Bar Chart ───
function renderBarChart() {
  const sorted = [...data].sort((a, b) => a.shortPercent - b.shortPercent);
  const barColors = sorted.map(d => d.squeezeScore >= 70 ? 'rgba(0,200,83,0.8)' : d.squeezeScore >= 50 ? 'rgba(255,193,7,0.8)' : 'rgba(96,125,139,0.6)');

  new Chart(document.getElementById('barChart'), {
    type: 'bar',
    data: {
      labels: sorted.map(d => d.ticker),
      datasets: [{
        label: 'Short % of Float',
        data: sorted.map(d => +(d.shortPercent * 100).toFixed(2)),
        backgroundColor: barColors,
        borderColor: barColors.map(c => c.replace('0.8','1').replace('0.6','0.9')),
        borderWidth: 1,
        borderRadius: 4
      }]
    },
    options: {
      indexAxis: 'y',
      responsive: true,
      maintainAspectRatio: false,
      scales: {
        x: { grid: { color: 'rgba(148,163,184,0.1)' }, ticks: { color: '#94a3b8', callback: v => v + '%' } },
        y: { grid: { display: false }, ticks: { color: '#c8d0de', font: { weight: '600', family: "'JetBrains Mono', monospace" } } }
      },
      plugins: {
        legend: { display: false },
        tooltip: { callbacks: { label: ctx => `Short Interest: ${ctx.raw}%` } }
      }
    }
  });
  // Set canvas height based on count
  document.getElementById('barChart').parentElement.style.height = (sorted.length * 40 + 60) + 'px';
}

// ─── Init ───
document.addEventListener('DOMContentLoaded', () => {
  populateStats();
  populateInsights();
  renderTable();
  renderRadar();
  renderBarChart();
});
  </script>

