        function formatCurrency(val) {
            if (val === null || val === undefined) return 'N/A';
            if (val >= 1e9) return '$' + (val / 1e9).toFixed(1) + 'B';
            if (val >= 1e6) return '$' + (val / 1e6).toFixed(1) + 'M';
            return '$' + val.toLocaleString();
        }

        function formatPercent(val) {
            if (val === null || val === undefined) return 'N/A';
            return (val * 100).toFixed(2) + '%';
        }

        function formatNumber(val) {
            if (val === null || val === undefined) return 'N/A';
            return val.toFixed(2);
        }

        function getColorClass(val) {
            if (val === null || val === undefined) return '';
            if (val > 0) return 'up';
            if (val < 0) return 'down';
            return '';
        }

        function renderTable() {
            const tbody = document.getElementById('tableBody');
            tbody.innerHTML = '';

            // Apply sorting
            const data = [...window.__INITIAL_DATA__].sort((a, b) => {
                let valA = a[currentSort.column];
                let valB = b[currentSort.column];

                if (valA === null || valA === undefined) valA = -Infinity;
                if (valB === null || valB === undefined) valB = -Infinity;

                if (typeof valA === 'string') {
                    return currentSort.isAsc ? valA.localeCompare(valB) : valB.localeCompare(valA);
                }

                return currentSort.isAsc ? valA - valB : valB - valA;
            });

            data.forEach(item => {
                const tr = document.createElement('tr');

                const wkClass = getColorClass(item.price1wk);
                const wkPrefix = item.price1wk > 0 ? '+' : '';

                const moClass = getColorClass(item.price1mo);
                const moPrefix = item.price1mo > 0 ? '+' : '';

