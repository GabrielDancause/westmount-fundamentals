// ─── Squeeze Score Calculator ───
function calcSqueezeScore(item) {
  // Normalize shortPercent: 0-100 scale (max ~50% = 100)
  const siNorm = Math.min((item.shortPercent / 0.50) * 100, 100);
  // Normalize daysToCover: 0-100 scale (max ~10 = 100)
  const dtcNorm = Math.min((item.daysToCover / 10) * 100, 100);
  // Normalize 1mo momentum: -50% to +50% → 0-100
  const momRaw = item.price1mo || 0;
  const momNorm = Math.min(Math.max((momRaw + 0.5) * 100, 0), 100);
  return Math.round(siNorm * 0.4 + dtcNorm * 0.3 + momNorm * 0.3);
}

// Attach scores
const data = window.__INITIAL_DATA__;
data.forEach(d => { d.squeezeScore = calcSqueezeScore(d); });

// ─── Stats Grid ───
function populateStats() {
  const maxSI = data.reduce((best, d) => d.shortPercent > best.shortPercent ? d : best, data[0]);
  const maxDTC = data.reduce((best, d) => d.daysToCover > best.daysToCover ? d : best, data[0]);
  const maxMom = data.reduce((best, d) => (d.price1mo||0) > (best.price1mo||0) ? d : best, data[0]);

  document.getElementById('stat-si').textContent = (maxSI.shortPercent * 100).toFixed(1) + '%';
  document.getElementById('stat-si-sub').textContent = maxSI.ticker;
  document.getElementById('stat-dtc').textContent = maxDTC.daysToCover.toFixed(1);
  document.getElementById('stat-dtc-sub').textContent = maxDTC.ticker;
  document.getElementById('stat-mom').textContent = (maxMom.price1mo > 0 ? '+' : '') + (maxMom.price1mo * 100).toFixed(1) + '%';
  document.getElementById('stat-mom-sub').textContent = maxMom.ticker;
}

