                    if (typeof valB === 'string') valB = valB.toLowerCase();

                    if (valA < valB) return currentSort.direction === 'asc' ? -1 : 1;
                    if (valA > valB) return currentSort.direction === 'asc' ? 1 : -1;
                    return 0;
                });

                renderTable(currentData);
            }

            headers.forEach(th => {
                th.addEventListener('click', () => {
                    sortData(th.dataset.sort);
                });
            });

            // Initial render
            renderTable(currentData);
        });
  </script>
</SiteLayout>
