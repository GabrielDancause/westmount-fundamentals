const page = (registry as any)["sp500-earnings-growth-rankings"];
export const meta = { title: "S&P 500 Earnings Growth Rankings 2026: Fastest Growing Co...", description: "Looking for the next big movers? We analyzed the top 50 S&P 500 companies poised for massive earnings growth through 2026. What you", category: "guide", published: "2026-03-15" };

const schema = {
  "@context": "https://schema.org",
  "@type": "Article",
