const page = (registry as any)["what-is-a-mutual-fund"];
export const meta = { title: "What is a Mutual Fund? | The Complete Beginner", description: "Everyone talks about them, but what are they really? We break down how mutual funds work, active vs. passive management, and how to choose the right one.", category: "guide", published: "2026-03-18" };

const schema = JSON.stringify({
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Article",
      "headline": page.title,
      "description": page.description,
      "author": {
        "@type": "Organization",
        "name": "Westmount Fundamentals",
        "url": "https://westmountfundamentals.com"
      },
      "publisher": {
        "@type": "Organization",
        "name": "Westmount Fundamentals",
        "url": "https://westmountfundamentals.com"
      }
    },
    {
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "What exactly is a mutual fund?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "A mutual fund is an investment vehicle that pools money from many different investors to purchase a large portfolio of stocks, bonds, or other securities. Instead of picking individual stocks, you buy a slice of the entire pie."
          }
        },
        {
          "@type": "Question",
          "name": "How does a mutual fund make money?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Investors make money from mutual funds in three ways: dividend distributions from the underlying stocks, capital gains distributions if the fund manager sells holdings for a profit, and an increase in the fund's overall Net Asset Value (NAV)."
          }
        },
        {
          "@type": "Question",
          "name": "What is the difference between active and passive mutual funds?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Active funds are managed by professionals who try to beat the market by actively picking winning stocks. Passive funds (like index funds) simply aim to match the performance of a specific market index, like the S&P 500, resulting in lower fees."
          }
        },
        {
          "@type": "Question",
          "name": "Are mutual funds a good investment for beginners?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Yes. They offer instant diversification, which significantly lowers risk compared to buying single stocks. They are an excellent foundational block for a retirement portfolio."
          }
        },
        {
          "@type": "Question",
          "name": "What are expense ratios?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "An expense ratio is the annual fee that all mutual funds charge their shareholders to cover management, administrative, and operating costs. It is expressed as a percentage of your total investment."
          }
        }
      ]
    }
  ]
});
---

<SiteLayout site="westmount" title={page.title} description={page.description} canonical={`https://westmountfundamentals.com/${page.slug}`} schema={schema}>
  <div style="max-width:1280px;margin:0 auto;padding:16px 24px 0;display:flex;justify-content:space-between;align-items:center;font-size:13px;color:var(--text-dim,#94a3b8)">
