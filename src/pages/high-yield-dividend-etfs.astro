              <th data-sort="strategy" class="sortable">Strategy Focus <span>↕</span></th>
              <th data-sort="yield" class="sortable">Est. Yield (%) <span>↕</span></th>
              <th data-sort="expense" class="sortable">Expense Ratio <span>↕</span></th>
            </tr>
          </thead>
          <tbody>
            <tr><td>Schwab US Dividend Equity ETF (SCHD)</td><td>Quality & Growth</td><td>3.4%</td><td>0.06%</td></tr>
