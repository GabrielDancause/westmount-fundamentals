const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Article",
      "headline": page.title,
      "description": page.description,
      "author": {
        "@type": "Organization",
        "name": "Westmount Fundamentals",
        "url": "https://westmountfundamentals.com"
      },
      "publisher": {
        "@type": "Organization",
        "name": "Westmount Fundamentals",
        "logo": {
          "@type": "ImageObject",
          "url": "https://westmountfundamentals.com/logo.png"
        }
      },
      "datePublished": page.published,
      "mainEntityOfPage": {
        "@type": "WebPage",
        "@id": "https://westmountfundamentals.com/when-to-sell-stocks"
      }
    },
    {
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "When is the right time to sell stocks?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "The right time to sell a stock is typically when your original investment thesis is no longer valid, you need the money for a short-term goal, or your portfolio requires rebalancing. It's rarely a good idea to sell simply because the price has dropped due to short-term market fluctuations."
          }
        },
        {
          "@type": "Question",
          "name": "Should I sell my stocks if the market is crashing?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Generally, selling purely due to a market crash is considered panic selling and can lock in your losses. Historically, markets have always recovered from crashes. If the underlying fundamentals of your companies remain strong, a crash might even represent a buying opportunity rather than a time to sell."
          }
        },
        {
          "@type": "Question",
          "name": "How do you know when to take profits on a stock?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "You might consider taking profits when a stock's valuation has become significantly disconnected from its underlying business fundamentals (e.g., extremely high P/E ratio compared to historical averages), or when the stock has grown so much that it now represents an uncomfortable or risky percentage of your overall portfolio."
          }
        },
        {
          "@type": "Question",
          "name": "What are the tax implications of selling stocks?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "When you sell a stock for a profit in a taxable account, you will owe capital gains taxes. If you held the stock for more than a year, you generally qualify for lower long-term capital gains tax rates. If you held it for less than a year, you will be taxed at your ordinary income tax rate. Selling at a loss can sometimes be used to offset other capital gains through tax-loss harvesting."
          }
        },
        {
          "@type": "Question",
          "name": "Should I sell a stock if the company cuts its dividend?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "A dividend cut is often a warning sign that the company is facing financial difficulties. It requires an immediate re-evaluation of your investment thesis. While it doesn't always mandate a sale, a dividend cut is frequently accompanied by weakening fundamentals, making it a common reason why income investors choose to sell."
          }
        }
      ]
    }
  ]
};
