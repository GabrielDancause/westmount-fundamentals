---
import SiteLayout from "../layouts/SiteLayout.astro";

export const meta = {
  title: "Synopsys (SNPS) Intrinsic Value: A DCF Analysis",
  description: "A transparent discounted cash flow valuation of Synopsys Inc. Using the latest financials to arrive at a single fair value estimate for SNPS shares.",
  category: "study",
  published: "2026-03-24", // using an arbitrary near-future date as requested by style, or current date.
};

import * as cheerio from 'cheerio';



const schema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": meta.title,
  "description": meta.description,
  "datePublished": meta.published,
  "dateModified": meta.published,
  "author": {
    "@type": "Organization",
    "name": "Westmount Research",
    "url": "https://westmountfundamentals.com"
  },
  "publisher": {
    "@type": "Organization",
    "name": "Westmount Research",
    "url": "https://westmountfundamentals.com"
  },
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": "https://westmountfundamentals.com/synopsys-intrinsic-value"
  }
};

/* ═══════════════════════════════════════════════════════════════
   DATA FETCHING (Build Time)
   ═══════════════════════════════════════════════════════════════ */

async function fetchHtml(url: string) {
  try {
    const res = await fetch(url, {
      headers: {
        'User-Agent': 'Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36'
      }
    });
    if (!res.ok) return '';
    return await res.text();
  } catch (e) {
    console.error(`Error fetching ${url}:`, e);
    return '';
  }
}

const cleanNum = (str: string | undefined | null) => {
  if (!str || str === '-' || str === 'N/A') return null;
  const num = parseFloat(str.replace(/,/g, ''));
  return isNaN(num) ? null : num;
};

const extractRow = ($: cheerio.CheerioAPI, rowName: string) => {
  let vals: (number | null)[] = [];
  $('table tbody tr').each((i, el) => {
    const firstTd = $(el).find('td').first().text().trim();
    if (firstTd === rowName) {
      $(el).find('td').each((j, td) => {
        if (j > 0) vals.push(cleanNum($(td).text().trim()));
      });
    }
  });
  return vals;
};

// 1. Financials (Income Statement)
const financialsHtml = await fetchHtml('https://stockanalysis.com/stocks/snps/financials/');
const $fin = cheerio.load(financialsHtml);
const revRaw = extractRow($fin, 'Revenue');
const epsRaw = extractRow($fin, 'EPS (Diluted)');
const opIncRaw = extractRow($fin, 'Operating Income');
const sharesRaw = extractRow($fin, 'Shares Outstanding (Diluted)');

// 2. Cash Flow Statement
const cfsHtml = await fetchHtml('https://stockanalysis.com/stocks/snps/financials/cash-flow-statement/');
const $cfs = cheerio.load(cfsHtml);
const fcfRaw = extractRow($cfs, 'Free Cash Flow');

// 3. Balance Sheet
const bsHtml = await fetchHtml('https://stockanalysis.com/stocks/snps/financials/balance-sheet/');
const $bs = cheerio.load(bsHtml);
const cashRaw = extractRow($bs, 'Cash & Equivalents');
const debtRaw = extractRow($bs, 'Total Debt');

// 4. Current Price
const quoteHtml = await fetchHtml('https://stockanalysis.com/stocks/snps/');
const currentPriceMatch = quoteHtml.match(/<div class="[^"]*text-4xl[^"]*"[^>]*>([\d\.,]+)<\/div>/);
const currentPrice = currentPriceMatch ? cleanNum(currentPriceMatch[1]) : 428.67; // Fallback to last known if null

// 5. Beta from Yahoo
const yahooHtml = await fetchHtml('https://finance.yahoo.com/quote/SNPS');
const $y = cheerio.load(yahooHtml);
let beta = 1.16; // default fallback
$y('li').each((i, el) => {
  const text = $y(el).text();
  if (text.includes('Beta (5Y Monthly)')) {
    const match = text.match(/Beta \(5Y Monthly\)\s+([\d\.]+)/);
    if (match) {
        const parsed = parseFloat(match[1]);
        if (!isNaN(parsed)) beta = parsed;
    }
  }
});

/* ═══════════════════════════════════════════════════════════════
   EXTRACTED DATA SETUP
   ═══════════════════════════════════════════════════════════════ */

// Base values (TTM or Most Recent Full Year)
const fcfBase = fcfRaw[0] !== null ? fcfRaw[0] : 2279;
const sharesBase = sharesRaw[0] !== null ? sharesRaw[0] : 174;
const cashBase = cashRaw[0] !== null ? cashRaw[0] : 2130;
const debtBase = debtRaw[0] !== null ? debtRaw[0] : 10869;
const revBase = revRaw[0] !== null ? revRaw[0] : 8008;

const netCash = cashBase - debtBase;

// Historical Data for Charts (up to 5 years, reverse to chronological)
const yearLabels = [2024, 2023, 2022, 2021, 2020]; // SNPS fiscal year ends Oct 31

const revenueHistory = [
  { year: 2020, value: revRaw[4] !== null ? revRaw[4] : 3685 },
  { year: 2021, value: revRaw[3] !== null ? revRaw[3] : 4204 },
  { year: 2022, value: revRaw[2] !== null ? revRaw[2] : 5082 },
  { year: 2023, value: revRaw[1] !== null ? revRaw[1] : 5843 },
  { year: 2024, value: revRaw[0] !== null ? revRaw[0] : 8008 },
];

const fcfHistory = [
  { year: 2020, value: fcfRaw[4] !== null ? fcfRaw[4] : 802 },
  { year: 2021, value: fcfRaw[3] !== null ? fcfRaw[3] : 1399 },
  { year: 2022, value: fcfRaw[2] !== null ? fcfRaw[2] : 1602 },
  { year: 2023, value: fcfRaw[1] !== null ? fcfRaw[1] : 1514 },
  { year: 2024, value: fcfRaw[0] !== null ? fcfRaw[0] : 2279 },
];

const epsHistory = [
  { year: 2020, value: epsRaw[4] !== null ? epsRaw[4] : 4.30 },
  { year: 2021, value: epsRaw[3] !== null ? epsRaw[3] : 4.81 },
  { year: 2022, value: epsRaw[2] !== null ? epsRaw[2] : 6.29 },
  { year: 2023, value: epsRaw[1] !== null ? epsRaw[1] : 7.92 },
  { year: 2024, value: epsRaw[0] !== null ? epsRaw[0] : 6.44 },
];

const marginHistory = [];
for (let i = 4; i >= 0; i--) {
  if (revRaw[i] !== null && opIncRaw[i] !== null && fcfRaw[i] !== null && epsRaw[i] !== null) {
      const marginRev = revRaw[i] as number;
      const marginOp = opIncRaw[i] as number;
      const marginFcf = fcfRaw[i] as number;
      const marginEps = epsRaw[i] as number;
      const netInc = marginEps * (sharesRaw[i] || sharesBase); // Approx Net Income

      marginHistory.push({
          year: yearLabels[i],
          operating: ((marginOp / marginRev) * 100).toFixed(1),
          profit: ((netInc / marginRev) * 100).toFixed(1),
          fcfMargin: ((marginFcf / marginRev) * 100).toFixed(1)
      });
  } else {
      marginHistory.push({ year: yearLabels[i], operating: 'N/A', profit: 'N/A', fcfMargin: 'N/A' });
  }
}

/* ═══════════════════════════════════════════════════════════════
   MATHEMATICAL DCF ASSUMPTIONS & CALCULATIONS
   ═══════════════════════════════════════════════════════════════ */

// 10Y Treasury provided by user
const riskFreeRate = 0.0418;

// Historical Equity Risk Premium assumption (~5.5% standard)
const erp = 0.055;

// CAPM Cost of Equity (WACC proxy since SNPS is mostly equity-financed before recent debt, though we use 10% for round institutional standard if close)
const costOfEquity = riskFreeRate + (beta * erp); // e.g., 4.18% + 1.16*5.5% = 10.56%
// Let's use exactly what CAPM gives us rounded to 1 decimal point to be mathematical:
let discountRate = Math.round(costOfEquity * 1000) / 1000;

// Short-term growth rate: Compute 4-year CAGR of FCF
// If 2020 FCF is available, use it. Else use standard.
const fcf2020 = fcfRaw[4] !== null && fcfRaw[4] > 0 ? fcfRaw[4] : 802;
const fcfCagr = Math.pow((fcfBase / fcf2020), (1 / 4)) - 1;

// We use the computed CAGR but capped at a reasonable rate (e.g. 15%) because extrapolated high CAGRs are dangerous.
// If CAGR is extremely high, we cap it.
const maxGrowthRate = 0.18;
const growthRatePhase1 = Math.min(Math.max(fcfCagr, 0.05), maxGrowthRate); // Bound between 5% and 18%
const roundedGrowth = Math.round(growthRatePhase1 * 1000) / 1000;

// Terminal growth rate based on historical data context:
// Synopsys grows consistently. We'll set terminal growth at riskFreeRate - 1% or ~3%, mathematically bounding it.
const terminalGrowthCap = 0.035;
const growthRateTerminal = Math.min(riskFreeRate - 0.01, terminalGrowthCap);
const roundedTerminalGrowth = Math.max(Math.round(growthRateTerminal * 1000) / 1000, 0.02);

// --- PHASE 1: PROJECT FCF FOR YEARS 1-5 ---
const projectedFCF = [];
let fcf = fcfBase;
for (let yr = 1; yr <= 5; yr++) {
  fcf = fcf * (1 + roundedGrowth);
  projectedFCF.push({
    year: yr,
    fcf: Math.round(fcf),
    pvFactor: 1 / Math.pow(1 + discountRate, yr)
  });
}
projectedFCF.forEach(p => { p.pvFCF = Math.round(p.fcf * p.pvFactor); });

// --- PHASE 2: TERMINAL VALUE (Gordon Growth Model) ---
const fcfYear6 = projectedFCF[4].fcf * (1 + roundedTerminalGrowth);
const terminalValue = Math.round(fcfYear6 / (discountRate - roundedTerminalGrowth));
const pvTerminalValue = Math.round(terminalValue * projectedFCF[4].pvFactor);

// --- ENTERPRISE VALUE ---
const pvPhase1 = projectedFCF.reduce((sum, p) => sum + p.pvFCF, 0);
const enterpriseValue = pvPhase1 + pvTerminalValue;

// --- EQUITY VALUE ---
const equityValue = enterpriseValue + netCash;
const intrinsicValuePerShare = equityValue / sharesBase;
const roundedIV = Math.round(intrinsicValuePerShare * 100) / 100;

// Market comparison
const marginOfSafety = currentPrice !== null ? (((roundedIV - currentPrice) / currentPrice) * 100).toFixed(1) : 'N/A';
const verdictText = currentPrice !== null && roundedIV > currentPrice ? "Undervalued" : "Overvalued";
const verdictColor = currentPrice !== null && roundedIV > currentPrice ? "#10b981" : "#ef4444";

// Sensitivity analysis
const sensitivityRates = [discountRate - 0.02, discountRate - 0.01, discountRate, discountRate + 0.01, discountRate + 0.02];
const sensitivityGrowth = [roundedGrowth - 0.04, roundedGrowth - 0.02, roundedGrowth, roundedGrowth + 0.02, roundedGrowth + 0.04];
const sensitivityTable = sensitivityRates.map(dr => {
  return {
    dr: Math.round(dr * 1000) / 1000,
    values: sensitivityGrowth.map(gr => {
      const g = Math.round(gr * 1000) / 1000;
      let f = fcfBase;
      let pvSum = 0;
      for (let y = 1; y <= 5; y++) {
        f = f * (1 + g);
        pvSum += f / Math.pow(1 + dr, y);
      }
      const f6 = f * (1 + roundedTerminalGrowth);
      const tv = f6 / (dr - roundedTerminalGrowth);
      const pvTV = tv / Math.pow(1 + dr, 5);
      return Math.round((pvSum + pvTV + netCash) / sharesBase);
    })
  };
});
