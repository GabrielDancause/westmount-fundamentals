        <div class="bar-track">
          <div class="bar-fill eps" style={`width: ${r.value !== null && epsRaw[0] !== null ? (r.value / epsRaw[0]) * 100 : 0}%`}>
            ${r.value !== null ? r.value.toFixed(2) : 'N/A'}
          </div>
        </div>
      </div>
    ))}
  </div>

  <!-- ═══ MARGIN TRENDS ═══ -->
  <h3>Margin Trends</h3>
  <div class="table-wrap">
