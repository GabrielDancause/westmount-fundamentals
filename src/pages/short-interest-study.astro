  <script define:vars={{ stocksJson: JSON.stringify(stocks) }}>
    (function() {
      const stocks = JSON.parse(stocksJson);
      const tableBody = document.getElementById('stockTableBody');
      const searchInput = document.getElementById('stockSearch');
      const sectorFilter = document.getElementById('sectorFilter');
      const resultCount = document.getElementById('resultCount');

      // Populate sector dropdown
      const sectors = [...new Set(stocks.map(s => s.sector))].sort();
      sectors.forEach(s => {
        const opt = document.createElement('option');
        opt.value = s;
        opt.textContent = s;
        sectorFilter.appendChild(opt);
      });

      let sortCol = 'squeezeScore';
      let sortDir = -1; // descending

      function getShortClass(pct) {
        if (pct >= 30) return 'short-extreme';
        if (pct >= 20) return 'short-high';
        if (pct >= 10) return 'short-elevated';
        return 'short-normal';
      }

      function getSqueezeClass(rating) {
        switch (rating) {
          case 'High': return 'squeeze-high';
          case 'Moderate': return 'squeeze-moderate';
          case 'Low': return 'squeeze-low';
          default: return 'squeeze-minimal';
        }
      }

      function momStr(v) {
        const sign = v >= 0 ? '+' : '';
        return sign + v.toFixed(1) + '%';
      }

      function momClass(v) {
        return v >= 0 ? 'positive' : 'negative';
      }

      function sortVal(stock) {
        switch (sortCol) {
          case 'rank': return stock.shortPercentOfFloat;
          case 'company': return stock.company.toLowerCase();
          case 'shortPercent': return stock.shortPercentOfFloat;
          case 'shortRatio': return stock.shortRatio;
          case 'momentum1m': return stock.momentum1m;
          case 'momentum3m': return stock.momentum3m;
          case 'squeezeScore': return stock.squeezeScore;
          default: return 0;
        }
      }

      function render() {
        const query = searchInput.value.toLowerCase().trim();
        const sector = sectorFilter.value;

        let filtered = stocks.filter(s => {
          if (sector !== 'all' && s.sector !== sector) return false;
          if (query && !s.ticker.toLowerCase().includes(query) && !s.company.toLowerCase().includes(query)) return false;
          return true;
        });

        // Sort
        filtered.sort((a, b) => {
          const va = sortVal(a);
          const vb = sortVal(b);
          if (typeof va === 'string') {
            return sortDir * va.localeCompare(vb);
          }
          return sortDir * (vb - va);
        });

        // Rank default by short % descending when rank col is active
        let html = '';
        filtered.forEach((s, i) => {
          html += `<tr>
            <td class="num">${i + 1}</td>
            <td>
              <div class="company-name">${s.company}</div>
              <div class="company-ticker">${s.ticker} <span class="sector-tag">${s.sector}</span></div>
            </td>
            <td class="num ${getShortClass(s.shortPercentOfFloat)}">${s.shortPercentOfFloat.toFixed(1)}%</td>
            <td class="num">${s.shortRatio.toFixed(1)}</td>
            <td class="num ${momClass(s.momentum1m)}">${momStr(s.momentum1m)}</td>
            <td class="num ${momClass(s.momentum3m)}">${momStr(s.momentum3m)}</td>
            <td><span class="squeeze-badge ${getSqueezeClass(s.squeezeRating)}">${s.squeezeScore.toFixed(0)}</span></td>
          </tr>`;
        });

        tableBody.innerHTML = html;
        resultCount.textContent = filtered.length + ' of ' + stocks.length + ' stocks';
      }

      // Header click sorting
      document.querySelectorAll('#stockTable th[data-col]').forEach(th => {
        th.addEventListener('click', function() {
          const col = this.dataset.col;
          if (sortCol === col) {
            sortDir *= -1;
          } else {
            sortCol = col;
            sortDir = -1;
          }
          // Update active state
          document.querySelectorAll('#stockTable th').forEach(h => h.classList.remove('sort-active'));
          this.classList.add('sort-active');
          const arrow = this.querySelector('.sort-arrow');
          if (arrow) arrow.textContent = sortDir === -1 ? '▼' : '▲';
          render();
        });
      });

      searchInput.addEventListener('input', render);
      sectorFilter.addEventListener('change', render);

      // Set initial sort indicator
      const defaultTh = document.querySelector('#stockTable th[data-col="squeezeScore"]');
      if (defaultTh) defaultTh.classList.add('sort-active');

      render();
    })();
  </script>
