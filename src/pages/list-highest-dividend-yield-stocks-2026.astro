        </div>
        <div class="stat-card">
          <div class="stat-value">${aristocrats}</div>
          <div class="stat-label">Aristocrats (25+ Yrs)</div>
        </div>
      `;

      // Setup Sectors
      const sectors = [...new Set(stockData.map(d => d.sector))].sort();
      sectors.forEach(s => {
        const option = document.createElement('option');
        option.value = s;
        option.textContent = s;
        sectorFilter.appendChild(option);
      });

      // Chart setup
      setupChart();

      // Events
      searchInput.addEventListener('keyup', renderTable);
      sectorFilter.addEventListener('change', renderTable);

      thElements.forEach(th => {
         th.addEventListener('click', () => {
             const col = th.dataset.sort;
             if (currentSort.column === col) {
                 currentSort.asc = !currentSort.asc;
             } else {
                 currentSort.column = col;
                 currentSort.asc = true;
             }
             renderTable();
         });
      });

      renderTable();
    }

    function renderTable() {
      const search = searchInput.value.toLowerCase();
      const sector = sectorFilter.value;

      let filtered = stockData.filter(d => {
         const matchSearch = d.ticker.toLowerCase().includes(search) || d.company.toLowerCase().includes(search);
         const matchSector = sector === '' || d.sector === sector;
         return matchSearch && matchSector;
      });

      filtered.sort((a, b) => {
         let valA = a[currentSort.column];
         let valB = b[currentSort.column];

         if (valA === null) valA = currentSort.asc ? Infinity : -Infinity;
         if (valB === null) valB = currentSort.asc ? Infinity : -Infinity;

         if (typeof valA === 'string') {
             return currentSort.asc ? valA.localeCompare(valB) : valB.localeCompare(valA);
         }
         return currentSort.asc ? valA - valB : valB - valA;
      });

      tableBody.innerHTML = filtered.map(d => `
        <tr>
          <td class="ticker">${d.ticker}</td>
          <td>${d.company}</td>
          <td class="numeric" style="color: #4a8fe7; font-weight:700;">${d.yield.toFixed(2)}%</td>
          <td class="numeric">
             ${d.payoutRatio !== null ? d.payoutRatio.toFixed(1) + '%' : 'N/A'}
             ${d.payoutRatio > 100 ? '<span class="warning" title="Payout ratio > 100% indicates the dividend may be unsustainable.">⚠️ UNSUSTAINABLE</span>' : ''}
          </td>
          <td class="numeric">${d.consecutiveYears}</td>
          <td>${d.sector}</td>
        </tr>
      `).join('');
    }

    function setupChart() {
       const sectorCounts = {};
       stockData.forEach(s => {
           sectorCounts[s.sector] = (sectorCounts[s.sector] || 0) + 1;
       });
       const sortedSectors = Object.entries(sectorCounts).sort((a,b) => b[1]-a[1]);

       const ctx = document.getElementById('sectorChart').getContext('2d');
       new Chart(ctx, {
           type: 'bar',
           data: {
               labels: sortedSectors.map(s => s[0]),
               datasets: [{
                   label: 'Number of Stocks in Top 50',
                   data: sortedSectors.map(s => s[1]),
                   backgroundColor: '#4a8fe7',
                   borderRadius: 4
               }]
           },
           options: {
               responsive: true,
               maintainAspectRatio: false,
               plugins: {
                   legend: { display: false },
                   title: {
                       display: true,
                       text: 'Sector Distribution (Top 50 Yields)',
                       color: '#e0e8f0',
                       font: { size: 16, family: 'Inter' }
                   }
               },
               scales: {
                   y: {
                       beginAtZero: true,
                       ticks: { color: '#a0aabf', stepSize: 1 },
                       grid: { color: 'rgba(21, 32, 64, 0.5)' }
                   },
                   x: {
                       ticks: { color: '#a0aabf', autoSkip: false, maxRotation: 45, minRotation: 45 },
                       grid: { display: false }
                   }
               }
           }
       });
    }

    document.addEventListener('DOMContentLoaded', init);
  </script>
</SiteLayout>
