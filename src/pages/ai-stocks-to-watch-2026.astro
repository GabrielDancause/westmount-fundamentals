        // Filter out nulls for calculations and clean data
        const stockData = rawData.filter(d => d.price !== null).map(d => ({
            ...d,
            marketCapVal: d.marketCap || 0,
            peVal: d.peRatio || 0,
            fwdPeVal: d.forwardPE || 0,
            revGrowthVal: d.revenueGrowth || 0,
            marginVal: d.profitMargin || 0
        }));

        // Formatters
        const formatMoney = (val) => val ? '$' + val.toLocaleString(undefined, {minimumFractionDigits: 2, maximumFractionDigits: 2}) : 'N/A';
        const formatCap = (val) => {
            if (!val) return 'N/A';
            if (val >= 1e12) return '$' + (val / 1e12).toFixed(2) + 'T';
            if (val >= 1e9) return '$' + (val / 1e9).toFixed(2) + 'B';
            if (val >= 1e6) return '$' + (val / 1e6).toFixed(2) + 'M';
            return '$' + val.toLocaleString();
        };
        const formatNum = (val) => val ? val.toFixed(2) : 'N/A';
        const formatPct = (val) => val ? (val * 100).toFixed(2) + '%' : 'N/A';

        // Initialize UI
        function init() {
            renderStats();
            renderTable(stockData);
            renderChart();
            setupInteractions();
        }

        function renderStats() {
            const grid = document.getElementById('stats-grid');

            // Calculate some aggregates
            const totalCap = stockData.reduce((sum, s) => sum + s.marketCapVal, 0);
            const avgRevGrowth = stockData.reduce((sum, s) => sum + s.revGrowthVal, 0) / stockData.length;
            const avgPe = stockData.filter(s => s.peVal > 0).reduce((sum, s, _, arr) => sum + s.peVal / arr.length, 0);

            grid.innerHTML = `
                <div class="stat-card">
                    <h3>Companies Analyzed</h3>
                    <div class="value">${stockData.length}</div>
                </div>
                <div class="stat-card">
