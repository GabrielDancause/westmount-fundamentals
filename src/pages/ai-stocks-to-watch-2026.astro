        let currentSort = { key: 'marketCap', asc: false };

        function renderTable(data) {
            const tbody = document.getElementById('tableBody');

            if (data.length === 0) {
                tbody.innerHTML = '<tr><td colspan="7" style="text-align:center">No stocks found matching your search.</td></tr>';
                return;
            }

            tbody.innerHTML = data.map(s => `
                <tr>
                    <td class="symbol-cell">
                        <span class="symbol-ticker">${s.symbol}</span>
                        <span class="symbol-name">${s.name}</span>
                    </td>
                    <td>${formatMoney(s.price)}</td>
                    <td>${formatCap(s.marketCap)}</td>
                    <td>${formatNum(s.peRatio)}</td>
                    <td>${formatNum(s.forwardPE)}</td>
                    <td class="${s.revGrowthVal > 0 ? 'positive' : (s.revGrowthVal < 0 ? 'negative' : 'neutral')}">${formatPct(s.revenueGrowth)}</td>
