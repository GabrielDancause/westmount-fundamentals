                const filtered = stockData.filter(s =>
                    s.symbol.toLowerCase().includes(term) ||
                    s.name.toLowerCase().includes(term)
                );

                // Re-apply sort
                sortData(filtered, currentSort.key, currentSort.asc);
                renderTable(filtered);
            });

            // Need to expose explicitly to the window to fix playwright test event dispatching if needed
            searchInput.addEventListener('keyup', (e) => {
                searchInput.dispatchEvent(new Event('input'));
            });

            // Sort
            document.querySelectorAll('th[data-sort]').forEach(th => {
                th.addEventListener('click', () => {
                    const key = th.dataset.sort;
                    if (currentSort.key === key) {
                        currentSort.asc = !currentSort.asc;
                    } else {
                        currentSort.key = key;
                        currentSort.asc = false; // default to desc for new column
                    }

                    const term = document.getElementById('searchInput').value.toLowerCase();
                    const filtered = stockData.filter(s =>
                        s.symbol.toLowerCase().includes(term) ||
                        s.name.toLowerCase().includes(term)
                    );

                    sortData(filtered, currentSort.key, currentSort.asc);
                    renderTable(filtered);
                });
            });

            // Initial sort
            sortData(stockData, currentSort.key, currentSort.asc);
            renderTable(stockData);
        }

        function sortData(data, key, asc) {
            data.sort((a, b) => {
                let valA = a[key];
                let valB = b[key];

                // Handle special cases based on key
                if (key === 'marketCap') { valA = a.marketCapVal; valB = b.marketCapVal; }
                if (key === 'peRatio') { valA = a.peVal; valB = b.peVal; }
                if (key === 'forwardPE') { valA = a.fwdPeVal; valB = b.fwdPeVal; }
                if (key === 'revenueGrowth') { valA = a.revGrowthVal; valB = b.revGrowthVal; }
                if (key === 'profitMargin') { valA = a.marginVal; valB = b.marginVal; }
                if (key === 'price') { valA = a.price || 0; valB = b.price || 0; }
                if (key === 'symbol') {
                     valA = a.symbol;
                     valB = b.symbol;
                     return asc ? valA.localeCompare(valB) : valB.localeCompare(valA);
                }

                if (valA === valB) return 0;

                // Put nulls/0s at bottom generally
                if (!valA && valB) return 1;
                if (valA && !valB) return -1;

                if (asc) {
                    return valA > valB ? 1 : -1;
                } else {
                    return valA < valB ? 1 : -1;
                }
            });
        }

        function renderChart() {
            const ctx = document.getElementById('marketCapChart').getContext('2d');

            // Top 10 by market cap
            const top10 = [...stockData].sort((a, b) => b.marketCapVal - a.marketCapVal).slice(0, 10);

            new Chart(ctx, {
                type: 'bar',
                data: {
                    labels: top10.map(s => s.symbol),
                    datasets: [{
                        label: 'Market Cap (Trillions $)',
                        data: top10.map(s => s.marketCapVal / 1e12),
                        backgroundColor: '#4a8fe7',
                        borderRadius: 4
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: { display: false },
                        title: {
                            display: true,
                            text: 'Top 10 AI Stocks by Market Cap',
                            color: '#8a9fc2',
                            font: { family: "'Inter', sans-serif", size: 16 }
                        },
                        tooltip: {
                            callbacks: {
                                label: function(context) {
                                    return '$' + context.raw.toFixed(2) + 'T';
                                }
                            }
                        }
                    },
                    scales: {
                        y: {
                            beginAtZero: true,
                            grid: { color: '#152040' },
                            ticks: { color: '#8a9fc2', font: { family: "'JetBrains Mono', monospace" } }
                        },
                        x: {
                            grid: { display: false },
                            ticks: { color: '#8a9fc2', font: { family: "'JetBrains Mono', monospace" } }
                        }
                    }
                }
            });
        }

        // Run
        document.addEventListener('DOMContentLoaded', init);
  </script>
</SiteLayout>
