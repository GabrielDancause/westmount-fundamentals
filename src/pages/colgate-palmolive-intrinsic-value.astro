        <tr>
          <td>Year 6 FCF (Year 5 × {(1 + growthRateTerminal).toFixed(3)})</td>
          <td>${fcfYear6 !== null ? Math.round(fcfYear6).toLocaleString() : "N/A"}</td>
        </tr>
        <tr>
          <td>Terminal Value (FCF₆ ÷ ({(discountRate * 100)}% − {(growthRateTerminal * 100)}%))</td>
          <td>${terminalValue !== null ? terminalValue.toLocaleString() : "N/A"}</td>
        </tr>
        <tr class="row-total">
          <td>PV of Terminal Value</td>
          <td class="highlight-cell">${pvTerminalValue !== null ? pvTerminalValue.toLocaleString() : "N/A"}</td>
        </tr>
      </tbody>
    </table>
  </div>

  <!-- ═══ FINAL CALCULATION ═══ -->
  <h3>Final Valuation</h3>
  <div class="table-wrap">
    <table>
      <thead>
        <tr>
          <th style="text-align:left">Component</th>
          <th>Value ($M)</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td>PV of Phase 1 Cash Flows</td>
          <td>${pvPhase1 !== null ? pvPhase1.toLocaleString() : "N/A"}</td>
        </tr>
        <tr>
          <td>PV of Terminal Value</td>
          <td>${pvTerminalValue !== null ? pvTerminalValue.toLocaleString() : "N/A"}</td>
        </tr>
        <tr>
          <td>= Enterprise Value</td>
          <td>${enterpriseValue !== null ? enterpriseValue.toLocaleString() : "N/A"}</td>
        </tr>
        <tr>
          <td>+ Net Cash (Cash − Debt)</td>
          <td>${netCash !== null ? netCash.toLocaleString() : "N/A"}</td>
        </tr>
        <tr>
          <td>= Equity Value</td>
          <td>${equityValue !== null ? equityValue.toLocaleString() : "N/A"}</td>
        </tr>
        <tr>
          <td>÷ Shares Outstanding</td>
          <td>{sharesOutstanding !== null ? sharesOutstanding.toLocaleString() : "N/A"}</td>
        </tr>
        <tr class="row-total">
          <td>Intrinsic Value Per Share</td>
          <td class="highlight-cell">${roundedIV !== null ? roundedIV.toFixed(2) : "N/A"}</td>
        </tr>
      </tbody>
    </table>
  </div>

  <!-- ═══ HISTORICAL CHARTS ═══ -->
