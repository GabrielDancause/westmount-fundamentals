  </div>

  <!-- ═══ TERMINAL VALUE ═══ -->
  <h3>Terminal Value</h3>
  <div class="table-wrap">
    <table>
      <thead>
        <tr>
          <th style="text-align:left">Component</th>
          <th>Value ($M)</th>
        </tr>
      </thead>
