          <td>—</td>
        </tr>
        {projectedFCF.map(p => (
          <tr>
            <td>Year {p.year}</td>
            <td>${p.fcf !== null ? p.fcf.toLocaleString() : "N/A"}</td>
            <td>{p.pvFactor !== null ? p.pvFactor.toFixed(4) : "N/A"}</td>
            <td>${p.pvFCF !== null ? p.pvFCF.toLocaleString() : "N/A"}</td>
          </tr>
        ))}
        <tr class="row-total">
          <td colspan="3">Sum of Phase 1 PV</td>
          <td class="highlight-cell">${pvPhase1 !== null ? pvPhase1.toLocaleString() : "N/A"}</td>
        </tr>
      </tbody>
