---
import SiteLayout from "../layouts/SiteLayout.astro";
import * as cheerio from 'cheerio';

export const meta = {
  title: "Colgate-Palmolive (CL) Intrinsic Value: A DCF Analysis",
  description: "A transparent, step-by-step discounted cash flow valuation of Colgate-Palmolive using actual financials. One number. Every assumption disclosed.",
  category: "study",
  published: new Date().toISOString().split('T')[0],
};

const schema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": meta.title,
  "description": meta.description,
  "datePublished": meta.published,
  "dateModified": meta.published,
  "author": {
    "@type": "Organization",
    "name": "Westmount Research",
    "url": "https://westmountfundamentals.com"
  },
  "publisher": {
    "@type": "Organization",
    "name": "Westmount Research",
    "url": "https://westmountfundamentals.com"
  },
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": "https://westmountfundamentals.com/colgate-palmolive-intrinsic-value"
  }
};

/* ═══════════════════════════════════════════════════════════════
   DATA FETCHING (stockanalysis.com)
   ═══════════════════════════════════════════════════════════════ */
async function fetchPage(url) {
  try {
    const res = await fetch(url, {
      headers: {
        'User-Agent': 'Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36'
      }
    });
    if (!res.ok) throw new Error(`HTTP ${res.status}`);
    return await res.text();
  } catch (e) {
    console.error(`Failed to fetch ${url}: ${e}`);
    return null;
  }
}

// Convert string like "20,382" to number 20382
const parseNum = (str) => {
  if (!str || str === '-') return null;
  return Number(str.replace(/,/g, ''));
};

let currentPrice = null;
let revenueHistory = [];
let operatingIncomeHistory = [];
let netIncomeHistory = [];
let epsHistory = [];
let sharesHistory = [];
let operatingCashFlowHistory = [];
let fcfHistory = [];
let cashAndEquivalents = null;
let totalDebt = null;

const htmlFin = await fetchPage('https://stockanalysis.com/stocks/cl/financials/');
if (htmlFin) {
  const $ = cheerio.load(htmlFin);
  const priceMatch = htmlFin.match(/<div class="[^"]*text-4xl[^"]*"[^>]*>([\d\.,]+)<\/div>/);
  if (priceMatch) currentPrice = parseFloat(priceMatch[1].replace(/,/g, ''));

  $('table tbody tr').each((i, el) => {
    const rowTitle = $(el).find('td').first().text().trim();
    if (rowTitle === 'Revenue') {
      $(el).find('td').each((j, td) => { if (j > 0 && j <= 5) revenueHistory.push(parseNum($(td).text().trim())); });
    } else if (rowTitle === 'Operating Income') {
      $(el).find('td').each((j, td) => { if (j > 0 && j <= 5) operatingIncomeHistory.push(parseNum($(td).text().trim())); });
    } else if (rowTitle === 'Net Income') {
      $(el).find('td').each((j, td) => { if (j > 0 && j <= 5) netIncomeHistory.push(parseNum($(td).text().trim())); });
    } else if (rowTitle === 'EPS (Diluted)') {
      $(el).find('td').each((j, td) => { if (j > 0 && j <= 5) epsHistory.push(parseNum($(td).text().trim())); });
    } else if (rowTitle === 'Shares Outstanding (Basic)') {
      $(el).find('td').each((j, td) => { if (j > 0 && j <= 5) sharesHistory.push(parseNum($(td).text().trim())); });
    }
  });
}

const htmlCF = await fetchPage('https://stockanalysis.com/stocks/cl/financials/cash-flow-statement/');
if (htmlCF) {
  const $ = cheerio.load(htmlCF);
  $('table tbody tr').each((i, el) => {
    const rowTitle = $(el).find('td').first().text().trim();
    if (rowTitle === 'Operating Cash Flow') {
      $(el).find('td').each((j, td) => { if (j > 0 && j <= 5) operatingCashFlowHistory.push(parseNum($(td).text().trim())); });
    } else if (rowTitle === 'Free Cash Flow') {
      $(el).find('td').each((j, td) => { if (j > 0 && j <= 5) fcfHistory.push(parseNum($(td).text().trim())); });
    }
  });
}

const htmlBS = await fetchPage('https://stockanalysis.com/stocks/cl/financials/balance-sheet/');
if (htmlBS) {
  const $ = cheerio.load(htmlBS);
  $('table tbody tr').each((i, el) => {
    const rowTitle = $(el).find('td').first().text().trim();
    if (rowTitle === 'Cash & Equivalents') {
      const val = parseNum($(el).find('td').eq(1).text().trim());
      if (val !== null) cashAndEquivalents = val;
    } else if (rowTitle === 'Total Debt') {
      const val = parseNum($(el).find('td').eq(1).text().trim());
      if (val !== null) totalDebt = val;
    }
  });
}

// Ensure arrays have exactly 5 elements if missing
if (revenueHistory.length < 5) revenueHistory = [null, null, null, null, null];
if (operatingIncomeHistory.length < 5) operatingIncomeHistory = [null, null, null, null, null];
if (netIncomeHistory.length < 5) netIncomeHistory = [null, null, null, null, null];
if (epsHistory.length < 5) epsHistory = [null, null, null, null, null];
if (sharesHistory.length < 5) sharesHistory = [null, null, null, null, null];
if (operatingCashFlowHistory.length < 5) operatingCashFlowHistory = [null, null, null, null, null];
if (fcfHistory.length < 5) fcfHistory = [null, null, null, null, null];

// Reverse history arrays so [0] is oldest, [4] is newest
revenueHistory.reverse();
operatingIncomeHistory.reverse();
netIncomeHistory.reverse();
epsHistory.reverse();
sharesHistory.reverse();
operatingCashFlowHistory.reverse();
fcfHistory.reverse();

const currentYear = new Date().getFullYear() - 1; // Assuming TTM/last reported full year
const years = [currentYear - 4, currentYear - 3, currentYear - 2, currentYear - 1, currentYear];

/* ═══════════════════════════════════════════════════════════════
   DCF MODEL — ALL INPUTS AND CALCULATIONS
   ═══════════════════════════════════════════════════════════════ */

// --- INPUTS ---
const baseFCF = fcfHistory[4] !== undefined ? fcfHistory[4] : null; // Millions
const sharesOutstanding = sharesHistory[4] !== undefined ? sharesHistory[4] : null; // Millions
const netCash = (cashAndEquivalents !== null && totalDebt !== null) ? (cashAndEquivalents - totalDebt) : null;

// --- ASSUMPTIONS ---
const growthRatePhase1 = 0.05;         // 5% FCF growth, Years 1-5 (Colgate is a mature, low-growth staples business with pricing power)
const growthRateTerminal = 0.02;       // 2% perpetuity growth (terminal) - mature FMCG tracks inflation roughly
const discountRate = 0.07;             // 7% WACC / required return (Low beta ~0.5, stable cash flows, 10Y=4.18%)

// --- CALCULATIONS ---
let projectedFCF = [];
let fcfYear6 = null;
let terminalValue = null;
let pvTerminalValue = null;
let pvPhase1 = null;
let enterpriseValue = null;
let equityValue = null;
let intrinsicValuePerShare = null;
let roundedIV = null;
let marginOfSafety = "N/A";
let verdictText = "N/A";
let verdictColor = "#5a6a80";

if (baseFCF !== null && sharesOutstanding !== null && netCash !== null && currentPrice !== null) {
  // --- PHASE 1: PROJECT FCF FOR YEARS 1-5 ---
  let fcf = baseFCF;
  for (let yr = 1; yr <= 5; yr++) {
    fcf = fcf * (1 + growthRatePhase1);
    projectedFCF.push({ year: yr, fcf: Math.round(fcf), pvFactor: 1 / Math.pow(1 + discountRate, yr) });
  }
  projectedFCF.forEach(p => { p.pvFCF = Math.round(p.fcf * p.pvFactor); });

  // --- PHASE 2: TERMINAL VALUE (Gordon Growth Model) ---
  fcfYear6 = projectedFCF[4].fcf * (1 + growthRateTerminal);
  terminalValue = Math.round(fcfYear6 / (discountRate - growthRateTerminal));
  pvTerminalValue = Math.round(terminalValue * projectedFCF[4].pvFactor);

  // --- ENTERPRISE VALUE ---
  pvPhase1 = projectedFCF.reduce((sum, p) => sum + p.pvFCF, 0);
  enterpriseValue = pvPhase1 + pvTerminalValue;

  // --- EQUITY VALUE ---
  equityValue = enterpriseValue + netCash;
  intrinsicValuePerShare = equityValue / sharesOutstanding;
  roundedIV = Math.round(intrinsicValuePerShare * 100) / 100;

  // Market comparison
  marginOfSafety = ((roundedIV - currentPrice) / currentPrice * 100).toFixed(1);
  verdictText = roundedIV > currentPrice ? "Undervalued" : "Overvalued";
  verdictColor = roundedIV > currentPrice ? "#10b981" : "#ef4444";
} else {
  // Add placeholder structure for template rendering if data is null
  for (let yr = 1; yr <= 5; yr++) {
    projectedFCF.push({ year: yr, fcf: null, pvFactor: null, pvFCF: null });
  }
}

// Margin data for table
const marginHistory = years.map((y, i) => {
  return {
    year: y,
    operating: (operatingIncomeHistory[i] !== null && revenueHistory[i] !== null) ? ((operatingIncomeHistory[i] / revenueHistory[i]) * 100).toFixed(2) : null,
    profit: (netIncomeHistory[i] !== null && revenueHistory[i] !== null) ? ((netIncomeHistory[i] / revenueHistory[i]) * 100).toFixed(2) : null,
    fcfMargin: (fcfHistory[i] !== null && revenueHistory[i] !== null) ? ((fcfHistory[i] / revenueHistory[i]) * 100).toFixed(2) : null
  };
});

// Sensitivity analysis
const sensitivityRates = [0.06, 0.065, 0.07, 0.075, 0.08];
const sensitivityGrowth = [0.03, 0.04, 0.05, 0.06, 0.07];
const sensitivityTable = sensitivityRates.map(dr => {
  return {
    dr,
    values: sensitivityGrowth.map(gr => {
      if (baseFCF === null || sharesOutstanding === null || netCash === null) return null;
      let f = baseFCF;
      let pvSum = 0;
      for (let y = 1; y <= 5; y++) {
        f = f * (1 + gr);
        pvSum += f / Math.pow(1 + dr, y);
      }
      const f6 = f * (1 + growthRateTerminal);
      const tv = f6 / (dr - growthRateTerminal);
      const pvTV = tv / Math.pow(1 + dr, 5);
      return Math.round((pvSum + pvTV + netCash) / sharesOutstanding);
    })
  };
});
