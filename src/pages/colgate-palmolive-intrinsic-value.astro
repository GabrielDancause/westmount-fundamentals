---
import SiteLayout from "../layouts/SiteLayout.astro";

const schema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": "Colgate-Palmolive (CL) Intrinsic Value: A DCF Analysis",
  "description": "A transparent, step-by-step discounted cash flow valuation of Colgate-Palmolive. Using actual FY2025 financials to arrive at a single fair value estimate for CL shares.",
  "datePublished": "2026-03-18",
  "dateModified": "2026-03-18",
  "author": {
    "@type": "Organization",
    "name": "Westmount Research",
    "url": "https://westmountfundamentals.com"
  },
  "publisher": {
    "@type": "Organization",
    "name": "Westmount Research",
    "url": "https://westmountfundamentals.com"
  },
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": "https://westmountfundamentals.com/colgate-palmolive-intrinsic-value"
  }
};

export const meta = {
  title: "Colgate-Palmolive (CL) Intrinsic Value: A DCF Analysis",
  description: "We ran a full discounted cash flow on Colgate-Palmolive using FY2025 actuals. One number. Every assumption disclosed. Here's what CL is really worth.",
  category: "study",
  published: "2026-03-18",
};

/* ═══════════════════════════════════════════════════════════════
   DCF MODEL — ALL INPUTS AND CALCULATIONS
   Every number is sourced from Colgate-Palmolive's FY2025 10-K.
   We use a two-stage DCF: steady-growth phase (Years 1-5) then terminal value.
   ═══════════════════════════════════════════════════════════════ */

import * as cheerio from "cheerio";

// --- INPUTS (all in millions USD unless noted) ---

// Fetch Function to get live data from stockanalysis.com
async function fetchFinancialData() {
  const headers = { 'User-Agent': 'Mozilla/5.0' };
  let currentPrice = null;
  let sharesOutstanding = null;
  let fcfBase = null;
  let totalDebt = null;
  let totalCash = null;

  try {
    // 1. Fetch Price
    const resPrice = await fetch('https://stockanalysis.com/stocks/cl/', { headers });
    if (resPrice.ok) {
      const html = await resPrice.text();
      const $ = cheerio.load(html);
      const priceText = $('.text-4xl.font-bold').text().trim() || $('.text-5xl.font-bold').text().trim();
      if (priceText) {
        currentPrice = parseFloat(priceText.replace(/,/g, ''));
      }
    }

    // 2. Fetch Shares & FCF
    const resInc = await fetch('https://stockanalysis.com/stocks/cl/financials/', { headers });
    if (resInc.ok) {
      const html = await resInc.text();
      const $ = cheerio.load(html);

      $('table tbody tr').each((i, el) => {
        const firstCol = $(el).find('td').first().text().trim();
        if (firstCol === 'Shares Outstanding (Basic)') {
          const val = $(el).find('td').eq(1).text().trim();
          if (val && val !== '-') sharesOutstanding = parseFloat(val.replace(/,/g, ''));
        }
        if (firstCol === 'Free Cash Flow') {
          const val = $(el).find('td').eq(1).text().trim();
          if (val && val !== '-') fcfBase = parseFloat(val.replace(/,/g, ''));
        }
      });
    }

    // 3. Fetch Balance Sheet
    const resBal = await fetch('https://stockanalysis.com/stocks/cl/financials/balance-sheet/', { headers });
    if (resBal.ok) {
      const html = await resBal.text();
      const $ = cheerio.load(html);
      $('table tbody tr').each((i, el) => {
        const firstCol = $(el).find('td').first().text().trim();
        if (firstCol === 'Cash & Equivalents') {
          const val = $(el).find('td').eq(1).text().trim();
          if (val && val !== '-') totalCash = parseFloat(val.replace(/,/g, ''));
        }
        if (firstCol === 'Total Debt') {
          const val = $(el).find('td').eq(1).text().trim();
          if (val && val !== '-') totalDebt = parseFloat(val.replace(/,/g, ''));
        }
      });
    }
  } catch (err) {
    console.error("Failed to fetch data", err);
  }

  return { currentPrice, sharesOutstanding, fcfBase, totalDebt, totalCash };
}

const fetchedData = await fetchFinancialData();

const currentPrice = fetchedData.currentPrice || 88.54;
const fcf2025 = fetchedData.fcfBase || 3634;                  // FY2025 Free Cash Flow ($M)
const sharesOutstanding = fetchedData.sharesOutstanding || 801;         // Basic shares outstanding ($M) — FY2025
const cashAndInvestments = fetchedData.totalCash || 1288;       // Cash + short-term investments ($M)
const totalDebt = fetchedData.totalDebt || 8554;                // Total debt ($M)
const netCash = cashAndInvestments - totalDebt; // Net Debt

// --- ASSUMPTIONS (fully disclosed below) ---
const growthRatePhase1 = 0.05;         // 5% FCF growth, Years 1-5
const growthRateTerminal = 0.025;      // 2.5% perpetuity growth (terminal)
const discountRate = 0.07;             // 7% WACC / required return

// --- PHASE 1: PROJECT FCF FOR YEARS 1-5 ---
const projectedFCF = [];
let fcf = fcf2025;
for (let yr = 1; yr <= 5; yr++) {
  fcf = fcf * (1 + growthRatePhase1);
  projectedFCF.push({ year: yr, fcf: Math.round(fcf), pvFactor: 1 / Math.pow(1 + discountRate, yr) });
}
projectedFCF.forEach(p => { p.pvFCF = Math.round(p.fcf * p.pvFactor); });

// --- PHASE 2: TERMINAL VALUE (Gordon Growth Model) ---
const fcfYear6 = projectedFCF[4].fcf * (1 + growthRateTerminal);
const terminalValue = Math.round(fcfYear6 / (discountRate - growthRateTerminal));
const pvTerminalValue = Math.round(terminalValue * projectedFCF[4].pvFactor);

// --- ENTERPRISE VALUE ---
const pvPhase1 = projectedFCF.reduce((sum, p) => sum + p.pvFCF, 0);
const enterpriseValue = pvPhase1 + pvTerminalValue;

// --- EQUITY VALUE ---
const equityValue = enterpriseValue + netCash;
const intrinsicValuePerShare = equityValue / sharesOutstanding;
const roundedIV = Math.round(intrinsicValuePerShare * 100) / 100;

// Market comparison
const marginOfSafety = ((roundedIV - currentPrice) / currentPrice * 100).toFixed(1);
const verdictText = roundedIV > currentPrice ? "Undervalued" : "Overvalued";
const verdictColor = roundedIV > currentPrice ? "#10b981" : "#ef4444";

// --- HISTORICAL DATA for charts ---
const revenueHistory = [
  { year: 2021, value: 17421 },
  { year: 2022, value: 17967 },
  { year: 2023, value: 19457 },
  { year: 2024, value: 20101 },
  { year: 2025, value: 20382 },
];
const fcfHistory = [
  { year: 2021, value: 2758 },
  { year: 2022, value: 1860 },
  { year: 2023, value: 3040 },
  { year: 2024, value: 3546 },
  { year: 2025, value: 3634 },
];
const epsHistory = [
  { year: 2021, value: 2.55 },
  { year: 2022, value: 2.13 },
  { year: 2023, value: 2.77 },
  { year: 2024, value: 3.51 },
  { year: 2025, value: 2.63 },
];
const marginHistory = [
  { year: 2021, operating: 19.1, profit: 12.4, fcfMargin: 15.8 },
  { year: 2022, operating: 16.1, profit: 9.9, fcfMargin: 10.4 },
  { year: 2023, operating: 20.5, profit: 11.8, fcfMargin: 15.6 },
  { year: 2024, operating: 21.2, profit: 14.4, fcfMargin: 17.6 },
  { year: 2025, operating: 16.2, profit: 10.5, fcfMargin: 17.8 },
];

// Sensitivity analysis
const sensitivityRates = [0.05, 0.06, 0.07, 0.08, 0.09];
const sensitivityGrowth = [0.03, 0.04, 0.05, 0.06, 0.07];
const sensitivityTable = sensitivityRates.map(dr => {
  return {
    dr,
    values: sensitivityGrowth.map(gr => {
      let f = fcf2025;
      let pvSum = 0;
      for (let y = 1; y <= 5; y++) {
        f = f * (1 + gr);
        pvSum += f / Math.pow(1 + dr, y);
      }
      const f6 = f * (1 + growthRateTerminal);
      const tv = f6 / (dr - growthRateTerminal);
      const pvTV = tv / Math.pow(1 + dr, 5);
      return Math.round((pvSum + pvTV + netCash) / sharesOutstanding);
    })
  };
});
