          <td>${pvTerminalValue.toLocaleString()}</td>
        </tr>
        <tr class="row-highlight">
          <td style="text-align:left"><strong>Implied Enterprise Value</strong></td>
          <td><strong>${enterpriseValue.toLocaleString()}</strong></td>
        </tr>
        <tr>
          <td style="text-align:left">Plus: Cash & Equivalents</td>
          <td>${cashAndInvestments.toLocaleString()}</td>
        </tr>
        <tr>
          <td style="text-align:left">Less: Total Debt</td>
          <td>-${totalDebt.toLocaleString()}</td>
        </tr>
        <tr class="row-highlight">
          <td style="text-align:left"><strong>Implied Equity Value</strong></td>
          <td><strong>${equityValue.toLocaleString()}</strong></td>
        </tr>
        <tr>
          <td style="text-align:left">Shares Outstanding (Millions)</td>
          <td>{sharesOutstanding}</td>
        </tr>
        <tr class="row-total">
          <td style="text-align:left">Intrinsic Value Per Share</td>
          <td class="highlight-cell">${roundedIV.toFixed(2)}</td>
        </tr>
      </tbody>
    </table>
  </div>

  <!-- ═══ HISTORICAL CHARTS ═══ -->
  <h2>Financial Track Record</h2>
  <p>Before trusting a forward projection, look at where the company has been. Here is PNC's 5-year performance.</p>

  <h3>Revenue ($B)</h3>
  <div class="bar-chart">
    {revenueHistory.map(r => (
      <div class="bar-row">
        <div class="bar-label">{r.year}</div>
        <div class="bar-track">
          <div class="bar-fill revenue" style={`width: ${(r.value / 25000) * 100}%`}>
            ${(r.value / 1000).toFixed(1)}B
          </div>
        </div>
      </div>
    ))}
  </div>

  <h3>Free Cash Flow ($B)</h3>
  <div class="bar-chart">
    {fcfHistory.map(r => (
      <div class="bar-row">
        <div class="bar-label">{r.year}</div>
        <div class="bar-track">
          <div class="bar-fill fcf" style={`width: ${(Math.max(r.value, 0) / 12000) * 100}%`}>
            ${(r.value / 1000).toFixed(1)}B
          </div>
        </div>
      </div>
    ))}
  </div>

  <h3>Earnings Per Share (Diluted)</h3>
  <div class="bar-chart">
    {epsHistory.map(r => (
      <div class="bar-row">
