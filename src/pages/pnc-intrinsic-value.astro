---
import SiteLayout from "../layouts/SiteLayout.astro";

const schema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": "PNC Financial Services (PNC) Intrinsic Value: A DCF Analysis",
  "description": "A transparent, step-by-step discounted cash flow valuation of PNC Financial Services Group. Using actual FY2025 financials to arrive at a single fair value estimate for PNC shares.",
  "datePublished": "2026-03-18",
  "dateModified": "2026-03-18",
  "author": {
    "@type": "Organization",
    "name": "Westmount Research",
    "url": "https://westmountfundamentals.com"
  },
  "publisher": {
    "@type": "Organization",
    "name": "Westmount Research",
    "url": "https://westmountfundamentals.com"
  },
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": "https://westmountfundamentals.com/pnc-intrinsic-value"
  }
};

export const meta = {
  title: "PNC Financial Services (PNC) Intrinsic Value: A DCF Analysis",
  description: "We ran a full discounted cash flow on PNC using FY2025 actuals. One number. Every assumption disclosed. Here's what PNC is really worth.",
  category: "study",
  published: "2026-03-18",
};

/* ═══════════════════════════════════════════════════════════════
   DATA FETCHING (Live Scraping from StockAnalysis)
   ═══════════════════════════════════════════════════════════════ */
async function fetchUrl(url) {
  const https = await import('https');
  return new Promise((resolve, reject) => {
    https.get(url, { headers: { 'User-Agent': 'Mozilla/5.0' } }, (res) => {
      let data = '';
      res.on('data', (chunk) => data += chunk);
      res.on('end', () => resolve(data));
    }).on('error', reject);
  });
}

function extractData(html) {
  const match = html.match(/financialData:({.*?})/);
  if (match) {
    try {
      return eval('(' + match[1] + ')');
    } catch(e) {
      return null;
    }
  }
  return null;
}

// Fetch Price from Yahoo Finance
async function fetchPrice() {
  const https = await import('https');
  return new Promise((resolve) => {
    https.get("https://query1.finance.yahoo.com/v8/finance/chart/PNC", { headers: { 'User-Agent': 'Mozilla/5.0' } }, (res) => {
      let data = '';
      res.on('data', (chunk) => data += chunk);
      res.on('end', () => {
        try {
          const json = JSON.parse(data);
          resolve(json.chart.result[0].meta.regularMarketPrice);
        } catch(e) {
          resolve(204.69); // fallback
        }
      });
    }).on('error', () => resolve(204.69));
  });
}

// Fetch historical data
let rawFinData = null;
let rawBsData = null;
let rawCfData = null;
let currentPrice = 204.69;

try {
  const [finHtml, bsHtml, cfHtml] = await Promise.all([
    fetchUrl('https://stockanalysis.com/stocks/pnc/financials/'),
    fetchUrl('https://stockanalysis.com/stocks/pnc/financials/balance-sheet/'),
    fetchUrl('https://stockanalysis.com/stocks/pnc/financials/cash-flow-statement/')
  ]);
  rawFinData = extractData(finHtml);
  rawBsData = extractData(bsHtml);
  rawCfData = extractData(cfHtml);
  currentPrice = await fetchPrice();
} catch (e) {
  console.error("Error fetching data:", e);
}

// Fallback logic if scrape fails
let fcf2025 = 4384;
let sharesOutstanding = 396;
let cashAndInvestments = 39713;
let totalDebt = 41658;
let revenueHistory = [];
let fcfHistory = [];
let epsHistory = [];
let marginHistory = [];

if (rawFinData && rawBsData && rawCfData) {
  // Array index 1 is FY2025
  fcf2025 = Math.round(rawCfData.fcf[1] / 1000000) || fcf2025;
  sharesOutstanding = Math.round(rawFinData.sharesBasic[1] / 1000000) || sharesOutstanding;
  cashAndInvestments = Math.round(rawBsData.cashneq[1] / 1000000) || cashAndInvestments;
  totalDebt = Math.round(rawBsData.debt[1] / 1000000) || totalDebt;

  revenueHistory = rawFinData.fiscalYear.slice(1, 6).map((yearStr, i) => {
    return { year: parseInt(yearStr), value: rawFinData.revenue[i + 1] ? Math.round(rawFinData.revenue[i + 1] / 1000000) : 0 };
  }).reverse();

  fcfHistory = rawCfData.fiscalYear.slice(1, 6).map((yearStr, i) => {
    return { year: parseInt(yearStr), value: rawCfData.fcf[i + 1] ? Math.round(rawCfData.fcf[i + 1] / 1000000) : 0 };
  }).reverse();

  epsHistory = rawFinData.fiscalYear.slice(1, 6).map((yearStr, i) => {
    return { year: parseInt(yearStr), value: rawFinData.epsDiluted[i + 1] || 0 };
  }).reverse();

  marginHistory = rawFinData.fiscalYear.slice(1, 6).map((yearStr, i) => {
    const rev = rawFinData.revenue[i + 1];
    const netInc = rawFinData.netIncome[i + 1];
    const pretax = rawFinData.pretax[i + 1];
    const fcf = rawCfData.fcf[i + 1];
    return {
      year: parseInt(yearStr),
      operating: rev ? (pretax / rev * 100).toFixed(1) : 0,
      profit: rev ? (netInc / rev * 100).toFixed(1) : 0,
      fcfMargin: rev ? (fcf / rev * 100).toFixed(1) : 0
    };
  }).reverse();
}

/* ═══════════════════════════════════════════════════════════════
   DCF MODEL — ALL INPUTS AND CALCULATIONS
   ═══════════════════════════════════════════════════════════════ */

const netCash = cashAndInvestments - totalDebt;

// --- ASSUMPTIONS (fully disclosed below) ---
const growthRatePhase1 = 0.04;         // 4% FCF growth, Years 1-5
const growthRateTerminal = 0.025;      // 2.5% perpetuity growth (terminal)
const discountRate = 0.09;             // 9% WACC / required return

// --- PHASE 1: PROJECT FCF FOR YEARS 1-5 ---
const projectedFCF = [];
let fcf = fcf2025;
for (let yr = 1; yr <= 5; yr++) {
  fcf = fcf * (1 + growthRatePhase1);
  projectedFCF.push({ year: yr, fcf: Math.round(fcf), pvFactor: 1 / Math.pow(1 + discountRate, yr) });
}
projectedFCF.forEach(p => { p.pvFCF = Math.round(p.fcf * p.pvFactor); });

// --- PHASE 2: TERMINAL VALUE (Gordon Growth Model) ---
const fcfYear6 = projectedFCF[4].fcf * (1 + growthRateTerminal);
const terminalValue = Math.round(fcfYear6 / (discountRate - growthRateTerminal));
const pvTerminalValue = Math.round(terminalValue * projectedFCF[4].pvFactor);

// --- ENTERPRISE VALUE ---
const pvPhase1 = projectedFCF.reduce((sum, p) => sum + p.pvFCF, 0);
const enterpriseValue = pvPhase1 + pvTerminalValue;

// --- EQUITY VALUE ---
const equityValue = enterpriseValue + netCash;
const intrinsicValuePerShare = equityValue / sharesOutstanding;
const roundedIV = Math.round(intrinsicValuePerShare * 100) / 100;

// Market comparison
const marginOfSafety = ((roundedIV - currentPrice) / currentPrice * 100).toFixed(1);
const verdictText = roundedIV > currentPrice ? "Undervalued" : "Overvalued";
const verdictColor = roundedIV > currentPrice ? "#10b981" : "#ef4444";

// --- SENSITIVITY TABLE ---
const sensitivityRates = [0.07, 0.08, 0.09, 0.10, 0.11];
const sensitivityGrowth = [0.00, 0.02, 0.04, 0.06, 0.08];

const sensitivityTable = sensitivityRates.map(dr => {
  const rowValues = sensitivityGrowth.map(gr => {
    let simFCF = fcf2025;
    let simPVPhase1 = 0;
    for (let yr = 1; yr <= 5; yr++) {
      simFCF = simFCF * (1 + gr);
      simPVPhase1 += simFCF / Math.pow(1 + dr, yr);
    }
    const simFCFYear6 = simFCF * (1 + growthRateTerminal);
    // Gordon growth
    let tv = 0;
    if (dr > growthRateTerminal) {
       tv = simFCFYear6 / (dr - growthRateTerminal);
    }
    const simPVTerminal = tv / Math.pow(1 + dr, 5);
    const simEV = simPVPhase1 + simPVTerminal;
    const simEquity = simEV + netCash;
    return (Math.round((simEquity / sharesOutstanding) * 100) / 100).toFixed(2);
  });
  return { dr, values: rowValues };
});
