    <div class="subtitle">A full discounted cash flow analysis using actual FY2025 financials.</div>
    <div class="header-content">
      <div class="tag">Valuation Study</div>
      <div class="tag">Financial Sector</div>
      <div class="tag">Compiled by Gemini 3.1</div>
    </div>
  </div>

