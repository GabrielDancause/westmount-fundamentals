---
import SiteLayout from '../layouts/SiteLayout.astro';

const allScores = await import('../data/dashboard-scores.json');
const scores = (allScores.default || allScores) as any[];

export const meta = {
  title: 'AI Stock Analysis Dashboard — Opus 4.6 vs Gemini 3.1 | Westmount Fundamentals',
  description: 'Compare AI-generated intrinsic values and economic prospect scores for the top 60 S&P 500 companies. Side-by-side analysis from Opus 4.6 and Gemini 3.1.',
  published: '2026-03-20',
  section: 'tools',
};
---
<SiteLayout
  title={meta.title}
  description={meta.description}
  siteName="westmount"
>
  <style>
    .dashboard-hero {
      text-align: center;
      padding: 3rem 1rem 2rem;
      background: linear-gradient(135deg, rgba(74,143,231,0.08), rgba(74,143,231,0.02));
      border-bottom: 1px solid rgba(74,143,231,0.15);
    }
    .dashboard-hero h1 {
      font-size: 2.2rem;
      margin-bottom: 0.5rem;
      color: #e8eaed;
    }
    .dashboard-hero .subtitle {
      color: #9aa0a6;
      font-size: 1.1rem;
      max-width: 700px;
      margin: 0 auto 1.5rem;
    }
    .stat-row {
      display: flex;
      gap: 1.5rem;
      justify-content: center;
      flex-wrap: wrap;
      margin-top: 1rem;
    }
    .stat-card {
      background: rgba(255,255,255,0.05);
      border: 1px solid rgba(255,255,255,0.1);
      border-radius: 12px;
      padding: 1rem 1.5rem;
      min-width: 150px;
      text-align: center;
    }
    .stat-card .stat-value { font-size: 1.8rem; font-weight: 700; color: #4a8fe7; }
    .stat-card .stat-label { font-size: 0.8rem; color: #9aa0a6; text-transform: uppercase; letter-spacing: 0.05em; }

    .controls {
      display: flex;
      gap: 1rem;
      padding: 1rem 2rem;
      flex-wrap: wrap;
      align-items: center;
      border-bottom: 1px solid rgba(255,255,255,0.08);
      background: rgba(0,0,0,0.2);
    }
    .controls input[type="text"] {
      background: rgba(255,255,255,0.08);
      border: 1px solid rgba(255,255,255,0.15);
      border-radius: 8px;
      padding: 0.6rem 1rem;
      color: #e8eaed;
      font-size: 0.95rem;
      width: 220px;
    }
    .controls select {
      background: rgba(255,255,255,0.08);
      border: 1px solid rgba(255,255,255,0.15);
      border-radius: 8px;
      padding: 0.6rem 1rem;
      color: #e8eaed;
      font-size: 0.9rem;
    }
    .controls label {
      color: #9aa0a6;
      font-size: 0.85rem;
    }

    .table-wrapper {
      overflow-x: auto;
      padding: 0 1rem;
    }
    table {
      width: 100%;
      border-collapse: collapse;
      font-size: 0.88rem;
      margin: 1rem 0;
    }
    thead th {
      position: sticky;
      top: 0;
      background: #1a1a2e;
      padding: 0.8rem 0.6rem;
      text-align: left;
      color: #9aa0a6;
      font-size: 0.75rem;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      border-bottom: 2px solid rgba(74,143,231,0.3);
      cursor: pointer;
      user-select: none;
      white-space: nowrap;
    }
    thead th:hover { color: #4a8fe7; }
    thead th.sorted-asc::after { content: ' ▲'; color: #4a8fe7; }
    thead th.sorted-desc::after { content: ' ▼'; color: #4a8fe7; }

    tbody tr {
      border-bottom: 1px solid rgba(255,255,255,0.05);
      transition: background 0.15s;
    }
    tbody tr:hover { background: rgba(74,143,231,0.06); }
    td { padding: 0.65rem 0.6rem; white-space: nowrap; }
    td.ticker { font-weight: 700; color: #4a8fe7; }
    td.company { color: #bdc1c6; max-width: 180px; overflow: hidden; text-overflow: ellipsis; }

    .score-cell {
      display: inline-flex;
      align-items: center;
      gap: 0.3rem;
    }
    .score-bar {
      width: 40px;
      height: 6px;
      border-radius: 3px;
      background: rgba(255,255,255,0.1);
      overflow: hidden;
      display: inline-block;
    }
    .score-bar-fill {
      height: 100%;
      border-radius: 3px;
      transition: width 0.3s;
    }

    .verdict-badge {
      display: inline-block;
      padding: 0.2rem 0.5rem;
      border-radius: 4px;
      font-size: 0.72rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.03em;
    }
    .verdict-OVERVALUED { background: rgba(234,67,53,0.15); color: #ea4335; }
    .verdict-UNDERVALUED { background: rgba(52,168,83,0.15); color: #34a853; }
    .verdict-FAIR { background: rgba(251,188,4,0.15); color: #fbbc04; }

    .prospect-strong { color: #34a853; }
    .prospect-moderate { color: #fbbc04; }
    .prospect-weak { color: #ea4335; }

    .diff-positive { color: #34a853; }
    .diff-negative { color: #ea4335; }
    .diff-neutral { color: #9aa0a6; }

    .ai-label {
      display: inline-block;
      padding: 0.15rem 0.4rem;
      border-radius: 3px;
      font-size: 0.65rem;
      font-weight: 600;
      margin-left: 0.3rem;
    }
    .ai-opus { background: rgba(168,85,247,0.2); color: #a855f7; }
    .ai-gemini { background: rgba(59,130,246,0.2); color: #3b82f6; }

    .legend {
      display: flex;
      gap: 2rem;
      justify-content: center;
      padding: 0.8rem;
      flex-wrap: wrap;
    }
    .legend-item {
      display: flex;
      align-items: center;
      gap: 0.4rem;
      font-size: 0.8rem;
      color: #9aa0a6;
    }
    .legend-dot {
      width: 10px;
      height: 10px;
      border-radius: 50%;
    }

    .section-title {
      padding: 1.5rem 2rem 0.5rem;
      color: #e8eaed;
      font-size: 1.1rem;
      font-weight: 600;
    }

    .methodology {
      max-width: 800px;
      margin: 2rem auto;
      padding: 1.5rem 2rem;
      background: rgba(255,255,255,0.03);
      border-radius: 12px;
      border: 1px solid rgba(255,255,255,0.08);
    }
    .methodology h3 { color: #e8eaed; margin-bottom: 1rem; }
    .methodology p { color: #9aa0a6; font-size: 0.9rem; line-height: 1.6; margin-bottom: 0.8rem; }

    @media (max-width: 768px) {
      .dashboard-hero h1 { font-size: 1.5rem; }
      .stat-row { gap: 0.8rem; }
      .stat-card { min-width: 120px; padding: 0.8rem 1rem; }
      .controls { padding: 0.8rem 1rem; }
      table { font-size: 0.78rem; }
      td, th { padding: 0.5rem 0.4rem; }
    }
  </style>

  <div class="dashboard-hero">
    <h1>🤖 AI Stock Analysis Dashboard</h1>
    <p class="subtitle">Two AI models independently analyze the top 60 S&P 500 companies. Compare their intrinsic value estimates and economic prospect scores side by side.</p>
    <div class="stat-row">
      <div class="stat-card">
        <div class="stat-value">60</div>
        <div class="stat-label">Companies Analyzed</div>
      </div>
      <div class="stat-card">
        <div class="stat-value">240</div>
        <div class="stat-label">AI Analyses</div>
      </div>
      <div class="stat-card">
        <div class="stat-value">2</div>
        <div class="stat-label">AI Models</div>
      </div>
    </div>
  </div>

  <div class="legend">
    <div class="legend-item"><div class="legend-dot" style="background:#a855f7"></div> Opus 4.6 (Claude)</div>
    <div class="legend-item"><div class="legend-dot" style="background:#3b82f6"></div> Gemini 3.1 (Google)</div>
    <div class="legend-item"><div class="legend-dot" style="background:#34a853"></div> Undervalued / Strong</div>
    <div class="legend-item"><div class="legend-dot" style="background:#fbbc04"></div> Fair Value / Moderate</div>
    <div class="legend-item"><div class="legend-dot" style="background:#ea4335"></div> Overvalued / Weak</div>
  </div>

  <div class="controls" id="controls">
    <input type="text" id="search" placeholder="Search ticker or company..." />
    <select id="filter-verdict">
      <option value="all">All Verdicts</option>
      <option value="UNDERVALUED">Undervalued</option>
      <option value="FAIR VALUE">Fair Value</option>
      <option value="OVERVALUED">Overvalued</option>
    </select>
    <select id="sort-by">
      <option value="ticker">Sort: Ticker</option>
      <option value="opusProspect-desc">Opus Prospect ↓</option>
      <option value="geminiProspect-desc">Gemini Prospect ↓</option>
      <option value="opusIV-desc">Opus IV ↓</option>
      <option value="opusMoS-desc">Margin of Safety ↓</option>
      <option value="diff-desc">AI Disagreement ↓</option>
    </select>
  </div>

  <div class="table-wrapper">
    <table id="dashboard-table">
      <thead>
        <tr>
          <th>Ticker</th>
          <th>Company</th>
          <th>Opus PS</th>
          <th>Gemini PS</th>
          <th>Δ PS</th>
          <th>Opus IV</th>
          <th>Gemini IV</th>
          <th>Price</th>
          <th>Opus MoS</th>
          <th>Opus Verdict</th>
        </tr>
      </thead>
      <tbody id="dashboard-body">
      </tbody>
    </table>
  </div>

  <div class="methodology">
    <h3>📊 Methodology</h3>
    <p><strong>Economic Prospect Score (0-100):</strong> Three pillars — Competitive Momentum (0-35), Moat Durability (0-35), and Sentiment & Catalysts (0-30). Each pillar contains individually scored factors with transparent rationale. Higher is better.</p>
    <p><strong>Intrinsic Value (DCF):</strong> 10-year discounted cash flow model using company-specific FCF growth rates, WACC, and terminal growth assumptions. Each AI model independently selects its own assumptions based on fundamental analysis.</p>
    <p><strong>Margin of Safety:</strong> ((Intrinsic Value − Current Price) / Current Price) × 100. Positive = undervalued, negative = overvalued.</p>
    <p><strong>AI Disagreement (Δ):</strong> The difference between Opus and Gemini prospect scores. Large disagreements highlight stocks where the two AIs have fundamentally different views — worth investigating further.</p>
    <p><em>⚠️ This is not financial advice. AI models cannot predict the future. These analyses are demonstrations of AI reasoning and should be one of many inputs in your investment research.</em></p>
  </div>

  <script define:vars={{ scores }}>
    const data = scores;

    function getScoreColor(score, max) {
      const pct = score / max;
      if (pct >= 0.7) return '#34a853';
      if (pct >= 0.5) return '#fbbc04';
      return '#ea4335';
    }

    function formatCurrency(val) {
      if (!val && val !== 0) return '—';
      if (val >= 1000) return '$' + val.toLocaleString('en-US', { maximumFractionDigits: 0 });
      return '$' + val.toFixed(2);
    }

    function renderTable(items) {
      const tbody = document.getElementById('dashboard-body');
      tbody.innerHTML = '';

      items.forEach(d => {
        const tr = document.createElement('tr');
        const opusPS = d.opusProspect || 0;
        const gemPS = d.geminiProspect || 0;
        const diff = opusPS - gemPS;
        const diffClass = diff > 0 ? 'diff-positive' : diff < 0 ? 'diff-negative' : 'diff-neutral';
        const mos = d.opusMoS || 0;
        const mosClass = mos > 10 ? 'diff-positive' : mos < -10 ? 'diff-negative' : 'diff-neutral';
        const verdictClass = d.opusVerdict === 'OVERVALUED' ? 'verdict-OVERVALUED' :
          d.opusVerdict === 'UNDERVALUED' ? 'verdict-UNDERVALUED' : 'verdict-FAIR';

        const opusIVLink = d.opusIVSlug ? `/${d.opusIVSlug}/` : '#';
        const gemIVLink = d.geminiIVSlug ? `/${d.geminiIVSlug}/` : '#';
        const opusPSLink = d.opusProspectSlug ? `/${d.opusProspectSlug}/` : '#';
        const gemPSLink = d.geminiProspectSlug ? `/${d.geminiProspectSlug}/` : '#';

        tr.innerHTML = `
          <td class="ticker">${d.ticker}</td>
          <td class="company">${d.name}</td>
          <td><a href="${opusPSLink}" style="color:inherit;text-decoration:none"><span class="score-cell"><span class="score-bar"><span class="score-bar-fill" style="width:${opusPS}%;background:${getScoreColor(opusPS,100)}"></span></span> ${opusPS}</span></a></td>
          <td><a href="${gemPSLink}" style="color:inherit;text-decoration:none"><span class="score-cell"><span class="score-bar"><span class="score-bar-fill" style="width:${gemPS}%;background:${getScoreColor(gemPS,100)}"></span></span> ${gemPS}</span></a></td>
          <td class="${diffClass}">${diff > 0 ? '+' : ''}${diff}</td>
          <td><a href="${opusIVLink}" style="color:#a855f7;text-decoration:none">${formatCurrency(d.opusIV)}</a></td>
          <td><a href="${gemIVLink}" style="color:#3b82f6;text-decoration:none">${formatCurrency(d.geminiIV)}</a></td>
          <td>${formatCurrency(d.opusPrice || d.geminiPrice)}</td>
          <td class="${mosClass}">${mos > 0 ? '+' : ''}${mos.toFixed(1)}%</td>
          <td><span class="verdict-badge ${verdictClass}">${d.opusVerdict || '—'}</span></td>
        `;
        tbody.appendChild(tr);
      });
    }

    function filterAndSort() {
      const search = document.getElementById('search').value.toLowerCase();
      const verdictFilter = document.getElementById('filter-verdict').value;
      const sortBy = document.getElementById('sort-by').value;

      let filtered = data.filter(d => {
        const matchSearch = !search || d.ticker.toLowerCase().includes(search) || d.name.toLowerCase().includes(search);
        const matchVerdict = verdictFilter === 'all' || d.opusVerdict === verdictFilter;
        return matchSearch && matchVerdict;
      });

      filtered.sort((a, b) => {
        switch (sortBy) {
          case 'opusProspect-desc': return (b.opusProspect || 0) - (a.opusProspect || 0);
          case 'geminiProspect-desc': return (b.geminiProspect || 0) - (a.geminiProspect || 0);
          case 'opusIV-desc': return (b.opusIV || 0) - (a.opusIV || 0);
          case 'opusMoS-desc': return (b.opusMoS || 0) - (a.opusMoS || 0);
          case 'diff-desc': return Math.abs((b.opusProspect||0)-(b.geminiProspect||0)) - Math.abs((a.opusProspect||0)-(a.geminiProspect||0));
          default: return a.ticker.localeCompare(b.ticker);
        }
      });

      renderTable(filtered);
    }

    document.getElementById('search').addEventListener('input', filterAndSort);
    document.getElementById('filter-verdict').addEventListener('change', filterAndSort);
    document.getElementById('sort-by').addEventListener('change', filterAndSort);

    filterAndSort();
  </script>
</SiteLayout>
