---
import SiteLayout from "../layouts/SiteLayout.astro";
import registry from "../data/pages-registry.json";

const page = (registry as any)["list-best-money-market-funds-2026"];
export const meta = { title: "Best Money Market Funds 2026: Top Yields Ranked", description: "Compare the best money market funds of 2026. Ranked by 7-day SEC yield, expense ratio, and minimum investment. Including Vanguard, Fidelity, and Schwab.", category: "list", published: "2026-03-15" };

const schema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": "Best Money Market Funds 2026: Top Yields Ranked",
  "description": "Compare the best money market funds of 2026. Ranked by 7-day SEC yield, expense ratio, and minimum investment. Including Vanguard, Fidelity, and Schwab.",
  "datePublished": "2026-01-01T00:00:00Z",
  "dateModified": "2026-01-01T00:00:00Z",
  "publisher": {
    "@type": "Organization",
    "name": "Westmount Research",
    "logo": {
      "@type": "ImageObject",
      "url": "https://westmountfundamentals.com/logo.png"
    }
  }
};

---

 · Updated March 2026<SiteLayout
  site="westmount"
  title={page.title}
  description={page.description}
  canonical={`https://westmountfundamentals.com/${page.slug}/`} schema={schema}
>
  <style is:global>
:root {
        --gradient: linear-gradient(135deg, #4a8fe7 0%, #6366f1 100%);

}

      * {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }

      body {
        font-family: 'Inter', sans-serif;
        background-color: var(--bg-color);
        color: var(--text-primary);
        line-height: 1.6;
        padding-bottom: 4rem;
      }

      .font-mono {
        font-family: 'JetBrains Mono', monospace;
      }

      /* Nav */
      nav {
        position: sticky;
        top: 0;
        z-index: 1000;
        background: rgba(6, 10, 18, 0.8);
        backdrop-filter: blur(12px);
        border-bottom: 1px solid var(--border-color);
        padding: 1rem 0;
      }
      .nav-container {
        max-width: 1200px;
        margin: 0 auto;
        padding: 0 1.5rem;
        display: flex;
        justify-content: space-between;
        align-items: center;
      }
      .nav-brand {
        font-weight: 700;
        font-size: 1.25rem;
        color: var(--text-primary);
        text-decoration: none;
        display: flex;
        align-items: center;
        gap: 0.5rem;
      }
      .nav-links {
        display: flex;
        gap: 1.5rem;
      }
      .nav-links a {
        color: var(--text-muted);
        text-decoration: none;
        font-size: 0.9rem;
        font-weight: 500;
        transition: color 0.2s;
      }
      .nav-links a:hover {
        color: var(--accent-color);
      }

      /* Layout */
      .container {
        max-width: 1200px;
        margin: 0 auto;
        padding: 0 1.5rem;
      }

      header {
        text-align: center;
        padding: 4rem 0 2rem;
      }

      h1 {
        font-size: 2.5rem;
        font-weight: 800;
        margin-bottom: 1rem;
        background: var(--gradient);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        line-height: 1.2;
      }

      .subtitle {
        color: var(--text-muted);
        font-size: 1.1rem;
        max-width: 700px;
        margin: 0 auto;
      }

      /* Stats */
      .stats-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
        gap: 1.5rem;
        margin-bottom: 3rem;
      }

      .stat-card {
        background: var(--card-bg);
        border: 1px solid var(--border-color);
        border-radius: 12px;
        padding: 1.5rem;
        text-align: center;
      }

      .stat-value {
        font-size: 2rem;
        font-weight: 700;
        color: var(--accent-color);
        margin-bottom: 0.25rem;
      }

      .stat-label {
        font-size: 0.9rem;
        color: var(--text-muted);
        font-weight: 500;
      }

      /* Controls */
      .controls {
        display: flex;
        flex-wrap: wrap;
        gap: 1rem;
        margin-bottom: 1.5rem;
        justify-content: space-between;
        align-items: center;
      }

      .search-box {
        flex: 1;
        min-width: 250px;
        max-width: 400px;
      }

      .search-box input {
        width: 100%;
        background: var(--card-bg);
        border: 1px solid var(--border-color);
        color: var(--text-primary);
        padding: 0.75rem 1rem;
        border-radius: 8px;
        font-family: inherit;
        font-size: 0.95rem;
      }

      .search-box input:focus {
        outline: none;
        border-color: var(--accent-color);
      }

      /* Table */
      .table-container {
        overflow-x: auto;
        background: var(--card-bg);
        border: 1px solid var(--border-color);
        border-radius: 12px;
        margin-bottom: 3rem;
      }

      table {
        width: 100%;
        border-collapse: collapse;
        text-align: left;
      }

      th, td {
        padding: 1rem 1.5rem;
        border-bottom: 1px solid var(--border-color);
      }

      th {
        font-weight: 600;
        color: var(--text-muted);
        font-size: 0.85rem;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        cursor: pointer;
        user-select: none;
      }

      th:hover {
        color: var(--accent-color);
      }

      th .sort-icon {
        display: inline-block;
        margin-left: 0.25rem;
        font-size: 0.8rem;
      }

      tbody tr {
        transition: background-color 0.2s;
      }

      tbody tr:hover {
        background-color: rgba(74, 143, 231, 0.05);
      }

      .ticker {
        font-weight: 700;
        color: var(--accent-color);
      }

      .company-badge {
        display: inline-block;
        padding: 0.2rem 0.5rem;
        border-radius: 4px;
        font-size: 0.75rem;
        font-weight: 600;
        background: rgba(255, 255, 255, 0.1);
        margin-top: 0.25rem;
      }
      .vanguard { background: rgba(181, 41, 46, 0.2); color: #ff8a8f; }
      .fidelity { background: rgba(62, 146, 62, 0.2); color: #86efac; }
      .schwab { background: rgba(0, 160, 223, 0.2); color: #7dd3fc; }

      /* Chart */
      .chart-container {
        background: var(--card-bg);
        border: 1px solid var(--border-color);
        border-radius: 12px;
        padding: 1.5rem;
        margin-bottom: 3rem;
        height: 400px;
        position: relative;
      }

      /* Sections */
      .section {
        margin-bottom: 3rem;
        background: var(--card-bg);
        border: 1px solid var(--border-color);
        border-radius: 12px;
        padding: 2rem;
      }

      .section h2 {
        font-size: 1.5rem;
        margin-bottom: 1.5rem;
        color: var(--accent-color);
      }

      .faq-item {
        margin-bottom: 1.5rem;
        padding-bottom: 1.5rem;
        border-bottom: 1px solid var(--border-color);
      }
      .faq-item:last-child {
        margin-bottom: 0;
        padding-bottom: 0;
        border-bottom: none;
      }
      .faq-q {
        font-weight: 600;
        font-size: 1.1rem;
        margin-bottom: 0.5rem;
      }
      .faq-a {
        color: var(--text-muted);
      }

      footer {
        text-align: center;
        padding: 2rem 0;
        border-top: 1px solid var(--border-color);
        color: var(--text-muted);
        font-size: 0.85rem;
        margin-top: 4rem;
      }

      @media (max-width: 768px) {
        th, td { padding: 0.75rem 1rem; }
        .chart-container { height: 300px; }
      }
  </style>

<div class="container">
  <div style="max-width:1280px;margin:0 auto;padding:16px 24px 0;display:flex;justify-content:space-between;align-items:center;font-size:13px;color:var(--text-dim,#94a3b8)">
    <nav aria-label="Breadcrumb"><a href="/" style="color:var(--text-dim,#94a3b8);text-decoration:none">Home</a> <span style="margin:0 6px;opacity:0.5">›</span> <a href="/lists/" style="color:var(--text-dim,#94a3b8);text-decoration:none">Lists</a> <span style="margin:0 6px;opacity:0.5">›</span> <span style="color:var(--text-primary,#c8d0de)">Best Money Market Funds 2026: Top Yields Ranked</span></nav>
    <span>4 min read</span>
  </div>
    <h1>{page.h1}</h1>


    <div class="stats-grid" id="stats-container">
      <!-- Injected via JS -->
    </div>

    <div class="controls">
      <div class="search-box">
        <input type="text" id="searchInput" placeholder="Search by ticker or fund name...">
      </div>
    </div>

    <div class="table-container">
      <table id="fundsTable">
        <thead>
          <tr>
            <th data-sort="ticker">Fund <span class="sort-icon"></span></th>
            <th data-sort="yield">7-Day Yield <span class="sort-icon">▼</span></th>
            <th data-sort="er">Expense Ratio <span class="sort-icon"></span></th>
            <th data-sort="min">Min Investment <span class="sort-icon"></span></th>
            <th data-sort="aum">Assets (AUM) <span class="sort-icon"></span></th>
          </tr>
        </thead>
        <tbody id="tableBody">
          <!-- Injected via JS -->
        </tbody>
      </table>
    </div>

    <div class="chart-container">
      <canvas id="yieldChart"></canvas>
    </div>

    <div class="section">
      <h2>Methodology</h2>
      <p style="color: var(--text-muted); margin-bottom: 1rem;">The data presented on this page represents current 7-day SEC yields, expense ratios, and minimum initial investments for some of the most popular money market mutual funds available to retail investors in 2026. Yields for money market funds fluctuate daily based on the Federal Funds rate and the underlying short-term debt instruments held by the fund.</p>
      <p style="color: var(--text-muted);">Expense ratios represent the annual fee charged by the fund, which is automatically deducted from the fund's yield. The "7-Day Yield" shown is a standardized measure representing the fund's annualized net yield over a 7-day period. Data is aggregated from public financial APIs. Westmount Research does not guarantee the accuracy of this data; always verify with the fund provider before investing.</p>
    </div>

    <div class="section">
      <h2>Frequently Asked Questions</h2>
      <div class="faq-item">
        <div class="faq-q">What is the highest yielding money market fund?</div>
        <div class="faq-a">The highest yielding money market funds currently top 5% APY, though rates change daily. Schwab Value Advantage (SWVXX) and Vanguard Federal (VMFXX) are consistently top performers, but their specific yields depend on the current Federal Funds rate.</div>
      </div>
      <div class="faq-item">
        <div class="faq-q">Money market vs savings account: Which is better?</div>
        <div class="faq-a">Money market funds often provide slightly higher yields than standard High Yield Savings Accounts (HYSAs) and offer quick liquidity. However, HYSAs are FDIC-insured, whereas money market funds are investments (SIPC-insured but not FDIC-insured), though they are considered extremely low-risk.</div>
      </div>
      <div class="faq-item">
        <div class="faq-q">Are money market funds safe in 2026?</div>
        <div class="faq-a">Yes, money market funds are considered cash equivalents and are among the safest investments available. They invest in short-term U.S. government debt and highly rated corporate paper. While not FDIC-insured, funds like Vanguard, Fidelity, and Schwab are backed by SIPC and massive institutional stability.</div>
      </div>
      <div class="faq-item">
        <div class="faq-q">How are money market funds taxed?</div>
        <div class="faq-a">Dividends from most money market funds are taxed as ordinary income at the federal and state level. However, Treasury-only money market funds (like VUSXX or SNSXX) are generally exempt from state and local income taxes, which can result in a higher after-tax yield for investors in high-tax states.</div>
      </div>
      <div class="faq-item">
        <div class="faq-q">Do I need a minimum investment for a money market fund?</div>
        <div class="faq-a">It depends on the fund. Fidelity and Schwab offer several excellent money market funds with a $0 minimum investment. Vanguard typically requires a $3,000 minimum initial investment for its primary money market funds.</div>
      </div>
    </div>
  </div>
  <script is:inline src="https://cdn.jsdelivr.net/npm/chart.js"></script>
  <script is:inline>
// Embedded Data
    const fundsData = [{"ticker":"VMFXX","name":"Vanguard Federal Money Market Fund","er":0.11,"min":3000,"company":"Vanguard","yield":3.64,"aum":375910563840},{"ticker":"SPAXX","name":"Fidelity Government Money Market Fund","er":0.42,"min":0,"company":"Fidelity","yield":3.43,"aum":null},{"ticker":"SWVXX","name":"Schwab Value Advantage Money Fund","er":0.34,"min":0,"company":"Schwab","yield":3.54,"aum":248755748864},{"ticker":"SPRXX","name":"Fidelity Money Market Fund","er":0.42,"min":0,"company":"Fidelity","yield":3.48,"aum":null},{"ticker":"SNVXX","name":"Schwab Government Money Fund","er":0.34,"min":0,"company":"Schwab","yield":5.22,"aum":32420530176},{"ticker":"VUSXX","name":"Vanguard Treasury Money Market Fund","er":0.09,"min":3000,"company":"Vanguard","yield":3.69,"aum":106512539648},{"ticker":"GABXX","name":"Gabelli US Treasury Money Market Fund","er":0.08,"min":10000,"company":"Gabelli","yield":3.66,"aum":5678692352},{"ticker":"FZFXX","name":"Fidelity Treasury Money Market Fund","er":0.42,"min":0,"company":"Fidelity","yield":3.42,"aum":null},{"ticker":"VMRXX","name":"Vanguard Cash Reserves Federal Money Market Fund","er":0.1,"min":3000000,"company":"Vanguard","yield":3.66,"aum":120596635648},{"ticker":"SNSXX","name":"Schwab U.S. Treasury Money Fund","er":0.34,"min":0,"company":"Schwab","yield":3.44,"aum":40536326144}];

    // State
    let currentSort = 'yield';
    let sortDesc = true;
    let filteredData = [...fundsData];

    // DOM Elements
    const tableBody = document.getElementById('tableBody');
    const searchInput = document.getElementById('searchInput');
    const ths = document.querySelectorAll('th[data-sort]');
    const statsContainer = document.getElementById('stats-container');

    // Formatters
    const formatCurrency = (val) => val === null ? 'N/A' : '$' + val.toLocaleString();
    const formatAUM = (val) => {
      if (val === null) return 'N/A';
      if (val >= 1e9) return '$' + (val / 1e9).toFixed(2) + 'B';
      if (val >= 1e6) return '$' + (val / 1e6).toFixed(2) + 'M';
      return '$' + val.toLocaleString();
    };
    const formatYield = (val) => val === null ? 'N/A' : val.toFixed(2) + '%';
    const formatER = (val) => val === null ? 'N/A' : val.toFixed(2) + '%';

    // Init
    function init() {
      // Sort initial data
      sortData();
      renderTable();
      renderStats();
      renderChart();

      // Events
      searchInput.addEventListener('input', (e) => {
        const term = e.target.value.toLowerCase();
        filteredData = fundsData.filter(f =>
          f.ticker.toLowerCase().includes(term) ||
          f.name.toLowerCase().includes(term)
        );
        sortData();
        renderTable();
      });
      // also handle keyup for Playwright
      searchInput.addEventListener('keyup', (e) => {
        const term = e.target.value.toLowerCase();
        filteredData = fundsData.filter(f =>
          f.ticker.toLowerCase().includes(term) ||
          f.name.toLowerCase().includes(term)
        );
        sortData();
        renderTable();
      });

      ths.forEach(th => {
        th.addEventListener('click', () => {
          const sortKey = th.getAttribute('data-sort');
          if (currentSort === sortKey) {
            sortDesc = !sortDesc;
          } else {
            currentSort = sortKey;
            sortDesc = true;
          }

          ths.forEach(t => t.querySelector('.sort-icon').textContent = '');
          th.querySelector('.sort-icon').textContent = sortDesc ? '▼' : '▲';

          sortData();
          renderTable();
        });
      });
    }

    function sortData() {
      filteredData.sort((a, b) => {
        let valA = a[currentSort];
        let valB = b[currentSort];

        // Handle nulls
        if (valA === null) valA = -Infinity;
        if (valB === null) valB = -Infinity;

        if (typeof valA === 'string') {
          return sortDesc ? valB.localeCompare(valA) : valA.localeCompare(valB);
        }

        return sortDesc ? valB - valA : valA - valB;
      });
    }

    function renderTable() {
      tableBody.innerHTML = '';
      if (filteredData.length === 0) {
        tableBody.innerHTML = '<tr><td colspan="5" style="text-align:center;color:var(--text-muted)">No funds found matching your search.</td></tr>';
        return;
      }

      filteredData.forEach(f => {
        const tr = document.createElement('tr');

        let badgeClass = '';
        if (f.company === 'Vanguard') badgeClass = 'vanguard';
        if (f.company === 'Fidelity') badgeClass = 'fidelity';
        if (f.company === 'Schwab') badgeClass = 'schwab';

        tr.innerHTML = `
          <td>
            <div class="font-mono ticker">${f.ticker}</div>
            <div style="font-size: 0.85rem; color: var(--text-muted); margin-top: 0.25rem; max-width: 300px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;" title="${f.name}">${f.name}</div>
            ${badgeClass ? `<span class="company-badge ${badgeClass}">${f.company}</span>` : ''}
          </td>
          <td class="font-mono" style="font-weight: 600; color: ${f.yield ? 'var(--accent-color)' : 'inherit'}">${formatYield(f.yield)}</td>
          <td class="font-mono">${formatER(f.er)}</td>
          <td class="font-mono">${formatCurrency(f.min)}</td>
          <td class="font-mono">${formatAUM(f.aum)}</td>
        `;
        tableBody.appendChild(tr);
      });
    }

    function renderStats() {
      const validYields = fundsData.filter(f => f.yield !== null).map(f => f.yield);
      const avgYield = validYields.length > 0 ? (validYields.reduce((a, b) => a + b, 0) / validYields.length) : 0;

      let highestYieldFund = null;
      let highestYield = -1;
      fundsData.forEach(f => {
        if (f.yield !== null && f.yield > highestYield) {
          highestYield = f.yield;
          highestYieldFund = f;
        }
      });

      const noMinCount = fundsData.filter(f => f.min === 0).length;

      statsContainer.innerHTML = `
        <div class="stat-card">
          <div class="stat-value font-mono">${avgYield.toFixed(2)}%</div>
          <div class="stat-label">Average Top Fund Yield</div>
        </div>
        <div class="stat-card">
          <div class="stat-value font-mono">${highestYieldFund ? highestYieldFund.ticker : 'N/A'}</div>
          <div class="stat-label">Highest Yielding Fund (${highestYieldFund ? formatYield(highestYieldFund.yield) : ''})</div>
        </div>
        <div class="stat-card">
          <div class="stat-value font-mono">${noMinCount}</div>
          <div class="stat-label">Funds with $0 Minimum</div>
        </div>
      `;
    }

    function renderChart() {
      const ctx = document.getElementById('yieldChart').getContext('2d');

      // Top 5 funds by yield
      const sortedByYield = [...fundsData].filter(f => f.yield !== null).sort((a, b) => b.yield - a.yield).slice(0, 5);

      const labels = sortedByYield.map(f => f.ticker);
      const data = sortedByYield.map(f => f.yield);

      // Add a baseline comparison (e.g. Average HYSA ~4.20% currently, but let's use a static approx 4.0% for context if yields are higher)
      // Since yields vary, let's just chart the top funds

      new Chart(ctx, {
        type: 'bar',
        data: {
          labels: labels,
          datasets: [{
            label: '7-Day SEC Yield (%)',
            data: data,
            backgroundColor: 'rgba(74, 143, 231, 0.5)',
            borderColor: '#4a8fe7',
            borderWidth: 1,
            borderRadius: 4
          }]
        },
        options: {
          responsive: true,
          maintainAspectRatio: false,
          plugins: {
            legend: {
              labels: { color: '#e2e8f0', font: { family: "'Inter', sans-serif" } }
            },
            tooltip: {
              backgroundColor: '#0a1020',
              titleColor: '#e2e8f0',
              bodyColor: '#e2e8f0',
              borderColor: '#152040',
              borderWidth: 1,
              titleFont: { family: "'Inter', sans-serif" },
              bodyFont: { family: "'JetBrains Mono', monospace" }
            }
          },
          scales: {
            y: {
              beginAtZero: false,
              grid: { color: '#152040' },
              ticks: { color: '#94a3b8', font: { family: "'JetBrains Mono', monospace" } }
            },
            x: {
              grid: { display: false },
              ticks: { color: '#94a3b8', font: { family: "'JetBrains Mono', monospace" } }
            }
          }
        }
      });
    }

    // Run
    init();
  </script>

  
