            if (abs >= 1e9) return '$' + (val / 1e9).toFixed(2) + 'B';
            if (abs >= 1e6) return '$' + (val / 1e6).toFixed(2) + 'M';
            return '$' + val.toLocaleString(undefined, { maximumFractionDigits: 0 });
        };

        const formatPercent = (val) => {
            return (val * 100).toFixed(2) + '%';
        };

        let currentData = [...window.__INITIAL_DATA__];
        let currentSort = { column: 'flow1m', direction: 'asc' };

        const tbody = document.getElementById('tableBody');
        const searchInput = document.getElementById('searchInput');
        const categoryFilter = document.getElementById('categoryFilter');

        function renderTable() {
            tbody.innerHTML = currentData.map(d => {
                const f1mClass = d.flow1m > 0 ? 'value-positive' : 'value-negative';
                const f3mClass = d.flow3m > 0 ? 'value-positive' : 'value-negative';
                const ytdClass = d.ytdReturn > 0 ? 'value-positive' : 'value-negative';

                return `
                    <tr>
                        <td><span class="ticker-badge">${d.ticker}</span></td>
                        <td style="font-weight:600">${d.name}</td>
                        <td><span class="category-badge">${d.category}</span></td>
                        <td class="mono-val">${formatMoney(d.aum)}</td>
                        <td class="mono-val ${ytdClass}">${d.ytdReturn > 0 ? '+' : ''}${formatPercent(d.ytdReturn)}</td>
                        <td class="mono-val ${f1mClass}">${d.flow1m > 0 ? '+' : ''}${formatMoney(d.flow1m)}</td>
                        <td class="mono-val ${f3mClass}">${d.flow3m > 0 ? '+' : ''}${formatMoney(d.flow3m)}</td>
                    </tr>
                `;
            }).join('');
        }

        function filterAndSort() {
            const query = searchInput.value.toLowerCase();
            const cat = categoryFilter.value;

            currentData = window.__INITIAL_DATA__.filter(d => {
                const matchQuery = d.ticker.toLowerCase().includes(query) || d.name.toLowerCase().includes(query);
                const matchCat = cat === 'all' || d.category === cat;
                return matchQuery && matchCat;
            });

            currentData.sort((a, b) => {
                let valA = a[currentSort.column];
                let valB = b[currentSort.column];

                if (typeof valA === 'string') valA = valA.toLowerCase();
                if (typeof valB === 'string') valB = valB.toLowerCase();

                if (valA < valB) return currentSort.direction === 'asc' ? -1 : 1;
                if (valA > valB) return currentSort.direction === 'asc' ? 1 : -1;
                return 0;
            });

            renderTable();
        }

        document.querySelectorAll('th[data-sort]').forEach(th => {
            th.addEventListener('click', () => {
                const col = th.dataset.sort;
                if (currentSort.column === col) {
                    currentSort.direction = currentSort.direction === 'asc' ? 'desc' : 'asc';
                } else {
                    currentSort.column = col;
                    currentSort.direction = col.includes('flow') || col === 'aum' || col === 'ytdReturn' ? 'desc' : 'asc';
                }
                filterAndSort();
            });
        });

        searchInput.addEventListener('input', filterAndSort);
        categoryFilter.addEventListener('change', filterAndSort);

        // Render Charts
        function renderCharts() {
            const sortedByFlow = [...window.__INITIAL_DATA__].sort((a,b) => b.flow1m - a.flow1m);
            const topInflows = sortedByFlow.slice(0, 5);
            const topOutflows = [...window.__INITIAL_DATA__].sort((a,b) => a.flow1m - b.flow1m).slice(0, 5);

            const ctxIn = document.getElementById('inflowsChart').getContext('2d');
            new Chart(ctxIn, {
                type: 'bar',
                data: {
                    labels: topInflows.map(d => d.ticker),
                    datasets: [{
                        label: '1M Net Flow ($B)',
                        data: topInflows.map(d => d.flow1m / 1e9),
                        backgroundColor: '#10b981',
                        borderRadius: 4
                    }]
                },
                options: {
                    responsive: true,
                    plugins: { legend: { display: false } },
                    scales: {
                        y: {
                            grid: { color: 'rgba(255,255,255,0.05)' },
                            ticks: { color: '#a0b0c0' }
                        },
                        x: {
                            grid: { display: false },
                            ticks: { color: '#a0b0c0' }
                        }
                    }
                }
            });

            const ctxOut = document.getElementById('outflowsChart').getContext('2d');
            new Chart(ctxOut, {
                type: 'bar',
                data: {
                    labels: topOutflows.map(d => d.ticker),
                    datasets: [{
                        label: '1M Net Flow ($B)',
                        data: topOutflows.map(d => Math.abs(d.flow1m) / 1e9),
                        backgroundColor: '#ef4444',
                        borderRadius: 4
                    }]
                },
                options: {
                    responsive: true,
                    plugins: { legend: { display: false } },
                    scales: {
                        y: {
                            grid: { color: 'rgba(255,255,255,0.05)' },
                            ticks: { color: '#a0b0c0' }
                        },
                        x: {
                            grid: { display: false },
                            ticks: { color: '#a0b0c0' }
                        }
                    }
                }
            });
        }

        filterAndSort();
        renderCharts();
  </script>

  
