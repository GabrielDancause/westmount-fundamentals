---
import SiteLayout from "../layouts/SiteLayout.astro";
import registry from "../data/pages-registry.json";

const page = (registry as any)["most-shorted-stocks-march-2026"];
export const meta = { title: "Most Shorted Stocks Right Now (March 2026) — Top 100 List", description: "Live list of the 100 most shorted stocks in March 2026. See exact short interest %, days to cover, and squeeze candidates. Updated with latest data.", category: "tool", published: "2026-03-15" };

const schema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What are the most shorted stocks in March 2026?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "The most shorted stocks in March 2026 include companies with high short interest percentages relative to their float. Top names typically include highly debated companies in sectors like consumer discretionary, technology, and real estate where investors anticipate potential price declines."
      }
    },
    {
      "@type": "Question",
      "name": "Where can I find a list of stocks with the highest short interest percentage right now?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "You can find a complete, ranked list of stocks with the highest short interest percentage right now on this page. We track the top 100 most shorted stocks, updating the data to reflect the current market conditions as of March 2026."
      }
    },
    {
      "@type": "Question",
      "name": "What does it mean when a stock has high short interest?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "High short interest means a large number of investors have borrowed shares and sold them, hoping to buy them back later at a lower price. It indicates bearish sentiment but also creates the potential for a 'short squeeze' if the stock price rises unexpectedly."
      }
    },
    {
      "@type": "Question",
      "name": "How is the short percentage of float calculated?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "The short percentage of float is calculated by dividing the number of shares currently sold short by the total number of shares available for public trading (the float), and multiplying by 100."
      }
    },
    {
      "@type": "Question",
      "name": "Can high short interest predict a market downturn?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "While high short interest indicates pessimism about a specific stock, it is not a guaranteed predictor of a broader market downturn. Often, heavily shorted stocks can experience rapid price increases (short squeezes) if positive news forces short sellers to buy shares to cover their positions."
      }
    }
  ]
};

---

<SiteLayout
  site="westmount"
  title={page.title}
  description={page.description}
  canonical={`https://westmountfundamentals.com/${page.slug}`} schema={schema}
>
  <style is:global>
:root {
        --success: #10b981;
        --danger: #ef4444;

}
      * { margin: 0; padding: 0; box-sizing: border-box; }
      body {
        font-family: 'Inter', -apple-system, sans-serif;
        background-color: var(--bg-color);
        color: var(--text-primary);
        line-height: 1.6;
      }
      .sticky-nav {
        position: sticky;
        top: 0;
        z-index: 100;
        background: rgba(6, 10, 18, 0.9);
        backdrop-filter: blur(10px);
        border-bottom: 1px solid var(--border-color);
        padding: 1rem 2rem;
        display: flex;
        justify-content: space-between;
        align-items: center;
      }
      .sticky-nav .logo {
        color: var(--text-primary);
        font-weight: 800;
        text-decoration: none;
