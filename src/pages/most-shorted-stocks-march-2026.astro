        // Formatting functions
        const formatMoney = (value) => {
            if (!value) return 'N/A';
            if (value >= 1e9) return '$' + (value / 1e9).toFixed(2) + 'B';
            if (value >= 1e6) return '$' + (value / 1e6).toFixed(2) + 'M';
            return '$' + value.toLocaleString();
        };

        const formatNumber = (value) => {
            if (!value) return 'N/A';
            if (typeof value === 'string') return value;
            if (value >= 1e9) return (value / 1e9).toFixed(2) + 'B';
            if (value >= 1e6) return (value / 1e6).toFixed(2) + 'M';
            return value.toLocaleString();
        };

        const formatPercent = (value) => {
            if (value === null || value === undefined) return 'N/A';
            return value.toFixed(2) + '%';
        };

        const formatChange = (value) => {
            if (value === null || value === undefined) return 'N/A';
            const sign = value >= 0 ? '+' : '';
            const cls = value >= 0 ? 'pos' : 'neg';
            return `<span class="${cls}">${sign}${value.toFixed(2)}%</span>`;
        };

        // State
        let currentData = [...window.__INITIAL_DATA__];
        let sortCol = 'shortInt';
        let sortAsc = false;

        // Initialize
        function init() {
            calculateStats();
            populateSectors();
            renderTable();
            renderChart();

            // Event listeners
            document.getElementById('searchInput').addEventListener('input', filterData);
            document.getElementById('sectorSelect').addEventListener('change', filterData);

            document.querySelectorAll('th[data-sort]').forEach(th => {
                th.addEventListener('click', () => {
                    const col = th.dataset.sort;
                    if (sortCol === col) {
                        sortAsc = !sortAsc;
                    } else {
                        sortCol = col;
                        sortAsc = false;
                    }
                    sortData();
                    renderTable();
                });
            });
        }

        function calculateStats() {
            const avgShort = window.__INITIAL_DATA__.reduce((sum, item) => sum + item.shortInt, 0) / window.__INITIAL_DATA__.length;

            // Find most shorted sector
            const sectorCounts = {};
            window.__INITIAL_DATA__.forEach(item => {
                if(item.sector) {
                    sectorCounts[item.sector] = (sectorCounts[item.sector] || 0) + 1;
                }
            });
            let topSector = 'Unknown';
            let maxCount = 0;
            for (const [sector, count] of Object.entries(sectorCounts)) {
                if (count > maxCount) {
                    maxCount = count;
                    topSector = sector;
                }
            }

            const html = `
                <div class="stat-card">
                    <div class="stat-value">${avgShort.toFixed(1)}%</div>
                    <div class="stat-label">Avg Short Interest</div>
                </div>
                <div class="stat-card">
                    <div class="stat-value" style="font-size: 1.5rem; display: flex; align-items: center; justify-content: center; height: 38px;" title="${topSector}">${topSector.length > 20 ? topSector.substring(0, 18) + '...' : topSector}</div>
                    <div class="stat-label">Most Shorted Sector</div>
                </div>
                <div class="stat-card">
                    <div class="stat-value">${window.__INITIAL_DATA__.length}</div>
                    <div class="stat-label">Stocks Analyzed</div>
                </div>
            `;
            document.getElementById('summary-stats').innerHTML = html;
        }

        function populateSectors() {
            const sectors = [...new Set(window.__INITIAL_DATA__.map(item => item.sector).filter(Boolean))].sort();
            const select = document.getElementById('sectorSelect');
            sectors.forEach(sector => {
                const option = document.createElement('option');
                option.value = sector;
                option.textContent = sector;
                select.appendChild(option);
            });
        }

        function filterData() {
            const search = document.getElementById('searchInput').value.toLowerCase();
            const sector = document.getElementById('sectorSelect').value;

            currentData = window.__INITIAL_DATA__.filter(item => {
                const matchesSearch = item.ticker.toLowerCase().includes(search) ||
                                      item.company.toLowerCase().includes(search);
                const matchesSector = sector === 'all' || item.sector === sector;
                return matchesSearch && matchesSector;
            });

            sortData();
            renderTable();
            renderChart();
        }

        function sortData() {
            currentData.sort((a, b) => {
                let valA = a[sortCol];
                let valB = b[sortCol];

                // Handle missing values
                if (valA === null || valA === undefined) valA = sortAsc ? Infinity : -Infinity;
                if (valB === null || valB === undefined) valB = sortAsc ? Infinity : -Infinity;

                // Handle strings vs numbers
                if (typeof valA === 'string' && typeof valB === 'string') {
                    return sortAsc ? valA.localeCompare(valB) : valB.localeCompare(valA);
                }

                return sortAsc ? valA - valB : valB - valA;
            });
        }

        function renderTable() {
            const tbody = document.getElementById('tableBody');
            tbody.innerHTML = '';

            // Update headers
            document.querySelectorAll('th[data-sort]').forEach(th => {
                th.textContent = th.textContent.replace(' ↑', '').replace(' ↓', '');
                if (th.dataset.sort === sortCol) {
                    th.textContent += sortAsc ? ' ↑' : ' ↓';
                }
            });

            currentData.forEach(item => {
                const tr = document.createElement('tr');
                tr.innerHTML = `
                    <td class="ticker">${item.ticker}</td>
                    <td class="company" title="${item.company}">${item.company}</td>
                    <td>${item.sector || 'N/A'}</td>
                    <td class="num">${formatPercent(item.shortInt)}</td>
                    <td class="num">${formatNumber(item.sharesShort)}</td>
                    <td class="num">${item.daysToCover ? item.daysToCover.toFixed(2) : 'N/A'}</td>
                    <td class="num">${item.float || 'N/A'}</td>
                    <td class="num">${formatMoney(item.marketCap)}</td>
                    <td class="num">${formatChange(item.oneMonthChange)}</td>
                `;
                tbody.appendChild(tr);
            });

            if (currentData.length === 0) {
                tbody.innerHTML = '<tr><td colspan="9" style="text-align:center; padding: 2rem;">No stocks found matching criteria</td></tr>';
            }
        }

        let chartInstance = null;
        function renderChart() {
            const ctx = document.getElementById('distributionChart').getContext('2d');

            if (chartInstance) {
                chartInstance.destroy();
            }

            // Group by short interest brackets
            const bins = {
                '20-25%': 0,
                '25-30%': 0,
                '30-40%': 0,
                '40-50%': 0,
                '50%+': 0
            };

            currentData.forEach(item => {
                const s = item.shortInt;
                if (s >= 50) bins['50%+']++;
                else if (s >= 40) bins['40-50%']++;
                else if (s >= 30) bins['30-40%']++;
                else if (s >= 25) bins['25-30%']++;
                else bins['20-25%']++;
            });

            chartInstance = new Chart(ctx, {
                type: 'bar',
                data: {
                    labels: Object.keys(bins),
                    datasets: [{
                        label: 'Number of Stocks',
                        data: Object.values(bins),
                        backgroundColor: 'rgba(74, 143, 231, 0.6)',
                        borderColor: 'rgba(74, 143, 231, 1)',
                        borderWidth: 1,
                        borderRadius: 4
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: { display: false },
                        title: {
                            display: true,
                            text: 'Short Interest Distribution',
                            color: '#f0f4f8',
                            font: { size: 16, family: 'Inter' }
                        }
                    },
                    scales: {
                        y: {
                            beginAtZero: true,
                            grid: { color: 'rgba(21, 32, 64, 0.5)' },
                            ticks: { color: '#94a3b8', stepSize: 5 }
                        },
                        x: {
                            grid: { display: false },
                            ticks: { color: '#94a3b8' }
                        }
                    }
                }
            });
        }

