      .pos { color: var(--success); }
      .neg { color: var(--danger); }

      .content-section {
        background: var(--card-bg);
        border: 1px solid var(--border-color);
        border-radius: 12px;
        padding: 2.5rem;
        margin-bottom: 3rem;
