      .content-section p { margin-bottom: 1rem; color: var(--text-secondary); }
      .content-section a { color: var(--accent-color); text-decoration: none; }
      .content-section a:hover { text-decoration: underline; }

      .faq-item { margin-bottom: 1.5rem; }
      .faq-q { font-weight: 700; font-size: 1.1rem; margin-bottom: 0.5rem; color: var(--text-primary); }
      .faq-a { color: var(--text-secondary); }

