            new Chart(ctxYield, {
                type: 'line',
                data: {
                    labels: yieldSliced.map(d => d.date),
                    datasets: [{
                        label: '10Y-2Y Yield Spread (%)',
                        data: yieldSliced.map(d => d.value),
                        borderColor: '#4a8fe7',
                        borderWidth: 2,
                        pointRadius: 0,
                        fill: false
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: { position: 'top' },
                        tooltip: { mode: 'index', intersect: false }
                    },
                    scales: {
                        y: {
                            grid: { color: '#152040' }
                        },
                        x: {
                            grid: { display: false },
                            ticks: { maxTicksLimit: 10 }
                        }
                    }
                }
            });
        }

        if (allData.sahmRule && allData.sahmRule.length > 0) {
            const ctxSahm = document.getElementById('sahmChart').getContext('2d');
            const sahmSliced = allData.sahmRule.slice(-120);
            new Chart(ctxSahm, {
                type: 'line',
                data: {
                    labels: sahmSliced.map(d => d.date),
                    datasets: [{
                        label: 'Sahm Rule Indicator (%)',
                        data: sahmSliced.map(d => d.value),
                        borderColor: '#ef4444',
                        borderWidth: 2,
                        pointRadius: 0,
                        fill: false
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: { position: 'top' },
                        tooltip: { mode: 'index', intersect: false }
                    },
                    scales: {
                        y: {
                            grid: { color: '#152040' }
                        },
                        x: {
                            grid: { display: false },
                            ticks: { maxTicksLimit: 10 }
                        }
                    }
                }
            });
        }
