        const allData = JSON.parse(rawData);

        const latest = `{"yieldCurve":{"date":"2026-03-12","value":0.51},"sahmRule":{"date":"2026-02-01","value":0.27},"unemploymentClaims":{"date":"2026-03-07","value":213000},"consumerConfidence":{"date":"2026-01-01","value":56.4},"creditSpreads":{"date":"2026-03-11","value":3.09},"housingStarts":{"date":"2026-01-01","value":1487},"durableGoods":{"date":"2025-12-01","value":319898},"nonfarmPayrolls":{"date":"2026-02-01","value":158466}}`;
        const latestData = JSON.parse(latest);

        const formatNumber = (num, decimals = 2) => {
            if (num === null || num === undefined) return 'N/A';
            return parseFloat(num).toLocaleString('en-US', { minimumFractionDigits: decimals, maximumFractionDigits: decimals });
        };

        // Populate Cards
        document.getElementById('stat-yield').textContent = latestData.yieldCurve ? formatNumber(latestData.yieldCurve.value, 2) + '%' : 'N/A';
        const yieldStatus = document.getElementById('status-yield');
        if (latestData.yieldCurve) {
            if (latestData.yieldCurve.value < 0) {
                yieldStatus.textContent = '● Inverted (Recession Signal)';
                yieldStatus.className = 'status danger';
            } else if (latestData.yieldCurve.value < 0.5) {
                yieldStatus.textContent = '● Flattening (Warning)';
                yieldStatus.className = 'status warning';
            } else {
                yieldStatus.textContent = '● Normal';
                yieldStatus.className = 'status success';
            }
        }

        document.getElementById('stat-sahm').textContent = latestData.sahmRule ? formatNumber(latestData.sahmRule.value, 2) + '%' : 'N/A';
        const sahmStatus = document.getElementById('status-sahm');
        if (latestData.sahmRule) {
            if (latestData.sahmRule.value >= 0.5) {
                sahmStatus.textContent = '● Triggered (Recession Signal)';
                sahmStatus.className = 'status danger';
            } else {
                sahmStatus.textContent = '● Safe';
                sahmStatus.className = 'status success';
            }
        }

        document.getElementById('stat-claims').textContent = latestData.unemploymentClaims ? formatNumber(latestData.unemploymentClaims.value, 0) : 'N/A';
        const claimsStatus = document.getElementById('status-claims');
        if (latestData.unemploymentClaims) {
            if (latestData.unemploymentClaims.value > 300000) {
                claimsStatus.textContent = '● Elevated Risk';
                claimsStatus.className = 'status danger';
            } else {
                claimsStatus.textContent = '● Normal';
                claimsStatus.className = 'status success';
            }
        }

        document.getElementById('stat-confidence').textContent = latestData.consumerConfidence ? formatNumber(latestData.consumerConfidence.value, 1) : 'N/A';
        const confStatus = document.getElementById('status-confidence');
        if (latestData.consumerConfidence) {
            if (latestData.consumerConfidence.value < 65) {
                confStatus.textContent = '● Pessimistic';
                confStatus.className = 'status warning';
            } else {
                confStatus.textContent = '● Optimistic';
                confStatus.className = 'status success';
            }
        }

        // Table Data
        const indicatorsList = [
            { name: "Yield Curve (10Y-2Y)", id: "yieldCurve", data: latestData.yieldCurve, threshold: "< 0.0%", condition: (v) => v < 0 },
            { name: "Sahm Rule", id: "sahmRule", data: latestData.sahmRule, threshold: "≥ 0.50%", condition: (v) => v >= 0.5 },
            { name: "Initial Unemployment Claims", id: "unemploymentClaims", data: latestData.unemploymentClaims, threshold: "> 300k", condition: (v) => v > 300000 },
            { name: "Consumer Confidence", id: "consumerConfidence", data: latestData.consumerConfidence, threshold: "< 65.0", condition: (v) => v < 65 },
            { name: "Credit Spreads (High Yield)", id: "creditSpreads", data: latestData.creditSpreads, threshold: "> 5.0%", condition: (v) => v > 5 },
            { name: "Housing Starts", id: "housingStarts", data: latestData.housingStarts, threshold: "< 1,200k", condition: (v) => v < 1200 },
            { name: "Durable Goods Orders", id: "durableGoods", data: latestData.durableGoods, threshold: "Declining trend", condition: (v) => false }, // simplified
            { name: "Nonfarm Payrolls", id: "nonfarmPayrolls", data: latestData.nonfarmPayrolls, threshold: "Negative growth", condition: (v) => false } // simplified
        ];

        let currentSort = { column: 'name', asc: true };

        function renderTable(dataToRender) {
            const tbody = document.getElementById('tableBody');
            tbody.innerHTML = '';

            dataToRender.forEach(ind => {
                const tr = document.createElement('tr');
                const val = ind.data ? ind.data.value : null;
                const date = ind.data ? ind.data.date : 'N/A';

                let statusHtml = '<span style="color: var(--text-muted)">N/A</span>';
                if (val !== null) {
                    const isTriggered = ind.condition(val);
                    statusHtml = isTriggered ? '<span style="color: var(--danger)">Triggered</span>' : '<span style="color: var(--success)">Normal</span>';
                }

                const displayVal = val !== null ? formatNumber(val, ind.id === 'unemploymentClaims' || ind.id === 'housingStarts' || ind.id === 'durableGoods' || ind.id === 'nonfarmPayrolls' ? 0 : 2) : 'N/A';

                tr.innerHTML = `
                    <td>${ind.name}</td>
                    <td>${displayVal}</td>
                    <td>${date}</td>
                    <td>${ind.threshold}</td>
                    <td>${statusHtml}</td>
                `;
                tbody.appendChild(tr);
            });
        }

        renderTable(indicatorsList);

        // Search & Filter
        document.getElementById('tableSearch').addEventListener('input', (e) => {
            const term = e.target.value.toLowerCase();
            const filtered = indicatorsList.filter(ind => ind.name.toLowerCase().includes(term));
            renderTable(filtered);
        });

        // Sort
        document.querySelectorAll('th').forEach(th => {
            th.addEventListener('click', () => {
                const col = th.dataset.sort;
                currentSort.asc = currentSort.column === col ? !currentSort.asc : true;
                currentSort.column = col;

                const sorted = [...indicatorsList].sort((a, b) => {
                    let valA, valB;
                    if (col === 'name') { valA = a.name; valB = b.name; }
                    else if (col === 'value') { valA = a.data ? a.data.value : -Infinity; valB = b.data ? b.data.value : -Infinity; }
                    else if (col === 'date') { valA = a.data ? a.data.date : ''; valB = b.data ? b.data.date : ''; }
                    else if (col === 'threshold') { valA = a.threshold; valB = b.threshold; }
                    else if (col === 'status') { valA = a.data ? a.condition(a.data.value) : false; valB = b.data ? b.condition(b.data.value) : false; }

                    if (valA < valB) return currentSort.asc ? -1 : 1;
                    if (valA > valB) return currentSort.asc ? 1 : -1;
                    return 0;
                });
                renderTable(sorted);
            });
        });

        // Charts
        Chart.defaults.color = '#9ca3af';
        Chart.defaults.font.family = "'JetBrains Mono', monospace";
        Chart.defaults.borderColor = '#152040';

        if (allData.yieldCurve && allData.yieldCurve.length > 0) {
            const ctxYield = document.getElementById('yieldChart').getContext('2d');
            // get last 10 years
