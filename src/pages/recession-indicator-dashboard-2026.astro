---
import SiteLayout from "../layouts/SiteLayout.astro";

const schema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What are the most reliable recession indicators for 2026?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "The most reliable leading indicators include the 10-Year/2-Year Yield Curve inversion, the Sahm Rule (unemployment rate momentum), and the Leading Economic Index (LEI)."
      }
    },
    {
      "@type": "Question",
      "name": "Is a recession coming in 2026?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "While no single indicator guarantees a recession, tracking multiple metrics like consumer confidence, credit spreads, and yield curves provides a probabilistic assessment of economic downturns."
      }
    },
    {
      "@type": "Question",
      "name": "What is the yield curve inversion?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "A yield curve inversion occurs when short-term interest rates (like the 2-Year Treasury) rise above long-term rates (like the 10-Year Treasury). Historically, this has preceded every major US recession."
      }
    },
    {
      "@type": "Question",
      "name": "How does the Sahm rule indicator work?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "The Sahm Rule signals the start of a recession when the three-month moving average of the national unemployment rate rises by 0.50 percentage points or more relative to its minimum during the previous 12 months."
      }
    },
    {
      "@type": "Question",
      "name": "What is the current recession probability for 2026?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Recession probability models rely on the aggregate data of these 8 leading indicators. When multiple metrics breach their historical trigger thresholds simultaneously, the probability of a near-term recession increases significantly."
      }
    }
  ]
};

export const meta = {
  title: "Recession Indicators Dashboard 2026",
  description: "Track 8 key leading recession indicators including the Yield Curve and Sahm Rule to gauge the probability of a 2026 economic downturn.",
  category: "guide",
  published: "2026-03-15",
};
---

<SiteLayout
  site="westmount"
  title="Recession Indicators Dashboard 2026"
  description="Track 8 key leading recession indicators including the Yield Curve and Sahm Rule to gauge the probability of a 2026 economic downturn."
