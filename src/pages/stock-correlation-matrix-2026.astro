        // Render Heatmap
        document.addEventListener('DOMContentLoaded', () => {
            const data = window.__INITIAL_DATA__;
            const table = document.getElementById('matrixTable');
            const tooltip = document.getElementById('tooltip');

            // Function to map correlation to color
            function getColor(val) {
                if (val === null) return 'transparent';

                // Color mapping:
                // 1.0 = #10b981 (Green)
                // 0.0 = #060a12 (Dark)
                // -1.0 = #ef4444 (Red)

                if (val > 0) {
                    // Map 0 to 1 -> opacity of green
                    const opacity = val;
                    return `rgba(16, 185, 129, ${opacity})`;
                } else if (val < 0) {
                    // Map -1 to 0 -> opacity of red
                    const opacity = Math.abs(val);
                    return `rgba(239, 68, 68, ${opacity})`;
                }
                return '#060a12';
            }

            // Create Header Row
            const thead = document.createElement('thead');
            const headerRow = document.createElement('tr');

            // Empty top-left cell
            headerRow.appendChild(document.createElement('th'));

            data.labels.forEach((label, idx) => {
                const th = document.createElement('th');
                th.className = 'col-header';
                th.textContent = data.symbols[idx];
                th.title = label; // tooltip fallback
                headerRow.appendChild(th);
            });
            thead.appendChild(headerRow);
            table.appendChild(thead);

            // Create Body Rows
            const tbody = document.createElement('tbody');

            data.matrix.forEach((row, rIdx) => {
                const tr = document.createElement('tr');

                // Row Header
                const th = document.createElement('td');
                th.className = 'row-header';
                th.textContent = `${data.labels[rIdx]} (${data.symbols[rIdx]})`;
                tr.appendChild(th);

                // Cells
                row.forEach((val, cIdx) => {
                    const td = document.createElement('td');
                    if (val !== null) {
                        td.style.backgroundColor = getColor(val);
                        // For readability, if magnitude is low, make text muted, otherwise white
                        const intensity = Math.abs(val);
                        td.style.color = intensity > 0.5 ? '#fff' : 'rgba(255,255,255,0.7)';
                        td.textContent = val.toFixed(2);

                        // Tooltip logic
                        td.addEventListener('mouseenter', (e) => {
                            tooltip.style.opacity = 1;
                            tooltip.innerHTML = `
                                <strong>${data.labels[rIdx]}</strong> vs <strong>${data.labels[cIdx]}</strong><br>
                                Correlation: ${val.toFixed(2)}
                            `;
                        });
                        td.addEventListener('mousemove', (e) => {
                            tooltip.style.left = e.pageX + 15 + 'px';
                            tooltip.style.top = e.pageY + 15 + 'px';
                        });
                        td.addEventListener('mouseleave', () => {
                            tooltip.style.opacity = 0;
                        });
                    } else {
                        td.textContent = '-';
                    }
                    tr.appendChild(td);
                });

                tbody.appendChild(tr);
            });

            table.appendChild(tbody);
        });
