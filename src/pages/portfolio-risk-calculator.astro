---
import SiteLayout from "../layouts/SiteLayout.astro";

const schema = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": "Advanced Portfolio Risk Calculator",
  "operatingSystem": "Web",
  "applicationCategory": "FinanceApplication",
  "description": "Calculate portfolio volatility, beta, Sharpe ratio, max drawdown, VaR. Analyze sector allocation, correlation matrix, and run Monte Carlo simulations.",
  "publisher": {
    "@type": "Organization",
    "name": "Westmount Research",
    "url": "https://westmountfundamentals.com"
  }
};

export const meta = {
  title: "Advanced Portfolio Risk Calculator | Westmount Research",
  description: "How much could your portfolio drop in a crash? Run a Monte Carlo simulation on your actual holdings to see your real risk exposure.",
  category: "tool",
  published: "2026-03-15",
};
---

<SiteLayout
  site="westmount"
  title="Advanced Portfolio Risk Calculator | Westmount Research"
  description="How much could your portfolio drop in a crash? Run a Monte Carlo simulation on your actual holdings to see your real risk exposure."
  canonical="https://westmountfundamentals.com/portfolio-risk-calculator" schema={schema}
>
  <style>
:root {
  --accent-light: #4a8fe7;
  --buy-color: #27ae60;
  --sell-color: #e74c3c;

}

* { box-sizing: border-box; margin: 0; padding: 0; }
body {
  font-family: 'Inter', -apple-system, sans-serif;
  background: var(--bg-color);
  color: var(--text-main);
  line-height: 1.6;
}

.header {
  padding: 20px 24px;
  border-bottom: 1px solid var(--border-color);
  background: #040810;
}
.header a {
  color: var(--accent-light);
  text-decoration: none;
  font-weight: 800;
  font-size: 1.1rem;
  letter-spacing: -0.5px;
}

.container {
  max-width: 1200px;
  margin: 0 auto;
