  </style>

<div class="container">
  <h1>Advanced Portfolio Risk Calculator</h1>
  <p>Calculate portfolio volatility, beta, Sharpe ratio, maximum drawdown, and Value at Risk (VaR). Analyze sector allocation, correlation matrix, and run Monte Carlo simulations using real historical market data.</p>

  <div class="card">
    <h2>Portfolio Holdings</h2>
    <div style="overflow-x: auto;">
      <table id="holdings-table">
        <thead>
          <tr>
            <th style="width: 40%">Ticker Symbol</th>
            <th style="width: 40%">Allocation (%)</th>
            <th style="width: 20%">Action</th>
          </tr>
        </thead>
        <tbody id="holdings-body">
          <!-- Rows will be dynamically added here -->
        </tbody>
      </table>
      <button class="btn btn-add" id="add-row-btn">+ Add Ticker</button>
    </div>

    <div class="summary-panel">
      <div class="summary-item">
        <span class="summary-label">Risk Free Rate (%)</span>
        <input type="number" id="risk-free-rate" value="4.0" step="0.1" style="width: 100px; background: transparent; border: 1px solid var(--border-color); color: #fff; font-family: 'JetBrains Mono', monospace; font-size: 1.2rem; padding: 4px 8px; border-radius: 4px;">
      </div>
      <div class="summary-item" style="text-align: right;">
        <span class="summary-label">Total Allocation</span>
        <span class="summary-val" id="total-alloc-pct">0%</span>
        <span id="alloc-error" class="error-text">Must equal 100%</span>
      </div>
    </div>

    <div style="margin-top: 24px; text-align: center;">
      <button class="btn" id="analyze-btn" style="padding: 14px 32px; font-size: 1.1rem;">Analyze Risk</button>
    </div>

    <div id="loader" class="loader">Fetching historical market data & running simulations...</div>
  </div>

  <div id="results-section" style="display: none;">
    <div class="card">
      <h2>Risk Metrics (5-Year Historical)</h2>
      <div class="metrics-grid">
        <div class="metric-box">
          <span class="label">Ann. Volatility</span>
          <span class="value" id="res-volatility">--%</span>
        </div>
        <div class="metric-box">
          <span class="label">Portfolio Beta</span>
          <span class="value" id="res-beta">--</span>
        </div>
