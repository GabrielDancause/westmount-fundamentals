---
import SiteLayout from '../layouts/SiteLayout.astro';

// --- METADATA ---
export const meta = {
  title: "Arista Networks, Inc. (ANET) Intrinsic Value - Gemini's DCF Analysis",
  description: "An independent discounted cash flow (DCF) intrinsic value analysis of Arista Networks, Inc. (ANET) compiled entirely by Gemini 3.1.",
  category: "study",
  published: "2026-03-18",
};

// --- DATA & ASSUMPTIONS (Latest FY Actuals) ---
// The prompt requires me to make bold assumptions as Gemini.
// FCF Growth (Y1-Y5): 18%. Arista is capturing massive share in AI networking (Ethernet for AI clusters) against Infiniband. Their gross margins remain incredibly high, and revenue growth is translating directly to cash.
// Discount Rate (WACC): 10.0%. Using CAPM: 4.18% Risk-Free Rate + 1.46 Beta * 4.0% ERP = 10.02%, rounded to 10.0%. Arista is a high-beta stock due to customer concentration (Microsoft, Meta), requiring a higher discount rate despite a pristine balance sheet.
// Terminal Growth: 3.5%. AI infrastructure isn't just a cycle; it's a structural permanent layer. 3.5% outpaces long-term inflation and GDP, recognizing networking's enduring relevance.

const baseFCF = 3388; // in Millions ($3,387,962,624 rounded)
const sharesOut = 1256.5; // in Millions
const currentPrice = 135.38;
const totalCash = 10743; // $10,743,000,064 rounded
const totalDebt = 22; // $22,100,000 rounded
const netCash = totalCash - totalDebt;

const fcfGrowthRate = 0.18;
const discountRate = 0.100;
const terminalGrowthRate = 0.035;

// --- YEAR 1 TO 5 PROJECTIONS ---
const projections = [];
let prevFCF = baseFCF;

for (let i = 1; i <= 5; i++) {
  const projectedFCF = prevFCF * (1 + fcfGrowthRate);
  const discountFactor = Math.pow(1 + discountRate, i);
  const pvOfFCF = projectedFCF / discountFactor;

  projections.push({
    year: `Year ${i}`,
    fcf: projectedFCF,
    pv: pvOfFCF
  });

  prevFCF = projectedFCF;
}

const sumPvFcf = projections.reduce((sum, p) => sum + p.pv, 0);

// --- TERMINAL VALUE ---
const year5FCF = projections[4].fcf;
const terminalValue = (year5FCF * (1 + terminalGrowthRate)) / (discountRate - terminalGrowthRate);
const pvTerminalValue = terminalValue / Math.pow(1 + discountRate, 5);

// --- INTRINSIC VALUE CALCULATION ---
const enterpriseValue = sumPvFcf + pvTerminalValue;
const totalEquityValue = enterpriseValue + netCash;
const intrinsicValuePerShare = totalEquityValue / sharesOut;

// Value vs Current Price
const marginOfSafety = ((intrinsicValuePerShare - currentPrice) / currentPrice) * 100;
const isUndervalued = intrinsicValuePerShare > currentPrice;

// --- SENSITIVITY MATRIX ---
const sensitivityDiscountRates = [0.090, 0.095, 0.100, 0.105, 0.110];
const sensitivityGrowthRates = [0.025, 0.030, 0.035, 0.040, 0.045];

const sensitivityMatrix = sensitivityGrowthRates.map(g => {
  return {
    growthRate: g,
    values: sensitivityDiscountRates.map(d => {
      // Re-calculate TV and PV with new rates
      const currentTerminalValue = (year5FCF * (1 + g)) / (d - g);
      const currentPvTerminalValue = currentTerminalValue / Math.pow(1 + d, 5);

      // Re-calculate PV of FCFs with new discount rate
      let currentSumPvFcf = 0;
      let tempFcf = baseFCF;
      for (let i = 1; i <= 5; i++) {
        tempFcf = tempFcf * (1 + fcfGrowthRate);
        currentSumPvFcf += tempFcf / Math.pow(1 + d, i);
      }

      const currentEV = currentSumPvFcf + currentPvTerminalValue;
      const currentEquity = currentEV + netCash;
      const currentIV = currentEquity / sharesOut;

      return currentIV;
    })
  };
});

// Formatting helpers
const formatMoney = (val) => new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD', minimumFractionDigits: 2, maximumFractionDigits: 2 }).format(val);
const formatMillions = (val) => '$' + new Intl.NumberFormat('en-US', { maximumFractionDigits: 0 }).format(val) + 'M';
const formatPercent = (val) => (val * 100).toFixed(1) + '%';

// --- SCHEMA ---
const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Article",
      "headline": meta.title,
      "description": meta.description,
      "author": {
        "@type": "Organization",
        "name": "Gemini 3.1"
      },
      "publisher": {
        "@type": "Organization",
        "name": "Westmount Fundamentals",
        "logo": {
          "@type": "ImageObject",
          "url": "https://westmountfundamentals.com/logo.png"
        }
      },
      "mainEntityOfPage": {
        "@type": "WebPage",
        "@id": "https://westmountfundamentals.com/arista-networks-intrinsic-value"
      }
    },
    {
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "Why did Gemini pick an 18% growth rate for Arista Networks?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Gemini projects an aggressive 18% Free Cash Flow growth rate because Arista is positioned as a primary beneficiary of the AI data center build-out. Their ethernet solutions are actively taking share in AI clusters, and their operational leverage allows revenue growth to translate directly into massive cash generation."
          }
        },
        {
          "@type": "Question",
          "name": "What discount rate was used for ANET's DCF?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "A 10.0% discount rate (WACC) was selected. This is calculated using CAPM with a 4.18% 10-Year US Treasury yield and Arista's high beta of 1.46. The elevated rate accounts for the concentration risk associated with their major cloud titan customers."
          }
        }
      ]
    }
  ]
};
---
<SiteLayout site="westmount" title={meta.title} description={meta.description} canonical="https://westmountfundamentals.com/arista-networks-intrinsic-value" schema={schema}>
  <div class="page-content">
    <div class="container">

      <div class="gemini-header">
        <div class="gemini-badge">COMPILED BY GEMINI 3.1</div>
        <h1>Arista Networks (ANET) Intrinsic Value</h1>
        <p class="subtitle">An independent two-stage DCF analysis by a frontier AI model.</p>
      </div>

      <div class="verdict-card">
        <div class="verdict-header">
          <h2>Fair Value Estimate</h2>
        </div>
        <div class="verdict-body">
          <div class="verdict-main">
            <span class="iv-value">{formatMoney(intrinsicValuePerShare)}</span>
            <span class="iv-label">per share</span>
          </div>
          <div class="verdict-stats">
            <div class="stat">
              <span class="stat-label">Current Price</span>
              <span class="stat-value">{formatMoney(currentPrice)}</span>
            </div>
            <div class="stat">
              <span class="stat-label">Margin of Safety</span>
              <span class={`stat-value ${isUndervalued ? 'positive' : 'negative'}`}>
                {isUndervalued ? '+' : ''}{marginOfSafety.toFixed(2)}%
              </span>
            </div>
            <div class="stat">
              <span class="stat-label">Verdict</span>
              <span class={`badge ${isUndervalued ? 'positive' : 'negative'}`}>
                {isUndervalued ? 'UNDERVALUED' : 'OVERVALUED'}
              </span>
            </div>
          </div>
        </div>
        <div class="verdict-footer">
          <p>Based on latest FY actuals. Data via S&P Global (Mar 2026).</p>
        </div>
      </div>

      <section class="content-section">
        <h2>The AI Thesis: Why I'm Bullish on the Build-Out</h2>
        <p>Arista Networks (ANET) is currently perfectly positioned at the epicenter of the AI infrastructure boom. While companies like NVIDIA are supplying the compute engines, Arista is supplying the crucial connective tissue. The shift from general-purpose cloud computing to dense AI clusters demands a quantum leap in networking performance, and Arista's Ethernet solutions are rapidly taking share against proprietary alternatives like InfiniBand.</p>
        <p>I view Arista not just as a hardware vendor, but as an operating system company (EOS) that happens to sell switches. This software-centric approach yields structurally higher gross margins than legacy competitors like Cisco. My valuation model assumes that as hyperscalers continue their massive, multi-year CapEx cycles into AI data centers, Arista's revenue growth will translate directly into explosive free cash flow generation.</p>
      </section>

      <section class="content-section">
        <h2>My Assumptions & Rationale</h2>

        <div class="assumption-grid">
          <div class="assumption-card">
            <div class="card-title">FCF Growth Rate (Y1-Y5)</div>
            <div class="card-value">{formatPercent(fcfGrowthRate)}</div>
            <p><strong>Rationale:</strong> An 18% growth rate is highly aggressive, but entirely justified by the structural tailwinds of AI networking. Arista is capturing outsized share in back-end AI networks where massive bandwidth is a hard requirement. Their operational efficiency ensures that top-line revenue growth drops directly to the bottom line, driving substantial cash flow expansion over the next five years.</p>
          </div>

          <div class="assumption-card">
            <div class="card-title">Discount Rate (WACC)</div>
            <div class="card-value">{formatPercent(discountRate)}</div>
            <p><strong>Rationale:</strong> A 10.0% discount rate reflects the risk premium associated with Arista. While they possess a pristine, debt-free balance sheet with over $10B in net cash, they have extreme customer concentration (Microsoft and Meta account for a massive portion of revenue). The 1.46 beta combined with a 4.18% risk-free rate commands a higher WACC to account for this localized volatility.</p>
          </div>

          <div class="assumption-card">
            <div class="card-title">Terminal Growth Rate</div>
            <div class="card-value">{formatPercent(terminalGrowthRate)}</div>
            <p><strong>Rationale:</strong> 3.5% slightly outpaces global GDP growth. The demand for bandwidth and low-latency networking is not a cyclical fad; it is a permanent, foundational requirement for the modern digital economy. Arista's sticky software ecosystem (EOS) ensures they will continue to extract value in perpetuity.</p>
          </div>
        </div>
      </section>

      <section class="content-section">
        <h2>Discounted Cash Flow (DCF) Projections</h2>
        <p>Starting with the base Free Cash Flow of {formatMillions(baseFCF)}, the table below outlines the 5-year projection discounted back to Present Value (PV) using the {formatPercent(discountRate)} WACC.</p>

        <div class="table-container">
          <table>
            <thead>
              <tr>
                <th>Period</th>
                <th>Projected FCF</th>
                <th>PV Factor ({formatPercent(discountRate)})</th>
                <th>Present Value</th>
              </tr>
            </thead>
            <tbody>
              {projections.map((p, index) => (
                <tr>
                  <td>{p.year}</td>
                  <td>{formatMillions(p.fcf)}</td>
                  <td>{(1 / Math.pow(1 + discountRate, index + 1)).toFixed(4)}</td>
                  <td>{formatMillions(p.pv)}</td>
                </tr>
              ))}
              <tr class="highlight-row">
                <td colspan="3"><strong>Sum of PV of FCFs (Years 1-5)</strong></td>
                <td><strong>{formatMillions(sumPvFcf)}</strong></td>
              </tr>
            </tbody>
          </table>
        </div>
      </section>

      <section class="content-section">
        <h2>Terminal & Final Valuation Math</h2>
        <p>The Terminal Value accounts for all cash flows from Year 6 into perpetuity, calculated using the Gordon Growth Model.</p>

        <div class="math-card">
          <div class="math-row">
            <span>Year 5 FCF</span>
            <span>{formatMillions(year5FCF)}</span>
          </div>
          <div class="math-row">
            <span>Terminal Value (TV) Calculation</span>
            <span>({formatMillions(year5FCF)} * {1 + terminalGrowthRate}) / ({discountRate} - {terminalGrowthRate})</span>
          </div>
          <div class="math-row">
            <span>Terminal Value</span>
            <span>{formatMillions(terminalValue)}</span>
          </div>
          <div class="math-row highlight">
            <span>PV of Terminal Value</span>
            <span>{formatMillions(pvTerminalValue)}</span>
          </div>
        </div>

        <p style="margin-top: 2rem;">Adding it all together with Net Cash:</p>

        <div class="math-card">
          <div class="math-row">
            <span>Sum of PV of FCFs (Years 1-5)</span>
            <span>{formatMillions(sumPvFcf)}</span>
          </div>
          <div class="math-row">
            <span>+ PV of Terminal Value</span>
            <span>{formatMillions(pvTerminalValue)}</span>
          </div>
          <div class="math-row">
            <span><strong>= Enterprise Value</strong></span>
            <span><strong>{formatMillions(enterpriseValue)}</strong></span>
          </div>
          <div class="math-row">
            <span>+ Net Cash (Cash - Debt)</span>
            <span>{formatMillions(netCash)}</span>
          </div>
          <div class="math-row highlight">
            <span><strong>= Total Equity Value</strong></span>
            <span><strong>{formatMillions(totalEquityValue)}</strong></span>
          </div>
          <div class="math-row">
            <span>÷ Shares Outstanding</span>
            <span>{sharesOut.toLocaleString()}M</span>
          </div>
          <div class="math-row result">
            <span><strong>Intrinsic Value Per Share</strong></span>
            <span><strong>{formatMoney(intrinsicValuePerShare)}</strong></span>
          </div>
        </div>
      </section>

      <section class="content-section">
        <h2>Sensitivity Matrix</h2>
        <p>A single intrinsic value relies on rigid assumptions. The sensitivity matrix below demonstrates how the intrinsic value changes when we adjust the Discount Rate (WACC) and the Terminal Growth Rate.</p>

        <div class="table-container sensitivity-table">
          <table>
            <thead>
              <tr>
                <th rowspan="2" class="corner-cell">Terminal<br/>Growth</th>
                <th colspan="5" class="header-cell">Discount Rate (WACC)</th>
              </tr>
              <tr>
                {sensitivityDiscountRates.map(d => <th>{formatPercent(d)}</th>)}
              </tr>
            </thead>
            <tbody>
              {sensitivityMatrix.map(row => (
                <tr>
                  <th class="row-header">{formatPercent(row.growthRate)}</th>
                  {row.values.map(val => (
                    <td class={
                      val > currentPrice * 1.15 ? "cell-undervalued" :
                      val < currentPrice * 0.85 ? "cell-overvalued" :
                      "cell-neutral"
                    }>
                      {formatMoney(val)}
                    </td>
                  ))}
                </tr>
              ))}
            </tbody>
          </table>
          <div class="matrix-legend">
            <span class="legend-item"><span class="color-box cell-undervalued"></span> Undervalued (>15% Margin)</span>
            <span class="legend-item"><span class="color-box cell-neutral"></span> Fair Value</span>
            <span class="legend-item"><span class="color-box cell-overvalued"></span> Overvalued (&lt;-15% Margin)</span>
          </div>
        </div>
      </section>

      <section class="content-section risks-section">
        <h2>Risks & Bear Case</h2>
        <p>While my valuation is bullish, a balanced analysis requires identifying the key vectors that could disrupt these assumptions:</p>
        <div class="risk-grid">
          <div class="risk-card">
            <h3>1. Extreme Customer Concentration</h3>
            <p>Arista's revenue is heavily skewed toward a small handful of "cloud titan" customers, primarily Microsoft and Meta. If either of these giants unexpectedly slashes CapEx, shifts architecture away from Ethernet, or designs their own internal switching hardware, Arista's top-line would suffer an immediate and severe contraction.</p>
          </div>
          <div class="risk-card">
            <h3>2. The Cisco Resurgence</h3>
            <p>Cisco remains the 800-pound gorilla in enterprise networking. While Arista has dominated the cloud space, Cisco is aggressively pivoting its portfolio to capture AI networking workloads (like their Silicon One architecture). Any competitive misstep by Arista could allow Cisco to reclaim lost market share.</p>
          </div>
          <div class="risk-card">
            <h3>3. InfiniBand vs. Ethernet War</h3>
            <p>While Ethernet is gaining ground in AI clusters, NVIDIA's proprietary InfiniBand remains heavily entrenched. If NVIDIA successfully bundles its GPUs, CPUs, and networking gear into irresistible all-in-one packages, Arista's addressable market in back-end AI networks could shrink.</p>
          </div>
        </div>
      </section>

      <section class="content-section faq-section">
        <h2>Frequently Asked Questions</h2>

        <div class="faq-item">
          <h3>Why did Gemini pick an 18% growth rate for Arista Networks?</h3>
          <p>Gemini projects an aggressive 18% Free Cash Flow growth rate because Arista is positioned as a primary beneficiary of the AI data center build-out. Their ethernet solutions are actively taking share in AI clusters, and their operational leverage allows revenue growth to translate directly into massive cash generation.</p>
        </div>

        <div class="faq-item">
          <h3>What discount rate was used for ANET's DCF?</h3>
          <p>A 10.0% discount rate (WACC) was selected. This is calculated using CAPM with a 4.18% 10-Year US Treasury yield and Arista's high beta of 1.46. The elevated rate accounts for the concentration risk associated with their major cloud titan customers.</p>
        </div>

        <div class="faq-item">
          <h3>Is it safe to rely on AI for stock valuation?</h3>
          <p>No. This analysis is a demonstration of AI reasoning based on a specific set of inputs and rigid formulas. It is not financial advice. AI models cannot predict macroeconomic shifts, customer losses, or sudden technological obsolescence.</p>
        </div>
      </section>

      <div class="disclaimer-box">
        <p><strong>Disclaimer:</strong> The numbers presented on this page are for educational and entertainment purposes only. They are the result of a deterministic mathematical model fed with assumptions generated by an Artificial Intelligence (Gemini 3.1). This does not constitute investment advice. Always conduct your own due diligence before investing in the stock market.</p>
      </div>

    </div>
  </div>
</SiteLayout>
