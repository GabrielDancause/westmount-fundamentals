const schema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": "Intercontinental Exchange (ICE) Intrinsic Value: A DCF Analysis",
  "description": "A transparent, step-by-step discounted cash flow valuation of Intercontinental Exchange Inc. Using actual FY2025 financials to arrive at a single fair value estimate for ICE shares.",
  "datePublished": "2026-03-20",
  "dateModified": "2026-03-20",
  "author": {
    "@type": "Organization",
    "name": "Westmount Research",
    "url": "https://westmountfundamentals.com"
  },
  "publisher": {
    "@type": "Organization",
    "name": "Westmount Research",
    "url": "https://westmountfundamentals.com"
  },
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": "https://westmountfundamentals.com/ice-intrinsic-value"
  }
};

export const meta = {
  title: "Intercontinental Exchange (ICE) Intrinsic Value: A DCF Analysis",
  description: "We ran a full discounted cash flow on Intercontinental Exchange using FY2025 actuals. One number. Every assumption disclosed. Here's what ICE is really worth.",
  category: "study",
  published: "2026-03-20",
};

/* ═══════════════════════════════════════════════════════════════
   DCF MODEL — ALL INPUTS AND CALCULATIONS
   Every number is sourced from ICE's FY2025 financials (via stockanalysis.com).
   We use a two-stage DCF: high-growth phase (Years 1-5) then terminal value.
   ═══════════════════════════════════════════════════════════════ */

// --- HTTP FETCH UTILS ---
import * as cheerio from 'cheerio';

async function fetchPage(url) {
  try {
    const res = await fetch(url, {
      headers: { 'User-Agent': 'Mozilla/5.0 (Windows NT 10.0; Win64; x64)' }
    });
    if (!res.ok) return null;
    return await res.text();
  } catch (e) {
    return null;
  }
}

function parseRow($, textToFind) {
  let values = null;
  $('table tbody tr').each((i, el) => {
    const rowText = $(el).find('td').first().text().trim();
    if (rowText === textToFind) {
      values = [];
      $(el).find('td').each((j, td) => {
        if (j > 0) {
          const valStr = $(td).text().replace(/,/g, '').replace(/%/g, '').trim();
          values.push(valStr === '-' ? null : parseFloat(valStr));
        }
      });
    }
  });
  return values;
}

// Fetch all 3 pages
const [htmlFins, htmlCF, htmlBS] = await Promise.all([
  fetchPage('https://stockanalysis.com/stocks/ice/financials/'),
  fetchPage('https://stockanalysis.com/stocks/ice/financials/cash-flow-statement/'),
  fetchPage('https://stockanalysis.com/stocks/ice/financials/balance-sheet/')
]);

// Parse numbers
let revArr = [12640, 11761, 9903, 9636, 9168];
let epsArr = [5.77, 4.78, 4.19, 2.58, 7.18];
let opMarginArr = [39.00, 36.64, 37.30, 37.75, 37.62];
let fcfMarginArr = [33.93, 35.74, 33.85, 34.55, 32.11];
let sharesArr = [572];

if (htmlFins) {
  const $fins = cheerio.load(htmlFins);
  revArr = parseRow($fins, 'Revenue') || revArr;
  epsArr = parseRow($fins, 'EPS (Diluted)') || epsArr;
  opMarginArr = parseRow($fins, 'Operating Margin') || opMarginArr;
  fcfMarginArr = parseRow($fins, 'FCF Margin') || fcfMarginArr;
  sharesArr = parseRow($fins, 'Shares Outstanding (Basic)') || sharesArr;
}

let fcfArr = [4289, 4203, 3352, 3329, 2944];
if (htmlCF) {
  const $cf = cheerio.load(htmlCF);
  fcfArr = parseRow($cf, 'Free Cash Flow') || fcfArr;
}

let cashArr = [837];
let debtArr = [20279];
if (htmlBS) {
  const $bs = cheerio.load(htmlBS);
  cashArr = parseRow($bs, 'Cash & Equivalents') || cashArr;
  debtArr = parseRow($bs, 'Total Debt') || debtArr;
}

// --- INPUTS (all in millions USD unless noted) ---
const fcfRecent = fcfArr[0] || null;
const sharesOutstanding = sharesArr[0] || null;
const cashAndInvestments = cashArr[0] || null;
const totalDebt = debtArr[0] || null;
const netCash = cashAndInvestments !== null && totalDebt !== null ? cashAndInvestments - totalDebt : null;

// --- ASSUMPTIONS (fully disclosed below) ---
const growthRatePhase1 = 0.08;         // 8% FCF growth, Years 1-5
const growthRateTerminal = 0.035;      // 3.5% perpetuity growth (terminal)
const discountRate = 0.09;             // 9% WACC / required return

// --- PHASE 1: PROJECT FCF FOR YEARS 1-5 ---
const projectedFCF = [];
let fcf = fcfRecent || 4289;
for (let yr = 1; yr <= 5; yr++) {
  fcf = fcf * (1 + growthRatePhase1);
  projectedFCF.push({ year: yr, fcf: Math.round(fcf), pvFactor: 1 / Math.pow(1 + discountRate, yr) });
}
projectedFCF.forEach(p => { p.pvFCF = Math.round(p.fcf * p.pvFactor); });

// --- PHASE 2: TERMINAL VALUE (Gordon Growth Model) ---
const fcfYear6 = projectedFCF[4].fcf * (1 + growthRateTerminal);
const terminalValue = Math.round(fcfYear6 / (discountRate - growthRateTerminal));
const pvTerminalValue = Math.round(terminalValue * projectedFCF[4].pvFactor);

// --- ENTERPRISE VALUE ---
const pvPhase1 = projectedFCF.reduce((sum, p) => sum + p.pvFCF, 0);
const enterpriseValue = pvPhase1 + pvTerminalValue;

// --- EQUITY VALUE ---
const equityValue = enterpriseValue + netCash;
const intrinsicValuePerShare = equityValue / sharesOutstanding;
const roundedIV = Math.round(intrinsicValuePerShare * 100) / 100;

// Market comparison
const currentPrice = 158.59;
const marginOfSafety = ((roundedIV - currentPrice) / currentPrice * 100).toFixed(1);
const verdictText = roundedIV > currentPrice ? "Undervalued" : "Overvalued";
const verdictColor = roundedIV > currentPrice ? "#10b981" : "#ef4444";

// --- HISTORICAL DATA for charts ---
const revenueHistory = revArr.slice(0,5).reverse().map((v, i) => ({ year: 2021 + i, value: v || 0 }));
const fcfHistory = fcfArr.slice(0,5).reverse().map((v, i) => ({ year: 2021 + i, value: v || 0 }));
const epsHistory = epsArr.slice(0,5).reverse().map((v, i) => ({ year: 2021 + i, value: v || 0 }));
const marginHistory = opMarginArr.slice(0,5).reverse().map((op, i) => ({
  year: 2021 + i,
  operating: op || 0,
  profit: 0, // Simplified for fallback
  fcfMargin: fcfMarginArr[4-i] || 0
}));

// Sensitivity analysis
const sensitivityRates = [0.07, 0.08, 0.09, 0.10, 0.11];
const sensitivityGrowth = [0.04, 0.06, 0.08, 0.10, 0.12];
const sensitivityTable = sensitivityRates.map(dr => {
  return {
    dr,
    values: sensitivityGrowth.map(gr => {
      let f = fcfRecent;
      let pvSum = 0;
      for (let y = 1; y <= 5; y++) {
        f = f * (1 + gr);
        pvSum += f / Math.pow(1 + dr, y);
      }
      const f6 = f * (1 + growthRateTerminal);
      const tv = f6 / (dr - growthRateTerminal);
      const pvTV = tv / Math.pow(1 + dr, 5);
      return Math.round((pvSum + pvTV + netCash) / sharesOutstanding);
    })
  };
});
