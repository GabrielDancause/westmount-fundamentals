          <div class="stat-value">${(revenueHistory[0].value / 1000).toFixed(1)}B</div>
          <div class="stat-label">FY2025 Revenue</div>
        </div>
        <div class="stat-card">
          <div class="stat-value">${(fcf2025 / 1000).toFixed(2)}B</div>
          <div class="stat-label">Free Cash Flow</div>
        </div>
        <div class="stat-card">
          <div class="stat-value">${epsHistory[0].value !== null ? epsHistory[0].value.toFixed(2) : 'N/A'}</div>
          <div class="stat-label">EPS (Diluted)</div>
        </div>
        <div class="stat-card">
          <div class="stat-value">{marginHistory[0].operating !== null ? marginHistory[0].operating + '%' : 'N/A'}</div>
          <div class="stat-label">Operating Margin</div>
        </div>
