/* ═══════════════════════════════════════════════════════════════
   DCF MODEL — ALL INPUTS AND CALCULATIONS
   Every number is sourced from ITW's FY2025 data.
   We use a two-stage DCF: high-growth phase (Years 1-5) then terminal value.
   ═══════════════════════════════════════════════════════════════ */

// --- INPUTS (all in millions USD unless noted) ---
// Dynamically fetch financials
async function fetchStockAnalysisData(url, key, isTotalDebt = false) {
  try {
    const res = await fetch(url);
    if (!res.ok) return null;
    const text = await res.text();
    const regex = new RegExp(`${key}:\\[(.*?)\\]`, "g");

    let match;
    let matches = [];
    while ((match = regex.exec(text)) !== null) {
        matches.push(match[1]);
    }

    if (matches.length > 0) {
      // For total debt, we usually want the last match of 'debt' which represents Total Debt
      let targetMatch = isTotalDebt ? matches[matches.length - 1] : matches[0];
      const arr = targetMatch.split(',').map(x => x.replace(/['"]/g, '').trim());

      for (const val of arr) {
          if (val && val !== 'null' && !isNaN(Number(val))) {
             if (key.includes('eps') || key.includes('shares')) {
                 return Number(val);
             }
             return Number(val) / 1000000; // Return in millions
          }
      }
    }
  } catch (e) {
    console.error(`Error fetching ${key} from ${url}:`, e);
  }
  return null;
}

const financialsUrl = 'https://stockanalysis.com/stocks/itw/financials/';
const cashFlowUrl = 'https://stockanalysis.com/stocks/itw/financials/cash-flow-statement/';
const balanceSheetUrl = 'https://stockanalysis.com/stocks/itw/financials/balance-sheet/';

const [
  fcfData,
  revenueData,
  epsData,
  sharesData,
  cashData,
  debtData
] = await Promise.all([
  fetchStockAnalysisData(cashFlowUrl, 'fcf'),
  fetchStockAnalysisData(financialsUrl, 'revenue'),
  fetchStockAnalysisData(financialsUrl, 'epsDiluted'),
  fetchStockAnalysisData(financialsUrl, 'sharesDiluted'),
  fetchStockAnalysisData(balanceSheetUrl, 'cashneq'),
  fetchStockAnalysisData(balanceSheetUrl, 'debt', true)
]);

// Fallbacks if fetch fails
const fcf2025 = fcfData || 2707;
const revenue2025 = revenueData || 16044;
const eps2025 = epsData || 10.49;
const sharesOutstanding = sharesData ? sharesData / 1000000 : 288.2;
const cashAndInvestments = cashData || 851;
const totalDebt = debtData || 8969;
const netCash = cashAndInvestments - totalDebt; // -$8,360M

// --- ASSUMPTIONS (fully disclosed below) ---
const growthRatePhase1 = 0.05;         // 5% FCF growth, Years 1-5
const growthRateTerminal = 0.025;      // 2.5% perpetuity growth (terminal)
const discountRate = 0.085;            // 8.5% WACC / required return

// --- PHASE 1: PROJECT FCF FOR YEARS 1-5 ---
const projectedFCF = [];
let fcf = fcf2025;
for (let yr = 1; yr <= 5; yr++) {
  fcf = fcf * (1 + growthRatePhase1);
  projectedFCF.push({ year: yr, fcf: Math.round(fcf), pvFactor: 1 / Math.pow(1 + discountRate, yr) });
}
projectedFCF.forEach(p => { p.pvFCF = Math.round(p.fcf * p.pvFactor); });

// --- PHASE 2: TERMINAL VALUE (Gordon Growth Model) ---
const fcfYear6 = projectedFCF[4].fcf * (1 + growthRateTerminal);
const terminalValue = Math.round(fcfYear6 / (discountRate - growthRateTerminal));
const pvTerminalValue = Math.round(terminalValue * projectedFCF[4].pvFactor);

// --- ENTERPRISE VALUE ---
const pvPhase1 = projectedFCF.reduce((sum, p) => sum + p.pvFCF, 0);
const enterpriseValue = pvPhase1 + pvTerminalValue;

// --- EQUITY VALUE ---
const equityValue = enterpriseValue + netCash;
const intrinsicValuePerShare = equityValue / sharesOutstanding;
const roundedIV = Math.round(intrinsicValuePerShare * 100) / 100;

// Market comparison
const currentPrice = 264.48;
const marginOfSafety = ((roundedIV - currentPrice) / currentPrice * 100).toFixed(1);
const verdictText = roundedIV > currentPrice ? "Undervalued" : "Overvalued";
const verdictColor = roundedIV > currentPrice ? "#10b981" : "#ef4444";

// --- HISTORICAL DATA for charts ---
const revenueHistory = [
  { year: 2021, value: 14_455 },
  { year: 2022, value: 15_932 },
  { year: 2023, value: 16_107 },
  { year: 2024, value: 15_898 },
  { year: 2025, value: 16_044 },
];
const fcfHistory = [
  { year: 2021, value: 2_261 },
  { year: 2022, value: 1_936 },
  { year: 2023, value: 3_084 },
  { year: 2024, value: 2_844 },
  { year: 2025, value: 2_707 },
];
const epsHistory = [
  { year: 2021, value: 8.51 },
  { year: 2022, value: 9.77 },
  { year: 2023, value: 9.74 },
  { year: 2024, value: 11.71 },
  { year: 2025, value: 10.49 },
];
const marginHistory = [
  { year: 2021, operating: 23.8, profit: 18.6, fcfMargin: 15.6 },
  { year: 2022, operating: 23.8, profit: 19.0, fcfMargin: 12.1 },
  { year: 2023, operating: 25.1, profit: 18.4, fcfMargin: 19.1 },
  { year: 2024, operating: 26.8, profit: 21.9, fcfMargin: 17.9 },
  { year: 2025, operating: 26.3, profit: 19.1, fcfMargin: 16.9 },
];

// Sensitivity analysis
const sensitivityRates = [0.065, 0.075, 0.085, 0.095, 0.105];
const sensitivityGrowth = [0.01, 0.03, 0.05, 0.07, 0.09];
const sensitivityTable = sensitivityRates.map(dr => {
  return {
    dr,
    values: sensitivityGrowth.map(gr => {
      let f = fcf2025;
      let pvSum = 0;
      for (let y = 1; y <= 5; y++) {
        f = f * (1 + gr);
        pvSum += f / Math.pow(1 + dr, y);
      }
      const f6 = f * (1 + growthRateTerminal);
      const tv = f6 / (dr - growthRateTerminal);
      const pvTV = tv / Math.pow(1 + dr, 5);
      return Math.round((pvSum + pvTV + netCash) / sharesOutstanding);
    })
  };
});
