---
import SiteLayout from "../layouts/SiteLayout.astro";
import * as cheerio from 'cheerio';

export const meta = {
  title: "Illinois Tool Works (ITW) Intrinsic Value: A DCF Analysis",
  description: "We ran a full discounted cash flow on Illinois Tool Works using FY2025 actuals. One number. Every assumption disclosed. Here's what ITW is really worth.",
  category: "study",
  published: "2026-03-18",
};

const schema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": "Illinois Tool Works (ITW) Intrinsic Value: A DCF Analysis",
  "description": "A transparent, step-by-step discounted cash flow valuation of Illinois Tool Works. Using actual FY2025 financials to arrive at a single fair value estimate for ITW shares.",
  "datePublished": "2026-03-18",
  "dateModified": "2026-03-18",
  "author": {
    "@type": "Organization",
    "name": "Westmount Research",
    "url": "https://westmountfundamentals.com"
  },
  "publisher": {
    "@type": "Organization",
    "name": "Westmount Research",
    "url": "https://westmountfundamentals.com"
  },
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": "https://westmountfundamentals.com/illinois-tool-works-intrinsic-value"
  }
};

/* ═══════════════════════════════════════════════════════════════
   DATA FETCHING & PARSING
   ═══════════════════════════════════════════════════════════════ */

async function fetchHtml(url) {
  try {
    const response = await fetch(url, {
      headers: {
        'User-Agent': 'Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36'
      }
    });
    if (!response.ok) return null;
    return await response.text();
  } catch (e) {
    return null;
  }
}

const htmlFin = await fetchHtml('https://stockanalysis.com/stocks/itw/financials/');
const htmlCf = await fetchHtml('https://stockanalysis.com/stocks/itw/financials/cash-flow-statement/');
const htmlBs = await fetchHtml('https://stockanalysis.com/stocks/itw/financials/balance-sheet/');

function extractRow(html, headerTitle) {
  if (!html) return null;
  const $ = cheerio.load(html);
  let result = null;
  $('table tbody tr').each((i, el) => {
    const firstTd = $(el).find('td').first().text().trim();
    if (firstTd === headerTitle) {
      result = [];
      $(el).find('td').each((j, td) => {
        if (j > 0) result.push($(td).text().trim());
      });
      return false;
    }
  });
  return result;
}

function parseVal(str) {
  if (!str || str === '-' || str === 'N/A') return null;
  return parseFloat(str.replace(/,/g, ''));
}

let currentPrice = null;
if (htmlFin) {
  const match = htmlFin.match(/<div class="[^"]*text-4xl[^"]*"[^>]*>([\d\.,]+)<\/div>/);
  if (match) currentPrice = parseFloat(match[1].replace(/,/g, ''));
}

const yearsRaw = [];
if (htmlFin) {
  const $ = cheerio.load(htmlFin);
  $('table thead tr th').each((i, th) => {
    if (i > 0) {
      const text = $(th).text().trim();
      const yearMatch = text.match(/\b(20\d{2})\b/);
      if (yearMatch) yearsRaw.push(parseInt(yearMatch[1]));
    }
  });
}

const revData = extractRow(htmlFin, 'Revenue');
const epsData = extractRow(htmlFin, 'EPS (Diluted)');
const sharesData = extractRow(htmlFin, 'Shares Outstanding (Diluted)');
const opMarginData = extractRow(htmlFin, 'Operating Margin');
const profitMarginData = extractRow(htmlFin, 'Profit Margin');

const fcfData = extractRow(htmlCf, 'Free Cash Flow');

const cashData = extractRow(htmlBs, 'Cash & Equivalents');
const totalDebtData = extractRow(htmlBs, 'Total Debt');

const numCols = revData ? revData.length : 0;
const years = yearsRaw.slice(0, numCols);

// Safe mapping arrays
const revenueHistory = years.map((y, i) => ({ year: y, value: revData ? parseVal(revData[i]) : null }));
const fcfHistory = years.map((y, i) => ({ year: y, value: fcfData ? parseVal(fcfData[i]) : null }));
const epsHistory = years.map((y, i) => ({ year: y, value: epsData ? parseVal(epsData[i]) : null }));

const marginHistory = years.map((y, i) => {
  const rev = revData ? parseVal(revData[i]) : null;
  const fcf = fcfData ? parseVal(fcfData[i]) : null;
  let fcfMargin = null;
  if (rev !== null && fcf !== null && rev > 0) {
      fcfMargin = ((fcf / rev) * 100).toFixed(2);
  }
  return {
    year: y,
    operating: opMarginData ? parseFloat(opMarginData[i].replace('%', '')) : null,
    profit: profitMarginData ? parseFloat(profitMarginData[i].replace('%', '')) : null,
    fcfMargin: fcfMargin !== null ? parseFloat(fcfMargin) : null,
  };
});

/* ═══════════════════════════════════════════════════════════════
   DCF MODEL — ALL INPUTS AND CALCULATIONS
   ═══════════════════════════════════════════════════════════════ */

// --- INPUTS ---
// FY2025 Data (Most recent year, index 0)
const fcf2025 = fcfData ? parseVal(fcfData[0]) : null; // Millions
const sharesOutstanding = sharesData ? parseVal(sharesData[0]) : null; // Millions
const cashAndInvestments = cashData ? parseVal(cashData[0]) : null; // Millions
const totalDebt = totalDebtData ? parseVal(totalDebtData[0]) : null; // Millions

// Derived
let netCash = null;
if (cashAndInvestments !== null && totalDebt !== null) {
  netCash = cashAndInvestments - totalDebt;
}

// Check for nulls to prevent crashes
const hasRequiredData = fcf2025 !== null && sharesOutstanding !== null && netCash !== null && currentPrice !== null;

// --- ASSUMPTIONS ---
const growthRatePhase1 = 0.05;         // 5% FCF growth, Years 1-5. ITW is a mature, cyclical industrial.
const growthRateTerminal = 0.025;      // 2.5% perpetuity growth. Matches long-term inflation/GDP.
const discountRate = 0.085;            // 8.5% WACC. 4.18% Treasury + standard risk premium.

// --- PHASE 1: PROJECT FCF FOR YEARS 1-5 ---
const projectedFCF = [];
let fcf = fcf2025 || 0;
let pvPhase1 = 0;
for (let yr = 1; yr <= 5; yr++) {
  fcf = fcf * (1 + growthRatePhase1);
  const pvFactor = 1 / Math.pow(1 + discountRate, yr);
  const pvFCF = fcf * pvFactor;
  projectedFCF.push({ year: yr, fcf: Math.round(fcf), pvFactor, pvFCF: Math.round(pvFCF) });
  pvPhase1 += pvFCF;
}
pvPhase1 = Math.round(pvPhase1);

// --- PHASE 2: TERMINAL VALUE ---
const fcfYear6 = (projectedFCF.length > 0) ? (projectedFCF[4].fcf * (1 + growthRateTerminal)) : 0;
const terminalValue = (discountRate - growthRateTerminal) > 0 ? fcfYear6 / (discountRate - growthRateTerminal) : 0;
const pvTerminalValue = (projectedFCF.length > 0) ? Math.round(terminalValue * projectedFCF[4].pvFactor) : 0;

// --- ENTERPRISE VALUE & EQUITY VALUE ---
const enterpriseValue = pvPhase1 + pvTerminalValue;
const equityValue = hasRequiredData ? enterpriseValue + netCash : 0;
const intrinsicValuePerShare = hasRequiredData ? equityValue / sharesOutstanding : 0;
const roundedIV = Math.round(intrinsicValuePerShare * 100) / 100;

// Market comparison
let marginOfSafety = "N/A";
let verdictText = "N/A";
let verdictColor = "#5a6a80";

if (hasRequiredData) {
    marginOfSafety = ((roundedIV - currentPrice) / currentPrice * 100).toFixed(1);
    verdictText = roundedIV > currentPrice ? "Undervalued" : "Overvalued";
    verdictColor = roundedIV > currentPrice ? "#10b981" : "#ef4444";
}

// Sensitivity analysis
const sensitivityRates = [0.065, 0.075, 0.085, 0.095, 0.105];
const sensitivityGrowth = [0.01, 0.03, 0.05, 0.07, 0.09];
const sensitivityTable = sensitivityRates.map(dr => {
  return {
    dr,
    values: sensitivityGrowth.map(gr => {
      if (!hasRequiredData) return "N/A";
      let f = fcf2025;
      let pvSum = 0;
      for (let y = 1; y <= 5; y++) {
        f = f * (1 + gr);
        pvSum += f / Math.pow(1 + dr, y);
      }
      const f6 = f * (1 + growthRateTerminal);
      const tv = f6 / (dr - growthRateTerminal);
      const pvTV = tv / Math.pow(1 + dr, 5);
      return Math.round((pvSum + pvTV + netCash) / sharesOutstanding);
    })
  };
});

// Reversing arrays for charts (oldest to newest)
const revChart = [...revenueHistory].reverse();
const fcfChart = [...fcfHistory].reverse();
const epsChart = [...epsHistory].reverse();
const maxRev = revChart.length > 0 ? Math.max(...revChart.map(r => r.value || 0)) : 1;
const maxFcf = fcfChart.length > 0 ? Math.max(...fcfChart.map(r => r.value || 0)) : 1;
const maxEps = epsChart.length > 0 ? Math.max(...epsChart.map(r => r.value || 0)) : 1;

