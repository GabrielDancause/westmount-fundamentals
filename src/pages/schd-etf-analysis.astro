  <script is:inline src="https://cdn.jsdelivr.net/npm/chart.js"></script>
  <script is:inline>
    // Calculator
    (function() {
      var typeEl = document.getElementById('calcType');
      var inputEl = document.getElementById('calcInput');
      var labelEl = document.getElementById('calcInputLabel');
      var growthEl = document.getElementById('calcGrowth');
      var btnEl = document.getElementById('calcBtn');
      var price = 27.10;
      var currentYield = 0.034;

      typeEl.addEventListener('change', function() {
        if (typeEl.value === 'shares') {
          labelEl.textContent = 'Number of Shares';
          inputEl.value = '1000';
        } else {
          labelEl.textContent = 'Amount Invested ($)';
          inputEl.value = '10000';
        }
        calculate();
      });

      function calculate() {
        var val = parseFloat(inputEl.value) || 0;
        var growth = parseFloat(growthEl.value) / 100 || 0.11;
        var shares, costBasis;
        if (typeEl.value === 'shares') {
          shares = val;
          costBasis = val * price;
        } else {
          shares = val / price;
          costBasis = val;
        }
        var annualDiv = shares * price * currentYield;
        var monthlyDiv = annualDiv / 12;
        var yoc5 = currentYield * Math.pow(1 + growth, 5) * 100;
        var yoc10 = currentYield * Math.pow(1 + growth, 10) * 100;

        document.getElementById('crAnnual').textContent = '$' + annualDiv.toFixed(0).replace(/\B(?=(\d{3})+(?!\d))/g, ',');
        document.getElementById('crMonthly').textContent = '$' + monthlyDiv.toFixed(2).replace(/\B(?=(\d{3})+(?!\d))/g, ',');
        document.getElementById('crYield5').textContent = yoc5.toFixed(1) + '%';
        document.getElementById('crYield10').textContent = yoc10.toFixed(1) + '%';
      }

      btnEl.addEventListener('click', calculate);
      calculate();
    })();

    // Growth Chart: $10K in SCHD since 2011
    (function() {
      var years = ['2011','2012','2013','2014','2015','2016','2017','2018','2019','2020','2021','2022','2023','2024','2025'];
      var annualReturns = [0, 0.115, 0.303, 0.132, -0.003, 0.163, 0.217, -0.056, 0.273, 0.139, 0.292, -0.032, 0.054, 0.120, -0.03];
      var values = [10000];
      for (var i = 1; i < annualReturns.length; i++) {
        values.push(Math.round(values[i-1] * (1 + annualReturns[i])));
      }
      var ctx = document.getElementById('growthChart').getContext('2d');
      new Chart(ctx, {
        type: 'line',
        data: {
          labels: years,
          datasets: [{
            label: 'Portfolio Value ($)',
            data: values,
            borderColor: '#4a8fe7',
            backgroundColor: 'rgba(74,143,231,0.1)',
            fill: true,
            tension: 0.3,
            pointBackgroundColor: '#4a8fe7',
            pointRadius: 4
          }]
        },
        options: {
          responsive: true,
          plugins: {
            legend: { labels: { color: '#9aa0a6' } },
            tooltip: {
              callbacks: {
                label: function(ctx2) {
                  return '$' + ctx2.parsed.y.toLocaleString();
                }
              }
            }
          },
          scales: {
            x: { ticks: { color: '#9aa0a6' }, grid: { color: 'rgba(255,255,255,0.05)' } },
            y: {
              ticks: {
                color: '#9aa0a6',
                callback: function(v) { return '$' + (v/1000).toFixed(0) + 'K'; }
              },
              grid: { color: 'rgba(255,255,255,0.05)' }
            }
          }
        }
      });
    })();

    // Annual Returns Bar Chart
    (function() {
      var labels = ['2012','2013','2014','2015','2016','2017','2018','2019','2020','2021','2022','2023','2024','2025 YTD'];
      var data = [11.5, 30.3, 13.2, -0.3, 16.3, 21.7, -5.6, 27.3, 13.9, 29.2, -3.2, 5.4, 12.0, -3.0];
