---
import SiteLayout from "../layouts/SiteLayout.astro";

// --- METADATA ---
export const meta = {
  title: "Apple Inc. (AAPL) Intrinsic Value",
  description: "An independent discounted cash flow (DCF) intrinsic value analysis of Apple Inc (AAPL) compiled entirely by Gemini 3.1.",
  category: "study",
  published: "2026-03-18",
};

// --- DATA & ASSUMPTIONS (FY2025 Actuals) ---
// FCF Growth (Y1-Y5): 8.5%. Services segment continues to grow reliably at double digits with high margins, offsetting slower iPhone upgrade cycles. Apple Intelligence provides a modest upgrade supercycle over the next 2-3 years.
// Discount Rate (WACC): 8.2%. Apple's cash generation is incredibly reliable. A 4.18% risk-free rate and ~1.05 beta justifies a low WACC, but regulatory scrutiny on the App Store and antitrust concerns justify a slightly higher WACC than a pure monopoly.
// Terminal Growth: 3.0%. Slightly below global GDP growth to reflect the law of large numbers for a $3.5T+ company, but sustained by the stickiness of the ecosystem.

const baseFCF = 123324; // in Millions
const sharesOut = 14865; // in Millions
const currentPrice = 252.38;
const netCash = -23602; // Cash & ST investments - Total Debt

const fcfGrowthRate = 0.085;
const discountRate = 0.082;
const terminalGrowthRate = 0.030;

// --- YEAR 1 TO 5 PROJECTIONS ---
const projections = [];
let prevFCF = baseFCF;

for (let i = 1; i <= 5; i++) {
  const projectedFCF = prevFCF * (1 + fcfGrowthRate);
  const discountFactor = Math.pow(1 + discountRate, i);
  const pvOfFCF = projectedFCF / discountFactor;

  projections.push({
    year: `Year ${i}`,
    fcf: projectedFCF,
    pv: pvOfFCF
  });

  prevFCF = projectedFCF;
}

const sumPvFcf = projections.reduce((sum, p) => sum + p.pv, 0);

// --- TERMINAL VALUE ---
const year5FCF = projections[4].fcf;
const terminalValue = (year5FCF * (1 + terminalGrowthRate)) / (discountRate - terminalGrowthRate);
const pvTerminalValue = terminalValue / Math.pow(1 + discountRate, 5);

// --- INTRINSIC VALUE CALCULATION ---
const enterpriseValue = sumPvFcf + pvTerminalValue;
const totalEquityValue = enterpriseValue + netCash;
const intrinsicValuePerShare = totalEquityValue / sharesOut;

// Value vs Current Price
const marginOfSafety = ((intrinsicValuePerShare - currentPrice) / currentPrice) * 100;
const isUndervalued = intrinsicValuePerShare > currentPrice;

// --- SENSITIVITY MATRIX ---
const sensitivityDiscountRates = [0.072, 0.077, 0.082, 0.087, 0.092];
const sensitivityGrowthRates = [0.020, 0.025, 0.030, 0.035, 0.040];

const sensitivityMatrix = sensitivityGrowthRates.map(g => {
  return {
    growthRate: g,
    values: sensitivityDiscountRates.map(d => {
      // Re-calculate TV and PV with new rates
      const currentTerminalValue = (year5FCF * (1 + g)) / (d - g);
      const currentPvTerminalValue = currentTerminalValue / Math.pow(1 + d, 5);

      // Re-calculate PV of FCFs with new discount rate
      let currentSumPvFcf = 0;
      let tempFcf = baseFCF;
      for (let i = 1; i <= 5; i++) {
        tempFcf = tempFcf * (1 + fcfGrowthRate);
        currentSumPvFcf += tempFcf / Math.pow(1 + d, i);
      }

      const currentEV = currentSumPvFcf + currentPvTerminalValue;
      const currentEquity = currentEV + netCash;
      const currentIV = currentEquity / sharesOut;

      return currentIV;
    })
  };
});

// Formatting helpers
const formatMoney = (val) => new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD', minimumFractionDigits: 2, maximumFractionDigits: 2 }).format(val);
const formatMillions = (val) => '$' + new Intl.NumberFormat('en-US', { maximumFractionDigits: 0 }).format(val) + 'M';
const formatPercent = (val) => (val * 100).toFixed(1) + '%';

// --- SCHEMA ---
const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Article",
      "headline": meta.title,
      "description": meta.description,
      "author": {
        "@type": "Organization",
        "name": "Gemini 3.1"
      },
      "publisher": {
        "@type": "Organization",
        "name": "Westmount Fundamentals",
        "logo": {
          "@type": "ImageObject",
          "url": "https://westmountfundamentals.com/logo.png"
        }
      },
      "mainEntityOfPage": {
        "@type": "WebPage",
        "@id": "https://westmountfundamentals.com/apple-intrinsic-value"
      }
    },
    {
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "Why did Gemini pick an 8.5% growth rate for Apple?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Gemini projects that while hardware sales might see slower upgrade cycles, the high-margin Services segment continues to grow reliably at double digits. Additionally, Apple Intelligence is expected to drive a modest hardware upgrade supercycle over the next 2-3 years, justifying a blended 8.5% free cash flow growth rate."
          }
        },
        {
          "@type": "Question",
          "name": "What discount rate was used for Apple's DCF?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "An 8.2% discount rate was selected. This reflects a 4.18% risk-free rate and Apple's incredibly reliable cash generation, balanced against the increasing regulatory scrutiny on the App Store and broader antitrust concerns."
          }
        }
      ]
    }
  ]
};
---
<SiteLayout site="westmount" title={meta.title} description={meta.description} canonical="https://westmountfundamentals.com/apple-intrinsic-value" schema={schema}>
  <div class="page-content">
    <div class="container">

      <div class="gemini-header">
        <div class="gemini-badge">COMPILED BY GEMINI 3.1</div>
        <h1>Apple Inc. (AAPL) Intrinsic Value</h1>
        <p class="subtitle">An independent two-stage DCF analysis by a frontier AI model.</p>
      </div>

      <div class="verdict-card">
        <div class="verdict-header">
          <h2>Fair Value Estimate</h2>
        </div>
        <div class="verdict-body">
          <div class="verdict-main">
            <span class="iv-value">{formatMoney(intrinsicValuePerShare)}</span>
            <span class="iv-label">per share</span>
          </div>
          <div class="verdict-stats">
            <div class="stat">
              <span class="stat-label">Current Price</span>
              <span class="stat-value">{formatMoney(currentPrice)}</span>
            </div>
            <div class="stat">
              <span class="stat-label">Margin of Safety</span>
              <span class={`stat-value ${isUndervalued ? 'positive' : 'negative'}`}>
                {isUndervalued ? '+' : ''}{marginOfSafety.toFixed(2)}%
              </span>
            </div>
            <div class="stat">
              <span class="stat-label">Verdict</span>
              <span class={`badge ${isUndervalued ? 'positive' : 'negative'}`}>
                {isUndervalued ? 'UNDERVALUED' : 'OVERVALUED'}
              </span>
            </div>
          </div>
        </div>
        <div class="verdict-footer">
          <p>Based on FY2025 actuals. Data via S&P Global (Mar 17, 2026).</p>
        </div>
      </div>

      <section class="content-section">
        <h2>The AI Thesis: The Ecosystem Toll Road</h2>
        <p>Apple's transition from a pure hardware company to a services-oriented ecosystem is largely complete, yet the market still heavily penalizes it for fluctuations in iPhone units sold. <strong>This is a mistake.</strong></p>
        <p>The true value of Apple lies in its installed base of over 2.2 billion active devices. This base functions as an inescapable digital toll road, funneling incredibly high-margin recurring revenue through iCloud, the App Store, Apple Music, and Apple Pay. While hardware growth may be slowing, the monetization of the existing user base continues to compound. My valuation model heavily weights this high-margin Service revenue stream, projecting it will continue to buoy overall Free Cash Flow even amidst cyclical hardware downturns, bolstered in the short-to-medium term by the AI-driven "Apple Intelligence" upgrade cycle.</p>
      </section>

      <section class="content-section">
        <h2>My Assumptions & Rationale</h2>

        <div class="assumption-grid">
          <div class="assumption-card">
            <div class="card-title">FCF Growth Rate (Y1-Y5)</div>
            <div class="card-value">{formatPercent(fcfGrowthRate)}</div>
            <p><strong>Rationale:</strong> An 8.5% growth rate reflects a blended projection. While iPhone upgrade cycles have elongated, Services revenue continues to grow at double digits with gross margins exceeding 70%. Furthermore, the rollout of Apple Intelligence features tied strictly to newer silicon will force a modest, multi-year hardware upgrade supercycle, lifting overall FCF.</p>
          </div>

          <div class="assumption-card">
            <div class="card-title">Discount Rate (WACC)</div>
            <div class="card-value">{formatPercent(discountRate)}</div>
            <p><strong>Rationale:</strong> 8.2% is an appropriately low discount rate for a company that generates over $100B in FCF annually. Given the 10-year treasury at 4.18%, this implies a very low equity risk premium, justified by Apple's unparalleled brand loyalty. However, the rate is not lower due to the tangible risk of regulatory actions forcing changes to App Store fee structures.</p>
          </div>

          <div class="assumption-card">
            <div class="card-title">Terminal Growth Rate</div>
            <div class="card-value">{formatPercent(terminalGrowthRate)}</div>
            <p><strong>Rationale:</strong> 3.0% is a conservative terminal rate. It sits slightly below historical global GDP growth, acknowledging the law of large numbers—it is mathematically difficult for a $3.5T+ enterprise to grow much faster than the economy itself into perpetuity, despite its formidable moat.</p>
          </div>
        </div>
      </section>

      <section class="content-section">
        <h2>Discounted Cash Flow (DCF) Projections</h2>
        <p>Starting with the FY2025 base FCF of {formatMillions(baseFCF)}, the table below outlines the 5-year projection discounted back to Present Value (PV) using the {formatPercent(discountRate)} WACC.</p>

        <div class="table-container">
          <table>
            <thead>
              <tr>
                <th>Period</th>
                <th>Projected FCF</th>
                <th>PV Factor ({formatPercent(discountRate)})</th>
                <th>Present Value</th>
              </tr>
            </thead>
            <tbody>
              {projections.map((p, index) => (
                <tr>
                  <td>{p.year}</td>
                  <td>{formatMillions(p.fcf)}</td>
                  <td>{(1 / Math.pow(1 + discountRate, index + 1)).toFixed(4)}</td>
                  <td>{formatMillions(p.pv)}</td>
                </tr>
              ))}
              <tr class="highlight-row">
                <td colspan="3"><strong>Sum of PV of FCFs (Years 1-5)</strong></td>
                <td><strong>{formatMillions(sumPvFcf)}</strong></td>
              </tr>
            </tbody>
          </table>
        </div>
      </section>

      <section class="content-section">
        <h2>Terminal & Final Valuation Math</h2>
        <p>The Terminal Value accounts for all cash flows from Year 6 into perpetuity, calculated using the Gordon Growth Model.</p>

        <div class="math-card">
          <div class="math-row">
            <span>Year 5 FCF</span>
            <span>{formatMillions(year5FCF)}</span>
          </div>
          <div class="math-row">
            <span>Terminal Value (TV) Calculation</span>
            <span>({formatMillions(year5FCF)} * {1 + terminalGrowthRate}) / ({discountRate} - {terminalGrowthRate})</span>
          </div>
          <div class="math-row">
            <span>Terminal Value</span>
            <span>{formatMillions(terminalValue)}</span>
          </div>
          <div class="math-row highlight">
            <span>PV of Terminal Value</span>
            <span>{formatMillions(pvTerminalValue)}</span>
          </div>
        </div>

        <p style="margin-top: 2rem;">Adding it all together with Net Debt/Cash:</p>

        <div class="math-card">
          <div class="math-row">
            <span>Sum of PV of FCFs (Years 1-5)</span>
            <span>{formatMillions(sumPvFcf)}</span>
          </div>
          <div class="math-row">
            <span>+ PV of Terminal Value</span>
            <span>{formatMillions(pvTerminalValue)}</span>
          </div>
          <div class="math-row">
            <span><strong>= Enterprise Value</strong></span>
            <span><strong>{formatMillions(enterpriseValue)}</strong></span>
          </div>
          <div class="math-row">
            <span>+ Net Cash (Cash - Debt)</span>
            <span>{formatMillions(netCash)}</span>
          </div>
          <div class="math-row highlight">
            <span><strong>= Total Equity Value</strong></span>
            <span><strong>{formatMillions(totalEquityValue)}</strong></span>
          </div>
          <div class="math-row">
            <span>÷ Shares Outstanding</span>
            <span>{sharesOut.toLocaleString()}M</span>
          </div>
          <div class="math-row result">
            <span><strong>Intrinsic Value Per Share</strong></span>
            <span><strong>{formatMoney(intrinsicValuePerShare)}</strong></span>
          </div>
        </div>
      </section>

      <section class="content-section">
        <h2>Sensitivity Matrix</h2>
        <p>A single intrinsic value relies on rigid assumptions. The sensitivity matrix below demonstrates how the intrinsic value changes when we adjust the Discount Rate (WACC) and the Terminal Growth Rate.</p>

        <div class="table-container sensitivity-table">
          <table>
            <thead>
              <tr>
                <th rowspan="2" class="corner-cell">Terminal<br/>Growth</th>
                <th colspan="5" class="header-cell">Discount Rate (WACC)</th>
              </tr>
              <tr>
                {sensitivityDiscountRates.map(d => <th>{formatPercent(d)}</th>)}
              </tr>
            </thead>
            <tbody>
              {sensitivityMatrix.map(row => (
                <tr>
                  <th class="row-header">{formatPercent(row.growthRate)}</th>
                  {row.values.map(val => (
                    <td class={
                      val > currentPrice * 1.15 ? "cell-undervalued" :
                      val < currentPrice * 0.85 ? "cell-overvalued" :
                      "cell-neutral"
                    }>
                      {formatMoney(val)}
                    </td>
                  ))}
                </tr>
              ))}
            </tbody>
          </table>
          <div class="matrix-legend">
            <span class="legend-item"><span class="color-box cell-undervalued"></span> Undervalued (>15% Margin)</span>
            <span class="legend-item"><span class="color-box cell-neutral"></span> Fair Value</span>
            <span class="legend-item"><span class="color-box cell-overvalued"></span> Overvalued (&lt;-15% Margin)</span>
          </div>
        </div>
      </section>

      <section class="content-section risks-section">
        <h2>Risks & Bear Case</h2>
        <p>While my valuation leans moderately bullish, several structural risks could materially impact Apple's intrinsic value trajectory:</p>
        <div class="risk-grid">
          <div class="risk-card">
            <h3>1. Geopolitical Supply Chain Risk</h3>
            <p>Despite diversification efforts into India and Vietnam, Apple's manufacturing base and a significant portion of its end-market revenue remain deeply tied to China. Escalating trade tensions or tariffs could severely compress gross margins.</p>
          </div>
          <div class="risk-card">
            <h3>2. App Store Antitrust Regulation</h3>
            <p>Regulators in the EU and the US are actively challenging the 30% App Store "tax" and the restriction of third-party payment systems. A forced dismantling of this walled garden would directly impact Apple's highest-margin Services revenue.</p>
          </div>
          <div class="risk-card">
            <h3>3. The Search Engine Deal</h3>
            <p>The DOJ's antitrust case against Google threatens the $20B+ annual payment Apple receives for making Google the default search engine on iOS. Losing this pure-profit revenue stream would instantly impair Free Cash Flow.</p>
          </div>
        </div>
      </section>

      <section class="content-section faq-section">
        <h2>Frequently Asked Questions</h2>

        <div class="faq-item">
          <h3>Why did Gemini pick an 8.5% growth rate for Apple?</h3>
          <p>Gemini projects that while hardware sales might see slower upgrade cycles, the high-margin Services segment continues to grow reliably at double digits. Additionally, Apple Intelligence is expected to drive a modest hardware upgrade supercycle over the next 2-3 years, justifying a blended 8.5% free cash flow growth rate.</p>
        </div>

        <div class="faq-item">
          <h3>What discount rate was used for Apple's DCF?</h3>
          <p>An 8.2% discount rate was selected. This reflects a 4.18% risk-free rate and Apple's incredibly reliable cash generation, balanced against the increasing regulatory scrutiny on the App Store and broader antitrust concerns.</p>
        </div>

        <div class="faq-item">
          <h3>Is it safe to rely on AI for stock valuation?</h3>
          <p>No. This analysis is a demonstration of AI reasoning based on a specific set of inputs and rigid formulas. It is not financial advice. AI models cannot predict regulatory actions, geopolitical shifts, or black swan economic events.</p>
        </div>
      </section>

      <div class="disclaimer-box">
        <p><strong>Disclaimer:</strong> The numbers presented on this page are for educational and entertainment purposes only. They are the result of a deterministic mathematical model fed with assumptions generated by an Artificial Intelligence (Gemini 3.1). This does not constitute investment advice. Always conduct your own due diligence before investing in the stock market.</p>
      </div>

    </div>
  </div>
</SiteLayout>
