---
import SiteLayout from "../../layouts/SiteLayout.astro";
import { sites } from "../../config/sites";

const SITE_ID = 'westmount';
const siteConfig = sites[SITE_ID];

const allPages = import.meta.glob('../*.astro', { eager: true });

interface PageEntry {
  slug: string;
  title: string;
  description: string;
  category: string;
}

const guides: PageEntry[] = Object.entries(allPages)
  .filter(([path]) => !path.includes('index') && !path.includes('['))
  .map(([path, mod]: [string, any]) => ({
    slug: path.replace('../', '').replace('.astro', ''),
    title: mod.meta?.title || path.replace('../', '').replace('.astro', '').replace(/-/g, ' '),
    description: mod.meta?.description || '',
    category: mod.meta?.category || 'tool',
  }))
  .filter(p => p.category === 'guide')
  .sort((a, b) => a.title.localeCompare(b.title));

function getEmoji(slug: string): string {
  if (slug.includes('dividend') || slug.includes('yield')) return '💰';
  if (slug.includes('etf') || slug.includes('index-fund')) return '📈';
  if (slug.includes('tax') || slug.includes('rrsp') || slug.includes('ira')) return '🏛️';
  if (slug.includes('retirement') || slug.includes('fire')) return '🏖️';
  if (slug.includes('option')) return '⚡';
  if (slug.includes('stock') || slug.includes('market')) return '📊';
  if (slug.includes('bond')) return '🔐';
  if (slug.includes('portfolio') || slug.includes('allocation')) return '🎯';
  if (slug.includes('what-is') || slug.includes('what-are')) return '❓';
  if (slug.includes('how-to') || slug.includes('how-do')) return '🗺️';
  return '📖';
}

function truncate(text: string, max: number): string {
  if (!text || text.length <= max) return text || '';
  return text.slice(0, max).replace(/\s+\S*$/, '') + '…';
}

const schema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": "Investing Guides & Explainers",
  "description": `${guides.length} free investing guides covering stocks, ETFs, bonds, and more.`,
  "url": `https://${siteConfig.domain}/guides/`,
  "isPartOf": { "@type": "WebSite", "name": siteConfig.name, "url": `https://${siteConfig.domain}/` }
});
---

<SiteLayout
  site={SITE_ID}
  title={`Investing Guides & Explainers — ${siteConfig.name}`}
  description={`${guides.length} free investing guides. Learn about stocks, ETFs, dividends, bonds, portfolio strategies, and more.`}
  canonical={`https://${siteConfig.domain}/guides/`}
  schema={schema}
>
  <div class="hero">
    <div class="hero-content">
      <span class="hero-tag">📖 GUIDES</span>
      <h1>Investing Guides & Explainers</h1>
      <p>{guides.length} clear, jargon-free explanations of investing concepts.</p>
      <div class="search-box">
        <svg class="search-icon" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" /></svg>
        <input type="text" id="searchInput" placeholder={`Search ${guides.length} guides…`} autocomplete="off" />
      </div>
    </div>
  </div>

  <div class="page-container">
    <div class="results-count" id="resultsCount">{guides.length} guides</div>
    <div class="guides-grid" id="guidesGrid">
      {guides.map(page => (
        <a class="guide-card" href={`/${page.slug}`} data-title={page.title.toLowerCase()} data-desc={page.description.toLowerCase()}>
          <span class="guide-emoji">{getEmoji(page.slug)}</span>
          <h2 class="guide-name">{page.title}</h2>
          <p class="guide-desc">{truncate(page.description, 130)}</p>
        </a>
      ))}
    </div>
    <div class="no-results" id="noResults">No guides found matching your search.</div>
  </div>

  <script is:inline>
    document.addEventListener('DOMContentLoaded', () => {
      const input = document.getElementById('searchInput');
      const grid = document.getElementById('guidesGrid');
      const cards = grid.querySelectorAll('.guide-card');
      const count = document.getElementById('resultsCount');
      const noResults = document.getElementById('noResults');

      input.addEventListener('input', () => {
        const q = input.value.toLowerCase().trim();
        let visible = 0;
        cards.forEach(card => {
          const match = !q || card.dataset.title.includes(q) || card.dataset.desc.includes(q);
          card.style.display = match ? '' : 'none';
          if (match) visible++;
        });
        count.textContent = `${visible} guide${visible !== 1 ? 's' : ''}`;
        noResults.style.display = visible === 0 ? 'block' : 'none';
      });
    });
  </script>

  <style is:inline>
    .hero { text-align: center; padding: 4rem 1.5rem 2.5rem; }
    .hero-tag { display: inline-block; background: color-mix(in srgb, var(--accent-color) 10%, transparent); color: var(--accent-color); font-size: .7rem; font-weight: 800; padding: 6px 16px; border-radius: 20px; letter-spacing: 1px; margin-bottom: 1rem; }
    .hero h1 { font-size: 2.2rem; font-weight: 800; margin-bottom: 0.5rem; }
    .hero p { color: var(--text-secondary); font-size: 1.05rem; margin-bottom: 1.5rem; }

    .search-box { max-width: 420px; margin: 0 auto; position: relative; }
    .search-icon { position: absolute; left: 14px; top: 50%; transform: translateY(-50%); width: 18px; height: 18px; color: var(--text-secondary); }
    .search-box input { width: 100%; padding: 12px 16px 12px 42px; border: 1px solid var(--border-color); border-radius: 10px; font-size: 0.95rem; background: var(--card-bg); color: var(--text-primary); outline: none; box-sizing: border-box; }
    .search-box input:focus { border-color: var(--accent-color); }

    .page-container { max-width: 1100px; margin: 0 auto 3rem; padding: 0 1.5rem; }
    .results-count { font-size: 0.85rem; color: var(--text-secondary); margin-bottom: 1rem; }

    .guides-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 1rem; }
    .guide-card { display: block; background: var(--card-bg); border: 1px solid var(--border-color); border-radius: 12px; padding: 1.25rem; text-decoration: none; color: inherit; transition: border-color 0.2s, transform 0.2s; }
    .guide-card:hover { border-color: var(--accent-color); transform: translateY(-2px); }
    .guide-emoji { font-size: 1.5rem; display: block; margin-bottom: 0.5rem; }
    .guide-name { font-size: 1rem; font-weight: 700; margin: 0 0 0.35rem; line-height: 1.3; }
    .guide-desc { font-size: 0.85rem; color: var(--text-secondary); line-height: 1.4; margin: 0; }

    .no-results { display: none; text-align: center; color: var(--text-secondary); padding: 3rem 0; font-size: 1rem; }

    @media (max-width: 640px) {
      .hero h1 { font-size: 1.6rem; }
      .guides-grid { grid-template-columns: 1fr; }
    }
  </style>
</SiteLayout>
