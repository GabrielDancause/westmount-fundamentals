---
import SiteLayout from "../layouts/SiteLayout.astro";

const schema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": "Price-to-Book Ratio Rankings by Sector 2026",
  "description": "Analyze price-to-book (P/B) ratios across S&P 500 sectors. Discover deep value stocks with P/B below 1, sector medians, and outliers.",
  "author": {
    "@type": "Organization",
    "name": "Westmount Fundamentals"
  },
  "datePublished": "2026-03-09"
};

export const meta = {
  title: "Price-to-Book Ratio Rankings by Sector 2026",
  description: "Some S&P 500 stocks trade below the value of their own assets. We mapped P/B ratios across every sector to find the deepest value.",
  category: "guide",
  published: "2026-03-15",
};
---

<SiteLayout
  site="westmount"
  title="Price-to-Book Ratio Rankings by Sector 2026"
  description="Some S&P 500 stocks trade below the value of their own assets. We mapped P/B ratios across every sector to find the deepest value."
  canonical="https://westmountfundamentals.com/price-to-book" schema={schema}
