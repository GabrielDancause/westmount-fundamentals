MG", "category": "Thematic", "index": "ISE Cyber Security", "expenseRatio": 0.6, "aumB": 1.8, "dividendYield": 0.3, "inceptionYear": 2014, "avgVolume": null, "ytdReturn": null}, {"ticker": "EEM", "name": "iShares MSCI Emerging Markets ETF", "issuer": "iShares", "category": "International", "index": "MSCI Emerging Markets", "expenseRatio": 0.68, "aumB": 18, "dividendYield": 2.3, "inceptionYear": 2003, "avgVolume": null, "ytdReturn": null}, {"ticker": "ARKK", "name": "ARK Innovation ETF", "issuer": "ARK Invest", "category": "Thematic", "index": "Actively Managed", "expenseRatio": 0.75, "aumB": 5, "dividendYield": null, "inceptionYear": 2014, "avgVolume": null, "ytdReturn": null}]};
const etfs = DATA.results;

// Stats
const ers = etfs.map(e=>e.expenseRatio).filter(v=>v!=null);
const avgER = (ers.reduce((a,b)=>a+b,0)/ers.length);
const medER = ers.sort((a,b)=>a-b)[Math.floor(ers.length/2)];
const totalAUM = etfs.reduce((a,e)=>a+(e.aumB||0),0);
const cheapest = etfs[0];

document.getElementById('stats').innerHTML = `
  <div class="stat"><div class="val">${DATA.totalEtfs}</div><div class="label">ETFs Compared</div></div>
  <div class="stat"><div class="val">${avgER.toFixed(3)}%</div><div class="label">Average Expense Ratio</div></div>
  <div class="stat"><div class="val">${medER.toFixed(2)}%</div><div class="label">Median Expense Ratio</div></div>
  <div class="stat"><div class="val">$${totalAUM.toFixed(0)}B</div><div class="label">Total AUM Covered</div></div>
  <div class="stat"><div class="val">${cheapest.ticker}</div><div class="label">Cheapest ETF (${cheapest.expenseRatio}%)</div></div>
`;

// Chart — top 30 by expense ratio (sorted cheapest first, show variety)
const chartData = etfs.filter(e=>e.expenseRatio!=null).slice(0,30);
const maxER = Math.max(...chartData.map(e=>e.expenseRatio));
const chartEl = document.getElementById('chart');
chartData.forEach(e=>{
  const pct = (e.expenseRatio/maxER)*100;
  const color = e.expenseRatio <= 0.05 ? '#22c55e' : e.expenseRatio <= 0.20 ? 'var(--accent-color)' : e.expenseRatio <= 0.40 ? '#eab308' : '#ef4444';
  chartEl.innerHTML += `<div class="bar-row"><span class="bar-label">${e.ticker}</span><div class="bar" style="width:${Math.max(pct,3)}%;background:${color}">${e.expenseRatio}%</div><span class="bar-name">${e.name}</span></div>`;
});

// Issuer comparison
const issuerMap = {};
etfs.forEach(e=>{
  if(!issuerMap[e.issuer]) issuerMap[e.issuer]={sum:0,count:0,minER:Infinity,aum:0};
  const im = issuerMap[e.issuer];
  if(e.expenseRatio!=null){im.sum+=e.expenseRatio;im.count++;}
  if(e.expenseRatio!=null && e.expenseRatio<im.minER) im.minER=e.expenseRatio;
  im.aum+=(e.aumB||0);
});
const issuers = Object.entries(issuerMap).sort((a,b)=>(a[1].sum/a[1].count)-(b[1].sum/b[1].count));
const issuerEl = document.getElementById('issuers');
issuers.forEach(([name,d])=>{
  const avg = d.count?d.sum/d.count:0;
  const color = avg <= 0.06 ? '#22c55e' : avg <= 0.20 ? 'var(--accent-color)' : avg <= 0.40 ? '#eab308' : '#ef4444';
  issuerEl.innerHTML += `<div class="issuer-card"><h3>${name}</h3><div class="avg" style="color:${color}">${avg.toFixed(3)}%</div><div class="detail">${d.count} ETFs · Cheapest: ${d.minER.toFixed(2)}% · $${d.aum.toFixed(0)}B AUM</div></div>`;
});

// Findings
const findingsData = [
  {title:"Vanguard and Schwab dominate the low-cost space", text:"Schwab's average expense ratio of 0.046% edges out Vanguard's 0.055%. Both providers have driven the industry fee war, with their cheapest funds at just 0.02-0.03%. For broad-market exposure, there's virtually no reason to pay more than 0.05%."},
  {title:"SPY is the most expensive S&P 500 ETF", text:"Despite being the most traded ETF in the world with $590B in AUM, SPY charges 0.0945% — more than 3x what VOO (0.03%) and nearly 5x what SPLG (0.02%) charge. Legacy structure and trust status prevent fee cuts, costing long-term investors thousands."},
  {title:"Actively managed ETFs charge 5-25x more than passive index funds", text:"ARKK (0.75%), JEPI (0.35%), and JEPQ (0.35%) show the premium for active management. Passive S&P 500 funds at 0.02-0.03% offer identical market exposure at a fraction of the cost. The fee gap narrows only for niche strategies."},
  {title:"Commodity ETFs are consistently the most expensive category", text:"Gold (GLD: 0.40%), silver (SLV: 0.50%), and oil (USO: 0.60%) ETFs carry higher expense ratios due to physical storage and futures contract rolling costs. GLDM at 0.10% is the notable exception for gold exposure."},
  {title:"The median ETF now costs just 0.09%", text:"Across 86 major ETFs, the median expense ratio has fallen to 0.09%. A decade ago, 0.20% was considered cheap. The fee compression has saved investors billions and shows no signs of reversing."}
];
const findingsEl = document.getElementById('findings');
findingsData.forEach(f=>{
  findingsEl.innerHTML += `<div class="finding-card"><h3>${f.title}</h3><p>${f.text}</p></div>`;
});

// Table
const tbody = document.getElementById('tbody');
const searchEl = document.getElementById('search');
const catFilter = document.getElementById('catFilter');
const issuerFilterEl = document.getElementById('issuerFilter');

// Populate issuer filter
const uniqueIssuers = [...new Set(etfs.map(e=>e.issuer))].sort();
uniqueIssuers.forEach(i=>{issuerFilterEl.innerHTML+=`<option value="${i}">${i}</option>`});

let sortKey = 'expenseRatio', sortDir = 1;

function erClass(er){
  if(er==null) return '';
  if(er<=0.05) return 'er-low';
  if(er<=0.20) return 'er-mid';
  return 'er-high';
}

function renderTable(){
  const q = searchEl.value.toLowerCase();
  const cat = catFilter.value;
  const iss = issuerFilterEl.value;
  let filtered = etfs.filter(e=>{
    if(q && !e.ticker.toLowerCase().includes(q) && !e.name.toLowerCase().includes(q)) return false;
    if(cat && e.category!==cat) return false;
    if(iss && e.issuer!==iss) return false;
    return true;
  });
  filtered.sort((a,b)=>{
    let va=a[sortKey], vb=b[sortKey];
    if(va==null) return 1; if(vb==null) return -1;
    if(typeof va==='string') return va.localeCompare(vb)*sortDir;
    return (va-vb)*sortDir;
  });
  tbody.innerHTML = filtered.map(e=>`<tr>
    <td class="ticker">${e.ticker}</td>
    <td>${e.name}</td>
    <td>${e.issuer}</td>
    <td class="num ${erClass(e.expenseRatio)}">${e.expenseRatio!=null?e.expenseRatio.toFixed(e.expenseRatio<0.1?4:2)+'%':'—'}</td>
    <td class="num">${e.aumB!=null?'$'+e.aumB.toFixed(1):'—'}</td>
    <td>${e.category}</td>
    <td class="num">${e.dividendYield!=null?e.dividendYield.toFixed(1)+'%':'—'}</td>
    <td style="font-size:12px;color:var(--text-secondary);max-width:200px;overflow:hidden;text-overflow:ellipsis">${e.index||'—'}</td>
    <td class="num">${e.inceptionYear||'—'}</td>
  </tr>`).join('');
}

// Sort headers
document.querySelectorAll('th[data-key]').forEach(th=>{
  th.addEventListener('click',()=>{
    const key = th.dataset.key;
    if(sortKey===key) sortDir*=-1; else {sortKey=key;sortDir=1;}
    document.querySelectorAll('th').forEach(t=>t.classList.remove('sorted-asc','sorted-desc'));
    th.classList.add(sortDir===1?'sorted-asc':'sorted-desc');
    renderTable();
  });
});

searchEl.addEventListener('input', renderTable);
catFilter.addEventListener('change', renderTable);
issuerFilterEl.addEventListener('change', renderTable);

// FAQ
const faqData = [
  {q:"What is the cheapest S&P 500 ETF?",a:"SPLG (SPDR Portfolio S&P 500 ETF) is the cheapest S&P 500 ETF with an expense ratio of just 0.02%. VOO and IVV are tied at 0.03%. SPY, the original and most liquid S&P 500 ETF, charges 0.0945% — nearly 5x more than SPLG. For buy-and-hold investors, the cheaper options deliver virtually identical performance with lower drag."},
  {q:"Does expense ratio really matter?",a:"Yes, significantly. On a $100,000 portfolio growing at 7% annually over 30 years, a 0.03% expense ratio costs ~$2,800 total, while a 0.50% ratio costs ~$17,000 — a difference of $14,200. For passive index funds tracking the same benchmark, a lower expense ratio directly translates to higher net returns. It's one of the few variables investors can fully control."},
  {q:"VOO vs SPY: which is better?",a:"Both track the S&P 500 identically. VOO charges 0.03% vs SPY's 0.0945%, saving ~$65/year per $100,000 invested. SPY has tighter bid-ask spreads and higher daily volume, making it preferred by active traders and institutions. For long-term investors holding for years, VOO (or even cheaper SPLG at 0.02%) is the better choice. SPY's trust structure prevents it from lowering fees or lending securities."},
  {q:"What is the average ETF expense ratio?",a:"Across our index of 86 major ETFs, the average expense ratio is 0.164% and the median is 0.09%. Broad-market index funds average 0.03-0.05%, sector ETFs around 0.09%, international funds 0.05-0.32%, and thematic/actively managed ETFs 0.35-0.75%. The industry trend is strongly toward lower fees, with multiple fund families now offering core products below 0.05%."},
  {q:"Which ETF provider has the lowest fees?",a:"Schwab leads with an average expense ratio of 0.046% across 8 ETFs, followed closely by Vanguard at 0.055% across 17 ETFs. SPDR's Portfolio line (SPLG, SPTM, SPYG, SPYV) is extremely competitive at 0.02-0.04%, though their legacy products like SPY (0.0945%) and GLD (0.40%) bring up the average. iShares Core series funds are also competitive at 0.03-0.09%."},
  {q:"What is a good expense ratio for an ETF?",a:"For broad-market index ETFs (S&P 500, total stock market, total bond), a good expense ratio in 2026 is 0.03-0.05%. For international funds, 0.05-0.10% is reasonable. For sector ETFs, 0.09-0.12% is standard. For thematic or actively managed ETFs, 0.15-0.40% is typical. As a general rule: if you're paying more than 0.10% for a core US index fund, you're likely overpaying — cheaper alternatives almost certainly exist."},
  {q:"What is considered a high expense ratio?",a:"Any broad-market ETF charging above 0.20% is high by 2026 standards. For context, VOO charges 0.03% and tracks the S&P 500. An expense ratio above 0.50% is high for any ETF category except niche commodities or highly specialized active strategies. Even among thematic ETFs, the average is about 0.40%. The only ETFs in our index above 0.60% are USO (0.60% for oil futures), EEM (0.68% — use the cheaper IEMG at 0.09%), and ARKK (0.75% for active management)."},
  {q:"How are ETF expense ratios paid?",a:"Expense ratios are not billed to you directly — they are deducted automatically from the fund's net asset value (NAV) on a daily basis. If an ETF has a 0.12% expense ratio, approximately 0.00033% is deducted each day from the fund's total assets. This means the ETF's price already reflects the fee. You will never see a line item on your brokerage statement for expense ratios. The cost is invisible but real: it reduces your total return over time compared to a hypothetical zero-fee fund."},
  {q:"What is the average ETF expense ratio in 2026?",a:"Based on our index of 86 major ETFs, the asset-weighted average expense ratio in 2026 is approximately 0.164%, and the median is 0.09%. However, averages vary dramatically by category: core US index funds average 0.03-0.05%, international funds 0.05-0.32%, bonds 0.03-0.49%, sector funds 0.09-0.12%, thematic ETFs 0.15-0.75%, and commodities 0.10-0.60%. The industry trend continues to push fees lower, especially for passive index products."},
  {q:"SPY expense ratio vs VOO: how much does the difference cost?",a:"SPY charges 0.0945% and VOO charges 0.03% — a gap of 0.0645%. On a $100,000 investment, that's $64.50/year in extra fees for SPY. Over 30 years at 7% annual growth, SPY's higher fee costs approximately $6,000 more than VOO. Both track the identical S&P 500 index. SPY cannot lower its fee due to its legacy unit investment trust structure. For long-term buy-and-hold investors, VOO or SPLG (0.02%) are strictly better choices."}
];
const faqEl = document.getElementById('faq');
faqData.forEach(f=>{
  const div = document.createElement('div');
  div.className='faq-item';
  div.innerHTML=`<div class="faq-q">${f.q}</div><div class="faq-a">${f.a}</div>`;
  div.querySelector('.faq-q').addEventListener('click',()=>div.classList.toggle('open'));
  faqEl.appendChild(div);
});

// Initial render
renderTable();
// Set initial sort indicator
document.querySelector('th[data-key="expenseRatio"]').classList.add('sorted-asc');
  </script>

  
