  <!-- ═══ HISTORICAL CHARTS ═══ -->
  <h2>Financial Track Record</h2>

  <h3>Revenue ($M)</h3>
  <div class="bar-chart">
    {chartRevenue.map(r => (
      <div class="bar-row">
        <div class="bar-label">{r.year}</div>
        <div class="bar-track">
          <div class="bar-fill revenue" style={`width: ${(r.value / Math.max(...chartRevenue.map(d=>d.value))) * 100}%`}>
            ${r.value.toLocaleString()}
          </div>
        </div>
      </div>
    ))}
  </div>

  <h3>Free Cash Flow ($M)</h3>
  <div class="bar-chart">
    {chartFcf.map(r => (
      <div class="bar-row">
        <div class="bar-label">{r.year}</div>
        <div class="bar-track">
          <div class="bar-fill fcf" style={`width: ${(r.value / Math.max(...chartFcf.map(d=>d.value))) * 100}%`}>
