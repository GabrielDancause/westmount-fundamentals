---
export const meta = {
  title: "Republic Services (RSG) Intrinsic Value: A DCF Analysis",
  description: "A transparent, step-by-step discounted cash flow valuation of Republic Services. Using actual financials to arrive at a single fair value estimate for RSG shares.",
  category: "study",
  published: "2026-03-24",
};

import SiteLayout from "../layouts/SiteLayout.astro";
import * as cheerio from 'cheerio';

const schema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": meta.title,
  "description": meta.description,
  "datePublished": meta.published,
  "dateModified": meta.published,
  "author": {
    "@type": "Organization",
    "name": "Westmount Research",
    "url": "https://westmountfundamentals.com"
  },
  "publisher": {
    "@type": "Organization",
    "name": "Westmount Research",
    "url": "https://westmountfundamentals.com"
  },
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": "https://westmountfundamentals.com/republic-services-intrinsic-value"
  }
};

/* ═══════════════════════════════════════════════════════════════
   DATA FETCHING & PARSING
   ═══════════════════════════════════════════════════════════════ */
const headers = {
  'User-Agent': 'Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36'
};

const ticker = 'rsg';
let revenueHistory = [];
let fcfHistory = [];
let epsHistory = [];
let operatingIncomeHistory = [];
let netIncomeHistory = [];
let sharesBasic = null;
let currentPrice = null;
let cashAndEquivalents = null;
let totalDebt = null;

try {
  // 1. Fetch Income Statement
  const isUrl = `https://stockanalysis.com/stocks/${ticker}/financials/`;
  const isRes = await fetch(isUrl, { headers });
  const isHtml = await isRes.text();
  const $is = cheerio.load(isHtml);

  // Extract current price
  const priceMatch = isHtml.match(/<div class="[^"]*text-4xl[^"]*"[^>]*>([\d\.,]+)<\/div>/);
  if (priceMatch) currentPrice = parseFloat(priceMatch[1].replace(/,/g, ''));

  $is('table tbody tr').each((_, row) => {
    const title = $is(row).find('td').first().text().trim();
    if (title === 'Revenue') {
      $is(row).find('td').slice(1).each((i, cell) => {
        const val = $is(cell).text().trim().replace(/,/g, '');
        if (val !== '-') revenueHistory.push(parseFloat(val));
      });
    } else if (title === 'Operating Income') {
      $is(row).find('td').slice(1).each((i, cell) => {
        const val = $is(cell).text().trim().replace(/,/g, '');
        if (val !== '-') operatingIncomeHistory.push(parseFloat(val));
      });
    } else if (title === 'Net Income') {
      $is(row).find('td').slice(1).each((i, cell) => {
        const val = $is(cell).text().trim().replace(/,/g, '');
        if (val !== '-') netIncomeHistory.push(parseFloat(val));
      });
    } else if (title === 'EPS (Diluted)') {
      $is(row).find('td').slice(1).each((i, cell) => {
        const val = $is(cell).text().trim().replace(/,/g, '');
        if (val !== '-') epsHistory.push(parseFloat(val));
      });
    } else if (title === 'Shares Outstanding (Basic)') {
        $is(row).find('td').slice(1).each((i, cell) => {
            if(sharesBasic === null) {
                 const val = $is(cell).text().trim().replace(/,/g, '');
                 if (val !== '-') sharesBasic = parseFloat(val);
            }
        });
    } else if (title === 'Shares Outstanding (Diluted)') {
        if (sharesBasic === null) {
            $is(row).find('td').slice(1).each((i, cell) => {
                if(sharesBasic === null) {
                    const val = $is(cell).text().trim().replace(/,/g, '');
                    if (val !== '-') sharesBasic = parseFloat(val);
                }
            });
        }
    }
  });

  // 2. Fetch Cash Flow Statement
  const cfUrl = `https://stockanalysis.com/stocks/${ticker}/financials/cash-flow-statement/`;
  const cfRes = await fetch(cfUrl, { headers });
  const cfHtml = await cfRes.text();
  const $cf = cheerio.load(cfHtml);

  $cf('table tbody tr').each((_, row) => {
    const title = $cf(row).find('td').first().text().trim();
    if (title === 'Free Cash Flow') {
      $cf(row).find('td').slice(1).each((i, cell) => {
        const val = $cf(cell).text().trim().replace(/,/g, '');
        if (val !== '-') fcfHistory.push(parseFloat(val));
      });
    }
  });

  // 3. Fetch Balance Sheet
  const bsUrl = `https://stockanalysis.com/stocks/${ticker}/financials/balance-sheet/`;
  const bsRes = await fetch(bsUrl, { headers });
  const bsHtml = await bsRes.text();
  const $bs = cheerio.load(bsHtml);

  $bs('table tbody tr').each((_, row) => {
    const title = $bs(row).find('td').first().text().trim();
    if (title === 'Cash & Equivalents') {
      $bs(row).find('td').slice(1).each((i, cell) => {
        if (cashAndEquivalents === null) {
            const val = $bs(cell).text().trim().replace(/,/g, '');
            if (val !== '-') cashAndEquivalents = parseFloat(val);
        }
      });
    } else if (title === 'Total Debt') {
      $bs(row).find('td').slice(1).each((i, cell) => {
        if (totalDebt === null) {
            const val = $bs(cell).text().trim().replace(/,/g, '');
            if (val !== '-') totalDebt = parseFloat(val);
        }
      });
    }
  });
} catch (error) {
  console.error("Error fetching data:", error);
}

// Fallbacks if data fetching fails
if (!revenueHistory.length) revenueHistory = [14967, 13511, 11295, 10153, 10299];
if (!fcfHistory.length) fcfHistory = [1908, 1756, 1494, 1184, 1205];
if (!epsHistory.length) epsHistory = [5.50, 4.69, 4.07, 3.01, 3.32];
if (!operatingIncomeHistory.length) operatingIncomeHistory = [2855, 2378, 2038, 1726, 1757];
if (!netIncomeHistory.length) netIncomeHistory = [1731, 1483, 1289, 967, 1073];
if (sharesBasic === null) sharesBasic = 313;
if (cashAndEquivalents === null) cashAndEquivalents = 135;
if (totalDebt === null) totalDebt = 12613;
if (currentPrice === null) currentPrice = 191.03; // Fallback price

// Format data for charts/tables (taking the most recent 5 years)
const years = [2023, 2022, 2021, 2020, 2019];
const revData = revenueHistory.slice(0, 5).reverse();
const fcfData = fcfHistory.slice(0, 5).reverse();
const epsData = epsHistory.slice(0, 5).reverse();
const opIncData = operatingIncomeHistory.slice(0, 5).reverse();
const netIncData = netIncomeHistory.slice(0, 5).reverse();

const chartRevenue = revData.map((val, i) => ({ year: years[4-i], value: val }));
const chartFcf = fcfData.map((val, i) => ({ year: years[4-i], value: val }));
const chartEps = epsData.map((val, i) => ({ year: years[4-i], value: val }));

const marginHistory = revData.map((rev, i) => {
  const op = opIncData[i];
  const net = netIncData[i];
  const fcf = fcfData[i];
  return {
    year: years[4-i],
    operating: rev ? ((op / rev) * 100).toFixed(1) : "N/A",
    profit: rev ? ((net / rev) * 100).toFixed(1) : "N/A",
    fcfMargin: rev ? ((fcf / rev) * 100).toFixed(1) : "N/A"
  };
});

/* ═══════════════════════════════════════════════════════════════
   DCF MODEL — CALCULATIONS
   ═══════════════════════════════════════════════════════════════ */

const currentFcf = fcfData[fcfData.length - 1]; // TTM or latest year FCF
const netCash = cashAndEquivalents - totalDebt;

// ASSUMPTIONS (Derived strictly)
// Calculate historical FCF CAGR (Year 0 to Year 4)
const fcfCagr = Math.pow(currentFcf / fcfData[0], 1/4) - 1;
// We'll use a slightly moderated growth rate for phase 1
const growthRatePhase1 = Math.max(Math.min(fcfCagr, 0.12), 0.05); // Cap between 5% and 12%

// Terminal Growth Rate
const terminalGrowthRate = 0.03; // 3% for a stable, essential service

// Discount Rate
const treasuryYield = 0.0418; // 10Y Treasury: 4.18%
// Since RSG is a stable, low-beta utility-like company, we apply a moderate equity risk premium
const discountRate = treasuryYield + 0.04; // 8.18%

const projectedFCF = [];
let fcf = currentFcf;
for (let yr = 1; yr <= 5; yr++) {
  fcf = fcf * (1 + growthRatePhase1);
  projectedFCF.push({ year: yr, fcf: Math.round(fcf), pvFactor: 1 / Math.pow(1 + discountRate, yr) });
}
projectedFCF.forEach(p => { p.pvFCF = Math.round(p.fcf * p.pvFactor); });

const fcfYear6 = projectedFCF[4].fcf * (1 + terminalGrowthRate);
const terminalValue = Math.round(fcfYear6 / (discountRate - terminalGrowthRate));
const pvTerminalValue = Math.round(terminalValue * projectedFCF[4].pvFactor);

const pvPhase1 = projectedFCF.reduce((sum, p) => sum + p.pvFCF, 0);
const enterpriseValue = pvPhase1 + pvTerminalValue;

const equityValue = enterpriseValue + netCash;
const intrinsicValuePerShare = equityValue / sharesBasic;
const roundedIV = Math.round(intrinsicValuePerShare * 100) / 100;

const marginOfSafety = (((roundedIV - currentPrice) / currentPrice) * 100).toFixed(1);
const verdictText = roundedIV > currentPrice ? "Undervalued" : "Overvalued";
const verdictColor = roundedIV > currentPrice ? "#10b981" : "#ef4444";

// Sensitivity analysis
const sensitivityRates = [discountRate - 0.02, discountRate - 0.01, discountRate, discountRate + 0.01, discountRate + 0.02];
const sensitivityGrowth = [growthRatePhase1 - 0.04, growthRatePhase1 - 0.02, growthRatePhase1, growthRatePhase1 + 0.02, growthRatePhase1 + 0.04];
const sensitivityTable = sensitivityRates.map(dr => {
  return {
    dr,
    values: sensitivityGrowth.map(gr => {
      let f = currentFcf;
      let pvSum = 0;
      for (let y = 1; y <= 5; y++) {
        f = f * (1 + gr);
        pvSum += f / Math.pow(1 + dr, y);
      }
      const f6 = f * (1 + terminalGrowthRate);
      const tv = f6 / (dr - terminalGrowthRate);
      const pvTV = tv / Math.pow(1 + dr, 5);
      return Math.round((pvSum + pvTV + netCash) / sharesBasic);
    })
  };
});
---

