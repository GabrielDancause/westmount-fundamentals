      "@type": "Organization",
      "name": "Westmount Fundamentals"
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "When is the deadline for RRSP contributions?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "The deadline is usually March 1st, or the last day of February during leap years. This deadline applies for deducting the contribution from the previous year's income."
        }
      },
      {
        "@type": "Question",
        "name": "What happens if I miss the RRSP deadline?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "You can still contribute at any time, but if you miss the first 60 days of the year, the deduction can only be claimed for the current tax year, not the previous one."
        }
      },
      {
        "@type": "Question",
        "name": "Can I claim a contribution made in January for the previous year?",
        "acceptedAnswer": {
