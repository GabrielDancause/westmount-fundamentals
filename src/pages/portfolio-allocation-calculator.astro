  .alloc-pct { font-family: var(--font-mono); font-weight: 700; color: var(--text-secondary); }

  .progress-bar-bg { width: 100%; height: 12px; background-color: color-mix(in srgb, var(--text-secondary) 20%, transparent); border-radius: 6px; overflow: hidden; }
  .progress-bar-fill { height: 100%; border-radius: 6px; transition: width 0.3s ease; }

  /* Fallback colors for bars */
  .fill-stocks { background-color: var(--accent-color, #3b82f6); }
  .fill-bonds { background-color: var(--buy-color, #22c55e); }
