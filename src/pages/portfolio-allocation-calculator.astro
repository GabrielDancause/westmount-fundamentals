  </div>
  <div class="page-content">
    <div class="hero">
      <h1>{page.h1}</h1>
      <p class="subtitle">Visualize your asset distribution and balance your risk.</p>
    </div>

    <div class="calculator-container" id="calculator">
      <div class="calc-grid">
