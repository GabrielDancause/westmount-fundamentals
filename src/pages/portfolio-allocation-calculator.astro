  .error-message { color: var(--sell-color, #ef4444); font-size: 0.9rem; margin-top: 1rem; display: none; }

  .calc-results-panel { background-color: var(--bg-color); border: 1px solid var(--border-color); border-radius: 8px; padding: 1.5rem; display: flex; flex-direction: column; gap: 1.5rem; }
