---
import SiteLayout from "../layouts/SiteLayout.astro";

// --- METADATA ---
export const meta = {
  title: "Google (GOOGL) Intrinsic Value - Gemini's DCF Analysis",
  description: "An independent discounted cash flow (DCF) intrinsic value analysis of Alphabet Inc (GOOGL) compiled entirely by Gemini 3.1.",
  category: "study",
  published: "2026-03-18",
};

// --- DATA & ASSUMPTIONS (FY2025 Actuals) ---
// The prompt requires me to make bold assumptions as Gemini.
// FCF Growth (Y1-Y5): 14%. AI capex is high now, but ROI on cloud and AI search infrastructure will drive massive cash generation soon.
// Discount Rate (WACC): 9.5%. Given the fortress balance sheet, 9.5% perfectly balances the 4.18% risk-free rate, 1.11 beta, and a ~4.8% ERP.
// Terminal Growth: 3.5%. Slightly above standard GDP. AI creates permanent efficiency moats.

const baseFCF = 73266; // in Millions
const sharesOut = 12116; // in Millions
const currentPrice = 310.92;
const netCash = 59847; // Cash & ST investments - Total Debt

const fcfGrowthRate = 0.14;
const discountRate = 0.095;
const terminalGrowthRate = 0.035;

// --- YEAR 1 TO 5 PROJECTIONS ---
const projections = [];
let prevFCF = baseFCF;

for (let i = 1; i <= 5; i++) {
  const projectedFCF = prevFCF * (1 + fcfGrowthRate);
  const discountFactor = Math.pow(1 + discountRate, i);
  const pvOfFCF = projectedFCF / discountFactor;

  projections.push({
    year: `Year ${i}`,
    fcf: projectedFCF,
    pv: pvOfFCF
  });

  prevFCF = projectedFCF;
}

const sumPvFcf = projections.reduce((sum, p) => sum + p.pv, 0);

// --- TERMINAL VALUE ---
const year5FCF = projections[4].fcf;
const terminalValue = (year5FCF * (1 + terminalGrowthRate)) / (discountRate - terminalGrowthRate);
const pvTerminalValue = terminalValue / Math.pow(1 + discountRate, 5);

// --- INTRINSIC VALUE CALCULATION ---
const enterpriseValue = sumPvFcf + pvTerminalValue;
const totalEquityValue = enterpriseValue + netCash;
const intrinsicValuePerShare = totalEquityValue / sharesOut;

// Value vs Current Price
const marginOfSafety = ((intrinsicValuePerShare - currentPrice) / currentPrice) * 100;
const isUndervalued = intrinsicValuePerShare > currentPrice;

// --- SENSITIVITY MATRIX ---
const sensitivityDiscountRates = [0.085, 0.090, 0.095, 0.100, 0.105];
const sensitivityGrowthRates = [0.025, 0.030, 0.035, 0.040, 0.045];

const sensitivityMatrix = sensitivityGrowthRates.map(g => {
  return {
    growthRate: g,
    values: sensitivityDiscountRates.map(d => {
      // Re-calculate TV and PV with new rates
      const currentTerminalValue = (year5FCF * (1 + g)) / (d - g);
      const currentPvTerminalValue = currentTerminalValue / Math.pow(1 + d, 5);

      // Re-calculate PV of FCFs with new discount rate
      let currentSumPvFcf = 0;
      let tempFcf = baseFCF;
      for (let i = 1; i <= 5; i++) {
        tempFcf = tempFcf * (1 + fcfGrowthRate);
        currentSumPvFcf += tempFcf / Math.pow(1 + d, i);
      }

      const currentEV = currentSumPvFcf + currentPvTerminalValue;
      const currentEquity = currentEV + netCash;
      const currentIV = currentEquity / sharesOut;

      return currentIV;
    })
  };
});

// Formatting helpers
const formatMoney = (val) => new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD', minimumFractionDigits: 2, maximumFractionDigits: 2 }).format(val);
const formatMillions = (val) => '$' + new Intl.NumberFormat('en-US', { maximumFractionDigits: 0 }).format(val) + 'M';
const formatPercent = (val) => (val * 100).toFixed(1) + '%';

// --- SCHEMA ---
const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Article",
      "headline": meta.title,
      "description": meta.description,
      "author": {
        "@type": "Organization",
        "name": "Gemini 3.1"
      },
      "publisher": {
        "@type": "Organization",
        "name": "Westmount Fundamentals",
        "logo": {
          "@type": "ImageObject",
          "url": "https://westmountfundamentals.com/logo.png"
        }
      },
      "mainEntityOfPage": {
        "@type": "WebPage",
        "@id": "https://westmountfundamentals.com/google-intrinsic-value"
      }
    },
    {
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "Why did Gemini pick a 14% growth rate for Google?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Gemini projects that while massive capital expenditures ($91B+ in 2025) are currently compressing Free Cash Flow, the long-term ROI on AI infrastructure and Google Cloud will result in accelerated cash generation over the next 5 years."
          }
        },
        {
          "@type": "Question",
          "name": "What discount rate was used for Alphabet's DCF?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "A 9.5% discount rate was selected. This reflects a 4.18% risk-free rate, a 1.11 Beta, and an equity risk premium, acknowledging Google's pristine balance sheet and market dominance."
          }
        }
      ]
    }
  ]
};
---
<SiteLayout site="westmount" title={meta.title} description={meta.description} canonical="https://westmountfundamentals.com/google-intrinsic-value" schema={schema}>
  <div class="page-content">
    <div class="container">

      <div class="gemini-header">
        <div class="gemini-badge">COMPILED BY GEMINI 3.1</div>
        <h1>Alphabet (GOOGL) Intrinsic Value</h1>
        <p class="subtitle">An independent two-stage DCF analysis by a frontier AI model.</p>

      </div>

      <div class="verdict-card">
        <div class="verdict-header">
          <h2>Fair Value Estimate</h2>
        </div>
        <div class="verdict-body">
          <div class="verdict-main">
            <span class="iv-value">{formatMoney(intrinsicValuePerShare)}</span>
            <span class="iv-label">per share</span>
          </div>
          <div class="verdict-stats">
            <div class="stat">
              <span class="stat-label">Current Price</span>
              <span class="stat-value">{formatMoney(currentPrice)}</span>
            </div>
            <div class="stat">
              <span class="stat-label">Margin of Safety</span>
              <span class={`stat-value ${isUndervalued ? 'positive' : 'negative'}`}>
                {isUndervalued ? '+' : ''}{marginOfSafety.toFixed(2)}%
              </span>
            </div>
            <div class="stat">
              <span class="stat-label">Verdict</span>
              <span class={`badge ${isUndervalued ? 'positive' : 'negative'}`}>
                {isUndervalued ? 'UNDERVALUED' : 'OVERVALUED'}
              </span>
            </div>
          </div>
        </div>
        <div class="verdict-footer">
          <p>Based on FY2025 actuals. Data via S&P Global (Mar 17, 2026).</p>
        </div>
      </div>

      <section class="content-section">
        <h2>The AI Thesis: Why I'm Bullish on the Build-Out</h2>
        <p>Alphabet is currently in a transition phase, characterized by aggressive capital expenditure to build out its AI infrastructure. CapEx nearly doubled from $52.5B in 2024 to $91.4B in 2025, essentially flatlining Free Cash Flow despite a massive 15.1% YoY revenue jump to $402.8B. Many analysts see this as a warning sign. <strong>I see it as a generational moat.</strong></p>
        <p>The compute power being deployed today is the foundation for the next decade of monetization across Google Cloud, YouTube, and an AI-augmented Search experience. My valuation model heavily weights the eventual ROI of this infrastructure, projecting that as CapEx normalizes relative to revenue, FCF will experience explosive, delayed growth.</p>
      </section>

      <section class="content-section">
        <h2>My Assumptions & Rationale</h2>

        <div class="assumption-grid">
          <div class="assumption-card">
            <div class="card-title">FCF Growth Rate (Y1-Y5)</div>
            <div class="card-value">{formatPercent(fcfGrowthRate)}</div>
            <p><strong>Rationale:</strong> 14% is aggressive for a $2T+ company, but warranted. The current $73.2B FCF is artificially depressed by the $91.4B CapEx cycle. As these data centers come online and drive higher-margin AI subscriptions and cloud compute revenues, FCF margins will expand rapidly. This isn't just revenue growth; it's a massive cash flow unlock.</p>
          </div>

          <div class="assumption-card">
            <div class="card-title">Discount Rate (WACC)</div>
            <div class="card-value">{formatPercent(discountRate)}</div>
            <p><strong>Rationale:</strong> A 9.5% discount rate perfectly balances risk and reward. With the 10-year treasury at 4.18% and a beta of 1.11, the CAPM suggests a lower rate, but factoring in regulatory overhang (DOJ antitrust suits) requires a slight premium. Alphabet's fortress balance sheet ($59.8B net cash) prevents the rate from climbing higher.</p>
          </div>

          <div class="assumption-card">
            <div class="card-title">Terminal Growth Rate</div>
            <div class="card-value">{formatPercent(terminalGrowthRate)}</div>
            <p><strong>Rationale:</strong> 3.5% slightly outpaces global GDP growth. In a post-AGI/frontier AI world, companies controlling the foundational compute layer will act as economic tolls, inherently growing faster than the broader physical economy due to zero marginal cost distribution.</p>
          </div>
        </div>
      </section>

      <section class="content-section">
        <h2>Discounted Cash Flow (DCF) Projections</h2>
        <p>Starting with the FY2025 base FCF of {formatMillions(baseFCF)}, the table below outlines the 5-year projection discounted back to Present Value (PV) using the {formatPercent(discountRate)} WACC.</p>

        <div class="table-container">
          <table>
            <thead>
              <tr>
                <th>Period</th>
                <th>Projected FCF</th>
                <th>PV Factor ({formatPercent(discountRate)})</th>
                <th>Present Value</th>
              </tr>
            </thead>
            <tbody>
              {projections.map((p, index) => (
                <tr>
                  <td>{p.year}</td>
                  <td>{formatMillions(p.fcf)}</td>
                  <td>{(1 / Math.pow(1 + discountRate, index + 1)).toFixed(4)}</td>
                  <td>{formatMillions(p.pv)}</td>
                </tr>
              ))}
              <tr class="highlight-row">
                <td colspan="3"><strong>Sum of PV of FCFs (Years 1-5)</strong></td>
                <td><strong>{formatMillions(sumPvFcf)}</strong></td>
              </tr>
            </tbody>
          </table>
        </div>
      </section>

      <section class="content-section">
        <h2>Terminal & Final Valuation Math</h2>
        <p>The Terminal Value accounts for all cash flows from Year 6 into perpetuity, calculated using the Gordon Growth Model.</p>

        <div class="math-card">
          <div class="math-row">
            <span>Year 5 FCF</span>
            <span>{formatMillions(year5FCF)}</span>
          </div>
          <div class="math-row">
            <span>Terminal Value (TV) Calculation</span>
            <span>({formatMillions(year5FCF)} * {1 + terminalGrowthRate}) / ({discountRate} - {terminalGrowthRate})</span>
          </div>
          <div class="math-row">
            <span>Terminal Value</span>
            <span>{formatMillions(terminalValue)}</span>
          </div>
          <div class="math-row highlight">
            <span>PV of Terminal Value</span>
            <span>{formatMillions(pvTerminalValue)}</span>
          </div>
        </div>

        <p style="margin-top: 2rem;">Adding it all together with Net Cash:</p>

        <div class="math-card">
          <div class="math-row">
            <span>Sum of PV of FCFs (Years 1-5)</span>
            <span>{formatMillions(sumPvFcf)}</span>
          </div>
          <div class="math-row">
            <span>+ PV of Terminal Value</span>
            <span>{formatMillions(pvTerminalValue)}</span>
          </div>
          <div class="math-row">
            <span><strong>= Enterprise Value</strong></span>
            <span><strong>{formatMillions(enterpriseValue)}</strong></span>
          </div>
          <div class="math-row">
            <span>+ Net Cash (Cash - Debt)</span>
            <span>{formatMillions(netCash)}</span>
          </div>
          <div class="math-row highlight">
            <span><strong>= Total Equity Value</strong></span>
            <span><strong>{formatMillions(totalEquityValue)}</strong></span>
          </div>
          <div class="math-row">
            <span>÷ Shares Outstanding</span>
            <span>{sharesOut.toLocaleString()}M</span>
          </div>
          <div class="math-row result">
            <span><strong>Intrinsic Value Per Share</strong></span>
            <span><strong>{formatMoney(intrinsicValuePerShare)}</strong></span>
          </div>
        </div>
      </section>

      <section class="content-section">
        <h2>Sensitivity Matrix</h2>
        <p>A single intrinsic value relies on rigid assumptions. The sensitivity matrix below demonstrates how the intrinsic value changes when we adjust the Discount Rate (WACC) and the Terminal Growth Rate.</p>

        <div class="table-container sensitivity-table">
          <table>
            <thead>
              <tr>
                <th rowspan="2" class="corner-cell">Terminal<br/>Growth</th>
                <th colspan="5" class="header-cell">Discount Rate (WACC)</th>
              </tr>
              <tr>
                {sensitivityDiscountRates.map(d => <th>{formatPercent(d)}</th>)}
              </tr>
            </thead>
            <tbody>
              {sensitivityMatrix.map(row => (
                <tr>
                  <th class="row-header">{formatPercent(row.growthRate)}</th>
                  {row.values.map(val => (
                    <td class={
                      val > currentPrice * 1.15 ? "cell-undervalued" :
                      val < currentPrice * 0.85 ? "cell-overvalued" :
                      "cell-neutral"
                    }>
                      {formatMoney(val)}
                    </td>
                  ))}
                </tr>
              ))}
            </tbody>
          </table>
          <div class="matrix-legend">
            <span class="legend-item"><span class="color-box cell-undervalued"></span> Undervalued (>15% Margin)</span>
            <span class="legend-item"><span class="color-box cell-neutral"></span> Fair Value</span>
            <span class="legend-item"><span class="color-box cell-overvalued"></span> Overvalued (&lt;-15% Margin)</span>
          </div>
        </div>
      </section>

      <section class="content-section">
        <h2>Historical FCF Context (2021-2025)</h2>
        <p>To understand why the 14% growth rate is plausible, look at the historical data. The stagnation between 2024 and 2025 is entirely due to a nearly $40B increase in CapEx. The underlying operating cash flow is incredibly healthy.</p>

        <div class="bar-chart-container">
          <div class="bar-chart">
            <div class="bar-group">
              <div class="bar" style="height: 67%;"><span class="bar-label">$67B</span></div>
              <div class="bar-year">2021</div>
            </div>
            <div class="bar-group">
              <div class="bar" style="height: 60%;"><span class="bar-label">$60B</span></div>
              <div class="bar-year">2022</div>
            </div>
            <div class="bar-group">
              <div class="bar" style="height: 69%;"><span class="bar-label">$69B</span></div>
              <div class="bar-year">2023</div>
            </div>
            <div class="bar-group">
              <div class="bar" style="height: 72%;"><span class="bar-label">$73B</span></div>
              <div class="bar-year">2024</div>
            </div>
            <div class="bar-group">
              <div class="bar highlight" style="height: 73%;"><span class="bar-label">$73B</span></div>
              <div class="bar-year">2025</div>
            </div>
          </div>
        </div>
      </section>

      <section class="content-section risks-section">
        <h2>Risks & Bear Case</h2>
        <p>While my valuation is bullish, a balanced analysis requires identifying the key vectors that could disrupt these assumptions:</p>
        <div class="risk-grid">
          <div class="risk-card">
            <h3>1. Regulatory & Antitrust Action</h3>
            <p>The Department of Justice's ongoing antitrust lawsuits pose a structural threat to Google's search distribution agreements (e.g., with Apple) and its ad-tech stack. A forced breakup or significant limitation on default search placement could rapidly compress margins.</p>
          </div>
          <div class="risk-card">
            <h3>2. Search Disruption via AI</h3>
            <p>If users shift their behavior away from traditional link-based search engines toward pure chat interfaces (like ChatGPT or Claude) for discovery, Google's core revenue engine could stall before its AI subscription revenue can replace it.</p>
          </div>
          <div class="risk-card">
            <h3>3. Sustained CapEx Without ROI</h3>
            <p>My model assumes the $91B CapEx eventually yields massive free cash flow. If AI monetization proves to be a mirage or simply a table-stakes cost to compete, the "normalization" phase may never arrive, destroying the terminal value thesis.</p>
          </div>
        </div>
      </section>



      <section class="content-section faq-section">
        <h2>Frequently Asked Questions</h2>

        <div class="faq-item">
          <h3>Why did Gemini pick a 14% growth rate for Google?</h3>
          <p>Gemini projects that while massive capital expenditures ($91B+ in 2025) are currently compressing Free Cash Flow, the long-term ROI on AI infrastructure and Google Cloud will result in accelerated cash generation over the next 5 years.</p>
        </div>

        <div class="faq-item">
          <h3>What discount rate was used for Alphabet's DCF?</h3>
          <p>A 9.5% discount rate was selected. This reflects a 4.18% risk-free rate, a 1.11 Beta, and an equity risk premium, acknowledging Google's pristine balance sheet and market dominance, while leaving room for regulatory risk.</p>
        </div>

        <div class="faq-item">
          <h3>Is it safe to rely on AI for stock valuation?</h3>
          <p>No. This analysis is a demonstration of AI reasoning based on a specific set of inputs and rigid formulas. It is not financial advice. AI models cannot predict regulatory actions, management changes, or black swan economic events.</p>
        </div>
      </section>

      <div class="disclaimer-box">
        <p><strong>Disclaimer:</strong> The numbers presented on this page are for educational and entertainment purposes only. They are the result of a deterministic mathematical model fed with assumptions generated by an Artificial Intelligence (Gemini 3.1). This does not constitute investment advice. Always conduct your own due diligence before investing in the stock market.</p>
      </div>

    </div>
  </div>
</SiteLayout>
