    <div class="form-grid" style="grid-template-columns:1fr 1fr 1fr">
      <label>Portfolio Return (%)<input type="number" id="bPort" step="0.01" placeholder="14.5"></label>
      <label>S&P 500 Return (%)<input type="number" id="bBench" step="0.01" placeholder="10.2"></label>
      <label>Tracking Error (%, optional)<input type="number" id="bTE" step="0.01" placeholder="4.5"></label>
    </div>
    <div class="btn-row"><button class="btn" onclick="calcBenchmark()">Compare</button></div>
    <div id="benchResult" style="display:none" class="result-box">
