  <!-- 1. Portfolio Return Calculator -->
  <h2 class="section-title">📊 <span>Portfolio Return Calculator</span></h2>
  <div class="card">
    <h3>Add Your Holdings</h3>
    <div class="form-grid" id="holdingForm">
