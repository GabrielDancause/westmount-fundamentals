---
import SiteLayout from "../layouts/SiteLayout.astro";

export const meta = {
  title: "Portfolio Performance Tracker — Calculate Returns, Risk & Alpha | Westmount Fundamentals",
  description: "Free portfolio performance tracker with return calculators, time-weighted returns, benchmark comparison, and interactive charts. Analyze your investment portfolio analytics instantly.",
  category: "study",
  published: "2026-03-20"
};

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Article",
      "headline": "Portfolio Performance Tracker — Calculate Returns, Risk & Alpha",
      "description": meta.description,
      "datePublished": "2026-03-20",
      "author": {
        "@type": "Organization",
        "name": "Westmount Fundamentals",
        "url": "https://westmountfundamentals.com"
      },
      "publisher": {
        "@type": "Organization",
        "name": "Westmount Fundamentals"
      }
    },
    {
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "What is the best way to track portfolio performance?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "The best way to track portfolio performance is to calculate time-weighted returns (TWR) for each holding and your overall portfolio, then compare against a relevant benchmark like the S&P 500. This removes the distortion caused by deposits and withdrawals, giving you a true measure of investment skill."
          }
        },
        {
          "@type": "Question",
          "name": "What is the difference between time-weighted and money-weighted returns?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Time-weighted return (TWR) measures the compound growth rate of one dollar invested and eliminates the impact of cash flows, making it ideal for comparing against benchmarks. Money-weighted return (MWR), also called internal rate of return (IRR), accounts for the timing and size of deposits and withdrawals, reflecting your actual experience as an investor."
          }
        },
        {
          "@type": "Question",
          "name": "How do you calculate portfolio alpha?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Portfolio alpha is calculated by subtracting the benchmark return from your portfolio return. For example, if your portfolio returned 12% and the S&P 500 returned 10%, your alpha is +2%. A positive alpha means you outperformed the benchmark after accounting for market movements."
          }
        },
        {
          "@type": "Question",
          "name": "What is a good portfolio return?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "A good portfolio return depends on your risk level and time horizon. Historically, the S&P 500 has returned roughly 10% annually before inflation. Beating this benchmark consistently after fees is considered excellent performance. Most professional fund managers fail to outperform the index over 15+ year periods."
          }
        },
        {
          "@type": "Question",
          "name": "How often should I review my investment portfolio?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Most experts recommend reviewing your portfolio quarterly for performance and annually for rebalancing. Checking too frequently can lead to emotional trading decisions. Focus on long-term trends rather than daily fluctuations, and ensure your asset allocation still aligns with your goals and risk tolerance."
          }
        }
      ]
    }
  ]
};
---
