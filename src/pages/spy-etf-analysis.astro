---
import SiteLayout from "../layouts/SiteLayout.astro";

export const meta = {
  title: "SPY ETF Analysis: SPDR S&P 500 Holdings, Performance & Options Guide (2026)",
  description: "Complete SPY ETF analysis — expense ratio, top holdings, SPY vs VOO vs IVV comparison, annual returns, options liquidity, and growth calculator. The definitive SPDR S&P 500 guide.",
  category: "study",
  published: "2026-03-20"
};

var schema = [
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": meta.title,
    "description": meta.description,
    "datePublished": "2026-03-20",
    "author": { "@type": "Organization", "name": "Westmount Fundamentals" },
    "publisher": { "@type": "Organization", "name": "Westmount Fundamentals", "url": "https://westmountfundamentals.com" }
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "What is the SPY ETF expense ratio?",
        "acceptedAnswer": { "@type": "Answer", "text": "SPY has an expense ratio of 0.0945%, which is higher than VOO (0.03%) and IVV (0.03%). However, SPY's superior liquidity, tighter bid-ask spreads, and dominant options market often make up for the fee difference, especially for active traders." }
      },
      {
        "@type": "Question",
        "name": "Is SPY better than VOO?",
        "acceptedAnswer": { "@type": "Answer", "text": "It depends on your strategy. VOO is cheaper (0.03% vs 0.0945%) and better for long-term buy-and-hold investors. SPY is better for traders who need liquidity, tight spreads, and options. SPY trades over 80 million shares daily versus about 5 million for VOO." }
      },
      {
        "@type": "Question",
        "name": "What are the top holdings in SPY?",
        "acceptedAnswer": { "@type": "Answer", "text": "As of early 2026, SPY's top holdings include Apple (~7.1%), Microsoft (~6.5%), NVIDIA (~6.2%), Amazon (~3.8%), Meta (~2.7%), Alphabet Class A (~2.2%), Broadcom (~2.0%), Alphabet Class C (~1.8%), Tesla (~1.7%), and Berkshire Hathaway (~1.6%)." }
      },
      {
        "@type": "Question",
        "name": "Why is SPY the most traded ETF in the world?",
        "acceptedAnswer": { "@type": "Answer", "text": "SPY is the most traded security in the world because of its deep liquidity, the massive options market built around it, and its role as a benchmark hedging instrument. Institutional investors, hedge funds, and market makers all use SPY as their primary S&P 500 vehicle." }
      },
      {
        "@type": "Question",
        "name": "How much would $10,000 invested in SPY in 1993 be worth today?",
        "acceptedAnswer": { "@type": "Answer", "text": "A $10,000 investment in SPY at its inception in January 1993 would be worth approximately $230,000 today (early 2026), representing roughly a 10.3% annualized return over 32+ years with dividends reinvested." }
      }
    ]
  }
];
---

<SiteLayout
  site="westmount"
  title={meta.title}
  description={meta.description}
  canonical="https://westmountfundamentals.com/spy-etf-analysis/"
  schema={schema}
>

<style is:inline>
  .spy-hero {
    background: linear-gradient(135deg, #0a1628 0%, #1a0a2e 50%, #0a1628 100%);
    padding: 4rem 1.5rem 3rem;
    text-align: center;
    border-bottom: 1px solid rgba(99,102,241,0.2);
  }
  .spy-hero h1 {
    font-size: 2.4rem;
    font-weight: 800;
    background: linear-gradient(135deg, #818cf8, #a78bfa, #c084fc);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    margin: 0 0 1rem;
    line-height: 1.2;
  }
  .spy-hero .subtitle {
    color: #94a3b8;
    font-size: 1.15rem;
    max-width: 700px;
    margin: 0 auto;
    line-height: 1.6;
  }
  .spy-container {
    max-width: 1000px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }
  .spy-section {
    padding: 3rem 0;
    border-bottom: 1px solid rgba(148,163,184,0.1);
  }
  .spy-section:last-child { border-bottom: none; }
  .spy-section h2 {
    font-size: 1.7rem;
    font-weight: 700;
    color: #e2e8f0;
    margin: 0 0 0.5rem;
  }
  .spy-section h3 {
    font-size: 1.25rem;
    font-weight: 600;
    color: #cbd5e1;
    margin: 1.5rem 0 0.75rem;
  }
  .spy-section p, .spy-section li {
    color: #94a3b8;
    font-size: 1rem;
    line-height: 1.7;
  }
  .section-lead {
    color: #94a3b8;
    font-size: 1.05rem;
    margin: 0 0 2rem;
    max-width: 800px;
  }

  /* Overview Dashboard */
  .overview-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
    margin-top: 1.5rem;
  }
  .overview-card {
    background: rgba(15,23,42,0.6);
    border: 1px solid rgba(148,163,184,0.1);
    border-radius: 12px;
    padding: 1.25rem;
    text-align: center;
  }
  .overview-card .ov-label {
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: #64748b;
    margin-bottom: 0.4rem;
  }
  .overview-card .ov-value {
    font-size: 1.5rem;
    font-weight: 700;
    color: #e2e8f0;
  }
  .overview-card .ov-note {
    font-size: 0.78rem;
    color: #64748b;
    margin-top: 0.3rem;
  }

  /* Stat Cards */
  .stat-cards {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1rem;
    margin-top: 1.5rem;
  }
  .stat-card {
    background: linear-gradient(135deg, rgba(99,102,241,0.1), rgba(168,85,247,0.1));
    border: 1px solid rgba(99,102,241,0.2);
    border-radius: 12px;
    padding: 1.5rem;
    text-align: center;
  }
  .stat-card .stat-icon { font-size: 2rem; margin-bottom: 0.5rem; }
  .stat-card .stat-value {
    font-size: 1.4rem;
    font-weight: 700;
    color: #a78bfa;
  }
  .stat-card .stat-label {
    font-size: 0.82rem;
    color: #94a3b8;
    margin-top: 0.3rem;
  }

  /* Tables */
  .spy-table-wrap {
    overflow-x: auto;
    margin-top: 1.5rem;
    border-radius: 12px;
    border: 1px solid rgba(148,163,184,0.1);
  }
  .spy-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.92rem;
  }
  .spy-table th {
    background: rgba(15,23,42,0.8);
    color: #a78bfa;
    font-weight: 600;
    text-align: left;
    padding: 0.85rem 1rem;
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    white-space: nowrap;
  }
  .spy-table td {
    padding: 0.75rem 1rem;
    color: #cbd5e1;
    border-top: 1px solid rgba(148,163,184,0.07);
  }
  .spy-table tbody tr:hover { background: rgba(99,102,241,0.05); }
  .spy-table .num { text-align: right; font-variant-numeric: tabular-nums; }
  .highlight-best {
    color: #34d399;
    font-weight: 600;
  }
  .highlight-label {
    display: inline-block;
    background: rgba(52,211,153,0.15);
    color: #34d399;
    font-size: 0.7rem;
    padding: 0.15rem 0.5rem;
    border-radius: 4px;
    margin-left: 0.4rem;
    text-transform: uppercase;
    font-weight: 600;
  }

  /* Calculator */
  .calc-box {
    background: rgba(15,23,42,0.6);
    border: 1px solid rgba(148,163,184,0.15);
    border-radius: 16px;
    padding: 2rem;
    margin-top: 1.5rem;
  }
  .calc-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
    margin-bottom: 1.5rem;
  }
  .calc-field label {
    display: block;
    font-size: 0.82rem;
    color: #94a3b8;
    margin-bottom: 0.4rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }
  .calc-field input {
    width: 100%;
    padding: 0.7rem 1rem;
    background: rgba(30,41,59,0.8);
    border: 1px solid rgba(148,163,184,0.2);
    border-radius: 8px;
    color: #e2e8f0;
    font-size: 1rem;
    box-sizing: border-box;
  }
  .calc-field input:focus {
    outline: none;
    border-color: #818cf8;
  }
  .calc-btn {
    display: inline-block;
    background: linear-gradient(135deg, #6366f1, #8b5cf6);
    color: #fff;
    border: none;
    padding: 0.75rem 2rem;
    border-radius: 8px;
    font-size: 1rem;
    font-weight: 600;
    cursor: pointer;
    transition: opacity 0.2s;
  }
  .calc-btn:hover { opacity: 0.9; }
  .calc-result {
    margin-top: 1.5rem;
    display: none;
  }
  .calc-result-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
  }
  .calc-result-card {
    background: rgba(99,102,241,0.1);
    border: 1px solid rgba(99,102,241,0.2);
    border-radius: 10px;
    padding: 1.25rem;
    text-align: center;
  }
  .calc-result-card .cr-label {
    font-size: 0.78rem;
    color: #94a3b8;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }
  .calc-result-card .cr-value {
    font-size: 1.5rem;
    font-weight: 700;
    color: #818cf8;
    margin-top: 0.3rem;
  }

  /* Charts */
  .chart-wrap {
    background: rgba(15,23,42,0.6);
    border: 1px solid rgba(148,163,184,0.1);
    border-radius: 16px;
    padding: 1.5rem;
    margin-top: 1.5rem;
  }
  .chart-wrap canvas { max-height: 400px; }

  /* Insights */
  .insights-list {
    list-style: none;
    padding: 0;
    margin: 1.5rem 0 0;
    display: grid;
    gap: 1rem;
  }
  .insights-list li {
    background: rgba(15,23,42,0.6);
    border: 1px solid rgba(148,163,184,0.1);
    border-left: 3px solid #818cf8;
    border-radius: 10px;
    padding: 1.25rem 1.5rem;
    color: #cbd5e1;
  }
  .insights-list li strong { color: #e2e8f0; }

  /* Options section */
  .options-highlights {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem;
    margin-top: 1.5rem;
  }
  .opt-card {
    background: rgba(15,23,42,0.6);
    border: 1px solid rgba(148,163,184,0.1);
    border-radius: 12px;
    padding: 1.5rem;
  }
  .opt-card h4 {
    color: #a78bfa;
    font-size: 1rem;
    margin: 0 0 0.5rem;
  }
  .opt-card p {
    color: #94a3b8;
    font-size: 0.92rem;
    margin: 0;
    line-height: 1.6;
  }

  /* FAQ */
  .faq-item {
    border: 1px solid rgba(148,163,184,0.1);
    border-radius: 12px;
    margin-bottom: 0.75rem;
    overflow: hidden;
  }
  .faq-q {
    padding: 1.1rem 1.5rem;
    background: rgba(15,23,42,0.6);
    color: #e2e8f0;
    font-weight: 600;
    cursor: pointer;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .faq-q:hover { background: rgba(15,23,42,0.8); }
  .faq-q .faq-arrow { color: #818cf8; transition: transform 0.2s; }
  .faq-a {
    padding: 0 1.5rem;
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.3s ease, padding 0.3s ease;
    color: #94a3b8;
    line-height: 1.7;
    font-size: 0.95rem;
  }
  .faq-item.open .faq-a {
    padding: 1rem 1.5rem;
    max-height: 500px;
  }
  .faq-item.open .faq-arrow { transform: rotate(180deg); }

  /* Responsive */
  @media (max-width: 768px) {
    .spy-hero h1 { font-size: 1.7rem; }
    .overview-grid { grid-template-columns: repeat(2, 1fr); }
    .stat-cards { grid-template-columns: repeat(2, 1fr); }
    .calc-grid { grid-template-columns: 1fr; }
    .calc-result-grid { grid-template-columns: 1fr; }
    .options-highlights { grid-template-columns: 1fr; }
  }
  @media (max-width: 480px) {
    .overview-grid { grid-template-columns: 1fr; }
    .stat-cards { grid-template-columns: 1fr; }
  }
</style>

<div class="spy-hero">
  <div class="spy-container">
    <h1>SPY ETF Analysis: The Definitive SPDR S&P 500 Guide</h1>
    <p class="subtitle">Everything you need to know about the world's most traded ETF — holdings, performance, options liquidity, and why SPY has been the benchmark since 1993.</p>
  </div>
</div>

<div class="spy-container">

  <!-- Section 1: Overview Dashboard -->
  <section class="spy-section">
    <h2>SPY Overview Dashboard</h2>
    <p class="section-lead">SPDR S&P 500 ETF Trust (SPY) is the original S&P 500 ETF and remains the most liquid security on Earth. Here's a snapshot of the key metrics every investor should know.</p>
    <div class="overview-grid">
      <div class="overview-card">
        <div class="ov-label">Price</div>
        <div class="ov-value">~$565</div>
        <div class="ov-note">As of Mar 2026</div>
      </div>
      <div class="overview-card">
        <div class="ov-label">Expense Ratio</div>
        <div class="ov-value">0.0945%</div>
        <div class="ov-note">$9.45 per $10K/year</div>
      </div>
      <div class="overview-card">
        <div class="ov-label">Dividend Yield</div>
        <div class="ov-value">~1.2%</div>
        <div class="ov-note">Quarterly distributions</div>
      </div>
      <div class="overview-card">
        <div class="ov-label">AUM</div>
        <div class="ov-value">$560B</div>
        <div class="ov-note">Largest ETF globally</div>
      </div>
      <div class="overview-card">
        <div class="ov-label">Inception</div>
        <div class="ov-value">Jan 1993</div>
        <div class="ov-note">Oldest US ETF (32+ years)</div>
      </div>
      <div class="overview-card">
        <div class="ov-label">Benchmark</div>
        <div class="ov-value">S&P 500</div>
        <div class="ov-note">500 largest US companies</div>
      </div>
    </div>
  </section>

  <!-- Section 10: Stat Cards -->
  <section class="spy-section">
    <h2>SPY by the Numbers</h2>
    <p class="section-lead">Four stats that explain why SPY is in a league of its own among exchange-traded funds.</p>
    <div class="stat-cards">
      <div class="stat-card">
        <div class="stat-icon">🏛️</div>
        <div class="stat-value">1993</div>
        <div class="stat-label">Oldest US ETF — the one that started it all</div>
      </div>
      <div class="stat-card">
        <div class="stat-icon">📊</div>
        <div class="stat-value">80M+</div>
        <div class="stat-label">Avg daily volume — most traded security on Earth</div>
      </div>
      <div class="stat-card">
        <div class="stat-icon">💰</div>
        <div class="stat-value">$560B</div>
        <div class="stat-label">Assets under management</div>
      </div>
      <div class="stat-card">
        <div class="stat-icon">📈</div>
        <div class="stat-value">~10.3%</div>
        <div class="stat-label">Annualized return since inception</div>
      </div>
    </div>
  </section>

  <!-- Section 2: Growth Calculator -->
  <section class="spy-section">
    <h2>SPY Growth Calculator</h2>
    <p class="section-lead">See how your money could grow invested in SPY. We use the historical average annualized return of 10.3% for projections.</p>
    <div class="calc-box">
      <div class="calc-grid">
        <div class="calc-field">
          <label>Initial Investment ($)</label>
          <input type="number" id="calcInit" value="10000" min="0" step="1000">
        </div>
        <div class="calc-field">
          <label>Monthly Contribution ($)</label>
          <input type="number" id="calcMonthly" value="500" min="0" step="100">
        </div>
        <div class="calc-field">
          <label>Years</label>
          <input type="number" id="calcYears" value="20" min="1" max="50" step="1">
        </div>
      </div>
      <button class="calc-btn" onclick="calcGrowth()">Calculate Projected Growth</button>
      <div class="calc-result" id="calcResult">
        <div class="calc-result-grid">
          <div class="calc-result-card">
            <div class="cr-label">Total Invested</div>
            <div class="cr-value" id="crInvested">—</div>
          </div>
          <div class="calc-result-card">
            <div class="cr-label">Projected Value</div>
            <div class="cr-value" id="crValue">—</div>
          </div>
          <div class="calc-result-card">
            <div class="cr-label">Growth</div>
            <div class="cr-value" id="crGrowth">—</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Section 3: $10K Growth Chart -->
  <section class="spy-section">
    <h2>$10,000 Invested in SPY Since 1993</h2>
    <p class="section-lead">The ultimate buy-and-hold story. A $10,000 investment in SPY at its 1993 launch grew to approximately $230,000 by early 2026 — through the dot-com bust, the Great Financial Crisis, COVID, and everything in between.</p>
    <div class="chart-wrap">
      <canvas id="growthChart"></canvas>
    </div>
  </section>

  <!-- Section 4: SPY vs VOO vs IVV -->
  <section class="spy-section">
    <h2>SPY vs VOO vs IVV: S&P 500 ETF Comparison</h2>
    <p class="section-lead">All three track the same index, but they are not identical. Here's why SPY costs more — and why millions of traders still prefer it.</p>
    <div class="spy-table-wrap">
      <table class="spy-table">
        <thead>
          <tr>
            <th>Metric</th>
            <th>SPY (SPDR)</th>
            <th>VOO (Vanguard)</th>
            <th>IVV (iShares)</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td>Expense Ratio</td>
            <td>0.0945%</td>
            <td class="highlight-best">0.03% <span class="highlight-label">Cheapest</span></td>
            <td class="highlight-best">0.03%</td>
          </tr>
          <tr>
            <td>AUM</td>
            <td class="highlight-best">$560B <span class="highlight-label">Largest</span></td>
            <td>$480B</td>
            <td>$520B</td>
          </tr>
          <tr>
            <td>Avg Daily Volume</td>
            <td class="highlight-best">~80M <span class="highlight-label">Most Liquid</span></td>
            <td>~5M</td>
            <td>~7M</td>
          </tr>
          <tr>
            <td>Bid-Ask Spread</td>
            <td class="highlight-best">$0.01 <span class="highlight-label">Tightest</span></td>
            <td>$0.01–$0.02</td>
            <td>$0.01–$0.02</td>
          </tr>
          <tr>
            <td>Options Volume</td>
            <td class="highlight-best">Enormous <span class="highlight-label">King of Options</span></td>
            <td>Moderate</td>
            <td>Moderate</td>
          </tr>
          <tr>
            <td>Structure</td>
            <td>Unit Investment Trust</td>
            <td>Open-End Fund</td>
            <td>Open-End Fund</td>
          </tr>
          <tr>
            <td>Dividend Reinvestment</td>
            <td>No (cash drag)</td>
            <td class="highlight-best">Yes <span class="highlight-label">Better</span></td>
            <td class="highlight-best">Yes</td>
          </tr>
          <tr>
            <td>Inception</td>
            <td class="highlight-best">1993 <span class="highlight-label">Pioneer</span></td>
            <td>2010</td>
            <td>2000</td>
          </tr>
          <tr>
            <td>Best For</td>
            <td><strong>Traders & Options</strong></td>
            <td><strong>Long-term Buy & Hold</strong></td>
            <td><strong>Low-cost Core</strong></td>
          </tr>
        </tbody>
      </table>
    </div>
    <p style="color:#64748b;font-size:0.85rem;margin-top:0.75rem;">💡 <strong style="color:#94a3b8;">Bottom line:</strong> If you're buying and holding for decades, VOO saves you money. If you trade options or need instant liquidity, SPY is irreplaceable.</p>
  </section>

  <!-- Section 5: Annual Returns Bar Chart -->
  <section class="spy-section">
    <h2>SPY Annual Returns (2015–2025)</h2>
    <p class="section-lead">A decade of returns shows SPY's resilience — even with two negative years, the cumulative performance has been extraordinary.</p>
    <div class="chart-wrap">
      <canvas id="returnsChart"></canvas>
    </div>
  </section>

  <!-- Section 6: Top 10 Holdings -->
  <section class="spy-section">
    <h2>SPY Top 10 Holdings</h2>
    <p class="section-lead">SPY is market-cap weighted, meaning the biggest companies have the biggest impact. The top 10 holdings represent about 35% of the entire fund.</p>
    <div class="spy-table-wrap">
      <table class="spy-table">
        <thead>
          <tr>
            <th>#</th>
            <th>Company</th>
            <th>Ticker</th>
            <th class="num">Weight</th>
          </tr>
        </thead>
        <tbody>
          <tr><td>1</td><td>Apple Inc.</td><td>AAPL</td><td class="num">7.1%</td></tr>
          <tr><td>2</td><td>Microsoft Corp.</td><td>MSFT</td><td class="num">6.5%</td></tr>
          <tr><td>3</td><td>NVIDIA Corp.</td><td>NVDA</td><td class="num">6.2%</td></tr>
          <tr><td>4</td><td>Amazon.com Inc.</td><td>AMZN</td><td class="num">3.8%</td></tr>
          <tr><td>5</td><td>Meta Platforms</td><td>META</td><td class="num">2.7%</td></tr>
          <tr><td>6</td><td>Alphabet Inc. (A)</td><td>GOOGL</td><td class="num">2.2%</td></tr>
          <tr><td>7</td><td>Broadcom Inc.</td><td>AVGO</td><td class="num">2.0%</td></tr>
          <tr><td>8</td><td>Alphabet Inc. (C)</td><td>GOOG</td><td class="num">1.8%</td></tr>
          <tr><td>9</td><td>Tesla Inc.</td><td>TSLA</td><td class="num">1.7%</td></tr>
          <tr><td>10</td><td>Berkshire Hathaway</td><td>BRK.B</td><td class="num">1.6%</td></tr>
        </tbody>
      </table>
    </div>
    <p style="color:#64748b;font-size:0.85rem;margin-top:0.75rem;">Data approximate as of March 2026. Holdings change as market caps fluctuate.</p>
  </section>

  <!-- Section 7: Sector Allocation Doughnut -->
  <section class="spy-section">
