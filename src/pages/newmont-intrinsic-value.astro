---
import SiteLayout from "../layouts/SiteLayout.astro";
import * as cheerio from 'cheerio';

const schema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": "Newmont (NEM) Intrinsic Value: A DCF Analysis",
  "description": "A transparent, step-by-step discounted cash flow valuation of Newmont Corporation. Using actual financials to arrive at a single fair value estimate for NEM shares.",
  "datePublished": "2026-03-18",
  "dateModified": "2026-03-18",
  "author": {
    "@type": "Organization",
    "name": "Westmount Research",
    "url": "https://westmountfundamentals.com"
  },
  "publisher": {
    "@type": "Organization",
    "name": "Westmount Research",
    "url": "https://westmountfundamentals.com"
  },
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": "https://westmountfundamentals.com/newmont-intrinsic-value"
  }
};

export const meta = {
  title: "Newmont (NEM) Intrinsic Value: A DCF Analysis",
  description: "We ran a full discounted cash flow on Newmont. One number. Every assumption disclosed. Here's what NEM is really worth.",
  category: "study",
  published: "2026-03-18",
};

// --- DATA FETCHING ---
async function fetchAndParse(url) {
  try {
    const res = await fetch(url, { headers: { 'User-Agent': 'Mozilla/5.0' } });
    if (!res.ok) return { headers: [], data: {} };
    const html = await res.text();
    const $ = cheerio.load(html);

    const headers = [];
    $('table thead tr th').each((i, el) => {
      headers.push($(el).text().trim());
    });

    const data = {};
    $('table tbody tr').each((i, el) => {
      const cells = $(el).find('td');
      const rowName = $(cells[0]).text().trim();
      data[rowName] = [];
      cells.each((j, cell) => {
        if (j > 0) {
          data[rowName].push($(cell).text().trim().replace(/,/g, ''));
        }
      });
    });

    return { headers, data };
  } catch (e) {
    return { headers: [], data: {} };
  }
}

const [fin, cfs, bs, priceRes] = await Promise.all([
  fetchAndParse('https://stockanalysis.com/stocks/nem/financials/'),
  fetchAndParse('https://stockanalysis.com/stocks/nem/financials/cash-flow-statement/'),
  fetchAndParse('https://stockanalysis.com/stocks/nem/financials/balance-sheet/'),
  fetch('https://stockanalysis.com/stocks/nem/', { headers: { 'User-Agent': 'Mozilla/5.0' } }).catch(() => null)
]);

let currentPrice = null;
if (priceRes && priceRes.ok) {
  const priceHtml = await priceRes.text();
  const $p = cheerio.load(priceHtml);
  const priceText = $p('.text-4xl.font-bold').first().text().trim().replace(/,/g, '');
  currentPrice = parseFloat(priceText);
}


// Extract values, handling possible missing data. We want the most recent year (index 0).
const extractNum = (obj, key, index = 0) => {
  if (!obj || !obj[key] || !obj[key][index] || obj[key][index] === '-') return null;
  const val = parseFloat(obj[key][index]);
  return isNaN(val) ? null : val;
};

// Arrays for charts (reverse them so oldest is first)
const getHistory = (obj, key) => {
  if (!obj || !obj[key]) return [];
  const years = obj === fin ? fin.headers.slice(1) : (obj === cfs ? cfs.headers.slice(1) : bs.headers.slice(1));
  const data = obj[key].slice(0, years.length);
  return years.map((yr, i) => {
    let val = parseFloat(data[i]);
    if (isNaN(val) || data[i] === '-') val = 0;
    return { year: yr.replace('FY ', ''), value: val };
  }).reverse();
};

const revHistoryRaw = getHistory(fin.data, 'Revenue');
const epsHistoryRaw = getHistory(fin.data, 'EPS (Diluted)');
const fcfHistoryRaw = getHistory(cfs.data, 'Free Cash Flow');
const ocfHistoryRaw = getHistory(cfs.data, 'Operating Cash Flow');

// For DCF, we need base numbers.
let sharesOutstanding = extractNum(fin.data, 'Shares Outstanding (Diluted)');


let cashAndInvestments = extractNum(bs.data, 'Cash & Equivalents');


let totalDebt = extractNum(bs.data, 'Total Debt');


const netCash = (cashAndInvestments !== null && totalDebt !== null) ? cashAndInvestments - totalDebt : null;

// For Newmont, FCF can be highly volatile or negative due to heavy capex in mining.
// We'll use Operating Cash Flow as a proxy for normalized cash generating ability if FCF is unrepresentative,
// but let's see what the latest FCF is.
let latestFCF = extractNum(cfs.data, 'Free Cash Flow');
let latestOCF = extractNum(cfs.data, 'Operating Cash Flow');



// Historical growth derivation
let growthRatePhase1 = null;
if (ocfHistoryRaw.length >= 4) {
  // Use OCF for growth calculation to smooth out capex lumpiness
  const oldest = ocfHistoryRaw[0].value;
  const newest = ocfHistoryRaw[ocfHistoryRaw.length - 1].value;
  if (oldest > 0 && newest > 0) {
    const years = ocfHistoryRaw.length - 1;
    let cagr = Math.pow(newest / oldest, 1 / years) - 1;
    // Cap it between 0% and 15% to be reasonable for a miner
    growthRatePhase1 = Math.max(0.00, Math.min(0.15, cagr));
  }
}

// Discount rate derivation
const treasury10Y = 0.0418; // 4.18%
const equityRiskPremium = 0.055;
const beta = 0.65; // Approximate beta for NEM
const costOfEquity = treasury10Y + (beta * equityRiskPremium);
const discountRate = parseFloat(Math.max(0.07, costOfEquity).toFixed(3)); // min 7%, let's say ~7.7%

// Terminal growth derivation
// Usually limited to long-term inflation or GDP growth. We'll use 2.5%.
const growthRateTerminal = 0.025;

// We will use Operating Cash Flow minus a normalized maintenance capex, or just rely on the latest FCF if it's positive.
// Let's use the actual latest FCF as the base if it's > 0, otherwise use 50% of OCF as a proxy for normalized FCF.
let baseFCF = latestFCF !== null && latestFCF > 0 ? latestFCF : (latestOCF !== null ? latestOCF * 0.5 : null);

// --- PHASE 1: PROJECT FCF FOR YEARS 1-5 ---
const projectedFCF = [];
let currentYearFCF = baseFCF;
let pvPhase1 = null;

if (baseFCF !== null && growthRatePhase1 !== null) {
  for (let yr = 1; yr <= 5; yr++) {
    currentYearFCF = currentYearFCF * (1 + growthRatePhase1);
    projectedFCF.push({
      year: yr,
      fcf: Math.round(currentYearFCF),
      pvFactor: 1 / Math.pow(1 + discountRate, yr)
    });
  }
  projectedFCF.forEach(p => { p.pvFCF = Math.round(p.fcf * p.pvFactor); });
  pvPhase1 = projectedFCF.reduce((sum, p) => sum + p.pvFCF, 0);
}
// --- PHASE 2: TERMINAL VALUE ---
let fcfYear6 = null;
let terminalValue = null;
let pvTerminalValue = null;

if (projectedFCF.length === 5) {
  fcfYear6 = projectedFCF[4].fcf * (1 + growthRateTerminal);
  terminalValue = Math.round(fcfYear6 / (discountRate - growthRateTerminal));
  pvTerminalValue = Math.round(terminalValue * projectedFCF[4].pvFactor);
}
// --- ENTERPRISE VALUE & EQUITY VALUE ---
let enterpriseValue = null;
let equityValue = null;
let intrinsicValuePerShare = null;
let roundedIV = null;
let marginOfSafety = null;
let verdictText = "N/A";
let verdictColor = "#5a6a80";

if (pvPhase1 !== null && pvTerminalValue !== null) {
  enterpriseValue = pvPhase1 + pvTerminalValue;
  if (netCash !== null) {
    equityValue = enterpriseValue + netCash;
    if (sharesOutstanding !== null && sharesOutstanding > 0) {
      intrinsicValuePerShare = equityValue / sharesOutstanding;
      roundedIV = Math.round(intrinsicValuePerShare * 100) / 100;

      if (currentPrice !== null && currentPrice > 0) {
        marginOfSafety = ((roundedIV - currentPrice) / currentPrice * 100).toFixed(1);
        verdictText = roundedIV > currentPrice ? "Undervalued" : "Overvalued";
        verdictColor = roundedIV > currentPrice ? "#10b981" : "#ef4444";
      }
    }
  }
}
// Sensitivity table
const sensitivityRates = [discountRate - 0.02, discountRate - 0.01, discountRate, discountRate + 0.01, discountRate + 0.02];
const sensitivityGrowth = [growthRatePhase1 - 0.04, growthRatePhase1 - 0.02, growthRatePhase1, growthRatePhase1 + 0.02, growthRatePhase1 + 0.04].map(g => Math.max(0, g));

const sensitivityTable = sensitivityRates.map(dr => {
  return {
    dr,
    values: sensitivityGrowth.map(gr => {
      if (baseFCF === null || netCash === null || sharesOutstanding === null) return 'N/A';
      let f = baseFCF;
      let pvSum = 0;
      for (let y = 1; y <= 5; y++) {
        f = f * (1 + gr);
        pvSum += f / Math.pow(1 + dr, y);
      }
      const f6 = f * (1 + growthRateTerminal);
      const tv = f6 / (dr - growthRateTerminal);
      const pvTV = tv / Math.pow(1 + dr, 5);
      const eq = pvSum + pvTV + netCash;
      return Math.round(eq / sharesOutstanding);
    })
  };
});

// Margin history (Revenue - Operating Income / Revenue, etc. - simplified here using OCF margin)
const marginHistory = revHistoryRaw.map((r, i) => {
  const rev = r.value;
  const ocf = ocfHistoryRaw[i] ? ocfHistoryRaw[i].value : 0;
  const fcf = fcfHistoryRaw[i] ? fcfHistoryRaw[i].value : 0;
  return {
    year: r.year,
    ocfMargin: rev > 0 ? ((ocf / rev) * 100).toFixed(1) : '0.0',
    fcfMargin: rev > 0 ? ((fcf / rev) * 100).toFixed(1) : '0.0'
  };
});

---

<style is:global>
*, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
body { font-family: 'Inter', -apple-system, sans-serif; background: #060a12; color: #c8d0de; line-height: 1.7; }
a { color: #4a8fe7; text-decoration: none; }
a:hover { text-decoration: underline; }
.container { max-width: 900px; margin: 0 auto; padding: 0 24px; }

/* Header */
.header { text-align: center; padding: 80px 24px 60px; background: linear-gradient(180deg, #0a1628 0%, #060a12 100%); position: relative; border-bottom: 1px solid #152040; }
.header::before { content: ''; position: absolute; inset: 0; background: radial-gradient(circle at 50% 40%, rgba(74,143,231,0.06) 0%, transparent 60%); }
.header-content { position: relative; z-index: 1; }
.tag { display: inline-block; background: rgba(74,143,231,0.12); color: #4a8fe7; font-size: 0.75rem; font-weight: 800; padding: 6px 16px; border-radius: 20px; letter-spacing: 1.5px; text-transform: uppercase; margin-bottom: 16px; }
h1 { font-size: 2.8rem; font-weight: 900; color: #fff; letter-spacing: -1.2px; margin-bottom: 16px; line-height: 1.1; }
@media (max-width: 640px) { h1 { font-size: 2rem; } }
.subtitle { color: #7a8a9e; font-size: 1.1rem; max-width: 700px; margin: 0 auto 16px; }
.date { color: #3a4a60; font-size: 0.85rem; font-weight: 600; letter-spacing: 1px; }

/* Big verdict */
.verdict-card { max-width: 560px; margin: 60px auto 0; background: linear-gradient(135deg, #0a1628 0%, #0d1830 100%); border: 2px solid #152040; border-radius: 20px; padding: 48px 32px; text-align: center; box-shadow: 0 20px 60px rgba(0,0,0,0.4); position: relative; overflow: hidden; }
.verdict-card::before { content: ''; position: absolute; top: -60%; left: -20%; width: 140%; height: 120%; background: radial-gradient(ellipse, rgba(74,143,231,0.04) 0%, transparent 70%); }
.verdict-label { font-size: 0.8rem; color: #5a6a80; font-weight: 700; text-transform: uppercase; letter-spacing: 2px; margin-bottom: 12px; position: relative; }
.verdict-price { font-family: 'JetBrains Mono', monospace; font-size: 4.5rem; font-weight: 800; color: #fff; line-height: 1; margin-bottom: 8px; position: relative; }
@media (max-width: 640px) { .verdict-price { font-size: 3rem; } }
.verdict-vs { font-size: 0.95rem; color: #5a6a80; margin-bottom: 20px; position: relative; }
.verdict-badge { display: inline-block; padding: 8px 24px; border-radius: 30px; font-weight: 800; font-size: 0.9rem; letter-spacing: 1px; text-transform: uppercase; position: relative; }

/* Stats */
.stats-row { display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); gap: 16px; margin: 40px auto; max-width: 900px; }
.stat-card { background: #0a1020; border: 1px solid #152040; border-radius: 14px; padding: 24px 16px; text-align: center; }
.stat-value { font-family: 'JetBrains Mono', monospace; font-size: 1.8rem; font-weight: 700; color: #4a8fe7; margin-bottom: 4px; }
.stat-label { font-size: 0.78rem; color: #5a6a80; font-weight: 600; text-transform: uppercase; letter-spacing: 0.5px; }

/* Sections */
h2 { font-size: 1.8rem; font-weight: 800; color: #fff; margin: 60px 0 20px; letter-spacing: -0.5px; border-bottom: 2px solid #152040; padding-bottom: 12px; }
h3 { font-size: 1.3rem; font-weight: 700; color: #e0e6f0; margin: 32px 0 12px; }
p, li { color: #a0aab8; font-size: 1rem; margin-bottom: 16px; }
ul, ol { padding-left: 24px; }
li { margin-bottom: 8px; }
strong { color: #e0e6f0; }
.highlight { color: #4a8fe7; font-weight: 700; }

/* Assumption cards */
.assumption-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); gap: 16px; margin: 24px 0 40px; }
.assumption-card { background: #0a1020; border: 1px solid #152040; border-radius: 14px; padding: 24px; }
.assumption-card .label { font-size: 0.75rem; color: #5a6a80; font-weight: 700; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 8px; }
.assumption-card .value { font-family: 'JetBrains Mono', monospace; font-size: 2rem; font-weight: 700; color: #fff; margin-bottom: 8px; }
.assumption-card .rationale { font-size: 0.85rem; color: #7a8a9e; line-height: 1.5; }

/* Tables */
.table-wrap { overflow-x: auto; margin: 24px 0 40px; border-radius: 14px; border: 1px solid #152040; background: #0a1020; }
table { width: 100%; border-collapse: collapse; }
th { background: #0d1428; padding: 14px 16px; font-size: 0.75rem; color: #5a6a80; font-weight: 700; text-transform: uppercase; letter-spacing: 1px; text-align: right; border-bottom: 2px solid #152040; white-space: nowrap; }
th:first-child { text-align: left; }
td { padding: 14px 16px; font-size: 0.9rem; color: #c8d0de; text-align: right; border-bottom: 1px solid #0d1428; font-family: 'JetBrains Mono', monospace; }
td:first-child { text-align: left; font-family: 'Inter', sans-serif; color: #a0aab8; font-weight: 600; }
tr:hover td { background: rgba(74,143,231,0.03); }
.row-total td { font-weight: 800; color: #fff; border-top: 2px solid #1a2a40; background: rgba(74,143,231,0.04); }
td.highlight-cell { color: #4a8fe7; font-weight: 700; }

/* Sensitivity */
.sensitivity-table th.current { background: rgba(74,143,231,0.15); color: #4a8fe7; }
.sensitivity-table td.current { background: rgba(74,143,231,0.08); color: #4a8fe7; font-weight: 700; }

/* Chart bars */
.bar-chart { margin: 24px 0 40px; }
.bar-row { display: flex; align-items: center; gap: 12px; margin-bottom: 10px; }
.bar-label { width: 48px; font-size: 0.85rem; color: #5a6a80; font-weight: 600; text-align: right; flex-shrink: 0; }
.bar-track { flex: 1; background: #0a1020; border-radius: 8px; height: 32px; overflow: hidden; position: relative; }
.bar-fill { height: 100%; border-radius: 8px; display: flex; align-items: center; padding-left: 12px; font-size: 0.8rem; font-weight: 700; color: #fff; font-family: 'JetBrains Mono', monospace; min-width: 80px; transition: width 0.6s ease; }
.bar-fill.revenue { background: linear-gradient(90deg, #1a3a6e, #4a8fe7); }
.bar-fill.fcf { background: linear-gradient(90deg, #1a5a3e, #10b981); }
.bar-fill.eps { background: linear-gradient(90deg, #5a3a7e, #a78bfa); }

/* Methodology */
.method-step { display: flex; gap: 16px; margin-bottom: 24px; padding: 20px; background: #0a1020; border: 1px solid #152040; border-radius: 14px; }
.step-num { width: 40px; height: 40px; background: rgba(74,143,231,0.12); color: #4a8fe7; font-weight: 800; font-size: 1.1rem; border-radius: 50%; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
.step-content { flex: 1; }
.step-content h4 { color: #e0e6f0; font-size: 1rem; margin-bottom: 6px; }
.step-content p { margin-bottom: 0; font-size: 0.9rem; }

/* Disclaimer */
.disclaimer { margin: 60px 0 0; padding: 24px; background: rgba(239,68,68,0.05); border: 1px solid rgba(239,68,68,0.15); border-radius: 14px; }
.disclaimer h4 { color: #ef4444; margin-bottom: 8px; font-size: 0.85rem; text-transform: uppercase; letter-spacing: 1px; }
.disclaimer p { font-size: 0.85rem; color: #7a8a9e; margin-bottom: 0; }

/* FAQ */
.faq { margin: 40px 0; }
.faq details { background: #0a1020; border: 1px solid #152040; border-radius: 14px; margin-bottom: 12px; overflow: hidden; }
.faq summary { padding: 18px 20px; cursor: pointer; font-weight: 700; color: #e0e6f0; font-size: 1rem; list-style: none; display: flex; justify-content: space-between; align-items: center; }
.faq summary::after { content: '+'; font-size: 1.2rem; color: #4a8fe7; transition: transform 0.2s; }
.faq details[open] summary::after { content: '−'; }
.faq .faq-answer { padding: 0 20px 18px; font-size: 0.9rem; color: #a0aab8; }
</style>

<SiteLayout
  site="westmount"
  title="Newmont (NEM) Intrinsic Value: A DCF Analysis"
  description="We ran a full discounted cash flow on Newmont. One number. Every assumption disclosed. Here's what NEM is really worth."
  canonical="https://westmountfundamentals.com/newmont-intrinsic-value"
  schema={schema}
>

<div class="header">
  <div class="header-content">
    <div class="tag">Compiled by Gemini 3.1</div>
    <h1>Newmont (NEM)<br/>Intrinsic Value</h1>
    <p class="subtitle">A transparent, step-by-step discounted cash flow valuation of Newmont Corporation — using derived assumptions and real financial data.</p>
    <p class="date">Updated March 18, 2026</p>
  </div>
</div>

<div class="container">
  <!-- ═══ THE VERDICT ═══ -->
  <div class="verdict-card">
    <div class="verdict-label">Estimated Intrinsic Value Per Share</div>
    <div class="verdict-price">${roundedIV !== null ? roundedIV.toFixed(2) : 'N/A'}</div>
    <div class="verdict-vs">vs. market price of ${currentPrice !== null ? currentPrice.toFixed(2) : 'N/A'} ({marginOfSafety !== null ? marginOfSafety : '0'}%)</div>
    <div class="verdict-badge" style={`background: ${verdictColor}22; color: ${verdictColor}; border: 1px solid ${verdictColor}44;`}>
      {verdictText}
    </div>
  </div>

  <!-- ═══ KEY METRICS ═══ -->
  <div class="stats-row">
    <div class="stat-card">
      <div class="stat-value">{revHistoryRaw.length > 0 ? '$' + (revHistoryRaw[revHistoryRaw.length - 1].value / 1000).toFixed(1) + 'B' : 'N/A'}</div>
      <div class="stat-label">Latest Revenue</div>
    </div>
    <div class="stat-card">
      <div class="stat-value">${latestFCF !== null ? (latestFCF / 1000).toFixed(1) : 'N/A'}B</div>
      <div class="stat-label">Free Cash Flow</div>
    </div>
    <div class="stat-card">
      <div class="stat-value">${latestOCF !== null ? (latestOCF / 1000).toFixed(1) : 'N/A'}B</div>
      <div class="stat-label">Operating Cash Flow</div>
    </div>
    <div class="stat-card">
      <div class="stat-value">${netCash !== null ? (netCash / 1000).toFixed(1) : 'N/A'}B</div>
      <div class="stat-label">Net Cash</div>
    </div>
  </div>

  <!-- ═══ METHODOLOGY ═══ -->
  <h2>Methodology: Two-Stage DCF</h2>
  <p>We use a <strong>two-stage discounted cash flow (DCF)</strong> model to estimate Newmont's intrinsic value, adapting for the capital-intensive nature of the gold mining industry.</p>

  <div class="method-step">
    <div class="step-num">1</div>
    <div class="step-content">
      <h4>Base Cash Flow Proxy</h4>
      <p>Mining companies often have lumpy and highly volatile Free Cash Flow due to massive upfront capital expenditures. For our base, we use ${baseFCF !== null ? baseFCF.toLocaleString() : 'N/A'} million, derived from recent cash flow data, to better represent normalized cash generating ability.</p>
    </div>
  </div>

  <div class="method-step">
    <div class="step-num">2</div>
    <div class="step-content">
      <h4>Project FCF growth for 5 years (Phase 1)</h4>
      <p>We apply a mathematically derived growth rate of <strong>{growthRatePhase1 !== null ? (growthRatePhase1 * 100).toFixed(1) : 'N/A'}%</strong> per year for 5 years, based on historical operating cash flow trends.</p>
    </div>
  </div>

  <div class="method-step">
    <div class="step-num">3</div>
    <div class="step-content">
      <h4>Calculate terminal value (Phase 2)</h4>
      <p>After Year 5, we assume growth settles at a perpetual rate of <strong>{(growthRateTerminal * 100).toFixed(1)}%</strong>, aligned with long-term inflation and GDP expectations, utilizing the Gordon Growth Model.</p>
    </div>
  </div>

  <div class="method-step">
    <div class="step-num">4</div>
    <div class="step-content">
      <h4>Discount everything to present value</h4>
      <p>Future cash flows are discounted at <strong>{(discountRate * 100).toFixed(1)}%</strong>. This required rate of return is calculated mathematically starting from the 10Y Treasury yield ({ (treasury10Y * 100).toFixed(2) }%) plus an equity risk premium adjusted for Newmont's beta.</p>
    </div>
  </div>

  <div class="method-step">
    <div class="step-num">5</div>
    <div class="step-content">
      <h4>Add net cash, divide by shares</h4>
      <p>Enterprise Value is added to Net Cash (${netCash.toLocaleString()}M). The resulting Equity Value is divided by shares outstanding ({sharesOutstanding !== null ? sharesOutstanding.toLocaleString() : 'N/A'}M) for the per-share value.</p>
    </div>
  </div>

  <!-- ═══ THE THREE ASSUMPTIONS ═══ -->
  <h2>The Three Assumptions That Drive Everything</h2>

  <div class="assumption-grid">
    <div class="assumption-card">
      <div class="label">FCF Growth Rate (Years 1-5)</div>
      <div class="value">{growthRatePhase1 !== null ? (growthRatePhase1 * 100).toFixed(1) : 'N/A'}%</div>
      <div class="rationale">
        Derived mathematically from the historical CAGR of operating cash flows, capped to reflect realistic medium-term expansion in mining production and gold price stabilization.
      </div>
    </div>
    <div class="assumption-card">
      <div class="label">Discount Rate (WACC)</div>
      <div class="value">{(discountRate * 100).toFixed(1)}%</div>
      <div class="rationale">
        Calculated using CAPM: 10Y Treasury ({ (treasury10Y * 100).toFixed(2) }%) + (Beta × ERP). Reflects the required return demanded by investors for bearing the risk of holding Newmont equity.
      </div>
    </div>
    <div class="assumption-card">
      <div class="label">Terminal Growth Rate</div>
      <div class="value">{(growthRateTerminal * 100).toFixed(1)}%</div>
      <div class="rationale">
        Assumes 2.5% long-term nominal economic growth. A mature mining company will typically track inflation and global economic expansion in perpetuity.
      </div>
    </div>
  </div>

  <!-- ═══ FCF PROJECTIONS TABLE ═══ -->
  <h2>Projected Free Cash Flows</h2>
  <div class="table-wrap">
    <table>
      <thead>
        <tr>
          <th style="text-align:left">Year</th>
          <th>FCF ($M)</th>
          <th>PV Factor</th>
          <th>Present Value ($M)</th>
        </tr>
      </thead>
      <tbody>
        <tr>
