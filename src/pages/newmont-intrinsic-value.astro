  <!-- ═══ SENSITIVITY ANALYSIS ═══ -->
  <h2>Sensitivity Analysis</h2>
  <p>Our base case relies on mathematically derived inputs. See how the intrinsic value changes if assumptions are flexed up or down.</p>

  <div class="table-wrap">
    <table class="sensitivity-table">
      <thead>
        <tr>
          <th style="text-align:left">Discount Rate ↓ / Growth →</th>
          {sensitivityGrowth.map(g => (
            <th class={growthRatePhase1 !== null && Math.abs(g - growthRatePhase1) < 0.001 ? 'current' : ''}>{(g * 100).toFixed(1)}%</th>
          ))}
        </tr>
      </thead>
      <tbody>
        {sensitivityTable.map(row => (
          <tr>
            <td>{(row.dr * 100).toFixed(1)}%</td>
            {row.values.map((v, i) => (
              <td class={growthRatePhase1 !== null && Math.abs(row.dr - discountRate) < 0.001 && Math.abs(sensitivityGrowth[i] - growthRatePhase1) < 0.001 ? 'current' : ''}>
                ${v}
              </td>
            ))}
          </tr>
        ))}
      </tbody>
    </table>
