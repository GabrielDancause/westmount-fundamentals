        </div>
      );
    })}
  </div>

  <h3>Free Cash Flow ($M)</h3>
  <div class="bar-chart">
    {fcfHistoryRaw.map(r => {
      const maxVal = Math.max(...fcfHistoryRaw.map(x => Math.abs(x.value)));
      const pct = maxVal > 0 ? (Math.abs(r.value) / maxVal) * 100 : 0;
      const colorStyle = r.value < 0 ? 'background: linear-gradient(90deg, #5a1a1a, #ef4444);' : '';
      return (
        <div class="bar-row">
          <div class="bar-label">{r.year}</div>
          <div class="bar-track">
