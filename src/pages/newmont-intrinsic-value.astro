      const maxVal = Math.max(...revHistoryRaw.map(x => x.value));
      const pct = maxVal > 0 ? (r.value / maxVal) * 100 : 0;
      return (
        <div class="bar-row">
          <div class="bar-label">{r.year}</div>
          <div class="bar-track">
            <div class="bar-fill revenue" style={`width: ${Math.max(10, pct)}%`}>
