.18000001,"marketCap":225768456192,"beta":null,"roe":42.641,"debtEquity":9.727,"revGrowth":3.8},{"symbol":"GNRC","name":"Generac Holdlings Inc.","sector":"Industrials","price":204.1,"pe":75.873604,"dividendYield":null,"marketCap":11977418752,"beta":1.769,"roe":6.2829999999999995,"debtEquity":52.479,"revGrowth":-11.600000000000001},{"symbol":"GD","name":"General Dynamics Corporation","sector":"Industrials","price":355.23,"pe":22.992233,"dividendYield":1.71,"marketCap":96050561024,"beta":0.372,"roe":17.658001000000002,"debtEquity":38.205,"revGrowth":7.8},{"symbol":"GIS","name":"General Mills, Inc.","sector":"Consumer Defensive","price":39.4,"pe":8.473119,"dividendYield":6.1899999999999995,"marketCap":21023135744,"beta":-0.095,"roe":27.173000000000002,"debtEquity":147.23,"revGrowth":-7.199999999999999},{"symbol":"GM","name":"General Motors Company","sector":"Consumer Cyclical","price":73.45,"pe":22.461773,"dividendYield":0.98,"marketCap":68518662144,"beta":1.356,"roe":4.3180000000000005,"debtEquity":208.299,"revGrowth":-5.1},{"symbol":"GPC","name":"Genuine Parts Company","sector":"Consumer Cyclical","price":107.01,"pe":227.68086,"dividendYield":3.9699999999999998,"marketCap":14887457792,"beta":0.734,"roe":1.5,"debtEquity":156.063,"revGrowth":4.1000000000000005}];

        // State
        let filteredData = [...stocksData];
        let currentSort = { column: 'marketCap', direction: 'desc' };

        // DOM Elements
        const tbody = document.getElementById('table-body');
        const searchInput = document.getElementById('search');
        const sectorSelect = document.getElementById('sector');
        const headers = document.querySelectorAll('th');

        // Formatters
        const formatNumber = (num, decimals = 2) => {
            if (num === null || num === undefined) return '<span class="null-val">-</span>';
            return num.toLocaleString('en-US', { minimumFractionDigits: decimals, maximumFractionDigits: decimals });
        };

        const formatBillion = (num) => {
            if (num === null || num === undefined) return '<span class="null-val">-</span>';
            return (num / 1e9).toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
        };

        const formatPercent = (num) => {
            if (num === null || num === undefined) return '<span class="null-val">-</span>';
            return num.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 }) + '%';
        };

        // Initialize
        function init() {
            // Populate Sectors
            const sectors = [...new Set(stocksData.map(s => s.sector).filter(Boolean))].sort();
            sectors.forEach(s => {
                const opt = document.createElement('option');
                opt.value = s;
                opt.textContent = s;
                sectorSelect.appendChild(opt);
            });

            // Event Listeners
            searchInput.addEventListener('input', applyFilters);
            sectorSelect.addEventListener('change', applyFilters);

            const numInputs = ['pe', 'div', 'cap', 'roe', 'beta'];
            numInputs.forEach(prefix => {
                document.getElementById(prefix + '-min').addEventListener('input', applyFilters);
                document.getElementById(prefix + '-max').addEventListener('input', applyFilters);
            });

            document.getElementById('reset-filters').addEventListener('click', () => {
                searchInput.value = '';
                sectorSelect.value = '';
                numInputs.forEach(prefix => {
                    document.getElementById(prefix + '-min').value = '';
                    document.getElementById(prefix + '-max').value = '';
                });
                applyFilters();
            });

            headers.forEach(th => {
                th.addEventListener('click', () => {
                    const column = th.dataset.sort;
                    if (currentSort.column === column) {
                        currentSort.direction = currentSort.direction === 'asc' ? 'desc' : 'asc';
                    } else {
                        currentSort.column = column;
                        currentSort.direction = 'desc';
                    }
                    updateSortIndicators();
                    renderTable();
                });
            });

            updateStats();
            renderTable();
        }

        function getFilterValue(id) {
            const val = document.getElementById(id).value;
            return val === '' ? null : parseFloat(val);
        }

        function applyFilters() {
            const search = searchInput.value.toLowerCase();
            const sector = sectorSelect.value;

            const peMin = getFilterValue('pe-min');
            const peMax = getFilterValue('pe-max');
            const divMin = getFilterValue('div-min');
            const divMax = getFilterValue('div-max');
            const capMin = getFilterValue('cap-min');
            const capMax = getFilterValue('cap-max');
            const roeMin = getFilterValue('roe-min');
            const roeMax = getFilterValue('roe-max');
            const betaMin = getFilterValue('beta-min');
            const betaMax = getFilterValue('beta-max');

            filteredData = stocksData.filter(stock => {
                // Search
                if (search && !stock.symbol.toLowerCase().includes(search) && !stock.name.toLowerCase().includes(search)) return false;

                // Sector
                if (sector && stock.sector !== sector) return false;

                // Numerics
                if (peMin !== null && (stock.pe === null || stock.pe < peMin)) return false;
                if (peMax !== null && (stock.pe === null || stock.pe > peMax)) return false;

                if (divMin !== null && (stock.dividendYield === null || stock.dividendYield < divMin)) return false;
                if (divMax !== null && (stock.dividendYield === null || stock.dividendYield > divMax)) return false;

                const capB = stock.marketCap ? stock.marketCap / 1e9 : null;
                if (capMin !== null && (capB === null || capB < capMin)) return false;
                if (capMax !== null && (capB === null || capB > capMax)) return false;

                if (roeMin !== null && (stock.roe === null || stock.roe < roeMin)) return false;
                if (roeMax !== null && (stock.roe === null || stock.roe > roeMax)) return false;

                if (betaMin !== null && (stock.beta === null || stock.beta < betaMin)) return false;
                if (betaMax !== null && (stock.beta === null || stock.beta > betaMax)) return false;

                return true;
            });

            updateStats();
            renderTable();
        }

        function sortData() {
            const { column, direction } = currentSort;
            filteredData.sort((a, b) => {
                let valA = a[column];
                let valB = b[column];

                // Handle nulls
                if (valA === null && valB === null) return 0;
                if (valA === null) return 1; // Nulls always at bottom
                if (valB === null) return -1;

                if (typeof valA === 'string') {
                    valA = valA.toLowerCase();
                    valB = valB.toLowerCase();
                }

                if (valA < valB) return direction === 'asc' ? -1 : 1;
                if (valA > valB) return direction === 'asc' ? 1 : -1;
                return 0;
            });
        }

        function updateSortIndicators() {
            headers.forEach(th => {
                th.classList.remove('sort-asc', 'sort-desc');
                if (th.dataset.sort === currentSort.column) {
                    th.classList.add('sort-' + currentSort.direction);
                }
            });
        }

        function updateStats() {
            document.getElementById('results-count').textContent = 'Showing ' + filteredData.length + ' results';
            document.getElementById('stat-total').textContent = filteredData.length;

            const peSum = filteredData.reduce((acc, s) => s.pe ? acc + s.pe : acc, 0);
            const peCount = filteredData.filter(s => s.pe).length;
            document.getElementById('stat-pe').textContent = peCount > 0 ? (peSum / peCount).toFixed(2) : '-';

            const divSum = filteredData.reduce((acc, s) => s.dividendYield ? acc + s.dividendYield : acc, 0);
            const divCount = filteredData.filter(s => s.dividendYield).length;
            document.getElementById('stat-div').textContent = divCount > 0 ? (divSum / divCount).toFixed(2) + '%' : '-';
        }

        function renderTable() {
            sortData();
            tbody.innerHTML = '';

            filteredData.forEach(stock => {
                const tr = document.createElement('tr');

                // Truncate name
                const shortName = stock.name.length > 25 ? stock.name.substring(0, 25) + '...' : stock.name;

                tr.innerHTML = `
                    <td><span class="symbol">${stock.symbol}</span></td>
                    <td title="${stock.name}">${shortName}</td>
                    <td><span class="sector-badge">${stock.sector}</span></td>
                    <td>$${formatNumber(stock.price)}</td>
                    <td>${formatBillion(stock.marketCap)}</td>
                    <td>${formatNumber(stock.pe)}</td>
                    <td>${formatPercent(stock.dividendYield)}</td>
                    <td>${formatPercent(stock.roe)}</td>
                    <td>${formatNumber(stock.beta)}</td>
                `;
                tbody.appendChild(tr);
            });
        }

        // Run
        init();
        updateSortIndicators();
  </script>
</SiteLayout>
