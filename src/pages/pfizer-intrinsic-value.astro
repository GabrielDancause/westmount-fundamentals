---
import SiteLayout from "../layouts/SiteLayout.astro";
import * as cheerio from 'cheerio';

const schema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": "Pfizer (PFE) Intrinsic Value: A DCF Analysis",
  "description": "A transparent, step-by-step discounted cash flow valuation of Pfizer Inc. Using actual FY2025 financials to arrive at a single fair value estimate for PFE shares.",
  "datePublished": new Date().toISOString().split('T')[0],
  "dateModified": new Date().toISOString().split('T')[0],
  "author": {
    "@type": "Organization",
    "name": "Westmount Research",
    "url": "https://westmountfundamentals.com"
  },
  "publisher": {
    "@type": "Organization",
    "name": "Westmount Research",
    "url": "https://westmountfundamentals.com"
  },
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": "https://westmountfundamentals.com/pfizer-intrinsic-value"
  }
};

export const meta = {
  title: "Pfizer (PFE) Intrinsic Value: A DCF Analysis",
  description: "We ran a full discounted cash flow on Pfizer using FY2025 actuals. One number. Every assumption disclosed. Here's what PFE is really worth.",
  category: "study",
  published: new Date().toISOString().split('T')[0],
};

/* ═══════════════════════════════════════════════════════════════
   DATA FETCHING FROM STOCKANALYSIS.COM
   ═══════════════════════════════════════════════════════════════ */
async function fetchFromTable(url) {
  try {
    const res = await fetch(url, { headers: { 'User-Agent': 'Mozilla/5.0 (Windows NT 10.0; Win64; x64)' } });
    if (!res.ok) return null;
    const html = await res.text();
    const $ = cheerio.load(html);
    const headers = [];
    $('table thead tr th').each((i, el) => {
      headers.push($(el).text().trim());
    });
    const data = {};
    $('table tbody tr').each((i, row) => {
      const title = $(row).find('td').eq(0).text().trim();
      const values = [];
      $(row).find('td').each((j, col) => {
        if (j > 0) values.push($(col).text().trim().replace(/,/g, '').replace('%', ''));
      });
      data[title] = values;
    });
    return { headers, data };
  } catch (e) {
    return null;
  }
}

async function fetchPrice(ticker) {
  try {
    const res = await fetch(`https://stockanalysis.com/stocks/${ticker}/`, { headers: { 'User-Agent': 'Mozilla/5.0 (Windows NT 10.0; Win64; x64)' } });
    if (!res.ok) return null;
    const html = await res.text();
    const match = html.match(/<div class="[^"]*text-4xl[^"]*">([\d\.]+)<\/div>/);
    if (match) return parseFloat(match[1]);
    const match2 = html.match(/"price":([\d\.]+)/);
    if (match2) return parseFloat(match2[1]);
  } catch (e) {
    return null;
  }
  return null;
}

const is = await fetchFromTable('https://stockanalysis.com/stocks/pfe/financials/');
const bs = await fetchFromTable('https://stockanalysis.com/stocks/pfe/financials/balance-sheet/');
const cf = await fetchFromTable('https://stockanalysis.com/stocks/pfe/financials/cash-flow-statement/');
const fetchedPrice = await fetchPrice('pfe');

const parseVal = (arr, i) => arr && arr[i] !== '-' && arr[i] !== undefined ? parseFloat(arr[i]) : null;

// Extracted metrics for base case calculation
let fcf2025 = parseVal(cf?.data['Free Cash Flow'], 0);
let sharesOutstanding = parseVal(is?.data['Shares Outstanding (Basic)'], 0);
let cashAndEquiv = parseVal(bs?.data['Cash & Equivalents'], 0);
let stInvestments = parseVal(bs?.data['Short-Term Investments'], 0);
let totalDebt = parseVal(bs?.data['Total Debt'], 0);
let rev2025 = parseVal(is?.data['Revenue'], 0);
let eps2025 = parseVal(is?.data['EPS (Diluted)'], 0);
let opMargin2025 = parseVal(is?.data['Operating Margin'], 0);

// Set null fallbacks safely
const fcf2025Val = fcf2025 ?? 9075;
const sharesOutstandingVal = sharesOutstanding ?? 5683;
const cashAndInvestmentsVal = (cashAndEquiv ?? 1142) + (stInvestments ?? 12454);
const totalDebtVal = totalDebt ?? 64795;
const netCash = cashAndInvestmentsVal - totalDebtVal;
const rev2025Val = rev2025 ?? 62579;
const eps2025Val = eps2025 ?? 1.36;
const opMargin2025Val = opMargin2025 ?? 12.02;

// Market comparison
const currentPrice = fetchedPrice ?? 27.32;

// --- ASSUMPTIONS ---
const growthRatePhase1 = 0.04;         // 4% FCF growth, Years 1-5
const growthRateTerminal = 0.02;      // 2% perpetuity growth (terminal)
const discountRate = 0.08;             // 8% WACC / required return

// --- PHASE 1: PROJECT FCF FOR YEARS 1-5 ---
const projectedFCF = [];
let fcf = fcf2025Val;
for (let yr = 1; yr <= 5; yr++) {
  fcf = fcf * (1 + growthRatePhase1);
  projectedFCF.push({ year: yr, fcf: Math.round(fcf), pvFactor: 1 / Math.pow(1 + discountRate, yr) });
}
projectedFCF.forEach(p => { p.pvFCF = Math.round(p.fcf * p.pvFactor); });

// --- PHASE 2: TERMINAL VALUE ---
const fcfYear6 = projectedFCF[4].fcf * (1 + growthRateTerminal);
const terminalValue = Math.round(fcfYear6 / (discountRate - growthRateTerminal));
const pvTerminalValue = Math.round(terminalValue * projectedFCF[4].pvFactor);

// --- ENTERPRISE VALUE ---
const pvPhase1 = projectedFCF.reduce((sum, p) => sum + p.pvFCF, 0);
const enterpriseValue = pvPhase1 + pvTerminalValue;

// --- EQUITY VALUE ---
const equityValue = enterpriseValue + netCash;
const intrinsicValuePerShare = equityValue / sharesOutstandingVal;
const roundedIV = Math.round(intrinsicValuePerShare * 100) / 100;

const marginOfSafety = (((roundedIV - currentPrice) / currentPrice) * 100).toFixed(1);
const verdictText = roundedIV > currentPrice ? "Undervalued" : "Overvalued";
const verdictColor = roundedIV > currentPrice ? "#10b981" : "#ef4444";

// --- HISTORICAL DATA for charts ---
const revenueHistory = is ? is.headers.slice(1, 6).map((yr, i) => {
  return { year: parseInt(yr.replace('FY ', '')) || (2025 - i), value: parseVal(is.data['Revenue'], i) || 0 };
}).reverse() : [];

const fcfHistory = cf ? cf.headers.slice(1, 6).map((yr, i) => {
  return { year: parseInt(yr.replace('FY ', '')) || (2025 - i), value: parseVal(cf.data['Free Cash Flow'], i) || 0 };
}).reverse() : [];

const epsHistory = is ? is.headers.slice(1, 6).map((yr, i) => {
  return { year: parseInt(yr.replace('FY ', '')) || (2025 - i), value: parseVal(is.data['EPS (Diluted)'], i) || 0 };
}).reverse() : [];

const marginHistory = is ? is.headers.slice(1, 6).map((yr, i) => {
  const op = parseVal(is.data['Operating Margin'], i) || 0;
  const pr = parseVal(is.data['Profit Margin'], i) || 0;
  // approximate FCF margin
  const fcfVal = parseVal(cf?.data['Free Cash Flow'], i);
  const revVal = parseVal(is.data['Revenue'], i);
  const fcfM = (fcfVal && revVal) ? (fcfVal / revVal * 100).toFixed(2) : '0.00';
  return { year: parseInt(yr.replace('FY ', '')) || (2025 - i), operating: op, profit: pr, fcfMargin: parseFloat(fcfM) };
}).reverse() : [];

// Sensitivity analysis
const sensitivityRates = [0.06, 0.07, 0.08, 0.09, 0.10];
const sensitivityGrowth = [0.00, 0.02, 0.04, 0.06, 0.08];
const sensitivityTable = sensitivityRates.map(dr => {
  return {
    dr,
    values: sensitivityGrowth.map(gr => {
      let f = fcf2025Val;
      let pvSum = 0;
      for (let y = 1; y <= 5; y++) {
        f = f * (1 + gr);
        pvSum += f / Math.pow(1 + dr, y);
      }
      const f6 = f * (1 + growthRateTerminal);
      const tv = f6 / (dr - growthRateTerminal);
      const pvTV = tv / Math.pow(1 + dr, 5);
      return Math.round((pvSum + pvTV + netCash) / sharesOutstandingVal);
    })
  };
});
