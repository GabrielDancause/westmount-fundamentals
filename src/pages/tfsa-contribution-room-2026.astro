---
import SiteLayout from "../layouts/SiteLayout.astro";

const schema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What is the TFSA contribution room for 2026?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "The TFSA contribution limit for 2026 is $7,000. This is the same limit as 2025 and 2024."
      }
    },
    {
      "@type": "Question",
      "name": "What is the cumulative TFSA limit for 2026?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "The cumulative TFSA contribution limit for 2026 is $109,000. This applies if you were born in 1991 or earlier, have been a Canadian resident since 2009, and have never contributed to a TFSA before."
      }
    },
    {
      "@type": "Question",
      "name": "How is TFSA contribution room calculated?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Your TFSA contribution room is calculated by adding your annual TFSA limits for every year since 2009 that you were 18 or older and a resident of Canada, minus any contributions you have made, plus any withdrawals you made in previous years."
      }
    },
    {
      "@type": "Question",
      "name": "Do I get my TFSA room back if I withdraw money?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes. Any amount you withdraw from your TFSA is added back to your contribution room, but not until the following calendar year (January 1st)."
      }
    },
    {
      "@type": "Question",
      "name": "What happens if I overcontribute to my TFSA?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "If you contribute more than your available room, the CRA will charge a penalty tax of 1% per month on the highest excess amount in the month. You should withdraw the excess amount immediately to stop the penalty from growing."
      }
    }
  ]
};

export const meta = {
  title: "TFSA Contribution Room & Limits (2026 Calculator)",
  description: "Interactive 2026 TFSA contribution room calculator. Find your exact limit, see the history of changes from 2009-2026, and track your cumulative room.",
  category: "tool",
  published: "2026-03-15",
};
---

<SiteLayout
  site="westmount"
  title="TFSA Contribution Room & Limits (2026 Calculator)"
  description="Interactive 2026 TFSA contribution room calculator. Find your exact limit, see the history of changes from 2009-2026, and track your cumulative room."
  canonical="https://westmountfundamentals.com/tfsa-contribution-room-2026" schema={schema}
>
  <style>

    * { margin: 0; padding: 0; box-sizing: border-box; }

    body {
      font-family: 'Inter', -apple-system, sans-serif;
      background: var(--bg-color);
      color: var(--text-main);
      line-height: 1.6;
    }

    /* Nav */
    nav {
      position: sticky;
      top: 0;
      z-index: 1000;
      background: rgba(6, 10, 18, 0.85);
      backdrop-filter: blur(12px);
      border-bottom: 1px solid var(--border-color);
      padding: 16px 24px;
      display: flex;
      justify-content: space-between;
      align-items: center;
    }
    .nav-brand {
      color: #fff;
      font-weight: 800;
      text-decoration: none;
      font-size: 1.1rem;
      letter-spacing: -0.5px;
    }
    .nav-links { display: flex; gap: 24px; }
    .nav-links a {
      color: var(--text-muted);
      text-decoration: none;
      font-size: 0.9rem;
      font-weight: 600;
      transition: color 0.2s;
    }
    .nav-links a:hover { color: var(--accent-color); }

    /* Layout */
    .container {
      max-width: 1000px;
      margin: 0 auto;
      padding: 60px 24px;
    }

    /* Header */
    header { text-align: center; margin-bottom: 50px; }
    h1 {
      font-size: 3rem;
      font-weight: 900;
      letter-spacing: -1.5px;
      margin-bottom: 16px;
      background: linear-gradient(90deg, #fff, #4a8fe7);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      line-height: 1.2;
    }
    .subtitle {
      font-size: 1.1rem;
      color: var(--text-muted);
      max-width: 600px;
      margin: 0 auto;
    }

    /* Stats Row */
    .stats-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
      gap: 20px;
      margin-bottom: 40px;
    }
    .stat-card {
      background: var(--card-bg);
      border: 1px solid var(--border-color);
      border-radius: 12px;
      padding: 24px;
      text-align: center;
    }
    .stat-val {
      font-size: 2.2rem;
      font-weight: 800;
      color: var(--accent-color);
      font-family: 'JetBrains Mono', monospace;
      line-height: 1;
      margin-bottom: 8px;
    }
    .stat-label { font-size: 0.85rem; color: var(--text-muted); font-weight: 600; text-transform: uppercase; letter-spacing: 0.5px; }

    /* Calculator Section */
    .calc-section {
      background: linear-gradient(145deg, var(--card-bg) 0%, #0d1428 100%);
      border: 1px solid var(--border-color);
      border-radius: 16px;
      padding: 40px;
      margin-bottom: 50px;
    }
    .calc-title {
      font-size: 1.8rem;
      font-weight: 800;
      color: #fff;
      margin-bottom: 24px;
      text-align: center;
    }
    .calc-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 30px;
      align-items: stretch;
    }
    .input-group { margin-bottom: 20px; }
    label {
      display: block;
      font-size: 0.9rem;
      font-weight: 600;
      color: #e0e8f0;
      margin-bottom: 8px;
    }
    input {
      width: 100%;
      background: var(--bg-color);
      border: 1px solid var(--border-color);
      color: #fff;
      padding: 14px;
      border-radius: 8px;
      font-family: 'JetBrains Mono', monospace;
      font-size: 1rem;
    }
    input:focus { outline: none; border-color: var(--accent-color); }
    button {
      width: 100%;
      background: var(--accent-color);
      color: #fff;
      border: none;
      padding: 16px;
      border-radius: 8px;
      font-size: 1rem;
      font-weight: 700;
      cursor: pointer;
      transition: background 0.2s;
    }
    button:hover { background: #3a7bd5; }

    .result-box {
      background: var(--bg-color);
      border: 1px solid var(--accent-color);
      border-radius: 12px;
      padding: 30px;
      display: flex;
      flex-direction: column;
      justify-content: center;
      align-items: center;
      text-align: center;
    }
    .result-label { font-size: 0.9rem; color: var(--text-muted); font-weight: 600; margin-bottom: 12px; }
    .result-val { font-size: 3rem; font-weight: 900; color: #fff; font-family: 'JetBrains Mono', monospace; line-height: 1; }
    .result-note { font-size: 0.8rem; color: var(--text-muted); margin-top: 16px; max-width: 250px; }

    /* Chart Section */
    .chart-container {
      background: var(--card-bg);
      border: 1px solid var(--border-color);
      border-radius: 12px;
      padding: 30px;
      margin-bottom: 50px;
      height: 400px;
      position: relative;
    }

    /* Table Section */
    .table-container {
      background: var(--card-bg);
      border: 1px solid var(--border-color);
      border-radius: 12px;
      overflow: hidden;
      margin-bottom: 50px;
    }
    table { width: 100%; border-collapse: collapse; }
    th, td { padding: 16px 24px; text-align: right; }
    th:first-child, td:first-child { text-align: left; }
    th {
      background: rgba(21, 32, 64, 0.5);
      color: #fff;
      font-size: 0.85rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.5px;
      border-bottom: 1px solid var(--border-color);
    }
    td {
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.95rem;
      border-bottom: 1px solid var(--border-color);
    }
    tr:last-child td { border-bottom: none; }
    tr:hover td { background: rgba(74, 143, 231, 0.05); }

    /* Content Sections */
    .content-section {
      background: var(--card-bg);
      border: 1px solid var(--border-color);
      border-radius: 12px;
      padding: 40px;
      margin-bottom: 50px;
    }
    h2 { font-size: 1.8rem; font-weight: 800; color: #fff; margin-bottom: 24px; }
    h3 { font-size: 1.2rem; font-weight: 700; color: #e0e8f0; margin-bottom: 12px; margin-top: 24px; }
    p { margin-bottom: 16px; color: var(--text-main); }

    .faq-item {
      border-bottom: 1px solid var(--border-color);
      padding: 24px 0;
    }
    .faq-item:last-child { border-bottom: none; }
    .faq-q { font-size: 1.1rem; font-weight: 700; color: #fff; margin-bottom: 12px; }
    .faq-a { color: var(--text-main); }

    /* Footer */
    footer {
      text-align: center;
      padding: 40px 24px;
      border-top: 1px solid var(--border-color);
      font-size: 0.85rem;
      color: var(--text-muted);
    }
    footer a { color: var(--accent-color); text-decoration: none; }

    /* Responsive */
    @media (max-width: 768px) {
      h1 { font-size: 2.2rem; }
      .calc-grid { grid-template-columns: 1fr; }
      .nav-links { display: none; }
      .chart-container { height: 300px; padding: 15px; }
      th, td { padding: 12px 16px; }
    }
  </style>

<div class="container">
    <h1>TFSA Contribution Room & Limits (2026 Calculator)</h1>


    <div class="stats-grid">
      <div class="stat-card">
        <div class="stat-val">$7,000</div>
        <div class="stat-label">2026 Limit</div>
      </div>
      <div class="stat-card">
        <div class="stat-val">$109,000</div>
        <div class="stat-label">Max Cumulative Room</div>
      </div>
      <div class="stat-card">
        <div class="stat-val">18</div>
        <div class="stat-label">Years of TFSA History</div>
      </div>
    </div>

    <div class="calc-section">
      <h2 class="calc-title">Interactive TFSA Calculator</h2>
      <div class="calc-grid">
        <div class="calc-inputs">
          <div class="input-group">
            <label for="birthYear">Birth Year</label>
            <input type="number" id="birthYear" placeholder="e.g. 1995" value="1990" min="1900" max="2026">
          </div>
          <div class="input-group">
            <label for="pastContributions">Total Previous Contributions ($)</label>
            <input type="number" id="pastContributions" placeholder="0" value="0" min="0">
          </div>
          <div class="input-group">
            <label for="pastWithdrawals">Total Previous Withdrawals ($)</label>
            <input type="number" id="pastWithdrawals" placeholder="0" value="0" min="0">
          </div>
          <button id="calcBtn">Calculate Available Room</button>
        </div>
        <div class="calc-result">
          <div class="result-box">
            <div class="result-label">YOUR 2026 AVAILABLE ROOM</div>
            <div class="result-val" id="resultRoom">$109,000</div>
            <div class="result-note">Assumes you have been a Canadian resident since turning 18. Withdrawals made in the current year are not added back until next year.</div>
          </div>
        </div>
      </div>
    </div>

    <div class="chart-container">
      <canvas id="tfsaChart"></canvas>
    </div>

    <div class="content-section">
      <h2>TFSA Limit History (2009-2026)</h2>
      <p>The Tax-Free Savings Account (TFSA) was introduced in 2009. The annual contribution limit is indexed to inflation and rounded to the nearest $500. Below is the historical data showing annual and cumulative limits.</p>

      <div class="table-container">
        <table>
          <thead>
            <tr>
              <th>Year</th>
              <th>Annual Limit</th>
              <th>Cumulative Room</th>
            </tr>
          </thead>
          <tbody id="tableBody">
            <!-- Populated by JS -->
          </tbody>
        </table>
      </div>
    </div>

    <div class="content-section">
      <h2>Frequently Asked Questions</h2>

      <div class="faq-item">
        <div class="faq-q">What is the TFSA contribution room for 2026?</div>
        <div class="faq-a">The TFSA contribution limit for 2026 is $7,000. This is the same limit as 2025 and 2024. The federal government sets this limit based on inflation rounding rules.</div>
      </div>

      <div class="faq-item">
        <div class="faq-q">What is the cumulative TFSA limit for 2026?</div>
        <div class="faq-a">The cumulative TFSA contribution limit for 2026 is $109,000. This maximum amount applies to individuals who were born in 1991 or earlier, have been a Canadian resident since 2009, and have never contributed to a TFSA.</div>
      </div>

      <div class="faq-item">
        <div class="faq-q">How is TFSA contribution room calculated?</div>
        <div class="faq-a">Your TFSA contribution room is calculated by adding your annual TFSA limits for every year since 2009 that you were 18 or older and a resident of Canada, subtracting any contributions you have made, and adding back any withdrawals you made in previous calendar years.</div>
      </div>

      <div class="faq-item">
        <div class="faq-q">Do I get my TFSA room back if I withdraw money?</div>
        <div class="faq-a">Yes. Any amount you withdraw from your TFSA is added back to your available contribution room, but not until the following calendar year (January 1st). If you withdraw and re-contribute in the same year, you could face over-contribution penalties.</div>
      </div>

      <div class="faq-item">
        <div class="faq-q">What happens if I overcontribute to my TFSA?</div>
        <div class="faq-a">If you contribute more than your available room, the Canada Revenue Agency (CRA) will charge a penalty tax of 1% per month on the highest excess amount in the month. To stop the penalty from growing, you must withdraw the excess amount immediately.</div>
      </div>
    </div>

    <div class="content-section">
      <h2>Methodology & Data Sources</h2>
      <p>Data presented on this page is based on historical and current limits published by the Canada Revenue Agency (CRA). The TFSA program began in 2009. Annual limits are subject to change based on federal government indexing to inflation, rounded to the nearest $500 step. Individuals must be 18 years of age and a Canadian resident to accumulate room for any given year.</p>
    </div>

  </div>
  <script is:inline>
// Embedded Data: REAL TFSA limits 2009-2026
    const tfsaData = [
      { year: 2009, limit: 5000, cumulative: 5000 },
      { year: 2010, limit: 5000, cumulative: 10000 },
      { year: 2011, limit: 5000, cumulative: 15000 },
      { year: 2012, limit: 5000, cumulative: 20000 },
      { year: 2013, limit: 5500, cumulative: 25500 },
      { year: 2014, limit: 5500, cumulative: 31000 },
      { year: 2015, limit: 10000, cumulative: 41000 },
      { year: 2016, limit: 5500, cumulative: 46500 },
      { year: 2017, limit: 5500, cumulative: 52000 },
      { year: 2018, limit: 5500, cumulative: 57500 },
      { year: 2019, limit: 6000, cumulative: 63500 },
      { year: 2020, limit: 6000, cumulative: 69500 },
      { year: 2021, limit: 6000, cumulative: 75500 },
      { year: 2022, limit: 6000, cumulative: 81500 },
      { year: 2023, limit: 6500, cumulative: 88000 },
      { year: 2024, limit: 7000, cumulative: 95000 },
      { year: 2025, limit: 7000, cumulative: 102000 },
      { year: 2026, limit: 7000, cumulative: 109000 }
    ];

    // Format currency
    const formatMoney = (amount) => {
      return new Intl.NumberFormat('en-CA', {
        style: 'currency',
        currency: 'CAD',
        maximumFractionDigits: 0
      }).format(amount);
    };

    // Populate Table
    const tableBody = document.getElementById('tableBody');
    tfsaData.forEach(row => {
      const tr = document.createElement('tr');
      tr.innerHTML = `
        <td>${row.year}</td>
        <td>${formatMoney(row.limit)}</td>
        <td>${formatMoney(row.cumulative)}</td>
      `;
      tableBody.appendChild(tr);
    });

    // Chart.js Visualization
    const ctx = document.getElementById('tfsaChart').getContext('2d');
    const years = tfsaData.map(d => d.year);
    const cumulativeLimits = tfsaData.map(d => d.cumulative);
    const annualLimits = tfsaData.map(d => d.limit);

    new Chart(ctx, {
      type: 'bar',
      data: {
        labels: years,
        datasets: [
          {
            label: 'Cumulative Limit ($)',
            data: cumulativeLimits,
            type: 'line',
            borderColor: '#4a8fe7',
            backgroundColor: 'rgba(74, 143, 231, 0.1)',
            borderWidth: 3,
            fill: true,
            tension: 0.1,
            yAxisID: 'y'
          },
          {
            label: 'Annual Limit ($)',
            data: annualLimits,
            type: 'bar',
            backgroundColor: '#152040',
            borderColor: '#3a7bd5',
            borderWidth: 1,
            yAxisID: 'y1'
          }
        ]
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        interaction: {
          mode: 'index',
          intersect: false,
        },
        plugins: {
          legend: {
            labels: { color: '#c8d0de' }
          },
          tooltip: {
            backgroundColor: 'rgba(10, 16, 32, 0.9)',
            titleColor: '#fff',
            bodyColor: '#c8d0de',
            borderColor: '#152040',
            borderWidth: 1,
            callbacks: {
              label: function(context) {
                let label = context.dataset.label || '';
                if (label) { label += ': '; }
                if (context.parsed.y !== null) {
                  label += formatMoney(context.parsed.y);
                }
                return label;
              }
            }
          }
        },
        scales: {
          x: {
            grid: { color: '#152040', drawBorder: false },
            ticks: { color: '#5a6a80' }
          },
          y: {
            type: 'linear',
            display: true,
            position: 'left',
            grid: { color: '#152040', drawBorder: false },
            ticks: {
              color: '#5a6a80',
              callback: function(value) { return '$' + value / 1000 + 'k'; }
            }
          },
          y1: {
            type: 'linear',
            display: true,
            position: 'right',
            grid: { drawOnChartArea: false },
            ticks: {
              color: '#5a6a80',
              callback: function(value) { return '$' + value; }
            }
          }
        }
      }
    });

    // Calculator Logic
    const calcBtn = document.getElementById('calcBtn');
    calcBtn.addEventListener('click', () => {
      const birthYear = parseInt(document.getElementById('birthYear').value) || 0;
      const contributions = parseFloat(document.getElementById('pastContributions').value) || 0;
      const withdrawals = parseFloat(document.getElementById('pastWithdrawals').value) || 0;

      let totalRoom = 0;

      // Calculate eligible years (must be 18 or older)
      tfsaData.forEach(data => {
        // Individual turns 18 in the year they reach 18 years of age.
        // E.g., born in 1991: turns 18 in 2009. Eligible for 2009.
        if (data.year - birthYear >= 18) {
          totalRoom += data.limit;
        }
      });

      // Available room = Total eligible room - contributions + past withdrawals
      let availableRoom = totalRoom - contributions + withdrawals;

      // Room cannot be negative from standard contributions, but overcontributions make it negative.
      // We'll show the actual calculated value, even if negative (indicating overcontribution).

      document.getElementById('resultRoom').textContent = formatMoney(availableRoom);

      if (availableRoom < 0) {
        document.getElementById('resultRoom').style.color = '#ef4444'; // Red for overcontribution
        document.querySelector('.result-note').textContent = "Warning: A negative balance indicates a potential overcontribution. You may be subject to CRA penalties.";
      } else {
        document.getElementById('resultRoom').style.color = '#fff';
        document.querySelector('.result-note').textContent = "Assumes you have been a Canadian resident since turning 18. Withdrawals made in the current year are not added back until next year.";
      }
    });

    // Trigger initial calculation
    calcBtn.click();
  </script>
</SiteLayout>
