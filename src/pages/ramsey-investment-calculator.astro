<script is:inline>
  document.addEventListener("DOMContentLoaded", () => {
    const initialInput = document.getElementById("initialInvestment");
    const monthlyInput = document.getElementById("monthlyContribution");
    const yearsInput = document.getElementById("yearsToGrow");
    const rateInput = document.getElementById("interestRate");
    const calcBtn = document.getElementById("calculateBtn");

    const totalValueEl = document.getElementById("totalValue");
    const totalPrincipalEl = document.getElementById("totalPrincipal");
    const totalInterestEl = document.getElementById("totalInterest");
    const conservativeValueEl = document.getElementById("conservativeValue");
    // valueDifference is dynamically recreated

    const formatCurrency = (value) => {
      return new Intl.NumberFormat('en-US', {
        style: 'currency',
        currency: 'USD',
        minimumFractionDigits: 2,
        maximumFractionDigits: 2
      }).format(value);
    };

    const calculateCompoundInterest = (principal, monthly, years, annualRate) => {
      // Handle edge cases
      if (principal < 0) principal = 0;
      if (monthly < 0) monthly = 0;
      if (years < 0) years = 0;

      const r = annualRate / 100;
      const n = 12; // Compounded monthly
      const t = years;

      // If rate is 0 or negative
      if (r <= 0) {
        return principal + (monthly * 12 * t);
      }

      // Principal compound interest: A = P(1 + r/n)^(nt)
      const principalFutureValue = principal * Math.pow((1 + r/n), (n * t));

      // Future value of a series (annuity): PMT × [((1 + r/n)^(nt) - 1) / (r/n)]
      const pmtFutureValue = monthly * ((Math.pow((1 + r/n), (n * t)) - 1) / (r / n));

      let result = principalFutureValue + pmtFutureValue;

      // Precision handling
      let fixed = parseFloat(result.toPrecision(14));
      if (Math.abs(fixed - Math.round(fixed)) < 1e-14) {
        return Math.round(fixed);
      }
      return fixed;
    };

    const updateCalculations = () => {
      let principal = parseFloat(initialInput.value) || 0;
      let monthly = parseFloat(monthlyInput.value) || 0;
      let years = parseFloat(yearsInput.value) || 0;
      let rate = parseFloat(rateInput.value) || 0;

      // Main calculation
      const futureValue = calculateCompoundInterest(principal, monthly, years, rate);
      const totalInvested = principal + (monthly * 12 * years);
      const interestEarned = futureValue - totalInvested;

      // Conservative calculation (always at 8%)
      const conservativeRate = 8;
      const conservativeValue = calculateCompoundInterest(principal, monthly, years, conservativeRate);
      const diff = futureValue - conservativeValue;

      // Update UI
      totalValueEl.textContent = formatCurrency(futureValue);
      totalPrincipalEl.textContent = formatCurrency(totalInvested);
      totalInterestEl.textContent = formatCurrency(Math.max(0, interestEarned));

      conservativeValueEl.textContent = formatCurrency(conservativeValue);
      // valueDifference updated inside diffContainer logic

      // Adjust text based on whether the main rate is higher or lower than the conservative rate
      const diffContainer = document.querySelector('.difference-text');
      if (diffContainer) {
        if (rate > conservativeRate) {
          diffContainer.textContent = "That's a difference of ";
          const strong = document.createElement("strong");
          strong.id = "valueDifference";
          strong.textContent = formatCurrency(diff);
          diffContainer.appendChild(strong);
        } else if (rate < conservativeRate) {
          diffContainer.textContent = "The 8% return would give you ";
          const strong = document.createElement("strong");
          strong.id = "valueDifference";
          strong.textContent = formatCurrency(Math.abs(diff));
          diffContainer.appendChild(strong);
          diffContainer.appendChild(document.createTextNode(" more."));
        } else {
          diffContainer.textContent = `This matches the conservative 8% estimate.`;
        }
      }
    };

    // Calculate on button click
    calcBtn.addEventListener("click", updateCalculations);

    // Also calculate on any input change for real-time calculation
    const inputs = [initialInput, monthlyInput, yearsInput, rateInput];
    inputs.forEach(input => {
      input.addEventListener("input", updateCalculations);
    });

    // Initial calculation on load
    updateCalculations();
  });
</script>
