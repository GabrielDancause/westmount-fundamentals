    }

    function formatPercent(val) {
      return new Intl.NumberFormat('en-US', { style: 'percent', minimumFractionDigits: 1, maximumFractionDigits: 1 }).format(val / 100);
    }

    function generateMatrixRow(price, intrinsic, profit, risk) {
      const returnPct = risk > 0 ? (profit / risk) * 100 : 0;
      let profitClass = '';
      if (profit > 0) profitClass = 'positive';
      else if (profit < 0) profitClass = 'negative';

      return `
        <tr>
          <td>${formatCurrency(price)}</td>
          <td>${formatCurrency(intrinsic)}</td>
          <td class="${profitClass}"><strong>${formatCurrency(profit)}</strong></td>
          <td class="${profitClass}">${formatPercent(returnPct)}</td>
        </tr>
      `;
    }

    function calculateProfit() {
      const type = document.getElementById('optionType').value;
      const strike = parseFloat(document.getElementById('strikePrice').value);
      const premium = parseFloat(document.getElementById('premium').value);
      const contracts = parseInt(document.getElementById('contracts').value, 10);
      const currentPrice = parseFloat(document.getElementById('currentPrice').value);
      const target = parseFloat(document.getElementById('targetPrice').value);

      const errorMsg = document.getElementById('error-message');
      const matrixContainer = document.getElementById('matrixContainer');

      // Edge case handling: Validate inputs
      if (isNaN(strike) || isNaN(premium) || isNaN(contracts) || isNaN(currentPrice) || isNaN(target) ||
          strike <= 0 || premium <= 0 || contracts < 1 || currentPrice <= 0 || target < 0) {
        errorMsg.style.display = 'block';
        matrixContainer.style.display = 'none';

        // Reset outputs
        document.getElementById('resBreakeven').innerText = '$0.00';
        document.getElementById('resMaxLoss').innerText = '-$0.00';
        document.getElementById('resMaxProfit').innerText = '$0.00';
        document.getElementById('resTargetPL').innerText = '$0.00';
        return;
      }

      errorMsg.style.display = 'none';
      matrixContainer.style.display = 'block';

      // Core Calculations
      // Fix floating point errors with integer cents
      const premiumCents = Math.round(premium * 100);
      const totalRisk = premiumCents * contracts * 100; // Total Max Loss in cents

      let breakeven, maxProfit, targetPL;

      if (type === 'call') {
        breakeven = strike + premium;
        maxProfit = Infinity;

        // Target Profit calculation
        const intrinsicCents = target > strike ? Math.round((target - strike) * 100) * 100 * contracts : 0;
        targetPL = intrinsicCents - totalRisk;

      } else { // Put
        breakeven = strike - premium;
        // Max profit is if stock goes to 0
        const maxIntrinsicCents = Math.round(strike * 100) * 100 * contracts;
        maxProfit = (maxIntrinsicCents - totalRisk) / 100; // Convert back to dollars

        // Target Profit calculation
        const intrinsicCents = target < strike ? Math.round((strike - target) * 100) * 100 * contracts : 0;
        targetPL = intrinsicCents - totalRisk;
      }

      // Update UI Result Cards
      document.getElementById('resBreakeven').innerText = formatCurrency(breakeven);
      document.getElementById('resMaxLoss').innerText = '-' + formatCurrency(totalRisk / 100);

      if (maxProfit === Infinity) {
        document.getElementById('resMaxProfit').innerText = 'Infinite';
      } else {
        document.getElementById('resMaxProfit').innerText = formatCurrency(maxProfit);
      }

      const targetEl = document.getElementById('resTargetPL');
      targetEl.innerText = formatCurrency(targetPL / 100);
      targetEl.className = 'result-value ' + (targetPL > 0 ? 'positive' : (targetPL < 0 ? 'negative' : ''));

      // Generate Payout Matrix Table
      const tbody = document.querySelector('#payoutMatrix tbody');
      let html = '';

      // Determine steps based on current price for reasonable spread
      const step = currentPrice * 0.05; // 5% increments

      // Create price points: from -30% to +30% around current price
      const pricePoints = [];
      for (let i = -6; i <= 6; i++) {
        let p = currentPrice + (i * step);
        if (p < 0) p = 0; // Prevent negative prices
        pricePoints.push(p);
      }

      // Add breakeven point and target point, then sort and deduplicate
      pricePoints.push(breakeven);
      if(target > 0) pricePoints.push(target);

      // Unique and sorted
      const uniquePrices = [...new Set(pricePoints.map(p => Math.round(p * 100) / 100))].sort((a, b) => a - b);

      // Filter extreme outlier prices (e.g. if target was 1000 and current is 10)
      const filteredPrices = uniquePrices.filter(p => p >= 0);

      filteredPrices.forEach(price => {
        let intrinsicValueCents = 0;
        let netProfitCents = 0;

        if (type === 'call') {
          intrinsicValueCents = price > strike ? Math.round((price - strike) * 100) * 100 * contracts : 0;
        } else {
          intrinsicValueCents = price < strike ? Math.round((strike - price) * 100) * 100 * contracts : 0;
        }

        netProfitCents = intrinsicValueCents - totalRisk;

        // Convert to dollars for display
        const intrinsicValue = intrinsicValueCents / 100;
        const netProfit = netProfitCents / 100;
        const riskDollars = totalRisk / 100;

        html += generateMatrixRow(price, intrinsicValue, netProfit, riskDollars);
      });

      tbody.innerHTML = html;
    }

    // Attach Event Listeners
    document.addEventListener('DOMContentLoaded', () => {
      const inputs = ['optionType', 'strikePrice', 'premium', 'contracts', 'currentPrice', 'targetPrice'];
      inputs.forEach(id => {
        const el = document.getElementById(id);
        if(el) {
          el.addEventListener('input', calculateProfit);
        }
      });

      // Run initial calculation
      calculateProfit();
    });
  </script>

