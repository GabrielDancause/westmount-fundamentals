        function formatPercent(val) {
            if (val === null || val === undefined) return 'N/A';
            return val.toFixed(2) + '%';
        }

        function formatCurrency(val) {
            if (val === null || val === undefined) return 'N/A';
            if (val >= 1e9) return '$' + (val / 1e9).toFixed(1) + 'B';
            if (val >= 1e6) return '$' + (val / 1e6).toFixed(1) + 'M';
            return '$' + val.toLocaleString();
        }

        function getColorClass(val) {
            if (val === null || val === undefined) return '';
            if (val > 0) return 'positive';
            if (val < 0) return 'negative';
            return '';
        }

        let currentSort = { column: 'yield', asc: false };

        function renderTable(data) {
            const tbody = document.getElementById('etfBody');
            tbody.innerHTML = '';

            data.forEach(etf => {
                const tr = document.createElement('tr');
                const durStr = etf.duration !== null ? etf.duration.toFixed(1) + ' yrs' : 'N/A';
                tr.innerHTML = `
                    <td class="td-symbol">${etf.symbol}</td>
                    <td class="td-name">${etf.name}</td>
                    <td>${etf.category}</td>
                    <td>${formatPercent(etf.yield)}</td>
                    <td>${durStr}</td>
                    <td>${formatPercent(etf.expenseRatio)}</td>
                    <td class="${getColorClass(etf.ytdReturn)}">${formatPercent(etf.ytdReturn)}</td>
                    <td class="${getColorClass(etf.fiveYearReturn)}">${formatPercent(etf.fiveYearReturn)}</td>
                    <td>${formatCurrency(etf.aum)}</td>
                `;
                tbody.appendChild(tr);
            });
        }

        function sortData(column) {
            if (currentSort.column === column) {
                currentSort.asc = !currentSort.asc;
            } else {
                currentSort.column = column;
                currentSort.asc = true;
            }

            const sorted = [...etfData].sort((a, b) => {
                let valA = a[column];
                let valB = b[column];

                if (valA === null) valA = currentSort.asc ? Infinity : -Infinity;
                if (valB === null) valB = currentSort.asc ? Infinity : -Infinity;

                if (typeof valA === 'string') {
                    return currentSort.asc ? valA.localeCompare(valB) : valB.localeCompare(valA);
                }

                return currentSort.asc ? valA - valB : valB - valA;
            });

            filterAndRender(sorted);
        }

        function filterAndRender(data) {
            const query = document.getElementById('searchInput').value.toLowerCase();
            const filtered = data.filter(etf =>
                etf.symbol.toLowerCase().includes(query) ||
                etf.name.toLowerCase().includes(query) ||
                etf.category.toLowerCase().includes(query)
            );
            renderTable(filtered);
        }

        document.getElementById('searchInput').addEventListener('keyup', () => filterAndRender(etfData));

        document.querySelectorAll('th[data-sort]').forEach(th => {
            th.addEventListener('click', () => {
                sortData(th.getAttribute('data-sort'));
            });
        });

        // Initialize Stats
        const validYields = etfData.filter(d => d.yield !== null);
        if (validYields.length > 0) {
            const avgYield = validYields.reduce((sum, d) => sum + d.yield, 0) / validYields.length;
            document.getElementById('stat-avg-yield').innerText = avgYield.toFixed(2) + '%';

            const highestYield = validYields.reduce((prev, curr) => (prev.yield > curr.yield) ? prev : curr);
            document.getElementById('stat-highest-yield').innerText = highestYield.yield.toFixed(2) + '%';
            document.getElementById('stat-high-ticker').innerText = highestYield.symbol;
        }

        const validExps = etfData.filter(d => d.expenseRatio !== null);
        if (validExps.length > 0) {
            const avgExp = validExps.reduce((sum, d) => sum + d.expenseRatio, 0) / validExps.length;
            document.getElementById('stat-avg-exp').innerText = avgExp.toFixed(2) + '%';
        }

        // Initialize Chart
        const ctx = document.getElementById('yieldChart').getContext('2d');
        const sortedForChart = [...etfData].sort((a,b) => (b.yield || 0) - (a.yield || 0));

        new Chart(ctx, {
            type: 'bar',
            data: {
                labels: sortedForChart.map(d => d.symbol),
                datasets: [{
                    label: 'Dividend Yield (%)',
                    data: sortedForChart.map(d => d.yield || 0),
                    backgroundColor: '#4a8fe7',
                    borderRadius: 4
                }]
            },
            options: {
                responsive: true,
                plugins: {
                    legend: {
                        labels: { color: '#f3f4f6' }
                    }
                },
                scales: {
                    y: {
                        beginAtZero: true,
                        grid: { color: '#152040' },
                        ticks: { color: '#9ca3af' }
                    },
                    x: {
                        grid: { display: false },
                        ticks: { color: '#9ca3af' }
                    }
                }
            }
        });

        // Initial Sort and Render
        sortData('yield'); // Default sort by yield descending
  </script>

  
