  "description": "Compare commissions, options fees, margin rates, and features across 22 online brokers in the US and Canada.",
  "datePublished": "2026-03-09",
  "dateModified": "2026-03-09",
  "publisher": {
    "@type": "Organization",
    "name": "Westmount Research",
    "url": "https://westmountfundamentals.com"
  },
  "author": {
    "@type": "Organization",
    "name": "Westmount Research"
  }
};

export const meta = {
  title: "Online Broker Fee Comparison 2026 — Westmount Research",
