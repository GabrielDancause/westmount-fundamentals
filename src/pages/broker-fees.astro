// Render margin rate chart
function renderChart(){
  const withMargin=data.filter(d=>d.marginRate!==null).sort((a,b)=>a.marginRate-b.marginRate);
  const maxRate=Math.max(...withMargin.map(d=>d.marginRate));
  const container=document.getElementById('marginChart');
  container.innerHTML=withMargin.map(d=>{
    const pct=(d.marginRate/maxRate*100).toFixed(1);
    const cls=d.marginRate<7?'low':d.marginRate<10?'mid':'high';
    return `<div class="bar-row">
      <div class="bar-name">${d.name.replace(/ \(.*\)/,'')}</div>
      <div class="bar-track"><div class="bar-fill ${cls}" style="width:${pct}%">${d.marginRate.toFixed(2)}%</div></div>
    </div>`;
  }).join('');
}

// Render table
let sortCol='marginRate',sortDir='asc';
function renderTable(){
  const country=document.getElementById('countryFilter').value;
  const search=document.getElementById('searchInput').value.toLowerCase();
  let filtered=data.filter(d=>{
    if(country!=='all'&&d.country!==country)return false;
    if(search&&!d.name.toLowerCase().includes(search))return false;
    return true;
  });
  filtered.sort((a,b)=>{
    let av=a[sortCol],bv=b[sortCol];
    if(av===null)return 1;if(bv===null)return -1;
    if(typeof av==='string')return sortDir==='asc'?av.localeCompare(bv):bv.localeCompare(av);
    if(typeof av==='boolean'){av=av?1:0;bv=bv?1:0;}
    return sortDir==='asc'?av-bv:bv-av;
  });
  const tbody=document.getElementById('tableBody');
  tbody.innerHTML=filtered.map(d=>{
    const fmtFee=v=>v===0?'<span class="free">$0</span>':`<span class="paid">$${v.toFixed(2)}</span>`;
    const fmtMargin=v=>v===null?'<span class="no">N/A</span>':v<7?`<span class="free">${v.toFixed(2)}%</span>`:v<10?`<span class="paid">${v.toFixed(2)}%</span>`:`<span class="expensive">${v.toFixed(2)}%</span>`;
    const fmtBool=v=>v?'<span class="yes">✓</span>':'<span class="no">✗</span>';
    const stars=n=>'<span class="rating">'+'★'.repeat(n)+'☆'.repeat(5-n)+'</span>';
    const cBadge=`<span class="country-badge">${d.country}</span>`;
    return `<tr>
      <td><span class="broker-name">${d.name}</span>${cBadge}</td>
      <td>${fmtFee(d.stockCommission)}</td>
      <td>${fmtFee(d.optionsPerContract)}</td>
      <td>${fmtMargin(d.marginRate)}</td>
      <td>${d.accountMinimum===0?'<span class="free">$0</span>':`$${d.accountMinimum.toLocaleString()}`}</td>
      <td>${fmtBool(d.fractionalShares)}</td>
      <td>${fmtBool(d.cryptoTrading)}</td>
      <td>${fmtBool(d.internationalMarkets)}</td>
      <td>${stars(d.researchRating)}</td>
      <td>${stars(d.mobileRating)}</td>
    </tr>`;
  }).join('');
  // Update header classes
  document.querySelectorAll('th').forEach(th=>{
    th.classList.remove('sorted-asc','sorted-desc');
    if(th.dataset.col===sortCol)th.classList.add(sortDir==='asc'?'sorted-asc':'sorted-desc');
  });
}

// Sort handler
document.querySelectorAll('th').forEach(th=>{
  th.addEventListener('click',()=>{
    const col=th.dataset.col;
    if(sortCol===col)sortDir=sortDir==='asc'?'desc':'asc';
    else{sortCol=col;sortDir=col==='name'?'asc':'asc';}
    renderTable();
  });
});

// Filter handlers
document.getElementById('countryFilter').addEventListener('change',renderTable);
document.getElementById('searchInput').addEventListener('input',renderTable);

// FAQ toggle
document.querySelectorAll('.faq-item').forEach(item=>{
  item.querySelector('.faq-q').addEventListener('click',()=>item.classList.toggle('open'));
});

// Init
renderChart();
renderTable();
  </script>

