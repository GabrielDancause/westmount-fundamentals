        function formatNumber(num) {
            if (num === null || num === undefined) return 'N/A';
            if (num >= 1e9) return '$' + (num / 1e9).toFixed(2) + 'B';
            if (num >= 1e6) return '$' + (num / 1e6).toFixed(2) + 'M';
            return num.toLocaleString();
        }

        function formatDecimal(num, decimals = 2) {
            if (num === null || num === undefined) return 'N/A';
            return num.toFixed(decimals);
        }

        function escapeHTML(str) {
            if (!str) return '';
            return str.replace(/[&<>'"]/g,
                tag => ({
                    '&': '&amp;',
                    '<': '<',
                    '>': '>',
                    "'": '&#39;',
                    '"': '&quot;'
                }[tag] || tag)
            );
        }

        function renderTable(data) {
            const tbody = document.getElementById('tableBody');
            tbody.innerHTML = '';

            data.forEach(row => {
                const tr = document.createElement('tr');

                const insiderStr = row.insiderBuying === null ? 'N/A' : row.insiderBuying.toLocaleString();
                const insiderClass = row.insiderBuying > 0 ? 'pos' : (row.insiderBuying < 0 ? 'neg' : '');

                tr.innerHTML = `
                    <td><a href="https://finance.yahoo.com/quote/${escapeHTML(row.ticker)}" target="_blank" rel="noopener noreferrer" class="ticker">${escapeHTML(row.ticker)}</a></td>
                    <td class="company-name">${escapeHTML(row.company)}</td>
                    <td><span class="sector-badge">${escapeHTML(row.sector)}</span></td>
                    <td class="mono">${formatNumber(row.marketCap)}</td>
                    <td class="mono">${formatDecimal(row.pe)}</td>
                    <td class="mono">${formatDecimal(row.pb)}</td>
                    <td class="mono ${row.change > 0 ? 'pos' : (row.change < 0 ? 'neg' : '')}">${formatDecimal(row.change * 100, 2)}%</td>
                    <td class="mono score">${formatDecimal(row.score)}</td>
                    <td class="mono ${insiderClass}">${insiderStr}</td>
                `;
                tbody.appendChild(tr);
            });
        }

        let currentSortCol = 7; // Default sorted by score
        let currentSortAsc = true;

        function sortTable(colIndex, isNumeric = false) {
            if (currentSortCol === colIndex) {
                currentSortAsc = !currentSortAsc;
            } else {
                currentSortCol = colIndex;
                currentSortAsc = true;
            }

            const keys = ['ticker', 'company', 'sector', 'marketCap', 'pe', 'pb', 'change', 'score', 'insiderBuying'];
            const key = keys[colIndex];

            window.__INITIAL_DATA__.sort((a, b) => {
                let valA = a[key];
                let valB = b[key];

                if (valA === null) return 1;
                if (valB === null) return -1;

                if (isNumeric) {
                    return currentSortAsc ? valA - valB : valB - valA;
                } else {
                    return currentSortAsc ? valA.localeCompare(valB) : valB.localeCompare(valA);
                }
            });

            renderTable(window.__INITIAL_DATA__);
        }

        // Initial render
        renderTable(window.__INITIAL_DATA__);
  </script>
