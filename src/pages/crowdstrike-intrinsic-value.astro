---
import SiteLayout from "../layouts/SiteLayout.astro";
import * as cheerio from 'cheerio';

const schema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": "CrowdStrike (CRWD) Intrinsic Value: A DCF Analysis",
  "description": "A transparent, step-by-step discounted cash flow valuation of CrowdStrike Holdings, Inc. Using actual financials to arrive at a single fair value estimate for CRWD shares.",
  "datePublished": "2024-03-24",
  "dateModified": "2024-03-24",
  "author": {
    "@type": "Organization",
    "name": "Westmount Research",
    "url": "https://westmountfundamentals.com"
  },
  "publisher": {
    "@type": "Organization",
    "name": "Westmount Research",
    "url": "https://westmountfundamentals.com"
  },
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": "https://westmountfundamentals.com/crowdstrike-intrinsic-value"
  }
};

const meta = {
  title: "CrowdStrike (CRWD) Intrinsic Value: A DCF Analysis",
  description: "We ran a full discounted cash flow on CrowdStrike. One number. Every assumption disclosed. Here's what CRWD is really worth.",
  category: "study",
  published: "2024-03-24",
};

/* ═══════════════════════════════════════════════════════════════
   DATA FETCHING FROM STOCKANALYSIS.COM
   null over fake data.
   ═══════════════════════════════════════════════════════════════ */
let currentPrice = null;
let fcfData = [];
let cashData = [];
let debtData = [];
let revData = [];
let epsData = [];
let sharesData = [];
let opData = [];
let netData = [];
let headers = [];

try {
  const headersObj = { 'User-Agent': 'Mozilla/5.0 (Windows NT 10.0; Win64; x64)' };

  // 1. Current Price
  const res = await fetch('https://stockanalysis.com/stocks/crwd/', { headers: headersObj });
  if (res.ok) {
    const html = await res.text();
    const $ = cheerio.load(html);
    const priceText = $('.text-4xl.font-bold').text().replace(/,/g, '');
    currentPrice = parseFloat(priceText) || null;
  }

  // 2. Free Cash Flow
  const fcfRes = await fetch('https://stockanalysis.com/stocks/crwd/financials/cash-flow-statement/', { headers: headersObj });
  if (fcfRes.ok) {
    const fcfHtml = await fcfRes.text();
    const $fcf = cheerio.load(fcfHtml);
    $fcf('table tbody tr').each((i, el) => {
      const rowHeader = $fcf(el).find('td').first().text().trim();
      if (rowHeader === 'Free Cash Flow') {
        $fcf(el).find('td').each((j, td) => {
          if (j > 0) {
            const val = $fcf(td).text().trim().replace(/,/g, '');
            fcfData.push(val === '-' ? null : parseFloat(val));
          }
        });
      }
    });
  }

  // 3. Balance Sheet (Cash & Debt)
  const bsRes = await fetch('https://stockanalysis.com/stocks/crwd/financials/balance-sheet/', { headers: headersObj });
  if (bsRes.ok) {
    const bsHtml = await bsRes.text();
    const $bs = cheerio.load(bsHtml);
    $bs('table tbody tr').each((i, el) => {
      const rowHeader = $bs(el).find('td').first().text().trim();
      if (rowHeader === 'Cash & Equivalents') {
        $bs(el).find('td').each((j, td) => {
          if (j > 0) {
            const val = $bs(td).text().trim().replace(/,/g, '');
            cashData.push(val === '-' ? null : parseFloat(val));
          }
        });
      }
      if (rowHeader === 'Total Debt') {
        $bs(el).find('td').each((j, td) => {
          if (j > 0) {
            const val = $bs(td).text().trim().replace(/,/g, '');
            debtData.push(val === '-' ? null : parseFloat(val));
          }
        });
      }
    });
  }

  // 4. Financials (Income Statement & Shares)
  const finRes = await fetch('https://stockanalysis.com/stocks/crwd/financials/', { headers: headersObj });
  if (finRes.ok) {
    const finHtml = await finRes.text();
    const $fin = cheerio.load(finHtml);

    $fin('table thead tr th').each((i, el) => {
      if (i > 0) headers.push($fin(el).text().trim());
    });

    $fin('table tbody tr').each((i, el) => {
      const rowHeader = $fin(el).find('td').first().text().trim();
      if (rowHeader === 'Revenue') {
        $fin(el).find('td').each((j, td) => {
          if (j > 0) {
            const val = $fin(td).text().trim().replace(/,/g, '');
            revData.push(val === '-' ? null : parseFloat(val));
          }
        });
      }
      if (rowHeader === 'EPS (Diluted)') {
        $fin(el).find('td').each((j, td) => {
          if (j > 0) {
            const val = $fin(td).text().trim().replace(/,/g, '');
            epsData.push(val === '-' ? null : parseFloat(val));
          }
        });
      }
      if (rowHeader === 'Shares Outstanding (Diluted)') {
        $fin(el).find('td').each((j, td) => {
          if (j > 0) {
            const val = $fin(td).text().trim().replace(/,/g, '');
            sharesData.push(val === '-' ? null : parseFloat(val));
          }
        });
      }
      if (rowHeader === 'Operating Income') {
        $fin(el).find('td').each((j, td) => {
          if (j > 0) {
            const val = $fin(td).text().trim().replace(/,/g, '');
            opData.push(val === '-' ? null : parseFloat(val));
          }
        });
      }
      if (rowHeader === 'Net Income') {
        $fin(el).find('td').each((j, td) => {
          if (j > 0) {
            const val = $fin(td).text().trim().replace(/,/g, '');
            netData.push(val === '-' ? null : parseFloat(val));
          }
        });
      }
    });
  }
} catch (e) {
  console.error("Error fetching data:", e);
}

/* ═══════════════════════════════════════════════════════════════
   DCF MODEL — ALL INPUTS AND CALCULATIONS
   ═══════════════════════════════════════════════════════════════ */

// Use TTM or most recent fiscal year data. We'll use the first column of the fetched data.
const latestYearLabel = headers[0] || 'TTM/Current';

// --- INPUTS (all in millions USD unless noted) ---
const baseFCF = fcfData[0] !== undefined ? fcfData[0] : null;
const sharesOutstanding = sharesData[0] !== undefined ? sharesData[0] : null;
const cashAndInvestments = cashData[0] !== undefined ? cashData[0] : null;
const totalDebt = debtData[0] !== undefined ? debtData[0] : null;
const currentRevenue = revData[0] !== undefined ? revData[0] : null;
const currentEPS = epsData[0] !== undefined ? epsData[0] : null;
const currentOpIncome = opData[0] !== undefined ? opData[0] : null;

// Derived values
let netCash = null;
if (cashAndInvestments !== null && totalDebt !== null) {
  netCash = cashAndInvestments - totalDebt;
}

let opMargin = null;
if (currentOpIncome !== null && currentRevenue !== null && currentRevenue !== 0) {
  opMargin = (currentOpIncome / currentRevenue) * 100;
}

// --- ASSUMPTIONS ---
const growthRatePhase1 = 0.22;         // 22% FCF growth, Years 1-5 (High growth SaaS)
const growthRateTerminal = 0.04;       // 4% perpetuity growth (terminal)
const discountRate = 0.10;             // 10% WACC / required return
const treasuryRate = 4.18;             // 10Y Treasury 4.18%

// --- DCF CALCULATION ---
const projectedFCF = [];
let pvPhase1 = null;
let terminalValue = null;
let pvTerminalValue = null;
let enterpriseValue = null;
let equityValue = null;
let roundedIV = null;
let marginOfSafety = null;
let verdictText = "N/A";
let verdictColor = "#7a8a9e";

if (baseFCF !== null && sharesOutstanding !== null && netCash !== null) {
  let fcf = baseFCF;
  pvPhase1 = 0;
  for (let yr = 1; yr <= 5; yr++) {
    fcf = fcf * (1 + growthRatePhase1);
    const pvFactor = 1 / Math.pow(1 + discountRate, yr);
    const pvFCF = fcf * pvFactor;
    projectedFCF.push({ year: yr, fcf: Math.round(fcf), pvFactor, pvFCF: Math.round(pvFCF) });
    pvPhase1 += Math.round(pvFCF);
  }

  const fcfYear6 = projectedFCF[4].fcf * (1 + growthRateTerminal);
  terminalValue = Math.round(fcfYear6 / (discountRate - growthRateTerminal));
  pvTerminalValue = Math.round(terminalValue * projectedFCF[4].pvFactor);

  enterpriseValue = pvPhase1 + pvTerminalValue;
  equityValue = enterpriseValue + netCash;
  const intrinsicValuePerShare = equityValue / sharesOutstanding;
  roundedIV = Math.round(intrinsicValuePerShare * 100) / 100;

  if (currentPrice !== null) {
    marginOfSafety = ((roundedIV - currentPrice) / currentPrice * 100).toFixed(1);
    verdictText = roundedIV > currentPrice ? "Undervalued" : "Overvalued";
    verdictColor = roundedIV > currentPrice ? "#10b981" : "#ef4444";
  }
}

// --- HISTORICAL DATA for charts (Reverse to chronological order: oldest to newest) ---
const historicalYears = headers.slice(0, 5).reverse().map(h => h.split(' ')[1] || h);

const revenueHistory = revData.slice(0, 5).reverse().map((val, i) => ({ year: historicalYears[i] || 'N/A', value: val }));
const fcfHistory = fcfData.slice(0, 5).reverse().map((val, i) => ({ year: historicalYears[i] || 'N/A', value: val }));
const epsHistory = epsData.slice(0, 5).reverse().map((val, i) => ({ year: historicalYears[i] || 'N/A', value: val }));

const maxRev = revenueHistory.reduce((max, r) => (r.value !== null && r.value > max) ? r.value : max, 0);
const maxFCF = fcfHistory.reduce((max, r) => (r.value !== null && Math.abs(r.value) > max) ? Math.abs(r.value) : max, 0);
const maxEPS = epsHistory.reduce((max, r) => (r.value !== null && Math.abs(r.value) > max) ? Math.abs(r.value) : max, 0.01); // Prevent div by 0

const marginHistory = revData.slice(0, 5).reverse().map((rev, i) => {
  const opInc = opData.slice(0, 5).reverse()[i];
  const netInc = netData.slice(0, 5).reverse()[i];
  const fcfVal = fcfData.slice(0, 5).reverse()[i];

  return {
    year: historicalYears[i] || 'N/A',
    operating: (opInc !== null && opInc !== undefined && rev !== null && rev !== undefined && rev !== 0) ? ((opInc / rev) * 100).toFixed(1) : 'N/A',
    profit: (netInc !== null && netInc !== undefined && rev !== null && rev !== undefined && rev !== 0) ? ((netInc / rev) * 100).toFixed(1) : 'N/A',
    fcfMargin: (fcfVal !== null && fcfVal !== undefined && rev !== null && rev !== undefined && rev !== 0) ? ((fcfVal / rev) * 100).toFixed(1) : 'N/A'
  };
});

// Sensitivity analysis
const sensitivityRates = [0.08, 0.09, 0.10, 0.11, 0.12];
const sensitivityGrowth = [0.18, 0.20, 0.22, 0.24, 0.26];
let sensitivityTable = [];

if (baseFCF !== null && sharesOutstanding !== null && netCash !== null) {
  sensitivityTable = sensitivityRates.map(dr => {
    return {
      dr,
      values: sensitivityGrowth.map(gr => {
        let f = baseFCF;
        let sum = 0;
        for (let y = 1; y <= 5; y++) {
          f = f * (1 + gr);
          sum += f / Math.pow(1 + dr, y);
        }
        const f6 = f * (1 + growthRateTerminal);
        const tv = f6 / (dr - growthRateTerminal);
        const pTV = tv / Math.pow(1 + dr, 5);
        return Math.round((sum + pTV + netCash) / sharesOutstanding);
      })
    };
  });
}
