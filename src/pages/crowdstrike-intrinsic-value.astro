.dcf-wrapper * { box-sizing: border-box; }
.dcf-wrapper a { color: #4a8fe7; text-decoration: none; }
.dcf-wrapper a:hover { text-decoration: underline; }
.dcf-wrapper .container { max-width: 900px; margin: 0 auto; padding: 0 24px; }

/* Header */
.dcf-wrapper .header { text-align: center; padding: 80px 24px 60px; background: linear-gradient(180deg, #0a1628 0%, #060a12 100%); position: relative; border-bottom: 1px solid #152040; margin-bottom: 60px; }
.dcf-wrapper .header::before { content: ''; position: absolute; inset: 0; background: radial-gradient(circle at 50% 40%, rgba(74,143,231,0.06) 0%, transparent 60%); }
