  <script is:inline>
// Inject Data securely
        window.__INITIAL_DATA__ = {"spyYield":0.0106,"aristocratsCount":69,"stocksData":[{"ticker":"JNJ","name":"Johnson & Johnson","yield":0.0214,"payoutRatio":0.466,"peRatio":21.94379,"divRate":5.2},{"ticker":"PG","name":"Procter & Gamble Company (The)","yield":0.0276,"payoutRatio":0.6188,"peRatio":22.296297,"divRate":4.23},{"ticker":"KO","name":"Coca-Cola Company (The)","yield":0.026500002,"payoutRatio":0.6711,"peRatio":25.529606,"divRate":2.06},{"ticker":"PEP","name":"Pepsico, Inc.","yield":0.0355,"payoutRatio":0.9371,"peRatio":26.432611,"divRate":5.69},{"ticker":"ABBV","name":"AbbVie Inc.","yield":0.0304,"payoutRatio":2.7679,"peRatio":95.09283,"divRate":6.92},{"ticker":"VZ","name":"Verizon Communications Inc.","yield":0.0558,"payoutRatio":0.5037,"peRatio":12.470444,"divRate":2.83},{"ticker":"MO","name":"Altria Group, Inc.","yield":0.0639,"payoutRatio":1.0097001,"peRatio":16.436893,"divRate":4.24},{"ticker":"O","name":"Realty Income Corporation","yield":0.050100002,"payoutRatio":2.7547,"peRatio":55.581196,"divRate":3.24},{"ticker":"XOM","name":"Exxon Mobil Corporation","yield":0.0272,"payoutRatio":0.597,"peRatio":22.914927,"divRate":4.12},{"ticker":"CVX","name":"Chevron Corporation","yield":0.037100002,"payoutRatio":1.0317,"peRatio":29.664158,"divRate":7.12},{"ticker":"MCD","name":"McDonald's Corporation","yield":0.0229,"payoutRatio":0.6,"peRatio":27.128141,"divRate":7.44},{"ticker":"T","name":"AT&T Inc.","yield":0.040900003,"payoutRatio":0.2738,"peRatio":9.009869,"divRate":1.11},{"ticker":"PFE","name":"Pfizer, Inc.","yield":0.063,"payoutRatio":1.2647,"peRatio":19.60584,"divRate":1.72},{"ticker":"IBM","name":"International Business Machines","yield":0.027,"payoutRatio":0.6023,"peRatio":22.213453,"divRate":6.72},{"ticker":"MMM","name":"3M Company","yield":0.0201,"payoutRatio":0.48669997,"peRatio":24.808653,"divRate":3.12}]};

        document.addEventListener('DOMContentLoaded', () => {
            const data = window.__INITIAL_DATA__;

            // Wait, I need to check how to format the yield based on the memory
            // Memory: "In yahoo-finance2, the quote.dividendYield field is already represented as a percentage (e.g., a value of 3.14 means 3.14%). Do not multiply it by 100 when formatting."
            // But we used quoteSummary which returns a decimal (e.g., 0.0214).
            // Let's use a smart formatter that handles both cases just in case.
            const formatYield = (val) => {
                if (!val) return 'N/A';
                if (val < 1) return (val * 100).toFixed(2) + '%';
                return val.toFixed(2) + '%';
            };

            const formatRatio = (val) => {
                if (!val) return 'N/A';
                return (val * 100).toFixed(1) + '%';
            };

            // Populate Stats
            document.getElementById('val-spy-yield').innerText = formatYield(data.spyYield);
            document.getElementById('val-aristocrats').innerText = data.aristocratsCount;
            document.getElementById('text-aristocrats').innerText = data.aristocratsCount;

            // Table Logic
            let stocks = data.stocksData;
            let currentSort = 'yield';
            let sortAsc = false;

            const renderTable = (filter = '') => {
                const tbody = document.getElementById('tableBody');
                tbody.innerHTML = '';

                const filtered = stocks.filter(s =>
                    s.ticker.toLowerCase().includes(filter.toLowerCase()) ||
                    s.name.toLowerCase().includes(filter.toLowerCase())
                );

                filtered.sort((a, b) => {
                    let valA = a[currentSort] || 0;
                    let valB = b[currentSort] || 0;

                    if (currentSort === 'ticker') {
                        return sortAsc ? a.ticker.localeCompare(b.ticker) : b.ticker.localeCompare(a.ticker);
                    }

                    return sortAsc ? valA - valB : valB - valA;
                });

                filtered.forEach(s => {
                    const tr = document.createElement('tr');
                    tr.innerHTML = `
                        <td style="text-align: left;"><span class="ticker">${s.ticker}</span><br><span style="font-size:0.8rem; color:var(--text-muted);">${s.name}</span></td>
                        <td style="color: var(--accent-color);">${formatYield(s.yield)}</td>
                        <td>${formatRatio(s.payoutRatio)}</td>
                        <td>${s.peRatio ? s.peRatio.toFixed(1) : 'N/A'}</td>
                    `;
                    tbody.appendChild(tr);
                });
            };

            document.getElementById('searchInput').addEventListener('input', (e) => {
                renderTable(e.target.value);
            });

            document.querySelectorAll('th').forEach(th => {
                th.addEventListener('click', () => {
                    const sortKey = th.getAttribute('data-sort');
                    if (currentSort === sortKey) {
                        sortAsc = !sortAsc;
                    } else {
                        currentSort = sortKey;
                        sortAsc = false;
                    }
                    renderTable(document.getElementById('searchInput').value);
                });
            });

            renderTable();

            // Chart.js - DRIP Visualization
            const ctx = document.getElementById('dripChart').getContext('2d');

            // Simple projection: $10,000 initial, 4% yield, 6% stock appreciation
            const years = Array.from({length: 21}, (_, i) => i);
            const initial = 10000;
            const noDrip = [];
            const withDrip = [];

            let sharesNoDrip = initial / 100; // Assuming $100 price
            let price = 100;
            let cashCollected = 0;

            let sharesDrip = initial / 100;
            let priceDrip = 100;

            for(let i = 0; i <= 20; i++) {
                // No DRIP: Stock grows at 6%, we collect 4% dividend in cash
                if (i > 0) {
                    price *= 1.06;
                    cashCollected += sharesNoDrip * price * 0.04;

                    priceDrip *= 1.06;
                    let dividend = sharesDrip * priceDrip * 0.04;
                    sharesDrip += dividend / priceDrip;
                }

                noDrip.push(Math.round(sharesNoDrip * price + cashCollected));
                withDrip.push(Math.round(sharesDrip * priceDrip));
            }

            Chart.defaults.color = '#6a7a90';
            Chart.defaults.font.family = 'Inter';

            new Chart(ctx, {
                type: 'line',
                data: {
                    labels: years.map(y => 'Year ' + y),
                    datasets: [
                        {
                            label: 'With DRIP Reinvested',
                            data: withDrip,
                            borderColor: '#4a8fe7',
                            backgroundColor: 'rgba(74, 143, 231, 0.1)',
                            borderWidth: 3,
                            fill: true,
                            tension: 0.4
                        },
                        {
                            label: 'Without DRIP (Cash Kept)',
                            data: noDrip,
                            borderColor: '#e78f4a',
                            borderWidth: 2,
                            borderDash: [5, 5],
                            fill: false,
                            tension: 0.4
                        }
                    ]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: { position: 'top' },
                        tooltip: {
                            mode: 'index',
                            intersect: false,
                            callbacks: {
                                label: function(context) {
                                    let label = context.dataset.label || '';
                                    if (label) { label += ': '; }
                                    if (context.parsed.y !== null) {
                                        label += new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD', maximumFractionDigits: 0 }).format(context.parsed.y);
                                    }
                                    return label;
                                }
                            }
                        }
                    },
                    scales: {
                        y: {
                            beginAtZero: true,
                            grid: { color: '#152040' },
                            ticks: {
                                callback: function(value) {
                                    return '$' + (value/1000) + 'k';
                                }
                            }
                        },
                        x: {
                            grid: { display: false },
                            ticks: { maxTicksLimit: 5 }
                        }
                    }
                }
            });
        });
  </script>

  
