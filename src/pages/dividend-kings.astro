const schema = {"@context": "https://schema.org", "@type": "FAQPage", "mainEntity": [{"@type": "Question", "name": "What are Dividend Kings?", "acceptedAnswer": {"@type": "Answer", "text": "Dividend Kings are S&P 500 companies that have successfully increased their dividend payout for at least 50 consecutive years. They represent some of the most consistent and reliable dividend-paying stocks in the market."}}, {"@type": "Question", "name": "How many Dividend Kings are there in 2025?", "acceptedAnswer": {"@type": "Answer", "text": "As of early 2025, there are more than 50 Dividend Kings. The exact list frequently updates as companies reach the 50-year milestone or, rarely, if a company cuts its dividend."}}, {"@type": "Question", "name": "Are Dividend Kings better than Dividend Aristocrats?", "acceptedAnswer": {"@type": "Answer", "text": "Not necessarily better, but they have a longer track record. While Dividend Aristocrats require 25 consecutive years of increases, Dividend Kings require 50 years, demonstrating even greater long-term resilience across multiple economic cycles."}}, {"@type": "Question", "name": "What is the highest yielding Dividend King?", "acceptedAnswer": {"@type": "Answer", "text": "The highest yielding Dividend King varies as stock prices fluctuate, but companies like Altria Group (MO) and Universal Corp (UVV) frequently offer yields above 5%, often leading the list in terms of current yield."}}, {"@type": "Question", "name": "How to invest in Dividend Kings?", "acceptedAnswer": {"@type": "Answer", "text": "You can invest in Dividend Kings individually through a brokerage account, or you can purchase ETFs and mutual funds that specifically target dividend growth companies, though few funds focus exclusively on the 50-year requirement."}}]};
