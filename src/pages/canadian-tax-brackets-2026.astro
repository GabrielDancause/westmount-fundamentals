---
import SiteLayout from "../layouts/SiteLayout.astro";
import registry from "../data/pages-registry.json";

const page = (registry as any)["canadian-tax-brackets-2026"];
export const meta = { title: "2026 Canadian Tax Brackets & Income Calculator", description: "Complete 2026 Canadian federal and provincial tax brackets. Interactive calculator: see your marginal rate, total tax, and take-home pay instantly.", category: "tool", published: "2026-03-15" };

const schema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What are the Canadian federal tax brackets for 2026?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "For 2026, the projected federal tax brackets are: 15% up to $58,809; 20.5% between $58,809 and $117,619; 26% between $117,619 and $182,329; 29% between $182,329 and $259,749; and 33% on income over $259,749."
      }
    },
    {
      "@type": "Question",
      "name": "How much is the Basic Personal Amount (BPA) for 2026?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "The projected federal Basic Personal Amount for 2026 is approximately $16,611. This is the amount of income you can earn before paying any federal income tax."
      }
    },
    {
      "@type": "Question",
      "name": "What is the difference between marginal tax rate and average tax rate?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Your marginal tax rate is the percentage of tax applied to your last dollar earned. Your average tax rate is the total tax you pay divided by your total income, which is always lower than your marginal rate due to progressive tax brackets."
      }
    },
    {
      "@type": "Question",
      "name": "Are Canadian tax brackets adjusted for inflation?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes, both federal and provincial tax brackets (in most provinces) are indexed to inflation annually using the Consumer Price Index (CPI). This prevents 'bracket creep' where inflation pushes individuals into higher tax brackets without a real increase in purchasing power."
      }
    },
    {
      "@type": "Question",
      "name": "How much are the CPP and EI deductions in 2026?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "For 2026, CPP base contributions are roughly 5.95% up to the max pensionable earnings limit, plus the CPP2 second ceiling contribution of 4%. EI premiums are 1.66% up to the maximum insurable earnings limit."
      }
    }
  ]
};

---

<SiteLayout
