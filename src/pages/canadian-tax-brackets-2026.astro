        { rate: 0.10, threshold: 0 },
        { rate: 0.12, threshold: 152000 },
        { rate: 0.13, threshold: 182400 },
        { rate: 0.14, threshold: 243200 },
        { rate: 0.15, threshold: 304000 }
      ],
      QC: [
