      ],
      ON: [
        { rate: 0.0505, threshold: 0 },
        { rate: 0.0915, threshold: 52732 },
        { rate: 0.1116, threshold: 105464 },
        { rate: 0.1216, threshold: 150000 },
        { rate: 0.1316, threshold: 220000 }
