  title={page.title}
  description={page.description}
  canonical={`https://westmountfundamentals.com/${page.slug}`} schema={schema}
>
  <style>
:root {
            --accent-glow: rgba(74, 143, 231, 0.2);
            --text-heading: #ffffff;
            --red: #e74c3c;
            --green: #2ecc71;
            --yellow: #f1c40f;

}

        * { box-sizing: border-box; margin: 0; padding: 0; }
        body {
            font-family: var(--font-sans);
            background-color: var(--bg-color);
            color: var(--text-primary);
            line-height: 1.6;
