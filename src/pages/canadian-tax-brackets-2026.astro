        { rate: 0.19, threshold: 51069 },
        { rate: 0.24, threshold: 102137 },
        { rate: 0.2575, threshold: 125568 }
      ],
      MB: [
        { rate: 0.108, threshold: 0 },
        { rate: 0.1275, threshold: 48350 },
        { rate: 0.174, threshold: 102434 }
      ],
      SK: [
        { rate: 0.105, threshold: 0 },
        { rate: 0.125, threshold: 53139 },
        { rate: 0.145, threshold: 152865 }
      ],
      NS: [
        { rate: 0.0879, threshold: 0 },
        { rate: 0.1495, threshold: 29590 },
        { rate: 0.1667, threshold: 59180 },
        { rate: 0.175, threshold: 93000 },
        { rate: 0.21, threshold: 150000 }
      ],
      NB: [
        { rate: 0.094, threshold: 0 },
        { rate: 0.14, threshold: 49451 },
        { rate: 0.16, threshold: 98901 },
        { rate: 0.195, threshold: 189726 },
        { rate: 0.203, threshold: 199623 }
      ],
      PE: [
        { rate: 0.0965, threshold: 0 },
        { rate: 0.1363, threshold: 33328 },
        { rate: 0.1665, threshold: 64656 },
        { rate: 0.18, threshold: 105000 },
        { rate: 0.1875, threshold: 140000 }
      ],
      NL: [
        { rate: 0.087, threshold: 0 },
        { rate: 0.145, threshold: 44040 },
        { rate: 0.158, threshold: 88081 },
        { rate: 0.178, threshold: 148107 },
        { rate: 0.198, threshold: 209761 },
        { rate: 0.208, threshold: 262201 },
        { rate: 0.213, threshold: 524401 },
        { rate: 0.218, threshold: 1048803 }
      ],
      YT: [
        { rate: 0.064, threshold: 0 },
        { rate: 0.09, threshold: 58809 },
        { rate: 0.109, threshold: 117619 },
        { rate: 0.128, threshold: 182329 },
        { rate: 0.15, threshold: 500000 }
      ],
      NT: [
        { rate: 0.059, threshold: 0 },
        { rate: 0.086, threshold: 52206 },
        { rate: 0.122, threshold: 104412 },
        { rate: 0.1405, threshold: 169824 }
      ],
      NU: [
        { rate: 0.04, threshold: 0 },
        { rate: 0.07, threshold: 55653 },
        { rate: 0.09, threshold: 111306 },
        { rate: 0.115, threshold: 181313 }
      ]
    };

    const payrollData = {
        bpaFederal: 16611,
        eiRate: 0.0166,
        eiMax: 1087.30,
        cppRate: 0.0595,
        cppExemption: 3500,
        cppMax: 4034.10,
        cpp2Rate: 0.04,
        cpp2Threshold: 71300,
        cpp2Max: 204
    };

    const provNames = {
        ON: "Ontario", BC: "British Columbia", AB: "Alberta", QC: "Quebec",
        MB: "Manitoba", SK: "Saskatchewan", NS: "Nova Scotia", NB: "New Brunswick",
        PE: "Prince Edward Island", NL: "Newfoundland & Labrador", YT: "Yukon",
        NT: "Northwest Territories", NU: "Nunavut"
    };

    let currentChart = null;

    function formatMoney(amount) {
        return new Intl.NumberFormat('en-CA', { style: 'currency', currency: 'CAD', maximumFractionDigits: 0 }).format(amount);
    }

    function formatPct(rate) {
        return (rate * 100).toFixed(1) + '%';
    }

    function calculateTax(income, brackets, bpa) {
        let tax = 0;
        let marginalRate = brackets[0].rate;
        let taxableIncome = Math.max(0, income - bpa);

        for (let i = 0; i < brackets.length; i++) {
            const b = brackets[i];
            const nextThreshold = brackets[i+1] ? brackets[i+1].threshold : Infinity;

            if (taxableIncome > b.threshold) {
                const incomeInBracket = Math.min(taxableIncome - b.threshold, nextThreshold - b.threshold);
                tax += incomeInBracket * b.rate;
                marginalRate = b.rate;
            }
        }
        return { tax, marginalRate };
    }

    function calculate() {
        const income = parseFloat(document.getElementById('income').value) || 0;
        const prov = document.getElementById('province').value;

        // Payroll deductions
        const ei = Math.min(income * payrollData.eiRate, payrollData.eiMax);
        const cppIncome = Math.max(0, income - payrollData.cppExemption);
        const cppBase = Math.min(cppIncome * payrollData.cppRate, payrollData.cppMax);

        let cpp2 = 0;
        if (income > payrollData.cpp2Threshold) {
             cpp2 = Math.min((income - payrollData.cpp2Threshold) * payrollData.cpp2Rate, payrollData.cpp2Max);
        }
        const totalCppEi = ei + cppBase + cpp2;

        // Tax
        const federalBPA = payrollData.bpaFederal;
        const provBPA = federalBPA * 0.8; // Rough estimate for prov BPA

        const fed = calculateTax(income, taxData.federal, federalBPA);
        const prv = calculateTax(income, taxData[prov], provBPA);

        const totalTax = fed.tax + prv.tax;
        const takeHome = income - totalTax - totalCppEi;

        const marginalTotal = fed.marginalRate + prv.marginalRate;
        const avgTotal = income > 0 ? (totalTax / income) : 0;

        // Update DOM
        document.getElementById('takeHomePay').textContent = formatMoney(takeHome);
        document.getElementById('totalTax').textContent = formatMoney(totalTax);
        document.getElementById('avgRate').textContent = formatPct(avgTotal);
        document.getElementById('marginalRate').textContent = formatPct(marginalTotal);

        // Breakdown table
        document.getElementById('breakdownBody').innerHTML = `
            <tr>
                <td>Federal Income Tax</td>
                <td class="text-right">${formatMoney(fed.tax)}</td>
                <td class="text-right">${formatPct(income > 0 ? fed.tax / income : 0)}</td>
            </tr>
            <tr>
                <td>Provincial Income Tax (${provNames[prov]})</td>
                <td class="text-right">${formatMoney(prv.tax)}</td>
                <td class="text-right">${formatPct(income > 0 ? prv.tax / income : 0)}</td>
            </tr>
            <tr>
                <td>CPP / QPP Premiums</td>
                <td class="text-right">${formatMoney(cppBase + cpp2)}</td>
                <td class="text-right">${formatPct(income > 0 ? (cppBase + cpp2) / income : 0)}</td>
            </tr>
            <tr>
                <td>EI Premiums</td>
                <td class="text-right">${formatMoney(ei)}</td>
                <td class="text-right">${formatPct(income > 0 ? ei / income : 0)}</td>
            </tr>
            <tr class="row-total">
                <td>Total Deductions</td>
                <td class="text-right" style="color: var(--red)">${formatMoney(totalTax + totalCppEi)}</td>
                <td class="text-right">${formatPct(income > 0 ? (totalTax + totalCppEi) / income : 0)}</td>
            </tr>
            <tr class="row-total">
                <td>Net Take-Home Pay</td>
                <td class="text-right" style="color: var(--green)">${formatMoney(takeHome)}</td>
                <td class="text-right">${formatPct(income > 0 ? takeHome / income : 0)}</td>
            </tr>
        `;

        updateChart(takeHome, fed.tax, prv.tax, cppBase + cpp2 + ei);
    }

    function updateChart(takeHome, fed, prv, cppEi) {
        if (!window.Chart) return;
        const ctx = document.getElementById('taxChart').getContext('2d');
        if (currentChart) currentChart.destroy();

        currentChart = new Chart(ctx, {
            type: 'doughnut',
            data: {
                labels: ['Take-Home Pay', 'Federal Tax', 'Provincial Tax', 'CPP & EI'],
                datasets: [{
                    data: [takeHome, fed, prv, cppEi],
                    backgroundColor: ['#2ecc71', '#3498db', '#9b59b6', '#f1c40f'],
                    borderWidth: 0,
                    hoverOffset: 4
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: {
                        position: 'right',
                        labels: { color: '#c8d0de', font: { family: 'Inter', size: 12 } }
                    },
                    tooltip: {
                        callbacks: {
                            label: function(context) {
                                let label = context.label || '';
                                if (label) label += ': ';
                                label += formatMoney(context.raw);
                                return label;
                            }
                        }
                    }
                }
            }
        });
    }

    function renderBrackets(type) {
        const container = document.getElementById('bracketsDisplay');
        let html = '';

        function renderTable(title, brackets) {
            let t = `<div class="bracket-table-wrapper"><table class="bracket-table">
                <thead><tr><th colspan="2" style="font-size:1.1rem; color:var(--text-heading); background:var(--card-bg);">${title}</th></tr>
                <tr><th>Income Threshold</th><th>Tax Rate</th></tr></thead><tbody>`;

            for (let i = 0; i < brackets.length; i++) {
                const start = formatMoney(brackets[i].threshold);
                const end = brackets[i+1] ? ' to ' + formatMoney(brackets[i+1].threshold) : ' and up';
                const range = i === 0 ? `Up to ${brackets[i+1] ? formatMoney(brackets[i+1].threshold) : 'and up'}` : `${start}${end}`;
                t += `<tr><td>${range}</td><td>${formatPct(brackets[i].rate)}</td></tr>`;
            }
            t += `</tbody></table></div>`;
            return t;
        }

        if (type === 'federal') {
            html += renderTable('2026 Federal Tax Brackets', taxData.federal);
        } else {
            const prov = document.getElementById('province').value;
            html += renderTable(`2026 Provincial Brackets (${provNames[prov]})`, taxData[prov]);
        }

        container.innerHTML = html;
    }

    document.getElementById('income').addEventListener('input', calculate);
    document.getElementById('province').addEventListener('change', () => {
        calculate();
        const activeTab = document.querySelector('.tab.active').dataset.target;
        if (activeTab === 'provincial') renderBrackets('provincial');
    });

    document.querySelectorAll('.tab').forEach(tab => {
        tab.addEventListener('click', (e) => {
            document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
            e.target.classList.add('active');
            renderBrackets(e.target.dataset.target);
        });
    });

    // Init
    setTimeout(() => {
        calculate();
        renderBrackets('federal');
    }, 100);
  </script>

  
