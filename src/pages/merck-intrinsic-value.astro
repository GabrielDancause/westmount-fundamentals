---
import SiteLayout from "../layouts/SiteLayout.astro";

// --- METADATA ---
export const meta = {
  title: "Merck & Co., Inc. (MRK) Intrinsic Value",
  description: "An independent discounted cash flow (DCF) intrinsic value analysis of Merck & Co., Inc. (MRK) compiled by Gemini 3.1.",
  category: "study",
  published: "2026-03-18",
};

// --- DATA & ASSUMPTIONS (FY2025 Actuals) ---
// FCF Growth (Y1-Y5): 4.0%. Merck faces a significant patent cliff for its blockbuster drug Keytruda in 2028. While their pipeline (Prometheus acquisition, Harpoon Therapeutics, ADC collaborations) is robust, replacing $25B+ in annual revenue is a massive hurdle. A 4% growth rate reflects moderate near-term growth offset by the impending cliff, requiring successful pipeline execution just to maintain this trajectory.
// Discount Rate (WACC): 7.5%. MRK is a highly defensive stock with a very low beta (0.26). However, the massive concentration risk tied to Keytruda warrants a premium over the standard CAPM output. Given the 10-Year Treasury at 4.18%, a 7.5% WACC balances the company's strong current cash generation against the pipeline execution risk.
// Terminal Growth: 2.0%. Representing long-term GDP-like growth. The pharmaceutical industry is mature, and while MRK will continue to innovate, a conservative terminal growth rate is prudent given the cyclical nature of drug development and patent expirations.

const baseFCF = 11886.75; // in Millions
const sharesOut = 2472.39; // in Millions
const currentPrice = 114.51;
const netCash = -35969.0; // Cash & ST investments - Total Debt (Net Debt is actually positive, so netCash is negative)

const fcfGrowthRate = 0.04;
const discountRate = 0.075;
const terminalGrowthRate = 0.02;

// --- YEAR 1 TO 5 PROJECTIONS ---
const projections = [];
let prevFCF = baseFCF;

for (let i = 1; i <= 5; i++) {
  const projectedFCF = prevFCF * (1 + fcfGrowthRate);
  const discountFactor = Math.pow(1 + discountRate, i);
  const pvOfFCF = projectedFCF / discountFactor;

  projections.push({
    year: `Year ${i}`,
    fcf: projectedFCF,
    pv: pvOfFCF
  });

  prevFCF = projectedFCF;
}

const sumPvFcf = projections.reduce((sum, p) => sum + p.pv, 0);

// --- TERMINAL VALUE ---
const year5FCF = projections[4].fcf;
const terminalValue = (year5FCF * (1 + terminalGrowthRate)) / (discountRate - terminalGrowthRate);
const pvTerminalValue = terminalValue / Math.pow(1 + discountRate, 5);

// --- INTRINSIC VALUE CALCULATION ---
const enterpriseValue = sumPvFcf + pvTerminalValue;
const totalEquityValue = enterpriseValue + netCash;
const intrinsicValuePerShare = totalEquityValue / sharesOut;

// Value vs Current Price
const marginOfSafety = ((intrinsicValuePerShare - currentPrice) / currentPrice) * 100;
const isUndervalued = intrinsicValuePerShare > currentPrice;

// --- SENSITIVITY MATRIX ---
const sensitivityDiscountRates = [0.065, 0.070, 0.075, 0.080, 0.085];
const sensitivityGrowthRates = [0.010, 0.015, 0.020, 0.025, 0.030];

const sensitivityMatrix = sensitivityGrowthRates.map(g => {
  return {
    growthRate: g,
    values: sensitivityDiscountRates.map(d => {
      // Re-calculate TV and PV with new rates
      const currentTerminalValue = (year5FCF * (1 + g)) / (d - g);
      const currentPvTerminalValue = currentTerminalValue / Math.pow(1 + d, 5);

      // Re-calculate PV of FCFs with new discount rate
      let currentSumPvFcf = 0;
      let tempFcf = baseFCF;
      for (let i = 1; i <= 5; i++) {
        tempFcf = tempFcf * (1 + fcfGrowthRate);
        currentSumPvFcf += tempFcf / Math.pow(1 + d, i);
      }

      const currentEV = currentSumPvFcf + currentPvTerminalValue;
      const currentEquity = currentEV + netCash;
      const currentIV = currentEquity / sharesOut;

      return currentIV;
    })
  };
});

// Formatting helpers
const formatMoney = (val) => new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD', minimumFractionDigits: 2, maximumFractionDigits: 2 }).format(val);
const formatMillions = (val) => '$' + new Intl.NumberFormat('en-US', { maximumFractionDigits: 0 }).format(val) + 'M';
const formatPercent = (val) => (val * 100).toFixed(1) + '%';

// --- SCHEMA ---
const schema = [
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": meta.title,
    "description": meta.description,
    "author": {
      "@type": "Person",
      "name": "Gemini 3.1"
    },
    "publisher": {
      "@type": "Organization",
      "name": "Westmount Fundamentals",
      "logo": {
        "@type": "ImageObject",
        "url": "https://westmountfundamentals.com/logo.png"
      }
    },
    "datePublished": meta.published
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "Why is the free cash flow growth rate so low for Merck?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Merck faces a massive patent cliff for its flagship oncology drug, Keytruda, in 2028. Keytruda currently accounts for roughly 40% of their total revenue. A 4% growth rate factors in the immense challenge of replacing this revenue through their pipeline and recent acquisitions."
        }
      },
      {
        "@type": "Question",
        "name": "How does Keytruda's patent expiration impact the valuation?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "The patent expiration is the primary driver of risk in this model. It suppresses the terminal growth rate (2.0%) and elevates the required discount rate (7.5%) to account for the execution risk of successfully commercializing the pipeline to offset the impending revenue gap."
        }
      },
      {
        "@type": "Question",
        "name": "Is MRK undervalued according to this DCF?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": `According to this independent analysis by Gemini 3.1, MRK's estimated intrinsic value is ${formatMoney(intrinsicValuePerShare)} per share. Compared to the current price of ${formatMoney(currentPrice)}, it appears ${isUndervalued ? 'undervalued' : 'overvalued'} with a margin of safety of ${formatPercent(Math.abs(marginOfSafety)/100)}.`
        }
      }
    ]
  }
];
---

<SiteLayout site="westmount" title={meta.title} description={meta.description} canonical="https://westmountfundamentals.com/merck-intrinsic-value" schema={schema}>
  <article class="valuation-container">
    <header class="valuation-header">
      <div class="ai-badge">Compiled by Gemini 3.1</div>
      <h1>Merck & Co., Inc. (MRK) Intrinsic Value</h1>
      <p class="subtitle">A Discounted Cash Flow (DCF) Analysis</p>
    </header>

    <section class="verdict-section">
      <div class={`verdict-card ${isUndervalued ? 'undervalued' : 'overvalued'}`}>
        <h2>Final Verdict</h2>
        <div class="verdict-comparison">
          <div class="verdict-metric">
            <span class="label">Intrinsic Value</span>
            <span class="value">{formatMoney(intrinsicValuePerShare)}</span>
          </div>
          <div class="verdict-divider">vs</div>
          <div class="verdict-metric">
            <span class="label">Current Price</span>
            <span class="value">{formatMoney(currentPrice)}</span>
          </div>
        </div>
        <div class="verdict-conclusion">
          MRK is currently <strong>{isUndervalued ? 'Undervalued' : 'Overvalued'}</strong> by {formatPercent(Math.abs(marginOfSafety)/100)}
        </div>
      </div>
    </section>

    <section class="content-section">
      <h2>Methodology: Two-Stage DCF</h2>
      <p>This intrinsic value estimate utilizes a two-stage Discounted Cash Flow (DCF) model. This approach projects Free Cash Flow (FCF) for the next five years (Stage 1) and then calculates a Terminal Value to represent all future cash flows beyond year 5 (Stage 2). These future cash flows are then discounted back to their present value using the Weighted Average Cost of Capital (WACC).</p>

      <div class="assumptions-grid">
        <div class="assumption-card">
          <div class="assumption-header">
            <h3>FCF Growth (Y1-Y5)</h3>
            <span class="assumption-value">{formatPercent(fcfGrowthRate)}</span>
          </div>
          <p>Merck faces a significant patent cliff for its blockbuster drug Keytruda in 2028. While their pipeline (Prometheus acquisition, Harpoon Therapeutics, ADC collaborations) is robust, replacing $25B+ in annual revenue is a massive hurdle. A 4% growth rate reflects moderate near-term growth offset by the impending cliff, requiring successful pipeline execution just to maintain this trajectory.</p>
        </div>

        <div class="assumption-card">
          <div class="assumption-header">
            <h3>Discount Rate (WACC)</h3>
            <span class="assumption-value">{formatPercent(discountRate)}</span>
          </div>
          <p>MRK is a highly defensive stock with a very low beta (0.26). However, the massive concentration risk tied to Keytruda warrants a premium over the standard CAPM output. Given the 10-Year Treasury at 4.18%, a 7.5% WACC balances the company's strong current cash generation against the pipeline execution risk.</p>
        </div>

        <div class="assumption-card">
          <div class="assumption-header">
            <h3>Terminal Growth Rate</h3>
            <span class="assumption-value">{formatPercent(terminalGrowthRate)}</span>
          </div>
          <p>Representing long-term GDP-like growth. The pharmaceutical industry is mature, and while MRK will continue to innovate, a conservative terminal growth rate is prudent given the cyclical nature of drug development and patent expirations.</p>
        </div>
      </div>
    </section>

    <section class="content-section">
      <h2>Stage 1: 5-Year Free Cash Flow Projections</h2>
      <div class="table-container">
        <table class="data-table">
          <thead>
            <tr>
              <th>Period</th>
              <th>Projected FCF</th>
              <th>Present Value (PV)</th>
            </tr>
          </thead>
          <tbody>
            {projections.map((p) => (
              <tr>
                <td>{p.year}</td>
                <td class="numeric">{formatMillions(p.fcf)}</td>
                <td class="numeric">{formatMillions(p.pv)}</td>
              </tr>
            ))}
          </tbody>
          <tfoot>
            <tr>
              <td><strong>Sum of PV of FCFs</strong></td>
              <td></td>
              <td class="numeric"><strong>{formatMillions(sumPvFcf)}</strong></td>
            </tr>
          </tfoot>
        </table>
      </div>
    </section>

    <section class="content-section">
      <h2>Stage 2: Terminal Value</h2>
      <div class="calc-box">
        <p><strong>Terminal Value formula:</strong> (Year 5 FCF * (1 + Terminal Growth)) / (Discount Rate - Terminal Growth)</p>
        <p><strong>Terminal Value:</strong> {formatMillions(terminalValue)}</p>
        <p><strong>Present Value of Terminal Value:</strong> {formatMillions(pvTerminalValue)}</p>
      </div>
    </section>

    <section class="content-section">
      <h2>Final Valuation</h2>
      <div class="table-container">
        <table class="valuation-table">
          <tbody>
            <tr>
              <td>PV of 5-Year FCFs</td>
              <td class="numeric">{formatMillions(sumPvFcf)}</td>
            </tr>
            <tr>
              <td>PV of Terminal Value</td>
              <td class="numeric">+ {formatMillions(pvTerminalValue)}</td>
            </tr>
            <tr class="highlight-row">
              <td><strong>Enterprise Value</strong></td>
              <td class="numeric"><strong>{formatMillions(enterpriseValue)}</strong></td>
            </tr>
            <tr>
              <td>Plus: Net Cash (Cash - Debt)</td>
              <td class="numeric">{formatMillions(netCash)}</td>
            </tr>
            <tr class="highlight-row">
              <td><strong>Total Equity Value</strong></td>
              <td class="numeric"><strong>{formatMillions(totalEquityValue)}</strong></td>
            </tr>
            <tr>
              <td>Shares Outstanding</td>
              <td class="numeric">/ {(sharesOut).toLocaleString()}M</td>
            </tr>
            <tr class="final-row">
              <td><strong>Intrinsic Value Per Share</strong></td>
              <td class="numeric"><strong>{formatMoney(intrinsicValuePerShare)}</strong></td>
            </tr>
          </tbody>
        </table>
      </div>
    </section>

    <section class="content-section">
      <h2>Sensitivity Matrix</h2>
      <p>This matrix shows how the intrinsic value changes under different growth and discount rate assumptions.</p>

      <div class="table-container">
        <table class="sensitivity-table">
          <thead>
            <tr>
              <th>Growth / WACC</th>
              {sensitivityDiscountRates.map(d => (
                <th class="numeric">{formatPercent(d)}</th>
              ))}
            </tr>
          </thead>
          <tbody>
            {sensitivityMatrix.map(row => (
              <tr>
                <th>{formatPercent(row.growthRate)}</th>
                {row.values.map(val => (
                  <td class={`numeric ${val > currentPrice ? 'cell-undervalued' : 'cell-overvalued'}`}>
                    {formatMoney(val)}
                  </td>
                ))}
              </tr>
            ))}
          </tbody>
        </table>
      </div>
      <div class="matrix-legend">
        <span class="legend-item"><span class="legend-color legend-undervalued"></span> Undervalued</span>
        <span class="legend-item"><span class="legend-color legend-overvalued"></span> Overvalued</span>
      </div>
    </section>

    <section class="content-section">
      <h2>Key Risks to This Valuation</h2>
      <ul class="risk-list">
        <li><strong>Keytruda Patent Cliff (2028):</strong> This is the single biggest risk. Keytruda generates a massive portion of Merck's revenue. If the pipeline fails to adequately offset the revenue loss from biosimilar competition starting in 2028, these FCF projections will be overly optimistic.</li>
        <li><strong>Pipeline Execution Risk:</strong> Merck has aggressively pursued acquisitions (like Prometheus) and partnerships (like Daiichi Sankyo) to bolster its pipeline. Clinical trial failures or regulatory setbacks for these assets would severely impact future growth.</li>
        <li><strong>Pricing Pressures:</strong> Changes in healthcare policy, particularly the Inflation Reduction Act (IRA) in the US, could mandate price negotiations for successful drugs, squeezing margins and reducing future cash flows.</li>
      </ul>
    </section>

    <section class="content-section">
      <h2>Frequently Asked Questions</h2>
      <div class="faq-container">
        <details class="faq-item">
          <summary>Why is the free cash flow growth rate so low for Merck?</summary>
          <div class="faq-content">
            <p>Merck faces a massive patent cliff for its flagship oncology drug, Keytruda, in 2028. Keytruda currently accounts for roughly 40% of their total revenue. A 4% growth rate factors in the immense challenge of replacing this revenue through their pipeline and recent acquisitions.</p>
          </div>
        </details>
        <details class="faq-item">
          <summary>How does Keytruda's patent expiration impact the valuation?</summary>
          <div class="faq-content">
            <p>The patent expiration is the primary driver of risk in this model. It suppresses the terminal growth rate (2.0%) and elevates the required discount rate (7.5%) to account for the execution risk of successfully commercializing the pipeline to offset the impending revenue gap.</p>
          </div>
        </details>
        <details class="faq-item">
          <summary>Is MRK undervalued according to this DCF?</summary>
          <div class="faq-content">
            <p>According to this independent analysis by Gemini 3.1, MRK's estimated intrinsic value is {formatMoney(intrinsicValuePerShare)} per share. Compared to the current price of {formatMoney(currentPrice)}, it appears {isUndervalued ? 'undervalued' : 'overvalued'} with a margin of safety of {formatPercent(Math.abs(marginOfSafety)/100)}.</p>
          </div>
        </details>
      </div>
    </section>

    <footer class="disclaimer">
      <p><strong>Disclaimer:</strong> This intrinsic value analysis was completely compiled and generated by an AI model (Gemini 3.1). It is for educational and informational purposes only and should not be considered financial advice. The calculations rely heavily on future assumptions regarding growth rates and discount rates, which are inherently uncertain. Always conduct your own due diligence and consult with a licensed financial professional before making investment decisions.</p>
    </footer>
  </article>
</SiteLayout>

