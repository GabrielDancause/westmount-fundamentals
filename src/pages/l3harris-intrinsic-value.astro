---
import SiteLayout from "../layouts/SiteLayout.astro";
import * as cheerio from 'cheerio';

const schema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": "L3Harris Technologies (LHX) Intrinsic Value: A DCF Analysis",
  "description": "A transparent, step-by-step discounted cash flow valuation of L3Harris Technologies (LHX). Using actual FY2025 financials to arrive at a single fair value estimate for LHX shares.",
  "datePublished": "2026-03-18",
  "dateModified": "2026-03-18",
  "author": {
    "@type": "Organization",
    "name": "Westmount Research",
    "url": "https://westmountfundamentals.com"
  },
  "publisher": {
    "@type": "Organization",
    "name": "Westmount Research",
    "url": "https://westmountfundamentals.com"
  },
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": "https://westmountfundamentals.com/l3harris-intrinsic-value"
  }
};

export const meta = {
  title: "L3Harris Technologies (LHX) Intrinsic Value: A DCF Analysis",
  description: "We ran a full discounted cash flow on L3Harris using FY2025 actuals. One number. Every assumption disclosed. Here's what LHX is really worth.",
  category: "study",
  published: "2026-03-18",
};

/* ═══════════════════════════════════════════════════════════════
   DATA FETCHING FROM STOCKANALYSIS
   ═══════════════════════════════════════════════════════════════ */

async function fetchStockAnalysis(url) {
  try {
    const res = await fetch(url, { headers: { 'User-Agent': 'Mozilla/5.0' } });
    const html = await res.text();
    return cheerio.load(html);
  } catch (error) {
    console.error("Error fetching", url, error);
    return null;
  }
}

let sharesOut = null;
let currentPrice = null;
let cash = null;
let debt = null;
let fcfData = null;
let revData = null;
let epsData = null;
let opMarginData = null;
let profMarginData = null;
let fcfMarginData = null;
let years = [];

try {
  // Fetch overview
  const $overview = await fetchStockAnalysis('https://stockanalysis.com/stocks/lhx/');
  if ($overview) {
    const sharesText = $overview('td').filter((i, el) => $overview(el).text().includes('Shares Out')).next().text().replace(/[MB,]/g, '').trim();
    sharesOut = sharesText ? parseFloat(sharesText) : null;
    const priceText = $overview('.text-4xl.font-bold').text().replace(/,/g, '').trim();
    currentPrice = priceText ? parseFloat(priceText) : null;
  }

  // Fetch balance sheet
  const $bs = await fetchStockAnalysis('https://stockanalysis.com/stocks/lhx/financials/balance-sheet/');
  if ($bs) {
    $bs('table tr').each((i, row) => {
      const rowHtml = $bs(row).html();
      if (!rowHtml) return;
      const cells = $bs(row).find('td').map((i, c) => $bs(c).text().replace(/,/g, '')).get();
      if (rowHtml.includes('Cash &amp; Equivalents') || rowHtml.includes('Cash & Equivalents')) {
        cash = parseFloat(cells[1]) || null;
      }
      if (rowHtml.includes('Total Debt')) {
        debt = parseFloat(cells[1]) || null;
      }
    });
  }

  // Fetch financials
  const $fin = await fetchStockAnalysis('https://stockanalysis.com/stocks/lhx/financials/');
  if ($fin) {
    $fin('table thead th').each((i, th) => {
      const text = $fin(th).text();
      const yearMatch = text.match(/(20\d{2})/);
      if (yearMatch) years.push(yearMatch[1]);
    });

    $fin('table tr').each((i, row) => {
      const rowHtml = $fin(row).html();
      if (!rowHtml) return;
      const cells = $fin(row).find('td').map((i, c) => $fin(c).text().replace(/,/g, '').replace('%', '')).get();

      if (rowHtml.includes('Revenue') && !rowHtml.includes('Growth') && !rowHtml.includes('Cost')) {
         revData = cells.slice(1).map(Number);
      }
      if (rowHtml.includes('Free Cash Flow') && !rowHtml.includes('Margin') && !rowHtml.includes('Per Share') && !rowHtml.includes('Growth')) {
         fcfData = cells.slice(1).map(Number);
      }
      if (rowHtml.includes('EPS (Diluted)')) {
         epsData = cells.slice(1).map(Number);
      }
      if (rowHtml.includes('Operating Margin')) {
         opMarginData = cells.slice(1).map(Number);
      }
      if (rowHtml.includes('Profit Margin')) {
         profMarginData = cells.slice(1).map(Number);
      }
      if (rowHtml.includes('FCF Margin')) {
         fcfMarginData = cells.slice(1).map(Number);
      }
    });
  }
} catch (error) {
  console.error("Data fetching error:", error);
}

// Fallbacks
const fcf2025 = fcfData && fcfData[0] ? fcfData[0] : null;
const sharesOutstanding = sharesOut !== null ? sharesOut : null;
const cashAndInvestments = cash !== null ? cash : null;
const totalDebt = debt !== null ? debt : null;
currentPrice = currentPrice !== null ? currentPrice : null;
const netCash = (cashAndInvestments !== null && totalDebt !== null) ? cashAndInvestments - totalDebt : null;

// ASSUMPTIONS
const growthRatePhase1 = 0.06;         // 6% FCF growth, Years 1-5
const growthRateTerminal = 0.025;      // 2.5% perpetuity growth (terminal)
const discountRate = 0.09;             // 9% WACC / required return

let projectedFCF = [];
let fcfYear6 = null;
let terminalValue = null;
let pvTerminalValue = null;
let pvPhase1 = null;
let enterpriseValue = null;
let equityValue = null;
let intrinsicValuePerShare = null;
let roundedIV = null;
let marginOfSafety = null;
let verdictText = "N/A";
let verdictColor = "#94a3b8";

if (fcf2025 !== null && sharesOutstanding !== null && netCash !== null && currentPrice !== null) {
  // PHASE 1
  let fcf = fcf2025;
  for (let yr = 1; yr <= 5; yr++) {
    fcf = fcf * (1 + growthRatePhase1);
    projectedFCF.push({ year: yr, fcf: Math.round(fcf), pvFactor: 1 / Math.pow(1 + discountRate, yr) });
  }
  projectedFCF.forEach(p => { p.pvFCF = Math.round(p.fcf * p.pvFactor); });

  // PHASE 2
  fcfYear6 = projectedFCF[4].fcf * (1 + growthRateTerminal);
  terminalValue = Math.round(fcfYear6 / (discountRate - growthRateTerminal));
  pvTerminalValue = Math.round(terminalValue * projectedFCF[4].pvFactor);

  // ENTERPRISE VALUE
  pvPhase1 = projectedFCF.reduce((sum, p) => sum + p.pvFCF, 0);
  enterpriseValue = pvPhase1 + pvTerminalValue;

  // EQUITY VALUE
  equityValue = enterpriseValue + netCash;
  intrinsicValuePerShare = equityValue / sharesOutstanding;
  roundedIV = Math.round(intrinsicValuePerShare * 100) / 100;

  marginOfSafety = ((roundedIV - currentPrice) / currentPrice * 100).toFixed(1);
  verdictText = roundedIV > currentPrice ? "Undervalued" : "Overvalued";
  verdictColor = roundedIV > currentPrice ? "#10b981" : "#ef4444";
}

const revHistoryFinal = revData ? revData.slice(0, 5).reverse().map((v, i) => ({ year: years[4-i] || (2021+i), value: v })) : [];
const fcfHistoryFinal = fcfData ? fcfData.slice(0, 5).reverse().map((v, i) => ({ year: years[4-i] || (2021+i), value: v })) : [];
const epsHistoryFinal = epsData ? epsData.slice(0, 5).reverse().map((v, i) => ({ year: years[4-i] || (2021+i), value: v })) : [];
const marginHistoryFinal = (opMarginData && profMarginData && fcfMarginData) ?
  opMarginData.slice(0, 5).reverse().map((op, i) => ({
    year: years[4-i] || (2021+i),
    operating: op,
    profit: profMarginData.slice(0, 5).reverse()[i],
    fcfMargin: fcfMarginData.slice(0, 5).reverse()[i]
  })) : [];

const sensitivityRates = [0.07, 0.08, 0.09, 0.10, 0.11];
const sensitivityGrowth = [0.02, 0.04, 0.06, 0.08, 0.10];
let sensitivityTable = [];

if (fcf2025 !== null && netCash !== null && sharesOutstanding !== null) {
  sensitivityTable = sensitivityRates.map(dr => {
    return {
      dr,
      values: sensitivityGrowth.map(gr => {
        let f = fcf2025;
        let pvSum = 0;
        for (let y = 1; y <= 5; y++) {
          f = f * (1 + gr);
          pvSum += f / Math.pow(1 + dr, y);
        }
        const f6 = f * (1 + growthRateTerminal);
        const tv = f6 / (dr - growthRateTerminal);
        const pvTV = tv / Math.pow(1 + dr, 5);
        return Math.round((pvSum + pvTV + netCash) / sharesOutstanding);
      })
    };
  });
}
---
<SiteLayout
  site="westmount"
  title="L3Harris Technologies (LHX) Intrinsic Value: A DCF Analysis"
  description="We ran a full discounted cash flow on L3Harris using FY2025 actuals. One number. Every assumption disclosed. Here's what LHX is really worth."
  canonical="https://westmountfundamentals.com/l3harris-intrinsic-value"
  schema={schema}
>
<style>
