body { font-family: 'Inter', -apple-system, sans-serif; background: #060a12; color: #c8d0de; line-height: 1.7; }
a { color: #4a8fe7; text-decoration: none; }
a:hover { text-decoration: underline; }
.container { max-width: 900px; margin: 0 auto; padding: 0 24px; }

/* Header */
.header { text-align: center; padding: 80px 24px 60px; background: linear-gradient(180deg, #0a1628 0%, #060a12 100%); position: relative; border-bottom: 1px solid #152040; }
.header::before { content: ''; position: absolute; inset: 0; background: radial-gradient(circle at 50% 40%, rgba(74,143,231,0.06) 0%, transparent 60%); }
.header-content { position: relative; z-index: 1; display: flex; flex-direction: column; align-items: center; }
.tag { display: inline-block; background: rgba(74,143,231,0.1); color: #4a8fe7; padding: 4px 12px; border-radius: 20px; font-size: 0.85rem; font-weight: 600; margin-bottom: 16px; border: 1px solid rgba(74,143,231,0.2); }
h1 { font-size: 2.8rem; color: #ffffff; letter-spacing: -0.03em; margin-bottom: 24px; line-height: 1.1; }
.subtitle { font-size: 1.2rem; color: #94a3b8; max-width: 600px; margin: 0 auto; }

/* Verdict Card */
.verdict-card { background: #0f172a; border: 1px solid #1e293b; border-radius: 16px; padding: 32px; margin: -30px auto 40px; position: relative; z-index: 2; display: flex; align-items: center; justify-content: space-between; box-shadow: 0 20px 40px rgba(0,0,0,0.4); }
.vc-left { display: flex; flex-direction: column; }
.vc-label { font-size: 0.9rem; text-transform: uppercase; letter-spacing: 0.05em; color: #64748b; font-weight: 600; margin-bottom: 8px; }
.vc-value { font-size: 3.5rem; font-weight: 700; color: #ffffff; line-height: 1; font-family: 'JetBrains Mono', monospace; letter-spacing: -0.02em; }
.vc-right { text-align: right; }
.vc-price { font-size: 1.2rem; color: #94a3b8; margin-bottom: 8px; }
.vc-status { display: inline-block; padding: 6px 16px; border-radius: 8px; font-weight: 600; font-size: 1.1rem; }

/* Content sections */
h2 { font-size: 1.8rem; color: #ffffff; margin: 48px 0 20px; padding-bottom: 12px; border-bottom: 1px solid #1e293b; }
h3 { font-size: 1.3rem; color: #f8fafc; margin: 32px 0 16px; }
p { margin-bottom: 16px; font-size: 1.05rem; }
ul { margin-bottom: 24px; padding-left: 24px; }
li { margin-bottom: 8px; font-size: 1.05rem; }

/* Tables */
.table-wrap { overflow-x: auto; margin: 32px 0; background: #0f172a; border-radius: 12px; border: 1px solid #1e293b; }
table { width: 100%; border-collapse: collapse; text-align: right; font-family: 'JetBrains Mono', monospace; font-size: 0.95rem; }
th { background: #152040; color: #94a3b8; font-weight: 500; padding: 16px; border-bottom: 1px solid #1e293b; }
td { padding: 16px; border-bottom: 1px solid #1e293b; color: #cbd5e1; }
tr:last-child td { border-bottom: none; }
.row-total td { font-weight: 700; color: #ffffff; background: rgba(74,143,231,0.05); }
.highlight-cell { color: #4a8fe7; font-weight: 700; font-size: 1.1rem; }

/* Sensitivity Table specific */
.sensitivity-table th.current { color: #ffffff; background: rgba(74,143,231,0.2); font-weight: 700; }
.sensitivity-table td.current { background: rgba(74,143,231,0.2); color: #ffffff; font-weight: 700; border: 1px solid #4a8fe7; }

/* Assumption Cards */
.assumptions-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 20px; margin: 32px 0; }
.assumption-card { background: #0f172a; border: 1px solid #1e293b; padding: 24px; border-radius: 12px; }
.ac-title { font-size: 0.9rem; color: #64748b; text-transform: uppercase; letter-spacing: 0.05em; font-weight: 600; margin-bottom: 12px; }
.ac-value { font-size: 2rem; color: #ffffff; font-weight: 700; font-family: 'JetBrains Mono', monospace; margin-bottom: 12px; }
.ac-desc { font-size: 0.9rem; color: #94a3b8; line-height: 1.5; }

/* Bar Charts (CSS only) */
.bar-chart { margin: 24px 0 48px; display: flex; flex-direction: column; gap: 12px; }
.bar-row { display: flex; align-items: center; gap: 16px; }
.bar-label { width: 48px; font-weight: 600; color: #94a3b8; font-family: 'JetBrains Mono', monospace; font-size: 0.9rem; }
.bar-track { flex: 1; background: #0f172a; height: 32px; border-radius: 4px; overflow: hidden; position: relative; }
.bar-fill { height: 100%; display: flex; align-items: center; padding-left: 12px; font-family: 'JetBrains Mono', monospace; font-size: 0.85rem; font-weight: 600; color: #ffffff; transition: width 0.5s ease; white-space: nowrap; }
.bar-fill.revenue { background: linear-gradient(90deg, #1d4ed8, #3b82f6); }
.bar-fill.fcf { background: linear-gradient(90deg, #047857, #10b981); }
.bar-fill.eps { background: linear-gradient(90deg, #6d28d9, #8b5cf6); }

/* FAQ */
.faq { margin: 32px 0; }
details { background: #0f172a; border: 1px solid #1e293b; border-radius: 8px; margin-bottom: 12px; overflow: hidden; }
summary { padding: 16px 20px; font-weight: 600; color: #ffffff; cursor: pointer; display: flex; justify-content: space-between; align-items: center; user-select: none; }
summary::-webkit-details-marker { display: none; }
summary::after { content: '+'; color: #4a8fe7; font-size: 1.4rem; font-weight: 400; }
details[open] summary::after { content: '−'; }
.faq-answer { padding: 0 20px 20px; color: #94a3b8; line-height: 1.6; }

/* Misc Blocks */
.cite-block { background: #1e293b; padding: 20px; border-radius: 8px; border-left: 4px solid #4a8fe7; margin: 48px 0; }
.cite-block h4 { color: #ffffff; margin-bottom: 8px; }
.cite-block p { margin: 0; font-family: 'JetBrains Mono', monospace; font-size: 0.9rem; color: #cbd5e1; }
.sources { font-size: 0.9rem; color: #64748b; padding-top: 24px; border-top: 1px solid #1e293b; margin-top: 48px; }
.sources h4 { color: #94a3b8; margin-bottom: 12px; }
.sources ul { margin-bottom: 0; }

/* Related Grid */
.related-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 16px; margin: 32px 0; }
