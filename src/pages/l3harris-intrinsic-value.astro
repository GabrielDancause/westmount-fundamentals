---
import SiteLayout from "../layouts/SiteLayout.astro";

const schema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": "L3Harris Technologies (LHX) Intrinsic Value: A DCF Analysis",
  "description": "A transparent, step-by-step discounted cash flow valuation of L3Harris Technologies. Using actual financials to arrive at a single fair value estimate for LHX shares.",
  "datePublished": new Date().toISOString().split('T')[0],
  "dateModified": new Date().toISOString().split('T')[0],
  "author": {
    "@type": "Organization",
    "name": "Compiled by Gemini 3.1",
    "url": "https://westmountfundamentals.com"
  },
  "publisher": {
    "@type": "Organization",
    "name": "Westmount Research",
    "url": "https://westmountfundamentals.com"
  },
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": "https://westmountfundamentals.com/l3harris-intrinsic-value"
  }
};

export const meta = {
  title: "L3Harris Technologies (LHX) Intrinsic Value: A DCF Analysis",
  description: "We ran a full discounted cash flow on L3Harris Technologies. One number. Every assumption disclosed. Here's what LHX is really worth.",
  category: "study",
  published: new Date().toISOString().split('T')[0],
};

import * as cheerio from 'cheerio';

// --- DATA FETCHING (stockanalysis.com) ---
let currentPrice = null;
let sharesM = null;
let totalDebtM = null;
let totalCashM = null;
let fcfM = null;
let revenue2025 = null;
let eps = null;
let operatingMargin = null;

let revenueHistory = [];
let fcfHistory = [];
let epsHistory = [];
let marginHistory = [];

try {
  const ticker = 'lhx';
  const urls = [
    `https://stockanalysis.com/stocks/${ticker}/financials/`,
    `https://stockanalysis.com/stocks/${ticker}/financials/cash-flow-statement/`,
    `https://stockanalysis.com/stocks/${ticker}/financials/balance-sheet/`
  ];

  const headers = {
    'User-Agent': 'Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/121.0.0.0 Safari/537.36',
    'Accept': 'text/html,application/xhtml+xml,application/xml;q=0.9,*/*;q=0.8',
    'Accept-Language': 'en-US,en;q=0.5',
    'Connection': 'keep-alive',
    'Upgrade-Insecure-Requests': '1'
  };

  const responses = [];
  for (const url of urls) {
    const res = await fetch(url, { headers });
    if (!res.ok) {
      throw new Error(`HTTP error! status: ${res.status} for ${url}`);
    }
    responses.push(res);
  }

  const [finHtml, cfHtml, bsHtml] = await Promise.all(responses.map(res => res.text()));

  const parseTable = (html) => {
    const $ = cheerio.load(html);
    const data = {};
    const years = [];

    // Extract years from the header
    $('table thead tr th').each((i, cell) => {
      if (i > 0) {
        const text = $(cell).text().trim();
        const yearMatch = text.match(/\b(20\d{2})\b/);
        years.push(yearMatch ? parseInt(yearMatch[1], 10) : new Date().getFullYear() - i + 1);
      }
    });

    // Extract row data
    $('table tbody tr').each((_, row) => {
      const rowHeader = $(row).find('td').first().text().trim();
      const values = [];
      $(row).find('td').each((i, cell) => {
        if (i > 0) {
          const textVal = $(cell).text().trim().replace(/,/g, '');
          values.push(textVal === '-' || textVal === '' ? null : parseFloat(textVal));
        }
      });
      if (values.length > 0) {
        data[rowHeader] = { values, years };
      }
    });
    return data;
  };

  const finData = parseTable(finHtml);
  const cfData = parseTable(cfHtml);
  const bsData = parseTable(bsHtml);

  // Parse current price
  const priceMatch = finHtml.match(/<div class="[^"]*text-4xl[^"]*"[^>]*>([\d\.,]+)<\/div>/);
  if (priceMatch && priceMatch[1]) {
    currentPrice = parseFloat(priceMatch[1].replace(/,/g, ''));
  }

  // Set latest metrics (index 0 is TTM/Latest)
  if (finData['Revenue'] && finData['Revenue'].values.length > 0) {
    revenue2025 = finData['Revenue'].values[0] * 1000000; // Multiply by 1M since stockanalysis is in millions
  }
  if (cfData['Free Cash Flow'] && cfData['Free Cash Flow'].values.length > 0) {
    fcfM = cfData['Free Cash Flow'].values[0];
  }
  if (finData['EPS (Diluted)'] && finData['EPS (Diluted)'].values.length > 0) {
    eps = finData['EPS (Diluted)'].values[0];
  }
  if (finData['Shares Outstanding (Diluted)'] && finData['Shares Outstanding (Diluted)'].values.length > 0) {
    sharesM = finData['Shares Outstanding (Diluted)'].values[0];
  }
  if (bsData['Cash & Equivalents'] && bsData['Cash & Equivalents'].values.length > 0) {
    totalCashM = bsData['Cash & Equivalents'].values[0];
  }
  if (bsData['Total Debt'] && bsData['Total Debt'].values.length > 0) {
    totalDebtM = bsData['Total Debt'].values[0];
  }

  if (finData['Operating Income'] && finData['Revenue'] &&
      finData['Operating Income'].values[0] !== null && finData['Revenue'].values[0] !== null) {
    operatingMargin = (finData['Operating Income'].values[0] / finData['Revenue'].values[0]) * 100;
  }

  // Populate history arrays (reverse to chronological order)
  if (finData['Revenue']) {
    for (let i = finData['Revenue'].values.length - 1; i >= 0; i--) {
      if (finData['Revenue'].values[i] !== null) {
        revenueHistory.push({ year: finData['Revenue'].years[i], value: finData['Revenue'].values[i] * 1000000 });
      }
    }
  }

  if (cfData['Free Cash Flow']) {
    for (let i = cfData['Free Cash Flow'].values.length - 1; i >= 0; i--) {
      if (cfData['Free Cash Flow'].values[i] !== null) {
        fcfHistory.push({ year: cfData['Free Cash Flow'].years[i], value: cfData['Free Cash Flow'].values[i] * 1000000 });
      }
    }
  }

  if (finData['Operating Income'] && finData['Revenue']) {
    for (let i = finData['Operating Income'].values.length - 1; i >= 0; i--) {
      const op = finData['Operating Income'].values[i];
      const rev = finData['Revenue'].values[i];
      if (op !== null && rev !== null && rev !== 0) {
        marginHistory.push({ year: finData['Operating Income'].years[i], operating: parseFloat(((op / rev) * 100).toFixed(2)) });
      }
    }
  }

} catch (err) {
  console.error("Error fetching LHX data from stockanalysis:", err.message);
}

const netCashM = (totalCashM !== null && totalDebtM !== null) ? totalCashM - totalDebtM : null;

// Ensure base numbers are present before projecting
const fcfBase = fcfM;

// --- ASSUMPTIONS ---
const growthRatePhase1 = 0.08;         // 8% FCF growth, Years 1-5
const growthRateTerminal = 0.025;      // 2.5% perpetuity growth (terminal)
const riskFreeRate = 0.0418;           // 10Y Treasury: 4.18%
const equityRiskPremium = 0.055;       // 5.5% ERP
const actualBeta = 0.70; // Hardcoded fallback or sourced from other means since stockanalysis beta is not easily scraped here
// WACC / Cost of Equity using CAPM
const calculatedDiscountRate = riskFreeRate + (actualBeta * equityRiskPremium);
const discountRate = calculatedDiscountRate;

// --- PHASE 1: PROJECT FCF FOR YEARS 1-5 ---
const projectedFCF = [];
let pvPhase1 = 0;
if (fcfBase !== null) {
  let fcf = fcfBase;
  for (let yr = 1; yr <= 5; yr++) {
    fcf = fcf * (1 + growthRatePhase1);
    const pvFactor = 1 / Math.pow(1 + discountRate, yr);
    const pvFCF = Math.round(fcf * pvFactor);
    projectedFCF.push({ year: yr, fcf: Math.round(fcf), pvFactor, pvFCF });
    pvPhase1 += pvFCF;
  }
}

// --- PHASE 2: TERMINAL VALUE ---
let fcfYear6 = null;
let terminalValue = null;
let pvTerminalValue = null;
if (projectedFCF.length === 5) {
  fcfYear6 = projectedFCF[4].fcf * (1 + growthRateTerminal);
  terminalValue = Math.round(fcfYear6 / (discountRate - growthRateTerminal));
  pvTerminalValue = Math.round(terminalValue * projectedFCF[4].pvFactor);
}

// --- VALUATION ---
let enterpriseValue = null;
let equityValue = null;
let roundedIV = null;
let marginOfSafety = null;
let verdictText = "N/A";
let verdictColor = "#5a6a80";

if (fcfBase !== null && netCashM !== null && sharesM !== null && pvTerminalValue !== null) {
  enterpriseValue = pvPhase1 + pvTerminalValue;
  equityValue = enterpriseValue + netCashM;
  const intrinsicValuePerShare = equityValue / sharesM;
  roundedIV = Math.round(intrinsicValuePerShare * 100) / 100;

  if (currentPrice !== null) {
    marginOfSafety = ((roundedIV - currentPrice) / currentPrice * 100).toFixed(1);
    verdictText = roundedIV > currentPrice ? "Undervalued" : "Overvalued";
    verdictColor = roundedIV > currentPrice ? "#10b981" : "#ef4444";
  }
}

// Sensitivity analysis
const sensitivityRates = [discountRate - 0.02, discountRate - 0.01, discountRate, discountRate + 0.01, discountRate + 0.02];
const sensitivityGrowth = [0.04, 0.06, 0.08, 0.10, 0.12];
const sensitivityTable = sensitivityRates.map(dr => {
  return {
    dr,
    values: sensitivityGrowth.map(gr => {
      if (fcfBase === null || netCashM === null || sharesM === null) return null;
      let f = fcfBase;
      let pvSum = 0;
      for (let y = 1; y <= 5; y++) {
        f = f * (1 + gr);
        pvSum += f / Math.pow(1 + dr, y);
      }
      const f6 = f * (1 + growthRateTerminal);
      const tv = f6 / (dr - growthRateTerminal);
      const pvTV = tv / Math.pow(1 + dr, 5);
      return Math.round((pvSum + pvTV + netCashM) / sharesM);
    })
  };
});
