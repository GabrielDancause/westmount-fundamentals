import SiteLayout from "../layouts/SiteLayout.astro";

export const meta = {
  title: "What is Short Selling? A Complete Guide to Shorting Stocks",
  description: "Learn what short selling is and how investors profit from falling stock prices. Discover the mechanics, risks like short squeezes, and real-world examples.",
  category: "guide",
};

const schema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What is the simple definition of short selling?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Short selling is an investment strategy where an investor borrows shares of a stock, sells them on the open market, and hopes to buy them back later at a lower price to return to the lender. The investor profits from the difference between the selling price and the lower repurchase price."
      }
    },
    {
      "@type": "Question",
      "name": "How does an investor lose money in a short sale?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "An investor loses money in a short sale if the price of the stock goes up instead of down. Because they must eventually buy back the borrowed shares to return them, a higher stock price means they must repurchase the shares at a loss. Theoretically, since a stock's price can rise indefinitely, the potential loss on a short sale is infinite."
      }
    },
    {
      "@type": "Question",
      "name": "What is a short squeeze?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "A short squeeze occurs when a heavily shorted stock rapidly increases in price. This forces short sellers to buy back shares to close their positions and limit their losses. This sudden surge of buying pressure drives the stock price even higher, causing a vicious cycle of more short covering and further price increases."
      }
    },
    {
      "@type": "Question",
      "name": "Who borrows the shares in a short sale?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "The investor's brokerage firm handles the borrowing. The broker locates shares to borrow, typically from their own inventory, another client's margin account, or another brokerage firm. The investor must have a margin account and meet specific requirements to borrow these shares."
      }
    },
    {
      "@type": "Question",
      "name": "Do short sellers have to pay dividends?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes. If the stock pays a dividend while the short seller is borrowing the shares, the short seller is responsible for paying that dividend amount to the lender of the shares. This is because the original owner of the shares is still entitled to receive the dividend."
      }
    }
  ]
});
