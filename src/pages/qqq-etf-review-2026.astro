---
import SiteLayout from "../layouts/SiteLayout.astro";

const schema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What is the QQQ ETF expense ratio?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "The Invesco QQQ Trust (QQQ) has an expense ratio of 0.18%. This means you pay $18 annually for every $10,000 invested."
      }
    },
    {
      "@type": "Question",
      "name": "QQQ vs SPY: Which is better?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "QQQ focuses on the top 100 non-financial Nasdaq companies, making it heavily tech-weighted with higher historical growth and volatility. SPY tracks the broader S&P 500, offering more diversification across all sectors. The better choice depends on your risk tolerance and need for diversification."
      }
    },
    {
      "@type": "Question",
      "name": "QQQ vs QQQM: What is the difference?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "QQQ and QQQM track the exact same Nasdaq-100 index. However, QQQM is designed for buy-and-hold retail investors with a lower expense ratio (0.15% vs 0.18%) and a lower share price. QQQ has vastly higher trading volume, making it better for day traders and options."
      }
    },
    {
      "@type": "Question",
      "name": "Does QQQ pay dividends?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes, QQQ pays a quarterly dividend, although the yield is typically very low (around 0.29%) because it primarily holds growth-oriented technology companies that reinvest profits rather than paying them out."
      }
    },
    {
      "@type": "Question",
      "name": "What companies are in QQQ?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "QQQ holds the 100 largest non-financial companies listed on the Nasdaq exchange. The top holdings are dominated by mega-cap tech companies such as Apple, Microsoft, NVIDIA, Amazon, and Meta."
      }
    }
  ]
};

export const meta = {
  title: "QQQ ETF Review (2026): Invesco Nasdaq 100 Holdings",
  description: "Complete 2026 review of the Invesco QQQ Trust ETF. Analyze its Nasdaq-100 holdings, performance history, and head-to-head vs SPY and QQQM.",
  category: "tool",
  published: "2026-03-15",
};
---

<SiteLayout
  site="westmount"
  title="QQQ ETF Review (2026): Invesco Nasdaq 100 Holdings"
  description="Complete 2026 review of the Invesco QQQ Trust ETF. Analyze its Nasdaq-100 holdings, performance history, and head-to-head vs SPY and QQQM."
  canonical="https://westmountfundamentals.com/qqq-etf-review-2026" schema={schema}
>
  <style>
:root {
      --white: #ffffff;
      --positive: #10b981;
      --negative: #ef4444;

}

    * { margin: 0; padding: 0; box-sizing: border-box; }

    body {
      font-family: 'Inter', -apple-system, sans-serif;
      background-color: var(--bg-color);
      color: var(--text-primary);
      line-height: 1.6;
    }

    nav {
      position: sticky;
      top: 0;
      z-index: 1000;
      background: rgba(6, 10, 18, 0.85);
      backdrop-filter: blur(12px);
      border-bottom: 1px solid var(--border-color);
      padding: 1rem 2rem;
      display: flex;
      justify-content: space-between;
      align-items: center;
    }

    nav .brand {
      color: var(--white);
      font-weight: 800;
      text-decoration: none;
      font-size: 1.2rem;
      letter-spacing: -0.5px;
    }

    nav .links a {
      color: var(--text-primary);
      text-decoration: none;
      margin-left: 1.5rem;
      font-size: 0.9rem;
      font-weight: 500;
      transition: color 0.2s;
    }

    nav .links a:hover {
      color: var(--accent-color);
    }

    .container {
      max-width: 1000px;
      margin: 0 auto;
      padding: 3rem 1.5rem;
    }

    .hero {
      text-align: center;
      margin-bottom: 4rem;
    }

    .tagline {
      display: inline-block;
      color: var(--accent-color);
      background: rgba(74, 143, 231, 0.1);
      padding: 0.4rem 1rem;
      border-radius: 2rem;
      font-size: 0.8rem;
      font-weight: 700;
      letter-spacing: 1px;
      text-transform: uppercase;
      margin-bottom: 1.5rem;
    }

    h1 {
      font-size: 3.5rem;
      font-weight: 900;
      line-height: 1.1;
      letter-spacing: -1.5px;
      margin-bottom: 1.5rem;
      background: linear-gradient(135deg, #fff 0%, #8b9bb4 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
    }

    .hero-desc {
      font-size: 1.1rem;
      color: var(--text-muted);
      max-width: 700px;
      margin: 0 auto;
    }

    .stats-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
      gap: 1.5rem;
      margin-bottom: 3rem;
    }

    .stat-card {
      background: var(--card-bg);
      border: 1px solid var(--border-color);
      border-radius: 16px;
      padding: 1.5rem;
      text-align: center;
    }

    .stat-card.featured {
      border-color: var(--accent-color);
      background: linear-gradient(180deg, rgba(74,143,231,0.05) 0%, var(--card-bg) 100%);
    }

    .stat-value {
      font-size: 2.5rem;
      font-weight: 800;
      color: var(--white);
      line-height: 1.2;
      margin-bottom: 0.5rem;
      font-family: 'JetBrains Mono', monospace;
    }

    .stat-card.featured .stat-value {
      color: var(--accent-color);
    }

    .stat-label {
      font-size: 0.85rem;
      color: var(--text-muted);
      text-transform: uppercase;
      letter-spacing: 1px;
      font-weight: 600;
    }

    .section-title {
      font-size: 2rem;
      font-weight: 800;
      color: var(--white);
      margin: 4rem 0 2rem;
      letter-spacing: -0.5px;
      display: flex;
      align-items: center;
      gap: 1rem;
    }

    .section-title::after {
      content: '';
      height: 1px;
      flex: 1;
      background: var(--border-color);
    }

    .content-block {
      background: var(--card-bg);
      border: 1px solid var(--border-color);
      border-radius: 16px;
      padding: 2.5rem;
      margin-bottom: 2rem;
    }

    p {
      margin-bottom: 1.5rem;
      font-size: 1.05rem;
    }

    .comparison-table {
      width: 100%;
      border-collapse: collapse;
      margin: 2rem 0;
      font-family: 'JetBrains Mono', monospace;
    }

    .comparison-table th,
    .comparison-table td {
      padding: 1rem;
      text-align: left;
      border-bottom: 1px solid var(--border-color);
    }

    .comparison-table th {
      color: var(--text-muted);
      font-size: 0.85rem;
      text-transform: uppercase;
      font-family: 'Inter', sans-serif;
      font-weight: 600;
    }

    .comparison-table td {
      font-size: 0.95rem;
    }

    .comparison-table tr:hover td {
      background: rgba(255,255,255,0.02);
    }

    .ticker-col {
      font-weight: 700;
      color: var(--white);
      display: flex;
      align-items: center;
      gap: 0.5rem;
    }

    .highlight-row {
      background: rgba(74, 143, 231, 0.05);
    }

    .highlight-row td {
      border-bottom-color: rgba(74, 143, 231, 0.2);
    }

    .winner-badge {
      font-size: 0.65rem;
      background: var(--accent-color);
      color: #fff;
      padding: 0.2rem 0.5rem;
      border-radius: 4px;
      font-family: 'Inter', sans-serif;
      text-transform: uppercase;
    }

    .holdings-list {
      list-style: none;
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
      gap: 1rem;
    }

    .holding-item {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 1rem;
      background: rgba(255,255,255,0.02);
      border: 1px solid var(--border-color);
      border-radius: 8px;
    }

    .holding-ticker {
      font-weight: 700;
      color: var(--white);
      font-family: 'JetBrains Mono', monospace;
    }

    .holding-name {
      color: var(--text-muted);
      font-size: 0.85rem;
      margin-left: 0.5rem;
    }

    .holding-weight {
      color: var(--accent-color);
      font-weight: 600;
      font-family: 'JetBrains Mono', monospace;
    }

    .chart-container {
      position: relative;
      height: 300px;
      width: 100%;
      margin: 2rem 0;
    }

    .faq-item {
      border-bottom: 1px solid var(--border-color);
      padding: 1.5rem 0;
    }

    .faq-q {
      font-size: 1.2rem;
      font-weight: 700;
      color: var(--white);
      margin-bottom: 0.5rem;
      cursor: pointer;
    }

    .faq-a {
      color: var(--text-muted);
    }

    footer {
      text-align: center;
      padding: 3rem 1.5rem;
      border-top: 1px solid var(--border-color);
      margin-top: 4rem;
      color: var(--text-muted);
      font-size: 0.85rem;
    }

    @media (max-width: 768px) {
      h1 { font-size: 2.5rem; }
      nav { flex-direction: column; gap: 1rem; }
      nav .links { margin-left: 0; display: flex; gap: 1rem; }
      nav .links a { margin-left: 0; }
      .comparison-table { display: block; overflow-x: auto; }
    }
  </style>

<div class="container">
    <div class="hero">
      <div class="tagline">ETF Review 2026</div>
      <h1>Invesco QQQ Trust (Nasdaq-100)</h1>
      <p class="hero-desc">An in-depth review of the QQQ ETF. We analyze its heavily concentrated tech holdings, performance history, and compare it head-to-head with SPY and its cheaper twin, QQQM.</p>
    </div>

    <div class="stats-grid" id="main-stats">
      <!-- Injected via JS -->
    </div>

    <div class="content-block">
      <h2>The Bottom Line</h2>
      <p>The Invesco QQQ Trust (QQQ) tracks the Nasdaq-100 Index, holding the 100 largest non-financial companies listed on the Nasdaq. It has been one of the best-performing ETFs of the last decade, driven largely by the massive growth of mega-cap technology companies.</p>
      <p>While its returns have been stellar, QQQ comes with significantly higher volatility and concentration risk compared to a broad market index like the S&P 500. For long-term retail investors, the newer <strong>QQQM</strong> offers the exact same portfolio at a lower expense ratio.</p>
    </div>

    <h2 class="section-title">QQQ vs. QQQM vs. SPY vs. VOO</h2>
    <p>How does QQQ stack up against the broader S&P 500 (SPY/VOO) and its cheaper counterpart (QQQM)? Here is a side-by-side comparison:</p>

    <div class="content-block" style="padding: 1rem;">
      <div class="table-controls" style="margin-bottom: 1rem; display: flex; justify-content: space-between; align-items: center; gap: 1rem; flex-wrap: wrap;">
        <input type="text" id="table-search" placeholder="Search ETFs..." style="padding: 0.5rem 1rem; border-radius: 8px; border: 1px solid var(--border-color); background: rgba(255,255,255,0.05); color: var(--white); font-family: 'Inter', sans-serif; min-width: 250px;">
        <div style="font-size: 0.85rem; color: var(--text-muted);">Click headers to sort</div>
      </div>
      <table class="comparison-table" id="comparison-table">
        <thead>
          <tr>
            <th data-sort="ticker" style="cursor: pointer;">ETF ↕</th>
            <th data-sort="name" style="cursor: pointer;">Name ↕</th>
            <th data-sort="expense" style="cursor: pointer;">Expense Ratio ↕</th>
            <th data-sort="aum" style="cursor: pointer;">AUM ↕</th>
            <th data-sort="return" style="cursor: pointer;">10Y Return ↕</th>
          </tr>
        </thead>
        <tbody>
          <!-- Injected via JS -->
        </tbody>
      </table>
    </div>

    <p><strong>The Verdict:</strong> For long-term holders wanting Nasdaq-100 exposure, <strong>QQQM</strong> is the superior choice over QQQ due to its lower fee (0.15% vs 0.18%). If you want more diversification and less volatility, a low-cost S&P 500 fund like <strong>VOO</strong> remains the gold standard.</p>

    <h2 class="section-title">Performance History</h2>
    <div class="content-block">
      <div class="chart-container">
        <canvas id="performanceChart"></canvas>
      </div>
      <p style="font-size: 0.9rem; color: var(--text-muted); text-align: center; margin-top: 1rem;">Trailing total returns (including dividends). Note: QQQM inception was late 2020.</p>
    </div>

    <h2 class="section-title">Top 10 Holdings</h2>
    <p>Because QQQ is market-cap weighted and focuses only on 100 companies, it is heavily concentrated. The top 10 holdings account for a massive portion of the ETF's total performance:</p>
    <div class="content-block">
      <ul class="holdings-list" id="holdings-list">
        <!-- Injected via JS -->
      </ul>
    </div>

    <h2 class="section-title">Frequently Asked Questions</h2>
    <div class="content-block">
      <div class="faq-item">
        <div class="faq-q">What is the QQQ ETF expense ratio?</div>
        <div class="faq-a">The Invesco QQQ Trust (QQQ) has an expense ratio of 0.18%. This means you pay $18 annually for every $10,000 invested.</div>
      </div>
      <div class="faq-item">
        <div class="faq-q">QQQ vs SPY: Which is better?</div>
        <div class="faq-a">QQQ focuses on the top 100 non-financial Nasdaq companies, making it heavily tech-weighted with higher historical growth and volatility. SPY tracks the broader S&P 500, offering more diversification across all sectors. The better choice depends on your risk tolerance and need for diversification.</div>
      </div>
      <div class="faq-item">
        <div class="faq-q">QQQ vs QQQM: What is the difference?</div>
        <div class="faq-a">QQQ and QQQM track the exact same Nasdaq-100 index. However, QQQM is designed for buy-and-hold retail investors with a lower expense ratio (0.15% vs 0.18%) and a lower share price. QQQ has vastly higher trading volume, making it better for day traders and options.</div>
      </div>
      <div class="faq-item">
        <div class="faq-q">Does QQQ pay dividends?</div>
        <div class="faq-a">Yes, QQQ pays a quarterly dividend, although the yield is typically very low (around 0.29%) because it primarily holds growth-oriented technology companies that reinvest profits rather than paying them out.</div>
      </div>
      <div class="faq-item">
        <div class="faq-q">What companies are in QQQ?</div>
        <div class="faq-a">QQQ holds the 100 largest non-financial companies listed on the Nasdaq exchange. The top holdings are dominated by mega-cap tech companies such as Apple, Microsoft, NVIDIA, Amazon, and Meta.</div>
      </div>
    </div>

    <h2 class="section-title">Methodology</h2>
    <div class="content-block">
      <p style="font-size: 0.9rem; color: var(--text-muted);">Data presented on this page is sourced directly from live market feeds via Yahoo Finance API. Expense ratios, Assets Under Management (AUM), and performance metrics are updated automatically to reflect real-time trailing data as of 2026. Top holdings are based on the fund's most recent disclosures.</p>
    </div>

  </div>
  <script is:inline>
const etfData = `{"QQQ":{"name":"Invesco QQQ Trust","expenseRatio":"0.18","aum":"234.78","dividendYield":"0.29","yr1Return":"26.06","yr5Return":"12.71","yr10Return":"19.73","topHoldings":[{"symbol":"NVDA","name":"NVIDIA Corp","percent":8.39326},{"symbol":"AAPL","name":"Apple Inc","percent":7.609430000000001},{"symbol":"MSFT","name":"Microsoft Corp","percent":5.6900803},{"symbol":"AMZN","name":"Amazon.com Inc","percent":4.37613},{"symbol":"TSLA","name":"Tesla Inc","percent":3.9161302},{"symbol":"META","name":"Meta Platforms Inc Class A","percent":3.71074},{"symbol":"GOOGL","name":"Alphabet Inc Class A","percent":3.53573},{"symbol":"WMT","name":"Walmart Inc","percent":3.3651599999999995},{"symbol":"GOOG","name":"Alphabet Inc Class C","percent":3.28247},{"symbol":"AVGO","name":"Broadcom Inc","percent":2.9416}]},"QQQM":{"name":"Invesco NASDAQ 100 ETF","expenseRatio":"0.15","aum":"70.71","dividendYield":"0.50","yr1Return":"26.07","yr5Return":"12.80","yr10Return":"N/A","topHoldings":[{"symbol":"NVDA","name":"NVIDIA Corp","percent":8.38237},{"symbol":"AAPL","name":"Apple Inc","percent":7.5995594},{"symbol":"MSFT","name":"Microsoft Corp","percent":5.68271},{"symbol":"AMZN","name":"Amazon.com Inc","percent":4.3704600000000005},{"symbol":"TSLA","name":"Tesla Inc","percent":3.91108},{"symbol":"META","name":"Meta Platforms Inc Class A","percent":3.7059300000000004},{"symbol":"GOOGL","name":"Alphabet Inc Class A","percent":3.53111},{"symbol":"WMT","name":"Walmart Inc","percent":3.36078},{"symbol":"GOOG","name":"Alphabet Inc Class C","percent":3.2781900000000004},{"symbol":"AVGO","name":"Broadcom Inc","percent":2.93778}]},"SPY":{"name":"State Street SPDR S&P 500 ETF Trust","expenseRatio":"0.09","aum":"611.30","dividendYield":"0.84","yr1Return":"21.16","yr5Return":"11.25","yr10Return":"14.25","topHoldings":[{"symbol":"NVDA","name":"NVIDIA Corp","percent":7.315240000000001},{"symbol":"AAPL","name":"Apple Inc","percent":6.632059999999999},{"symbol":"MSFT","name":"Microsoft Corp","percent":4.9592},{"symbol":"AMZN","name":"Amazon.com Inc","percent":3.47069},{"symbol":"GOOGL","name":"Alphabet Inc Class A","percent":3.08148},{"symbol":"AVGO","name":"Broadcom Inc","percent":2.5636699},{"symbol":"GOOG","name":"Alphabet Inc Class C","percent":2.46022},{"symbol":"META","name":"Meta Platforms Inc Class A","percent":2.3982301},{"symbol":"TSLA","name":"Tesla Inc","percent":1.92143},{"symbol":"BRK-B","name":"Berkshire Hathaway Inc Class B","percent":1.5729700999999998}]},"VOO":{"name":"Vanguard S&P 500 ETF","expenseRatio":"0.03","aum":"1512.90","dividendYield":"0.87","yr1Return":"21.22","yr5Return":"11.32","yr10Return":"14.33","topHoldings":[{"symbol":"NVDA","name":"NVIDIA Corp","percent":7.827580000000001},{"symbol":"AAPL","name":"Apple Inc","percent":6.461989999999999},{"symbol":"MSFT","name":"Microsoft Corp","percent":5.3899},{"symbol":"AMZN","name":"Amazon.com Inc","percent":3.9234299999999998},{"symbol":"GOOGL","name":"Alphabet Inc Class A","percent":3.3143},{"symbol":"GOOG","name":"Alphabet Inc Class C","percent":2.6530199},{"symbol":"AVGO","name":"Broadcom Inc","percent":2.63679},{"symbol":"META","name":"Meta Platforms Inc Class A","percent":2.62994},{"symbol":"TSLA","name":"Tesla Inc","percent":2.0383101},{"symbol":"BRK-B","name":"Berkshire Hathaway Inc Class B","percent":1.48507}]}}`;
    const parsedData = JSON.parse(etfData);

    // Populate Hero Stats for QQQ
    const mainEtf = parsedData['QQQ'];
    if(mainEtf) {
      document.getElementById('main-stats').innerHTML = `
        <div class="stat-card featured">
          <div class="stat-value">${mainEtf.expenseRatio}%</div>
          <div class="stat-label">Expense Ratio</div>
        </div>
        <div class="stat-card">
          <div class="stat-value">$${mainEtf.aum}B</div>
          <div class="stat-label">Assets (AUM)</div>
        </div>
        <div class="stat-card">
          <div class="stat-value">${mainEtf.yr5Return}%</div>
          <div class="stat-label">5-Year Return</div>
        </div>
        <div class="stat-card">
          <div class="stat-value">${mainEtf.dividendYield}%</div>
          <div class="stat-label">Dividend Yield</div>
        </div>
      `;

      // Populate Holdings
      const holdingsHTML = mainEtf.topHoldings.slice(0, 10).map(h => `
        <li class="holding-item">
          <div>
            <span class="holding-ticker">${h.symbol}</span>
            <span class="holding-name">${h.name}</span>
          </div>
          <span class="holding-weight">${h.percent.toFixed(2)}%</span>
        </li>
      `).join('');
      document.getElementById('holdings-list').innerHTML = holdingsHTML;
    }

    // Populate Comparison Table
    const tableBody = document.querySelector('#comparison-table tbody');
    let tableData = ['QQQ', 'QQQM', 'SPY', 'VOO'].map(sym => ({
      sym,
      ...parsedData[sym]
    })).filter(d => d.name);

    function renderTable(data) {
      tableBody.innerHTML = '';
      data.forEach(d => {
        const isWinner = d.sym === 'QQQM' || d.sym === 'VOO';
        const rowClass = d.sym === 'QQQ' ? 'highlight-row' : '';
        const ret10 = d.yr10Return !== 'N/A' ? '+' + d.yr10Return + '%' : 'N/A';
        tableBody.innerHTML += `
          <tr class="${rowClass}">
            <td class="ticker-col">${d.sym} ${isWinner ? '<span class="winner-badge">Pick</span>' : ''}</td>
            <td>${d.name}</td>
            <td style="color: ${isWinner ? 'var(--positive)' : 'inherit'}; font-weight: ${isWinner ? 'bold' : 'normal'}">${d.expenseRatio}%</td>
            <td>$${d.aum}B</td>
            <td style="color: ${d.yr10Return !== 'N/A' ? 'var(--positive)' : 'var(--text-muted)'}">${ret10}</td>
          </tr>
        `;
      });
    }

    renderTable(tableData);

    // Search functionality
    document.getElementById('table-search').addEventListener('input', (e) => {
      const term = e.target.value.toLowerCase();
      const filtered = tableData.filter(d =>
        d.sym.toLowerCase().includes(term) || d.name.toLowerCase().includes(term)
      );
      renderTable(filtered);
    });

    // Sort functionality
    let sortCol = '';
    let sortAsc = true;
    document.querySelectorAll('#comparison-table th').forEach(th => {
      th.addEventListener('click', () => {
        const col = th.dataset.sort;
        if (sortCol === col) {
          sortAsc = !sortAsc;
        } else {
          sortCol = col;
          sortAsc = true;
        }

        const sorted = [...tableData].sort((a, b) => {
          let valA, valB;
          if (col === 'ticker') { valA = a.sym; valB = b.sym; }
          else if (col === 'name') { valA = a.name; valB = b.name; }
          else if (col === 'expense') { valA = parseFloat(a.expenseRatio); valB = parseFloat(b.expenseRatio); }
          else if (col === 'aum') { valA = parseFloat(a.aum); valB = parseFloat(b.aum); }
          else if (col === 'return') {
             valA = a.yr10Return === 'N/A' ? -999 : parseFloat(a.yr10Return);
             valB = b.yr10Return === 'N/A' ? -999 : parseFloat(b.yr10Return);
          }

          if (valA < valB) return sortAsc ? -1 : 1;
          if (valA > valB) return sortAsc ? 1 : -1;
          return 0;
        });

        // Update headers visual
        document.querySelectorAll('#comparison-table th').forEach(h => {
          h.innerText = h.innerText.replace(' ↑', '').replace(' ↓', '').replace(' ↕', '') + ' ↕';
        });
        th.innerText = th.innerText.replace(' ↕', '') + (sortAsc ? ' ↑' : ' ↓');

        // Render sorted data but respect search term if any
        const term = document.getElementById('table-search').value.toLowerCase();
        const filtered = sorted.filter(d =>
          d.sym.toLowerCase().includes(term) || d.name.toLowerCase().includes(term)
        );
        renderTable(filtered);
      });
    });

    // Chart
    const ctx = document.getElementById('performanceChart').getContext('2d');

    // Check if QQQM exists and has data
    const qqq = parsedData['QQQ'];
    const qqqm = parsedData['QQQM'];
    const spy = parsedData['SPY'];

    const datasets = [
      {
        label: 'QQQ Return',
        data: [parseFloat(qqq.yr1Return), parseFloat(qqq.yr5Return), parseFloat(qqq.yr10Return)],
        backgroundColor: '#4a8fe7',
        borderRadius: 6
      },
      {
        label: 'SPY Return',
        data: [parseFloat(spy.yr1Return), parseFloat(spy.yr5Return), parseFloat(spy.yr10Return)],
        backgroundColor: '#10b981',
        borderRadius: 6
      }
    ];

    new Chart(ctx, {
