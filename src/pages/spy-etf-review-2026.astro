        renderTable(data.tableData);

        // Sorting Logic
        let sortCol = -1;
        let sortAsc = true;
        window.sortTable = function(colIndex) {
            if (sortCol === colIndex) sortAsc = !sortAsc;
            else { sortCol = colIndex; sortAsc = true; }

            const keys = ['ticker', 'expenseRatio', 'aum', 'yield', 'ytd', 'fiveYr', 'volume'];
            const key = keys[colIndex];

            const sorted = [...data.tableData].sort((a, b) => {
                let valA = a[key];
                let valB = b[key];

                if (key === 'expenseRatio' || key === 'yield' || key === 'ytd' || key === 'fiveYr') {
                    valA = parseFloat(valA);
                    valB = parseFloat(valB);
                } else if (key === 'aum') {
                    valA = parseFloat(valA.replace(/[\$\,B]/g, ''));
                    valB = parseFloat(valB.replace(/[\$\,B]/g, ''));
                } else if (key === 'volume') {
                    valA = parseInt(valA.replace(/,/g, ''));
                    valB = parseInt(valB.replace(/,/g, ''));
                }

                if (valA < valB) return sortAsc ? -1 : 1;
                if (valA > valB) return sortAsc ? 1 : -1;
                return 0;
            });
