---
import SiteLayout from "../layouts/SiteLayout.astro";

// --- METADATA ---
export const meta = {
  title: "Costco Wholesale Corporation (COST) Intrinsic Value",
  description: "An independent discounted cash flow (DCF) intrinsic value analysis of Costco Wholesale Corporation (COST) compiled entirely by Gemini 3.1.",
  category: "study",
  published: "2026-03-18",
};

// --- DATA & ASSUMPTIONS (FY2025 Actuals) ---
// FCF Growth (Y1-Y5): 11%. Consistent membership fee hikes, e-commerce scale, and sticky international expansion fuel reliable compound growth.
// Discount Rate (WACC): 8.5%. With a virtually recession-proof model, low beta, and rock-solid balance sheet, 8.5% is a premium to the 4.18% 10-yr treasury.
// Terminal Growth: 3.5%. Outpacing standard inflation long-term through massive pricing power and secular moat.

const baseFCF = 7837; // in Millions
const sharesOut = 443.692; // in Millions
const currentPrice = 988.74;
const totalCash = 18240;
const totalDebt = 8335;
const netCash = totalCash - totalDebt;

const fcfGrowthRate = 0.11;
const discountRate = 0.085;
const terminalGrowthRate = 0.035;

// --- YEAR 1 TO 5 PROJECTIONS ---
const projections = [];
let prevFCF = baseFCF;

for (let i = 1; i <= 5; i++) {
  const projectedFCF = prevFCF * (1 + fcfGrowthRate);
  const discountFactor = Math.pow(1 + discountRate, i);
  const pvOfFCF = projectedFCF / discountFactor;

  projections.push({
    year: `Year ${i}`,
    fcf: projectedFCF,
    pv: pvOfFCF
  });

  prevFCF = projectedFCF;
}

const sumPvFcf = projections.reduce((sum, p) => sum + p.pv, 0);

// --- TERMINAL VALUE ---
const year5FCF = projections[4].fcf;
const terminalValue = (year5FCF * (1 + terminalGrowthRate)) / (discountRate - terminalGrowthRate);
const pvTerminalValue = terminalValue / Math.pow(1 + discountRate, 5);

// --- INTRINSIC VALUE CALCULATION ---
const enterpriseValue = sumPvFcf + pvTerminalValue;
const totalEquityValue = enterpriseValue + netCash;
const intrinsicValuePerShare = totalEquityValue / sharesOut;

// Value vs Current Price
const marginOfSafety = ((intrinsicValuePerShare - currentPrice) / currentPrice) * 100;
const isUndervalued = intrinsicValuePerShare > currentPrice;

// --- SENSITIVITY MATRIX ---
const sensitivityDiscountRates = [0.075, 0.080, 0.085, 0.090, 0.095];
const sensitivityGrowthRates = [0.025, 0.030, 0.035, 0.040, 0.045];

const sensitivityMatrix = sensitivityGrowthRates.map(g => {
  return {
    growthRate: g,
    values: sensitivityDiscountRates.map(d => {
      // Re-calculate TV and PV with new rates
      const currentTerminalValue = (year5FCF * (1 + g)) / (d - g);
      const currentPvTerminalValue = currentTerminalValue / Math.pow(1 + d, 5);

      // Re-calculate PV of FCFs with new discount rate
      let currentSumPvFcf = 0;
      let tempFcf = baseFCF;
      for (let i = 1; i <= 5; i++) {
        tempFcf = tempFcf * (1 + fcfGrowthRate);
        currentSumPvFcf += tempFcf / Math.pow(1 + d, i);
      }

      const currentEV = currentSumPvFcf + currentPvTerminalValue;
      const currentEquity = currentEV + netCash;
      const currentIV = currentEquity / sharesOut;

      return currentIV;
    })
  };
});

// Formatting helpers
const formatMoney = (val) => new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD', minimumFractionDigits: 2, maximumFractionDigits: 2 }).format(val);
const formatMillions = (val) => '$' + new Intl.NumberFormat('en-US', { maximumFractionDigits: 0 }).format(val) + 'M';
const formatPercent = (val) => (val * 100).toFixed(1) + '%';

// --- SCHEMA ---
const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Article",
      "headline": meta.title,
      "description": meta.description,
      "author": {
        "@type": "Organization",
        "name": "Gemini 3.1"
      },
      "publisher": {
        "@type": "Organization",
        "name": "Westmount Fundamentals",
        "logo": {
          "@type": "ImageObject",
          "url": "https://westmountfundamentals.com/logo.png"
        }
      },
      "mainEntityOfPage": {
        "@type": "WebPage",
        "@id": "https://westmountfundamentals.com/costco-intrinsic-value"
      }
    },
    {
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "Why did Gemini pick an 11% growth rate for Costco?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Gemini projects an 11% FCF growth rate driven by reliable membership fee hikes, an expanding high-margin e-commerce presence, and compounding returns from successful international store rollouts."
          }
        },
        {
          "@type": "Question",
          "name": "What discount rate was used for Costco's DCF?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "An 8.5% discount rate was selected. This reflects a virtually recession-proof business model, low stock beta, and massive net cash position ($18.2B cash vs $8.3B debt), meriting a solid premium to the 4.18% 10-year treasury."
          }
        },
        {
          "@type": "Question",
          "name": "Is Costco's terminal growth rate justifiable at 3.5%?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Yes. A 3.5% terminal growth rate outpaces standard long-term GDP growth, acknowledging Costco's entrenched pricing power and loyal membership base which creates a secular moat."
          }
        }
      ]
    }
  ]
};
---
<SiteLayout site="westmount" title={meta.title} description={meta.description} canonical="https://westmountfundamentals.com/costco-intrinsic-value" schema={schema}>
  <div class="page-content">
    <div class="container">

      <div class="gemini-header">
        <div class="gemini-badge">COMPILED BY GEMINI 2.5 PRO</div>
        <h1>Costco (COST) Intrinsic Value</h1>
        <p class="subtitle">An independent two-stage DCF analysis by a frontier AI model.</p>
      </div>

      <div class="verdict-card">
        <div class="verdict-header">
          <h2>Fair Value Estimate</h2>
        </div>
        <div class="verdict-body">
          <div class="verdict-main">
            <span class="iv-value">{formatMoney(intrinsicValuePerShare)}</span>
            <span class="iv-label">per share</span>
          </div>
          <div class="verdict-stats">
            <div class="stat">
              <span class="stat-label">Current Price</span>
              <span class="stat-value">{formatMoney(currentPrice)}</span>
            </div>
            <div class="stat">
              <span class="stat-label">Margin of Safety</span>
              <span class={`stat-value ${isUndervalued ? 'positive' : 'negative'}`}>
                {isUndervalued ? '+' : ''}{marginOfSafety.toFixed(2)}%
              </span>
            </div>
            <div class="stat">
              <span class="stat-label">Verdict</span>
              <span class={`badge ${isUndervalued ? 'positive' : 'negative'}`}>
                {isUndervalued ? 'UNDERVALUED' : 'OVERVALUED'}
              </span>
            </div>
          </div>
        </div>
        <div class="verdict-footer">
          <p>Based on FY2025 actuals. Data via S&P Global Market Intelligence (Mar 2026).</p>
        </div>
      </div>

      <section class="content-section">
        <h2>The AI Thesis: Why I Value Costco's Moat</h2>
        <p>Costco is not just a retailer; it is an incredible, cash-generating membership club masquerading as a grocer. While traditional retail is subject to extreme cyclicality, supply chain shocks, and rapidly compressing margins due to e-commerce, Costco fundamentally bypasses these issues. The core insight of my valuation hinges on the realization that <strong>the vast majority of Costco's bottom-line profit comes directly from high-margin membership fees</strong>, while merchandise is sold at near break-even to drive retention.</p>
        <p>This creates a flywheel effect: lower prices drive higher membership renewal rates (consistently above 90%), which leads to more predictable cash flows, fueling further expansion domestically and internationally. The premium valuation assigned to Costco reflects the market pricing in the extreme safety and predictability of its cash generation.</p>
      </section>

      <section class="content-section">
        <h2>My Assumptions & Rationale</h2>

        <div class="assumption-grid">
          <div class="assumption-card">
            <div class="card-title">FCF Growth Rate (Y1-Y5)</div>
            <div class="card-value">{formatPercent(fcfGrowthRate)}</div>
            <p><strong>Rationale:</strong> An 11% compound growth rate is robust, underpinned by consistent, predictable membership fee hikes over the coming years, coupled with scaling high-margin segments like Costco Logistics (big-and-bulky e-commerce delivery) and aggressive, highly profitable international store rollouts in markets like China and Europe.</p>
          </div>

          <div class="assumption-card">
            <div class="card-title">Discount Rate (WACC)</div>
            <div class="card-value">{formatPercent(discountRate)}</div>
            <p><strong>Rationale:</strong> At 8.5%, this aggressively low discount rate acknowledges Costco's fortress balance sheet ($18.2B cash vs. $8.3B debt). Even with the 10-year treasury at 4.18%, Costco's historically low beta and near-immunity to macro-recessions warrant a lower equity risk premium than the broader S&P 500.</p>
          </div>

          <div class="assumption-card">
            <div class="card-title">Terminal Growth Rate</div>
            <div class="card-value">{formatPercent(terminalGrowthRate)}</div>
            <p><strong>Rationale:</strong> 3.5% outpaces long-term standard GDP growth. Costco possesses unmatched pricing power; its loyal member base essentially treats the membership fee as a fixed utility cost. This dynamic ensures that Costco can safely pass on inflation directly to the consumer without sacrificing volume long-term.</p>
          </div>
        </div>
      </section>

      <section class="content-section">
        <h2>Discounted Cash Flow (DCF) Projections</h2>
        <p>Starting from a robust base FCF of {formatMillions(baseFCF)} in FY2025, the model outlines a highly visible, 5-year compounding path discounted at my chosen {formatPercent(discountRate)} WACC.</p>

        <div class="table-container">
          <table>
            <thead>
              <tr>
                <th>Period</th>
                <th>Projected FCF</th>
                <th>PV Factor ({formatPercent(discountRate)})</th>
                <th>Present Value</th>
              </tr>
            </thead>
            <tbody>
              {projections.map((p, index) => (
                <tr>
                  <td>{p.year}</td>
                  <td>{formatMillions(p.fcf)}</td>
                  <td>{(1 / Math.pow(1 + discountRate, index + 1)).toFixed(4)}</td>
                  <td>{formatMillions(p.pv)}</td>
                </tr>
              ))}
              <tr class="highlight-row">
                <td colspan="3"><strong>Sum of PV of FCFs (Years 1-5)</strong></td>
                <td><strong>{formatMillions(sumPvFcf)}</strong></td>
              </tr>
            </tbody>
          </table>
        </div>
      </section>

      <section class="content-section">
        <h2>Terminal & Final Valuation Math</h2>
        <p>Costco's predictability allows for a reliable Gordon Growth Model projection for Year 6 into perpetuity.</p>

        <div class="math-card">
          <div class="math-row">
            <span>Year 5 FCF</span>
            <span>{formatMillions(year5FCF)}</span>
          </div>
          <div class="math-row">
            <span>Terminal Value (TV) Calculation</span>
            <span>({formatMillions(year5FCF)} * {1 + terminalGrowthRate}) / ({discountRate} - {terminalGrowthRate})</span>
          </div>
          <div class="math-row">
            <span>Terminal Value</span>
            <span>{formatMillions(terminalValue)}</span>
          </div>
          <div class="math-row highlight">
            <span>PV of Terminal Value</span>
            <span>{formatMillions(pvTerminalValue)}</span>
          </div>
        </div>

        <p style="margin-top: 2rem;">Consolidating EV, net cash position, and outstanding shares:</p>

        <div class="math-card">
          <div class="math-row">
            <span>Sum of PV of FCFs (Years 1-5)</span>
            <span>{formatMillions(sumPvFcf)}</span>
          </div>
          <div class="math-row">
            <span>+ PV of Terminal Value</span>
            <span>{formatMillions(pvTerminalValue)}</span>
          </div>
          <div class="math-row">
            <span><strong>= Enterprise Value</strong></span>
            <span><strong>{formatMillions(enterpriseValue)}</strong></span>
          </div>
          <div class="math-row">
            <span>+ Net Cash (Cash - Debt)</span>
            <span>{formatMillions(netCash)}</span>
          </div>
          <div class="math-row highlight">
            <span><strong>= Total Equity Value</strong></span>
            <span><strong>{formatMillions(totalEquityValue)}</strong></span>
          </div>
          <div class="math-row">
            <span>÷ Shares Outstanding</span>
            <span>{sharesOut.toLocaleString()}M</span>
          </div>
          <div class="math-row result">
            <span><strong>Intrinsic Value Per Share</strong></span>
            <span><strong>{formatMoney(intrinsicValuePerShare)}</strong></span>
          </div>
        </div>
      </section>

      <section class="content-section">
        <h2>Sensitivity Matrix</h2>
        <p>The market currently prices Costco for perfection. The matrix below reveals how violently the intrinsic value swings if Costco falters slightly on growth, or if interest rates remain structurally higher forcing up the WACC.</p>

        <div class="table-container sensitivity-table">
          <table>
            <thead>
              <tr>
                <th rowspan="2" class="corner-cell">Terminal<br/>Growth</th>
                <th colspan="5" class="header-cell">Discount Rate (WACC)</th>
              </tr>
              <tr>
                {sensitivityDiscountRates.map(d => <th>{formatPercent(d)}</th>)}
              </tr>
            </thead>
            <tbody>
              {sensitivityMatrix.map(row => (
                <tr>
                  <th class="row-header">{formatPercent(row.growthRate)}</th>
                  {row.values.map(val => (
                    <td class={
                      val > currentPrice * 1.15 ? "cell-undervalued" :
                      val < currentPrice * 0.85 ? "cell-overvalued" :
                      "cell-neutral"
                    }>
                      {formatMoney(val)}
                    </td>
                  ))}
                </tr>
              ))}
            </tbody>
          </table>
          <div class="matrix-legend">
            <span class="legend-item"><span class="color-box cell-undervalued"></span> Undervalued (>15% Margin)</span>
            <span class="legend-item"><span class="color-box cell-neutral"></span> Fair Value</span>
            <span class="legend-item"><span class="color-box cell-overvalued"></span> Overvalued (&lt;-15% Margin)</span>
          </div>
        </div>
      </section>

      <section class="content-section risks-section">
        <h2>Risks & Bear Case</h2>
        <p>The greatest risk to a Costco investment is valuation multiple compression. Here is where the thesis could crack:</p>
        <div class="risk-grid">
          <div class="risk-card">
            <h3>1. Valuation Priced for Perfection</h3>
            <p>At an extreme P/E multiple historically hovering around 50x+, there is virtually zero margin of safety built into the current stock price. Even a minor miss on earnings expectations or a slowdown in membership growth could trigger a violent multiple contraction.</p>
          </div>
          <div class="risk-card">
            <h3>2. E-Commerce Margins & Fulfillment</h3>
            <p>While Costco Logistics is growing, Costco remains a physical retailer at heart. If shifting consumer behavior necessitates an accelerated, heavy investment in faster, unprofitable e-commerce fulfillment to compete with Amazon, FCF margins could compress structurally.</p>
          </div>
          <div class="risk-card">
            <h3>3. International Saturation Limits</h3>
            <p>My 11% FCF growth model relies heavily on successful international expansion. If new markets reject the bulk-buy model or face extreme local logistical hurdles (as seen historically in some European tests), the growth trajectory will stall.</p>
          </div>
        </div>
      </section>

      <section class="content-section faq-section">
        <h2>Frequently Asked Questions</h2>

        <div class="faq-item">
          <h3>Why did Gemini pick an 11% growth rate for Costco?</h3>
          <p>Gemini projects an 11% FCF growth rate driven by reliable membership fee hikes, an expanding high-margin e-commerce presence, and compounding returns from successful international store rollouts.</p>
        </div>

        <div class="faq-item">
          <h3>What discount rate was used for Costco's DCF?</h3>
          <p>An 8.5% discount rate was selected. This reflects a virtually recession-proof business model, low stock beta, and massive net cash position ($18.2B cash vs $8.3B debt), meriting a solid premium to the 4.18% 10-year treasury.</p>
        </div>

        <div class="faq-item">
          <h3>Is Costco's terminal growth rate justifiable at 3.5%?</h3>
          <p>Yes. A 3.5% terminal growth rate outpaces standard long-term GDP growth, acknowledging Costco's entrenched pricing power and loyal membership base which creates a secular moat.</p>
        </div>
      </section>

      <div class="disclaimer-box">
        <p><strong>Disclaimer:</strong> The numbers presented on this page are for educational and entertainment purposes only. They are the result of a deterministic mathematical model fed with assumptions generated by an Artificial Intelligence (Gemini 3.1). This does not constitute investment advice. Always conduct your own due diligence before investing in the stock market.</p>
      </div>

    </div>
  </div>
</SiteLayout>
