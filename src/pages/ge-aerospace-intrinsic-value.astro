---
import SiteLayout from "../layouts/SiteLayout.astro";

// --- METADATA ---
export const meta = {
  title: "GE Aerospace (GE) Intrinsic Value",
  description: "An independent discounted cash flow (DCF) intrinsic value analysis of GE Aerospace (GE) compiled entirely by Gemini 3.1.",
  category: "study",
  published: "2026-03-18",
};

// --- DATA & ASSUMPTIONS (Most recent fiscal year, via S&P Global / Yahoo Finance) ---
// Base FCF: $5.21B
// Shares Out: 1,048.8M
// Current Price: $302.55
// Total Cash: $11.99B
// Total Debt: $21.56B
// FCF Growth (Y1-Y5): 12%. Rationale: GE Aerospace operates in a duopoly for large commercial aircraft engines with an immense backlog and long-term service agreements (which are very high margin). Post-spin-off, GE is a pure-play aerospace business. Commercial aviation demand remains strong, and defense budgets are elevated.
// Discount Rate (WACC): 8.5%. Rationale: GE is highly stable with wide economic moats. A beta around 1.0, and 4.18% 10-year treasury.
// Terminal Growth: 3.0%. Rationale: Aerospace engines are long-cycle businesses tied closely to global travel demand, slightly outpacing global GDP growth.

const baseFCF = 5211; // in Millions
const sharesOut = 1048.8; // in Millions
const currentPrice = 302.55;
const netCash = 11992 - 21557; // Cash - Debt in Millions (-9565)

const fcfGrowthRate = 0.12;
const discountRate = 0.085;
const terminalGrowthRate = 0.03;

// --- YEAR 1 TO 5 PROJECTIONS ---
const projections = [];
let prevFCF = baseFCF;

for (let i = 1; i <= 5; i++) {
  const projectedFCF = prevFCF * (1 + fcfGrowthRate);
  const discountFactor = Math.pow(1 + discountRate, i);
  const pvOfFCF = projectedFCF / discountFactor;

  projections.push({
    year: `Year ${i}`,
    fcf: projectedFCF,
    pv: pvOfFCF
  });

  prevFCF = projectedFCF;
}

const sumPvFcf = projections.reduce((sum, p) => sum + p.pv, 0);

// --- TERMINAL VALUE ---
const year5FCF = projections[4].fcf;
const terminalValue = (year5FCF * (1 + terminalGrowthRate)) / (discountRate - terminalGrowthRate);
const pvTerminalValue = terminalValue / Math.pow(1 + discountRate, 5);

// --- INTRINSIC VALUE CALCULATION ---
const enterpriseValue = sumPvFcf + pvTerminalValue;
const totalEquityValue = enterpriseValue + netCash;
const intrinsicValuePerShare = totalEquityValue / sharesOut;

// Value vs Current Price
const marginOfSafety = ((intrinsicValuePerShare - currentPrice) / currentPrice) * 100;
const isUndervalued = intrinsicValuePerShare > currentPrice;

// --- SENSITIVITY MATRIX ---
const sensitivityDiscountRates = [0.075, 0.080, 0.085, 0.090, 0.095];
const sensitivityGrowthRates = [0.020, 0.025, 0.030, 0.035, 0.040];

const sensitivityMatrix = sensitivityGrowthRates.map(g => {
  return {
    growthRate: g,
    values: sensitivityDiscountRates.map(d => {
      // Re-calculate TV and PV with new rates
      const currentTerminalValue = (year5FCF * (1 + g)) / (d - g);
      const currentPvTerminalValue = currentTerminalValue / Math.pow(1 + d, 5);

      // Re-calculate PV of FCFs with new discount rate
      let currentSumPvFcf = 0;
      let tempFcf = baseFCF;
      for (let i = 1; i <= 5; i++) {
        tempFcf = tempFcf * (1 + fcfGrowthRate);
        currentSumPvFcf += tempFcf / Math.pow(1 + d, i);
      }

      const currentEV = currentSumPvFcf + currentPvTerminalValue;
      const currentEquity = currentEV + netCash;
      const currentIV = currentEquity / sharesOut;

      return currentIV;
    })
  };
});

// Formatting helpers
const formatMoney = (val) => new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD', minimumFractionDigits: 2, maximumFractionDigits: 2 }).format(val);
const formatMillions = (val) => '$' + new Intl.NumberFormat('en-US', { maximumFractionDigits: 0 }).format(val) + 'M';
const formatPercent = (val) => (val * 100).toFixed(1) + '%';

// --- SCHEMA ---
const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Article",
      "headline": meta.title,
      "description": meta.description,
      "author": {
        "@type": "Organization",
        "name": "Gemini 3.1"
      },
      "publisher": {
        "@type": "Organization",
        "name": "Westmount Fundamentals",
        "logo": {
          "@type": "ImageObject",
          "url": "https://westmountfundamentals.com/logo.png"
        }
      },
      "mainEntityOfPage": {
        "@type": "WebPage",
        "@id": "https://westmountfundamentals.com/ge-aerospace-intrinsic-value"
      }
    },
    {
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "Why did Gemini project a 12% FCF growth rate for GE Aerospace?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Gemini assumes a 12% growth rate due to GE Aerospace's dominant position in a duopoly market for commercial aviation engines. The company possesses an immense backlog, and its long-term service agreements provide high-margin, recurring revenue that scales as engine fleet utilization increases."
          }
        },
        {
          "@type": "Question",
          "name": "What discount rate (WACC) was applied to the GE DCF model?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "An 8.5% discount rate was selected. This is justified by GE's highly stable, wide-moat business model, a beta near 1.0, and the current 10-year treasury yield of 4.18%. The predictable nature of its service contracts warrants a relatively low cost of capital."
          }
        },
        {
          "@type": "Question",
          "name": "What is the terminal growth rate used for GE Aerospace?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "A 3.0% terminal growth rate was used. The commercial aerospace engine business is a long-cycle industry inherently tied to global travel demand, which is projected to slightly outpace global GDP growth over the long term."
          }
        }
      ]
    }
  ]
};
---
<SiteLayout site="westmount" title={meta.title} description={meta.description} canonical="https://westmountfundamentals.com/ge-aerospace-intrinsic-value" schema={schema}>
  <div class="page-content">
    <div class="container">

      <div class="gemini-header">
        <div class="gemini-badge">COMPILED BY GEMINI 2.5 PRO</div>
        <h1>GE Aerospace (GE) Intrinsic Value</h1>
        <p class="subtitle">An independent two-stage DCF analysis of the pure-play aerospace giant.</p>
      </div>

      <div class="verdict-card">
        <div class="verdict-header">
          <h2>Fair Value Estimate</h2>
        </div>
        <div class="verdict-body">
          <div class="verdict-main">
            <span class="iv-value">{formatMoney(intrinsicValuePerShare)}</span>
            <span class="iv-label">per share</span>
          </div>
          <div class="verdict-stats">
            <div class="stat">
              <span class="stat-label">Current Price</span>
              <span class="stat-value">{formatMoney(currentPrice)}</span>
            </div>
            <div class="stat">
              <span class="stat-label">Margin of Safety</span>
              <span class={`stat-value ${isUndervalued ? 'positive' : 'negative'}`}>
                {isUndervalued ? '+' : ''}{marginOfSafety.toFixed(2)}%
              </span>
            </div>
            <div class="stat">
              <span class="stat-label">Verdict</span>
              <span class={`badge ${isUndervalued ? 'positive' : 'negative'}`}>
                {isUndervalued ? 'UNDERVALUED' : 'OVERVALUED'}
              </span>
            </div>
          </div>
        </div>
        <div class="verdict-footer">
          <p>Based on recent trailing twelve-month data. Data via Yahoo Finance (Mar 18, 2026).</p>
        </div>
      </div>

      <section class="content-section">
        <h2>The Thesis: High-Margin Services Drive Value</h2>
        <p>Following its historic split into three distinct entities, GE Aerospace (GE) emerges as a remarkably focused, pure-play aerospace engine powerhouse. Dominating the widebody space with the GE90, GEnx, and GE9X, and capturing the narrowbody market via CFM International (LEAP engines), GE operates in a highly consolidated duopoly against Pratt & Whitney and Rolls-Royce.</p>
        <p>The core of GE's valuation lies not in the initial engine sale, which is often sold at a loss, but in the incredibly lucrative, multi-decade aftermarket service contracts. As the global commercial fleet expands and ages, these long-term service agreements provide immense, highly visible free cash flow generation. Coupled with robust defense spending, GE Aerospace is positioned to be a supreme cash-compounding engine over the next decade.</p>
      </section>

      <section class="content-section">
        <h2>My Assumptions & Rationale</h2>

        <div class="assumption-grid">
          <div class="assumption-card">
            <div class="card-title">FCF Growth Rate (Y1-Y5)</div>
            <div class="card-value">{formatPercent(fcfGrowthRate)}</div>
            <p><strong>Rationale:</strong> A 12% growth rate reflects GE's formidable pricing power and the structural growth of its high-margin services segment. Global airline capacity continues to climb, maximizing engine utilization. As next-generation LEAP engines enter their first major overhaul cycles, cash flow velocity will rapidly accelerate from the $5.21B base.</p>
          </div>

          <div class="assumption-card">
            <div class="card-title">Discount Rate (WACC)</div>
            <div class="card-value">{formatPercent(discountRate)}</div>
            <p><strong>Rationale:</strong> I've assigned an 8.5% discount rate. GE boasts immense revenue visibility via its multi-year backlog and service contracts, providing defensive stability. While the 10-year treasury is at 4.18%, GE's near-monopolistic positioning in key aircraft platforms results in a lower cost of equity, offset slightly by inherent supply chain execution risks.</p>
          </div>

          <div class="assumption-card">
            <div class="card-title">Terminal Growth Rate</div>
            <div class="card-value">{formatPercent(terminalGrowthRate)}</div>
            <p><strong>Rationale:</strong> 3.0% sits slightly above standard long-term global GDP forecasts. Commercial aviation is fundamentally tied to an expanding global middle class and increasing passenger miles flown. Aerospace engines are a profoundly long-cycle business, guaranteeing perpetual demand that naturally eclipses broader economic averages.</p>
          </div>
        </div>
      </section>

      <section class="content-section">
        <h2>Discounted Cash Flow (DCF) Projections</h2>
        <p>Starting with the trailing base FCF of {formatMillions(baseFCF)}, the following table outlines the 5-year projection discounted back to Present Value (PV) utilizing the {formatPercent(discountRate)} WACC.</p>

        <div class="table-container">
          <table>
            <thead>
              <tr>
                <th>Period</th>
                <th>Projected FCF</th>
                <th>PV Factor ({formatPercent(discountRate)})</th>
                <th>Present Value</th>
              </tr>
            </thead>
            <tbody>
              {projections.map((p, index) => (
                <tr>
                  <td>{p.year}</td>
                  <td>{formatMillions(p.fcf)}</td>
                  <td>{(1 / Math.pow(1 + discountRate, index + 1)).toFixed(4)}</td>
                  <td>{formatMillions(p.pv)}</td>
                </tr>
              ))}
              <tr class="highlight-row">
                <td colspan="3"><strong>Sum of PV of FCFs (Years 1-5)</strong></td>
                <td><strong>{formatMillions(sumPvFcf)}</strong></td>
              </tr>
            </tbody>
          </table>
        </div>
      </section>

      <section class="content-section">
        <h2>Terminal & Final Valuation Math</h2>
        <p>The Terminal Value accounts for all perpetual cash flows from Year 6 onward, calculated using the Gordon Growth Model.</p>

        <div class="math-card">
          <div class="math-row">
            <span>Year 5 FCF</span>
            <span>{formatMillions(year5FCF)}</span>
          </div>
          <div class="math-row">
            <span>Terminal Value (TV) Calculation</span>
            <span>({formatMillions(year5FCF)} * {1 + terminalGrowthRate}) / ({discountRate} - {terminalGrowthRate})</span>
          </div>
          <div class="math-row">
            <span>Terminal Value</span>
            <span>{formatMillions(terminalValue)}</span>
          </div>
          <div class="math-row highlight">
            <span>PV of Terminal Value</span>
            <span>{formatMillions(pvTerminalValue)}</span>
          </div>
        </div>

        <p style="margin-top: 2rem;">Summing the present values and adjusting for the company's net cash position:</p>

        <div class="math-card">
          <div class="math-row">
            <span>Sum of PV of FCFs (Years 1-5)</span>
            <span>{formatMillions(sumPvFcf)}</span>
          </div>
          <div class="math-row">
            <span>+ PV of Terminal Value</span>
            <span>{formatMillions(pvTerminalValue)}</span>
          </div>
          <div class="math-row">
            <span><strong>= Enterprise Value</strong></span>
            <span><strong>{formatMillions(enterpriseValue)}</strong></span>
          </div>
          <div class="math-row">
            <span>+ Net Cash (Cash - Debt)</span>
            <span>{formatMillions(netCash)}</span>
          </div>
          <div class="math-row highlight">
            <span><strong>= Total Equity Value</strong></span>
            <span><strong>{formatMillions(totalEquityValue)}</strong></span>
          </div>
          <div class="math-row">
            <span>÷ Shares Outstanding</span>
            <span>{sharesOut.toLocaleString()}M</span>
          </div>
          <div class="math-row result">
            <span><strong>Intrinsic Value Per Share</strong></span>
            <span><strong>{formatMoney(intrinsicValuePerShare)}</strong></span>
          </div>
        </div>
      </section>

      <section class="content-section">
        <h2>Sensitivity Matrix</h2>
        <p>Valuation models are sensitive to inputs. This matrix illustrates how GE's intrinsic value flexes under various Discount Rate (WACC) and Terminal Growth Rate assumptions.</p>

        <div class="table-container sensitivity-table">
          <table>
            <thead>
              <tr>
                <th rowspan="2" class="corner-cell">Terminal<br/>Growth</th>
                <th colspan="5" class="header-cell">Discount Rate (WACC)</th>
              </tr>
              <tr>
                {sensitivityDiscountRates.map(d => <th>{formatPercent(d)}</th>)}
              </tr>
            </thead>
            <tbody>
              {sensitivityMatrix.map(row => (
                <tr>
                  <th class="row-header">{formatPercent(row.growthRate)}</th>
                  {row.values.map(val => (
                    <td class={
                      val > currentPrice * 1.10 ? "cell-undervalued" :
                      val < currentPrice * 0.90 ? "cell-overvalued" :
                      "cell-neutral"
                    }>
                      {formatMoney(val)}
                    </td>
                  ))}
                </tr>
              ))}
            </tbody>
          </table>
          <div class="matrix-legend">
            <span class="legend-item"><span class="color-box cell-undervalued"></span> Undervalued (>10% Margin)</span>
            <span class="legend-item"><span class="color-box cell-neutral"></span> Fair Value</span>
            <span class="legend-item"><span class="color-box cell-overvalued"></span> Overvalued (&lt;-10% Margin)</span>
          </div>
        </div>
      </section>

      <section class="content-section risks-section">
        <h2>Risks & Bear Case</h2>
        <p>No investment is without risk. GE Aerospace's primary vulnerabilities center around manufacturing complexities and macroeconomic shocks.</p>
        <div class="risk-grid">
          <div class="risk-card">
            <h3>1. Supply Chain Bottlenecks</h3>
            <p>The aerospace sector is notoriously constrained by its complex supply chain. Material shortages, particularly in specialized alloys and titanium, or labor disputes can drastically impact engine delivery schedules, delaying both revenue recognition and the onset of lucrative service cycles.</p>
          </div>
          <div class="risk-card">
            <h3>2. Geopolitical and Macroeconomic Shocks</h3>
            <p>Commercial aviation demand is highly sensitive to global economic health and geopolitical stability. Pandemics, regional conflicts restricting airspace, or a severe global recession would immediately curtail airline capacity, decreasing engine utilization and gutting aftermarket service revenues.</p>
          </div>
          <div class="risk-card">
            <h3>3. Technical Defects and Groundings</h3>
            <p>A fatal design flaw or manufacturing defect leading to fleet-wide groundings (similar to historical Boeing incidents) would cause immense reputational damage and incur billions in financial liabilities, instantly destroying the DCF model's long-term assumptions.</p>
          </div>
        </div>
      </section>

      <section class="content-section faq-section">
        <h2>Frequently Asked Questions</h2>

        <div class="faq-item">
          <h3>Why did Gemini project a 12% FCF growth rate for GE Aerospace?</h3>
          <p>Gemini assumes a 12% growth rate due to GE Aerospace's dominant position in a duopoly market for commercial aviation engines. The company possesses an immense backlog, and its long-term service agreements provide high-margin, recurring revenue that scales as engine fleet utilization increases.</p>
        </div>

        <div class="faq-item">
          <h3>What discount rate (WACC) was applied to the GE DCF model?</h3>
          <p>An 8.5% discount rate was selected. This is justified by GE's highly stable, wide-moat business model, a beta near 1.0, and the current 10-year treasury yield of 4.18%. The predictable nature of its service contracts warrants a relatively low cost of capital.</p>
        </div>

        <div class="faq-item">
          <h3>What is the terminal growth rate used for GE Aerospace?</h3>
          <p>A 3.0% terminal growth rate was used. The commercial aerospace engine business is a long-cycle industry inherently tied to global travel demand, which is projected to slightly outpace global GDP growth over the long term.</p>
        </div>
      </section>

      <div class="disclaimer-box">
        <p><strong>Disclaimer:</strong> The numbers presented on this page are for educational and entertainment purposes only. They are the result of a deterministic mathematical model fed with assumptions generated by an Artificial Intelligence (Gemini 3.1). This does not constitute investment advice. Always conduct your own due diligence before investing in the stock market.</p>
      </div>

    </div>
  </div>
