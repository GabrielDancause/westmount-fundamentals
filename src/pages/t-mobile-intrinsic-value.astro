---
import SiteLayout from "../layouts/SiteLayout.astro";

// --- METADATA ---
export const meta = {
  title: "T-Mobile US, Inc. (TMUS) Intrinsic Value - Gemini's DCF Analysis",
  description: "An independent discounted cash flow (DCF) intrinsic value analysis of T-Mobile US, Inc. (TMUS) compiled entirely by Gemini 3.1.",
  category: "study",
  published: "2026-03-18",
};

// --- DATA & ASSUMPTIONS (FY2025 Actuals) ---
// Current Price: $208.73
// FCF Growth (Y1-Y5): 8%. Post-sprint integration and 5G buildout, Capex normalizes and FCF expands massively through scaling margins and share repurchases.
// Discount Rate (WACC): 8.0%. Given the stable nature of utility-like telecom revenues, offset by TMUS's significant $122B total debt load.
// Terminal Growth: 2.0%. Maturing telecom utility matching long-term inflation.

const baseFCF = 15427; // in Millions (from yfinance trailing 12m/FY2025)
const sharesOut = 1101.86; // in Millions
const currentPrice = 208.73;
const netCash = -116671; // Cash & Equivalents ($5.598B) - Total Debt ($122.269B) = -$116.671B

const fcfGrowthRate = 0.08;
const discountRate = 0.080;
const terminalGrowthRate = 0.020;

// --- YEAR 1 TO 5 PROJECTIONS ---
const projections = [];
let prevFCF = baseFCF;

for (let i = 1; i <= 5; i++) {
  const projectedFCF = prevFCF * (1 + fcfGrowthRate);
  const discountFactor = Math.pow(1 + discountRate, i);
  const pvOfFCF = projectedFCF / discountFactor;

  projections.push({
    year: `Year ${i}`,
    fcf: projectedFCF,
    pv: pvOfFCF
  });

  prevFCF = projectedFCF;
}

const sumPvFcf = projections.reduce((sum, p) => sum + p.pv, 0);

// --- TERMINAL VALUE ---
const year5FCF = projections[4].fcf;
const terminalValue = (year5FCF * (1 + terminalGrowthRate)) / (discountRate - terminalGrowthRate);
const pvTerminalValue = terminalValue / Math.pow(1 + discountRate, 5);

// --- INTRINSIC VALUE CALCULATION ---
const enterpriseValue = sumPvFcf + pvTerminalValue;
const totalEquityValue = enterpriseValue + netCash;
const intrinsicValuePerShare = totalEquityValue / sharesOut;

// Value vs Current Price
const marginOfSafety = ((intrinsicValuePerShare - currentPrice) / currentPrice) * 100;
const isUndervalued = intrinsicValuePerShare > currentPrice;

// --- SENSITIVITY MATRIX ---
const sensitivityDiscountRates = [0.070, 0.075, 0.080, 0.085, 0.090];
const sensitivityGrowthRates = [0.010, 0.015, 0.020, 0.025, 0.030];

const sensitivityMatrix = sensitivityGrowthRates.map(g => {
  return {
    growthRate: g,
    values: sensitivityDiscountRates.map(d => {
      // Re-calculate TV and PV with new rates
      const currentTerminalValue = (year5FCF * (1 + g)) / (d - g);
      const currentPvTerminalValue = currentTerminalValue / Math.pow(1 + d, 5);

      // Re-calculate PV of FCFs with new discount rate
      let currentSumPvFcf = 0;
      let tempFcf = baseFCF;
      for (let i = 1; i <= 5; i++) {
        tempFcf = tempFcf * (1 + fcfGrowthRate);
        currentSumPvFcf += tempFcf / Math.pow(1 + d, i);
      }

      const currentEV = currentSumPvFcf + currentPvTerminalValue;
      const currentEquity = currentEV + netCash;
      const currentIV = currentEquity / sharesOut;

      return currentIV;
    })
  };
});

// Formatting helpers
const formatMoney = (val) => new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD', minimumFractionDigits: 2, maximumFractionDigits: 2 }).format(val);
const formatMillions = (val) => '$' + new Intl.NumberFormat('en-US', { maximumFractionDigits: 0 }).format(val) + 'M';
const formatPercent = (val) => (val * 100).toFixed(1) + '%';

// --- SCHEMA ---
const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Article",
      "headline": meta.title,
      "description": meta.description,
      "author": {
        "@type": "Organization",
        "name": "Gemini 3.1"
      },
      "publisher": {
        "@type": "Organization",
        "name": "Westmount Fundamentals",
        "logo": {
          "@type": "ImageObject",
          "url": "https://westmountfundamentals.com/logo.png"
        }
      },
      "mainEntityOfPage": {
        "@type": "WebPage",
        "@id": "https://westmountfundamentals.com/t-mobile-intrinsic-value"
      }
    },
    {
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "Why did Gemini pick an 8% growth rate for T-Mobile?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Gemini models that T-Mobile has entered a 'harvesting' phase post-Sprint merger. As heavy 5G capital expenditures decline and the subscriber base continues to scale, operating leverage will drive strong, sustained cash flow expansion."
          }
        },
        {
          "@type": "Question",
          "name": "What discount rate was used for TMUS's DCF?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "An 8.0% discount rate was selected. Telecom revenues are highly resilient and utility-like, which usually commands a lower rate, but T-Mobile's significant debt load requires a slight premium to compensate for leverage risk."
          }
        },
        {
          "@type": "Question",
          "name": "Why is Net Cash deeply negative in this model?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "T-Mobile carries over $122 billion in total debt against just under $5.6 billion in cash. In a DCF, we must subtract this net debt from the total Enterprise Value to find the true Equity Value available to shareholders."
          }
        }
      ]
    }
  ]
};
---
<SiteLayout site="westmount" title={meta.title} description={meta.description} canonical="https://westmountfundamentals.com/t-mobile-intrinsic-value" schema={schema}>
  <div class="page-content">
    <div class="container">

      <div class="gemini-header">
        <div class="gemini-badge">COMPILED BY GEMINI 3.1</div>
        <h1>T-Mobile US, Inc. (TMUS) Intrinsic Value</h1>
        <p class="subtitle">An independent two-stage DCF analysis by a frontier AI model.</p>
      </div>

      <div class="verdict-card">
        <div class="verdict-header">
          <h2>Fair Value Estimate</h2>
        </div>
        <div class="verdict-body">
          <div class="verdict-main">
            <span class="iv-value">{formatMoney(intrinsicValuePerShare)}</span>
            <span class="iv-label">per share</span>
          </div>
          <div class="verdict-stats">
            <div class="stat">
              <span class="stat-label">Current Price</span>
              <span class="stat-value">{formatMoney(currentPrice)}</span>
            </div>
            <div class="stat">
              <span class="stat-label">Margin of Safety</span>
              <span class={`stat-value ${isUndervalued ? 'positive' : 'negative'}`}>
                {isUndervalued ? '+' : ''}{marginOfSafety.toFixed(2)}%
              </span>
            </div>
            <div class="stat">
              <span class="stat-label">Verdict</span>
              <span class={`badge ${isUndervalued ? 'positive' : 'negative'}`}>
                {isUndervalued ? 'UNDERVALUED' : 'OVERVALUED'}
              </span>
            </div>
          </div>
        </div>
        <div class="verdict-footer">
          <p>Based on FY2025 actuals. Data via S&P Global (Mar 17, 2026).</p>
        </div>
      </div>

      <section class="content-section">
        <h2>The AI Thesis: The Harvest Phase Has Begun</h2>
        <p>T-Mobile (TMUS) is no longer the scrappy "Un-carrier" underdog. Following its masterclass acquisition of Sprint and aggressive early deployment of mid-band 5G, T-Mobile has cemented itself as a dominant force in US telecommunications. The capital expenditure phase of building the nation's premier 5G network is largely in the rearview mirror.</p>
        <p>This transition marks a pivotal inflection point in valuation. As CapEx requirements normalize, the massive recurring revenues from its subscriber base are finally translating into pure, unadulterated Free Cash Flow. <strong>My analysis treats T-Mobile not as a high-growth tech stock, but as an incredibly efficient, cash-gushing utility</strong> entering a multi-year harvest cycle, heavily juiced by a monster share buyback program.</p>
      </section>

      <section class="content-section">
        <h2>My Assumptions & Rationale</h2>

        <div class="assumption-grid">
          <div class="assumption-card">
            <div class="card-title">FCF Growth Rate (Y1-Y5)</div>
            <div class="card-value">{formatPercent(fcfGrowthRate)}</div>
            <p><strong>Rationale:</strong> An 8% annual growth rate is robust for a mature telecom but entirely justified for TMUS. Revenue growth is stable, but the <em>cash flow</em> growth is driven by operating leverage. As the network scales, the marginal cost of a new subscriber approaches zero, leading to sustained FCF margin expansion over the next half-decade.</p>
          </div>

          <div class="assumption-card">
            <div class="card-title">Discount Rate (WACC)</div>
            <div class="card-value">{formatPercent(discountRate)}</div>
            <p><strong>Rationale:</strong> 8.0% balances the stability of telecom subscriptions against T-Mobile's highly leveraged balance sheet. While wireless service is practically a modern utility (implying low risk), the company carries over $122 billion in debt. An 8% WACC requires the company to deliver strong returns despite the cost of servicing this debt.</p>
          </div>

          <div class="assumption-card">
            <div class="card-title">Terminal Growth Rate</div>
            <div class="card-value">{formatPercent(terminalGrowthRate)}</div>
            <p><strong>Rationale:</strong> 2.0% aligns with long-term macroeconomic inflation targets and GDP growth. Telecoms ultimately scale with population growth and pricing power. Anything higher than 2-2.5% for a mature US telecom in perpetuity would be an aggressive overestimation of pricing power.</p>
          </div>
        </div>
      </section>

      <section class="content-section">
        <h2>Discounted Cash Flow (DCF) Projections</h2>
        <p>Starting with the FY2025 base FCF of {formatMillions(baseFCF)}, the table below outlines the 5-year projection discounted back to Present Value (PV) using the {formatPercent(discountRate)} WACC.</p>

        <div class="table-container">
          <table>
            <thead>
              <tr>
                <th>Period</th>
                <th>Projected FCF</th>
                <th>PV Factor ({formatPercent(discountRate)})</th>
                <th>Present Value</th>
              </tr>
            </thead>
            <tbody>
              {projections.map((p, index) => (
                <tr>
                  <td>{p.year}</td>
                  <td>{formatMillions(p.fcf)}</td>
                  <td>{(1 / Math.pow(1 + discountRate, index + 1)).toFixed(4)}</td>
                  <td>{formatMillions(p.pv)}</td>
                </tr>
              ))}
              <tr class="highlight-row">
                <td colspan="3"><strong>Sum of PV of FCFs (Years 1-5)</strong></td>
                <td><strong>{formatMillions(sumPvFcf)}</strong></td>
              </tr>
            </tbody>
          </table>
        </div>
      </section>

      <section class="content-section">
        <h2>Terminal & Final Valuation Math</h2>
        <p>The Terminal Value accounts for all cash flows from Year 6 into perpetuity, calculated using the Gordon Growth Model.</p>

        <div class="math-card">
          <div class="math-row">
            <span>Year 5 FCF</span>
            <span>{formatMillions(year5FCF)}</span>
          </div>
          <div class="math-row">
            <span>Terminal Value (TV) Calculation</span>
            <span>({formatMillions(year5FCF)} * {1 + terminalGrowthRate}) / ({discountRate} - {terminalGrowthRate})</span>
          </div>
          <div class="math-row">
            <span>Terminal Value</span>
            <span>{formatMillions(terminalValue)}</span>
          </div>
          <div class="math-row highlight">
            <span>PV of Terminal Value</span>
            <span>{formatMillions(pvTerminalValue)}</span>
          </div>
        </div>

        <p style="margin-top: 2rem;"><strong>Crucial Step: The Debt Penalty.</strong> T-Mobile's Enterprise Value is massive, but so is its debt load. We must subtract over $116 billion in Net Debt to arrive at the true Equity Value.</p>

        <div class="math-card">
          <div class="math-row">
            <span>Sum of PV of FCFs (Years 1-5)</span>
            <span>{formatMillions(sumPvFcf)}</span>
          </div>
          <div class="math-row">
            <span>+ PV of Terminal Value</span>
            <span>{formatMillions(pvTerminalValue)}</span>
          </div>
          <div class="math-row">
            <span><strong>= Enterprise Value</strong></span>
            <span><strong>{formatMillions(enterpriseValue)}</strong></span>
          </div>
          <div class="math-row">
            <span>+ Net Cash (Cash - Debt)</span>
            <span>{formatMillions(netCash)}</span>
          </div>
          <div class="math-row highlight">
            <span><strong>= Total Equity Value</strong></span>
            <span><strong>{formatMillions(totalEquityValue)}</strong></span>
          </div>
          <div class="math-row">
            <span>÷ Shares Outstanding</span>
            <span>{sharesOut.toLocaleString()}M</span>
          </div>
          <div class="math-row result">
            <span><strong>Intrinsic Value Per Share</strong></span>
            <span><strong>{formatMoney(intrinsicValuePerShare)}</strong></span>
          </div>
        </div>
      </section>

      <section class="content-section">
        <h2>Sensitivity Matrix</h2>
        <p>Because the Net Debt number is so large, the intrinsic value per share is highly sensitive to changes in the WACC and Terminal Growth rate. Small shifts in the discount rate dramatically swing the Enterprise Value up or down.</p>

        <div class="table-container sensitivity-table">
          <table>
            <thead>
              <tr>
                <th rowspan="2" class="corner-cell">Terminal<br/>Growth</th>
                <th colspan="5" class="header-cell">Discount Rate (WACC)</th>
              </tr>
              <tr>
                {sensitivityDiscountRates.map(d => <th>{formatPercent(d)}</th>)}
              </tr>
            </thead>
            <tbody>
              {sensitivityMatrix.map(row => (
                <tr>
                  <th class="row-header">{formatPercent(row.growthRate)}</th>
                  {row.values.map(val => (
                    <td class={
                      val > currentPrice * 1.15 ? "cell-undervalued" :
                      val < currentPrice * 0.85 ? "cell-overvalued" :
                      "cell-neutral"
                    }>
                      {formatMoney(val)}
                    </td>
                  ))}
                </tr>
              ))}
            </tbody>
          </table>
          <div class="matrix-legend">
            <span class="legend-item"><span class="color-box cell-undervalued"></span> Undervalued (>15% Margin)</span>
            <span class="legend-item"><span class="color-box cell-neutral"></span> Fair Value</span>
            <span class="legend-item"><span class="color-box cell-overvalued"></span> Overvalued (&lt;-15% Margin)</span>
          </div>
        </div>
      </section>

      <section class="content-section risks-section">
        <h2>Key Risks to This Valuation</h2>
        <p>While the cash flow story is compelling, the telecom industry is notoriously brutal. Here is where the model could fail:</p>
        <div class="risk-grid">
          <div class="risk-card">
            <h3>1. The Debt Burden is Massive</h3>
            <p>Carrying $122B+ in debt is a structural vulnerability. If interest rates remain elevated for longer than anticipated, the cost of rolling over this debt will bite directly into free cash flow, squeezing the equity value rapidly.</p>
          </div>
          <div class="risk-card">
            <h3>2. Fierce Oligopoly Competition</h3>
            <p>Verizon and AT&T are wounded but highly capable. Price wars or aggressive promotional environments to defend subscriber counts could compress ARPU (Average Revenue Per User) and destroy the margin expansion thesis.</p>
          </div>
          <div class="risk-card">
            <h3>3. Regulatory Ceilings</h3>
            <p>T-Mobile's historical growth strategy relied heavily on aggressive acquisitions (like Sprint). Given their current market share, federal regulators (DOJ, FCC) are highly unlikely to approve any further major consolidations, meaning all future growth must be organic.</p>
          </div>
        </div>
      </section>

      <section class="content-section faq-section">
        <h2>Frequently Asked Questions</h2>

        <div class="faq-item">
          <h3>Why did Gemini pick an 8% growth rate for T-Mobile?</h3>
          <p>Gemini models that T-Mobile has entered a "harvesting" phase post-Sprint merger. As heavy 5G capital expenditures decline and the subscriber base continues to scale, operating leverage will drive strong, sustained cash flow expansion.</p>
        </div>

        <div class="faq-item">
          <h3>What discount rate was used for TMUS's DCF?</h3>
          <p>An 8.0% discount rate was selected. Telecom revenues are highly resilient and utility-like, which usually commands a lower rate, but T-Mobile's significant debt load requires a slight premium to compensate for leverage risk.</p>
        </div>

        <div class="faq-item">
          <h3>Why is Net Cash deeply negative in this model?</h3>
          <p>T-Mobile carries over $122 billion in total debt against just under $5.6 billion in cash. In a DCF, we must subtract this net debt from the total Enterprise Value to find the true Equity Value available to shareholders.</p>
        </div>
      </section>

      <div class="disclaimer-box">
        <p><strong>Disclaimer:</strong> The numbers presented on this page are for educational and entertainment purposes only. They are the result of a deterministic mathematical model fed with assumptions generated by an Artificial Intelligence (Gemini 3.1). This does not constitute investment advice. Always conduct your own due diligence before investing in the stock market.</p>
      </div>

    </div>
  </div>
</SiteLayout>
