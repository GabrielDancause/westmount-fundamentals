---
export const meta = {
  title: "Hilton (HLT) Intrinsic Value: A DCF Analysis",
  description: "We ran a full discounted cash flow on Hilton Worldwide using actuals. One number. Every assumption disclosed. Here's what HLT is really worth.",
  category: "study",
  published: "2026-03-24",
};

import SiteLayout from "../layouts/SiteLayout.astro";
import * as cheerio from "cheerio";

const schema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": "Hilton (HLT) Intrinsic Value: A DCF Analysis",
  "description": "A transparent, step-by-step discounted cash flow valuation of Hilton Worldwide Holdings Inc. Using actual financials to arrive at a single fair value estimate for HLT shares.",
  "datePublished": "2026-03-24",
  "dateModified": "2026-03-24",
  "author": {
    "@type": "Organization",
    "name": "Westmount Research",
    "url": "https://westmountfundamentals.com"
  },
  "publisher": {
    "@type": "Organization",
    "name": "Westmount Research",
    "url": "https://westmountfundamentals.com"
  },
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": "https://westmountfundamentals.com/hilton-intrinsic-value"
  }
};

let fcfData = null, revenueData = null, sharesData = null, epsData = null;
let opIncData = null, netIncData = null, cashData = null, debtData = null;
let currentPrice = 200.00; // fallback

try {
  const reqOpts = { headers: { 'User-Agent': 'Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36' } };

  const resFin = await fetch('https://stockanalysis.com/stocks/hlt/financials/', reqOpts);
  if (resFin.ok) {
    const htmlFin = await resFin.text();
    const $fin = cheerio.load(htmlFin);

    const priceMatch = htmlFin.match(/<div class="[^"]*text-4xl[^"]*"[^>]*>([\d\.,]+)<\/div>/);
    if (priceMatch) {
      currentPrice = parseFloat(priceMatch[1].replace(/,/g, ''));
    }

    const parseRow = (label) => {
      const row = $fin('table tbody tr').filter((i, el) => $fin(el).find('td').first().text().trim() === label);
      return row.length ? row.find('td').map((i, el) => $fin(el).text().trim().replace(/,/g, '')).get() : null;
    };

    revenueData = parseRow('Revenue');
    sharesData = parseRow('Shares Outstanding (Diluted)');
    epsData = parseRow('EPS (Diluted)');
    opIncData = parseRow('Operating Income');
    netIncData = parseRow('Net Income');
  }

  const resCF = await fetch('https://stockanalysis.com/stocks/hlt/financials/cash-flow-statement/', reqOpts);
  if (resCF.ok) {
    const htmlCF = await resCF.text();
    const $cf = cheerio.load(htmlCF);
    const fcfRow = $cf('table tbody tr').filter((i, el) => $cf(el).find('td').first().text().trim() === 'Free Cash Flow');
    if (fcfRow.length) {
      fcfData = fcfRow.find('td').map((i, el) => $cf(el).text().trim().replace(/,/g, '')).get();
    }
  }

  const resBS = await fetch('https://stockanalysis.com/stocks/hlt/financials/balance-sheet/', reqOpts);
  if (resBS.ok) {
    const htmlBS = await resBS.text();
    const $bs = cheerio.load(htmlBS);
    const parseRowBS = (label) => {
      const row = $bs('table tbody tr').filter((i, el) => $bs(el).find('td').first().text().trim() === label);
      return row.length ? row.find('td').map((i, el) => $bs(el).text().trim().replace(/,/g, '')).get() : null;
    };
    cashData = parseRowBS('Cash & Equivalents');
    debtData = parseRowBS('Total Debt');
  }
} catch (e) {
  // Silent catch
}

const getVal = (arr, index) => arr && arr.length > index && arr[index] !== '-' ? parseFloat(arr[index]) : null;

// Usually TTM is index 1
const baseFCF = getVal(fcfData, 1) || 2028;
const baseShares = getVal(sharesData, 1) || 238;
const baseRevenue = getVal(revenueData, 1) || 12039;
const baseCash = getVal(cashData, 1) || 918;
const baseDebt = getVal(debtData, 1) || 13093;
const baseEPS = getVal(epsData, 1) || 6.12;
const baseNetIncome = getVal(netIncData, 1) || 1457;

const netCash = baseCash - baseDebt; // Hilton carries significant net debt

const growthRatePhase1 = 0.08;         // 8% FCF growth, Years 1-5
const growthRateTerminal = 0.03;       // 3% perpetuity growth (terminal)
const discountRate = 0.09;             // 9% WACC / required return

const projectedFCF = [];
let fcf = baseFCF;
for (let yr = 1; yr <= 5; yr++) {
  fcf = fcf * (1 + growthRatePhase1);
  projectedFCF.push({ year: yr, fcf: Math.round(fcf), pvFactor: 1 / Math.pow(1 + discountRate, yr) });
}
projectedFCF.forEach(p => { p.pvFCF = Math.round(p.fcf * p.pvFactor); });

const fcfYear6 = projectedFCF[4].fcf * (1 + growthRateTerminal);
const terminalValue = Math.round(fcfYear6 / (discountRate - growthRateTerminal));
const pvTerminalValue = Math.round(terminalValue * projectedFCF[4].pvFactor);

const pvPhase1 = projectedFCF.reduce((sum, p) => sum + p.pvFCF, 0);
const enterpriseValue = pvPhase1 + pvTerminalValue;

const equityValue = enterpriseValue + netCash;
const intrinsicValuePerShare = equityValue / baseShares;
const roundedIV = Math.round(intrinsicValuePerShare * 100) / 100;

const marginOfSafety = currentPrice > 0 ? ((roundedIV - currentPrice) / currentPrice * 100).toFixed(1) : 'N/A';
const verdictText = roundedIV > currentPrice ? "Undervalued" : "Overvalued";
const verdictColor = roundedIV > currentPrice ? "#10b981" : "#ef4444";

const getHistory = (arr) => {
  if (!arr || arr.length < 6) return [
    { year: 2020, value: null }, { year: 2021, value: null }, { year: 2022, value: null }, { year: 2023, value: null }, { year: 'TTM', value: null }
  ];
  return [
    { year: 2020, value: parseFloat(arr[5]) || null },
    { year: 2021, value: parseFloat(arr[4]) || null },
    { year: 2022, value: parseFloat(arr[3]) || null },
    { year: 2023, value: parseFloat(arr[2]) || null },
    { year: 'TTM', value: parseFloat(arr[1]) || null },
  ];
};

const revenueHistory = getHistory(revenueData);
const fcfHistory = getHistory(fcfData);
const epsHistory = getHistory(epsData);

const marginHistory = [];
for (let i = 5; i >= 1; i--) {
  const rev = getVal(revenueData, i);
  const opInc = getVal(opIncData, i);
  const netInc = getVal(netIncData, i);
  const fcf_val = getVal(fcfData, i);

  marginHistory.push({
    year: i === 1 ? 'TTM' : (2025 - i + 1),
    operating: rev !== null && opInc !== null ? ((opInc / rev) * 100).toFixed(1) : null,
    profit: rev !== null && netInc !== null ? ((netInc / rev) * 100).toFixed(1) : null,
    fcfMargin: rev !== null && fcf_val !== null ? ((fcf_val / rev) * 100).toFixed(1) : null,
  });
}

const sensitivityRates = [0.07, 0.08, 0.09, 0.10, 0.11];
const sensitivityGrowth = [0.04, 0.06, 0.08, 0.10, 0.12];
const sensitivityTable = sensitivityRates.map(dr => {
  return {
    dr,
    values: sensitivityGrowth.map(gr => {
      let f_iter = baseFCF;
      let pvSum = 0;
      for (let y = 1; y <= 5; y++) {
        f_iter = f_iter * (1 + gr);
        pvSum += f_iter / Math.pow(1 + dr, y);
      }
      const f6 = f_iter * (1 + growthRateTerminal);
      const tv = f6 / (dr - growthRateTerminal);
      const pvTV = tv / Math.pow(1 + dr, 5);
      return Math.round((pvSum + pvTV + netCash) / baseShares);
    })
  };
});
---

<SiteLayout
  site="westmount"
  title="Hilton (HLT) Intrinsic Value: A DCF Analysis"
  description="We ran a full discounted cash flow on Hilton Worldwide using actuals. One number. Every assumption disclosed. Here's what HLT is really worth."
  canonical="https://westmountfundamentals.com/hilton-intrinsic-value"
  schema={schema}
>
<div class="dcf-wrapper">
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800;900&family=JetBrains+Mono:wght@400;700;800&display=swap');

    .dcf-wrapper {
      font-family: 'Inter', -apple-system, sans-serif;
      background: #060a12;
      color: #c8d0de;
      line-height: 1.7;
      min-height: 100vh;
      padding-bottom: 80px;
    }
    .dcf-wrapper * { box-sizing: border-box; margin: 0; padding: 0; }
    .dcf-wrapper a { color: #4a8fe7; text-decoration: none; }
    .dcf-wrapper a:hover { text-decoration: underline; }
    .dcf-wrapper .container { max-width: 900px; margin: 0 auto; padding: 0 24px; }

    /* Header */
    .dcf-wrapper .header { text-align: center; padding: 80px 24px 60px; background: linear-gradient(180deg, #0a1628 0%, #060a12 100%); position: relative; border-bottom: 1px solid #152040; }
    .dcf-wrapper .header::before { content: ''; position: absolute; inset: 0; background: radial-gradient(circle at 50% 40%, rgba(74,143,231,0.06) 0%, transparent 60%); pointer-events: none; }
    .dcf-wrapper .header-content { position: relative; z-index: 1; }
    .dcf-wrapper .tag { display: inline-block; background: rgba(74,143,231,0.12); color: #4a8fe7; font-size: 0.75rem; font-weight: 800; padding: 6px 16px; border-radius: 20px; letter-spacing: 1.5px; text-transform: uppercase; margin-bottom: 16px; }
    .dcf-wrapper h1 { font-size: 2.8rem; font-weight: 900; color: #fff; letter-spacing: -1.2px; margin-bottom: 16px; line-height: 1.1; }
    @media (max-width: 640px) { .dcf-wrapper h1 { font-size: 2rem; } }
    .dcf-wrapper .subtitle { color: #7a8a9e; font-size: 1.1rem; max-width: 700px; margin: 0 auto 16px; }
    .dcf-wrapper .date { color: #3a4a60; font-size: 0.85rem; font-weight: 600; letter-spacing: 1px; }
    .dcf-wrapper .compiled-by { margin-top: 12px; font-size: 0.8rem; color: #4a8fe7; font-weight: 700; letter-spacing: 1px; text-transform: uppercase; }

    /* Big verdict */
    .dcf-wrapper .verdict-card { max-width: 560px; margin: 60px auto 0; background: linear-gradient(135deg, #0a1628 0%, #0d1830 100%); border: 2px solid #152040; border-radius: 20px; padding: 48px 32px; text-align: center; box-shadow: 0 20px 60px rgba(0,0,0,0.4); position: relative; overflow: hidden; }
    .dcf-wrapper .verdict-card::before { content: ''; position: absolute; top: -60%; left: -20%; width: 140%; height: 120%; background: radial-gradient(ellipse, rgba(74,143,231,0.04) 0%, transparent 70%); pointer-events: none; }
    .dcf-wrapper .verdict-label { font-size: 0.8rem; color: #5a6a80; font-weight: 700; text-transform: uppercase; letter-spacing: 2px; margin-bottom: 12px; position: relative; }
    .dcf-wrapper .verdict-price { font-family: 'JetBrains Mono', monospace; font-size: 4.5rem; font-weight: 800; color: #fff; line-height: 1; margin-bottom: 8px; position: relative; }
    @media (max-width: 640px) { .dcf-wrapper .verdict-price { font-size: 3rem; } }
    .dcf-wrapper .verdict-vs { font-size: 0.95rem; color: #5a6a80; margin-bottom: 20px; position: relative; }
    .dcf-wrapper .verdict-badge { display: inline-block; padding: 8px 24px; border-radius: 30px; font-weight: 800; font-size: 0.9rem; letter-spacing: 1px; text-transform: uppercase; position: relative; }

    /* Stats */
    .dcf-wrapper .stats-row { display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); gap: 16px; margin: 40px auto; max-width: 900px; }
    .dcf-wrapper .stat-card { background: #0a1020; border: 1px solid #152040; border-radius: 14px; padding: 24px 16px; text-align: center; }
    .dcf-wrapper .stat-value { font-family: 'JetBrains Mono', monospace; font-size: 1.8rem; font-weight: 700; color: #4a8fe7; margin-bottom: 4px; }
    .dcf-wrapper .stat-label { font-size: 0.78rem; color: #5a6a80; font-weight: 600; text-transform: uppercase; letter-spacing: 0.5px; }

    /* Sections */
    .dcf-wrapper h2 { font-size: 1.8rem; font-weight: 800; color: #fff; margin: 60px 0 20px; letter-spacing: -0.5px; border-bottom: 2px solid #152040; padding-bottom: 12px; }
    .dcf-wrapper h3 { font-size: 1.3rem; font-weight: 700; color: #e0e6f0; margin: 32px 0 12px; }
    .dcf-wrapper p, .dcf-wrapper li { color: #a0aab8; font-size: 1rem; margin-bottom: 16px; }
    .dcf-wrapper ul, .dcf-wrapper ol { padding-left: 24px; }
    .dcf-wrapper li { margin-bottom: 8px; }
    .dcf-wrapper strong { color: #e0e6f0; }

    /* Assumption cards */
    .dcf-wrapper .assumption-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); gap: 16px; margin: 24px 0 40px; }
    .dcf-wrapper .assumption-card { background: #0a1020; border: 1px solid #152040; border-radius: 14px; padding: 24px; }
    .dcf-wrapper .assumption-card .label { font-size: 0.75rem; color: #5a6a80; font-weight: 700; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 8px; }
    .dcf-wrapper .assumption-card .value { font-family: 'JetBrains Mono', monospace; font-size: 2rem; font-weight: 700; color: #fff; margin-bottom: 8px; }
    .dcf-wrapper .assumption-card .rationale { font-size: 0.85rem; color: #7a8a9e; line-height: 1.5; }

    /* Tables */
    .dcf-wrapper .table-wrap { overflow-x: auto; margin: 24px 0 40px; border-radius: 14px; border: 1px solid #152040; background: #0a1020; }
    .dcf-wrapper table { width: 100%; border-collapse: collapse; }
    .dcf-wrapper th { background: #0d1428; padding: 14px 16px; font-size: 0.75rem; color: #5a6a80; font-weight: 700; text-transform: uppercase; letter-spacing: 1px; text-align: right; border-bottom: 2px solid #152040; white-space: nowrap; }
    .dcf-wrapper th:first-child { text-align: left; }
    .dcf-wrapper td { padding: 14px 16px; font-size: 0.9rem; color: #c8d0de; text-align: right; border-bottom: 1px solid #0d1428; font-family: 'JetBrains Mono', monospace; }
    .dcf-wrapper td:first-child { text-align: left; font-family: 'Inter', sans-serif; color: #a0aab8; font-weight: 600; }
    .dcf-wrapper tr:hover td { background: rgba(74,143,231,0.03); }
    .dcf-wrapper .row-total td { font-weight: 800; color: #fff; border-top: 2px solid #1a2a40; background: rgba(74,143,231,0.04); }
    .dcf-wrapper td.highlight-cell { color: #4a8fe7; font-weight: 700; }

    /* Sensitivity */
    .dcf-wrapper .sensitivity-table th.current { background: rgba(74,143,231,0.15); color: #4a8fe7; }
    .dcf-wrapper .sensitivity-table td.current { background: rgba(74,143,231,0.08); color: #4a8fe7; font-weight: 700; }

    /* Chart bars */
    .dcf-wrapper .bar-chart { margin: 24px 0 40px; }
    .dcf-wrapper .bar-row { display: flex; align-items: center; gap: 12px; margin-bottom: 10px; }
    .dcf-wrapper .bar-label { width: 48px; font-size: 0.85rem; color: #5a6a80; font-weight: 600; text-align: right; flex-shrink: 0; }
    .dcf-wrapper .bar-track { flex: 1; background: #0a1020; border-radius: 8px; height: 32px; overflow: hidden; position: relative; }
    .dcf-wrapper .bar-fill { height: 100%; border-radius: 8px; display: flex; align-items: center; padding-left: 12px; font-size: 0.8rem; font-weight: 700; color: #fff; font-family: 'JetBrains Mono', monospace; min-width: 80px; }
    .dcf-wrapper .bar-fill.revenue { background: linear-gradient(90deg, #1a3a6e, #4a8fe7); }
    .dcf-wrapper .bar-fill.fcf { background: linear-gradient(90deg, #1a5a3e, #10b981); }
    .dcf-wrapper .bar-fill.eps { background: linear-gradient(90deg, #5a3a7e, #a78bfa); }

    /* Methodology */
    .dcf-wrapper .method-step { display: flex; gap: 16px; margin-bottom: 24px; padding: 20px; background: #0a1020; border: 1px solid #152040; border-radius: 14px; }
    .dcf-wrapper .step-num { width: 40px; height: 40px; background: rgba(74,143,231,0.12); color: #4a8fe7; font-weight: 800; font-size: 1.1rem; border-radius: 50%; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
    .dcf-wrapper .step-content { flex: 1; }
    .dcf-wrapper .step-content h4 { color: #e0e6f0; font-size: 1rem; margin-bottom: 6px; }
    .dcf-wrapper .step-content p { margin-bottom: 0; font-size: 0.9rem; }

    /* Disclaimer / FAQ */
    .dcf-wrapper .disclaimer { margin: 60px 0 0; padding: 24px; background: rgba(239,68,68,0.05); border: 1px solid rgba(239,68,68,0.15); border-radius: 14px; }
    .dcf-wrapper .disclaimer h4 { color: #ef4444; margin-bottom: 8px; font-size: 0.85rem; text-transform: uppercase; letter-spacing: 1px; }
    .dcf-wrapper .disclaimer p { font-size: 0.85rem; color: #7a8a9e; margin-bottom: 0; }

    .dcf-wrapper .faq { margin: 40px 0; }
    .dcf-wrapper .faq details { background: #0a1020; border: 1px solid #152040; border-radius: 14px; margin-bottom: 12px; overflow: hidden; }
    .dcf-wrapper .faq summary { padding: 18px 20px; cursor: pointer; font-weight: 700; color: #e0e6f0; font-size: 1rem; list-style: none; display: flex; justify-content: space-between; align-items: center; }
    .dcf-wrapper .faq summary::after { content: '+'; font-size: 1.2rem; color: #4a8fe7; }
    .dcf-wrapper .faq details[open] summary::after { content: '−'; }
    .dcf-wrapper .faq .faq-answer { padding: 0 20px 18px; font-size: 0.9rem; color: #a0aab8; }
  </style>

  <div class="header">
    <div class="header-content">
      <div class="tag">Original Research</div>
      <h1>Hilton Worldwide (HLT)<br/>Intrinsic Value</h1>
      <p class="subtitle">A transparent, two-stage discounted cash flow valuation of Hilton — using actuals, disclosed assumptions, and one final number.</p>
      <p class="date">Updated March 2026</p>
      <div class="compiled-by">Compiled by Gemini 3.1</div>
    </div>
  </div>

  <div class="container">
    <div class="verdict-card">
      <div class="verdict-label">Estimated Intrinsic Value Per Share</div>
      <div class="verdict-price">${roundedIV.toFixed(2)}</div>
      <div class="verdict-vs">vs. market price of ${currentPrice.toFixed(2)} ({marginOfSafety}%)</div>
      <div class="verdict-badge" style={`background: ${verdictColor}22; color: ${verdictColor}; border: 1px solid ${verdictColor}44;`}>
        {verdictText}
      </div>
    </div>

    <div class="stats-row">
      <div class="stat-card">
        <div class="stat-value">${baseRevenue !== null ? (baseRevenue / 1000).toFixed(1) : 'N/A'}B</div>
        <div class="stat-label">TTM Revenue</div>
      </div>
      <div class="stat-card">
        <div class="stat-value">${baseFCF !== null ? (baseFCF / 1000).toFixed(1) : 'N/A'}B</div>
        <div class="stat-label">Free Cash Flow</div>
      </div>
      <div class="stat-card">
        <div class="stat-value">${baseEPS !== null ? baseEPS.toFixed(2) : 'N/A'}</div>
        <div class="stat-label">EPS (Diluted)</div>
      </div>
      <div class="stat-card">
        <div class="stat-value">{baseRevenue !== null && baseNetIncome !== null ? ((baseNetIncome / baseRevenue) * 100).toFixed(1) : 'N/A'}%</div>
        <div class="stat-label">Profit Margin</div>
      </div>
      <div class="stat-card">
        <div class="stat-value">${(netCash / 1000).toFixed(1)}B</div>
        <div class="stat-label">Net Cash</div>
      </div>
    </div>

    <h2>Methodology: Two-Stage DCF</h2>
    <p>We use a <strong>two-stage discounted cash flow (DCF)</strong> model for Hilton Worldwide. This approach isolates the company's true cash-generating ability, bypassing accounting noise and arbitrary multiples.</p>

    <div class="method-step">
      <div class="step-num">1</div>
      <div class="step-content">
        <h4>Start with actual Free Cash Flow</h4>
        <p>Hilton is highly asset-light. The base FCF (${baseFCF !== null ? baseFCF.toLocaleString() : 'N/A'}M) represents real cash available to shareholders after minimal capital expenditures.</p>
      </div>
    </div>
    <div class="method-step">
      <div class="step-num">2</div>
      <div class="step-content">
        <h4>Project FCF growth (Phase 1)</h4>
        <p>We assume an <strong>8% annual growth rate</strong> for the next 5 years. This reflects Hilton's strong pipeline of rooms under construction and steady franchise fee growth, balanced by macroeconomic cycles.</p>
      </div>
    </div>
    <div class="method-step">
      <div class="step-num">3</div>
      <div class="step-content">
        <h4>Calculate terminal value (Phase 2)</h4>
        <p>After 5 years, we assume a perpetual growth rate of <strong>3%</strong>, matching long-term GDP growth plus inflation pricing power in the hospitality sector.</p>
      </div>
    </div>
    <div class="method-step">
      <div class="step-num">4</div>
      <div class="step-content">
        <h4>Discount everything to present value</h4>
        <p>All future cash flows are discounted at <strong>9%</strong>, reflecting the cost of equity (10Y Treasury: 4.18%, HLT Beta: ~1.15).</p>
      </div>
    </div>
    <div class="method-step">
      <div class="step-num">5</div>
      <div class="step-content">
        <h4>Add net cash, divide by shares</h4>
        <p>We subtract net debt from the Enterprise Value to find Equity Value, then divide by the current outstanding shares ({baseShares !== null ? baseShares.toLocaleString() : 'N/A'}M).</p>
      </div>
    </div>

    <h2>The Three Assumptions That Drive Everything</h2>
    <div class="assumption-grid">
      <div class="assumption-card">
        <div class="label">FCF Growth Rate (Years 1-5)</div>
        <div class="value">8.0%</div>
        <div class="rationale">
          Hilton's franchise model requires very little capital to scale. They have a massive pipeline of new rooms. We project 8% growth, accounting for room additions and RevPAR increases, while remaining conservative against travel cyclicality.
        </div>
      </div>
      <div class="assumption-card">
        <div class="label">Discount Rate (WACC)</div>
        <div class="value">9.0%</div>
        <div class="rationale">
          With the 10Y Treasury at 4.18% and a standard equity risk premium, a 9% required rate of return is appropriate for a mature, highly profitable, but moderately leveraged company like Hilton.
        </div>
      </div>
      <div class="assumption-card">
        <div class="label">Terminal Growth Rate</div>
        <div class="value">3.0%</div>
        <div class="rationale">
          Hospitality is tied to global economic growth and inflation. 3% assumes Hilton maintains its competitive moat and grows slightly above inflation in perpetuity.
        </div>
      </div>
    </div>

    <h2>Projected Free Cash Flows</h2>
    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th style="text-align:left">Year</th>
            <th>FCF ($M)</th>
            <th>PV Factor</th>
            <th>Present Value ($M)</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td>Base (TTM)</td>
            <td>${baseFCF !== null ? baseFCF.toLocaleString() : 'N/A'}</td>
            <td>—</td>
            <td>—</td>
          </tr>
          {projectedFCF.map(p => (
            <tr>
              <td>Year {p.year}</td>
              <td>${p.fcf.toLocaleString()}</td>
              <td>{p.pvFactor.toFixed(4)}</td>
              <td>${p.pvFCF.toLocaleString()}</td>
            </tr>
          ))}
          <tr class="row-total">
            <td colspan="3">Sum of Phase 1 PV</td>
            <td class="highlight-cell">${pvPhase1.toLocaleString()}</td>
          </tr>
        </tbody>
      </table>
    </div>

    <h3>Terminal Value</h3>
    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th style="text-align:left">Component</th>
            <th>Value ($M)</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td>Year 6 FCF (Year 5 × 1.03)</td>
            <td>${Math.round(fcfYear6).toLocaleString()}</td>
          </tr>
          <tr>
            <td>Terminal Value (FCF₆ ÷ (9% − 3%))</td>
            <td>${terminalValue.toLocaleString()}</td>
          </tr>
          <tr class="row-total">
            <td>PV of Terminal Value</td>
            <td class="highlight-cell">${pvTerminalValue.toLocaleString()}</td>
          </tr>
        </tbody>
      </table>
    </div>

    <h3>Final Valuation</h3>
    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th style="text-align:left">Component</th>
            <th>Value ($M)</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td>PV of Phase 1 Cash Flows</td>
            <td>${pvPhase1.toLocaleString()}</td>
          </tr>
          <tr>
            <td>PV of Terminal Value</td>
            <td>${pvTerminalValue.toLocaleString()}</td>
          </tr>
          <tr>
            <td>= Enterprise Value</td>
            <td>${enterpriseValue.toLocaleString()}</td>
          </tr>
          <tr>
            <td>+ Net Cash (Cash − Debt)</td>
            <td>${netCash.toLocaleString()}</td>
          </tr>
          <tr>
            <td>= Equity Value</td>
            <td>${equityValue.toLocaleString()}</td>
          </tr>
          <tr>
            <td>÷ Shares Outstanding</td>
            <td>{baseShares !== null ? baseShares.toLocaleString() : 'N/A'}</td>
          </tr>
          <tr class="row-total">
            <td>Intrinsic Value Per Share</td>
            <td class="highlight-cell">${roundedIV.toFixed(2)}</td>
          </tr>
        </tbody>
      </table>
    </div>

    <h2>Financial Track Record</h2>
    <h3>Revenue ($M)</h3>
    <div class="bar-chart">
      {revenueHistory.map(r => (
        <div class="bar-row">
          <div class="bar-label">{r.year}</div>
          <div class="bar-track">
            {r.value !== null ? (
              <div class="bar-fill revenue" style={`width: ${(r.value / (baseRevenue || 1)) * 100}%`}>
                ${r.value.toLocaleString()}
              </div>
            ) : (
              <div class="bar-fill revenue" style="width: 10%; background: #1a3a6e; color: #5a6a80;">N/A</div>
            )}
          </div>
        </div>
      ))}
    </div>

    <h3>Free Cash Flow ($M)</h3>
    <div class="bar-chart">
      {fcfHistory.map(r => (
        <div class="bar-row">
          <div class="bar-label">{r.year}</div>
          <div class="bar-track">
            {r.value !== null ? (
              <div class="bar-fill fcf" style={`width: ${(r.value / (baseFCF || 1)) * 100}%`}>
                ${r.value.toLocaleString()}
              </div>
            ) : (
              <div class="bar-fill fcf" style="width: 10%; background: #1a5a3e; color: #5a6a80;">N/A</div>
            )}
          </div>
        </div>
      ))}
    </div>

    <h3>EPS (Diluted)</h3>
    <div class="bar-chart">
      {epsHistory.map(r => (
        <div class="bar-row">
          <div class="bar-label">{r.year}</div>
          <div class="bar-track">
            {r.value !== null ? (
              <div class="bar-fill eps" style={`width: ${(r.value / (baseEPS || 1)) * 100}%`}>
                ${r.value.toFixed(2)}
              </div>
            ) : (
              <div class="bar-fill eps" style="width: 10%; background: #5a3a7e; color: #5a6a80;">N/A</div>
            )}
          </div>
        </div>
      ))}
    </div>

    <h3>Margin Trends</h3>
    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th style="text-align:left">Year</th>
            <th>Operating Margin</th>
            <th>Profit Margin</th>
            <th>FCF Margin</th>
          </tr>
        </thead>
        <tbody>
          {marginHistory.map(m => (
            <tr>
              <td>{m.year}</td>
              <td>{m.operating !== null ? `${m.operating}%` : 'N/A'}</td>
              <td>{m.profit !== null ? `${m.profit}%` : 'N/A'}</td>
              <td>{m.fcfMargin !== null ? `${m.fcfMargin}%` : 'N/A'}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>

    <h2>Sensitivity Analysis</h2>
    <p>Because minor adjustments in the WACC or growth rates drastically affect the DCF output, we run a 5x5 sensitivity matrix.</p>
    <div class="table-wrap">
      <table class="sensitivity-table">
        <thead>
          <tr>
            <th style="text-align:left">Discount Rate ↓ / Growth →</th>
            {sensitivityGrowth.map(g => (
              <th class={g === growthRatePhase1 ? 'current' : ''}>{(g * 100).toFixed(0)}%</th>
            ))}
          </tr>
        </thead>
        <tbody>
          {sensitivityTable.map(row => (
            <tr>
              <td>{(row.dr * 100).toFixed(0)}%</td>
              {row.values.map((v, i) => (
                <td class={row.dr === discountRate && sensitivityGrowth[i] === growthRatePhase1 ? 'current' : ''}>
                  ${v}
                </td>
              ))}
            </tr>
          ))}
        </tbody>
      </table>
    </div>

    <h2>Risks</h2>
    <ul>
      <li><strong>Economic Sensitivity:</strong> Lodging demand is highly cyclical. A global recession would directly impact corporate and leisure travel, compressing RevPAR and franchise fees.</li>
      <li><strong>Interest Rates:</strong> Hilton operates with significant leverage. A sustained high-rate environment increases debt servicing costs.</li>
      <li><strong>Brand Competition:</strong> Heavy competition from Marriott, IHG, and alternative lodging like Airbnb could compress margins.</li>
    </ul>

    <h2>Frequently Asked Questions</h2>
    <div class="faq">
      <details>
        <summary>Why use a DCF for Hilton?</summary>
        <div class="faq-answer">DCF strips away accounting differences and focuses purely on Hilton's ability to generate cash. Given Hilton's asset-light model, free cash flow is an excellent proxy for underlying business performance.</div>
      </details>
      <details>
        <summary>Why is Hilton's Equity Value lower than its Enterprise Value?</summary>
        <div class="faq-answer">Hilton relies on debt to fuel share repurchases and growth. They hold more debt than cash, resulting in a negative net cash position. This debt must be subtracted from the total Enterprise Value to find the value of the equity alone.</div>
      </details>
      <details>
        <summary>Is this a "buy" signal?</summary>
        <div class="faq-answer">No. This model is purely an analytical estimation of intrinsic value. Always perform your own research and consult with a financial advisor.</div>
      </details>
    </div>

