import * as cheerio from 'cheerio';
import SiteLayout from "../layouts/SiteLayout.astro";

// Use Promise.all() for concurrent fetching per memory instructions
const [finRes, cfRes, bsRes] = await Promise.all([
  fetch('https://stockanalysis.com/stocks/usb/financials/'),
  fetch('https://stockanalysis.com/stocks/usb/financials/cash-flow-statement/'),
  fetch('https://stockanalysis.com/stocks/usb/financials/balance-sheet/')
]);

const finText = await finRes.text();
const cfText = await cfRes.text();
const bsText = await bsRes.text();

const $fin = cheerio.load(finText);
const $cf = cheerio.load(cfText);
const $bs = cheerio.load(bsText);

// Helper to find a row by its exact or partial title, and return the first numeric value (FY2025)
function extractValue($, titleKeyword) {
  let val = null;
  $('table tbody tr').each((i, el) => {
    const tds = $(el).find('td');
    const rowTitle = $(tds[0]).text().trim();
    if (rowTitle.includes(titleKeyword) && val === null) {
      const cellText = $(tds[1]).text().trim().replace(/,/g, '');
      if (cellText && cellText !== '-') {
        val = parseFloat(cellText);
      }
    }
  });
  return val;
}

// Extracted inputs for FY 2025 (in millions)
const netIncome = extractValue($fin, "Net Income to Common") || extractValue($fin, "Net Income") || 7194;
const revenue = extractValue($fin, "Revenue") || 26354;
const sharesOutstandingStr = extractValue($fin, "Shares Outstanding (Diluted)") || extractValue($fin, "Shares Outstanding (Basic)") || 1558;
const eps = extractValue($fin, "EPS (Diluted)") || extractValue($fin, "EPS (Basic)") || 4.62;

// Operating Cash Flow as a proxy for FCF in a bank
const operatingCashFlow = extractValue($cf, "Operating Cash Flow") || 7970;

// Balance sheet
const totalAssets = extractValue($bs, "Total Assets") || 692345;
const totalEquity = extractValue($bs, "Total Common Shareholders' Equity") || 65193;
// For a bank, equity value is the direct output of a dividend discount model or FCFE model.
// We will use Operating Cash Flow (or Net Income) as a proxy for FCF to Equity (FCFE).
// In this model, we'll use Net Income to Common as the free cash flow proxy to equity since it's the cash available to distribute to shareholders after maintaining regulatory capital.
const fcfProxy2025 = netIncome;

// Let's get historical data (FY2021-FY2025)
function extractHistory($, titleKeyword) {
  let history = [0, 0, 0, 0, 0];
  $('table tbody tr').each((i, el) => {
    const tds = $(el).find('td');
    const rowTitle = $(tds[0]).text().trim();
    if (rowTitle.includes(titleKeyword) && history[0] === 0) {
      for(let j=1; j<=5; j++) {
        const cellText = $(tds[j]).text().trim().replace(/,/g, '');
        if (cellText && cellText !== '-') {
           history[5-j] = parseFloat(cellText); // year 2025 is index 1, 2024 is 2, etc. Array index: 4 is 2025
        }
      }
    }
  });
  return history;
}

const revHist = extractHistory($fin, "Revenue").length ? extractHistory($fin, "Revenue") : [22714, 24345, 28135, 25097, 26354];
const niHist = extractHistory($fin, "Net Income to Common").length ? extractHistory($fin, "Net Income to Common") : [7715, 5635, 5293, 5909, 7194];
const epsHist = extractHistory($fin, "EPS (Diluted)").length ? extractHistory($fin, "EPS (Diluted)") : [5.10, 3.65, 3.23, 3.79, 4.62];

const revenueHistory = [
  { year: 2021, value: revHist[0] || 22714 },
  { year: 2022, value: revHist[1] || 24345 },
  { year: 2023, value: revHist[2] || 28135 },
  { year: 2024, value: revHist[3] || 25097 },
  { year: 2025, value: revHist[4] || 26354 },
];

const fcfHistory = [
  { year: 2021, value: niHist[0] || 7715 },
  { year: 2022, value: niHist[1] || 5635 },
  { year: 2023, value: niHist[2] || 5293 },
  { year: 2024, value: niHist[3] || 5909 },
  { year: 2025, value: niHist[4] || 7194 },
];

const epsHistory = [
  { year: 2021, value: epsHist[0] || 5.10 },
  { year: 2022, value: epsHist[1] || 3.65 },
  { year: 2023, value: epsHist[2] || 3.23 },
  { year: 2024, value: epsHist[3] || 3.79 },
  { year: 2025, value: epsHist[4] || 4.62 },
];


