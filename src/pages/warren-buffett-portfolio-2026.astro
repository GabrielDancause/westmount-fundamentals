---
import SiteLayout from "../layouts/SiteLayout.astro";

const schema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What stocks does Warren Buffett own right now?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Warren Buffett's Berkshire Hathaway portfolio consists of over 40 publicly traded companies. Apple (AAPL) remains one of his largest holdings, but he also owns substantial stakes in financial stalwarts like American Express (AXP) and Bank of America (BAC), as well as consumer staples like Coca-Cola (KO)."
      }
    },
    {
      "@type": "Question",
      "name": "What is the Warren Buffett portfolio 2026?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "The 2026 portfolio represents the latest SEC 13F filings detailing Berkshire Hathaway's equity holdings. It provides insights into his current macroeconomic views, highlighting his strategic bets in technology, energy, and financial services sectors."
      }
    },
    {
      "@type": "Question",
      "name": "What are the largest Berkshire Hathaway holdings?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "The largest positions typically include Apple (AAPL), American Express (AXP), Bank of America (BAC), Coca-Cola (KO), and Chevron (CVX). These core holdings often make up over 70% of the entire portfolio's value."
      }
    },
    {
      "@type": "Question",
      "name": "Did Warren Buffett buy or sell recently?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Buffett actively manages the portfolio. Recent activities include both opportunistic additions and strategic trims. You can view the full 'Activity' column in our complete holdings table above to see exactly which stakes were reduced or added."
      }
    },
    {
      "@type": "Question",
      "name": "Why does Buffett like dividend stocks like Coca-Cola?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Buffett favors companies with durable competitive advantages ('moats'), predictable earnings, and strong management. Coca-Cola, a holding for decades, consistently generates free cash flow and returns capital to shareholders via dividends, epitomizing his value investing philosophy."
      }
    }
  ]
};

export const meta = {
  title: "Warren Buffett's Portfolio 2026: Every Berkshire Hathaway...",
  description: "See every stock Warren Buffett owns in 2026. One surprising sector makes up a massive chunk of Berkshire Hathaway's portfolio. Discover what he bought and sold.",
  category: "guide",
  published: "2026-03-15",
};
---

<SiteLayout
  site="westmount"
  title="Warren Buffett's Portfolio 2026: Every Berkshire Hathaway..."
  description="See every stock Warren Buffett owns in 2026. One surprising sector makes up a massive chunk of Berkshire Hathaway's portfolio. Discover what he bought and sold."
