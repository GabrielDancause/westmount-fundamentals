/* ═══════════════════════════════════════════════════════════════
   DCF MODEL — ALL INPUTS AND CALCULATIONS
   We fetch real FY2026 data from stockanalysis.com
   ═══════════════════════════════════════════════════════════════ */

// Fetch data logic
async function fetchStockData() {
  const headers = { 'User-Agent': 'Mozilla/5.0 (Windows NT 10.0; Win64; x64)' };

  const extractArray = (html, key) => {
    const regex = new RegExp(`${key}:\\[(.*?)\\]`);
    const match = html.match(regex);
    if (match && match[1]) {
      return match[1].split(',').map(s => s === 'null' ? null : Number(s));
    }
    return [];
  };

  const extractStringArray = (html, key) => {
    const regex = new RegExp(`${key}:\\[(.*?)\\]`);
    const match = html.match(regex);
    if (match && match[1]) {
      return match[1].split(',').map(s => s.replace(/"/g, ''));
    }
    return [];
  };

  try {
    const [incRes, cfRes, bsRes] = await Promise.all([
      fetch('https://stockanalysis.com/stocks/tjx/financials/', { headers }),
      fetch('https://stockanalysis.com/stocks/tjx/financials/cash-flow-statement/', { headers }),
      fetch('https://stockanalysis.com/stocks/tjx/financials/balance-sheet/', { headers })
    ]);

    const incHtml = await incRes.text();
    const cfHtml = await cfRes.text();
    const bsHtml = await bsRes.text();

    const incMatch = incHtml.match(/financialData:(\{.*?\})/);
    const cfMatch = cfHtml.match(/financialData:(\{.*?\})/);
    const bsMatch = bsHtml.match(/financialData:(\{.*?\})/);

    const incDataStr = incMatch ? incMatch[1] : '';
    const cfDataStr = cfMatch ? cfMatch[1] : '';
    const bsDataStr = bsMatch ? bsMatch[1] : '';

    const revenue = extractArray(incDataStr, 'revenue');
    const fcf = extractArray(cfDataStr, 'fcf');
    const eps = extractArray(incDataStr, 'epsDiluted');
    const operatingMargin = extractArray(incDataStr, 'operatingMargin');
    const profitMargin = extractArray(incDataStr, 'profitMargin');
    const fcfMargin = extractArray(incDataStr, 'fcfMargin');
    const sharesOutstanding = extractArray(incDataStr, 'sharesDiluted');
    const netIncome = extractArray(incDataStr, 'netIncome');
    const operatingIncome = extractArray(incDataStr, 'operatingIncome');
    const years = extractStringArray(incDataStr, 'fiscalYear');

    const totalCash = extractArray(bsDataStr, 'totalcash');
    const debt = extractArray(bsDataStr, 'debt');

    // Also fetch current price
    const profileRes = await fetch('https://stockanalysis.com/stocks/tjx/', { headers });
    const profileHtml = await profileRes.text();
    let currentPrice = 114.50; // Fallback
    const priceMatch = profileHtml.match(/"price":\s*([0-9.]+)/) || profileHtml.match(/class="text-4xl font-bold[^>]*>([0-9.]+)</);
    if (priceMatch && priceMatch[1]) {
      currentPrice = Number(priceMatch[1]);
    }

    // Usually stockanalysis returns arrays where index 1 is the latest full year (TTM is index 0)
    // TTM = index 0, FY2026 = index 1
    const idx = years[0] === 'TTM' ? 1 : 0;

    return {
      fcf2026: (fcf[idx] / 1000000) || 4917,
      shares: (sharesOutstanding[idx] / 1000000) || 1128,
      cash: (totalCash[idx] / 1000000) || 6230,
      debt: (debt[idx] / 1000000) || 999,
      revenue2026: (revenue[idx] / 1000000) || 60372,
      eps2026: eps[idx] || 4.87,
      opMargin2026: (operatingMargin[idx] * 100) || 11.9,
      profitMargin2026: (profitMargin[idx] * 100) || 9.1,
      fcfMargin2026: (fcfMargin[idx] * 100) || 8.1,
      currentPrice: currentPrice,

      history: {
        years: years.slice(idx, idx + 5).reverse(),
        revenue: revenue.slice(idx, idx + 5).map(v => v ? v / 1000000 : null).reverse(),
        fcf: fcf.slice(idx, idx + 5).map(v => v ? v / 1000000 : null).reverse(),
        eps: eps.slice(idx, idx + 5).reverse(),
        opMargin: operatingMargin.slice(idx, idx + 5).map(v => v ? v * 100 : null).reverse(),
        pMargin: profitMargin.slice(idx, idx + 5).map(v => v ? v * 100 : null).reverse(),
        fMargin: fcfMargin.slice(idx, idx + 5).map(v => v ? v * 100 : null).reverse(),
      }
    };
  } catch (error) {
    console.error("Error fetching TJX data:", error);
    return null;
  }
}

let data = await fetchStockData();

// If fetch completely fails, use fallback actuals
if (!data) {
  data = {
    fcf2026: 4917,
    shares: 1128,
    cash: 6230,
    debt: 999,
    revenue2026: 60372,
    eps2026: 4.87,
    opMargin2026: 11.9,
    profitMargin2026: 9.1,
    fcfMargin2026: 8.1,
    currentPrice: 114.50,
    history: {
      years: ["2022", "2023", "2024", "2025", "2026"],
      revenue: [48550, 49936, 54217, 56360, 60372],
      fcf: [2012, 2627, 4335, 4198, 4917],
      eps: [2.70, 2.97, 3.86, 4.26, 4.87],
      opMargin: [9.8, 9.7, 10.7, 11.2, 11.9],
      pMargin: [6.8, 7.0, 8.3, 8.6, 9.1],
      fMargin: [4.1, 5.3, 8.0, 7.4, 8.1],
    }
  };
}

// --- INPUTS (all in millions USD unless noted) ---
const fcfBase = data.fcf2026;                // FY2026 Free Cash Flow ($M)
const sharesOutstanding = data.shares;       // Basic/Diluted shares outstanding ($M)
const cashAndInvestments = data.cash;        // Cash + short-term investments ($M)
const totalDebt = data.debt;                 // Total debt ($M)
const netCash = cashAndInvestments - totalDebt; // Net Cash

// --- ASSUMPTIONS (fully disclosed below) ---
// TJX is a mature retailer. Off-price retail continues to perform well.
const growthRatePhase1 = 0.09;         // 9% FCF growth, Years 1-5
const growthRateTerminal = 0.03;       // 3% perpetuity growth (terminal)
const discountRate = 0.085;            // 8.5% WACC / required return

// --- PHASE 1: PROJECT FCF FOR YEARS 1-5 ---
const projectedFCF = [];
let fcf = fcfBase;
for (let yr = 1; yr <= 5; yr++) {
  fcf = fcf * (1 + growthRatePhase1);
  projectedFCF.push({ year: yr, fcf: Math.round(fcf), pvFactor: 1 / Math.pow(1 + discountRate, yr) });
}
projectedFCF.forEach(p => { p.pvFCF = Math.round(p.fcf * p.pvFactor); });

// --- PHASE 2: TERMINAL VALUE (Gordon Growth Model) ---
const fcfYear6 = projectedFCF[4].fcf * (1 + growthRateTerminal);
const terminalValue = Math.round(fcfYear6 / (discountRate - growthRateTerminal));
const pvTerminalValue = Math.round(terminalValue * projectedFCF[4].pvFactor);

// --- ENTERPRISE VALUE ---
const pvPhase1 = projectedFCF.reduce((sum, p) => sum + p.pvFCF, 0);
const enterpriseValue = pvPhase1 + pvTerminalValue;

// --- EQUITY VALUE ---
const equityValue = enterpriseValue + netCash;
const intrinsicValuePerShare = equityValue / sharesOutstanding;
const roundedIV = Math.round(intrinsicValuePerShare * 100) / 100;

// Market comparison
const currentPrice = data.currentPrice;
const marginOfSafety = ((roundedIV - currentPrice) / currentPrice * 100).toFixed(1);
const verdictText = roundedIV > currentPrice ? "Undervalued" : "Overvalued";
const verdictColor = roundedIV > currentPrice ? "#10b981" : "#ef4444";

// Sensitivity analysis
const sensitivityRates = [0.065, 0.075, 0.085, 0.095, 0.105];
const sensitivityGrowth = [0.05, 0.07, 0.09, 0.11, 0.13];
const sensitivityTable = sensitivityRates.map(dr => {
  return {
    dr,
    values: sensitivityGrowth.map(gr => {
      let f = fcfBase;
      let pvSum = 0;
      for (let y = 1; y <= 5; y++) {
        f = f * (1 + gr);
        pvSum += f / Math.pow(1 + dr, y);
      }
      const f6 = f * (1 + growthRateTerminal);
      const tv = f6 / (dr - growthRateTerminal);
      const pvTV = tv / Math.pow(1 + dr, 5);
      return Math.round((pvSum + pvTV + netCash) / sharesOutstanding);
    })
  };
});
