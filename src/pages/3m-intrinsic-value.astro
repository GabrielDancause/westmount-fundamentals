---
export const meta = {
  title: "3M (MMM) Intrinsic Value: A DCF Analysis",
  description: "A transparent, step-by-step discounted cash flow valuation of 3M Company (MMM). Every assumption disclosed. Here's what 3M is really worth.",
  category: "study",
  published: "2026-03-24", // Assuming roughly current or future date
};

const schema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": "3M (MMM) Intrinsic Value: A DCF Analysis",
  "description": "A transparent, step-by-step discounted cash flow valuation of 3M Company (MMM). Every assumption disclosed. Here's what 3M is really worth.",
  "datePublished": meta.published,
  "dateModified": meta.published,
  "author": {
    "@type": "Organization",
    "name": "Westmount Research",
    "url": "https://westmountfundamentals.com"
  },
  "publisher": {
    "@type": "Organization",
    "name": "Westmount Research",
    "url": "https://westmountfundamentals.com"
  },
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": "https://westmountfundamentals.com/3m-intrinsic-value"
  }
};

import SiteLayout from "../layouts/SiteLayout.astro";
import * as cheerio from 'cheerio';

/* ═══════════════════════════════════════════════════════════════
   DATA FETCHING FROM STOCKANALYSIS.COM
   ═══════════════════════════════════════════════════════════════ */
const headers = {
  'User-Agent': 'Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36'
};

const parseNum = (str) => {
  if (!str || str === '-') return null;
  return parseFloat(str.replace(/,/g, ''));
};

let currentPrice = null;
let revenueHistoryRaw = [];
let operatingIncomeHistoryRaw = [];
let netIncomeHistoryRaw = [];
let epsHistoryRaw = [];
let sharesHistoryRaw = [];
let operatingCashFlowHistoryRaw = [];
let freeCashFlowHistoryRaw = [];
let cashAndEquivalentsRaw = null;
let totalDebtRaw = null;
let yearsLabel = [];

try {
  // 1. Main financials
  const resFin = await fetch('https://stockanalysis.com/stocks/mmm/financials/', { headers });
  if (resFin.ok) {
    const htmlFin = await resFin.text();
    const $fin = cheerio.load(htmlFin);

    const priceMatch = htmlFin.match(/<div class="[^"]*text-4xl[^"]*"[^>]*>([\d\.,]+)<\/div>/);
    if (priceMatch) currentPrice = parseNum(priceMatch[1]);

    $fin('table thead tr th').each((i, el) => {
      if (i > 0 && i <= 5) yearsLabel.push($fin(el).text().trim());
    });

    $fin('table tbody tr').each((i, el) => {
      const header = $fin(el).find('td').first().text().trim();
      if (header === 'Revenue') {
        $fin(el).find('td').each((j, td) => { if (j > 0 && j <= 5) revenueHistoryRaw.push(parseNum($fin(td).text().trim())); });
      } else if (header === 'Operating Income') {
        $fin(el).find('td').each((j, td) => { if (j > 0 && j <= 5) operatingIncomeHistoryRaw.push(parseNum($fin(td).text().trim())); });
      } else if (header === 'Net Income') {
        $fin(el).find('td').each((j, td) => { if (j > 0 && j <= 5) netIncomeHistoryRaw.push(parseNum($fin(td).text().trim())); });
      } else if (header === 'EPS (Diluted)') {
        $fin(el).find('td').each((j, td) => { if (j > 0 && j <= 5) epsHistoryRaw.push(parseNum($fin(td).text().trim())); });
      } else if (header === 'Shares Outstanding (Diluted)') {
        $fin(el).find('td').each((j, td) => { if (j > 0 && j <= 5) sharesHistoryRaw.push(parseNum($fin(td).text().trim())); });
      }
    });
  }

  // 2. Cash Flow
  const resCf = await fetch('https://stockanalysis.com/stocks/mmm/financials/cash-flow-statement/', { headers });
  if (resCf.ok) {
    const htmlCf = await resCf.text();
    const $cf = cheerio.load(htmlCf);
    $cf('table tbody tr').each((i, el) => {
      const header = $cf(el).find('td').first().text().trim();
      if (header === 'Operating Cash Flow') {
        $cf(el).find('td').each((j, td) => { if (j > 0 && j <= 5) operatingCashFlowHistoryRaw.push(parseNum($cf(td).text().trim())); });
      } else if (header === 'Free Cash Flow') {
        $cf(el).find('td').each((j, td) => { if (j > 0 && j <= 5) freeCashFlowHistoryRaw.push(parseNum($cf(td).text().trim())); });
      }
    });
  }

  // 3. Balance Sheet
  const resBs = await fetch('https://stockanalysis.com/stocks/mmm/financials/balance-sheet/', { headers });
  if (resBs.ok) {
    const htmlBs = await resBs.text();
    const $bs = cheerio.load(htmlBs);
    $bs('table tbody tr').each((i, el) => {
      const header = $bs(el).find('td').first().text().trim();
      if (header === 'Cash & Equivalents') {
        cashAndEquivalentsRaw = parseNum($bs(el).find('td').eq(1).text().trim());
      } else if (header === 'Total Debt') {
        totalDebtRaw = parseNum($bs(el).find('td').eq(1).text().trim());
      }
    });
  }
} catch (e) {
  console.error("Error fetching data:", e);
}

/* ═══════════════════════════════════════════════════════════════
   DCF MODEL — ALL INPUTS AND CALCULATIONS
   ═══════════════════════════════════════════════════════════════ */

// Ensure we have current data to work with, otherwise use fallbacks
// "null over fake data", but for the DCF to calculate we need *something*.
// If fetch totally fails, the page will render N/A or zeroes for calculated fields.

// Values extracted (latest year is index 0)
const revenueTTM = revenueHistoryRaw[0] !== undefined ? revenueHistoryRaw[0] : null;
// Notice that 3M has high CapEx and volatile FCF due to settlements.
// We'll use Operating Cash Flow as proxy for base cash generation ability if FCF is severely depressed.
// However, the rule states to use actual Operating Cash Flow instead of fabricating normalized FCF.
const ocfTTM = operatingCashFlowHistoryRaw[0] !== undefined ? operatingCashFlowHistoryRaw[0] : null;
const fcfTTM = freeCashFlowHistoryRaw[0] !== undefined ? freeCashFlowHistoryRaw[0] : null;
const epsTTM = epsHistoryRaw[0] !== undefined ? epsHistoryRaw[0] : null;
const opIncTTM = operatingIncomeHistoryRaw[0] !== undefined ? operatingIncomeHistoryRaw[0] : null;

// --- INPUTS ---
const baseCashFlow = ocfTTM !== null ? ocfTTM : 0; // Explicitly use Operating Cash Flow as base per rules
const sharesOutstanding = sharesHistoryRaw[0] !== undefined ? sharesHistoryRaw[0] : 0;
const cashAndInvestments = cashAndEquivalentsRaw !== null ? cashAndEquivalentsRaw : 0;
const totalDebt = totalDebtRaw !== null ? totalDebtRaw : 0;
const netCash = cashAndInvestments - totalDebt;

// --- ASSUMPTIONS ---
const growthRatePhase1 = 0.04;         // 4% growth, Years 1-5 (Post-spinoff modest growth)
const growthRateTerminal = 0.025;      // 2.5% perpetuity growth (mature industrial)
const discountRate = 0.09;             // 9% WACC (4.18% Treasury + risk premium, adjusted for litigation/debt risk)

// --- PHASE 1: PROJECT CASH FLOWS FOR YEARS 1-5 ---
const projectedFCF = [];
let cf = baseCashFlow;
for (let yr = 1; yr <= 5; yr++) {
  cf = cf * (1 + growthRatePhase1);
  projectedFCF.push({
    year: yr,
    fcf: Math.round(cf),
    pvFactor: 1 / Math.pow(1 + discountRate, yr)
  });
}
projectedFCF.forEach(p => { p.pvFCF = Math.round(p.fcf * p.pvFactor); });

// --- PHASE 2: TERMINAL VALUE (Gordon Growth Model) ---
const fcfYear6 = projectedFCF[4] ? projectedFCF[4].fcf * (1 + growthRateTerminal) : 0;
const terminalValue = (discountRate - growthRateTerminal) > 0 ? Math.round(fcfYear6 / (discountRate - growthRateTerminal)) : 0;
const pvTerminalValue = projectedFCF[4] ? Math.round(terminalValue * projectedFCF[4].pvFactor) : 0;

// --- ENTERPRISE VALUE ---
const pvPhase1 = projectedFCF.reduce((sum, p) => sum + p.pvFCF, 0);
const enterpriseValue = pvPhase1 + pvTerminalValue;

// --- EQUITY VALUE ---
const equityValue = enterpriseValue + netCash;
const intrinsicValuePerShare = sharesOutstanding > 0 ? equityValue / sharesOutstanding : 0;
const roundedIV = Math.round(intrinsicValuePerShare * 100) / 100;

// Market comparison
const safeCurrentPrice = currentPrice !== null ? currentPrice : 0;
const marginOfSafety = safeCurrentPrice > 0 ? ((roundedIV - safeCurrentPrice) / safeCurrentPrice * 100).toFixed(1) : 'N/A';
const verdictText = roundedIV > safeCurrentPrice ? "Undervalued" : "Overvalued";
const verdictColor = roundedIV > safeCurrentPrice ? "#10b981" : "#ef4444";
const opMarginTTM = (opIncTTM !== null && revenueTTM !== null && revenueTTM > 0) ? ((opIncTTM / revenueTTM) * 100).toFixed(1) : 'N/A';

// --- HISTORICAL DATA for charts ---
const revenueHistory = [];
const fcfHistory = [];
const epsHistoryChart = [];
const marginHistory = [];

for (let i = 4; i >= 0; i--) {
  if (yearsLabel[i]) {
    // Reverse order for chronological display
    const yrMatch = yearsLabel[i].match(/\d{4}/);
    const yrNum = yrMatch ? parseInt(yrMatch[0]) : 2025 - i;

    const r = revenueHistoryRaw[i] !== undefined ? revenueHistoryRaw[i] : null;
    const f = freeCashFlowHistoryRaw[i] !== undefined ? freeCashFlowHistoryRaw[i] : null;
    const e = epsHistoryRaw[i] !== undefined ? epsHistoryRaw[i] : null;

    revenueHistory.push({ year: yrNum, value: r });
    fcfHistory.push({ year: yrNum, value: f });
    epsHistoryChart.push({ year: yrNum, value: e });

    const op = operatingIncomeHistoryRaw[i] !== undefined ? operatingIncomeHistoryRaw[i] : null;
    const ni = netIncomeHistoryRaw[i] !== undefined ? netIncomeHistoryRaw[i] : null;

    marginHistory.push({
      year: yrNum,
      operating: (op !== null && r !== null && r > 0) ? ((op / r) * 100).toFixed(2) : 'N/A',
      profit: (ni !== null && r !== null && r > 0) ? ((ni / r) * 100).toFixed(2) : 'N/A',
      fcfMargin: (f !== null && r !== null && r > 0) ? ((f / r) * 100).toFixed(2) : 'N/A'
    });
  }
}

// Sensitivity analysis
const sensitivityRates = [0.07, 0.08, 0.09, 0.10, 0.11];
const sensitivityGrowth = [0.00, 0.02, 0.04, 0.06, 0.08];
const sensitivityTable = sensitivityRates.map(dr => {
  return {
    dr,
    values: sensitivityGrowth.map(gr => {
      let f_val = baseCashFlow;
      let pvSum = 0;
      for (let y = 1; y <= 5; y++) {
        f_val = f_val * (1 + gr);
        pvSum += f_val / Math.pow(1 + dr, y);
      }
      const f6 = f_val * (1 + growthRateTerminal);
      const tv = f6 / (dr - growthRateTerminal);
      const pvTV = tv / Math.pow(1 + dr, 5);
      return sharesOutstanding > 0 ? Math.round((pvSum + pvTV + netCash) / sharesOutstanding) : 0;
    })
  };
});

// Helper for formatting
const formatCurrency = (val) => val !== null ? `$${val.toLocaleString()}` : 'N/A';
const formatBillions = (val) => val !== null ? `$${(val / 1000).toFixed(2)}B` : 'N/A';

// Calculate max values for charts to scale properly
const maxRev = Math.max(...revenueHistory.map(d => d.value !== null ? d.value : 0), 1);
const maxFcf = Math.max(...fcfHistory.map(d => d.value !== null ? d.value : 0), 1);
const maxEps = Math.max(...epsHistoryChart.map(d => d.value !== null ? d.value : 0), 1);

---

<SiteLayout
  site="westmount"
  title={meta.title}
  description={meta.description}
  canonical="https://westmountfundamentals.com/3m-intrinsic-value"
  schema={schema}
>
<style is:global>
@import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800;900&family=JetBrains+Mono:wght@400;700;800&display=swap');
*, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

body { font-family: 'Inter', -apple-system, sans-serif; background: #060a12; color: #c8d0de; line-height: 1.7; }
</style>
<style>
.dcf-wrapper { padding-bottom: 60px; }
a { color: #4a8fe7; text-decoration: none; }
a:hover { text-decoration: underline; }
.container { max-width: 900px; margin: 0 auto; padding: 0 24px; }

/* Header */
.header { text-align: center; padding: 80px 24px 60px; background: linear-gradient(180deg, #0a1628 0%, #060a12 100%); position: relative; border-bottom: 1px solid #152040; }
.header::before { content: ''; position: absolute; inset: 0; background: radial-gradient(circle at 50% 40%, rgba(74,143,231,0.06) 0%, transparent 60%); }
.header-content { position: relative; z-index: 1; }
.tag { display: inline-block; background: rgba(74,143,231,0.12); color: #4a8fe7; font-size: 0.75rem; font-weight: 800; padding: 6px 16px; border-radius: 20px; letter-spacing: 1.5px; text-transform: uppercase; margin-bottom: 16px; }
h1 { font-size: 2.8rem; font-weight: 900; color: #fff; letter-spacing: -1.2px; margin-bottom: 16px; line-height: 1.1; }
@media (max-width: 640px) { h1 { font-size: 2rem; } }
.subtitle { color: #7a8a9e; font-size: 1.1rem; max-width: 700px; margin: 0 auto 16px; }
.date { color: #3a4a60; font-size: 0.85rem; font-weight: 600; letter-spacing: 1px; }

/* Big verdict */
.verdict-card { max-width: 560px; margin: 60px auto 0; background: linear-gradient(135deg, #0a1628 0%, #0d1830 100%); border: 2px solid #152040; border-radius: 20px; padding: 48px 32px; text-align: center; box-shadow: 0 20px 60px rgba(0,0,0,0.4); position: relative; overflow: hidden; }
.verdict-card::before { content: ''; position: absolute; top: -60%; left: -20%; width: 140%; height: 120%; background: radial-gradient(ellipse, rgba(74,143,231,0.04) 0%, transparent 70%); }
.verdict-label { font-size: 0.8rem; color: #5a6a80; font-weight: 700; text-transform: uppercase; letter-spacing: 2px; margin-bottom: 12px; position: relative; }
.verdict-price { font-family: 'JetBrains Mono', monospace; font-size: 4.5rem; font-weight: 800; color: #fff; line-height: 1; margin-bottom: 8px; position: relative; }
@media (max-width: 640px) { .verdict-price { font-size: 3rem; } }
.verdict-vs { font-size: 0.95rem; color: #5a6a80; margin-bottom: 20px; position: relative; }
.verdict-badge { display: inline-block; padding: 8px 24px; border-radius: 30px; font-weight: 800; font-size: 0.9rem; letter-spacing: 1px; text-transform: uppercase; position: relative; }

/* Stats */
.stats-row { display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); gap: 16px; margin: 40px auto; max-width: 900px; }
.stat-card { background: #0a1020; border: 1px solid #152040; border-radius: 14px; padding: 24px 16px; text-align: center; }
.stat-value { font-family: 'JetBrains Mono', monospace; font-size: 1.8rem; font-weight: 700; color: #4a8fe7; margin-bottom: 4px; }
.stat-label { font-size: 0.78rem; color: #5a6a80; font-weight: 600; text-transform: uppercase; letter-spacing: 0.5px; }

/* Sections */
h2 { font-size: 1.8rem; font-weight: 800; color: #fff; margin: 60px 0 20px; letter-spacing: -0.5px; border-bottom: 2px solid #152040; padding-bottom: 12px; }
