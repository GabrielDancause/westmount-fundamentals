---
import SiteLayout from "../layouts/SiteLayout.astro";

const schema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What is the RRSP contribution limit for 2026?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "The maximum RRSP contribution limit for the 2026 tax year is $32,490. Your personal limit is calculated as 18% of your earned income from 2025, up to this maximum amount, plus any unused contribution room carried forward from previous years."
      }
    },
    {
      "@type": "Question",
      "name": "How is my 2026 RRSP deduction limit calculated?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Your 2026 RRSP deduction limit is calculated by taking 18% of your 2025 earned income (up to the maximum of $32,490) and subtracting any pension adjustments from your employer. You then add any unused contribution room from previous years."
      }
    },
    {
      "@type": "Question",
      "name": "What happens if I overcontribute to my RRSP?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "The CRA allows a lifetime overcontribution buffer of $2,000. If you exceed your RRSP contribution limit by more than $2,000, you will face a penalty tax of 1% per month on the excess amount until it is withdrawn or new room becomes available."
      }
    },
    {
      "@type": "Question",
      "name": "When is the deadline for 2026 RRSP contributions?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "The deadline for making RRSP contributions that can be deducted against your 2026 tax year income is generally March 1, 2027 (or February 28/29 if it's a leap year, adjusted for weekends)."
      }
    },
    {
      "@type": "Question",
      "name": "How does the RRSP room calculator work?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Our RRSP room calculator multiplies your prior year's earned income by 18%, compares it to the CRA maximum limit ($32,490 for 2026), and outputs your exact new contribution room. It also calculates your estimated tax savings based on your marginal tax bracket."
      }
    }
  ]
};

export const meta = {
  title: "RRSP Contribution Limit & Deduction Calculator 2026",
  description: "Calculate your 2026 RRSP contribution limit and deduction room. Learn how the 18% rule and $32,490 max apply to your income with our interactive tool.",
  category: "tool",
  published: "2026-03-15",
};
---

<SiteLayout
  site="westmount"
  title="RRSP Contribution Limit & Deduction Calculator 2026"
  description="Calculate your 2026 RRSP contribution limit and deduction room. Learn how the 18% rule and $32,490 max apply to your income with our interactive tool."
  canonical="https://westmountfundamentals.com/rrsp-contribution-limit-2026" schema={schema}
>
  <style>
:root {
      --white: #ffffff;
      --green: #2ecc71;

}
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      font-family: 'Inter', sans-serif;
      background-color: var(--bg-color);
      color: var(--text-primary);
      line-height: 1.6;
    }
    a { color: var(--accent-color); text-decoration: none; }
    a:hover { text-decoration: underline; }

    /* Nav */
    nav {
      position: sticky;
      top: 0;
      z-index: 1000;
      background: rgba(6, 10, 18, 0.85);
      backdrop-filter: blur(10px);
      border-bottom: 1px solid var(--border-color);
      padding: 16px 24px;
      display: flex;
      justify-content: space-between;
      align-items: center;
    }
    .brand {
      font-weight: 800;
      color: var(--white);
      font-size: 1.1rem;
      letter-spacing: -0.5px;
    }
    .nav-links { display: flex; gap: 24px; }
    .nav-links a { color: var(--text-primary); font-size: 0.9rem; font-weight: 500; }
    .nav-links a:hover { color: var(--accent-color); text-decoration: none; }

    /* Layout */
    .container { max-width: 1100px; margin: 0 auto; padding: 40px 24px; }
    header { text-align: center; margin-bottom: 50px; }
    h1 {
      font-size: 2.8rem;
      font-weight: 900;
      letter-spacing: -1px;
      margin-bottom: 16px;
      background: linear-gradient(90deg, #fff, var(--accent-color));
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      line-height: 1.2;
    }
    .subtitle { font-size: 1.1rem; color: var(--text-muted); max-width: 600px; margin: 0 auto; }

    /* Stats Row */
    .stats-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
      gap: 20px;
      margin-bottom: 40px;
    }
    .stat-card {
      background: var(--card-bg);
      border: 1px solid var(--border-color);
      border-radius: 12px;
      padding: 24px;
      text-align: center;
    }
    .stat-value {
      font-size: 2.2rem;
      font-weight: 800;
      color: var(--white);
      margin-bottom: 4px;
      font-family: 'JetBrains Mono', monospace;
    }
    .stat-label { font-size: 0.85rem; color: var(--text-muted); text-transform: uppercase; letter-spacing: 1px; }

    /* Calculator & Chart Grid */
    .dashboard-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 30px;
      margin-bottom: 50px;
    }
    @media (max-width: 800px) { .dashboard-grid { grid-template-columns: 1fr; } }

    .card {
      background: var(--card-bg);
      border: 1px solid var(--border-color);
      border-radius: 12px;
      padding: 30px;
    }
    .card h2 { font-size: 1.4rem; color: var(--white); margin-bottom: 20px; font-weight: 700; }

    .form-group { margin-bottom: 20px; }
    label { display: block; font-size: 0.9rem; color: var(--text-muted); margin-bottom: 8px; font-weight: 500; }
    input {
      width: 100%;
      background: var(--bg-color);
      border: 1px solid var(--border-color);
      color: var(--white);
      padding: 12px 16px;
      border-radius: 6px;
      font-family: 'JetBrains Mono', monospace;
      font-size: 1rem;
    }
    input:focus { outline: none; border-color: var(--accent-color); }

    .calc-result {
      margin-top: 30px;
      padding: 20px;
      background: rgba(74, 143, 231, 0.1);
      border-left: 4px solid var(--accent-color);
      border-radius: 4px;
    }
    .result-row { display: flex; justify-content: space-between; margin-bottom: 12px; }
    .result-row:last-child { margin-bottom: 0; padding-top: 12px; border-top: 1px solid var(--border-color); font-weight: 700; }
    .result-val { font-family: 'JetBrains Mono', monospace; color: var(--white); }
    .result-val.highlight { color: var(--accent-color); font-size: 1.2rem; }

    /* Table Section */
    .table-controls { display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px; }
    .search-box {
      background: var(--bg-color);
      border: 1px solid var(--border-color);
      color: var(--white);
      padding: 8px 12px;
      border-radius: 6px;
      width: 250px;
    }
    .table-responsive { overflow-x: auto; }
    table { width: 100%; border-collapse: collapse; text-align: left; }
    th, td { padding: 14px; border-bottom: 1px solid var(--border-color); }
    th { color: var(--text-muted); font-size: 0.85rem; text-transform: uppercase; font-weight: 600; cursor: pointer; }
    th:hover { color: var(--white); }
    td { font-family: 'JetBrains Mono', monospace; font-size: 0.95rem; color: var(--text-primary); }
    tr:hover td { background: rgba(255,255,255,0.02); }

    /* Content Sections */
    .content-section { margin-bottom: 50px; }
    .content-section h2 { font-size: 1.8rem; color: var(--white); margin-bottom: 20px; }
    .content-section p { margin-bottom: 16px; color: var(--text-primary); }

    .faq-item {
      background: var(--card-bg);
      border: 1px solid var(--border-color);
      border-radius: 8px;
      padding: 20px;
      margin-bottom: 16px;
    }
    .faq-q { font-size: 1.1rem; font-weight: 700; color: var(--white); margin-bottom: 10px; }
    .faq-a { color: var(--text-muted); font-size: 0.95rem; }

    footer {
      text-align: center;
      padding: 40px 24px;
      border-top: 1px solid var(--border-color);
      margin-top: 60px;
      font-size: 0.85rem;
      color: var(--text-muted);
    }
  </style>

<div class="container">
    <h1>RRSP Contribution Limit & Deduction Calculator 2026</h1>


    <div class="stats-grid">
      <div class="stat-card">
        <div class="stat-value">$32,490</div>
        <div class="stat-label">2026 Maximum Limit</div>
      </div>
      <div class="stat-card">
        <div class="stat-value">18%</div>
        <div class="stat-label">of 2025 Earned Income</div>
      </div>
      <div class="stat-card">
        <div class="stat-value" id="stat-tax-savings">--</div>
        <div class="stat-label">Est. Tax Savings (at 30%)</div>
      </div>
    </div>

    <div class="dashboard-grid">
      <div class="card">
        <h2>RRSP Room Calculator</h2>
        <div class="form-group">
          <label for="income">Your 2025 Earned Income ($)</label>
          <input type="number" id="income" placeholder="e.g. 100000" value="85000">
        </div>
        <div class="form-group">
          <label for="pension">Pension Adjustment for 2025 ($)</label>
          <input type="number" id="pension" placeholder="0" value="0">
        </div>
        <div class="form-group">
          <label for="carry">Unused Contribution Room ($)</label>
          <input type="number" id="carry" placeholder="0" value="0">
        </div>
        <div class="form-group">
          <label for="taxrate">Average Marginal Tax Rate (%)</label>
          <input type="number" id="taxrate" placeholder="30" value="30">
        </div>

        <div class="calc-result">
          <div class="result-row">
            <span>18% of Earned Income:</span>
            <span class="result-val" id="res-18pct">$15,300</span>
          </div>
          <div class="result-row">
            <span>CRA Max Limit Limit:</span>
            <span class="result-val">$32,490</span>
          </div>
          <div class="result-row">
            <span>Less Pension Adjustment:</span>
            <span class="result-val" id="res-pa">$0</span>
          </div>
          <div class="result-row">
            <span>Plus Unused Room:</span>
            <span class="result-val" id="res-carry">$0</span>
          </div>
          <div class="result-row">
            <span>Your 2026 RRSP Room:</span>
            <span class="result-val highlight" id="res-total">$15,300</span>
          </div>
          <div class="result-row" style="margin-top: 15px;">
            <span>Estimated Tax Refund:</span>
            <span class="result-val highlight" style="color: var(--green);" id="res-refund">$4,590</span>
          </div>
        </div>
      </div>

      <div class="card">
        <h2>Historical RRSP Limits</h2>
        <canvas id="limitChart"></canvas>
      </div>
    </div>

    <div class="card content-section">
      <div class="table-controls">
        <h2>Historical Limits Data</h2>
        <input type="text" id="searchTable" class="search-box" placeholder="Search year...">
      </div>
      <div class="table-responsive">
        <table id="dataTable">
          <thead>
            <tr>
              <th onclick="sortTable(0)">Tax Year ↕</th>
              <th onclick="sortTable(1)">Maximum Limit ↕</th>
              <th onclick="sortTable(2)">% Increase ↕</th>
            </tr>
          </thead>
          <tbody id="tableBody">
            <!-- Populated by JS -->
          </tbody>
        </table>
      </div>
    </div>

    <div class="content-section">
      <h2>Methodology & Data Sources</h2>
      <p>The Registered Retirement Savings Plan (RRSP) contribution limits displayed on this page are sourced directly from the Canada Revenue Agency (CRA) official announcements. The limits are indexed annually based on changes in the average wage in Canada.</p>
      <p>Our calculator computes the new room for 2026 by applying the CRA rule: 18% of the previous year's (2025) earned income, up to the maximum limit of $32,490, minus any pension adjustment (PA), plus any unused contribution room carried forward from previous years.</p>
      <p>Estimated tax savings are illustrative and based on a simplified marginal tax rate calculation. They assume the entire contribution is deducted in the 2026 tax year and falls within the specified tax bracket. For exact tax implications, please consult the CRA website or a qualified tax professional.</p>
    </div>

    <div class="content-section">
      <h2>Frequently Asked Questions</h2>
      <div class="faq-item">
        <div class="faq-q">What is the RRSP contribution limit for 2026?</div>
        <div class="faq-a">The maximum RRSP contribution limit for the 2026 tax year is $32,490. Your personal limit is calculated as 18% of your earned income from 2025, up to this maximum amount, plus any unused contribution room carried forward from previous years.</div>
      </div>
      <div class="faq-item">
        <div class="faq-q">How is my 2026 RRSP deduction limit calculated?</div>
        <div class="faq-a">Your 2026 RRSP deduction limit is calculated by taking 18% of your 2025 earned income (up to the maximum of $32,490) and subtracting any pension adjustments from your employer. You then add any unused contribution room from previous years.</div>
      </div>
      <div class="faq-item">
        <div class="faq-q">What happens if I overcontribute to my RRSP?</div>
        <div class="faq-a">The CRA allows a lifetime overcontribution buffer of $2,000. If you exceed your RRSP contribution limit by more than $2,000, you will face a penalty tax of 1% per month on the excess amount until it is withdrawn or new room becomes available.</div>
      </div>
      <div class="faq-item">
        <div class="faq-q">When is the deadline for 2026 RRSP contributions?</div>
        <div class="faq-a">The deadline for making RRSP contributions that can be deducted against your 2026 tax year income is generally March 1, 2027 (or February 28/29 if it's a leap year, adjusted for weekends).</div>
      </div>
      <div class="faq-item">
        <div class="faq-q">How does the RRSP room calculator work?</div>
        <div class="faq-a">Our RRSP room calculator multiplies your prior year's earned income by 18%, compares it to the CRA maximum limit ($32,490 for 2026), and outputs your exact new contribution room. It also calculates your estimated tax savings based on your marginal tax bracket.</div>
      </div>
    </div>

  </div>
  <script is:inline>
// Data
    const RRSP_MAX_2026 = 32490;

    const historicalData = [
      { year: 2026, limit: 32490 },
      { year: 2025, limit: 31560 },
      { year: 2024, limit: 31560 },
      { year: 2023, limit: 30780 },
      { year: 2022, limit: 29210 },
      { year: 2021, limit: 27830 },
      { year: 2020, limit: 27230 },
      { year: 2019, limit: 26500 },
      { year: 2018, limit: 26230 },
      { year: 2017, limit: 26010 },
      { year: 2016, limit: 25370 },
      { year: 2015, limit: 24930 },
      { year: 2014, limit: 24270 }
    ];

    // Format currency
    const formatCurrency = (val) => new Intl.NumberFormat('en-CA', { style: 'currency', currency: 'CAD', maximumFractionDigits: 0 }).format(val);

    // Calculator Logic
    function calculateRoom() {
      const income = parseFloat(document.getElementById('income').value) || 0;
      const pension = parseFloat(document.getElementById('pension').value) || 0;
      const carry = parseFloat(document.getElementById('carry').value) || 0;
      const taxrate = parseFloat(document.getElementById('taxrate').value) || 0;

      const pct18 = income * 0.18;
      const newRoomRaw = Math.min(pct18, RRSP_MAX_2026);

      let totalRoom = 0;

      // CRA formula logic simplified: (18% of prior year income OR max limit, whichever is lower) - PA + carry forward.
      const calcVal = newRoomRaw - pension + carry;
      totalRoom = Math.max(0, calcVal);

      const estRefund = totalRoom * (taxrate / 100);

      document.getElementById('res-18pct').innerText = formatCurrency(pct18);
      document.getElementById('res-pa').innerText = '-' + formatCurrency(pension);
      document.getElementById('res-carry').innerText = '+' + formatCurrency(carry);
      document.getElementById('res-total').innerText = formatCurrency(totalRoom);
      document.getElementById('res-refund').innerText = formatCurrency(estRefund);

      document.getElementById('stat-tax-savings').innerText = formatCurrency(estRefund);
    }

    // Event listeners
    ['income', 'pension', 'carry', 'taxrate'].forEach(id => {
      document.getElementById(id).addEventListener('input', calculateRoom);
    });

    // Initialize Calculator
    calculateRoom();

    // Table Generation
    function renderTable(data) {
      const tbody = document.getElementById('tableBody');
      tbody.innerHTML = '';

      for(let i = 0; i < data.length; i++) {
        let pctInc = "N/A";
        // Calculate % increase compared to previous year (which is at i+1 since array is descending)
        if (i < data.length - 1) {
          const prevLimit = data[i+1].limit;
          const inc = ((data[i].limit - prevLimit) / prevLimit) * 100;
          pctInc = inc > 0 ? '+' + inc.toFixed(2) + '%' : '0.00%';
        }

        // Find if this is latest sort order from global array to get correct inc value
        let realInc = "N/A";
        const origIdx = historicalData.findIndex(x => x.year === data[i].year);
        if(origIdx !== -1 && origIdx < historicalData.length - 1) {
           const prevL = historicalData[origIdx+1].limit;
           const v = ((data[i].limit - prevL) / prevL) * 100;
           realInc = v > 0 ? '+' + v.toFixed(2) + '%' : '0.00%';
        }

        tbody.innerHTML += `
          <tr>
            <td>${data[i].year}</td>
            <td>${formatCurrency(data[i].limit)}</td>
            <td style="color: ${realInc.startsWith('+') ? 'var(--green)' : 'inherit'}">${realInc}</td>
          </tr>
        `;
      }
    }
    renderTable(historicalData);

    // Table Search
    document.getElementById('searchTable').addEventListener('input', (e) => {
      const term = e.target.value.toLowerCase();
      const filtered = historicalData.filter(d => d.year.toString().includes(term));
      renderTable(filtered);
    });

    // Table Sorting
    let sortAsc = false;
    function sortTable(colIdx) {
      sortAsc = !sortAsc;
      const sorted = [...historicalData].sort((a, b) => {
        let valA, valB;
        if (colIdx === 0) { valA = a.year; valB = b.year; }
        else if (colIdx === 1) { valA = a.limit; valB = b.limit; }
        else {
          // Approximate sort for % increase
          const getInc = (item) => {
            const idx = historicalData.findIndex(x => x.year === item.year);
            if (idx < historicalData.length - 1) return item.limit - historicalData[idx+1].limit;
            return 0;
          };
          valA = getInc(a); valB = getInc(b);
        }
        return sortAsc ? valA - valB : valB - valA;
      });
      renderTable(sorted);
    }

    // Chart
    const ctx = document.getElementById('limitChart').getContext('2d');
    const chartData = [...historicalData].reverse();

    new Chart(ctx, {
      type: 'bar',
      data: {
        labels: chartData.map(d => d.year),
        datasets: [{
          label: 'RRSP Max Limit ($)',
          data: chartData.map(d => d.limit),
          backgroundColor: 'rgba(74, 143, 231, 0.2)',
          borderColor: '#4a8fe7',
          borderWidth: 2,
          borderRadius: 4
        }]
      },
      options: {
        responsive: true,
        plugins: {
          legend: { display: false },
          tooltip: {
            callbacks: {
              label: function(context) { return formatCurrency(context.raw); }
            }
          }
        },
        scales: {
          y: {
            beginAtZero: false,
            min: 20000,
            grid: { color: '#152040' },
            ticks: {
              color: '#8b9bb4',
              callback: function(value) { return '$' + (value/1000) + 'k'; }
            }
          },
          x: {
            grid: { display: false },
            ticks: { color: '#8b9bb4' }
          }
        }
      }
    });
  </script>

  <section style="max-width:800px;margin:40px auto;padding:0 24px">
    <h2 style="font-size:20px;color:var(--text-bright,#fff);margin-bottom:16px">Related Pages</h2>
    <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:12px">
      <a href="/rrsp-contribution-calculator/" style="display:block;padding:16px;background:var(--card-bg,#0a1020);border:1px solid var(--border-color,#152040);border-radius:8px;text-decoration:none;color:var(--text-primary,#c8d0de);transition:transform 0.2s" onmouseover="this.style.transform='translateY(-2px)'" onmouseout="this.style.transform='none'">RRSP Contribution Calculator</a>
      <a href="/tfsa-contribution-room-2026/" style="display:block;padding:16px;background:var(--card-bg,#0a1020);border:1px solid var(--border-color,#152040);border-radius:8px;text-decoration:none;color:var(--text-primary,#c8d0de);transition:transform 0.2s" onmouseover="this.style.transform='translateY(-2px)'" onmouseout="this.style.transform='none'">TFSA Contribution Room & Limits (2026 Calculator)</a>
      <a href="/rrsp-deadline-reminder/" style="display:block;padding:16px;background:var(--card-bg,#0a1020);border:1px solid var(--border-color,#152040);border-radius:8px;text-decoration:none;color:var(--text-primary,#c8d0de);transition:transform 0.2s" onmouseover="this.style.transform='translateY(-2px)'" onmouseout="this.style.transform='none'">RRSP Deadline & Key Dates</a>
      <a href="/what-is-limit-order/" style="display:block;padding:16px;background:var(--card-bg,#0a1020);border:1px solid var(--border-color,#152040);border-radius:8px;text-decoration:none;color:var(--text-primary,#c8d0de);transition:transform 0.2s" onmouseover="this.style.transform='translateY(-2px)'" onmouseout="this.style.transform='none'">What is a Limit Order in Stocks? A Complete Guide for Invest</a>
    </div>
  </section>
</SiteLayout>
