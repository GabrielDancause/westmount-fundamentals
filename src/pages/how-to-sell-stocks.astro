<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    const calculateBtn = document.getElementById('calculateTaxes');
    if (!calculateBtn) return;

    calculateBtn.addEventListener('click', () => {
      const purchasePrice = parseFloat(document.getElementById('purchasePrice').value);
      const sellPrice = parseFloat(document.getElementById('sellPrice').value);
      const taxBracket = parseFloat(document.getElementById('taxBracket').value);

      if (isNaN(purchasePrice) || isNaN(sellPrice) || isNaN(taxBracket)) {
        alert('Please enter valid numbers for all fields.');
        return;
      }

      const rawGrossProfit = sellPrice - purchasePrice;

      // Handle floating point precision issues
      let grossProfit = parseFloat(rawGrossProfit.toPrecision(14));
      if (Math.abs(grossProfit - Math.round(grossProfit)) < 1e-14) {
        grossProfit = Math.round(grossProfit);
      }

      let taxes = 0;
      let netProfit = 0;

      if (grossProfit > 0) {
        const rawTaxes = grossProfit * (taxBracket / 100);
        taxes = parseFloat(rawTaxes.toPrecision(14));
        if (Math.abs(taxes - Math.round(taxes)) < 1e-14) {
          taxes = Math.round(taxes);
        }

        const rawNet = grossProfit - taxes;
        netProfit = parseFloat(rawNet.toPrecision(14));
        if (Math.abs(netProfit - Math.round(netProfit)) < 1e-14) {
          netProfit = Math.round(netProfit);
        }
      } else {
        netProfit = grossProfit; // If loss, net is the loss
      }

      // Formatting
      const formatter = new Intl.NumberFormat('en-US', {
        style: 'currency',
        currency: 'USD'
      });

      document.getElementById('resGrossProfit').textContent = formatter.format(grossProfit);
      document.getElementById('resTaxes').textContent = grossProfit > 0 ? '-' + formatter.format(taxes) : '$0.00';
      document.getElementById('resNetProfit').textContent = formatter.format(netProfit);

      // Color coding based on profit/loss
      const resNetEl = document.getElementById('resNetProfit');
      if (netProfit > 0) {
        resNetEl.className = 'highlight-positive';
      } else if (netProfit < 0) {
        resNetEl.className = 'highlight-negative';
      } else {
        resNetEl.className = 'highlight';
      }

      document.getElementById('calcResults').style.display = 'block';
    });
  });
</script>
