          </div>
          <div class="input-group">
            <label for="holdingPeriod">Holding Period</label>
            <select id="holdingPeriod">
              <option value="short">1 Year or Less (Short-Term)</option>
              <option value="long" selected>More than 1 Year (Long-Term)</option>
            </select>
          </div>
          <div class="input-group">
            <label for="taxBracket">Estimated Tax Bracket (%)</label>
            <input type="number" id="taxBracket" min="0" max="50" step="1" value="15">
            <small class="helper-text">Typically 15% for Long-Term, or your ordinary income rate for Short-Term.</small>
          </div>

          <button id="calculateTaxes" class="calc-button">Estimate Tax Impact</button>

          <div id="calcResults" class="results-container" style="display: none;">
            <div class="result-row">
              <span>Gross Profit:</span>
              <span id="resGrossProfit" class="highlight"></span>
            </div>
            <div class="result-row">
