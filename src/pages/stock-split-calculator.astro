---
import SiteLayout from "../layouts/SiteLayout.astro";

const schema = {
  "@context": "https://schema.org",
  "@type": ["Article", "FAQPage"],
  "headline": "Stock Split Calculator & Guide: How Forward and Reverse Splits Work",
  "description": "Calculate your new share count and price after a stock split. See how forward and reverse splits impact your portfolio value—and why companies do them.",
  "datePublished": "2026-03-17",
  "publisher": {
    "@type": "Organization",
    "name": "Westmount Research"
  },
  "mainEntity": [
    {
      "@type": "Question",
      "name": "how does a stock split work",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "A stock split divides a company's existing shares into multiple new shares to boost liquidity. The total dollar value of the shares remains the same, as the share price drops proportionately. For example, in a 2-for-1 split, you get twice as many shares, but each share is worth half as much."
      }
    },
    {
      "@type": "Question",
      "name": "does a stock split change market cap",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "No, a stock split does not change the overall market capitalization of a company. It simply divides the existing market cap into more (or fewer, in a reverse split) slices. Your total investment value remains exactly the same immediately after the split."
      }
    },
    {
      "@type": "Question",
      "name": "what is a reverse stock split",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "A reverse stock split consolidates a company's existing shares into fewer, more valuable shares. It is typically done by companies whose stock price has fallen too low, often to avoid being delisted from a stock exchange."
      }
    },
    {
      "@type": "Question",
      "name": "how to calculate shares after stock split",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "To calculate your new share count, multiply your current number of shares by the first number in the split ratio, then divide by the second number. For example, in a 3-for-1 split, if you own 100 shares, you multiply 100 by 3 and divide by 1 to get 300 shares."
      }
    },
    {
      "@type": "Question",
      "name": "when do stock splits happen",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Stock splits usually happen when a company's stock price has risen significantly and the board of directors decides to make the stock more accessible to retail investors. The exact timing is announced by the company, including the record date and the execution (ex-dividend) date."
      }
    }
  ]
};

export const meta = {
  title: "Stock Split Calculator & Guide: How Forward and Reverse Splits Work",
  description: "Calculate your new share count and price after a stock split. See how forward and reverse splits impact your portfolio value—and why companies do them.",
  category: "tool",
  published: "2026-03-17",
};
