          </div>
          <div class="faq-item">
            <h3 class="faq-q">what is a reverse stock split</h3>
            <p class="faq-a">A reverse stock split consolidates a company's existing shares into fewer, more valuable shares. It is typically done by companies whose stock price has fallen too low, often to avoid being delisted from a stock exchange.</p>
          </div>
          <div class="faq-item">
            <h3 class="faq-q">how to calculate shares after stock split</h3>
            <p class="faq-a">To calculate your new share count, multiply your current number of shares by the first number in the split ratio, then divide by the second number. For example, in a 3-for-1 split, if you own 100 shares, you multiply 100 by 3 and divide by 1 to get 300 shares.</p>
          </div>
          <div class="faq-item">
            <h3 class="faq-q">when do stock splits happen</h3>
            <p class="faq-a">Stock splits usually happen when a company's stock price has risen significantly and the board of directors decides to make the stock more accessible to retail investors. The exact timing is announced by the company, including the record date and the execution (ex-dividend) date.</p>
          </div>
        </div>
      </div>

      <div class="content-section" style="margin-top: 60px; padding: 24px; background: rgba(74, 143, 231, 0.05); border: 1px solid rgba(74, 143, 231, 0.2); border-radius: 12px;">
        <h3 style="margin-top: 0; font-size: 1.2rem; color: var(--accent-color);">Related Investing Resources</h3>
        <p style="margin-bottom: 0;">Once you understand how stock splits affect your portfolio mechanics, you might also want to explore our <a href="/dividend-yield-calculator">Dividend Yield Calculator</a> to project annual income, or see how long-term market trends play out in our guide on the <a href="/average-stock-market-return">Average Stock Market Return</a>.</p>
      </div>

    </div>

  </div>

  <script is:inline>

    // UI Elements
    const elShares = document.getElementById('input-shares');
    const elPrice = document.getElementById('input-price');
    const toggleReverse = document.getElementById('input-reverse-toggle');
    const labelReverse = document.getElementById('split-type-label');
    const selectPreset = document.getElementById('preset-ratios');
    const customRatioGroup = document.getElementById('custom-ratio-group');
    const inputRatioY = document.getElementById('input-ratio-y'); // New shares you get
    const inputRatioX = document.getElementById('input-ratio-x'); // Old shares you give
    const ratioDescription = document.getElementById('ratio-description');

    // Output Elements
    const resPrice = document.getElementById('res-price');
    const resShares = document.getElementById('res-shares');
    const resValue = document.getElementById('res-value');

    const tblBeforeShares = document.getElementById('table-before-shares');
    const tblBeforePrice = document.getElementById('table-before-price');
    const tblBeforeValue = document.getElementById('table-before-value');

    const tblAfterShares = document.getElementById('table-after-shares');
    const tblAfterPrice = document.getElementById('table-after-price');
    const tblAfterValue = document.getElementById('table-after-value');

    const formatCurrency = (val) => new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD' }).format(val);
    const formatShares = (val) => new Intl.NumberFormat('en-US', { maximumFractionDigits: 4 }).format(val);

    function getRatio() {
      let isReverse = toggleReverse.checked;
      let ratioStr = selectPreset.value;
      let y, x;

      if (ratioStr === 'custom') {
        y = parseFloat(inputRatioY.value) || 1;
        x = parseFloat(inputRatioX.value) || 1;
        customRatioGroup.style.display = 'block';
      } else {
        customRatioGroup.style.display = 'none';
        const parts = ratioStr.split(':');
        y = parseFloat(parts[0]);
        x = parseFloat(parts[1]);

        // Update custom inputs to match preset so if they switch to custom, it holds the last preset
        inputRatioY.value = y;
        inputRatioX.value = x;
      }

      if (isReverse) {
        // Swap y and x for reverse split
        return { y: x, x: y, isReverse: true };
      }
      return { y: y, x: x, isReverse: false };
    }

    function calculate() {
      const shares = parseFloat(elShares.value) || 0;
      const price = parseFloat(elPrice.value) || 0;

      const ratio = getRatio();
      const splitFactor = ratio.y / ratio.x;

      // Describe ratio
      if (ratio.isReverse) {
        labelReverse.innerText = 'Reverse Split';
        ratioDescription.innerText = `You will receive ${ratio.y} new share(s) for every ${ratio.x} share(s) you own.`;
      } else {
        labelReverse.innerText = 'Forward Split';
        ratioDescription.innerText = `You will receive ${ratio.y} new share(s) for every ${ratio.x} share(s) you own.`;
      }

      // Calculations
      const newShares = shares * splitFactor;
      const newPrice = price / splitFactor;

      // To avoid floating point bugs, we snap to integer cents, and total value is ALWAYS shares * price.
      // E.g. 100 * 500 = 50,000
      const totalValueOriginal = shares * price;

      // Update UI Result Panels
      resShares.innerText = formatShares(newShares);
      resPrice.innerText = formatCurrency(newPrice);
      resValue.innerText = formatCurrency(totalValueOriginal);

      // Update Table
      tblBeforeShares.innerText = formatShares(shares);
      tblBeforePrice.innerText = formatCurrency(price);
      tblBeforeValue.innerText = formatCurrency(totalValueOriginal);

      tblAfterShares.innerText = formatShares(newShares);
      tblAfterPrice.innerText = formatCurrency(newPrice);
      tblAfterValue.innerText = formatCurrency(totalValueOriginal);
    }

    // Event Listeners
    [elShares, elPrice, toggleReverse, selectPreset, inputRatioY, inputRatioX].forEach(el => {
      if(el) {
        el.addEventListener('input', calculate);
        el.addEventListener('change', calculate);
      }
    });

    // Initial calculation
    calculate();

  </script>
</SiteLayout>
