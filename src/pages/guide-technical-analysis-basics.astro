---
import SiteLayout from "../layouts/SiteLayout.astro";

const schema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Should fundamental investors use technical analysis?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes, but strictly as a secondary tool. Fundamental analysis should dictate WHAT to buy and sell, while simple technical analysis (like volume and key moving averages) can help optimize WHEN to enter or exit positions."
      }
    },
    {
      "@type": "Question",
      "name": "Do support and resistance levels actually work?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes, support and resistance work primarily because of market psychology and memory. They represent price points where large pools of buyers or sellers have historically stepped in, creating self-fulfilling prophecies."
      }
    },
    {
      "@type": "Question",
      "name": "What is the difference between the 50-day and 200-day moving average?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "The 50-day moving average measures the medium-term trend and is closely watched by institutional traders. The 200-day moving average represents the long-term macroeconomic trend; stocks trading below it are generally considered to be in a downtrend."
      }
    },
    {
      "@type": "Question",
      "name": "Is RSI a good indicator for value investing?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "The Relative Strength Index (RSI) can be useful for value investors when looking to initiate a position in a stock they already like fundamentally. An RSI below 30 indicates the stock is temporarily oversold and might offer a better entry price."
      }
    },
    {
      "@type": "Question",
      "name": "Do chart patterns like head and shoulders work?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Most complex chart patterns lack robust statistical evidence. For fundamental investors, relying on subjective patterns like 'head and shoulders' or Elliott Wave theory is generally not recommended, as they are prone to confirmation bias."
      }
    }
  ]
};

export const meta = {
  title: "Technical Analysis for Fundamental Investors: What Actually Works",
  description: "A skeptical value investor's guide to technical analysis. Discover which chart signals actually work and which indicators you are better off ignoring...",
  category: "guide",
  published: "2026-03-15",
};
