  <script is:inline>
// Simple Chart Visualizer Script
    const canvas = document.getElementById('chartCanvas');
    const ctx = canvas.getContext('2d');
    const volInput = document.getElementById('volatility');
    const trendInput = document.getElementById('trend');
    const genBtn = document.getElementById('generate-btn');

    let priceData = [];
    let sma50Data = [];
    let sma200Data = [];

    function resizeCanvas() {
      const parent = canvas.parentElement;
      canvas.width = parent.clientWidth;
      canvas.height = parent.clientHeight;
      drawChart();
    }

    function generateData() {
      const points = 600;
      let currentPrice = 100;
      const vol = parseInt(volInput.value);
      const trend = parseInt(trendInput.value) / 10;

      priceData = [];

      for(let i=0; i<points; i++) {
        // Random walk with drift
        const change = (Math.random() - 0.5) * vol + trend;
        currentPrice += change;
        if(currentPrice < 10) currentPrice = 10;
        priceData.push(currentPrice);
      }

      // Calculate SMAs
      sma50Data = calculateSMA(priceData, 50);
      sma200Data = calculateSMA(priceData, 200);

      drawChart();
    }

    function calculateSMA(data, period) {
      const sma = new Array(data.length).fill(null);
      for (let i = period - 1; i < data.length; i++) {
        const slice = data.slice(i - period + 1, i + 1);
        const sum = slice.reduce((a, b) => a + b, 0);
        sma[i] = sum / period;
      }
      return sma;
    }

    function drawChart() {
      ctx.clearRect(0, 0, canvas.width, canvas.height);

      if(priceData.length === 0) return;

      const padding = 20;
      const width = canvas.width - padding * 2;
      const height = canvas.height - padding * 2;

      // Find min/max for scaling
      let allVisibleData = [...priceData];
      sma50Data.forEach(v => { if(v) allVisibleData.push(v); });
      sma200Data.forEach(v => { if(v) allVisibleData.push(v); });

      const maxVal = Math.max(...allVisibleData) * 1.05;
      const minVal = Math.min(...allVisibleData) * 0.95;
      const range = maxVal - minVal;

      const getX = (i) => padding + (i / (priceData.length - 1)) * width;
      const getY = (val) => canvas.height - padding - ((val - minVal) / range) * height;

      // Draw Grid
      ctx.strokeStyle = '#152040';
      ctx.lineWidth = 1;
      ctx.beginPath();
      for(let i=0; i<=4; i++) {
        const y = padding + i * (height/4);
        ctx.moveTo(padding, y);
        ctx.lineTo(canvas.width - padding, y);
      }
      ctx.stroke();

      // Function to draw a line
      function drawLine(data, color, lineWidth = 2) {
        ctx.beginPath();
        ctx.strokeStyle = color;
        ctx.lineWidth = lineWidth;
        ctx.lineJoin = 'round';

        let started = false;
        for(let i=0; i<data.length; i++) {
          if(data[i] !== null) {
            if(!started) {
              ctx.moveTo(getX(i), getY(data[i]));
              started = true;
            } else {
              ctx.lineTo(getX(i), getY(data[i]));
            }
          }
        }
        ctx.stroke();
      }

      // Draw Lines
      drawLine(priceData, '#8a94a6', 1); // Price
      drawLine(sma50Data, '#4a8fe7', 2); // 50 SMA
      drawLine(sma200Data, '#e74c3c', 2); // 200 SMA
    }

    window.addEventListener('resize', resizeCanvas);
    volInput.addEventListener('input', generateData);
    trendInput.addEventListener('input', generateData);
    genBtn.addEventListener('click', generateData);

    // Initial render
    resizeCanvas();
    generateData();
  </script>

  
  
