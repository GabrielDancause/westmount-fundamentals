---
import SiteLayout from "../layouts/SiteLayout.astro";
import registry from "../data/pages-registry.json";

export const meta = { title: "Intrinsic Value Calculator: Free DCF & Graham Number Tool (2026)", description: "Calculate the intrinsic value of any stock using our free DCF and Graham Number calculators. Pre-loaded with 168 S&P 500 stocks. No signup required.", category: "study", published: "2026-03-20" };

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Article",
      "headline": "Intrinsic Value Calculator: Free DCF & Graham Number Tool",
      "description": "Calculate the intrinsic value of any stock using our free DCF and Graham Number calculators. Pre-loaded with 168 S&P 500 stocks. No signup required.",
      "datePublished": "2026-03-20",
      "dateModified": "2026-03-20",
      "publisher": { "@type": "Organization", "name": "Westmount Fundamentals", "url": "https://westmountfundamentals.com" }
    },
    {
      "@type": "FAQPage",
      "mainEntity": [
        { "@type": "Question", "name": "How do you calculate the intrinsic value of a stock?", "acceptedAnswer": { "@type": "Answer", "text": "The most common method is a Discounted Cash Flow (DCF) analysis. You project the company's future free cash flows, then discount them back to present value using an appropriate discount rate (usually WACC). The sum of all discounted cash flows plus the terminal value gives you the intrinsic value. Another popular method is the Benjamin Graham formula, which uses EPS and expected growth rate." } },
        { "@type": "Question", "name": "What method does Warren Buffett use to calculate intrinsic value?", "acceptedAnswer": { "@type": "Answer", "text": "Warren Buffett primarily uses a Discounted Cash Flow (DCF) model focused on owner earnings — net income plus depreciation minus capital expenditures. He applies a discount rate based on the long-term US Treasury yield and looks for companies trading at a significant margin of safety below their calculated intrinsic value." } },
        { "@type": "Question", "name": "What is a good margin of safety for stocks?", "acceptedAnswer": { "@type": "Answer", "text": "Benjamin Graham recommended a margin of safety of at least 33%. Warren Buffett typically looks for 25-50% depending on the quality and predictability of the business. A higher margin of safety provides more protection against errors in your assumptions and unforeseen events." } },
        { "@type": "Question", "name": "What is the difference between intrinsic value and market price?", "acceptedAnswer": { "@type": "Answer", "text": "Market price is what investors are currently willing to pay for a stock — driven by supply, demand, and sentiment. Intrinsic value is an estimate of what the stock is actually worth based on the company's fundamentals (cash flows, earnings, assets). When market price is below intrinsic value, the stock may be undervalued." } },
        { "@type": "Question", "name": "How accurate are intrinsic value calculators?", "acceptedAnswer": { "@type": "Answer", "text": "No intrinsic value calculator is perfectly accurate because all valuations depend on assumptions about future growth, discount rates, and terminal values. Small changes in inputs can produce large differences in output. The value of a DCF model isn't the precise number — it's the framework for thinking about what drives a stock's worth. Always use a margin of safety." } }
      ]
    }
  ]
};
---

<SiteLayout
  site="westmount"
  title="Intrinsic Value Calculator: Free DCF & Graham Number Tool (2026)"
  description="Calculate the intrinsic value of any stock using our free DCF and Graham Number calculators. Pre-loaded with 168 S&P 500 stocks. No signup required."
  canonical="https://westmountfundamentals.com/intrinsic-value-calculator/"
  schema={schema}
>

<style>
:root { --accent: #4a8fe7; --positive: #10b981; --negative: #ef4444; --warning: #f59e0b; --bg-card: #0d1117; --bg-input: #161b22; --border: #30363d; --text: #e6edf3; --text-muted: #8b949e; }
.calc-hero { text-align:center; padding:2rem 0 1rem; }
.calc-hero h1 { font-size:2rem; margin-bottom:0.5rem; color:#fff; }
.calc-hero .sub { color:var(--text-muted); font-size:1.05rem; max-width:600px; margin:0 auto; }
.calc-hero .badge { display:inline-block; background:var(--accent); color:#fff; padding:0.2rem 0.7rem; border-radius:12px; font-size:0.8rem; font-weight:600; margin-bottom:1rem; }

/* Stat cards */
.stat-row { display:grid; grid-template-columns:repeat(4,1fr); gap:1rem; margin:1.5rem 0; }
.stat-card { background:var(--bg-card); border:1px solid var(--border); border-radius:12px; padding:1.2rem; text-align:center; }
.stat-card .val { font-size:1.8rem; font-weight:700; color:#fff; }
.stat-card .lbl { font-size:0.8rem; color:var(--text-muted); margin-top:0.3rem; }

/* Tabs */
.calc-tabs { display:flex; gap:0.5rem; margin:2rem 0 1rem; flex-wrap:wrap; }
.calc-tab { padding:0.6rem 1.5rem; border-radius:8px; border:1px solid var(--border); background:var(--bg-card); color:var(--text-muted); cursor:pointer; font-size:0.95rem; font-weight:600; transition:all 0.2s; }
.calc-tab:hover { border-color:var(--accent); color:var(--text); }
.calc-tab.active { background:var(--accent); color:#fff; border-color:var(--accent); }

/* Calculator panels */
.calc-panel { display:none; }
.calc-panel.active { display:block; }
.calc-container { background:var(--bg-card); border:1px solid var(--border); border-radius:16px; padding:2rem; margin-bottom:2rem; }
.calc-grid { display:grid; grid-template-columns:1fr 1fr; gap:2rem; }
.input-section h3 { color:#fff; margin-bottom:1rem; font-size:1.1rem; }
.input-group { margin-bottom:1rem; }
.input-group label { display:block; color:var(--text-muted); font-size:0.85rem; margin-bottom:0.3rem; }
.input-group input, .input-group select { width:100%; padding:0.7rem; background:var(--bg-input); border:1px solid var(--border); border-radius:8px; color:#fff; font-size:1rem; }
.input-group input:focus, .input-group select:focus { outline:none; border-color:var(--accent); }
.input-row { display:grid; grid-template-columns:1fr 1fr; gap:1rem; }
.input-hint { font-size:0.75rem; color:var(--text-muted); margin-top:0.2rem; }
.btn-calc { width:100%; padding:0.9rem; background:var(--accent); color:#fff; border:none; border-radius:8px; font-size:1rem; font-weight:700; cursor:pointer; margin-top:0.5rem; transition:all 0.2s; }
.btn-calc:hover { background:#3a7fd7; }

/* Result panel */
.result-panel { background:var(--bg-input); border-radius:12px; padding:1.5rem; min-height:320px; display:flex; flex-direction:column; justify-content:center; }
.result-verdict { text-align:center; padding:1rem 0; }
.result-verdict .iv-value { font-size:2.8rem; font-weight:800; color:#fff; }
.result-verdict .iv-label { color:var(--text-muted); font-size:0.9rem; }
.result-verdict .verdict-badge { display:inline-block; padding:0.4rem 1.2rem; border-radius:20px; font-weight:700; font-size:1.1rem; margin:0.8rem 0; }
.verdict-undervalued { background:rgba(16,185,129,0.15); color:var(--positive); border:1px solid var(--positive); }
.verdict-overvalued { background:rgba(239,68,68,0.15); color:var(--negative); border:1px solid var(--negative); }
.verdict-fair { background:rgba(245,158,11,0.15); color:var(--warning); border:1px solid var(--warning); }
.result-details { margin-top:1rem; }
.result-row { display:flex; justify-content:space-between; padding:0.5rem 0; border-bottom:1px solid var(--border); }
.result-row:last-child { border-bottom:none; }
.result-row .rl { color:var(--text-muted); font-size:0.9rem; }
.result-row .rv { color:#fff; font-weight:600; font-size:0.9rem; }

/* Gauge */
.gauge-container { margin:1rem 0; }
.gauge-bar { height:16px; border-radius:8px; background:linear-gradient(to right, var(--positive) 0%, var(--warning) 50%, var(--negative) 100%); position:relative; }
.gauge-marker { position:absolute; top:-4px; width:4px; height:24px; background:#fff; border-radius:2px; transform:translateX(-50%); transition:left 0.5s; }
.gauge-labels { display:flex; justify-content:space-between; margin-top:0.3rem; font-size:0.75rem; color:var(--text-muted); }

/* Ticker search */
.ticker-search-wrap { position:relative; margin-bottom:1.5rem; }
.ticker-search { width:100%; padding:0.9rem 1rem 0.9rem 2.8rem; background:var(--bg-input); border:2px solid var(--border); border-radius:12px; color:#fff; font-size:1.1rem; }
.ticker-search:focus { border-color:var(--accent); outline:none; }
.ticker-search-icon { position:absolute; left:0.9rem; top:50%; transform:translateY(-50%); color:var(--text-muted); font-size:1.1rem; }
.ticker-dropdown { position:absolute; top:100%; left:0; right:0; background:var(--bg-card); border:1px solid var(--border); border-radius:8px; max-height:240px; overflow-y:auto; z-index:100; display:none; }
.ticker-dropdown.show { display:block; }
.ticker-option { padding:0.7rem 1rem; cursor:pointer; display:flex; justify-content:space-between; align-items:center; }
.ticker-option:hover { background:var(--bg-input); }
.ticker-option .to-name { color:var(--text-muted); font-size:0.85rem; }
.ticker-option .to-ticker { font-weight:700; color:#fff; }
.ticker-loaded-badge { display:inline-block; background:rgba(16,185,129,0.15); color:var(--positive); padding:0.15rem 0.5rem; border-radius:6px; font-size:0.7rem; margin-left:0.5rem; }

/* Chart */
.chart-wrap { margin:2rem 0; background:var(--bg-card); border:1px solid var(--border); border-radius:12px; padding:1.5rem; }
.chart-wrap h3 { color:#fff; margin-bottom:1rem; }

/* Screener table */
.screener-section { margin:2rem 0; }
.screener-section h2 { color:#fff; margin-bottom:0.5rem; }
.screener-section .sub { color:var(--text-muted); margin-bottom:1rem; }
.screener-controls { display:flex; gap:1rem; margin-bottom:1rem; flex-wrap:wrap; align-items:center; }
.screener-filter { padding:0.5rem 1rem; background:var(--bg-input); border:1px solid var(--border); border-radius:8px; color:#fff; font-size:0.9rem; cursor:pointer; }
.screener-filter.active { background:var(--accent); border-color:var(--accent); }
.screener-search { padding:0.5rem 1rem; background:var(--bg-input); border:1px solid var(--border); border-radius:8px; color:#fff; font-size:0.9rem; flex:1; min-width:200px; }
.screener-table-wrap { overflow-x:auto; }
table.screener { width:100%; border-collapse:collapse; font-size:0.9rem; }
table.screener th { text-align:left; padding:0.7rem 0.8rem; color:var(--text-muted); border-bottom:2px solid var(--border); cursor:pointer; white-space:nowrap; }
table.screener th:hover { color:var(--accent); }
table.screener td { padding:0.6rem 0.8rem; border-bottom:1px solid var(--border); color:var(--text); }
table.screener tr:hover { background:rgba(74,143,231,0.05); }
.mos-bar { display:inline-block; height:8px; border-radius:4px; min-width:4px; }

/* Key insights */
.insights-grid { display:grid; grid-template-columns:repeat(2,1fr); gap:1.5rem; margin:2rem 0; }
.insight-card { background:var(--bg-card); border:1px solid var(--border); border-radius:12px; padding:1.5rem; }
.insight-card .ic-num { font-size:2rem; font-weight:800; color:var(--accent); }
.insight-card .ic-title { color:#fff; font-weight:600; margin:0.3rem 0; }
.insight-card .ic-desc { color:var(--text-muted); font-size:0.9rem; }

/* How-to section */
.how-section { margin:3rem 0; }
.how-section h2 { color:#fff; }
.how-steps { counter-reset:step; margin:1.5rem 0; }
.how-step { display:flex; gap:1.5rem; margin-bottom:2rem; align-items:flex-start; }
.how-step-num { background:var(--accent); color:#fff; width:36px; height:36px; border-radius:50%; display:flex; align-items:center; justify-content:center; font-weight:700; flex-shrink:0; }
.how-step-content h4 { color:#fff; margin:0 0 0.3rem; }
.how-step-content p { color:var(--text-muted); margin:0; font-size:0.95rem; line-height:1.6; }

/* Formula display */
.formula-box { background:var(--bg-input); border:1px solid var(--border); border-radius:12px; padding:1.5rem; margin:1.5rem 0; text-align:center; }
.formula-box .formula { font-size:1.2rem; color:var(--accent); font-weight:600; font-family:monospace; letter-spacing:0.5px; }
.formula-box .formula-label { color:var(--text-muted); font-size:0.85rem; margin-top:0.5rem; }

/* FAQ */
.faq-section { margin:3rem 0; }
.faq-item { border-bottom:1px solid var(--border); }
.faq-q { padding:1rem 0; cursor:pointer; display:flex; justify-content:space-between; align-items:center; color:#fff; font-weight:600; }
.faq-q:hover { color:var(--accent); }
.faq-a { padding:0 0 1rem; color:var(--text-muted); line-height:1.7; display:none; }
.faq-a.open { display:block; }
.faq-arrow { transition:transform 0.2s; }
.faq-arrow.open { transform:rotate(180deg); }

/* CTA */
.cta-box { background:linear-gradient(135deg, rgba(74,143,231,0.15), rgba(16,185,129,0.1)); border:1px solid var(--accent); border-radius:16px; padding:2rem; text-align:center; margin:2rem 0; }
.cta-box h3 { color:#fff; margin-bottom:0.5rem; }
.cta-box p { color:var(--text-muted); margin-bottom:1rem; }
.cta-btn { display:inline-block; padding:0.8rem 2rem; background:var(--accent); color:#fff; border-radius:8px; text-decoration:none; font-weight:700; }

/* Responsive */
@media(max-width:768px) {
  .stat-row { grid-template-columns:repeat(2,1fr); }
  .calc-grid { grid-template-columns:1fr; }
  .insights-grid { grid-template-columns:1fr; }
  .input-row { grid-template-columns:1fr; }
  .calc-hero h1 { font-size:1.5rem; }
}
</style>

<div class="calc-hero">
  <span class="badge">FREE TOOL · NO SIGNUP</span>
  <h1>Intrinsic Value Calculator</h1>
  <p class="sub">Calculate the fair value of any stock using DCF analysis or the Benjamin Graham formula. Pre-loaded with 168 S&P 500 companies.</p>
</div>

<div class="stat-row" id="hero-stats">
  <div class="stat-card">
    <div class="val" id="stat-stocks">168</div>
    <div class="lbl">Pre-loaded Stocks</div>
  </div>
  <div class="stat-card">
    <div class="val" style="color:var(--positive)" id="stat-under">39</div>
    <div class="lbl">Undervalued</div>
  </div>
  <div class="stat-card">
    <div class="val" style="color:var(--negative)" id="stat-over">127</div>
    <div class="lbl">Overvalued</div>
  </div>
  <div class="stat-card">
    <div class="val" style="color:var(--warning)" id="stat-avg-mos">38.4%</div>
    <div class="lbl">Avg Margin of Safety</div>
  </div>
</div>

<!-- Calculator Tabs -->
<div class="calc-tabs">
  <div class="calc-tab active" onclick="switchTab('dcf')">📊 DCF Calculator</div>
  <div class="calc-tab" onclick="switchTab('graham')">📐 Graham Number</div>
  <div class="calc-tab" onclick="switchTab('screener')">🔍 Stock Screener</div>
</div>

<!-- DCF Calculator -->
<div class="calc-panel active" id="panel-dcf">
  <div class="calc-container">
    <div class="ticker-search-wrap">
      <span class="ticker-search-icon">🔍</span>
      <input type="text" class="ticker-search" id="dcf-ticker" placeholder="Search ticker or company (e.g. AAPL, Apple)..." autocomplete="off">
      <div class="ticker-dropdown" id="dcf-dropdown"></div>
    </div>
    <div class="calc-grid">
      <div class="input-section">
        <h3>DCF Assumptions</h3>
        <div class="input-row">
          <div class="input-group">
            <label>Current Free Cash Flow ($M)</label>
            <input type="number" id="dcf-fcf" placeholder="e.g. 5000" step="any">
            <div class="input-hint">Annual FCF from latest filings</div>
          </div>
          <div class="input-group">
            <label>Shares Outstanding (M)</label>
            <input type="number" id="dcf-shares" placeholder="e.g. 1500" step="any">
            <div class="input-hint">Diluted share count</div>
          </div>
        </div>
        <div class="input-row">
          <div class="input-group">
            <label>FCF Growth Rate (Years 1-5)</label>
            <input type="number" id="dcf-growth" placeholder="e.g. 12" step="0.1" value="10"> %
            <div class="input-hint">How fast will FCF grow?</div>
          </div>
          <div class="input-group">
            <label>Terminal Growth Rate</label>
            <input type="number" id="dcf-terminal" placeholder="e.g. 3" step="0.1" value="3"> %
            <div class="input-hint">Long-term GDP growth (2-4%)</div>
          </div>
        </div>
        <div class="input-row">
          <div class="input-group">
            <label>Discount Rate (WACC)</label>
            <input type="number" id="dcf-discount" placeholder="e.g. 10" step="0.1" value="10"> %
            <div class="input-hint">Required rate of return</div>
          </div>
          <div class="input-group">
            <label>Current Stock Price ($)</label>
            <input type="number" id="dcf-price" placeholder="e.g. 150" step="0.01">
          </div>
        </div>
        <div class="input-group">
          <label>Projection Period</label>
          <select id="dcf-years">
            <option value="5">5 Years</option>
            <option value="10" selected>10 Years</option>
            <option value="15">15 Years</option>
            <option value="20">20 Years</option>
          </select>
        </div>
        <button class="btn-calc" onclick="calculateDCF()">Calculate Intrinsic Value →</button>
      </div>
      <div class="result-panel" id="dcf-result">
        <div style="text-align:center;color:var(--text-muted);">
          <div style="font-size:3rem;margin-bottom:0.5rem;">📊</div>
          <div>Enter a ticker or input your assumptions</div>
          <div style="font-size:0.85rem;margin-top:0.5rem;">168 stocks pre-loaded with AI-analyzed assumptions</div>
        </div>
      </div>
    </div>
  </div>

  <!-- DCF Sensitivity Chart -->
  <div class="chart-wrap" id="dcf-sensitivity-wrap" style="display:none;">
    <h3>📈 Sensitivity Analysis</h3>
    <p style="color:var(--text-muted);font-size:0.9rem;">How intrinsic value changes with different growth rates and discount rates</p>
    <canvas id="dcf-sensitivity-chart" height="300"></canvas>
  </div>

  <!-- DCF Cash Flow Projection -->
  <div class="chart-wrap" id="dcf-projection-wrap" style="display:none;">
    <h3>💰 Projected Free Cash Flows</h3>
    <canvas id="dcf-projection-chart" height="250"></canvas>
  </div>
</div>

<!-- Graham Number Calculator -->
<div class="calc-panel" id="panel-graham">
  <div class="calc-container">
    <div class="calc-grid">
      <div class="input-section">
        <h3>Benjamin Graham Formula</h3>
        <div class="formula-box">
          <div class="formula">V = EPS × (8.5 + 2g) × 4.4 / Y</div>
          <div class="formula-label">Where g = expected growth rate, Y = current AAA bond yield</div>
        </div>
        <div class="input-row">
          <div class="input-group">
            <label>Earnings Per Share (EPS)</label>
            <input type="number" id="graham-eps" placeholder="e.g. 6.50" step="0.01">
            <div class="input-hint">Trailing twelve months EPS</div>
          </div>
          <div class="input-group">
            <label>Expected Growth Rate (%)</label>
            <input type="number" id="graham-growth" placeholder="e.g. 10" step="0.1" value="10">
            <div class="input-hint">Next 7-10 years annual EPS growth</div>
          </div>
        </div>
        <div class="input-row">
          <div class="input-group">
            <label>Current AAA Bond Yield (%)</label>
            <input type="number" id="graham-yield" placeholder="e.g. 4.8" step="0.1" value="4.8">
            <div class="input-hint">Currently ~4.8% (Moody's AAA)</div>
          </div>
          <div class="input-group">
            <label>Current Stock Price ($)</label>
            <input type="number" id="graham-price" placeholder="e.g. 150" step="0.01">
          </div>
        </div>
        <h3 style="margin-top:1.5rem;">Graham Number</h3>
        <div class="formula-box">
          <div class="formula">GN = √(22.5 × EPS × BVPS)</div>
          <div class="formula-label">Maximum price for a defensive investor</div>
        </div>
        <div class="input-group">
          <label>Book Value Per Share (BVPS)</label>
          <input type="number" id="graham-bvps" placeholder="e.g. 25.00" step="0.01">
          <div class="input-hint">From latest balance sheet</div>
        </div>
        <button class="btn-calc" onclick="calculateGraham()">Calculate Graham Values →</button>
      </div>
      <div class="result-panel" id="graham-result">
        <div style="text-align:center;color:var(--text-muted);">
          <div style="font-size:3rem;margin-bottom:0.5rem;">📐</div>
          <div>Enter EPS and growth estimates</div>
          <div style="font-size:0.85rem;margin-top:0.5rem;">Uses Benjamin Graham's original 1974 revised formula</div>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Screener Panel -->
<div class="calc-panel" id="panel-screener">
  <div class="screener-section">
    <h2>S&P 500 Intrinsic Value Screener</h2>
    <p class="sub">168 stocks with AI-computed DCF valuations. Click any ticker for a detailed analysis.</p>
    <div class="screener-controls">
      <div class="screener-filter active" onclick="filterScreener('all',this)">All (168)</div>
      <div class="screener-filter" onclick="filterScreener('under',this)" style="color:var(--positive)">Undervalued</div>
      <div class="screener-filter" onclick="filterScreener('over',this)" style="color:var(--negative)">Overvalued</div>
      <input type="text" class="screener-search" id="screener-search" placeholder="Search ticker or company...">
    </div>
    <div class="screener-table-wrap">
      <table class="screener" id="screener-table">
        <thead>
          <tr>
            <th onclick="sortScreener('t')">Ticker ↕</th>
            <th onclick="sortScreener('n')">Company ↕</th>
            <th onclick="sortScreener('p')">Price ↕</th>
            <th onclick="sortScreener('iv')">Intrinsic Value ↕</th>
            <th onclick="sortScreener('mos')">Margin ↕</th>
            <th onclick="sortScreener('v')">Verdict ↕</th>
            <th>Action</th>
          </tr>
        </thead>
        <tbody id="screener-body"></tbody>
      </table>
    </div>
  </div>
</div>

<!-- Key Insights -->
<div class="insights-grid">
  <div class="insight-card">
    <div class="ic-num">76%</div>
    <div class="ic-title">Are Overvalued</div>
    <div class="ic-desc">76% of analyzed S&P 500 stocks trade above their DCF intrinsic value, suggesting stretched valuations across the index.</div>
  </div>
  <div class="insight-card">
    <div class="ic-num">38.4%</div>
    <div class="ic-title">Average Margin of Safety</div>
    <div class="ic-desc">The 39 undervalued stocks offer an average 38.4% margin of safety — well above Graham's recommended 33% threshold.</div>
  </div>
  <div class="insight-card">
    <div class="ic-num">$0</div>
    <div class="ic-title">Cost to Use</div>
    <div class="ic-desc">AlphaSpread charges $25/mo. Our calculator is permanently free with pre-loaded data for 168 S&P 500 companies.</div>
  </div>
  <div class="insight-card">
    <div class="ic-num">2</div>
    <div class="ic-title">Valuation Models</div>
    <div class="ic-desc">DCF (Discounted Cash Flow) for cash-flow-rich companies and Graham Number for conservative value investors. Both free, no signup.</div>
  </div>
</div>

<!-- How to Calculate Section -->
<div class="how-section">
  <h2>How to Calculate the Intrinsic Value of a Stock</h2>
  <div class="how-steps">
    <div class="how-step">
      <div class="how-step-num">1</div>
      <div class="how-step-content">
        <h4>Find the Free Cash Flow</h4>
        <p>Start with the company's annual Free Cash Flow (FCF) from their latest 10-K filing. FCF = Operating Cash Flow minus Capital Expenditures. This represents the actual cash the business generates after maintaining its operations.</p>
      </div>
    </div>
    <div class="how-step">
      <div class="how-step-num">2</div>
      <div class="how-step-content">
        <h4>Estimate Future Growth</h4>
        <p>Project how fast FCF will grow over the next 5-10 years. Look at historical growth rates, industry trends, and analyst estimates. Be conservative — overestimating growth is the #1 source of valuation errors.</p>
      </div>
    </div>
    <div class="how-step">
      <div class="how-step-num">3</div>
      <div class="how-step-content">
        <h4>Choose a Discount Rate</h4>
        <p>The discount rate (WACC) represents your required rate of return. Higher risk companies deserve higher discount rates (10-15%). Blue chips can use lower rates (7-10%). Warren Buffett often uses the 10-year Treasury yield as a minimum.</p>
      </div>
    </div>
    <div class="how-step">
      <div class="how-step-num">4</div>
      <div class="how-step-content">
        <h4>Calculate Terminal Value</h4>
        <p>After your projection period, the company doesn't stop existing. The terminal value captures all cash flows beyond year 10 using a perpetuity growth model (typically 2-3% matching long-term GDP growth).</p>
      </div>
    </div>
    <div class="how-step">
      <div class="how-step-num">5</div>
      <div class="how-step-content">
        <h4>Apply a Margin of Safety</h4>
        <p>Never pay full intrinsic value. Benjamin Graham recommended at least 33% margin of safety. Warren Buffett looks for 25-50%. This protects you from errors in your assumptions and unforeseen events. If IV = $100, only buy below $67-75.</p>
      </div>
    </div>
  </div>
</div>

