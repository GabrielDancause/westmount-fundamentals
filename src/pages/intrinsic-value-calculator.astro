/* Ticker search dropdown */
function setupTickerSearch(inputId, dropdownId, onSelect) {
  var input = document.getElementById(inputId);
  var dropdown = document.getElementById(dropdownId);
  if (!input || !dropdown) return;
  input.addEventListener('input', function() {
    var q = this.value.toUpperCase().trim();
    if (q.length < 1) { dropdown.classList.remove('show'); return; }
    var matches = [];
    var tickers = Object.keys(IV_DATA);
    for (var i = 0; i < tickers.length; i++) {
      var t = tickers[i];
      var d = IV_DATA[t];
      if (t.indexOf(q) === 0 || d.n.toUpperCase().indexOf(q) !== -1) {
        matches.push(t);
        if (matches.length >= 8) break;
      }
    }
    if (matches.length === 0) { dropdown.classList.remove('show'); return; }
    var html = '';
    for (var i = 0; i < matches.length; i++) {
      var m = matches[i];
      html += '<div class="ticker-option" data-ticker="' + m + '"><span class="to-ticker">' + m + '</span><span class="to-name">' + IV_DATA[m].n + '</span></div>';
    }
    dropdown.innerHTML = html;
    dropdown.classList.add('show');
    var opts = dropdown.querySelectorAll('.ticker-option');
    for (var i = 0; i < opts.length; i++) {
      opts[i].addEventListener('click', function() {
        var ticker = this.getAttribute('data-ticker');
        input.value = ticker;
        dropdown.classList.remove('show');
        onSelect(ticker);
      });
    }
  });
  input.addEventListener('keydown', function(e) {
    if (e.key === 'Enter') {
      var q = this.value.toUpperCase().trim();
      if (IV_DATA[q]) { dropdown.classList.remove('show'); onSelect(q); }
    }
  });
  document.addEventListener('click', function(e) {
    if (!input.contains(e.target) && !dropdown.contains(e.target)) dropdown.classList.remove('show');
  });
}

function loadTickerDCF(ticker) {
  var d = IV_DATA[ticker];
  if (!d) return;
  document.getElementById('dcf-growth').value = (d.fg * 100).toFixed(1);
  document.getElementById('dcf-discount').value = (d.dr * 100).toFixed(1);
  document.getElementById('dcf-terminal').value = (d.tg * 100).toFixed(1);
  document.getElementById('dcf-price').value = d.p;
  calculateDCF();
}

/* DCF Calculation */
function calculateDCF() {
  var fcf = parseFloat(document.getElementById('dcf-fcf').value);
  var shares = parseFloat(document.getElementById('dcf-shares').value);
  var growth = parseFloat(document.getElementById('dcf-growth').value) / 100;
  var terminal = parseFloat(document.getElementById('dcf-terminal').value) / 100;
  var discount = parseFloat(document.getElementById('dcf-discount').value) / 100;
  var price = parseFloat(document.getElementById('dcf-price').value);
  var years = parseInt(document.getElementById('dcf-years').value);

  /* If no FCF/shares but we have ticker data, use pre-loaded IV directly */
  var ticker = document.getElementById('dcf-ticker').value.toUpperCase().trim();
  var usingPreloaded = false;
  var iv = 0;

  if ((!fcf || !shares) && IV_DATA[ticker]) {
    iv = IV_DATA[ticker].iv;
    price = price || IV_DATA[ticker].p;
    usingPreloaded = true;
  } else if (fcf && shares && discount > terminal) {
    var projectedFCFs = [];
    var pvTotal = 0;
    for (var y = 1; y <= years; y++) {
      var futureFCF = fcf * Math.pow(1 + growth, y);
      var pv = futureFCF / Math.pow(1 + discount, y);
      pvTotal += pv;
      projectedFCFs.push({year: y, fcf: futureFCF, pv: pv});
    }
    var terminalFCF = fcf * Math.pow(1 + growth, years) * (1 + terminal);
    var terminalValue = terminalFCF / (discount - terminal);
    var pvTerminal = terminalValue / Math.pow(1 + discount, years);
    var totalValue = pvTotal + pvTerminal;
    iv = totalValue / shares;

    /* Render projection chart */
    renderProjectionChart(projectedFCFs, pvTerminal);
  } else {
    document.getElementById('dcf-result').innerHTML = '<div style="text-align:center;color:var(--negative);"><div style="font-size:2rem;">⚠️</div><div>Enter FCF & shares, or select a pre-loaded ticker</div><div style="font-size:0.85rem;color:var(--text-muted);margin-top:0.5rem;">Discount rate must exceed terminal growth rate</div></div>';
    return;
  }

  if (!price || iv <= 0) {
    document.getElementById('dcf-result').innerHTML = '<div style="text-align:center;color:var(--text-muted);">Enter current stock price to see verdict</div>';
    return;
  }

  var mos = ((iv - price) / iv * 100);
  var verdict = mos > 10 ? 'UNDERVALUED' : (mos < -10 ? 'OVERVALUED' : 'FAIR VALUE');
  var verdictClass = verdict === 'UNDERVALUED' ? 'verdict-undervalued' : (verdict === 'OVERVALUED' ? 'verdict-overvalued' : 'verdict-fair');
  var gaugePos = Math.max(0, Math.min(100, 50 - (mos / 2)));

  var html = '<div class="result-verdict">';
  html += '<div class="iv-label">Intrinsic Value Per Share</div>';
  html += '<div class="iv-value">$' + iv.toFixed(2) + '</div>';
  html += '<div class="verdict-badge ' + verdictClass + '">' + verdict + '</div>';
  html += '</div>';
  html += '<div class="gauge-container"><div class="gauge-bar"><div class="gauge-marker" style="left:' + gaugePos + '%"></div></div>';
  html += '<div class="gauge-labels"><span>Undervalued</span><span>Fair Value</span><span>Overvalued</span></div></div>';
  html += '<div class="result-details">';
  html += '<div class="result-row"><span class="rl">Current Price</span><span class="rv">$' + price.toFixed(2) + '</span></div>';
  html += '<div class="result-row"><span class="rl">Intrinsic Value</span><span class="rv">$' + iv.toFixed(2) + '</span></div>';
  html += '<div class="result-row"><span class="rl">Margin of Safety</span><span class="rv" style="color:' + (mos > 0 ? 'var(--positive)' : 'var(--negative)') + '">' + mos.toFixed(1) + '%</span></div>';
  if (usingPreloaded) {
    html += '<div class="result-row"><span class="rl">Growth Rate</span><span class="rv">' + (growth * 100).toFixed(1) + '%</span></div>';
    html += '<div class="result-row"><span class="rl">Discount Rate</span><span class="rv">' + (discount * 100).toFixed(1) + '%</span></div>';
    var link = IV_DATA[ticker] ? ticker.toLowerCase() : '';
    html += '<div style="margin-top:0.8rem;text-align:center;"><a href="/intrinsic-value-sp500/" style="color:var(--accent);text-decoration:none;font-size:0.85rem;">View full DCF breakdown →</a></div>';
  }
  html += '</div>';
  document.getElementById('dcf-result').innerHTML = html;

  /* Render sensitivity analysis */
  renderSensitivityChart(growth, discount, terminal, iv, fcf, shares, years, usingPreloaded, ticker);
}

function renderSensitivityChart(baseGrowth, baseDiscount, terminal, baseIV, fcf, shares, years, preloaded, ticker) {
  var wrap = document.getElementById('dcf-sensitivity-wrap');
  wrap.style.display = 'block';
  var ctx = document.getElementById('dcf-sensitivity-chart').getContext('2d');
  if (sensitivityChart) sensitivityChart.destroy();

  var growthRates = [];
  var base = baseGrowth * 100;
  for (var i = -4; i <= 4; i++) growthRates.push(Math.max(0, base + i * 2));

  var discountScenarios = [baseDiscount - 0.02, baseDiscount, baseDiscount + 0.02];
  var datasets = [];
  var colors = ['#10b981', '#4a8fe7', '#ef4444'];
  var labels = ['Low WACC (' + ((baseDiscount - 0.02) * 100).toFixed(0) + '%)', 'Base WACC (' + (baseDiscount * 100).toFixed(0) + '%)', 'High WACC (' + ((baseDiscount + 0.02) * 100).toFixed(0) + '%)'];

  for (var s = 0; s < discountScenarios.length; s++) {
    var dr = discountScenarios[s];
    var values = [];
    for (var g = 0; g < growthRates.length; g++) {
      var gr = growthRates[g] / 100;
      if (preloaded) {
        /* Rough scaling from base IV */
        var ratio = (1 + gr) / (1 + baseGrowth);
        var drRatio = baseDiscount / dr;
        values.push(baseIV * ratio * drRatio);
      } else if (fcf && shares && dr > terminal) {
        var pv = 0;
        for (var y = 1; y <= years; y++) {
          pv += fcf * Math.pow(1 + gr, y) / Math.pow(1 + dr, y);
        }
        var tv = fcf * Math.pow(1 + gr, years) * (1 + terminal) / (dr - terminal) / Math.pow(1 + dr, years);
        values.push((pv + tv) / shares);
      } else {
        values.push(0);
      }
    }
    datasets.push({
      label: labels[s],
      data: values,
      borderColor: colors[s],
      backgroundColor: colors[s] + '20',
      borderWidth: 2,
      fill: s === 1,
      tension: 0.3,
      pointRadius: 3
    });
  }

  sensitivityChart = new Chart(ctx, {
    type: 'line',
    data: { labels: growthRates.map(function(r) { return r.toFixed(0) + '%'; }), datasets: datasets },
    options: {
      responsive: true,
      plugins: { legend: { labels: { color: '#8b949e' } } },
      scales: {
        x: { title: { display: true, text: 'FCF Growth Rate', color: '#8b949e' }, ticks: { color: '#8b949e' }, grid: { color: '#30363d' } },
        y: { title: { display: true, text: 'Intrinsic Value ($)', color: '#8b949e' }, ticks: { color: '#8b949e', callback: function(v) { return '$' + v.toFixed(0); } }, grid: { color: '#30363d' } }
      }
    }
  });
}

function renderProjectionChart(projectedFCFs, pvTerminal) {
  var wrap = document.getElementById('dcf-projection-wrap');
  wrap.style.display = 'block';
  var ctx = document.getElementById('dcf-projection-chart').getContext('2d');
  if (projectionChart) projectionChart.destroy();

  var labels = projectedFCFs.map(function(f) { return 'Year ' + f.year; });
  labels.push('Terminal');
  var fcfValues = projectedFCFs.map(function(f) { return f.fcf; });
  fcfValues.push(0);
  var pvValues = projectedFCFs.map(function(f) { return f.pv; });
  pvValues.push(pvTerminal);

  projectionChart = new Chart(ctx, {
    type: 'bar',
    data: {
      labels: labels,
      datasets: [
        { label: 'Projected FCF ($M)', data: fcfValues, backgroundColor: '#4a8fe7', borderRadius: 4 },
        { label: 'Present Value ($M)', data: pvValues, backgroundColor: '#10b981', borderRadius: 4 }
      ]
    },
    options: {
      responsive: true,
      plugins: { legend: { labels: { color: '#8b949e' } } },
      scales: {
        x: { ticks: { color: '#8b949e' }, grid: { color: '#30363d' } },
        y: { ticks: { color: '#8b949e', callback: function(v) { return '$' + (v/1000).toFixed(0) + 'B'; } }, grid: { color: '#30363d' } }
      }
    }
  });
}

/* Graham Calculation */
function calculateGraham() {
  var eps = parseFloat(document.getElementById('graham-eps').value);
  var growth = parseFloat(document.getElementById('graham-growth').value);
  var bondYield = parseFloat(document.getElementById('graham-yield').value);
  var price = parseFloat(document.getElementById('graham-price').value);
  var bvps = parseFloat(document.getElementById('graham-bvps').value);

  if (!eps || eps <= 0) {
    document.getElementById('graham-result').innerHTML = '<div style="text-align:center;color:var(--negative);">Enter a positive EPS value</div>';
    return;
  }

  var html = '<div class="result-verdict">';

  /* Graham Intrinsic Value Formula */
  if (growth && bondYield) {
    var grahamIV = eps * (8.5 + 2 * growth) * 4.4 / bondYield;
    var mos = price ? ((grahamIV - price) / grahamIV * 100) : 0;
    var verdict = mos > 10 ? 'UNDERVALUED' : (mos < -10 ? 'OVERVALUED' : 'FAIR VALUE');
    var verdictClass = verdict === 'UNDERVALUED' ? 'verdict-undervalued' : (verdict === 'OVERVALUED' ? 'verdict-overvalued' : 'verdict-fair');

    html += '<div class="iv-label">Graham Intrinsic Value</div>';
    html += '<div class="iv-value">$' + grahamIV.toFixed(2) + '</div>';
    if (price) {
      html += '<div class="verdict-badge ' + verdictClass + '">' + verdict + '</div>';
    }
    html += '</div>';

    if (price) {
      var gaugePos = Math.max(0, Math.min(100, 50 - (mos / 2)));
      html += '<div class="gauge-container"><div class="gauge-bar"><div class="gauge-marker" style="left:' + gaugePos + '%"></div></div>';
      html += '<div class="gauge-labels"><span>Undervalued</span><span>Fair Value</span><span>Overvalued</span></div></div>';
    }

    html += '<div class="result-details">';
    if (price) {
      html += '<div class="result-row"><span class="rl">Current Price</span><span class="rv">$' + price.toFixed(2) + '</span></div>';
      html += '<div class="result-row"><span class="rl">Graham IV</span><span class="rv">$' + grahamIV.toFixed(2) + '</span></div>';
      html += '<div class="result-row"><span class="rl">Margin of Safety</span><span class="rv" style="color:' + (mos > 0 ? 'var(--positive)' : 'var(--negative)') + '">' + mos.toFixed(1) + '%</span></div>';
    }
    html += '<div class="result-row"><span class="rl">No-Growth Value</span><span class="rv">$' + (eps * 8.5 * 4.4 / bondYield).toFixed(2) + '</span></div>';
    html += '<div class="result-row"><span class="rl">Growth Premium</span><span class="rv">$' + (eps * 2 * growth * 4.4 / bondYield).toFixed(2) + '</span></div>';
  }

  /* Graham Number */
  if (bvps && eps > 0) {
    var gn = Math.sqrt(22.5 * eps * bvps);
    html += '<div style="border-top:1px solid var(--border);margin-top:1rem;padding-top:1rem;">';
    html += '<div class="result-row"><span class="rl">Graham Number</span><span class="rv" style="color:var(--accent);font-size:1.2rem;">$' + gn.toFixed(2) + '</span></div>';
    if (price) {
      var gnMos = ((gn - price) / gn * 100);
      html += '<div class="result-row"><span class="rl">GN vs Price</span><span class="rv" style="color:' + (gnMos > 0 ? 'var(--positive)' : 'var(--negative)') + '">' + gnMos.toFixed(1) + '%</span></div>';
    }
    html += '</div>';
  }

  html += '</div>';
  document.getElementById('graham-result').innerHTML = html;
}

/* Screener */
function getScreenerData() {
  var data = [];
  var tickers = Object.keys(IV_DATA);
  for (var i = 0; i < tickers.length; i++) {
    var t = tickers[i];
    var d = IV_DATA[t];
    var mos = d.iv && d.p ? ((d.iv - d.p) / d.iv * 100) : 0;
    var v = mos > 10 ? 'UNDERVALUED' : (mos < -10 ? 'OVERVALUED' : 'FAIR VALUE');
    data.push({t: t, n: d.n, p: d.p, iv: d.iv, mos: mos, v: v});
  }
  return data;
}

function renderScreener() {
  var data = getScreenerData();
  var searchQ = (document.getElementById('screener-search').value || '').toUpperCase();

  /* Filter */
  if (screenerFilter === 'under') data = data.filter(function(d) { return d.v === 'UNDERVALUED'; });
  if (screenerFilter === 'over') data = data.filter(function(d) { return d.v === 'OVERVALUED'; });
  if (searchQ) data = data.filter(function(d) { return d.t.indexOf(searchQ) !== -1 || d.n.toUpperCase().indexOf(searchQ) !== -1; });

  /* Sort */
  data.sort(function(a, b) {
    var av = a[screenerSort.col];
    var bv = b[screenerSort.col];
    if (typeof av === 'string') return screenerSort.dir * av.localeCompare(bv);
    return screenerSort.dir * ((av || 0) - (bv || 0));
  });

  var tbody = document.getElementById('screener-body');
  var html = '';
  for (var i = 0; i < data.length; i++) {
    var d = data[i];
    var mosColor = d.mos > 10 ? 'var(--positive)' : (d.mos < -10 ? 'var(--negative)' : 'var(--warning)');
    var mosWidth = Math.min(100, Math.abs(d.mos));
    var barColor = d.mos > 0 ? 'var(--positive)' : 'var(--negative)';
    var verdictBadge = d.v === 'UNDERVALUED' ? '<span style="color:var(--positive);font-weight:600;">▲ Undervalued</span>' : (d.v === 'OVERVALUED' ? '<span style="color:var(--negative);font-weight:600;">▼ Overvalued</span>' : '<span style="color:var(--warning);font-weight:600;">● Fair Value</span>');
    html += '<tr>';
    html += '<td><strong>' + d.t + '</strong></td>';
    html += '<td>' + d.n + '</td>';
    html += '<td>$' + (d.p ? d.p.toFixed(2) : '—') + '</td>';
    html += '<td>$' + (d.iv ? d.iv.toFixed(2) : '—') + '</td>';
    html += '<td><span style="color:' + mosColor + ';font-weight:600;">' + d.mos.toFixed(1) + '%</span> <span class="mos-bar" style="width:' + mosWidth + 'px;background:' + barColor + '"></span></td>';
    html += '<td>' + verdictBadge + '</td>';
    html += '<td><a href="javascript:void(0)" onclick="loadFromScreener(\'' + d.t + '\')" style="color:var(--accent);text-decoration:none;font-size:0.85rem;">Calculate →</a></td>';
    html += '</tr>';
  }
  tbody.innerHTML = html;
}

function sortScreener(col) {
  if (screenerSort.col === col) screenerSort.dir *= -1;
  else { screenerSort.col = col; screenerSort.dir = col === 'mos' ? -1 : 1; }
  renderScreener();
}

function filterScreener(filter, el) {
  screenerFilter = filter;
  var filters = document.querySelectorAll('.screener-filter');
  for (var i = 0; i < filters.length; i++) filters[i].classList.remove('active');
  el.classList.add('active');
  renderScreener();
}

function loadFromScreener(ticker) {
  switchTab('dcf');
  document.getElementById('dcf-ticker').value = ticker;
  loadTickerDCF(ticker);
  window.scrollTo({top: 0, behavior: 'smooth'});
}

/* FAQ */
function toggleFaq(el) {
  var answer = el.nextElementSibling;
  var arrow = el.querySelector('.faq-arrow');
  answer.classList.toggle('open');
  arrow.classList.toggle('open');
}

/* Init */
document.addEventListener('DOMContentLoaded', function() {
  setupTickerSearch('dcf-ticker', 'dcf-dropdown', loadTickerDCF);
  document.getElementById('screener-search').addEventListener('input', renderScreener);
});
</script>

