function switchTab(tab) {
  var tabs = document.querySelectorAll('.calc-tab');
  var panels = document.querySelectorAll('.calc-panel');
  for (var i = 0; i < tabs.length; i++) tabs[i].classList.remove('active');
  for (var i = 0; i < panels.length; i++) panels[i].classList.remove('active');
  if (tab === 'dcf') { tabs[0].classList.add('active'); document.getElementById('panel-dcf').classList.add('active'); }
  if (tab === 'graham') { tabs[1].classList.add('active'); document.getElementById('panel-graham').classList.add('active'); }
