---
import SiteLayout from "../layouts/SiteLayout.astro";

// --- METADATA ---
export const meta = {
  title: "Intel Corporation (INTC) Intrinsic Value - Gemini's DCF Analysis",
  description: "An independent discounted cash flow (DCF) intrinsic value estimate of Intel Corporation (INTC) compiled entirely by Gemini 3.1.",
  category: "study",
  published: "2026-03-18",
};

// --- DATA & ASSUMPTIONS (FY2025 Actuals) ---
// The prompt requires me to make bold assumptions as Gemini and handle negative FCF.
// FCF Growth (Y1-Y5): 18%. Intel's massive cyclical downturn and fab buildout is peaking. A recovery in client computing and stabilization of the data center business, combined with external foundry wins (IFS), will drive aggressive recovery from a depressed baseline.
// Discount Rate (WACC): 10.5%. Intel carries massive execution risk in its foundry pivot and turnaround strategy. To compensate, a 10.5% discount rate is used, significantly higher than the 4.18% risk-free rate.
// Terminal Growth: 2.5%. Reflects mature semiconductor industry growth, accounting for the cyclical nature of hardware.

const sharesOut = 4995; // in Millions
const currentPrice = 44.61;
// Net Debt = Total Debt - Total Cash = 47109 - 37416 = 9693
const netDebt = 9693; // Total Debt - Cash & ST investments

// Approach for Negative FCF: Normalized FCF over the cycle.
// Intel's FY2025 FCF is genuinely negative (-$4.95B) due to $14.6B in CapEx for its "five nodes in four years" strategy.
// Using a normalized FCF of $7,500M based on a return to historical operating cash flow levels ($15B-$20B) minus normalized maintenance CapEx ($7.5B-$12.5B).
const baseFCF = 7500; // Normalized in Millions

const fcfGrowthRate = 0.18;
const discountRate = 0.105;
const terminalGrowthRate = 0.025;

// --- YEAR 1 TO 5 PROJECTIONS ---
const projections = [];
let prevFCF = baseFCF;

for (let i = 1; i <= 5; i++) {
  const projectedFCF = prevFCF * (1 + fcfGrowthRate);
  const discountFactor = Math.pow(1 + discountRate, i);
  const pvOfFCF = projectedFCF / discountFactor;

  projections.push({
    year: `Year ${i}`,
    fcf: projectedFCF,
    pv: pvOfFCF
  });

  prevFCF = projectedFCF;
}

const sumPvFcf = projections.reduce((sum, p) => sum + p.pv, 0);

// --- TERMINAL VALUE ---
const year5FCF = projections[4].fcf;
const terminalValue = (year5FCF * (1 + terminalGrowthRate)) / (discountRate - terminalGrowthRate);
const pvTerminalValue = terminalValue / Math.pow(1 + discountRate, 5);

// --- INTRINSIC VALUE CALCULATION ---
const enterpriseValue = sumPvFcf + pvTerminalValue;
// Total Equity Value = Enterprise Value - Net Debt
const totalEquityValue = enterpriseValue - netDebt;
const intrinsicValuePerShare = totalEquityValue / sharesOut;

// Value vs Current Price
const marginOfSafety = ((intrinsicValuePerShare - currentPrice) / currentPrice) * 100;
const isUndervalued = intrinsicValuePerShare > currentPrice;

// --- SENSITIVITY MATRIX ---
const sensitivityDiscountRates = [0.095, 0.100, 0.105, 0.110, 0.115];
const sensitivityGrowthRates = [0.015, 0.020, 0.025, 0.030, 0.035];

const sensitivityMatrix = sensitivityGrowthRates.map(g => {
  return {
    growthRate: g,
    values: sensitivityDiscountRates.map(d => {
      // Re-calculate TV and PV with new rates
      const currentTerminalValue = (year5FCF * (1 + g)) / (d - g);
      const currentPvTerminalValue = currentTerminalValue / Math.pow(1 + d, 5);

      // Re-calculate PV of FCFs with new discount rate
      let currentSumPvFcf = 0;
      let tempFcf = baseFCF;
      for (let i = 1; i <= 5; i++) {
        tempFcf = tempFcf * (1 + fcfGrowthRate);
        currentSumPvFcf += tempFcf / Math.pow(1 + d, i);
      }

      const currentEV = currentSumPvFcf + currentPvTerminalValue;
      const currentEquity = currentEV - netDebt;
      const currentIV = currentEquity / sharesOut;

      return currentIV;
    })
  };
});

// Formatting helpers
const formatMoney = (val) => new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD', minimumFractionDigits: 2, maximumFractionDigits: 2 }).format(val);
const formatMillions = (val) => '$' + new Intl.NumberFormat('en-US', { maximumFractionDigits: 0 }).format(val) + 'M';
const formatPercent = (val) => (val * 100).toFixed(1) + '%';

// --- SCHEMA ---
const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Article",
      "headline": meta.title,
      "description": meta.description,
      "author": {
        "@type": "Organization",
        "name": "Gemini 3.1"
      },
      "publisher": {
        "@type": "Organization",
        "name": "Westmount Fundamentals",
        "logo": {
          "@type": "ImageObject",
          "url": "https://westmountfundamentals.com/logo.png"
        }
      },
      "mainEntityOfPage": {
        "@type": "WebPage",
        "@id": "https://westmountfundamentals.com/intel-intrinsic-value"
      }
    },
    {
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "Why did Gemini use a Normalized FCF for Intel instead of the current negative FCF?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Intel is currently undergoing a massive, capital-intensive fab buildout strategy ('five nodes in four years'), resulting in a genuinely negative FY2025 Free Cash Flow of -$4.95B. A standard DCF cannot function on a negative baseline. Therefore, Gemini utilized a 'Normalized FCF' approach over the cycle, estimating a sustainable $7.5B baseline assuming peak CapEx subsides and operating cash flows recover."
          }
        },
        {
          "@type": "Question",
          "name": "What discount rate was used for Intel's DCF?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "A 10.5% discount rate was selected. This heavily penalizes the model for Intel's massive execution risk in its foundry pivot and turnaround strategy, while acknowledging the 4.18% risk-free rate."
          }
        },
        {
          "@type": "Question",
          "name": "What is Intel's Free Cash Flow growth rate?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Gemini projected an 18% FCF growth rate for Years 1-5. This aggressive rate reflects a recovery from a cyclically depressed baseline as client computing stabilizes and external foundry wins (IFS) begin generating returns."
          }
        }
      ]
    }
  ]
};
---
<SiteLayout site="westmount" title={meta.title} description={meta.description} canonical="https://westmountfundamentals.com/intel-intrinsic-value" schema={schema}>
  <div class="page-content">
    <div class="container">

      <div class="gemini-header">
        <div class="gemini-badge">COMPILED BY GEMINI 2.5 PRO</div>
        <h1>Intel Corporation (INTC) Intrinsic Value</h1>
        <p class="subtitle">An independent two-stage DCF analysis of a cyclical semiconductor giant.</p>
      </div>

      <div class="verdict-card">
        <div class="verdict-header">
          <h2>Fair Value Estimate</h2>
        </div>
        <div class="verdict-body">
          <div class="verdict-main">
            <span class="iv-value">{formatMoney(intrinsicValuePerShare)}</span>
            <span class="iv-label">per share</span>
          </div>
          <div class="verdict-stats">
            <div class="stat">
              <span class="stat-label">Current Price</span>
              <span class="stat-value">{formatMoney(currentPrice)}</span>
            </div>
            <div class="stat">
              <span class="stat-label">Margin of Safety</span>
              <span class={`stat-value ${isUndervalued ? 'positive' : 'negative'}`}>
                {isUndervalued ? '+' : ''}{marginOfSafety.toFixed(2)}%
              </span>
            </div>
            <div class="stat">
              <span class="stat-label">Verdict</span>
              <span class={`badge ${isUndervalued ? 'positive' : 'negative'}`}>
                {isUndervalued ? 'UNDERVALUED' : 'OVERVALUED'}
              </span>
            </div>
          </div>
        </div>
        <div class="verdict-footer">
          <p>Based on FY2025 actuals. Data via S&P Global (Mar 18, 2026).</p>
        </div>
      </div>

      <section class="content-section">
        <h2>The AI Thesis: Why I'm Normalizing the Baseline</h2>
        <p>Intel is a deeply cyclical company currently in the trough of a massive capital expenditure supercycle. Their "five nodes in four years" strategy and the buildout of Intel Foundry Services (IFS) have completely obliterated Free Cash Flow (FCF), which stood at a deeply negative -$4.95B in FY2025 due to $14.6B in CapEx.</p>
        <p>You cannot run a standard Discounted Cash Flow model on a negative baseline. Standard models would project bankruptcy. <strong>I see a compressed spring.</strong> By normalizing FCF to a sustainable baseline representing a return to historical operating efficiency minus maintenance CapEx, we can value the underlying earnings power of the business once the heavy lifting is complete.</p>
      </section>

      <section class="content-section">
        <h2>My Assumptions & Rationale</h2>

        <div class="assumption-grid">
          <div class="assumption-card">
            <div class="card-title">Normalized Base FCF</div>
            <div class="card-value">{formatMillions(baseFCF)}</div>
            <p><strong>Rationale:</strong> Instead of using the -$4.95B actual, I assumed a $7.5B normalized baseline. This is highly conservative given Intel historically generated $15B-$20B in operating cash flow before the current foundry pivot. Once peak CapEx subsides, this baseline represents the true sustainable cash generation.</p>
          </div>

          <div class="assumption-card">
            <div class="card-title">FCF Growth Rate (Y1-Y5)</div>
            <div class="card-value">{formatPercent(fcfGrowthRate)}</div>
            <p><strong>Rationale:</strong> 18% is aggressive, but mathematically sound when recovering from a cyclical bottom. The AI PC upgrade cycle, stabilization in data center market share losses to AMD, and early external packaging wins for IFS will drive outsized YoY percentage growth as the operating leverage kicks in.</p>
          </div>

          <div class="assumption-card">
            <div class="card-title">Discount Rate (WACC)</div>
            <div class="card-value">{formatPercent(discountRate)}</div>
            <p><strong>Rationale:</strong> A 10.5% discount rate perfectly balances the execution risk. With the 10-year treasury at 4.18%, I applied a massive equity risk premium. Intel carries $47.1B in debt against $37.4B in cash, and a highly uncertain turnaround. This rate heavily penalizes the model for that uncertainty.</p>
          </div>

          <div class="assumption-card">
            <div class="card-title">Terminal Growth Rate</div>
            <div class="card-value">{formatPercent(terminalGrowthRate)}</div>
            <p><strong>Rationale:</strong> 2.5% reflects mature semiconductor cyclicality. While chips are critical infrastructure, Intel's specific terminal growth is constrained by permanent shifts in architecture (ARM) and relentless competition (TSMC/AMD).</p>
          </div>
        </div>
      </section>

      <section class="content-section">
        <h2>Discounted Cash Flow (DCF) Projections</h2>
        <p>Starting with the normalized FY2025 base FCF of {formatMillions(baseFCF)}, the table below outlines the 5-year projection discounted back to Present Value (PV) using the {formatPercent(discountRate)} WACC.</p>

        <div class="table-container">
          <table>
            <thead>
              <tr>
                <th>Period</th>
                <th>Projected FCF</th>
                <th>PV Factor ({formatPercent(discountRate)})</th>
                <th>Present Value</th>
              </tr>
            </thead>
            <tbody>
              {projections.map((p, index) => (
                <tr>
                  <td>{p.year}</td>
                  <td>{formatMillions(p.fcf)}</td>
                  <td>{(1 / Math.pow(1 + discountRate, index + 1)).toFixed(4)}</td>
                  <td>{formatMillions(p.pv)}</td>
                </tr>
              ))}
              <tr class="highlight-row">
                <td colspan="3"><strong>Sum of PV of FCFs (Years 1-5)</strong></td>
                <td><strong>{formatMillions(sumPvFcf)}</strong></td>
              </tr>
            </tbody>
          </table>
        </div>
      </section>

      <section class="content-section">
        <h2>Terminal & Final Valuation Math</h2>
        <p>The Terminal Value accounts for all cash flows from Year 6 into perpetuity, calculated using the Gordon Growth Model.</p>

        <div class="math-card">
          <div class="math-row">
            <span>Year 5 FCF</span>
            <span>{formatMillions(year5FCF)}</span>
          </div>
          <div class="math-row">
            <span>Terminal Value (TV) Calculation</span>
            <span>({formatMillions(year5FCF)} * {1 + terminalGrowthRate}) / ({discountRate} - {terminalGrowthRate})</span>
          </div>
          <div class="math-row">
            <span>Terminal Value</span>
            <span>{formatMillions(terminalValue)}</span>
          </div>
          <div class="math-row highlight">
            <span>PV of Terminal Value</span>
            <span>{formatMillions(pvTerminalValue)}</span>
          </div>
        </div>

        <p style="margin-top: 2rem;">Adding it all together with Net Debt:</p>

        <div class="math-card">
          <div class="math-row">
            <span>Sum of PV of FCFs (Years 1-5)</span>
            <span>{formatMillions(sumPvFcf)}</span>
          </div>
          <div class="math-row">
            <span>+ PV of Terminal Value</span>
            <span>{formatMillions(pvTerminalValue)}</span>
          </div>
          <div class="math-row">
            <span><strong>= Enterprise Value</strong></span>
            <span><strong>{formatMillions(enterpriseValue)}</strong></span>
          </div>
          <div class="math-row">
            <span>- Net Debt (Debt - Cash)</span>
            <span>{formatMillions(netDebt)}</span>
          </div>
          <div class="math-row highlight">
            <span><strong>= Total Equity Value</strong></span>
            <span><strong>{formatMillions(totalEquityValue)}</strong></span>
          </div>
          <div class="math-row">
            <span>÷ Shares Outstanding</span>
            <span>{sharesOut.toLocaleString()}M</span>
          </div>
          <div class="math-row result">
            <span><strong>Intrinsic Value Per Share</strong></span>
            <span><strong>{formatMoney(intrinsicValuePerShare)}</strong></span>
          </div>
        </div>
      </section>

      <section class="content-section">
        <h2>Sensitivity Matrix</h2>
        <p>A single intrinsic value relies on rigid assumptions. The sensitivity matrix below demonstrates how the intrinsic value changes when we adjust the Discount Rate (WACC) and the Terminal Growth Rate.</p>

        <div class="table-container sensitivity-table">
          <table>
            <thead>
              <tr>
                <th rowspan="2" class="corner-cell">Terminal<br/>Growth</th>
                <th colspan="5" class="header-cell">Discount Rate (WACC)</th>
              </tr>
              <tr>
                {sensitivityDiscountRates.map(d => <th>{formatPercent(d)}</th>)}
              </tr>
            </thead>
            <tbody>
              {sensitivityMatrix.map(row => (
                <tr>
                  <th class="row-header">{formatPercent(row.growthRate)}</th>
                  {row.values.map(val => (
                    <td class={
                      val > currentPrice * 1.15 ? "cell-undervalued" :
                      val < currentPrice * 0.85 ? "cell-overvalued" :
                      "cell-neutral"
                    }>
                      {formatMoney(val)}
                    </td>
                  ))}
                </tr>
              ))}
            </tbody>
          </table>
          <div class="matrix-legend">
            <span class="legend-item"><span class="color-box cell-undervalued"></span> Undervalued (>15% Margin)</span>
            <span class="legend-item"><span class="color-box cell-neutral"></span> Fair Value</span>
            <span class="legend-item"><span class="color-box cell-overvalued"></span> Overvalued (&lt;-15% Margin)</span>
          </div>
        </div>
      </section>

      <section class="content-section">
        <h2>Historical FCF Context (The Normalization Gap)</h2>
        <p>To understand why the negative -$4.95B FCF baseline is misleading, look at the historical data. Between 2022 and 2025, operating cash flow collapsed from $15.4B to $9.6B, while Capital Expenditure surged to a peak of $25B in 2023. This created a massive, structural negative FCF. However, as CapEx recedes ($14.6B in 2025) and operating leverage returns, the gap will slam shut, violently returning the company to positive cash generation.</p>

        <div class="bar-chart-container">
          <div class="bar-chart">
            <div class="bar-group">
              <div class="bar negative" style="height: 40%;"><span class="bar-label">-$9.4B</span></div>
              <div class="bar-year">2022</div>
            </div>
            <div class="bar-group">
              <div class="bar negative" style="height: 60%;"><span class="bar-label">-$14.2B</span></div>
              <div class="bar-year">2023</div>
            </div>
            <div class="bar-group">
              <div class="bar negative" style="height: 65%;"><span class="bar-label">-$15.6B</span></div>
              <div class="bar-year">2024</div>
            </div>
            <div class="bar-group">
              <div class="bar highlight" style="height: 20%;"><span class="bar-label">-$4.9B</span></div>
              <div class="bar-year">2025</div>
            </div>
            <div class="bar-group">
              <div class="bar positive" style="height: 35%;"><span class="bar-label">+$7.5B</span></div>
              <div class="bar-year">Norm</div>
            </div>
          </div>
        </div>
      </section>

      <section class="content-section risks-section">
        <h2>Risks & Bear Case</h2>
        <p>While my valuation attempts to price in execution risk through the WACC, a balanced analysis requires identifying the key vectors that could disrupt these assumptions entirely:</p>
        <div class="risk-grid">
          <div class="risk-card">
            <h3>1. The IFS Pivot Fails</h3>
            <p>If Intel Foundry Services fails to attract meaningful third-party fabless customers (like Nvidia, AMD, or Apple) beyond test chips, the massive CapEx investments of the last four years will have generated an insurmountable ROIC drag.</p>
          </div>
          <div class="risk-card">
            <h3>2. Geopolitical Subsidy Rollbacks</h3>
            <p>Intel's turnaround strategy heavily relies on CHIPS Act funding and European subsidies. Any political shifts that delay or reduce these capital injections could strain the balance sheet and force debt restructuring before the turnaround completes.</p>
          </div>
          <div class="risk-card">
            <h3>3. Perpetual Margin Compression</h3>
            <p>If TSMC maintains its node superiority and AMD continues to erode Data Center share, Intel may be forced into perpetual price cuts to maintain volume. In this scenario, operating cash flow will never return to the $15B+ levels required to justify the normalized baseline.</p>
          </div>
        </div>
      </section>

      <section class="content-section faq-section">
        <h2>Frequently Asked Questions</h2>

        <div class="faq-item">
          <h3>Why did Gemini use a Normalized FCF for Intel instead of the current negative FCF?</h3>
          <p>Intel is currently undergoing a massive, capital-intensive fab buildout strategy ("five nodes in four years"), resulting in a genuinely negative FY2025 Free Cash Flow of -$4.95B. A standard DCF cannot function on a negative baseline. Therefore, Gemini utilized a "Normalized FCF" approach over the cycle, estimating a sustainable $7.5B baseline assuming peak CapEx subsides and operating cash flows recover.</p>
        </div>

        <div class="faq-item">
          <h3>What discount rate was used for Intel's DCF?</h3>
          <p>A 10.5% discount rate was selected. This heavily penalizes the model for Intel's massive execution risk in its foundry pivot and turnaround strategy, while acknowledging the 4.18% risk-free rate.</p>
        </div>

        <div class="faq-item">
          <h3>What is Intel's Free Cash Flow growth rate?</h3>
          <p>Gemini projected an 18% FCF growth rate for Years 1-5. This aggressive rate reflects a recovery from a cyclically depressed baseline as client computing stabilizes and external foundry wins (IFS) begin generating returns.</p>
        </div>
      </section>

      <div class="disclaimer-box">
        <p><strong>Disclaimer:</strong> The numbers presented on this page are for educational and entertainment purposes only. They are the result of a deterministic mathematical model fed with assumptions generated by an Artificial Intelligence (Gemini 3.1). This does not constitute investment advice. Always conduct your own due diligence before investing in the stock market.</p>
      </div>

    </div>
  </div>
</SiteLayout>
