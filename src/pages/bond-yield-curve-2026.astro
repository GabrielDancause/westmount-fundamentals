  <script is:inline>
// Native Canvas Chart implementation
        window.addEventListener('DOMContentLoaded', () => {
            const canvas = document.getElementById('yieldChart');
            const ctx = canvas.getContext('2d');

            // Data injected from build
            const terms = ["1 Mo","2 Mo","3 Mo","4 Mo","6 Mo","1 Yr","2 Yr","3 Yr","5 Yr","7 Yr","10 Yr","20 Yr","30 Yr"];
            const datasetNow = [3.72,3.75,3.67,3.69,3.61,3.48,3.52,3.6,3.79,4.01,4.26,4.82,4.87];
            const dataset1y = [4.37,4.37,4.31,4.33,4.28,4.17,4.22,4.27,4.36,4.47,4.58,4.88,4.83];
            const dataset2y = [5.53,5.46,5.42,5.4,5.18,4.73,4.27,4.05,3.91,3.95,3.99,4.34,4.22];

            function resize() {
                const parent = canvas.parentElement;
                canvas.width = parent.clientWidth;
                canvas.height = parent.clientHeight;
                drawChart();
            }

            window.addEventListener('resize', resize);

            function drawChart() {
                ctx.clearRect(0, 0, canvas.width, canvas.height);

                const padding = { top: 20, right: 20, bottom: 40, left: 40 };
                const width = canvas.width - padding.left - padding.right;
                const height = canvas.height - padding.top - padding.bottom;

                // Find min and max
                let allVals = [...datasetNow, ...dataset1y, ...dataset2y].filter(v => v !== null);
                let maxVal = Math.max(...allVals) + 0.5;
                let minVal = Math.max(0, Math.min(...allVals) - 0.5); // ensure >= 0 unless actual negative

                // Draw grid lines and Y axis labels
                ctx.strokeStyle = '#152040';
                ctx.fillStyle = '#a0a8b8';
                ctx.font = '12px "JetBrains Mono"';
                ctx.textAlign = 'right';
                ctx.textBaseline = 'middle';

                const ySteps = 5;
                for(let i=0; i<=ySteps; i++) {
                    const val = minVal + (maxVal - minVal) * (i / ySteps);
                    const y = canvas.height - padding.bottom - (height * (i / ySteps));

                    ctx.beginPath();
                    ctx.moveTo(padding.left, y);
                    ctx.lineTo(canvas.width - padding.right, y);
                    ctx.stroke();

                    ctx.fillText(val.toFixed(1) + '%', padding.left - 5, y);
                }

                // Draw X axis labels
                ctx.textAlign = 'center';
                ctx.textBaseline = 'top';
                for(let i=0; i<terms.length; i++) {
                    const x = padding.left + (width * (i / (terms.length - 1)));

                    // only show some labels on mobile to prevent overlap
                    if (window.innerWidth < 600 && i % 2 !== 0 && i !== terms.length -1) continue;

                    ctx.fillText(terms[i], x, canvas.height - padding.bottom + 10);
                }

                // Draw lines
                function drawLine(dataset, color, fillAlpha) {
                    ctx.beginPath();
                    let started = false;
                    for(let i=0; i<terms.length; i++) {
                        if (dataset[i] === null) continue;

                        const x = padding.left + (width * (i / (terms.length - 1)));
                        const y = canvas.height - padding.bottom - (height * ((dataset[i] - minVal) / (maxVal - minVal)));

                        if (!started) {
                            ctx.moveTo(x, y);
                            started = true;
                        } else {
                            ctx.lineTo(x, y);
                        }
                    }

                    ctx.strokeStyle = color;
                    ctx.lineWidth = 3;
                    ctx.lineJoin = 'round';
                    ctx.stroke();

                    // Optional fill (like area chart)
                    if (fillAlpha && started) {
                        ctx.lineTo(canvas.width - padding.right, canvas.height - padding.bottom);
                        ctx.lineTo(padding.left, canvas.height - padding.bottom);
                        ctx.fillStyle = color.replace('rgb', 'rgba').replace(')', `, ${fillAlpha})`);
                        ctx.fill();
                    }
                }

                drawLine(dataset2y, 'rgb(46, 204, 113)', 0.0);
                drawLine(dataset1y, 'rgb(231, 76, 60)', 0.0);
                drawLine(datasetNow, 'rgb(74, 143, 231)', 0.1);
            }

            // Initial draw
            resize();
        });
  </script>

  
