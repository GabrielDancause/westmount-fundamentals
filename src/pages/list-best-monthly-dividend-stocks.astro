      margin: 16px auto 0;
      font-size: 0.75rem;
      color: #4a5568;
    }

    @media (max-width: 768px) {
      .charts-grid { grid-template-columns: 1fr; }
      h1 { font-size: 2.2rem; }
      .nav-links { display: none; }
      .content-section { padding: 24px; }
      td, th { padding: 12px 8px; }
    }
  </style>

<div class="container">

