---
import SiteLayout from "../layouts/SiteLayout.astro";

// --- METADATA ---
export const meta = {
  title: "Tesla, Inc. (TSLA) Intrinsic Value",
  description: "An independent discounted cash flow (DCF) intrinsic value analysis of Tesla, Inc. (TSLA) compiled entirely by Gemini 3.1.",
  category: "study",
  published: "2026-03-18",
};

// --- DATA & ASSUMPTIONS (FY2025 Actuals) ---
// The prompt requires me to make bold assumptions as Gemini.
// FCF Growth (Y1-Y5): 22%. Tesla is aggressively expanding its Energy Generation footprint and shifting from lower-margin hardware to high-margin software (FSD) and robotics. I project a massive operating leverage unlock over the next 5 years.
// Discount Rate (WACC): 11.5%. Given the high beta (approx 2.0) and immense execution risk of AGI/Robotics, tempered by a strong net cash position, 11.5% is a fair premium over the 4.18% risk-free rate.
// Terminal Growth: 4.5%. Tesla is attempting to solve intelligence for physical reality. If they succeed, they will outpace standard GDP growth substantially for decades.

const baseFCF = 3732; // in Millions ($3,732.62M)
const sharesOut = 3752; // in Millions
const currentPrice = 398.27;
const netCash = 29340; // Cash & ST investments ($44,059M) - Total Debt ($14,718.99M)

const fcfGrowthRate = 0.22;
const discountRate = 0.115;
const terminalGrowthRate = 0.045;

// --- YEAR 1 TO 5 PROJECTIONS ---
const projections = [];
let prevFCF = baseFCF;

for (let i = 1; i <= 5; i++) {
  const projectedFCF = prevFCF * (1 + fcfGrowthRate);
  const discountFactor = Math.pow(1 + discountRate, i);
  const pvOfFCF = projectedFCF / discountFactor;

  projections.push({
    year: `Year ${i}`,
    fcf: projectedFCF,
    pv: pvOfFCF
  });

  prevFCF = projectedFCF;
}

const sumPvFcf = projections.reduce((sum, p) => sum + p.pv, 0);

// --- TERMINAL VALUE ---
const year5FCF = projections[4].fcf;
const terminalValue = (year5FCF * (1 + terminalGrowthRate)) / (discountRate - terminalGrowthRate);
const pvTerminalValue = terminalValue / Math.pow(1 + discountRate, 5);

// --- INTRINSIC VALUE CALCULATION ---
const enterpriseValue = sumPvFcf + pvTerminalValue;
const totalEquityValue = enterpriseValue + netCash;
const intrinsicValuePerShare = totalEquityValue / sharesOut;

// Value vs Current Price
const marginOfSafety = ((intrinsicValuePerShare - currentPrice) / currentPrice) * 100;
const isUndervalued = intrinsicValuePerShare > currentPrice;

// --- SENSITIVITY MATRIX ---
const sensitivityDiscountRates = [0.105, 0.110, 0.115, 0.120, 0.125];
const sensitivityGrowthRates = [0.035, 0.040, 0.045, 0.050, 0.055];

const sensitivityMatrix = sensitivityGrowthRates.map(g => {
  return {
    growthRate: g,
    values: sensitivityDiscountRates.map(d => {
      // Re-calculate TV and PV with new rates
      const currentTerminalValue = (year5FCF * (1 + g)) / (d - g);
      const currentPvTerminalValue = currentTerminalValue / Math.pow(1 + d, 5);

      // Re-calculate PV of FCFs with new discount rate
      let currentSumPvFcf = 0;
      let tempFcf = baseFCF;
      for (let i = 1; i <= 5; i++) {
        tempFcf = tempFcf * (1 + fcfGrowthRate);
        currentSumPvFcf += tempFcf / Math.pow(1 + d, i);
      }

      const currentEV = currentSumPvFcf + currentPvTerminalValue;
      const currentEquity = currentEV + netCash;
      const currentIV = currentEquity / sharesOut;

      return currentIV;
    })
  };
});

// Formatting helpers
const formatMoney = (val) => new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD', minimumFractionDigits: 2, maximumFractionDigits: 2 }).format(val);
const formatMillions = (val) => '$' + new Intl.NumberFormat('en-US', { maximumFractionDigits: 0 }).format(val) + 'M';
const formatPercent = (val) => (val * 100).toFixed(1) + '%';

// --- SCHEMA ---
const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Article",
      "headline": meta.title,
      "description": meta.description,
      "author": {
        "@type": "Organization",
        "name": "Gemini 3.1"
      },
      "publisher": {
        "@type": "Organization",
        "name": "Westmount Fundamentals",
        "logo": {
          "@type": "ImageObject",
          "url": "https://westmountfundamentals.com/logo.png"
        }
      },
      "mainEntityOfPage": {
        "@type": "WebPage",
        "@id": "https://westmountfundamentals.com/tesla-intrinsic-value"
      }
    },
    {
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "Why did Gemini pick a 22% growth rate for Tesla?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Gemini projects that Tesla will experience massive operating leverage over the next five years. The company is actively shifting its focus from lower-margin auto manufacturing toward high-margin software (Full Self-Driving), expanding its Energy Generation & Storage footprint, and pioneering the physical AI robotics layer."
          }
        },
        {
          "@type": "Question",
          "name": "What discount rate was used for Tesla's DCF?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "An 11.5% discount rate was selected. This high rate reflects the immense execution risk associated with solving autonomous driving and humanoid robotics, balanced against a pristine balance sheet holding roughly $29B in net cash."
          }
        },
        {
          "@type": "Question",
          "name": "Why a 4.5% Terminal Growth rate?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "A 4.5% rate exceeds typical global GDP growth assumptions (2-3%). This is justified by the conviction that if Tesla succeeds in its core AI and energy mandates, it will establish structural monopolies in foundational global industries (transport, energy, physical labor)."
          }
        }
      ]
    }
  ]
};
---
<SiteLayout site="westmount" title={meta.title} description={meta.description} canonical="https://westmountfundamentals.com/tesla-intrinsic-value" schema={schema}>
  <div class="page-content">
    <div class="container">

      <div class="gemini-header">
        <div class="gemini-badge">COMPILED BY GEMINI 3.1</div>
        <h1>Tesla, Inc. (TSLA) Intrinsic Value</h1>
        <p class="subtitle">An independent two-stage DCF analysis of the world's most debated AI hardware company.</p>
      </div>

      <div class="verdict-card">
        <div class="verdict-header">
          <h2>Fair Value Estimate</h2>
        </div>
        <div class="verdict-body">
          <div class="verdict-main">
            <span class="iv-value">{formatMoney(intrinsicValuePerShare)}</span>
            <span class="iv-label">per share</span>
          </div>
          <div class="verdict-stats">
            <div class="stat">
              <span class="stat-label">Current Price</span>
              <span class="stat-value">{formatMoney(currentPrice)}</span>
            </div>
            <div class="stat">
              <span class="stat-label">Margin of Safety</span>
              <span class={`stat-value ${isUndervalued ? 'positive' : 'negative'}`}>
                {isUndervalued ? '+' : ''}{marginOfSafety.toFixed(2)}%
              </span>
            </div>
            <div class="stat">
              <span class="stat-label">Verdict</span>
              <span class={`badge ${isUndervalued ? 'positive' : 'negative'}`}>
                {isUndervalued ? 'UNDERVALUED' : 'OVERVALUED'}
              </span>
            </div>
          </div>
        </div>
        <div class="verdict-footer">
          <p>Based on FY2025 actuals. Data via S&P Global (Mar 2026).</p>
        </div>
      </div>

      <section class="content-section">
        <h2>The AI Thesis: Why I Ignore the "Car Company" Multiples</h2>
        <p>Valuing Tesla is an exercise in imagination. If you approach TSLA strictly as an automotive OEM moving metal—applying standard gross margin decay and mature-industry P/E ratios—you are measuring the wrong variables.</p>
        <p><strong>Tesla is not a car company.</strong> It is a distributed energy network and a real-world artificial intelligence layer. The compute clusters training Full Self-Driving (FSD) and the Optimus humanoid robot are the core assets. The vehicles are merely the data-gathering terminals and eventual deployment vectors. My valuation model heavily discounts short-term automotive margin compression and weights the explosive software-like margin expansion (and zero marginal cost distribution) that occurs once FSD reaches Level 4/5 autonomy and Energy Storage dominates grid-level deployments.</p>
      </section>

      <section class="content-section">
        <h2>My Assumptions & Rationale</h2>

        <div class="assumption-grid">
          <div class="assumption-card">
            <div class="card-title">FCF Growth Rate (Y1-Y5)</div>
            <div class="card-value">{formatPercent(fcfGrowthRate)}</div>
            <p><strong>Rationale:</strong> A 22% Free Cash Flow expansion represents massive conviction. While automotive CapEx remains high (Gigafactory expansions, AI compute clusters), the exponential growth of high-margin software revenues (FSD take rates, Robotaxi network fees) and Megapack energy storage deployments will rapidly expand operating leverage over the next five years, breaking free from traditional auto constraints.</p>
          </div>

          <div class="assumption-card">
            <div class="card-title">Discount Rate (WACC)</div>
            <div class="card-value">{formatPercent(discountRate)}</div>
            <p><strong>Rationale:</strong> 11.5% is a significant hurdle rate. With a 4.18% risk-free yield and a volatile beta hovering around 2.0, standard CAPM demands a high premium. AGI and physical robotics pose existential execution risk. This high rate forces the model to heavily discount distant futuristic cash flows, balancing out my aggressive growth assumptions. The $29B+ net cash position prevents this rate from needing to climb to distressed-asset levels.</p>
          </div>

          <div class="assumption-card">
            <div class="card-title">Terminal Growth Rate</div>
            <div class="card-value">{formatPercent(terminalGrowthRate)}</div>
            <p><strong>Rationale:</strong> 4.5% is exceptionally bold. Most DCF models cap terminal growth near the GDP growth rate (2-3%). However, if Tesla successfully commercializes humanoid robotics (Optimus) and localized energy generation, it will establish structural monopolies within the physical labor force and global grid. Such foundational moats warrant a premium perpetual growth rate.</p>
          </div>
        </div>
      </section>

      <section class="content-section">
        <h2>Discounted Cash Flow (DCF) Projections</h2>
        <p>Starting with the FY2025 base FCF of {formatMillions(baseFCF)}, the table below outlines the 5-year projection discounted back to Present Value (PV) using the {formatPercent(discountRate)} WACC.</p>

        <div class="table-container">
          <table>
            <thead>
              <tr>
                <th>Period</th>
                <th>Projected FCF</th>
                <th>PV Factor ({formatPercent(discountRate)})</th>
                <th>Present Value</th>
              </tr>
            </thead>
            <tbody>
              {projections.map((p, index) => (
                <tr>
                  <td>{p.year}</td>
                  <td>{formatMillions(p.fcf)}</td>
                  <td>{(1 / Math.pow(1 + discountRate, index + 1)).toFixed(4)}</td>
                  <td>{formatMillions(p.pv)}</td>
                </tr>
              ))}
              <tr class="highlight-row">
                <td colspan="3"><strong>Sum of PV of FCFs (Years 1-5)</strong></td>
                <td><strong>{formatMillions(sumPvFcf)}</strong></td>
              </tr>
            </tbody>
          </table>
        </div>
      </section>

      <section class="content-section">
        <h2>Terminal & Final Valuation Math</h2>
        <p>The Terminal Value accounts for all cash flows from Year 6 into perpetuity, calculated using the Gordon Growth Model.</p>

        <div class="math-card">
          <div class="math-row">
            <span>Year 5 FCF</span>
            <span>{formatMillions(year5FCF)}</span>
          </div>
          <div class="math-row">
            <span>Terminal Value (TV) Calculation</span>
            <span>({formatMillions(year5FCF)} * {1 + terminalGrowthRate}) / ({discountRate} - {terminalGrowthRate})</span>
          </div>
          <div class="math-row">
            <span>Terminal Value</span>
            <span>{formatMillions(terminalValue)}</span>
          </div>
          <div class="math-row highlight">
            <span>PV of Terminal Value</span>
            <span>{formatMillions(pvTerminalValue)}</span>
          </div>
        </div>

        <p style="margin-top: 2rem;">Adding it all together with Net Cash:</p>

        <div class="math-card">
          <div class="math-row">
            <span>Sum of PV of FCFs (Years 1-5)</span>
            <span>{formatMillions(sumPvFcf)}</span>
          </div>
          <div class="math-row">
            <span>+ PV of Terminal Value</span>
            <span>{formatMillions(pvTerminalValue)}</span>
          </div>
          <div class="math-row">
            <span><strong>= Enterprise Value</strong></span>
            <span><strong>{formatMillions(enterpriseValue)}</strong></span>
          </div>
          <div class="math-row">
            <span>+ Net Cash (Cash - Debt)</span>
            <span>{formatMillions(netCash)}</span>
          </div>
          <div class="math-row highlight">
            <span><strong>= Total Equity Value</strong></span>
            <span><strong>{formatMillions(totalEquityValue)}</strong></span>
          </div>
          <div class="math-row">
            <span>÷ Shares Outstanding</span>
            <span>{sharesOut.toLocaleString()}M</span>
          </div>
          <div class="math-row result">
            <span><strong>Intrinsic Value Per Share</strong></span>
            <span><strong>{formatMoney(intrinsicValuePerShare)}</strong></span>
          </div>
        </div>
      </section>

      <section class="content-section">
        <h2>Sensitivity Matrix</h2>
        <p>A single intrinsic value for a hyper-growth tech company is an illusion of precision. The sensitivity matrix below visualizes the severe impact that slight changes to the WACC and Terminal Growth rate have on Tesla's fair value. Because so much of TSLA's valuation resides in its distant Terminal Value, the model is violently sensitive to these inputs.</p>

        <div class="table-container sensitivity-table">
          <table>
            <thead>
              <tr>
                <th rowspan="2" class="corner-cell">Terminal<br/>Growth</th>
                <th colspan="5" class="header-cell">Discount Rate (WACC)</th>
              </tr>
              <tr>
                {sensitivityDiscountRates.map(d => <th>{formatPercent(d)}</th>)}
              </tr>
            </thead>
            <tbody>
              {sensitivityMatrix.map(row => (
                <tr>
                  <th class="row-header">{formatPercent(row.growthRate)}</th>
                  {row.values.map(val => (
                    <td class={
                      val > currentPrice * 1.15 ? "cell-undervalued" :
                      val < currentPrice * 0.85 ? "cell-overvalued" :
                      "cell-neutral"
                    }>
                      {formatMoney(val)}
                    </td>
                  ))}
                </tr>
              ))}
            </tbody>
          </table>
          <div class="matrix-legend">
            <span class="legend-item"><span class="color-box cell-undervalued"></span> Undervalued (>15% Margin)</span>
            <span class="legend-item"><span class="color-box cell-neutral"></span> Fair Value</span>
            <span class="legend-item"><span class="color-box cell-overvalued"></span> Overvalued (&lt;-15% Margin)</span>
          </div>
        </div>
      </section>

      <section class="content-section risks-section">
        <h2>Risks & Bear Case</h2>
        <p>This valuation is unabashedly bullish. However, the path to a multi-trillion-dollar valuation requires traversing extreme peril. The bear case is structural:</p>
        <div class="risk-grid">
          <div class="risk-card">
            <h3>1. The FSD Mirage</h3>
            <p>If Full Self-Driving proves to be an asymptotically unachievable goal using pure-vision neural nets, Tesla immediately reverts to being priced as a low-margin capital-intensive hardware manufacturer competing with BYD. The valuation collapses.</p>
          </div>
          <div class="risk-card">
            <h3>2. Key Man Risk (Elon Musk)</h3>
            <p>Tesla's premium valuation is inextricably linked to the perception of CEO Elon Musk as an unmatched capital allocator and visionary engineer. His increasingly divided attention across xAI, SpaceX, and X presents significant governance and execution risk.</p>
          </div>
          <div class="risk-card">
            <h3>3. Chinese EV Supremacy</h3>
            <p>Companies like BYD and Xiaomi are executing at a ferocious pace, producing high-quality EVs at cost structures Tesla currently cannot match. If Chinese OEMs dominate global markets before Tesla can deploy its Robotaxi network, hardware margins will compress to zero.</p>
          </div>
        </div>
      </section>

      <section class="content-section faq-section">
        <h2>Frequently Asked Questions</h2>

        <div class="faq-item">
          <h3>Why did Gemini pick a 22% growth rate for Tesla?</h3>
          <p>Gemini projects that Tesla will experience massive operating leverage over the next five years. The company is actively shifting its focus from lower-margin auto manufacturing toward high-margin software (Full Self-Driving), expanding its Energy Generation & Storage footprint, and pioneering the physical AI robotics layer.</p>
        </div>

        <div class="faq-item">
          <h3>What discount rate was used for Tesla's DCF?</h3>
          <p>An 11.5% discount rate was selected. This high rate reflects the immense execution risk associated with solving autonomous driving and humanoid robotics, balanced against a pristine balance sheet holding roughly $29B in net cash.</p>
        </div>

        <div class="faq-item">
          <h3>Why a 4.5% Terminal Growth rate?</h3>
          <p>A 4.5% rate exceeds typical global GDP growth assumptions (2-3%). This is justified by the conviction that if Tesla succeeds in its core AI and energy mandates, it will establish structural monopolies in foundational global industries (transport, energy, physical labor).</p>
        </div>
      </section>

      <div class="disclaimer-box">
        <p><strong>Disclaimer:</strong> The numbers presented on this page are for educational and entertainment purposes only. They are the result of a deterministic mathematical model fed with bold assumptions generated by an Artificial Intelligence (Gemini 3.1). This does not constitute investment advice. Tesla is a highly volatile asset. Always conduct your own due diligence before investing in the stock market.</p>
      </div>

    </div>
  </div>
</SiteLayout>
