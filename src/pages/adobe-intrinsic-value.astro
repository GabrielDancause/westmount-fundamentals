---
import SiteLayout from '../layouts/SiteLayout.astro';

// --- METADATA ---
export const meta = {
  title: "Adobe Inc. (ADBE) Intrinsic Value",
  description: "An independent discounted cash flow (DCF) intrinsic value analysis of Adobe Inc. (ADBE) compiled entirely by Gemini 2.5 Pro.",
  category: "study",
  published: "2026-03-18",
};

// --- DATA & ASSUMPTIONS (FY2025 Actuals) ---
// FCF Growth (Y1-Y5): 11%. Adobe's Firefly and AI integration across Creative Cloud and Document Cloud are massive tailwinds. 11% reflects strong monetization of new AI features while accounting for potential macroeconomic headwinds in enterprise software spending.
// Discount Rate (WACC): 8.5%. With a 10-year Treasury at 4.18%, Adobe's strong competitive moat, high margins, and predictable subscription revenue warrant a relatively low equity risk premium.
// Terminal Growth: 3.5%. Software moats in the AI era are durable. Adobe's entrenched position in creative workflows justifies a terminal growth rate slightly above long-term inflation.

const baseFCF = 10317; // in Millions, FY2025 FCF
const sharesOut = 420; // in Millions, FY2025 Diluted
const currentPrice = 248.75; // As of Mar 18, 2026
const netCash = 234; // Cash & ST investments - Total Debt (FY2025)

const fcfGrowthRate = 0.11;
const discountRate = 0.085;
const terminalGrowthRate = 0.035;

// --- YEAR 1 TO 5 PROJECTIONS ---
const projections = [];
let prevFCF = baseFCF;

for (let i = 1; i <= 5; i++) {
  const projectedFCF = prevFCF * (1 + fcfGrowthRate);
  const discountFactor = Math.pow(1 + discountRate, i);
  const pvOfFCF = projectedFCF / discountFactor;

  projections.push({
    year: `Year ${i}`,
    fcf: projectedFCF,
    pv: pvOfFCF
  });

  prevFCF = projectedFCF;
}

const sumPvFcf = projections.reduce((sum, p) => sum + p.pv, 0);

// --- TERMINAL VALUE ---
const year5FCF = projections[4].fcf;
const terminalValue = (year5FCF * (1 + terminalGrowthRate)) / (discountRate - terminalGrowthRate);
const pvTerminalValue = terminalValue / Math.pow(1 + discountRate, 5);

// --- INTRINSIC VALUE CALCULATION ---
const enterpriseValue = sumPvFcf + pvTerminalValue;
const totalEquityValue = enterpriseValue + netCash;
const intrinsicValuePerShare = totalEquityValue / sharesOut;

// Value vs Current Price
const marginOfSafety = ((intrinsicValuePerShare - currentPrice) / currentPrice) * 100;
const isUndervalued = intrinsicValuePerShare > currentPrice;

// --- SENSITIVITY MATRIX ---
const sensitivityDiscountRates = [0.075, 0.080, 0.085, 0.090, 0.095];
const sensitivityGrowthRates = [0.025, 0.030, 0.035, 0.040, 0.045];

const sensitivityMatrix = sensitivityGrowthRates.map(g => {
  return {
    growthRate: g,
    values: sensitivityDiscountRates.map(d => {
      // Re-calculate TV and PV with new rates
      const currentTerminalValue = (year5FCF * (1 + g)) / (d - g);
      const currentPvTerminalValue = currentTerminalValue / Math.pow(1 + d, 5);

      // Re-calculate PV of FCFs with new discount rate
      let currentSumPvFcf = 0;
      let tempFcf = baseFCF;
      for (let i = 1; i <= 5; i++) {
        tempFcf = tempFcf * (1 + fcfGrowthRate);
        currentSumPvFcf += tempFcf / Math.pow(1 + d, i);
      }

      const currentEV = currentSumPvFcf + currentPvTerminalValue;
      const currentEquity = currentEV + netCash;
      const currentIV = currentEquity / sharesOut;

      return currentIV;
    })
  };
});

// Formatting helpers
const formatMoney = (val) => new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD', minimumFractionDigits: 2, maximumFractionDigits: 2 }).format(val);
const formatMillions = (val) => '$' + new Intl.NumberFormat('en-US', { maximumFractionDigits: 0 }).format(val) + 'M';
const formatPercent = (val) => (val * 100).toFixed(1) + '%';

// --- SCHEMA ---
const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Article",
      "headline": meta.title,
      "description": meta.description,
      "author": {
        "@type": "Organization",
        "name": "Gemini 2.5 Pro"
      },
      "publisher": {
        "@type": "Organization",
        "name": "Westmount Fundamentals",
        "logo": {
          "@type": "ImageObject",
          "url": "https://westmountfundamentals.com/logo.png"
        }
      },
      "mainEntityOfPage": {
        "@type": "WebPage",
        "@id": "https://westmountfundamentals.com/adobe-intrinsic-value"
      }
    },
    {
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "Why did Gemini pick an 11% growth rate for Adobe?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Gemini projects that Adobe's deep integration of generative AI (Firefly) across its Creative Cloud suite will drive sustained pricing power and user expansion, justifying an 11% FCF growth rate over the next 5 years despite its mature market position."
          }
        },
        {
          "@type": "Question",
          "name": "What discount rate was used for Adobe's DCF?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "An 8.5% discount rate was selected. This reflects a 4.18% risk-free rate and a relatively low equity risk premium, acknowledging Adobe's highly predictable subscription revenue model and entrenched economic moat."
          }
        },
        {
          "@type": "Question",
          "name": "What are the main risks to Adobe's valuation?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Key risks include the commoditization of AI generation tools by competitors (like OpenAI or Midjourney), macroeconomic softness reducing enterprise software spending, and regulatory hurdles limiting future strategic acquisitions."
          }
        }
      ]
    }
  ]
};
---
<SiteLayout site="westmount" title={meta.title} description={meta.description} canonical="https://westmountfundamentals.com/adobe-intrinsic-value" schema={schema}>
  <div class="page-content">
    <div class="container">

      <div class="gemini-header">
        <div class="gemini-badge">COMPILED BY GEMINI 2.5 PRO</div>
        <h1>Adobe Inc. (ADBE) Intrinsic Value</h1>
        <p class="subtitle">An independent two-stage DCF analysis by a frontier AI model.</p>
      </div>

      <div class="verdict-card">
        <div class="verdict-header">
          <h2>Fair Value Estimate</h2>
        </div>
        <div class="verdict-body">
          <div class="verdict-main">
            <span class="iv-value">{formatMoney(intrinsicValuePerShare)}</span>
            <span class="iv-label">per share</span>
          </div>
          <div class="verdict-stats">
            <div class="stat">
              <span class="stat-label">Current Price</span>
              <span class="stat-value">{formatMoney(currentPrice)}</span>
            </div>
            <div class="stat">
              <span class="stat-label">Margin of Safety</span>
              <span class={`stat-value ${isUndervalued ? 'positive' : 'negative'}`}>
                {isUndervalued ? '+' : ''}{marginOfSafety.toFixed(2)}%
              </span>
            </div>
            <div class="stat">
              <span class="stat-label">Verdict</span>
              <span class={`badge ${isUndervalued ? 'positive' : 'negative'}`}>
                {isUndervalued ? 'UNDERVALUED' : 'OVERVALUED'}
              </span>
            </div>
          </div>
        </div>
        <div class="verdict-footer">
          <p>Based on FY2025 actuals. Data via S&P Global (Mar 18, 2026).</p>
        </div>
      </div>

      <section class="content-section">
        <h2>The AI Thesis: Monetizing the Creative Core</h2>
        <p>Adobe's transition into the AI era has been intensely scrutinized. Initial fears that generative AI would disrupt its core Creative Cloud suite have given way to a realization: Adobe is successfully integrating these tools (Firefly) directly into professional workflows. This isn't just a defensive move; it's a powerful monetization engine.</p>
        <p>By embedding AI generation into Photoshop, Illustrator, and Premiere, Adobe is increasing the stickiness of its subscriptions and enabling higher pricing tiers. My valuation model relies on this thesis: that Adobe's distribution advantage and entrenched user base will allow it to capture significant value from the AI revolution, translating into robust, high-margin cash flow generation.</p>
      </section>

      <section class="content-section">
        <h2>My Assumptions & Rationale</h2>

        <div class="assumption-grid">
          <div class="assumption-card">
            <div class="card-title">FCF Growth Rate (Y1-Y5)</div>
            <div class="card-value">{formatPercent(fcfGrowthRate)}</div>
            <p><strong>Rationale:</strong> An 11% growth rate is fundamentally sound for Adobe. Its FY2025 FCF of $10.3B demonstrates massive scale. The growth will be driven by continued seat expansion, upselling AI-powered 'generative credits', and operational leverage as R&D investments in AI models begin to scale efficiently.</p>
          </div>

          <div class="assumption-card">
            <div class="card-title">Discount Rate (WACC)</div>
            <div class="card-value">{formatPercent(discountRate)}</div>
            <p><strong>Rationale:</strong> 8.5% is a balanced discount rate. While the 10-year treasury sits at 4.18%, Adobe's revenue is overwhelmingly recurring (subscription-based), which dramatically lowers its risk profile. The company's strong net cash position and dominant market share further justify a lower equity risk premium compared to the broader tech sector.</p>
          </div>

          <div class="assumption-card">
            <div class="card-title">Terminal Growth Rate</div>
            <div class="card-value">{formatPercent(terminalGrowthRate)}</div>
            <p><strong>Rationale:</strong> A 3.5% terminal rate reflects Adobe's enduring moat. Creative workflows are foundational to the digital economy. Even as tools evolve, the need for professional-grade creation, editing, and management of digital assets will persist, allowing Adobe to grow slightly faster than overall GDP into perpetuity.</p>
          </div>
        </div>
      </section>

      <section class="content-section">
        <h2>Discounted Cash Flow (DCF) Projections</h2>
        <p>Starting with the FY2025 base FCF of {formatMillions(baseFCF)}, the table below outlines the 5-year projection discounted back to Present Value (PV) using the {formatPercent(discountRate)} WACC.</p>

        <div class="table-container">
          <table>
            <thead>
              <tr>
                <th>Period</th>
                <th>Projected FCF</th>
                <th>PV Factor ({formatPercent(discountRate)})</th>
                <th>Present Value</th>
              </tr>
            </thead>
            <tbody>
              {projections.map((p, index) => (
                <tr>
                  <td>{p.year}</td>
                  <td>{formatMillions(p.fcf)}</td>
                  <td>{(1 / Math.pow(1 + discountRate, index + 1)).toFixed(4)}</td>
                  <td>{formatMillions(p.pv)}</td>
                </tr>
              ))}
              <tr class="highlight-row">
                <td colspan="3"><strong>Sum of PV of FCFs (Years 1-5)</strong></td>
                <td><strong>{formatMillions(sumPvFcf)}</strong></td>
              </tr>
            </tbody>
          </table>
        </div>
      </section>

      <section class="content-section">
        <h2>Terminal & Final Valuation Math</h2>
        <p>The Terminal Value accounts for all cash flows from Year 6 into perpetuity, calculated using the Gordon Growth Model.</p>

        <div class="math-card">
          <div class="math-row">
            <span>Year 5 FCF</span>
            <span>{formatMillions(year5FCF)}</span>
          </div>
          <div class="math-row">
            <span>Terminal Value (TV) Calculation</span>
            <span>({formatMillions(year5FCF)} * {1 + terminalGrowthRate}) / ({discountRate} - {terminalGrowthRate})</span>
          </div>
          <div class="math-row">
            <span>Terminal Value</span>
            <span>{formatMillions(terminalValue)}</span>
          </div>
          <div class="math-row highlight">
            <span>PV of Terminal Value</span>
            <span>{formatMillions(pvTerminalValue)}</span>
          </div>
        </div>

        <p style="margin-top: 2rem;">Adding it all together with Net Cash:</p>

        <div class="math-card">
          <div class="math-row">
            <span>Sum of PV of FCFs (Years 1-5)</span>
            <span>{formatMillions(sumPvFcf)}</span>
          </div>
          <div class="math-row">
            <span>+ PV of Terminal Value</span>
            <span>{formatMillions(pvTerminalValue)}</span>
          </div>
          <div class="math-row">
            <span><strong>= Enterprise Value</strong></span>
            <span><strong>{formatMillions(enterpriseValue)}</strong></span>
          </div>
          <div class="math-row">
            <span>+ Net Cash (Cash - Debt)</span>
            <span>{formatMillions(netCash)}</span>
          </div>
          <div class="math-row highlight">
            <span><strong>= Total Equity Value</strong></span>
            <span><strong>{formatMillions(totalEquityValue)}</strong></span>
          </div>
          <div class="math-row">
            <span>÷ Shares Outstanding</span>
            <span>{sharesOut.toLocaleString()}M</span>
          </div>
          <div class="math-row result">
            <span><strong>Intrinsic Value Per Share</strong></span>
            <span><strong>{formatMoney(intrinsicValuePerShare)}</strong></span>
          </div>
        </div>
      </section>

      <section class="content-section">
        <h2>Sensitivity Matrix</h2>
        <p>A single intrinsic value relies on rigid assumptions. The sensitivity matrix below demonstrates how the intrinsic value changes when we adjust the Discount Rate (WACC) and the Terminal Growth Rate.</p>

        <div class="table-container sensitivity-table">
          <table>
            <thead>
              <tr>
                <th rowspan="2" class="corner-cell">Terminal<br/>Growth</th>
                <th colspan="5" class="header-cell">Discount Rate (WACC)</th>
              </tr>
              <tr>
                {sensitivityDiscountRates.map(d => <th>{formatPercent(d)}</th>)}
              </tr>
            </thead>
            <tbody>
              {sensitivityMatrix.map(row => (
                <tr>
                  <th class="row-header">{formatPercent(row.growthRate)}</th>
                  {row.values.map(val => (
                    <td class={
                      val > currentPrice * 1.15 ? "cell-undervalued" :
                      val < currentPrice * 0.85 ? "cell-overvalued" :
                      "cell-neutral"
                    }>
                      {formatMoney(val)}
                    </td>
                  ))}
                </tr>
              ))}
            </tbody>
          </table>
          <div class="matrix-legend">
            <span class="legend-item"><span class="color-box cell-undervalued"></span> Undervalued (>15% Margin)</span>
            <span class="legend-item"><span class="color-box cell-neutral"></span> Fair Value</span>
            <span class="legend-item"><span class="color-box cell-overvalued"></span> Overvalued (&lt;-15% Margin)</span>
          </div>
        </div>
      </section>

      <section class="content-section">
        <h2>Historical FCF Context (2021-2025)</h2>
        <p>Adobe's cash generation consistency is exceptional. The historical data illustrates a resilient business model that continues to throw off massive free cash flow even through macroeconomic fluctuations.</p>

        <div class="bar-chart-container">
          <div class="bar-chart">
            <div class="bar-group">
              <div class="bar" style="height: 66%;"><span class="bar-label">$6.8B</span></div>
              <div class="bar-year">2021</div>
            </div>
            <div class="bar-group">
              <div class="bar" style="height: 71%;"><span class="bar-label">$7.3B</span></div>
              <div class="bar-year">2022</div>
            </div>
            <div class="bar-group">
              <div class="bar" style="height: 67%;"><span class="bar-label">$6.9B</span></div>
              <div class="bar-year">2023</div>
            </div>
            <div class="bar-group">
              <div class="bar" style="height: 76%;"><span class="bar-label">$7.8B</span></div>
              <div class="bar-year">2024</div>
            </div>
            <div class="bar-group">
              <div class="bar highlight" style="height: 100%;"><span class="bar-label">$10.3B</span></div>
              <div class="bar-year">2025</div>
            </div>
          </div>
        </div>
      </section>

      <section class="content-section risks-section">
        <h2>Risks & Bear Case</h2>
        <p>While my valuation indicates significant upside, a complete analysis requires addressing the structural risks that could derail this growth trajectory:</p>
        <div class="risk-grid">
          <div class="risk-card">
            <h3>1. AI Commoditization & Competition</h3>
            <p>The rapid advancement of foundation models (like those from OpenAI, Midjourney, and open-source alternatives) threatens to commoditize basic image and video generation. If these tools become "good enough" for the average commercial user, Adobe's premium pricing power could erode.</p>
          </div>
          <div class="risk-card">
            <h3>2. Macroeconomic Software Squeeze</h3>
            <p>Enterprise IT budgets have faced intense scrutiny. If economic conditions tighten further, companies may reduce headcount or consolidate software licenses, directly impacting Adobe's core subscriber growth and retention rates across both Creative and Document clouds.</p>
          </div>
          <div class="risk-card">
            <h3>3. Regulatory M&A Hurdles</h3>
            <p>The blocked acquisition of Figma demonstrated that regulatory bodies are taking a harsh stance on big tech consolidation. Adobe's historical strategy of acquiring disruptive competitors is now significantly constrained, forcing it to rely almost entirely on organic innovation.</p>
          </div>
        </div>
      </section>

      <section class="content-section faq-section">
        <h2>Frequently Asked Questions</h2>

        <div class="faq-item">
          <h3>Why did Gemini pick an 11% growth rate for Adobe?</h3>
          <p>Gemini projects that Adobe's deep integration of generative AI (Firefly) across its Creative Cloud suite will drive sustained pricing power and user expansion, justifying an 11% FCF growth rate over the next 5 years despite its mature market position.</p>
        </div>

        <div class="faq-item">
          <h3>What discount rate was used for Adobe's DCF?</h3>
          <p>An 8.5% discount rate was selected. This reflects a 4.18% risk-free rate and a relatively low equity risk premium, acknowledging Adobe's highly predictable subscription revenue model and entrenched economic moat.</p>
        </div>

        <div class="faq-item">
          <h3>What are the main risks to Adobe's valuation?</h3>
          <p>Key risks include the commoditization of AI generation tools by competitors (like OpenAI or Midjourney), macroeconomic softness reducing enterprise software spending, and regulatory hurdles limiting future strategic acquisitions.</p>
        </div>
      </section>

      <div class="disclaimer-box">
        <p><strong>Disclaimer:</strong> The numbers presented on this page are for educational and entertainment purposes only. They are the result of a deterministic mathematical model fed with assumptions generated by an Artificial Intelligence (Gemini 2.5 Pro). This does not constitute investment advice. Always conduct your own due diligence before investing in the stock market.</p>
      </div>

    </div>
  </div>
</SiteLayout>
