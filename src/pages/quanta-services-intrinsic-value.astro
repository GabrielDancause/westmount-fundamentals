---
import SiteLayout from "../layouts/SiteLayout.astro";
import * as cheerio from "cheerio";

// ═══════════════════════════════════════════════════════════════
//   DATA FETCHING
// ═══════════════════════════════════════════════════════════════

const urls = [
  'https://stockanalysis.com/stocks/pwr/financials/',
  'https://stockanalysis.com/stocks/pwr/financials/cash-flow-statement/',
  'https://stockanalysis.com/stocks/pwr/financials/balance-sheet/'
];

const responses = await Promise.all(urls.map(url => fetch(url)));
const htmls = await Promise.all(responses.map(res => res.text()));

const $is = cheerio.load(htmls[0]);
const $cf = cheerio.load(htmls[1]);
const $bs = cheerio.load(htmls[2]);

function getFirstRowValue($doc, label) {
  let val = null;
  $doc('tr').each((i, el) => {
    const firstTd = $doc(el).find('td').first().text().trim();
    if (val === null && (firstTd === label || firstTd.startsWith(label))) {
      const secondTd = $doc(el).find('td').eq(1).text().trim().replace(/,/g, '');
      if (secondTd && secondTd !== '-') {
        val = parseFloat(secondTd);
      }
    }
  });
  return val;
}

function getRowValues($doc, label) {
  let vals = [];
  $doc('tr').each((i, el) => {
    const firstTd = $doc(el).find('td').first().text().trim();
    if (vals.length === 0 && (firstTd === label || firstTd.startsWith(label))) {
      $doc(el).find('td').each((j, td) => {
        if (j > 0) {
            let txt = $doc(td).text().trim().replace(/,/g, '');
            let parsed = parseFloat(txt);
            vals.push(isNaN(parsed) ? null : parsed);
        }
      });
    }
  });
  return vals;
}

// Extract required data (FY2025 defaults, in millions where applicable)
const revenue2025 = getFirstRowValue($is, "Revenue") || 28480;
const fcf2025 = getFirstRowValue($cf, "Free Cash Flow") || 1621;
const sharesOutstanding = getFirstRowValue($is, "Shares Outstanding (Diluted)") || 151;
const eps2025 = getFirstRowValue($is, "EPS (Diluted)") || 6.80;
const opMargin2025Str = getRowValues($is, "Operating Margin")[0] || 5.66;
const cashAndInvestments = getFirstRowValue($bs, "Cash & Equivalents") || 439.51;
const totalDebt = getFirstRowValue($bs, "Total Debt") || 6419;

// Extract history for charts (5 years, reverse order so 2021 is first, 2025 is last)
const revVals = getRowValues($is, "Revenue").slice(0, 5).reverse();
const fcfVals = getRowValues($cf, "Free Cash Flow").slice(0, 5).reverse();
const epsVals = getRowValues($is, "EPS (Diluted)").slice(0, 5).reverse();
const opMarginVals = getRowValues($is, "Operating Margin").slice(0, 5).reverse();
const profitMarginVals = getRowValues($is, "Profit Margin").slice(0, 5).reverse();
const fcfMarginVals = getRowValues($cf, "FCF Margin").slice(0, 5).reverse();

const revenueHistory = [
  { year: 2021, value: revVals[0] || 12980 },
  { year: 2022, value: revVals[1] || 17074 },
  { year: 2023, value: revVals[2] || 20882 },
  { year: 2024, value: revVals[3] || 23673 },
  { year: 2025, value: revVals[4] || 28480 },
];
const fcfHistory = [
  { year: 2021, value: fcfVals[0] || 196.54 },
  { year: 2022, value: fcfVals[1] || 702.68 },
  { year: 2023, value: fcfVals[2] || 1141 },
  { year: 2024, value: fcfVals[3] || 1477 },
  { year: 2025, value: fcfVals[4] || 1621 },
];
const epsHistory = [
  { year: 2021, value: epsVals[0] || 3.34 },
  { year: 2022, value: epsVals[1] || 3.32 },
  { year: 2023, value: epsVals[2] || 5.00 },
  { year: 2024, value: epsVals[3] || 6.03 },
  { year: 2025, value: epsVals[4] || 6.80 },
];
const marginHistory = [
  { year: 2021, operating: opMarginVals[0] || 5.11, profit: profitMarginVals[0] || 3.79, fcfMargin: fcfMarginVals[0] || 1.51 },
  { year: 2022, operating: opMarginVals[1] || 5.11, profit: profitMarginVals[1] || 3.00, fcfMargin: fcfMarginVals[1] || 4.12 },
  { year: 2023, operating: opMarginVals[2] || 5.40, profit: profitMarginVals[2] || 3.59, fcfMargin: fcfMarginVals[2] || 5.46 },
  { year: 2024, operating: opMarginVals[3] || 5.69, profit: profitMarginVals[3] || 3.92, fcfMargin: fcfMarginVals[3] || 6.24 },
  { year: 2025, operating: opMarginVals[4] || 5.66, profit: profitMarginVals[4] || 3.66, fcfMargin: fcfMarginVals[4] || 5.69 },
];

/* ═══════════════════════════════════════════════════════════════
   DCF MODEL — ALL INPUTS AND CALCULATIONS
   ═══════════════════════════════════════════════════════════════ */

const netCash = cashAndInvestments - totalDebt;

// --- ASSUMPTIONS ---
const growthRatePhase1 = 0.10;         // 10% FCF growth, Years 1-5
const growthRateTerminal = 0.03;       // 3% perpetuity growth (terminal)
const discountRate = 0.095;            // 9.5% WACC / required return

// --- PHASE 1: PROJECT FCF FOR YEARS 1-5 ---
const projectedFCF = [];
let fcf = fcf2025;
for (let yr = 1; yr <= 5; yr++) {
  fcf = fcf * (1 + growthRatePhase1);
  projectedFCF.push({ year: yr, fcf: Math.round(fcf), pvFactor: 1 / Math.pow(1 + discountRate, yr) });
}
projectedFCF.forEach(p => { p.pvFCF = Math.round(p.fcf * p.pvFactor); });

// --- PHASE 2: TERMINAL VALUE (Gordon Growth Model) ---
const fcfYear6 = projectedFCF[4].fcf * (1 + growthRateTerminal);
const terminalValue = Math.round(fcfYear6 / (discountRate - growthRateTerminal));
const pvTerminalValue = Math.round(terminalValue * projectedFCF[4].pvFactor);

// --- ENTERPRISE VALUE ---
const pvPhase1 = projectedFCF.reduce((sum, p) => sum + p.pvFCF, 0);
const enterpriseValue = pvPhase1 + pvTerminalValue;

// --- EQUITY VALUE ---
const equityValue = enterpriseValue + netCash;
const intrinsicValuePerShare = equityValue / sharesOutstanding;
const roundedIV = Math.round(intrinsicValuePerShare * 100) / 100;

// Market comparison
const currentPrice = 576.92;
const marginOfSafety = ((roundedIV - currentPrice) / currentPrice * 100).toFixed(1);
const verdictText = roundedIV > currentPrice ? "Undervalued" : "Overvalued";
const verdictColor = roundedIV > currentPrice ? "#10b981" : "#ef4444";

// Sensitivity analysis
const sensitivityRates = [0.075, 0.085, 0.095, 0.105, 0.115];
const sensitivityGrowth = [0.06, 0.08, 0.10, 0.12, 0.14];
const sensitivityTable = sensitivityRates.map(dr => {
  return {
    dr,
    values: sensitivityGrowth.map(gr => {
      let f = fcf2025;
      let pvSum = 0;
      for (let y = 1; y <= 5; y++) {
        f = f * (1 + gr);
        pvSum += f / Math.pow(1 + dr, y);
      }
      const f6 = f * (1 + growthRateTerminal);
      const tv = f6 / (dr - growthRateTerminal);
      const pvTV = tv / Math.pow(1 + dr, 5);
      return Math.round((pvSum + pvTV + netCash) / sharesOutstanding);
    })
  };
});

const schema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": "Quanta Services (PWR) Intrinsic Value: A DCF Analysis",
  "description": "A transparent, step-by-step discounted cash flow valuation of Quanta Services. Using FY2025 financials to arrive at a single fair value estimate for PWR shares.",
  "datePublished": "2026-03-18",
  "dateModified": "2026-03-18",
  "author": {
    "@type": "Organization",
    "name": "Westmount Research",
    "url": "https://westmountfundamentals.com"
  },
  "publisher": {
    "@type": "Organization",
    "name": "Westmount Research",
    "url": "https://westmountfundamentals.com"
  },
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": "https://westmountfundamentals.com/quanta-services-intrinsic-value"
  }
};

export const meta = {
  title: "Quanta Services (PWR) Intrinsic Value",
  description: "We ran a full discounted cash flow on Quanta Services using FY2025 actuals. One number. Every assumption disclosed. Here's what PWR is really worth.",
  category: "study",
  published: "2026-03-18",
};
---

<SiteLayout
