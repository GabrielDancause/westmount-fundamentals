    // Populate Hero Stats for VOO
    const voo = etfData['VOO'];
    if(voo) {
      document.getElementById('main-stats').innerHTML = `
        <div class="stat-card featured">
          <div class="stat-value">${voo.expenseRatio}%</div>
          <div class="stat-label">Expense Ratio</div>
        </div>
        <div class="stat-card">
          <div class="stat-value">$${voo.aum}B</div>
          <div class="stat-label">Assets (AUM)</div>
        </div>
        <div class="stat-card">
          <div class="stat-value">${voo.yr5Return}%</div>
