  <script is:inline>
    document.addEventListener('DOMContentLoaded', () => {
      const calcBtn = document.getElementById('calc-btn');
      if (calcBtn) {
        calcBtn.addEventListener('click', () => {
          const shares = parseFloat(document.getElementById('shares').value) || 0;
          const isDrip = document.getElementById('drip').checked;

          // Using hardcoded yield for calculator demo logic
          const baseYield = 0.94769996;
          const stockPrice = 31.45;

          let annualIncome = shares * stockPrice * baseYield;
          let effectiveYield = baseYield * 100;

          if (isDrip) {
            // Simple compounding approximation for 1 year monthly
            effectiveYield = (Math.pow(1 + baseYield/12, 12) - 1) * 100;
            annualIncome = shares * stockPrice * (effectiveYield / 100);
          }

          document.getElementById('est-income').textContent = '$' + annualIncome.toFixed(2);
          document.getElementById('yield-cost').textContent = effectiveYield.toFixed(2) + '%';
          document.getElementById('calc-result').style.display = 'block';
        });
      }
    });
  </script>

