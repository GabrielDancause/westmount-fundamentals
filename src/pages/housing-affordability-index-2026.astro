        const rawData = [{"city":"New York, NY","country":"United States","priceToIncome":14.3,"priceToRentCity":19.8,"priceToRentOut":14.9,"mortgageAsPctOfIncome":130.4,"affordabilityIndex":0.8},{"city":"Vancouver","country":"Canada","priceToIncome":11.2,"priceToRentCity":21.3,"priceToRentOut":21.1,"mortgageAsPctOfIncome":84.8,"affordabilityIndex":1.2},{"city":"Toronto","country":"Canada","priceToIncome":10.7,"priceToRentCity":25.2,"priceToRentOut":22.9,"mortgageAsPctOfIncome":81.5,"affordabilityIndex":1.2},{"city":"Los Angeles, CA","country":"United States","priceToIncome":9.3,"priceToRentCity":13.1,"priceToRentOut":14.2,"mortgageAsPctOfIncome":87.2,"affordabilityIndex":1.1},{"city":"Victoria","country":"Canada","priceToIncome":8.7,"priceToRentCity":16.8,"priceToRentOut":16.1,"mortgageAsPctOfIncome":67,"affordabilityIndex":1.5},{"city":"San Jose, CA","country":"United States","priceToIncome":8.4,"priceToRentCity":14.2,"priceToRentOut":17.1,"mortgageAsPctOfIncome":74.4,"affordabilityIndex":1.3},{"city":"Montreal","country":"Canada","priceToIncome":7.7,"priceToRentCity":19.6,"priceToRentOut":19.7,"mortgageAsPctOfIncome":58.6,"affordabilityIndex":1.7},{"city":"Quebec City","country":"Canada","priceToIncome":7.6,"priceToRentCity":30.3,"priceToRentOut":18.2,"mortgageAsPctOfIncome":58.8,"affordabilityIndex":1.7},{"city":"Boston, MA","country":"United States","priceToIncome":7.4,"priceToRentCity":17.3,"priceToRentOut":12.2,"mortgageAsPctOfIncome":65.8,"affordabilityIndex":1.5},{"city":"San Diego, CA","country":"United States","priceToIncome":7.1,"priceToRentCity":13,"priceToRentOut":12.1,"mortgageAsPctOfIncome":62.9,"affordabilityIndex":1.6},{"city":"San Francisco, CA","country":"United States","priceToIncome":7,"priceToRentCity":15.1,"priceToRentOut":16.3,"mortgageAsPctOfIncome":62.3,"affordabilityIndex":1.6},{"city":"Dallas, TX","country":"United States","priceToIncome":6.6,"priceToRentCity":21.4,"priceToRentOut":9.8,"mortgageAsPctOfIncome":59.6,"affordabilityIndex":1.