:3.6,"priceToRentCity":9.6,"priceToRentOut":11.3,"mortgageAsPctOfIncome":28,"affordabilityIndex":3.6},{"city":"Philadelphia, PA","country":"United States","priceToIncome":3.4,"priceToRentCity":9.5,"priceToRentOut":6.8,"mortgageAsPctOfIncome":30.2,"affordabilityIndex":3.3},{"city":"Columbus, OH","country":"United States","priceToIncome":3.3,"priceToRentCity":10.7,"priceToRentOut":7.3,"mortgageAsPctOfIncome":28.7,"affordabilityIndex":3.5},{"city":"Chicago, IL","country":"United States","priceToIncome":3.2,"priceToRentCity":7,"priceToRentOut":7.1,"mortgageAsPctOfIncome":29.4,"affordabilityIndex":3.4},{"city":"Jacksonville, FL","country":"United States","priceToIncome":2.8,"priceToRentCity":7.3,"priceToRentOut":8.8,"mortgageAsPctOfIncome":24.8,"affordabilityIndex":4},{"city":"Indianapolis, IN","country":"United States","priceToIncome":2.8,"priceToRentCity":7.9,"priceToRentOut":7.3,"mortgageAsPctOfIncome":24.4,"affordabilityIndex":4.1}];
        let currentData = [...rawData];
        let sortCol = 'priceToIncome';
        let sortAsc = false;

        // UI Elements
        const tableBody = document.getElementById('tableBody');
        const searchInput = document.getElementById('searchInput');
        const countryFilter = document.getElementById('countryFilter');
        const headers = document.querySelectorAll('th[data-sort]');
        const statsGrid = document.getElementById('statsGrid');

        let chartInstance = null;

        function init() {
            renderStats();
            renderTable();
            renderChart();
            setupEventListeners();
        }

        function renderStats() {
            if (rawData.length === 0) return;

            // Calculate some aggregates
            const usData = rawData.filter(d => d.country === 'United States');
            const caData = rawData.filter(d => d.country === 'Canada');

            const avgUsRatio = usData.length > 0 ? (usData.reduce((sum, d) => sum + d.priceToIncome, 0) / usData.length).toFixed(1) : 'N/A';
            const avgCaRatio = caData.length > 0 ? (caData.reduce((sum, d) => sum + d.priceToIncome, 0) / caData.length).toFixed(1) : 'N/A';

            const mostAffordable = [...rawData].sort((a,b) => a.priceToIncome - b.priceToIncome)[0];
            const leastAffordable = [...rawData].sort((a,b) => b.priceToIncome - a.priceToIncome)[0];

            statsGrid.innerHTML = `
                <div class="stat-card">
                    <div class="stat-value">${avgUsRatio}</div>
                    <div class="stat-label">Avg US Price-to-Income</div>
                </div>
                <div class="stat-card">
                    <div class="stat-value">${avgCaRatio}</div>
                    <div class="stat-label">Avg Canada Price-to-Income</div>
                </div>
                <div class="stat-card">
                    <div class="stat-value">${mostAffordable.city}</div>
                    <div class="stat-label">Most Affordable (${mostAffordable.priceToIncome}x)</div>
                </div>
                <div class="stat-card">
                    <div class="stat-value">${leastAffordable.city}</div>
                    <div class="stat-label">Least Affordable (${leastAffordable.priceToIncome}x)</div>
                </div>
            `;
        }

        function renderTable() {
            tableBody.innerHTML = '';

            currentData.forEach(row => {
                const tr = document.createElement('tr');
                tr.innerHTML = `
                    <td>${row.city}</td>
                    <td>${row.country}</td>
                    <td>${row.priceToIncome.toFixed(1)}</td>
                    <td>${row.mortgageAsPctOfIncome.toFixed(1)}%</td>
                    <td>${row.priceToRentCity.toFixed(1)}</td>
                `;
                tableBody.appendChild(tr);
            });
        }

        function renderChart() {
            const ctx = document.getElementById('affordabilityChart').getContext('2d');

            // Use top 15 most extreme ratios for chart to keep it readable
            const chartData = [...currentData].sort((a,b) => b.priceToIncome - a.priceToIncome).slice(0, 15);

            if (chartInstance) {
                chartInstance.destroy();
            }

            Chart.defaults.color = '#94a3b8';
            Chart.defaults.font.family = 'Inter';

            chartInstance = new Chart(ctx, {
                type: 'bar',
                data: {
                    labels: chartData.map(d => d.city.split(',')[0]),
                    datasets: [{
                        label: 'Price-to-Income Ratio',
                        data: chartData.map(d => d.priceToIncome),
                        backgroundColor: chartData.map(d => d.country === 'Canada' ? '#ef4444' : '#4a8fe7'),
                        borderRadius: 4
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: { display: false },
                        tooltip: {
                            backgroundColor: '#0a1020',
                            titleColor: '#e2e8f0',
                            bodyColor: '#94a3b8',
                            borderColor: '#152040',
                            borderWidth: 1,
                            callbacks: {
                                label: function(context) {
                                    return `Ratio: ${context.parsed.y}`;
                                }
                            }
                        }
                    },
                    scales: {
                        y: {
                            beginAtZero: true,
                            grid: { color: '#152040' },
                            title: { display: true, text: 'Price-to-Income Ratio' }
                        },
                        x: {
                            grid: { display: false }
                        }
                    }
                }
            });
        }

        function handleSort(col) {
            if (sortCol === col) {
                sortAsc = !sortAsc;
            } else {
                sortCol = col;
                sortAsc = true;
            }

            currentData.sort((a, b) => {
                let valA = a[col];
                let valB = b[col];

                if (typeof valA === 'string') valA = valA.toLowerCase();
                if (typeof valB === 'string') valB = valB.toLowerCase();

                if (valA < valB) return sortAsc ? -1 : 1;
                if (valA > valB) return sortAsc ? 1 : -1;
                return 0;
            });

            renderTable();
        }

        function handleFilter() {
            const query = searchInput.value.toLowerCase();
            const country = countryFilter.value;

            currentData = rawData.filter(d => {
                const matchesSearch = d.city.toLowerCase().includes(query) || d.country.toLowerCase().includes(query);
                const matchesCountry = country === 'all' || d.country === country;
                return matchesSearch && matchesCountry;
            });

            // Re-apply sort
            handleSort(sortCol);
            // Reverse sortAsc back to what it was because handleSort toggles it
            sortAsc = !sortAsc;

            renderTable();
            renderChart();
        }

        function setupEventListeners() {
            headers.forEach(th => {
                th.addEventListener('click', () => {
                    handleSort(th.dataset.sort);
                });
            });

            searchInput.addEventListener('keyup', handleFilter);
            countryFilter.addEventListener('change', handleFilter);
        }

