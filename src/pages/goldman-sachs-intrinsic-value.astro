---
import SiteLayout from '../layouts/SiteLayout.astro';

export const meta = {
  title: "The Goldman Sachs Group (GS) Intrinsic Value",
  description: "A comprehensive two-stage discounted cash flow (DCF) intrinsic value analysis of The Goldman Sachs Group (GS) compiled by Gemini 2.5 Pro.",
  category: "study",
  published: "2026-03-18"
};

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Article",
      "headline": meta.title,
      "description": meta.description,
      "author": {
        "@type": "Organization",
        "name": "Gemini 2.5 Pro",
        "url": "https://westmountfundamentals.com/"
      },
      "publisher": {
        "@type": "Organization",
        "name": "Westmount Fundamentals",
        "logo": {
          "@type": "ImageObject",
          "url": "https://westmountfundamentals.com/logo.png"
        }
      },
      "datePublished": meta.published,
      "mainEntityOfPage": {
        "@type": "WebPage",
        "@id": "https://westmountfundamentals.com/goldman-sachs-intrinsic-value"
      }
    },
    {
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "Why use Net Income instead of Free Cash Flow for Goldman Sachs?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "For banks and financial institutions like Goldman Sachs, traditional Free Cash Flow is heavily distorted by changes in working capital (such as customer deposits, loan originations, and trading assets). Because banks operate with money as their primary inventory, operating cash flow is not a reliable metric for valuation. Instead, we use Normalized Net Income, which serves as a proxy for Free Cash Flow to Equity (FCFE), measuring the cash available to shareholders after all obligations and reinvestment needs are met."
          }
        },
        {
          "@type": "Question",
          "name": "What growth rate is used for Goldman Sachs in this DCF?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "This model assumes a 6.5% annual growth rate for the first 5 years. While GS has strong wealth management and trading divisions, financial services are cyclical and sensitive to interest rates and macroeconomic conditions. A 6.5% rate balances their strong market position with the inherent volatility of deal flows and trading revenues."
          }
        },
        {
          "@type": "Question",
          "name": "What is the discount rate used for this valuation?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "The model uses an 11.0% discount rate (Cost of Equity). Given the March 2026 10-Year US Treasury Rate of 4.18%, a beta of approximately 1.3 for Goldman Sachs, and an equity risk premium of 5.5%, the Capital Asset Pricing Model (CAPM) suggests a required return of around 11.3%. We have adopted 11.0% as a reasonable cost of equity to discount future cash flows."
          }
        }
      ]
    }
  ]
};

// --- DATA FETCHING ---
// Fallbacks
let currentPrice = 811.08;
let sharesOut = 296.75; // millions
let netIncome = 17176; // millions (proxy for FCFE)

try {
    const quoteRes = await fetch('https://stockanalysis.com/stocks/gs/', { headers: { 'User-Agent': 'Mozilla/5.0' } });
    const quoteHtml = await quoteRes.text();

    // Parse Price
    const priceMatch = quoteHtml.match(/<div class="text-4xl[^>]*>([0-9,.]+)<\/div>/);
    if (priceMatch) {
        currentPrice = parseFloat(priceMatch[1].replace(/,/g, ''));
    }

    // Parse Shares Out
    const sharesMatch = quoteHtml.match(/Shares Out.*?<td[^>]*>([0-9.]+)([BMT]?)<\/td>/);
    if (sharesMatch) {
        let val = parseFloat(sharesMatch[1]);
        if (sharesMatch[2] === 'B') val *= 1000;
        if (sharesMatch[2] === 'T') val *= 1000000;
        sharesOut = val;
    }

    const finRes = await fetch('https://stockanalysis.com/stocks/gs/financials/', { headers: { 'User-Agent': 'Mozilla/5.0' } });
    const finHtml = await finRes.text();

    // Parse Net Income (using the most recent year 2025 net income to common from table)
    // The table shows values like: <td class="bolded svelte-11zo0q0">16,300</td>
    const tbodyMatch = finHtml.match(/<tbody[^>]*>(.*?)<\/tbody>/s);
    if (tbodyMatch && tbodyMatch[1].includes('Net Income to Common')) {
        const lines = tbodyMatch[1].split('</tr>');
        for (const line of lines) {
            if (line.includes('Net Income to Common')) {
                const vals = line.match(/<td[^>]*>([^<]+)<\/td>/g);
                if (vals && vals.length > 1) {
                    const latestValHtml = vals[1]; // first data column
                    const latestValText = latestValHtml.replace(/<[^>]+>/g, '').trim().replace(/,/g, '');
                    const parsedNi = parseFloat(latestValText);
                    if (!isNaN(parsedNi) && parsedNi > 0) {
                        netIncome = parsedNi;
                    }
                }
            }
        }
    }
} catch (e) {
    // Silently fallback
}

// Ensure proper scale
let netIncomeMillions = netIncome;
if (netIncomeMillions < 1000) {
    // If it parsed as billions instead of millions
    netIncomeMillions = netIncome * 1000;
}

// --- ASSUMPTIONS ---
const growthRate = 0.065; // 6.5% Years 1-5
const discountRate = 0.11; // 11.0% Cost of Equity
const terminalGrowthRate = 0.025; // 2.5% Long-term

// --- DCF CALCULATIONS ---
let fcfProjections = [];
let pvFcfProjections = [];
let currentFcf = netIncomeMillions;
let sumPvFcf = 0;

for (let i = 1; i <= 5; i++) {
    currentFcf = currentFcf * (1 + growthRate);
    fcfProjections.push(currentFcf);

    const pv = currentFcf / Math.pow(1 + discountRate, i);
    pvFcfProjections.push(pv);
    sumPvFcf += pv;
}

// Terminal Value using Gordon Growth Model
const finalYearFcf = fcfProjections[4];
const nextYearFcf = finalYearFcf * (1 + terminalGrowthRate);
const terminalValue = nextYearFcf / (discountRate - terminalGrowthRate);
const pvTerminalValue = terminalValue / Math.pow(1 + discountRate, 5);

const impliedMarketCap = sumPvFcf + pvTerminalValue;
const intrinsicValuePerShare = impliedMarketCap / sharesOut;

// Determine Verdict
const marginOfSafety = ((intrinsicValuePerShare - currentPrice) / currentPrice) * 100;
let verdict = "";
let verdictColor = "";

if (intrinsicValuePerShare > currentPrice * 1.1) {
    verdict = "Undervalued";
    verdictColor = "#22c55e"; // Green
} else if (intrinsicValuePerShare < currentPrice * 0.9) {
    verdict = "Overvalued";
    verdictColor = "#ef4444"; // Red
} else {
    verdict = "Fairly Valued";
    verdictColor = "#eab308"; // Yellow
}

// Sensitivity Matrix (5x5)
const sensitivities = [];
const discountRates = [0.09, 0.10, 0.11, 0.12, 0.13];
const termRates = [0.015, 0.020, 0.025, 0.030, 0.035];

for (let r of discountRates) {
    const row = [];
    for (let g of termRates) {
        if (g >= r) {
            row.push(null); // Invalid math
            continue;
        }

        let s_sumPvFcf = 0;
        let s_currentFcf = netIncomeMillions;
        for (let i = 1; i <= 5; i++) {
            s_currentFcf = s_currentFcf * (1 + growthRate);
            s_sumPvFcf += s_currentFcf / Math.pow(1 + r, i);
        }

        const s_nextYearFcf = s_currentFcf * (1 + g);
        const s_tv = s_nextYearFcf / (r - g);
        const s_pvTv = s_tv / Math.pow(1 + r, 5);

        const s_impliedCap = s_sumPvFcf + s_pvTv;
        const s_iv = s_impliedCap / sharesOut;
        row.push(s_iv);
    }
    sensitivities.push({ rate: r, values: row });
}

// Formatting helpers
const formatCurrency = (val) => new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD' }).format(val);
const formatMillions = (val) => new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD', maximumFractionDigits: 0 }).format(val) + "M";
const formatPercent = (val) => (val * 100).toFixed(1) + "%";
---
<SiteLayout site="westmount" title={meta.title} description={meta.description} canonical="https://westmountfundamentals.com/goldman-sachs-intrinsic-value" schema={schema}>

  <article class="dcf-container">
    <header class="dcf-header">
      <span class="compiled-badge">Compiled by Gemini 2.5 Pro</span>
      <h1>Intrinsic Value Analysis: The Goldman Sachs Group (GS)</h1>
      <p class="subtitle">A two-stage Discounted Cash Flow (DCF) model to determine the fair value of GS stock based on future cash flow projections.</p>
    </header>

    <section class="verdict-section">
      <div class="verdict-card">
        <div class="verdict-prices">
          <div class="price-box">
            <span class="label">Current Price</span>
            <span class="value">{formatCurrency(currentPrice)}</span>
          </div>
          <div class="price-box highlight">
            <span class="label">Intrinsic Value</span>
            <span class="value" style={`color: ${verdictColor}`}>{formatCurrency(intrinsicValuePerShare)}</span>
          </div>
        </div>
        <div class="verdict-result">
          <span class="verdict-text" style={`color: ${verdictColor}`}>{verdict}</span>
          <span class="margin-text">({marginOfSafety > 0 ? '+' : ''}{marginOfSafety.toFixed(2)}% vs Current Price)</span>
        </div>
      </div>
    </section>

    <section class="methodology-section">
      <h2>Valuation Methodology</h2>
      <p>
        Valuing financial institutions like Goldman Sachs requires a departure from standard corporate DCF models. For non-financial companies, Free Cash Flow (FCF) is derived by starting with Operating Cash Flow and subtracting Capital Expenditures. However, for a bank, changes in working capital (such as customer deposits, loan originations, and trading assets) flow through Operating Cash Flow, often rendering it negative and highly volatile.
      </p>
      <p>
        Because money is effectively a bank's inventory, traditional FCF is not a reliable indicator of intrinsic value. Instead, this model uses a <strong>Normalized Earnings Model</strong> (serving as a proxy for the Dividend Discount Model / Free Cash Flow to Equity). We utilize Net Income Available to Common Shareholders as the base cash flow, representing the total funds available to be distributed to equity holders after all debt obligations, taxes, and reinvestment requirements (regulatory capital) are met.
      </p>
    </section>

    <section class="assumptions-grid">
      <div class="assumption-card">
        <h3>Base Cash Flow (FCFE Proxy)</h3>
        <div class="assumption-value">{formatMillions(netIncomeMillions)}</div>
        <p>Most recent Net Income to Common, utilized as the starting base for future cash available to equity shareholders.</p>
      </div>
      <div class="assumption-card">
        <h3>Growth Rate (Years 1-5)</h3>
        <div class="assumption-value">{formatPercent(growthRate)}</div>
        <p>Projected annual growth in normalized earnings. Reflects a balance between GS's dominant wealth management/trading divisions and the cyclical nature of investment banking deal flows.</p>
      </div>
      <div class="assumption-card">
        <h3>Discount Rate (Cost of Equity)</h3>
        <div class="assumption-value">{formatPercent(discountRate)}</div>
        <p>Calculated via CAPM using a 4.18% Risk-Free Rate (10Y Treasury), an estimated Beta of 1.3, and a 5.5% Equity Risk Premium.</p>
      </div>
      <div class="assumption-card">
        <h3>Terminal Growth Rate</h3>
        <div class="assumption-value">{formatPercent(terminalGrowthRate)}</div>
        <p>The perpetual growth rate applied after Year 5. Set slightly above long-term inflation targets, representing sustainable economic expansion for a global banking leader.</p>
      </div>
    </section>

    <section class="data-section">
      <h2>Stage 1: Projected Cash Flows (Years 1-5)</h2>
      <div class="table-wrapper">
        <table>
          <thead>
            <tr>
              <th>Year</th>
              <th>Projected Net Income (FCFE Proxy)</th>
              <th>Present Value (Discounted at {formatPercent(discountRate)})</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td>Year 1</td>
              <td class="numeric">{formatMillions(fcfProjections[0])}</td>
              <td class="numeric">{formatMillions(pvFcfProjections[0])}</td>
            </tr>
            <tr>
              <td>Year 2</td>
              <td class="numeric">{formatMillions(fcfProjections[1])}</td>
              <td class="numeric">{formatMillions(pvFcfProjections[1])}</td>
            </tr>
            <tr>
              <td>Year 3</td>
              <td class="numeric">{formatMillions(fcfProjections[2])}</td>
              <td class="numeric">{formatMillions(pvFcfProjections[2])}</td>
            </tr>
            <tr>
              <td>Year 4</td>
              <td class="numeric">{formatMillions(fcfProjections[3])}</td>
              <td class="numeric">{formatMillions(pvFcfProjections[3])}</td>
            </tr>
            <tr>
              <td>Year 5</td>
              <td class="numeric">{formatMillions(fcfProjections[4])}</td>
              <td class="numeric">{formatMillions(pvFcfProjections[4])}</td>
            </tr>
            <tr class="summary-row">
              <td><strong>Sum of PV (Years 1-5)</strong></td>
              <td></td>
              <td class="numeric"><strong>{formatMillions(sumPvFcf)}</strong></td>
            </tr>
          </tbody>
        </table>
      </div>
    </section>

    <section class="data-section">
      <h2>Stage 2: Terminal Value</h2>
      <div class="valuation-summary">
        <div class="summary-item">
          <span class="label">Terminal Value (Gordon Growth Model)</span>
          <span class="value">{formatMillions(terminalValue)}</span>
        </div>
        <div class="summary-item highlight">
          <span class="label">Present Value of Terminal Value</span>
          <span class="value">{formatMillions(pvTerminalValue)}</span>
        </div>
      </div>
      <p class="note">Calculated using Year 5 Cash Flow of {formatMillions(fcfProjections[4])} growing perpetually at {formatPercent(terminalGrowthRate)}.</p>
    </section>

    <section class="data-section final-valuation">
      <h2>Final Valuation Summary</h2>
      <div class="table-wrapper">
        <table>
          <tbody>
            <tr>
              <td>Present Value of Stage 1 Cash Flows</td>
              <td class="numeric">{formatMillions(sumPvFcf)}</td>
            </tr>
            <tr>
              <td>Present Value of Terminal Value</td>
              <td class="numeric">{formatMillions(pvTerminalValue)}</td>
            </tr>
            <tr class="summary-row">
              <td><strong>Implied Equity Value</strong></td>
              <td class="numeric"><strong>{formatMillions(impliedMarketCap)}</strong></td>
            </tr>
            <tr>
              <td>Shares Outstanding</td>
              <td class="numeric">{sharesOut.toFixed(2)} Million</td>
            </tr>
            <tr class="intrinsic-row" style={`color: ${verdictColor}`}>
              <td><strong>Intrinsic Value per Share</strong></td>
              <td class="numeric"><strong>{formatCurrency(intrinsicValuePerShare)}</strong></td>
            </tr>
          </tbody>
        </table>
      </div>
    </section>

    <section class="data-section sensitivity">
      <h2>Sensitivity Analysis</h2>
      <p>How the Intrinsic Value changes based on varying Discount Rates (Cost of Equity) and Terminal Growth Rates.</p>
      <div class="table-wrapper">
        <table class="matrix-table">
          <thead>
            <tr>
              <th>Discount / Terminal</th>
              <th>{formatPercent(termRates[0])}</th>
              <th>{formatPercent(termRates[1])}</th>
              <th>{formatPercent(termRates[2])}</th>
              <th>{formatPercent(termRates[3])}</th>
              <th>{formatPercent(termRates[4])}</th>
            </tr>
          </thead>
          <tbody>
            {discountRates.map((dr, idx) => (
              <tr>
                <td><strong>{formatPercent(dr)}</strong></td>
                <td class="numeric">{formatCurrency(sensitivities[idx].values[0])}</td>
                <td class="numeric">{formatCurrency(sensitivities[idx].values[1])}</td>
                <td class="numeric highlight-cell">{formatCurrency(sensitivities[idx].values[2])}</td>
                <td class="numeric">{formatCurrency(sensitivities[idx].values[3])}</td>
                <td class="numeric">{formatCurrency(sensitivities[idx].values[4])}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
      <p class="note">Highlighted column represents the base case Terminal Growth Rate of {formatPercent(terminalGrowthRate)}.</p>
    </section>

    <section class="risks-section">
      <h2>Key Risks to This Valuation</h2>
      <ul>
        <li><strong>Interest Rate Sensitivity:</strong> Goldman Sachs' trading revenues and investment banking deal flows are highly sensitive to Federal Reserve interest rate policies and overall liquidity in the financial system.</li>
        <li><strong>Macroeconomic Downturns:</strong> A recession could significantly impact capital markets, reducing M&A activity and IPO underwriting fees, which are core profit drivers for GS.</li>
        <li><strong>Regulatory Capital Requirements:</strong> Changes in Basel III endgame rules or other regulatory frameworks could force GS to hold more capital, reducing the net income available to common shareholders and lowering the effective FCFE.</li>
        <li><strong>Market Volatility:</strong> While volatility can boost trading revenues in the short term, prolonged market distress can lead to significant mark-to-market losses on principal investments.</li>
      </ul>
    </section>

    <section class="faq-section">
      <h2>Frequently Asked Questions</h2>
      <details>
        <summary>Why use Net Income instead of Free Cash Flow for Goldman Sachs?</summary>
        <div class="details-content">
          <p>For banks and financial institutions like Goldman Sachs, traditional Free Cash Flow is heavily distorted by changes in working capital (such as customer deposits, loan originations, and trading assets). Because banks operate with money as their primary inventory, operating cash flow is not a reliable metric for valuation. Instead, we use Normalized Net Income, which serves as a proxy for Free Cash Flow to Equity (FCFE), measuring the cash available to shareholders after all obligations and reinvestment needs are met.</p>
        </div>
      </details>
      <details>
        <summary>What growth rate is used for Goldman Sachs in this DCF?</summary>
        <div class="details-content">
          <p>This model assumes a {formatPercent(growthRate)} annual growth rate for the first 5 years. While GS has strong wealth management and trading divisions, financial services are cyclical and sensitive to interest rates and macroeconomic conditions. A {formatPercent(growthRate)} rate balances their strong market position with the inherent volatility of deal flows and trading revenues.</p>
        </div>
      </details>
      <details>
        <summary>What is the discount rate used for this valuation?</summary>
        <div class="details-content">
          <p>The model uses an {formatPercent(discountRate)} discount rate (Cost of Equity). Given the March 2026 10-Year US Treasury Rate of 4.18%, a beta of approximately 1.3 for Goldman Sachs, and an equity risk premium of 5.5%, the Capital Asset Pricing Model (CAPM) suggests a required return of around 11.3%. We have adopted {formatPercent(discountRate)} as a reasonable cost of equity to discount future cash flows.</p>
        </div>
      </details>
    </section>

    <footer class="disclaimer">
      <p><strong>Disclaimer:</strong> This intrinsic value calculation was compiled automatically by Gemini 2.5 Pro using public financial data. The calculations rely on assumptions about future growth and discount rates that may not materialize. This analysis is for educational and informational purposes only and does not constitute financial advice or a recommendation to buy, sell, or hold any security. Always conduct your own due diligence or consult a qualified financial advisor before making investment decisions.</p>
    </footer>
  </article>
</SiteLayout>

<style>
