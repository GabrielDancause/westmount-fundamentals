  <script is:inline>
// Simple Interactive Simulator Engine
        document.addEventListener('DOMContentLoaded', () => {
            const canvas = document.getElementById('simChart');
            const ctx = canvas.getContext('2d');

            const btn = document.getElementById('run-sim-btn');
            const strategySelect = document.getElementById('sim-strategy');
            const marketSelect = document.getElementById('sim-market');

            const formatter = new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD', maximumFractionDigits: 0 });

            function runSimulation() {
                const strategy = strategySelect.value;
                const marketEnv = marketSelect.value;

                const initialCapital = 100000;
                let targetStocks = 0.60;
                let targetBonds = 0.40;

                let stockVal = initialCapital * targetStocks;
                let bondVal = initialCapital * targetBonds;

                let trades = 0;
                const years = 20;
                const periods = years * 12; // Monthly steps

                let history = [];
                history.push(initialCapital);

                // Define market parameters based on environment
                let stockMean, stockVol, bondMean, bondVol;

                if (marketEnv === 'trend') {
                    stockMean = 0.12 / 12; stockVol = 0.12 / Math.sqrt(12);
                    bondMean = 0.03 / 12; bondVol = 0.04 / Math.sqrt(12);
                } else if (marketEnv === 'volatile') {
                    stockMean = 0.06 / 12; stockVol = 0.25 / Math.sqrt(12);
                    bondMean = 0.04 / 12; bondVol = 0.08 / Math.sqrt(12);
                } else {
                    // Normal
                    stockMean = 0.08 / 12; stockVol = 0.15 / Math.sqrt(12);
                    bondMean = 0.04 / 12; bondVol = 0.05 / Math.sqrt(12);
                }

                // Box-Muller transform for normal distribution
                function randomNormal(mean, stdDev) {
                    let u1 = Math.random();
                    let u2 = Math.random();
                    let z0 = Math.sqrt(-2.0 * Math.log(u1)) * Math.cos(2.0 * Math.PI * u2);
                    return z0 * stdDev + mean;
                }

                for (let i = 1; i <= periods; i++) {
                    // Monthly returns
                    let sRet = randomNormal(stockMean, stockVol);
                    let bRet = randomNormal(bondMean, bondVol);

                    // Add some mean reversion for volatile market
                    if (marketEnv === 'volatile') {
                        if (i > 1) {
                            let prevTotal = history[i-1];
                            let expected = initialCapital * Math.pow(1 + 0.05/12, i);
                            if (prevTotal > expected) sRet -= 0.01;
                            else sRet += 0.01;
                        }
                    }

                    stockVal *= (1 + sRet);
                    bondVal *= (1 + bRet);

                    let totalVal = stockVal + bondVal;
                    let stockWeight = stockVal / totalVal;

                    let needsRebalance = false;

                    if (strategy === 'annual' && i % 12 === 0) {
                        needsRebalance = true;
                    } else if (strategy === 'quarterly' && i % 3 === 0) {
                        needsRebalance = true;
                    } else if (strategy === 'threshold5') {
                        if (Math.abs(stockWeight - targetStocks) > 0.05) {
                            needsRebalance = true;
                        }
                    }

                    if (needsRebalance) {
                        stockVal = totalVal * targetStocks;
                        bondVal = totalVal * targetBonds;
                        trades++;
                    }

                    history.push(totalVal);
                }

                const finalValue = history[history.length - 1];
                const cagr = (Math.pow(finalValue / initialCapital, 1 / years) - 1) * 100;

                document.getElementById('stat-final-value').textContent = formatter.format(finalValue);
                document.getElementById('stat-cagr').textContent = cagr.toFixed(2) + '%';
                document.getElementById('stat-trades').textContent = trades;

                drawChart(history);
            }

            function drawChart(data) {
                const width = canvas.parentElement.clientWidth;
                const height = canvas.parentElement.clientHeight;
                canvas.width = width;
                canvas.height = height;

                ctx.clearRect(0, 0, width, height);

                const maxVal = Math.max(...data);
                const minVal = Math.min(...data, 100000); // Floor at initial capital or lowest dip

                const padY = 20;
                const rangeY = maxVal - minVal;

                ctx.beginPath();
                ctx.moveTo(0, height - padY - ((data[0] - minVal) / rangeY) * (height - padY * 2));

                for (let i = 1; i < data.length; i++) {
                    let x = (i / (data.length - 1)) * width;
                    let y = height - padY - ((data[i] - minVal) / rangeY) * (height - padY * 2);
                    ctx.lineTo(x, y);
                }

                ctx.strokeStyle = '#4a8fe7';
                ctx.lineWidth = 2;
                ctx.stroke();

                // Fill area
                ctx.lineTo(width, height);
                ctx.lineTo(0, height);
                ctx.closePath();

                let gradient = ctx.createLinearGradient(0, 0, 0, height);
                gradient.addColorStop(0, 'rgba(74, 143, 231, 0.3)');
                gradient.addColorStop(1, 'rgba(74, 143, 231, 0.0)');

                ctx.fillStyle = gradient;
                ctx.fill();
            }

            // Initial run
            window.addEventListener('resize', runSimulation);
            btn.addEventListener('click', runSimulation);
            runSimulation();
        });
  </script>
