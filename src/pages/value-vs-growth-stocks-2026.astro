      background-color: var(--bg-color);
      color: var(--text-main);
      line-height: 1.6;
    }

    /* Sticky Nav */
    nav {
      position: sticky;
      top: 0;
      z-index: 1000;
      background: rgba(6, 10, 18, 0.85);
