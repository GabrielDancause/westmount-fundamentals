    <div class="stat-card">
      <div class="stat-label">VUG (Growth) YTD</div>
      <div class="stat-value ${vug.ytdReturn >= 0 ? 'pos' : 'neg'}">${formatPct(vug.ytdReturn)}</div>
      <div class="stat-sub">P/E: ${formatNum(vug.peRatio)} | Yield: ${formatPct(vug.yield)}</div>
    </div>
  `;

  // Render Table
  const tableBody = document.getElementById('tableBody');
  let currentSort = { col: 'symbol', dir: 'asc' };
  let currentFilter = 'all';

  function renderTable() {
    let filtered = dbData.holdings;
    if (currentFilter !== 'all') {
      filtered = filtered.filter(h => h.type === currentFilter);
    }

    const term = document.getElementById('searchInput').value.toLowerCase();
    if (term) {
      filtered = filtered.filter(h => h.symbol.toLowerCase().includes(term) || h.name.toLowerCase().includes(term));
    }

    filtered.sort((a, b) => {
      let valA = a[currentSort.col];
      let valB = b[currentSort.col];

      if (valA === null || valA === undefined) return 1;
      if (valB === null || valB === undefined) return -1;

      if (typeof valA === 'string') {
        return currentSort.dir === 'asc' ? valA.localeCompare(valB) : valB.localeCompare(valA);
      }
      return currentSort.dir === 'asc' ? valA - valB : valB - valA;
    });

    tableBody.innerHTML = filtered.map(h => `
      <tr>
        <td class="name-col"><span class="ticker">${h.symbol}</span> ${h.name}</td>
        <td><span class="type-badge ${h.type === 'Value' ? 'type-value' : 'type-growth'}">${h.type}</span></td>
        <td>${formatNum(h.peRatio)}</td>
        <td>${formatNum(h.pbRatio)}</td>
        <td>${formatPct(h.yield)}</td>
        <td class="${h.ytdReturn >= 0 ? 'pos' : 'neg'}">${formatPct(h.ytdReturn)}</td>
      </tr>
    `).join('');
  }

  // Events
  document.getElementById('searchInput').addEventListener('input', renderTable);

  document.querySelectorAll('.filter-btn').forEach(btn => {
    btn.addEventListener('click', (e) => {
      document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
      e.target.classList.add('active');
      currentFilter = e.target.dataset.filter;
      renderTable();
    });
  });

  document.querySelectorAll('th[data-sort]').forEach(th => {
    th.addEventListener('click', (e) => {
      const col = e.target.dataset.sort;
      if (currentSort.col === col) {
        currentSort.dir = currentSort.dir === 'asc' ? 'desc' : 'asc';
      } else {
        currentSort.col = col;
        currentSort.dir = 'desc'; // Default to desc for numbers
      }
      renderTable();
    });
  });

  renderTable();

  // Render Chart
  const ctx = document.getElementById('performanceChart').getContext('2d');

  // Normalize historical data to start at 100
  const vtvHist = dbData.historical.vtv;
  const vugHist = dbData.historical.vug;

  // Need matching dates. VTV and VUG should have same dates if fetched together by month.
  const labels = vtvHist.map(d => d.date.substring(0, 7)); // YYYY-MM

  const vtvStart = vtvHist[0].close;
  const vugStart = vugHist[0].close;

  const vtvData = vtvHist.map(d => (d.close / vtvStart) * 100);
  const vugData = vugHist.map(d => (d.close / vugStart) * 100);

  new Chart(ctx, {
    type: 'line',
    data: {
      labels: labels,
      datasets: [
        {
          label: 'VTV (Value)',
          data: vtvData,
          borderColor: '#38bdf8',
          backgroundColor: 'rgba(56, 189, 248, 0.1)',
          borderWidth: 2,
          pointRadius: 0,
          fill: true,
          tension: 0.2
        },
        {
          label: 'VUG (Growth)',
          data: vugData,
          borderColor: '#fbbf24',
          backgroundColor: 'rgba(251, 191, 36, 0.1)',
          borderWidth: 2,
          pointRadius: 0,
          fill: true,
          tension: 0.2
        }
      ]
    },
    options: {
      responsive: true,
      maintainAspectRatio: false,
      interaction: {
        mode: 'index',
        intersect: false,
      },
      plugins: {
        legend: {
          labels: { color: '#c8d0de', font: { family: 'Inter' } }
        },
        tooltip: {
          backgroundColor: '#0a1020',
          titleColor: '#fff',
          bodyColor: '#c8d0de',
          borderColor: '#152040',
          borderWidth: 1,
          callbacks: {
            label: function(context) {
              return context.dataset.label + ': ' + context.parsed.y.toFixed(2);
            }
          }
        }
      },
      scales: {
        x: {
          grid: { color: 'rgba(255,255,255,0.05)' },
          ticks: { color: '#5a6a80', maxTicksLimit: 10 }
        },
        y: {
          grid: { color: 'rgba(255,255,255,0.05)' },
          ticks: { color: '#5a6a80' },
          title: { display: true, text: 'Growth of $100', color: '#5a6a80' }
        }
      }
    }
  });

  // Render FAQs
  const faqContainer = document.querySelector('.faq-list');
  faqContainer.innerHTML = faqs.map(f => `
    <div class="faq-item">
      <h3>${f.q}</h3>
      <p>${f.a}</p>
    </div>
  `).join('');
  </script>

  
