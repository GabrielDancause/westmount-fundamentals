  <script is:inline>
const etfData = [{"symbol":"QQQ","name":"Invesco QQQ Trust, Series 1","price":597.26,"expenseRatio":0.18000001,"yield":0.45999999999999996,"aum":395032887296,"return3y":88.20957553298675,"return5y":81.86455668889505},{"symbol":"SCHG","name":"Schwab U.S. Large-Cap Growth ET","price":30.24,"expenseRatio":0.04,"yield":0.38,"aum":50521731072,"return3y":85.31547465844355,"return5y":77.05058355504018},{"symbol":"MGK","name":"Vanguard Mega Cap Growth ETF","price":383.41,"expenseRatio":0.05,"yield":0.37,"aum":29308968960,"return3y":86.57220229030844,"return5y":76.9214910627291},{"symbol":"VONG","name":"Vanguard Russell 1000 Growth ET","price":114.07,"expenseRatio":0.059999997,"yield":0.47999998000000005,"aum":47037652992,"return3y":82.65913911853555,"return5y":76.47757378175343},{"symbol":"IWF","name":"iShares Russell 1000 Growth Fun","price":443.3,"expenseRatio":0.18000001,"yield":0.38,"aum":116506607616,"return3y":82.19288756780236,"return5y":75.68790126729819},{"symbol":"VUG","name":"Vanguard Growth ETF","price":455.3,"expenseRatio":0.029999999000000003,"yield":0.44,"aum":335907094528,"return3y":83.25560045523804,"return5y":70.1116919997642}];

        let currentSort = { column: 'return5y', asc: false };

        function formatVal(val, type) {
            if (val === null || val === undefined) return 'N/A';
            if (type === 'currency') return '$' + val.toLocaleString(undefined, {minimumFractionDigits: 2, maximumFractionDigits: 2});
            if (type === 'percent') {
                return val.toFixed(2) + '%';
            }
            if (type === 'return') {
                const prefix = val > 0 ? '+' : '';
                return prefix + val.toFixed(2) + '%';
            }
            if (type === 'aum') {
                if (val >= 1e12) return '$' + (val / 1e12).toFixed(2) + 'T';
                if (val >= 1e9) return '$' + (val / 1e9).toFixed(2) + 'B';
                if (val >= 1e6) return '$' + (val / 1e6).toFixed(2) + 'M';
                return '$' + val.toLocaleString();
            }
            return val;
        }

        function renderTable(data) {
            const tbody = document.getElementById('tableBody');
            tbody.innerHTML = '';

            data.forEach(etf => {
                const tr = document.createElement('tr');

                const return3yClass = etf.return3y > 0 ? 'positive' : (etf.return3y < 0 ? 'negative' : '');
                const return5yClass = etf.return5y > 0 ? 'positive' : (etf.return5y < 0 ? 'negative' : '');

                tr.innerHTML = `
                    <td>
                        <span class="ticker">${etf.symbol}</span>
                        <span class="fund-name">${etf.name}</span>
                    </td>
                    <td>${formatVal(etf.price, 'currency')}</td>
                    <td>${formatVal(etf.expenseRatio, 'percent')}</td>
                    <td>${formatVal(etf.yield, 'percent')}</td>
                    <td>${formatVal(etf.aum, 'aum')}</td>
                    <td class="${return3yClass}">${formatVal(etf.return3y, 'percent')}</td>
                    <td class="${return5yClass}">${formatVal(etf.return5y, 'percent')}</td>
                `;
                tbody.appendChild(tr);
            });
        }

        function sortTable(column, keepSort = false) {
            if (currentSort.column === column && !keepSort) {
                currentSort.asc = !currentSort.asc;
            } else if (!keepSort) {
                currentSort.column = column;
                currentSort.asc = column === 'symbol' || column === 'name';
            }

            const sorted = [...etfData].sort((a, b) => {
                let valA = a[column];
                let valB = b[column];

                if (valA === null) valA = currentSort.asc ? Infinity : -Infinity;
                if (valB === null) valB = currentSort.asc ? Infinity : -Infinity;

                if (typeof valA === 'string') {
                    return currentSort.asc ? valA.localeCompare(valB) : valB.localeCompare(valA);
                }
                return currentSort.asc ? valA - valB : valB - valA;
            });

            const searchInput = document.getElementById('searchInput').value.toLowerCase();
            const filtered = sorted.filter(etf =>
                etf.symbol.toLowerCase().includes(searchInput) ||
                etf.name.toLowerCase().includes(searchInput)
            );

            renderTable(filtered);
        }

        document.getElementById('searchInput').addEventListener('input', (e) => {
            sortTable(currentSort.column, true);
        });

        // Initialize table
        sortTable('return5y');

        // Initialize Chart
        const ctx = document.getElementById('returnsChart').getContext('2d');

        // Prepare chart data sorted by 5y return
        const chartData = [...etfData].sort((a, b) => (b.return5y || 0) - (a.return5y || 0));

        new Chart(ctx, {
            type: 'bar',
            data: {
                labels: chartData.map(d => d.symbol),
                datasets: [
                    {
                        label: '3-Year Return (%)',
                        data: chartData.map(d => d.return3y),
                        backgroundColor: '#3b82f6',
                        borderRadius: 4
                    },
                    {
                        label: '5-Year Return (%)',
                        data: chartData.map(d => d.return5y),
                        backgroundColor: '#8b5cf6',
                        borderRadius: 4
                    }
                ]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: {
                        position: 'top',
                        labels: { color: '#94a3b8', font: { family: 'Inter' } }
                    },
                    tooltip: {
                        mode: 'index',
                        intersect: false,
                        backgroundColor: '#0a1020',
                        titleColor: '#fff',
                        bodyColor: '#e2e8f0',
                        borderColor: '#152040',
                        borderWidth: 1,
                        callbacks: {
                            label: function(context) {
                                return context.dataset.label + ': ' + context.parsed.y.toFixed(2) + '%';
                            }
                        }
                    }
                },
                scales: {
                    y: {
                        grid: { color: '#152040' },
                        ticks: {
                            color: '#94a3b8',
                            font: { family: 'JetBrains Mono' },
                            callback: function(value) { return value + '%'; }
                        }
                    },
                    x: {
                        grid: { display: false },
                        ticks: {
                            color: '#94a3b8',
                            font: { family: 'Inter', weight: 'bold' }
                        }
                    }
                }
            }
        });
  </script>

  <section style="max-width:800px;margin:40px auto;padding:0 24px">
