                            <th onclick="sortTable('return3y')">3Y Return ↕</th>
                            <th onclick="sortTable('return5y')">5Y Return ↕</th>
                        </tr>
                    </thead>
                    <tbody id="tableBody">
                        <!-- Populated by JS -->
                    </tbody>
                </table>
            </div>
