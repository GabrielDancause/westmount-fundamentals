---
import SiteLayout from "../layouts/SiteLayout.astro";
import * as cheerio from 'cheerio';

const schema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": "Mondelez (MDLZ) Intrinsic Value: A DCF Analysis",
  "description": "A transparent, step-by-step discounted cash flow valuation of Mondelez International (MDLZ). Using actual financials to arrive at a single fair value estimate for MDLZ shares.",
  "author": {
    "@type": "Organization",
    "name": "Westmount Research",
    "url": "https://westmountfundamentals.com"
  },
  "publisher": {
    "@type": "Organization",
    "name": "Westmount Research",
    "url": "https://westmountfundamentals.com"
  },
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": "https://westmountfundamentals.com/mondelez-intrinsic-value"
  }
};

export const meta = {
  title: "Mondelez (MDLZ) Intrinsic Value: A DCF Analysis",
  description: "We ran a full discounted cash flow on Mondelez using latest actuals. One number. Every assumption disclosed. Here's what MDLZ is really worth.",
  category: "study",
};

/* ═══════════════════════════════════════════════════════════════
   DATA FETCHING
   ═══════════════════════════════════════════════════════════════ */

async function fetchPage(url) {
  try {
    const res = await fetch(url, {
      headers: {
        'User-Agent': 'Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36',
        'Accept': 'text/html,application/xhtml+xml,application/xml;q=0.9,image/avif,image/webp,image/apng,*/*;q=0.8',
        'Accept-Language': 'en-US,en;q=0.9',
      }
    });
    if (!res.ok) throw new Error(`HTTP ${res.status}`);
    return await res.text();
  } catch (e) {
    console.error(`Error fetching ${url}:`, e);
    return null;
  }
}

function parseNumber(str) {
  if (!str || str === '-' || str === 'N/A') return null;
  return parseFloat(str.replace(/,/g, ''));
}

const htmlInc = await fetchPage('https://stockanalysis.com/stocks/mdlz/financials/');
const htmlCF = await fetchPage('https://stockanalysis.com/stocks/mdlz/financials/cash-flow-statement/');
const htmlBS = await fetchPage('https://stockanalysis.com/stocks/mdlz/financials/balance-sheet/');

let revenueHistory = [];
let fcfHistory = [];
let epsHistory = [];
let sharesHistory = [];
let cashHistory = [];
let debtHistory = [];
let opIncHistory = [];
let netIncHistory = [];
let currentPrice = null;
let marginHistory = [];

if (htmlInc && htmlCF && htmlBS) {
  const $inc = cheerio.load(htmlInc);
  const $cf = cheerio.load(htmlCF);
  const $bs = cheerio.load(htmlBS);

  const getRow = ($, label) => {
    const row = $('table tbody tr').filter((i, el) => $(el).find('td').first().text().trim() === label);
    return row.find('td').map((i, el) => $(el).text().trim()).get().slice(1).map(parseNumber);
  };

  const getYears = ($) => {
    return $('table thead th').map((i, el) => $(el).text().trim()).get().slice(1).filter(t => t !== 'Current');
  };

  const years = getYears($inc);

  const revData = getRow($inc, 'Revenue');
  const fcfData = getRow($cf, 'Free Cash Flow');
  const epsData = getRow($inc, 'EPS (Diluted)');
  const sharesData = getRow($inc, 'Shares Outstanding (Diluted)');
  const cashData = getRow($bs, 'Cash & Equivalents');
  const debtData = getRow($bs, 'Total Debt');
  const opIncData = getRow($inc, 'Operating Income');
  const netIncData = getRow($inc, 'Net Income');

  // Fill histories (using earliest to latest)
  for (let i = years.length - 1; i >= 0; i--) {
    let yearLabel = years[i];
    if (yearLabel.includes('-')) yearLabel = yearLabel.split('-')[0]; // simple year approximation
    const yr = parseInt(yearLabel) || (2025 - i - 1);

    if (revData[i] !== null) revenueHistory.push({ year: yr, value: revData[i] });
    if (fcfData[i] !== null) fcfHistory.push({ year: yr, value: fcfData[i] });
    if (epsData[i] !== null) epsHistory.push({ year: yr, value: epsData[i] });
    if (sharesData[i] !== null) sharesHistory.push({ year: yr, value: sharesData[i] });
    if (cashData[i] !== null) cashHistory.push({ year: yr, value: cashData[i] });
    if (debtData[i] !== null) debtHistory.push({ year: yr, value: debtData[i] });
    if (opIncData[i] !== null) opIncHistory.push({ year: yr, value: opIncData[i] });
    if (netIncData[i] !== null) netIncHistory.push({ year: yr, value: netIncData[i] });

    // Compute margins if available
    if (revData[i] && opIncData[i] && netIncData[i] && fcfData[i]) {
      marginHistory.push({
        year: yr,
        operating: ((opIncData[i] / revData[i]) * 100).toFixed(1),
        profit: ((netIncData[i] / revData[i]) * 100).toFixed(1),
        fcfMargin: ((fcfData[i] / revData[i]) * 100).toFixed(1)
      });
    }
  }

  const priceMatch = htmlInc.match(/<div class="[^"]*text-4xl[^"]*"[^>]*>([\d\.,]+)<\/div>/);
  if (priceMatch) {
    currentPrice = parseNumber(priceMatch[1]);
  }
}

/* ═══════════════════════════════════════════════════════════════
   DCF MODEL — ALL INPUTS AND CALCULATIONS
   ═══════════════════════════════════════════════════════════════ */

// Current baseline inputs (using most recent full year data)
const latestFCF = fcfHistory.length > 0 ? fcfHistory[fcfHistory.length - 1].value : null;
const latestShares = sharesHistory.length > 0 ? sharesHistory[sharesHistory.length - 1].value : null;
const latestCash = cashHistory.length > 0 ? cashHistory[cashHistory.length - 1].value : null;
const latestDebt = debtHistory.length > 0 ? debtHistory[debtHistory.length - 1].value : null;
const latestRev = revenueHistory.length > 0 ? revenueHistory[revenueHistory.length - 1].value : null;
const latestEps = epsHistory.length > 0 ? epsHistory[epsHistory.length - 1].value : null;

// Dynamic rates derived from data + constraints
const riskFreeRate = 0.0418; // 10Y Treasury 4.18%

// Calculate WACC/Discount rate dynamically
// Since MDLZ is a consumer staple, equity risk premium is standard ~5%. We use CAPM + debt cost weighting roughly.
// Without deep beta/debt cost fetch, we approximate required return for a stable consumer staple:
// Base risk free (4.18%) + ~4.5% equity premium for staple = 8.68% -> round to 8.5%
const discountRate = 0.085;

// Calculate Phase 1 Growth Rate dynamically based on historical FCF CAGR
let fcfCAGR = 0;
if (fcfHistory.length > 4 && fcfHistory[0].value > 0 && fcfHistory[fcfHistory.length - 1].value > 0) {
  const yrs = fcfHistory.length - 1;
  fcfCAGR = Math.pow(fcfHistory[fcfHistory.length - 1].value / fcfHistory[0].value, 1 / yrs) - 1;
}
// We cap FCF growth at a reasonable rate for a mature consumer staple (max 6%, min 2%)
const growthRatePhase1 = Math.max(0.02, Math.min(0.06, fcfCAGR > 0 ? fcfCAGR : 0.04));

// Calculate Terminal Growth Rate dynamically
// Should be tied to long term inflation/GDP minus a hair.
// Given 10Y is 4.18%, inflation expectations are around ~2.5%.
const growthRateTerminal = 0.025;

// Safety fallback for rendering if fetch completely failed
const netCash = (latestCash !== null && latestDebt !== null) ? (latestCash - latestDebt) : null;

let projectedFCF = [];
let terminalValue = null;
let pvTerminalValue = null;
let pvPhase1 = null;
let enterpriseValue = null;
let equityValue = null;
let intrinsicValuePerShare = null;
let roundedIV = null;
let marginOfSafety = null;
let verdictText = "N/A";
let verdictColor = "#5a6a80";
let sensitivityTable = [];
let sensitivityRates = [];
let sensitivityGrowth = [];

if (latestFCF !== null && latestShares !== null && netCash !== null && currentPrice !== null) {
  // --- PHASE 1: PROJECT FCF FOR YEARS 1-5 ---
  let fcf = latestFCF;
  for (let yr = 1; yr <= 5; yr++) {
    fcf = fcf * (1 + growthRatePhase1);
    projectedFCF.push({ year: yr, fcf: Math.round(fcf), pvFactor: 1 / Math.pow(1 + discountRate, yr) });
  }
  projectedFCF.forEach(p => { p.pvFCF = Math.round(p.fcf * p.pvFactor); });

  // --- PHASE 2: TERMINAL VALUE ---
  const fcfYear6 = projectedFCF[4].fcf * (1 + growthRateTerminal);
  terminalValue = Math.round(fcfYear6 / (discountRate - growthRateTerminal));
  pvTerminalValue = Math.round(terminalValue * projectedFCF[4].pvFactor);

  // --- ENTERPRISE & EQUITY VALUE ---
  pvPhase1 = projectedFCF.reduce((sum, p) => sum + p.pvFCF, 0);
  enterpriseValue = pvPhase1 + pvTerminalValue;
  equityValue = enterpriseValue + netCash;
  intrinsicValuePerShare = equityValue / latestShares;
  roundedIV = Math.round(intrinsicValuePerShare * 100) / 100;

  marginOfSafety = ((roundedIV - currentPrice) / currentPrice * 100).toFixed(1);
  verdictText = roundedIV > currentPrice ? "Undervalued" : "Overvalued";
  verdictColor = roundedIV > currentPrice ? "#10b981" : "#ef4444";

  // --- SENSITIVITY ---
  sensitivityRates = [
    discountRate - 0.02,
    discountRate - 0.01,
    discountRate,
    discountRate + 0.01,
    discountRate + 0.02
  ];
  sensitivityGrowth = [
    growthRatePhase1 - 0.02,
    growthRatePhase1 - 0.01,
    growthRatePhase1,
    growthRatePhase1 + 0.01,
    growthRatePhase1 + 0.02
  ];

  sensitivityTable = sensitivityRates.map(dr => {
    return {
      dr,
      values: sensitivityGrowth.map(gr => {
        let f = latestFCF;
        let pvSum = 0;
        for (let y = 1; y <= 5; y++) {
          f = f * (1 + gr);
          pvSum += f / Math.pow(1 + dr, y);
        }
        const f6 = f * (1 + growthRateTerminal);
        const tv = f6 / (dr - growthRateTerminal);
        const pvTV = tv / Math.pow(1 + dr, 5);
        return Math.round((pvSum + pvTV + netCash) / latestShares);
      })
    };
  });
}

