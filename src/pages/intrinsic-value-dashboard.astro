// Compute derived fields
const enriched = companies.map(c => {
  const margin = (c.iv && c.price) ? ((c.iv - c.price) / c.price * 100) : null;
  const verdict = margin !== null ? (margin > 0 ? "Undervalued" : "Overvalued") : "N/A";
  return { ...c, margin: margin !== null ? Math.round(margin * 10) / 10 : null, verdict };
}).sort((a, b) => (b.margin || -999) - (a.margin || -999));

const undervalued = enriched.filter(c => c.margin !== null && c.margin > 0);
const overvalued = enriched.filter(c => c.margin !== null && c.margin <= 0);
const totalCompanies = enriched.length;
