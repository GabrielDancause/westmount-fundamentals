        let currentData = [...rawData];
        let sortCol = 'date';
        let sortAsc = false;

        const tableBody = document.getElementById('tableBody');
        const searchInput = document.getElementById('searchInput');
        const sectorFilter = document.getElementById('sectorFilter');
        const roleFilter = document.getElementById('roleFilter');

        const currencyFmt = new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD', maximumFractionDigits: 0 });
        const numFmt = new Intl.NumberFormat('en-US');

        function renderTable() {
            tableBody.innerHTML = '';

            if (currentData.length === 0) {
                tableBody.innerHTML = '<tr><td colspan="7" style="text-align: center; color: var(--text-muted);">No insider buying found matching your criteria.</td></tr>';
                return;
            }

            currentData.forEach(row => {
                const tr = document.createElement('tr');
                tr.innerHTML = `
                    <td class="mono" style="color: var(--text-muted);">${row.date}</td>
                    <td>
                        <div style="font-weight: 500;">${row.companyName}</div>
                        <div class="ticker-badge" style="margin-top: 4px;">${row.ticker}</div>
                    </td>
                    <td style="font-weight: 500;">${row.insiderName}</td>
                    <td style="color: var(--text-muted); font-size: 0.85rem;">${row.title}</td>
                    <td class="mono">${numFmt.format(row.shares)}</td>
                    <td class="mono">${row.price ? currencyFmt.format(row.price) : 'N/A'}</td>
                    <td class="mono val-positive">${currencyFmt.format(row.value)}</td>
                `;
                tableBody.appendChild(tr);
            });
        }

        function filterAndSort() {
            const search = searchInput.value.toLowerCase();
            const sector = sectorFilter.value;
            const role = roleFilter.value;

            currentData = rawData.filter(d => {
                const matchSearch = d.ticker.toLowerCase().includes(search) ||
                                  d.companyName.toLowerCase().includes(search) ||
                                  d.insiderName.toLowerCase().includes(search);
                const matchSector = sector === '' || d.sector === sector;

                let matchRole = true;
                if (role !== '') {
                    if (role === 'Director') {
                        matchRole = d.title.includes('Director');
                    } else {
                        matchRole = d.title === role;
                    }
                }

                return matchSearch && matchSector && matchRole;
            });

            currentData.sort((a, b) => {
                let valA = a[sortCol];
                let valB = b[sortCol];

                if (sortCol === 'value' || sortCol === 'shares' || sortCol === 'price') {
                    valA = valA || 0;
                    valB = valB || 0;
                } else if (sortCol === 'date') {
                    valA = new Date(valA).getTime();
                    valB = new Date(valB).getTime();
                } else {
                    valA = String(valA).toLowerCase();
                    valB = String(valB).toLowerCase();
                }

                if (valA < valB) return sortAsc ? -1 : 1;
                if (valA > valB) return sortAsc ? 1 : -1;
                return 0;
            });

            renderTable();
        }

        // Event Listeners
        searchInput.addEventListener('input', filterAndSort);
        sectorFilter.addEventListener('change', filterAndSort);
        roleFilter.addEventListener('change', filterAndSort);

        document.querySelectorAll('th').forEach(th => {
            th.addEventListener('click', () => {
                const col = th.dataset.sort;
                if (!col) return;

                if (sortCol === col) {
                    sortAsc = !sortAsc;
                } else {
                    sortCol = col;
                    sortAsc = (col === 'date' || col === 'value' || col === 'shares') ? false : true;
                }

                // Update headers
                document.querySelectorAll('th').forEach(h => {
                    const text = h.innerText.replace(/ [▼▲]/, '');
                    if (h.dataset.sort === sortCol) {
                        h.innerText = text + (sortAsc ? ' ▲' : ' ▼');
                    } else if (h.dataset.sort) {
                        h.innerText = text;
                    }
                });

                filterAndSort();
            });
        });

        // Setup Chart
        const sectorData = rawData.reduce((acc, d) => {
            acc[d.sector] = (acc[d.sector] || 0) + d.value;
            return acc;
        }, {});

        const sortedSectors = Object.keys(sectorData).sort((a, b) => sectorData[b] - sectorData[a]).slice(0, 10);

        const ctx = document.getElementById('sectorChart').getContext('2d');
        new Chart(ctx, {
            type: 'bar',
            data: {
                labels: sortedSectors,
                datasets: [{
                    label: 'Total Value Bought ($)',
                    data: sortedSectors.map(s => sectorData[s]),
                    backgroundColor: '#4a8fe7',
                    borderRadius: 4
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: { display: false },
                    tooltip: {
                        callbacks: {
                            label: (context) => currencyFmt.format(context.raw)
                        }
                    }
                },
                scales: {
                    y: {
                        beginAtZero: true,
                        grid: { color: 'rgba(21, 32, 64, 0.5)' },
                        ticks: {
                            color: '#9ca3af',
                            callback: (value) => '$' + (value / 1000000).toFixed(1) + 'M'
                        }
                    },
                    x: {
                        grid: { display: false },
                        ticks: { color: '#9ca3af', maxRotation: 45, minRotation: 45 }
                    }
                }
            }
        });

        // Initial render
        renderTable();
  </script>

  
