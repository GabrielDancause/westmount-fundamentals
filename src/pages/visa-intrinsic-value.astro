---
import SiteLayout from "../layouts/SiteLayout.astro";

// --- METADATA ---
export const meta = {
  title: "Visa Inc. (V) Intrinsic Value - Gemini's DCF Analysis",
  description: "An independent discounted cash flow (DCF) intrinsic value analysis of Visa Inc. (V) compiled entirely by Gemini 2.5 Pro.",
  category: "study",
  published: "2026-03-18",
};

// --- DATA & ASSUMPTIONS (FY2025 Actuals) ---
// Visa numbers based on recent financial data fetched.
// FCF Growth (Y1-Y5): 11%. Visa operates a phenomenal toll-road business. While macro headwinds exist, 11% is deeply justified by their pricing power, B2B expansion, and Value-Added Services (VAS) growth.
// Discount Rate (WACC): 8.5%. With a 10-year treasury at 4.18%, Visa's incredibly low beta, and near-monopoly characteristics, 8.5% is an appropriate hurdle rate for such a low-risk, high-margin cash compounder.
// Terminal Growth: 3.5%. Visa's volumes are intrinsically linked to global inflation and GDP growth. They will grow at or slightly above global GDP into perpetuity.

const baseFCF = 22928; // in Millions
const sharesOut = 2180; // Diluted shares outstanding
const currentPrice = 301.37;
const cashAndShortTerm = 15240;
const totalDebt = 21177;
const netCash = cashAndShortTerm - totalDebt; // This will be negative (net debt)

const fcfGrowthRate = 0.11;
const discountRate = 0.085;
const terminalGrowthRate = 0.035;

// --- YEAR 1 TO 5 PROJECTIONS ---
const projections = [];
let prevFCF = baseFCF;

for (let i = 1; i <= 5; i++) {
  const projectedFCF = prevFCF * (1 + fcfGrowthRate);
  const discountFactor = Math.pow(1 + discountRate, i);
  const pvOfFCF = projectedFCF / discountFactor;

  projections.push({
    year: `Year ${i}`,
    fcf: projectedFCF,
    pv: pvOfFCF
  });

  prevFCF = projectedFCF;
}

const sumPvFcf = projections.reduce((sum, p) => sum + p.pv, 0);

// --- TERMINAL VALUE ---
const year5FCF = projections[4].fcf;
const terminalValue = (year5FCF * (1 + terminalGrowthRate)) / (discountRate - terminalGrowthRate);
const pvTerminalValue = terminalValue / Math.pow(1 + discountRate, 5);

// --- INTRINSIC VALUE CALCULATION ---
const enterpriseValue = sumPvFcf + pvTerminalValue;
const totalEquityValue = enterpriseValue + netCash;
const intrinsicValuePerShare = totalEquityValue / sharesOut;

// Value vs Current Price
const marginOfSafety = ((intrinsicValuePerShare - currentPrice) / currentPrice) * 100;
const isUndervalued = intrinsicValuePerShare > currentPrice;

// --- SENSITIVITY MATRIX ---
const sensitivityDiscountRates = [0.075, 0.080, 0.085, 0.090, 0.095];
const sensitivityGrowthRates = [0.025, 0.030, 0.035, 0.040, 0.045];

const sensitivityMatrix = sensitivityGrowthRates.map(g => {
  return {
    growthRate: g,
    values: sensitivityDiscountRates.map(d => {
      // Re-calculate TV and PV with new rates
      const currentTerminalValue = (year5FCF * (1 + g)) / (d - g);
      const currentPvTerminalValue = currentTerminalValue / Math.pow(1 + d, 5);

      // Re-calculate PV of FCFs with new discount rate
      let currentSumPvFcf = 0;
      let tempFcf = baseFCF;
      for (let i = 1; i <= 5; i++) {
        tempFcf = tempFcf * (1 + fcfGrowthRate);
        currentSumPvFcf += tempFcf / Math.pow(1 + d, i);
      }

      const currentEV = currentSumPvFcf + currentPvTerminalValue;
      const currentEquity = currentEV + netCash;
      const currentIV = currentEquity / sharesOut;

      return currentIV;
    })
  };
});

// Formatting helpers
const formatMoney = (val) => new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD', minimumFractionDigits: 2, maximumFractionDigits: 2 }).format(val);
const formatMillions = (val) => '$' + new Intl.NumberFormat('en-US', { maximumFractionDigits: 0 }).format(val) + 'M';
const formatPercent = (val) => (val * 100).toFixed(1) + '%';

// --- SCHEMA ---
const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Article",
      "headline": meta.title,
      "description": meta.description,
      "author": {
        "@type": "Organization",
        "name": "Gemini 2.5 Pro"
      },
      "publisher": {
        "@type": "Organization",
        "name": "Westmount Fundamentals",
        "logo": {
          "@type": "ImageObject",
          "url": "https://westmountfundamentals.com/logo.png"
        }
      },
      "mainEntityOfPage": {
        "@type": "WebPage",
        "@id": "https://westmountfundamentals.com/visa-intrinsic-value"
      }
    },
    {
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "Why did Gemini pick an 11% growth rate for Visa?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Visa's core payments network acts as a global tollbooth. While consumer spending growth is stable, their expansion into B2B payments, cross-border transactions, and high-margin Value-Added Services (VAS) supports an 11% compound annual FCF growth over the next five years."
          }
        },
        {
          "@type": "Question",
          "name": "What discount rate was used for Visa's DCF?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "An 8.5% discount rate was used. This relatively low WACC reflects Visa's extraordinarily strong business model, high operating margins (often exceeding 65%), and low revenue volatility compared to the broader market, offsetting the current 4.18% risk-free rate."
          }
        },
        {
          "@type": "Question",
          "name": "What are the biggest risks to Visa's intrinsic value?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "The primary risks include antitrust regulations (such as the Credit Card Competition Act), disintermediation by alternative payment networks (like FedNow or digital wallets bypassing traditional rails), and global economic recessions dampening total payment volume."
          }
        }
      ]
    }
  ]
};
---<SiteLayout site="westmount" title={meta.title} description={meta.description} canonical="https://westmountfundamentals.com/visa-intrinsic-value" schema={schema}>
  <div class="page-content">
    <div class="container">

      <div class="gemini-header">
        <div class="gemini-badge">COMPILED BY GEMINI 2.5 PRO</div>
        <h1>Visa Inc. (V) Intrinsic Value</h1>
        <p class="subtitle">An independent two-stage DCF analysis by a frontier AI model.</p>
      </div>

      <div class="verdict-card">
        <div class="verdict-header">
          <h2>Fair Value Estimate</h2>
        </div>
        <div class="verdict-body">
          <div class="verdict-main">
            <span class="iv-value">{formatMoney(intrinsicValuePerShare)}</span>
            <span class="iv-label">per share</span>
          </div>
          <div class="verdict-stats">
            <div class="stat">
              <span class="stat-label">Current Price</span>
              <span class="stat-value">{formatMoney(currentPrice)}</span>
            </div>
            <div class="stat">
              <span class="stat-label">Margin of Safety</span>
              <span class={`stat-value ${isUndervalued ? 'positive' : 'negative'}`}>
                {isUndervalued ? '+' : ''}{marginOfSafety.toFixed(2)}%
              </span>
            </div>
            <div class="stat">
              <span class="stat-label">Verdict</span>
              <span class={`badge ${isUndervalued ? 'positive' : 'negative'}`}>
                {isUndervalued ? 'UNDERVALUED' : 'OVERVALUED'}
              </span>
            </div>
          </div>
        </div>
        <div class="verdict-footer">
          <p>Based on FY2025 actuals. Data via S&P Global (Mar 17, 2026).</p>
        </div>
      </div>

      <section class="content-section">
        <h2>The AI Thesis: Why Visa's Moat is Indestructible</h2>
        <p>Visa operates the world's premier electronic payments network, effectively functioning as a global tollbooth on consumer spending. Despite macroeconomic headwinds and inflationary pressures, Visa's business model is inherently insulated: as prices rise, so do nominal transaction values, translating directly to revenue growth with minimal incremental capital expenditure.</p>
        <p>While skeptics point to regulatory pressure and the rise of alternative payment networks, my analysis reveals a different truth. The sheer scale of Visa's two-sided network—billions of cards and millions of merchants—creates a nearly insurmountable barrier to entry. Furthermore, their strategic pivot towards high-margin Value-Added Services (VAS), such as fraud management and data analytics, provides a massive runway for sustained double-digit free cash flow compounding. Visa is not just a payment rail; it's a global financial operating system.</p>
      </section>

      <section class="content-section">
        <h2>My Assumptions & Rationale</h2>

        <div class="assumption-grid">
          <div class="assumption-card">
            <div class="card-title">FCF Growth Rate (Y1-Y5)</div>
            <div class="card-value">{formatPercent(fcfGrowthRate)}</div>
            <p><strong>Rationale:</strong> An 11% compound annual growth rate in Free Cash Flow is highly achievable. While consumer volume growth may stabilize in the mid-single digits, Visa's aggressive expansion into B2B payments, cross-border transactions, and their rapidly scaling VAS segment provides tremendous margin leverage. The transition from cash to digital globally is still a massive tailwind.</p>
          </div>

          <div class="assumption-card">
            <div class="card-title">Discount Rate (WACC)</div>
            <div class="card-value">{formatPercent(discountRate)}</div>
            <p><strong>Rationale:</strong> 8.5% is an appropriate discount rate for an exceptionally high-quality business. Visa commands incredible operating margins (consistently above 65%) and operates with extremely low capital intensity. With the 10-year Treasury rate at 4.18% and Visa's historically low beta, the risk premium demanded by investors is structurally lower than the broader market.</p>
          </div>

          <div class="assumption-card">
            <div class="card-title">Terminal Growth Rate</div>
            <div class="card-value">{formatPercent(terminalGrowthRate)}</div>
            <p><strong>Rationale:</strong> 3.5% reflects Visa's enduring economic moat. As an inflation-protected asset whose fortunes are tied to global consumer spending, Visa will sustainably grow at a rate equal to or slightly exceeding long-term global nominal GDP growth. Their pricing power ensures terminal cash flows remain robust indefinitely.</p>
          </div>
        </div>
      </section>

      <section class="content-section">
        <h2>Discounted Cash Flow (DCF) Projections</h2>
        <p>Starting with the FY2025 base FCF of {formatMillions(baseFCF)}, the table below outlines the 5-year projection discounted back to Present Value (PV) using the {formatPercent(discountRate)} WACC.</p>

        <div class="table-container">
          <table>
            <thead>
              <tr>
                <th>Period</th>
                <th>Projected FCF</th>
                <th>PV Factor ({formatPercent(discountRate)})</th>
                <th>Present Value</th>
              </tr>
            </thead>
            <tbody>
              {projections.map((p, index) => (
                <tr>
                  <td>{p.year}</td>
                  <td>{formatMillions(p.fcf)}</td>
                  <td>{(1 / Math.pow(1 + discountRate, index + 1)).toFixed(4)}</td>
                  <td>{formatMillions(p.pv)}</td>
                </tr>
              ))}
              <tr class="highlight-row">
                <td colspan="3"><strong>Sum of PV of FCFs (Years 1-5)</strong></td>
                <td><strong>{formatMillions(sumPvFcf)}</strong></td>
              </tr>
            </tbody>
          </table>
        </div>
      </section>

      <section class="content-section">
        <h2>Terminal & Final Valuation Math</h2>
        <p>The Terminal Value captures all future cash flows beyond Year 5, calculated using the Gordon Growth Model and discounted to the present.</p>

        <div class="math-card">
          <div class="math-row">
            <span>Year 5 FCF</span>
            <span>{formatMillions(year5FCF)}</span>
          </div>
          <div class="math-row">
            <span>Terminal Value (TV) Calculation</span>
            <span>({formatMillions(year5FCF)} * {1 + terminalGrowthRate}) / ({discountRate} - {terminalGrowthRate})</span>
          </div>
          <div class="math-row">
            <span>Terminal Value</span>
            <span>{formatMillions(terminalValue)}</span>
          </div>
          <div class="math-row highlight">
            <span>PV of Terminal Value</span>
            <span>{formatMillions(pvTerminalValue)}</span>
          </div>
        </div>

        <p style="margin-top: 2rem;">Adding it all together with Net Cash:</p>

        <div class="math-card">
          <div class="math-row">
            <span>Sum of PV of FCFs (Years 1-5)</span>
            <span>{formatMillions(sumPvFcf)}</span>
          </div>
          <div class="math-row">
            <span>+ PV of Terminal Value</span>
            <span>{formatMillions(pvTerminalValue)}</span>
          </div>
          <div class="math-row">
            <span><strong>= Enterprise Value</strong></span>
            <span><strong>{formatMillions(enterpriseValue)}</strong></span>
          </div>
          <div class="math-row">
            <span>+ Net Cash (Cash - Debt)</span>
            <span>{formatMillions(netCash)}</span>
          </div>
          <div class="math-row highlight">
            <span><strong>= Total Equity Value</strong></span>
            <span><strong>{formatMillions(totalEquityValue)}</strong></span>
          </div>
          <div class="math-row">
            <span>÷ Shares Outstanding</span>
            <span>{sharesOut.toLocaleString()}M</span>
          </div>
          <div class="math-row result">
            <span><strong>Intrinsic Value Per Share</strong></span>
            <span><strong>{formatMoney(intrinsicValuePerShare)}</strong></span>
          </div>
        </div>
      </section>

      <section class="content-section">
        <h2>Sensitivity Matrix</h2>
        <p>Because intrinsic value is highly sensitive to input variables, the matrix below explores how changes in the Discount Rate and Terminal Growth Rate affect Visa's estimated value per share.</p>

        <div class="table-container sensitivity-table">
          <table>
            <thead>
              <tr>
                <th rowspan="2" class="corner-cell">Terminal<br/>Growth</th>
                <th colspan="5" class="header-cell">Discount Rate (WACC)</th>
              </tr>
              <tr>
                {sensitivityDiscountRates.map(d => <th>{formatPercent(d)}</th>)}
              </tr>
            </thead>
            <tbody>
              {sensitivityMatrix.map(row => (
                <tr>
                  <th class="row-header">{formatPercent(row.growthRate)}</th>
                  {row.values.map(val => (
                    <td class={
                      val > currentPrice * 1.15 ? "cell-undervalued" :
                      val < currentPrice * 0.85 ? "cell-overvalued" :
                      "cell-neutral"
                    }>
                      {formatMoney(val)}
                    </td>
                  ))}
                </tr>
              ))}
            </tbody>
          </table>
          <div class="matrix-legend">
            <span class="legend-item"><span class="color-box cell-undervalued"></span> Undervalued (>15% Margin)</span>
            <span class="legend-item"><span class="color-box cell-neutral"></span> Fair Value</span>
            <span class="legend-item"><span class="color-box cell-overvalued"></span> Overvalued (&lt;-15% Margin)</span>
          </div>
        </div>
      </section>

      <section class="content-section risks-section">
        <h2>Risks & Bear Case</h2>
        <p>Even for a fortress compounder like Visa, systemic and structural risks must be heavily weighted in any valuation scenario:</p>
        <div class="risk-grid">
          <div class="risk-card">
            <h3>1. Regulatory Overreach & The CCCA</h3>
            <p>The Credit Card Competition Act (CCCA) aims to dismantle the Visa/Mastercard duopoly by forcing merchants to route transactions through alternative networks. If enacted, interchange revenues would plummet as merchants switch to the lowest-cost routing providers, materially compressing Visa's take-rates.</p>
          </div>
          <div class="risk-card">
            <h3>2. Disintermediation by Next-Gen Payment Rails</h3>
            <p>The global proliferation of real-time payment systems (like FedNow in the US, PIX in Brazil, or UPI in India) presents an existential threat to traditional credit card rails. If consumers increasingly bypass cards for direct account-to-account (A2A) transfers, Visa's transaction volume growth will stall permanently.</p>
          </div>
          <div class="risk-card">
            <h3>3. Global Macroeconomic Contraction</h3>
            <p>Visa's revenue model is a direct derivative of consumer spending velocity. In a protracted global recession characterized by high unemployment and depressed consumer sentiment, total payment volumes will shrink, exposing the cyclicality underlying their secular growth narrative.</p>
          </div>
        </div>
      </section>

      <section class="content-section faq-section">
        <h2>Frequently Asked Questions</h2>

        <div class="faq-item">
          <h3>Why did Gemini pick an 11% growth rate for Visa?</h3>
          <p>Visa's core payments network acts as a global tollbooth. While consumer spending growth is stable, their expansion into B2B payments, cross-border transactions, and high-margin Value-Added Services (VAS) supports an 11% compound annual FCF growth over the next five years.</p>
        </div>

        <div class="faq-item">
          <h3>What discount rate was used for Visa's DCF?</h3>
          <p>An 8.5% discount rate was used. This relatively low WACC reflects Visa's extraordinarily strong business model, high operating margins (often exceeding 65%), and low revenue volatility compared to the broader market, offsetting the current 4.18% risk-free rate.</p>
        </div>

        <div class="faq-item">
          <h3>What are the biggest risks to Visa's intrinsic value?</h3>
          <p>The primary risks include antitrust regulations (such as the Credit Card Competition Act), disintermediation by alternative payment networks (like FedNow or digital wallets bypassing traditional rails), and global economic recessions dampening total payment volume.</p>
        </div>
      </section>

      <div class="disclaimer-box">
        <p><strong>Disclaimer:</strong> The numbers presented on this page are for educational and entertainment purposes only. They are the result of a deterministic mathematical model fed with assumptions generated by an Artificial Intelligence (Gemini 2.5 Pro). This does not constitute investment advice. Always conduct your own due diligence before investing in the stock market.</p>
      </div>

    </div>
  </div>
</SiteLayout>

