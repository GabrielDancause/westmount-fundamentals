        }
      },
      {
        "@type": "Question",
        "name": "What is a good EBITDA margin?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "A good EBITDA margin varies significantly by industry. Software and technology companies often achieve margins of 25-40%, while retail and restaurants typically operate at 5-15%. Generally, an EBITDA margin above 20% is considered strong, but always compare within the same sector for meaningful analysis."
        }
      },
      {
        "@type": "Question",
        "name": "What is the difference between EBITDA and net income?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "EBITDA excludes interest, taxes, depreciation, and amortization, showing operating performance before these costs. Net income is the bottom line after all expenses. EBITDA is useful for comparing companies with different capital structures and tax situations, while net income shows actual profitability after all obligations."
        }
      },
      {
        "@type": "Question",
        "name": "What does EV/EBITDA ratio tell you?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "The EV/EBITDA ratio (Enterprise Value to EBITDA) is a valuation multiple that compares a company's total value including debt to its operating earnings. A lower EV/EBITDA (under 10x) may indicate undervaluation, while a higher ratio (over 15x) suggests the market expects strong future growth. The S&P 500 average is roughly 12-14x."
        }
      }
    ]
  }
