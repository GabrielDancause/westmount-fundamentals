    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "What is EBITDA and what does it stand for?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "EBITDA stands for Earnings Before Interest, Taxes, Depreciation, and Amortization. It is a financial metric used to evaluate a company's operating performance by stripping out non-operating expenses like financing costs, tax environments, and non-cash charges. EBITDA provides a cleaner view of core business profitability."
        }
      },
      {
        "@type": "Question",
        "name": "How do you calculate EBITDA?",
