    }
  </script>
  <script is:inline src="https://cdn.jsdelivr.net/npm/chart.js"></script>
  <script is:inline>
window.__INITIAL_DATA__ = {"sectors":[{"symbol":"XLK","name":"Technology","type":"Growth","return1M":-0.970743519150412,"return3M":-4.665764878515689,"return6M":5.546955853278234,"return1Y":34.126678119056926,"currentPrice":139.75999450683594},{"symbol":"XLV","name":"Healthcare","type":"Defensive","return1M":-2.8913909221093563,"return3M":-0.0717738576890371,"return6M":11.099011327920827,"return1Y":4.854167093249736,"currentPrice":153.14999389648438},{"symbol":"XLF","name":"Financials","type":"Cyclical","return1M":-7.740503277117518,"return3M":-6.743664141774844,"return6M":-5.742796463960269,"return1Y":5.145979272276597,"currentPrice":50.060001373291016},{"symbol":"XLY","name":"Consumer Discretionary","type":"Cyclical","return1M":-3.008725728143569,"return3M":-4.418275091630154,"return6M":-3.0251670453348685,"return1Y":16.54361504869814,"currentPrice":114.44000244140625},{"symbol":"XLC","name":"Communication Services","type":"Growth","return1M":1.399442888123855,"return3M":0.21343806527981862,"return6M":2.2295746084287336,"return1Y":21.826672664603496,"currentPrice":117.37999725341797},{"symbol":"XLI","name":"Industrials","type":"Cyclical","return1M":-1.82468445372687,"return3M":9.98835700511966,"return6M":12.395054849227291,"return1Y":30.664010645972628,"currentPrice":170.02000427246094},{"symbol":"XLP","name":"Consumer Staples","type":"Defensive","return1M":-2.5244498056300317,"return3M":9.253125440919401,"return6M":6.391959222273325,"return1Y":5.216644085332346,"currentPrice":85.72000122070312},{"symbol":"XLE","name":"Energy","type":"Cyclical","return1M":4.41314267440581,"return3M":21.080140877971886,"return6M":27.581450523255995,"return1Y":27.26024312605763,"currentPrice":55.599998474121094},{"symbol":"XLU","name":"Utilities","type":"Defensive","return1M":7.404851239121073,"return3M":7.528873426492412,"return6M":12.708786796105962,"return1Y":20.294533446925005,"currentPrice":46.560001373291016},{"symbol":"XLRE","name":"Real Estate","type":"Cyclical","return1M":2.2148046042004186,"return3M":4.708456724685614,"return6M":2.4343594413389713,"return1Y":3.1234965651684035,"currentPrice":42.91999816894531},{"symbol":"XLB","name":"Materials","type":"Cyclical","return1M":-3.164428861447984,"return3M":13.132231561553978,"return6M":8.387658783041955,"return1Y":16.910816823543275,"currentPrice":49.880001068115234}],"phase":"Early Expansion / Recovery","lastUpdated":"2026-03-11T09:21:13.721Z"};

    document.addEventListener('DOMContentLoaded', () => {
      const data = window.__INITIAL_DATA__;

      // Update Phase
      document.getElementById('current-phase').textContent = data.phase;

      // Populate Table
      const tbody = document.querySelector('#sector-table tbody');

      const formatReturn = (val) => {
        if (val === null || val === undefined) return 'N/A';
        const formatted = val.toFixed(2) + '%';
        const className = val >= 0 ? 'val-positive' : 'val-negative';
        const sign = val >= 0 ? '+' : '';
        return `<span class="${className}">${sign}${formatted}</span>`;
      };

      // Sort by 3M return
      const sortedSectors = [...data.sectors].sort((a, b) => (b.return3M || 0) - (a.return3M || 0));

      sortedSectors.forEach(sector => {
        const tr = document.createElement('tr');
        tr.innerHTML = `
          <td><strong>${sector.name}</strong></td>
          <td>${sector.symbol}</td>
          <td><span style="font-size: 0.8rem; padding: 2px 6px; background: #152040; border-radius: 4px;">${sector.type}</span></td>
          <td>${formatReturn(sector.return1M)}</td>
          <td>${formatReturn(sector.return3M)}</td>
          <td>${formatReturn(sector.return6M)}</td>
          <td>${formatReturn(sector.return1Y)}</td>
        `;
        tbody.appendChild(tr);
      });

      // Render Chart
      const ctx = document.getElementById('rotationChart').getContext('2d');

      const labels = sortedSectors.map(s => s.symbol);
      const returns1M = sortedSectors.map(s => s.return1M || 0);
      const returns3M = sortedSectors.map(s => s.return3M || 0);

      new Chart(ctx, {
        type: 'bar',
        data: {
          labels: labels,
          datasets: [
            {
              label: '1M Return (%)',
              data: returns1M,
              backgroundColor: 'rgba(74, 143, 231, 0.5)',
              borderColor: 'rgba(74, 143, 231, 1)',
              borderWidth: 1
            },
            {
              label: '3M Return (%)',
              data: returns3M,
              backgroundColor: 'rgba(46, 204, 113, 0.5)',
              borderColor: 'rgba(46, 204, 113, 1)',
              borderWidth: 1
            }
          ]
        },
        options: {
          responsive: true,
          maintainAspectRatio: false,
          scales: {
            y: {
              beginAtZero: true,
              grid: { color: '#152040' },
              ticks: { color: '#5a6a80' }
            },
            x: {
              grid: { color: '#152040' },
              ticks: { color: '#5a6a80' }
            }
          },
          plugins: {
            legend: {
              labels: { color: '#c8d0de' }
            }
          }
        }
      });
    });
  </script>

  <section style="max-width:800px;margin:40px auto;padding:0 24px">
    <h2 style="font-size:20px;color:var(--text-bright,#fff);margin-bottom:16px">Related Pages</h2>
