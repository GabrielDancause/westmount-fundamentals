---
import SiteLayout from "../layouts/SiteLayout.astro";

const schema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "When do stocks report earnings?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Publicly traded companies in the S&P 500 typically report earnings four times a year, roughly 2-6 weeks after the end of their fiscal quarter. This period is known as 'earnings season'."
      }
    },
    {
      "@type": "Question",
      "name": "How to use an earnings calendar 2026?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "An earnings calendar tracks when companies will release their quarterly financial results. You can use it to anticipate market volatility, compare expected EPS versus previous EPS, and filter by sector to see industry trends."
      }
    },
    {
      "@type": "Question",
      "name": "What time are earnings reports released?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Earnings reports are generally released outside of regular trading hours to avoid excessive market volatility. They usually occur Before Market Open (BMO) around 7:00 AM - 8:30 AM EST, or After Market Close (AMC) around 4:00 PM - 4:30 PM EST."
      }
    },
    {
      "@type": "Question",
      "name": "Where to find sp500 earnings calendar?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "You can find comprehensive S&P 500 earnings calendars on financial data sites like Westmount Fundamentals, Yahoo Finance, or the NASDAQ website. This page provides a complete, filterable view of all 500 companies."
      }
    },
    {
      "@type": "Question",
      "name": "What happens to stock price after earnings?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Stock prices often react to the 'earnings surprise'\u2014the difference between the expected EPS and the actual reported EPS. Additionally, future forward guidance provided during the earnings call heavily influences the stock's direction."
      }
    }
  ]
};

export const meta = {
  title: "S&P 500 Earnings Calendar 2026: Upcoming Reports",
  description: "Interactive 2026 S&P 500 earnings calendar. Track upcoming report dates, expected EPS, and previous results by sector. Filter, sort, and search realtime.",
  category: "guide",
  published: "2026-03-15",
};
---

<SiteLayout
  site="westmount"
  title="S&P 500 Earnings Calendar 2026: Upcoming Reports"
  description="Interactive 2026 S&P 500 earnings calendar. Track upcoming report dates, expected EPS, and previous results by sector. Filter, sort, and search realtime."
  canonical="https://westmountfundamentals.com/sp500-earnings-calendar-2026" schema={schema}
>
  <style>
:root {
            --positive: #22c55e;
            --negative: #ef4444;

}

        * { margin: 0; padding: 0; box-sizing: border-box; }

        body {
            font-family: 'Inter', -apple-system, sans-serif;
            background: var(--bg-color);
            color: var(--text-primary);
            line-height: 1.6;
        }

        /* Sticky Nav */
        nav {
            position: sticky;
            top: 0;
            z-index: 1000;
            background: rgba(6, 10, 18, 0.85);
            backdrop-filter: blur(12px);
            border-bottom: 1px solid var(--border-color);
            padding: 16px 24px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }
        .nav-brand {
            font-weight: 800;
            color: #fff;
            text-decoration: none;
            font-size: 1.1rem;
            letter-spacing: -0.5px;
        }
        .nav-links {
            display: flex;
            gap: 24px;
        }
        .nav-links a {
            color: var(--text-dim);
            text-decoration: none;
            font-size: 0.9rem;
            font-weight: 600;
            transition: color 0.2s;
        }
        .nav-links a:hover { color: var(--accent-color); }

        .container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 60px 24px;
        }

        /* Header */
        header { text-align: center; margin-bottom: 50px; }
        .tag {
            display: inline-block;
            background: rgba(74,143,231,0.1);
            color: var(--accent-color);
            font-size: 0.75rem;
            font-weight: 800;
            padding: 6px 16px;
            border-radius: 20px;
            letter-spacing: 1px;
            margin-bottom: 16px;
        }
        h1 {
            font-size: 3rem;
            font-weight: 900;
            letter-spacing: -1px;
            margin-bottom: 16px;
            background: linear-gradient(90deg, #fff, #a0b0c0);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }
        .subtitle {
            font-size: 1.1rem;
            color: var(--text-dim);
            max-width: 600px;
            margin: 0 auto;
        }

        /* Stats Cards */
        .stats-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 20px;
            margin-bottom: 50px;
        }
        .stat-card {
            background: var(--card-bg);
            border: 1px solid var(--border-color);
            border-radius: 12px;
            padding: 24px;
        }
        .stat-value {
            font-family: 'JetBrains Mono', monospace;
            font-size: 2rem;
            font-weight: 700;
            color: #fff;
            margin-bottom: 4px;
        }
        .stat-label {
            font-size: 0.85rem;
            color: var(--text-dim);
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        /* Controls */
        .controls {
            display: flex;
            flex-wrap: wrap;
            gap: 16px;
            margin-bottom: 24px;
            background: var(--card-bg);
            padding: 20px;
            border-radius: 12px;
            border: 1px solid var(--border-color);
        }
        .control-group {
            flex: 1;
            min-width: 200px;
        }
        .control-group label {
            display: block;
            font-size: 0.8rem;
            color: var(--text-dim);
            margin-bottom: 8px;
            font-weight: 600;
        }
        input, select {
            width: 100%;
            background: rgba(255,255,255,0.03);
            border: 1px solid var(--border-color);
            color: #fff;
            padding: 10px 14px;
            border-radius: 6px;
            font-family: 'Inter', sans-serif;
            font-size: 0.95rem;
        }
        input:focus, select:focus {
            outline: none;
            border-color: var(--accent-color);
        }

        /* Chart */
        .chart-container {
            background: var(--card-bg);
            border: 1px solid var(--border-color);
            border-radius: 12px;
            padding: 24px;
            margin-bottom: 40px;
            height: 300px;
        }

        /* Table */
        .table-container {
            background: var(--card-bg);
            border: 1px solid var(--border-color);
            border-radius: 12px;
            overflow-x: auto;
            margin-bottom: 60px;
        }
        table {
            width: 100%;
            border-collapse: collapse;
            text-align: left;
        }
        th, td {
            padding: 16px 20px;
            border-bottom: 1px solid var(--border-color);
        }
        th {
            font-size: 0.8rem;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            color: var(--text-dim);
            font-weight: 600;
            background: rgba(255,255,255,0.02);
            cursor: pointer;
            user-select: none;
        }
        th:hover { color: #fff; }
        .ticker {
            font-family: 'JetBrains Mono', monospace;
            font-weight: 700;
            color: var(--accent-color);
        }
        .mono {
            font-family: 'JetBrains Mono', monospace;
        }
        .sector-tag {
            font-size: 0.75rem;
            padding: 4px 8px;
            background: rgba(255,255,255,0.05);
            border-radius: 4px;
            color: #a0b0c0;
            white-space: nowrap;
        }

        /* Text Sections */
        .text-section {
            background: var(--card-bg);
            border: 1px solid var(--border-color);
            border-radius: 12px;
            padding: 40px;
            margin-bottom: 40px;
        }
        .text-section h2 {
            font-size: 1.8rem;
            color: #fff;
            margin-bottom: 24px;
            letter-spacing: -0.5px;
        }
        .text-section h3 {
            font-size: 1.2rem;
            color: #fff;
            margin: 24px 0 12px;
        }
        .text-section p, .text-section ul {
            margin-bottom: 16px;
            color: #a0b0c0;
        }
        .text-section ul {
            padding-left: 24px;
        }
        .text-section li {
            margin-bottom: 8px;
        }

        /* FAQ */
        .faq-item {
            margin-bottom: 24px;
            border-bottom: 1px solid var(--border-color);
            padding-bottom: 24px;
        }
        .faq-item:last-child {
            border-bottom: none;
            margin-bottom: 0;
            padding-bottom: 0;
        }
        .faq-question {
            font-size: 1.1rem;
            font-weight: 700;
            color: #fff;
            margin-bottom: 8px;
        }
        .faq-answer {
            color: #a0b0c0;
        }

        /* Footer */
        footer {
            text-align: center;
            padding: 40px 24px;
            border-top: 1px solid var(--border-color);
            color: var(--text-dim);
            font-size: 0.85rem;
            background: #040810;
        }

        @media (max-width: 768px) {
            h1 { font-size: 2.2rem; }
            .nav-links { display: none; }
            .controls { flex-direction: column; }
            .text-section { padding: 24px; }
        }
  </style>

