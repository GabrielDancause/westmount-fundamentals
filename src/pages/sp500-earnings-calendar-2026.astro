            if (days !== 'all') {
                cutoffDate = new Date(now.getTime() + parseInt(days) * 24 * 60 * 60 * 1000);
            }

            currentData = earningsData.filter(item => {
                // Search
                const matchSearch = item.ticker.toLowerCase().includes(search) || item.name.toLowerCase().includes(search);

                // Sector
                const matchSector = sector === 'all' || item.sector === sector;

                // Date
                let matchDate = true;
                if (cutoffDate) {
                    if (!item.reportDate) {
                        matchDate = false;
                    } else {
                        const d = new Date(item.reportDate);
                        matchDate = d >= now && d <= cutoffDate;
                    }
                }

