                    <td>${item.name}</td>
                    <td><span class="sector-tag">${item.sector}</span></td>
                    <td class="mono">${formatDate(item.reportDate)}</td>
                    <td class="mono">${formatTime(item.reportDate)}</td>
                    <td class="mono">${formatNumber(item.expectedEps)}</td>
