        // Render Table
        function renderTable() {
            tableBody.innerHTML = '';

            if (currentData.length === 0) {
                tableBody.innerHTML = '<tr><td colspan="7" style="text-align: center; color: #5a6a80;">No earnings reports match your filters.</td></tr>';
                return;
            }

            currentData.forEach(item => {
                const tr = document.createElement('tr');
                tr.innerHTML = `
