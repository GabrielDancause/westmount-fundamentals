                if (sortCol === 'previous') { valA = a.previousEps || -9999; valB = b.previousEps || -9999; }
                if (sortCol === 'date') {
                    valA = a.reportDate ? new Date(a.reportDate).getTime() : 9999999999999;
                    valB = b.reportDate ? new Date(b.reportDate).getTime() : 9999999999999;
                }
                if (sortCol === 'time') {
                    valA = formatTime(a.reportDate);
                    valB = formatTime(b.reportDate);
                }

                if (valA < valB) return sortAsc ? -1 : 1;
                if (valA > valB) return sortAsc ? 1 : -1;
                return 0;
            });
        }

        // Event Listeners
        searchInput.addEventListener('input', applyFilters);
        sectorFilter.addEventListener('change', applyFilters);
        dateFilter.addEventListener('change', applyFilters);

        headers.forEach(th => {
            th.addEventListener('click', () => {
                const col = th.dataset.sort;
                if (sortCol === col) {
                    sortAsc = !sortAsc;
                } else {
                    sortCol = col;
                    sortAsc = true;
                }

                // Update header text arrows
                headers.forEach(h => h.textContent = h.textContent.replace(' ↑', ' ↕').replace(' ↓', ' ↕'));
                th.textContent = th.textContent.replace(' ↕', sortAsc ? ' ↑' : ' ↓');

                doSort();
                renderTable();
            });
        });

        // Chart
        let myChart = null;
        function updateChart() {
            const ctx = document.getElementById('sectorChart').getContext('2d');

            // Count reports by sector in current filtered data
            const counts = {};
            currentData.forEach(item => {
                if(item.sector && item.sector !== 'Unknown') {
                    counts[item.sector] = (counts[item.sector] || 0) + 1;
                }
            });

            const labels = Object.keys(counts);
            const dataVals = Object.values(counts);

            if (myChart) {
                myChart.destroy();
            }

            Chart.defaults.color = '#a0b0c0';
            Chart.defaults.font.family = 'Inter';

            myChart = new Chart(ctx, {
                type: 'bar',
                data: {
                    labels: labels,
                    datasets: [{
                        label: 'Upcoming Reports',
                        data: dataVals,
                        backgroundColor: '#4a8fe7',
                        borderRadius: 4
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: { display: false },
                        title: {
                            display: true,
                            text: 'Upcoming Reports by Sector (Filtered)',
                            color: '#fff',
                            font: { size: 16, weight: 'bold' }
                        }
                    },
                    scales: {
                        y: {
                            beginAtZero: true,
                            grid: { color: '#152040' }
                        },
                        x: {
                            grid: { display: false }
                        }
                    }
                }
            });
        }

        // Init
        doSort();
        renderTable();
        updateChart();
  </script>

