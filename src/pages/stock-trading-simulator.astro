---
import SiteLayout from "../layouts/SiteLayout.astro";
import registry from "../data/pages-registry.json";

const page = (registry as any)["stock-trading-simulator"];
export const meta = { title: "Free Stock Trading Simulator: Practice Paper Trading", description: "Practice investing with our free stock trading simulator. Learn market dynamics, build strategies, and track portfolio performance with zero financial risk.", category: "tool", published: "2026-03-18" };

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What is a stock trading simulator?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "A stock trading simulator is a virtual platform that allows you to buy and sell stocks using fake money, mirroring real-time market data to practice trading strategies."
      }
    },
    {
      "@type": "Question",
      "name": "Is paper trading good for beginners?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes, paper trading is highly beneficial for beginners as it allows them to learn market mechanics and test strategies without risking actual capital."
      }
    },
    {
      "@type": "Question",
      "name": "How much virtual money should I start with?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "It is best to start your simulator with an amount close to what you actually plan to invest in the real world to build realistic habits and risk management."
      }
    },
    {
      "@type": "Question",
      "name": "Do simulators account for trading fees?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Our simulator allows you to input custom commission fees per trade so you can accurately understand how trading costs impact your overall profitability."
      }
    },
    {
      "@type": "Question",
      "name": "Can a stock simulator predict future success?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "While simulators are great for practice, real trading involves emotional factors like fear and greed that paper trading cannot fully replicate. Success in a simulator does not guarantee future real-world profits."
      }
    }
  ]
};

const schema = JSON.stringify(faqSchema);
---

<SiteLayout site="westmount" title={page.title} description={page.description} canonical={`https://westmountfundamentals.com/${page.slug}/`} schema={schema}>
  <div class="page-content">
    <div class="container">
  <div style="max-width:1280px;margin:0 auto;padding:16px 24px 0;display:flex;justify-content:space-between;align-items:center;font-size:13px;color:var(--text-dim,#94a3b8)">
    <nav aria-label="Breadcrumb"><a href="/" style="color:var(--text-dim,#94a3b8);text-decoration:none">Home</a> <span style="margin:0 6px;opacity:0.5">›</span> <a href="/tools/" style="color:var(--text-dim,#94a3b8);text-decoration:none">Tools</a> <span style="margin:0 6px;opacity:0.5">›</span> <span style="color:var(--text-primary,#c8d0de)">Free Stock Trading Simulator: Practice Paper Tr...</span></nav>
    <span>3 min read</span>
  </div>
      <h1>{page.h1}</h1>
      <p>Welcome to our interactive stock trading simulator. Use this paper trading tool to buy and sell stocks in a virtual environment. Track your portfolio balance, practice your trading strategies, and see how commissions affect your returns without risking real money.</p>

      <div class="calculator-card">
        <h3>Live Market Simulator</h3>
        <p class="text-sm" style="text-align: center; margin-bottom: 1.5rem;">Enter a stock ticker (e.g., AAPL, MSFT) to get its current price and execute a trade. Requires an active internet connection to fetch live data.</p>

        <div class="stats-grid" id="portfolio-stats">
          <div class="stat-card">
            <span class="calc-result-label">Available Cash</span>
            <div class="calc-result-value" id="avail-cash">$100,000.00</div>
          </div>
          <div class="stat-card">
            <span class="calc-result-label">Portfolio Value</span>
            <div class="calc-result-value" id="port-value">$0.00</div>
          </div>
          <div class="stat-card">
            <span class="calc-result-label">Total Account Value</span>
            <div class="calc-result-value" id="total-value">$100,000.00</div>
          </div>
        </div>

        <div class="trade-panel">
          <div class="input-group">
            <label for="ticker-input">Stock Symbol</label>
            <div class="input-wrapper search-wrapper">
              <input type="text" id="ticker-input" placeholder="e.g. AAPL" style="text-transform: uppercase;">
              <button id="search-btn" class="btn">Get Quote</button>
            </div>
          </div>

          <div id="quote-result" class="quote-result hidden">
            <div class="quote-header">
              <h4 id="quote-symbol">---</h4>
              <div class="quote-price" id="quote-price">$0.00</div>
            </div>

            <div class="input-group">
              <label for="trade-action">Action</label>
              <select id="trade-action" class="trade-select">
                <option value="buy">Buy</option>
                <option value="sell">Sell</option>
              </select>
            </div>

            <div class="input-group">
              <label for="trade-shares">Shares</label>
              <input type="number" id="trade-shares" min="1" step="1" value="1">
            </div>

            <div class="input-group">
              <label for="trade-commission">Commission Fee ($)</label>
              <div class="input-wrapper">
                <span class="prefix" style="position: absolute; left: 1rem; color: var(--text-secondary); pointer-events: none;">$</span>
                <input type="number" id="trade-commission" min="0" step="0.01" value="0.00" style="padding-left: 2.5rem; padding-right: 1rem;">
              </div>
            </div>

            <div class="trade-summary">
              <div class="summary-row">
                <span>Estimated Cost/Proceeds</span>
                <span id="trade-cost">$0.00</span>
              </div>
              <button id="execute-btn" class="btn primary-btn" style="width: 100%; margin-top: 1rem;">Execute Trade</button>
            </div>
          </div>

          <div id="error-msg" class="error-msg hidden"></div>
        </div>

        <div class="positions-panel">
          <h3>Open Positions</h3>
          <div class="table-container">
            <table id="positions-table">
              <thead>
                <tr>
                  <th>Symbol</th>
                  <th>Shares</th>
                  <th>Avg Price</th>
                  <th>Current Value</th>
                  <th>P/L</th>
                </tr>
              </thead>
              <tbody id="positions-body">
                <tr><td colspan="5" style="text-align: center;">No open positions</td></tr>
              </tbody>
            </table>
          </div>
        </div>
      </div>


      <script>
        document.addEventListener('astro:page-load', () => {
          const UI = {
            availCash: document.getElementById('avail-cash'),
            portValue: document.getElementById('port-value'),
            totalValue: document.getElementById('total-value'),
            tickerInput: document.getElementById('ticker-input'),
            searchBtn: document.getElementById('search-btn'),
            quoteResult: document.getElementById('quote-result'),
            quoteSymbol: document.getElementById('quote-symbol'),
            quotePrice: document.getElementById('quote-price'),
            tradeAction: document.getElementById('trade-action'),
            tradeShares: document.getElementById('trade-shares'),
            tradeCommission: document.getElementById('trade-commission'),
            tradeCost: document.getElementById('trade-cost'),
            executeBtn: document.getElementById('execute-btn'),
            errorMsg: document.getElementById('error-msg'),
            positionsBody: document.getElementById('positions-body')
          };

          if (!UI.tickerInput) return; // Guard clause if script runs on other pages

          let cash = 100000;
          let portfolio = {}; // { AAPL: { shares: 10, avgPrice: 150.00 } }
          let currentQuote = null;

          const formatCurrency = (val) => new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD' }).format(val);

          const updatePositionsAndStats = async () => {
            let totalPortfolioValue = 0;
            const positionsHtml = [];

            if (Object.keys(portfolio).length === 0) {
              UI.positionsBody.innerHTML = '<tr><td colspan="5" style="text-align: center;">No open positions</td></tr>';
            } else {
              for (const [symbol, data] of Object.entries(portfolio)) {
                let currentPrice = data.avgPrice;
                try {
                  const res = await fetch(`https://api.allorigins.win/get?url=${encodeURIComponent(`https://query1.finance.yahoo.com/v8/finance/chart/${symbol}?interval=1d&range=1d`)}`);
                  const proxyData = await res.json();
                  const priceData = JSON.parse(proxyData.contents);
                  currentPrice = priceData.chart.result[0].meta.regularMarketPrice;
                } catch (e) {
                  console.error("Failed to fetch price for " + symbol, e);
                }
                const currentValue = currentPrice * data.shares;
                totalPortfolioValue += currentValue;

                const pl = currentValue - (data.avgPrice * data.shares);
                const plClass = pl >= 0 ? 'positive' : 'negative';
                const plFormatted = formatCurrency(Math.abs(pl));

                positionsHtml.push(`
                  <tr>
                    <td><strong>${symbol}</strong></td>
                    <td>${data.shares}</td>
                    <td>${formatCurrency(data.avgPrice)}</td>
                    <td>${formatCurrency(currentValue)}</td>
                    <td style="color: ${pl >= 0 ? '#22c55e' : '#ef4444'}">${pl >= 0 ? '+' : '-'}${plFormatted}</td>
                  </tr>
                `);
              }
              UI.positionsBody.innerHTML = positionsHtml.join('');
            }

            UI.availCash.textContent = formatCurrency(cash);
            UI.portValue.textContent = formatCurrency(totalPortfolioValue);
            UI.totalValue.textContent = formatCurrency(cash + totalPortfolioValue);
          };

          const updateTradeSummary = () => {
            if (!currentQuote) return;
            const shares = parseInt(UI.tradeShares.value) || 0;
            const commission = parseFloat(UI.tradeCommission.value) || 0;
            const isBuy = UI.tradeAction.value === 'buy';

            const baseCost = currentQuote.price * shares;
            let total = 0;

            if (isBuy) {
              total = baseCost + commission;
              UI.tradeCost.parentElement.firstElementChild.textContent = 'Estimated Cost';
            } else {
              total = baseCost - commission;
              UI.tradeCost.parentElement.firstElementChild.textContent = 'Estimated Proceeds';
            }

            UI.tradeCost.textContent = formatCurrency(total);
          };

          const fetchQuote = async () => {
            const symbol = UI.tickerInput.value.trim().toUpperCase();
            if (!symbol) return;

            UI.searchBtn.disabled = true;
            UI.searchBtn.textContent = 'Searching...';
            UI.errorMsg.classList.add('hidden');

            try {
              // Direct fetch from Yahoo Finance Chart API
              // Note: requires CORS proxy in some browser environments, but Cloudflare workers / modern browsers often allow it for simple GETs
              const res = await fetch(`https://api.allorigins.win/get?url=${encodeURIComponent(`https://query1.finance.yahoo.com/v8/finance/chart/${symbol}?interval=1d&range=1d`)}`);
              if (!res.ok) throw new Error('Symbol not found');

              const proxyData = await res.json();
              const data = JSON.parse(proxyData.contents);
              if (!data.chart || !data.chart.result || !data.chart.result[0].meta) throw new Error('Symbol not found');

              const price = data.chart.result[0].meta.regularMarketPrice;

              currentQuote = { symbol, price };

              UI.quoteSymbol.textContent = symbol;
              UI.quotePrice.textContent = formatCurrency(price);
              UI.quoteResult.classList.remove('hidden');
              updateTradeSummary();

            } catch (err) {
              UI.errorMsg.textContent = 'Could not fetch data for that symbol. Try popular tickers like AAPL, MSFT, or TSLA.';
              UI.errorMsg.classList.remove('hidden');
              UI.quoteResult.classList.add('hidden');
              currentQuote = null;
            } finally {
              UI.searchBtn.disabled = false;
              UI.searchBtn.textContent = 'Get Quote';
            }
          };

          const executeTrade = () => {
            if (!currentQuote) return;

            const shares = parseInt(UI.tradeShares.value);
            if (isNaN(shares) || shares <= 0) {
              alert('Please enter a valid positive number of shares.');
              return;
            }

            const commission = parseFloat(UI.tradeCommission.value) || 0;
            const isBuy = UI.tradeAction.value === 'buy';
            const baseCost = currentQuote.price * shares;

            if (isBuy) {
              const totalCost = baseCost + commission;
              if (cash < totalCost) {
                alert('Insufficient cash for this transaction.');
                return;
              }

              cash -= totalCost;

              if (!portfolio[currentQuote.symbol]) {
                portfolio[currentQuote.symbol] = { shares: 0, avgPrice: 0 };
              }

              const existingShares = portfolio[currentQuote.symbol].shares;
              const existingValue = existingShares * portfolio[currentQuote.symbol].avgPrice;
              const newTotalValue = existingValue + baseCost; // Commission is sunk cost, doesn't affect cost basis in this simple sim

              portfolio[currentQuote.symbol].shares += shares;
              portfolio[currentQuote.symbol].avgPrice = newTotalValue / portfolio[currentQuote.symbol].shares;

              alert(`Successfully bought ${shares} shares of ${currentQuote.symbol}.`);

            } else { // Sell
              if (!portfolio[currentQuote.symbol] || portfolio[currentQuote.symbol].shares < shares) {
                alert(`Insufficient shares to sell. You own ${portfolio[currentQuote.symbol] ? portfolio[currentQuote.symbol].shares : 0} shares.`);
                return;
              }

              const totalProceeds = baseCost - commission;
              cash += totalProceeds;
              portfolio[currentQuote.symbol].shares -= shares;

              if (portfolio[currentQuote.symbol].shares === 0) {
                delete portfolio[currentQuote.symbol];
              }

              alert(`Successfully sold ${shares} shares of ${currentQuote.symbol}.`);
            }

            UI.tradeShares.value = 1;
            updatePositionsAndStats();
            updateTradeSummary();
          };

          UI.searchBtn.addEventListener('click', fetchQuote);
          UI.tickerInput.addEventListener('keypress', (e) => {
            if (e.key === 'Enter') fetchQuote();
          });

          UI.tradeAction.addEventListener('change', updateTradeSummary);
          UI.tradeShares.addEventListener('input', updateTradeSummary);
          UI.tradeCommission.addEventListener('input', updateTradeSummary);
          UI.executeBtn.addEventListener('click', executeTrade);

          // Initial stats update
          updatePositionsAndStats();
        });
      </script>

      <div class="faq-section">
        <h2>Frequently Asked Questions</h2>
        <div class="faq-item">
          <h3>What is a stock trading simulator?</h3>
          <p>A stock trading simulator is a virtual platform that allows you to buy and sell stocks using fake money, mirroring real-time market data to practice trading strategies.</p>
        </div>
        <div class="faq-item">
          <h3>Is paper trading good for beginners?</h3>
          <p>Yes, paper trading is highly beneficial for beginners as it allows them to learn market mechanics and test strategies without risking actual capital.</p>
        </div>
        <div class="faq-item">
          <h3>How much virtual money should I start with?</h3>
          <p>It is best to start your simulator with an amount close to what you actually plan to invest in the real world to build realistic habits and risk management.</p>
        </div>
        <div class="faq-item">
          <h3>Do simulators account for trading fees?</h3>
          <p>Our simulator allows you to input custom commission fees per trade so you can accurately understand how trading costs impact your overall profitability.</p>
        </div>
        <div class="faq-item">
          <h3>Can a stock simulator predict future success?</h3>
          <p>While simulators are great for practice, real trading involves emotional factors like fear and greed that paper trading cannot fully replicate. Success in a simulator does not guarantee future real-world profits.</p>
        </div>
      </div>
    </div>
  </div>

  
  
  <section style="max-width:800px;margin:40px auto;padding:0 24px">
    <div style="background:var(--card-bg,#0a1020);border:1px solid var(--border-color,#152040);border-radius:12px;padding:24px">
      <h3 style="font-size:16px;color:var(--text-bright,#fff);margin-bottom:12px">Data Sources & Methodology</h3>
      <p style="font-size:14px;color:var(--text-dim,#94a3b8);line-height:1.7;margin:0">Market data sourced from S&P Global, Federal Reserve Economic Data (FRED), and historical datasets maintained by academic researchers. Returns include both price appreciation and reinvested dividends unless otherwise noted.</p>
    </div>
  </section>

  <section style="max-width:800px;margin:40px auto;padding:0 24px">
    <div style="background:var(--card-bg,#0a1020);border:1px solid var(--border-color,#152040);border-radius:12px;padding:24px">
      <h3 style="font-size:14px;color:var(--text-dim,#94a3b8);margin-bottom:8px;text-transform:uppercase;letter-spacing:0.5px">Cite This Page</h3>
      <code style="display:block;background:var(--bg-color,#060a12);padding:16px;border-radius:8px;font-size:13px;color:var(--text-primary,#c8d0de);font-family:monospace;white-space:pre-wrap;word-break:break-all">Westmount Fundamentals. "Free Stock Trading Simulator: Practice Paper Trading." westmountfundamentals.com/stock-trading-simulator, 2026.</code>
    </div>
  </section>

  <section style="max-width:800px;margin:40px auto;padding:0 24px">
    <h2 style="font-size:20px;color:var(--text-bright,#fff);margin-bottom:16px">Related Pages</h2>
    <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:12px">
      <a href="/options-trading-simulator/" style="display:block;padding:16px;background:var(--card-bg,#0a1020);border:1px solid var(--border-color,#152040);border-radius:8px;text-decoration:none;color:var(--text-primary,#c8d0de);transition:transform 0.2s" onmouseover="this.style.transform='translateY(-2px)'" onmouseout="this.style.transform='none'">Options Trading Simulator: Free Practice Calculator</a>
      <a href="/trading-simulator/" style="display:block;padding:16px;background:var(--card-bg,#0a1020);border:1px solid var(--border-color,#152040);border-radius:8px;text-decoration:none;color:var(--text-primary,#c8d0de);transition:transform 0.2s" onmouseover="this.style.transform='translateY(-2px)'" onmouseout="this.style.transform='none'">Free Trading Simulator & Stock Market Practice Game</a>
      <a href="/paper-trading-simulator/" style="display:block;padding:16px;background:var(--card-bg,#0a1020);border:1px solid var(--border-color,#152040);border-radius:8px;text-decoration:none;color:var(--text-primary,#c8d0de);transition:transform 0.2s" onmouseover="this.style.transform='translateY(-2px)'" onmouseout="this.style.transform='none'">Free Paper Trading Simulator & Virtual Portfolio Manager</a>
      <a href="/day-trading-simulator/" style="display:block;padding:16px;background:var(--card-bg,#0a1020);border:1px solid var(--border-color,#152040);border-radius:8px;text-decoration:none;color:var(--text-primary,#c8d0de);transition:transform 0.2s" onmouseover="this.style.transform='translateY(-2px)'" onmouseout="this.style.transform='none'">Day Trading Simulator: Test Your Strategy Risk-Free</a>
    </div>
  </section>
</SiteLayout>

<style is:global>

  .calculator-card {
    background-color: var(--card-bg);
    border: 1px solid var(--border-color);
    border-radius: 12px;
    padding: 2rem;
    margin: 2.5rem 0;
    box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06);
  }
  .calculator-card h3 {
    margin-top: 0;
    margin-bottom: 1.5rem;
    text-align: center;
    font-size: 1.5rem;
  }
  .stats-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 1.5rem;
    margin: 2rem 0;
  }
  .stat-card {
    background-color: var(--card-bg);
    border: 1px solid var(--border-color);
    border-radius: 12px;
    padding: 1.5rem;
    text-align: center;
  }
  .calc-result-label {
    color: var(--text-secondary);
    font-size: 0.95rem;
    margin-bottom: 0.5rem;
    display: block;
  }
  .calc-result-value {
    font-family: var(--font-mono);
    font-size: 2rem;
    font-weight: 800;
    color: var(--accent-color);
  }
  .input-group {
    margin-bottom: 1.5rem;
  }
  .input-group label {
    display: block;
    margin-bottom: 0.5rem;
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--text-primary);
  }
  .input-wrapper {
    position: relative;
    display: flex;
    align-items: center;
  }
  input[type="text"], input[type="number"] {
    width: 100%;
    background-color: var(--bg-color);
