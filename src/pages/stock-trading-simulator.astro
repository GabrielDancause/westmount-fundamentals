    color: var(--text-primary);
    border-radius: 8px;
    font-family: var(--font-ui);
    font-size: 1rem;
    appearance: none;
  }
  .trade-select:focus {
    outline: none;
    border-color: var(--accent-color);
  }
  .trade-summary {
    background-color: color-mix(in srgb, var(--bg-color) 50%, var(--card-bg));
    padding: 1.25rem;
    border-radius: 8px;
    margin-top: 1.5rem;
    border: 1px solid var(--border-color);
  }
  .summary-row {
    display: flex;
    justify-content: space-between;
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--text-primary);
  }
  .hidden {
    display: none !important;
  }
  .error-msg {
    margin-top: 1rem;
