---
import SiteLayout from "../layouts/SiteLayout.astro";
import registry from "../data/pages-registry.json";

const page = (registry as any)["market-concentration"];
export const meta = { title: "S&P 500 Market Cap Concentration 2026 — Westmount Research", description: "Just 10 stocks now control over a third of the entire S&P 500. See the full weight rankings and how concentrated your index fund really is.", category: "guide", published: "2026-03-15" };

const schema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": "S&P 500 Market Cap Concentration 2026: How Top-Heavy Is the Index?",
  "description": "503 S&P 500 companies ranked by index weight. Top 10 stocks control 37.3% of the index. Interactive data, sector breakdown, and concentration analysis.",
  "datePublished": "2026-03-09",
  "dateModified": "2026-03-09",
  "author": {
    "@type": "Organization",
    "name": "Westmount Research",
    "url": "https://westmountfundamentals.com"
  },
  "publisher": {
    "@type": "Organization",
    "name": "Westmount Research",
    "url": "https://westmountfundamentals.com"
  },
  "mainEntityOfPage": "https://westmountfundamentals.com/market-concentration"
};

---

 · Updated March 2026<SiteLayout
  site="westmount"
  title={page.title}
  description={page.description}
  canonical={`https://westmountfundamentals.com/${page.slug}`} schema={schema}
>
  <style is:global>
*, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
body { font-family: 'Inter', -apple-system, sans-serif; background: #060a12; color: #c8d0de; line-height: 1.6; }
a { color: #4a8fe7; text-decoration: none; }
a:hover { text-decoration: underline; }

.back-nav { padding: 20px 24px; max-width: 1200px; margin: 0 auto; }
.back-nav a { font-size: 0.82rem; color: #4a6fa5; font-weight: 600; }
.back-nav a:hover { color: #4a8fe7; }

.hero { text-align: center; padding: 60px 24px 50px; }
.hero-tag { display: inline-block; background: rgba(74,143,231,0.1); color: #4a8fe7; font-size: 0.65rem; font-weight: 800; padding: 5px 16px; border-radius: 20px; letter-spacing: 1.5px; margin-bottom: 20px; border: 1px solid rgba(74,143,231,0.2); }
.hero h1 { font-size: 2.6rem; font-weight: 900; color: #fff; letter-spacing: -1.5px; margin-bottom: 10px; line-height: 1.15; }
.hero .subtitle { color: #4a6fa5; font-size: 0.95rem; font-weight: 500; }
.hero .date { color: #2a3a50; font-size: 0.78rem; margin-top: 10px; }

.container { max-width: 1200px; margin: 0 auto; padding: 0 24px; }

/* Big stats */
.stats-row { display: grid; grid-template-columns: repeat(4, 1fr); gap: 16px; margin-bottom: 50px; }
.stat-card { background: linear-gradient(135deg, #0a1020 0%, #0d1428 100%); border: 1px solid #152040; border-radius: 14px; padding: 24px 20px; text-align: center; }
.stat-number { font-family: 'JetBrains Mono', monospace; font-size: 2rem; font-weight: 700; color: #4a8fe7; display: block; }
.stat-label { font-size: 0.72rem; color: #4a6fa5; margin-top: 4px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.5px; }

/* Sections */
.section { margin-bottom: 50px; }
.section-title { font-size: 1.4rem; font-weight: 800; color: #e0e8f0; margin-bottom: 6px; letter-spacing: -0.5px; }
.section-sub { font-size: 0.82rem; color: #4a6fa5; margin-bottom: 24px; }

/* Key findings */
.findings { display: grid; gap: 12px; margin-bottom: 50px; }
.finding { background: #0a1020; border-left: 3px solid #4a8fe7; padding: 16px 20px; border-radius: 0 10px 10px 0; }
.finding strong { color: #e0e8f0; }

/* Chart */
.chart-container { background: #0a1020; border: 1px solid #152040; border-radius: 14px; padding: 28px 24px; margin-bottom: 50px; overflow-x: auto; }
.chart-title { font-size: 1.1rem; font-weight: 700; color: #e0e8f0; margin-bottom: 20px; }
.bar-row { display: flex; align-items: center; margin-bottom: 6px; }
.bar-label { width: 100px; font-size: 0.75rem; font-family: 'JetBrains Mono', monospace; color: #8090a8; text-align: right; padding-right: 12px; flex-shrink: 0; white-space: nowrap; overflow: hidden; }
.bar-track { flex: 1; height: 22px; position: relative; }
.bar-fill { height: 100%; border-radius: 4px; background: linear-gradient(90deg, #1a4a8f, #4a8fe7); position: relative; min-width: 2px; transition: width 0.5s; }
.bar-value { position: absolute; right: -45px; top: 50%; transform: translateY(-50%); font-size: 0.7rem; font-family: 'JetBrains Mono', monospace; color: #6a8ab0; white-space: nowrap; }
.bar-company { width: 140px; font-size: 0.7rem; color: #5a7090; padding-left: 50px; flex-shrink: 0; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }

/* Sector chart */
.sector-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 14px; margin-bottom: 30px; }
.sector-card { background: #0a1020; border: 1px solid #152040; border-radius: 12px; padding: 18px 16px; display: flex; justify-content: space-between; align-items: center; }
.sector-name { font-size: 0.85rem; font-weight: 600; color: #c8d0de; }
.sector-meta { text-align: right; }
.sector-weight { font-family: 'JetBrains Mono', monospace; font-size: 1.1rem; font-weight: 700; color: #4a8fe7; }
.sector-count { font-size: 0.7rem; color: #4a6fa5; }

/* Concentration visual */
.conc-visual { background: #0a1020; border: 1px solid #152040; border-radius: 14px; padding: 28px 24px; margin-bottom: 50px; }
.conc-bar-outer { height: 40px; background: #0d1428; border-radius: 8px; overflow: hidden; display: flex; margin: 16px 0; }
.conc-segment { height: 100%; display: flex; align-items: center; justify-content: center; font-size: 0.7rem; font-weight: 700; color: #fff; transition: width 0.5s; }
.conc-legend { display: flex; flex-wrap: wrap; gap: 16px; margin-top: 12px; }
.conc-legend-item { display: flex; align-items: center; gap: 6px; font-size: 0.78rem; color: #8090a8; }
.conc-dot { width: 10px; height: 10px; border-radius: 3px; flex-shrink: 0; }

/* Table */
.table-controls { display: flex; gap: 12px; margin-bottom: 16px; flex-wrap: wrap; align-items: center; }
.table-controls input, .table-controls select { background: #0d1428; border: 1px solid #152040; color: #c8d0de; padding: 8px 14px; border-radius: 8px; font-size: 0.82rem; font-family: 'Inter', sans-serif; outline: none; }
.table-controls input:focus, .table-controls select:focus { border-color: #4a8fe7; }
.table-controls input { flex: 1; min-width: 200px; }
.result-count { font-size: 0.75rem; color: #4a6fa5; margin-left: auto; font-family: 'JetBrains Mono', monospace; }

.table-wrap { overflow-x: auto; border-radius: 12px; border: 1px solid #152040; }
table { width: 100%; border-collapse: collapse; font-size: 0.8rem; }
thead th { background: #0a1020; color: #4a8fe7; font-weight: 700; padding: 12px 14px; text-align: left; cursor: pointer; user-select: none; white-space: nowrap; border-bottom: 2px solid #152040; position: sticky; top: 0; z-index: 2; }
thead th:hover { color: #7ab4f5; }
thead th.sorted-asc::after { content: ' ▲'; font-size: 0.65rem; }
thead th.sorted-desc::after { content: ' ▼'; font-size: 0.65rem; }
tbody tr { border-bottom: 1px solid #0d1428; transition: background 0.15s; }
tbody tr:hover { background: rgba(74,143,231,0.04); }
tbody td { padding: 10px 14px; white-space: nowrap; }
.ticker-cell { font-family: 'JetBrains Mono', monospace; font-weight: 700; color: #4a8fe7; }
.num-cell { font-family: 'JetBrains Mono', monospace; text-align: right; color: #8090a8; }
.weight-cell { font-family: 'JetBrains Mono', monospace; text-align: right; font-weight: 600; }
.top10-row { background: rgba(74,143,231,0.03); }
.top10-row .weight-cell { color: #4a8fe7; }

/* FAQ */
.faq-list { display: grid; gap: 12px; }
.faq-item { background: #0a1020; border: 1px solid #152040; border-radius: 12px; overflow: hidden; }
.faq-q { padding: 18px 20px; font-weight: 700; color: #e0e8f0; cursor: pointer; display: flex; justify-content: space-between; align-items: center; font-size: 0.92rem; }
.faq-q::after { content: '+'; font-size: 1.2rem; color: #4a8fe7; flex-shrink: 0; margin-left: 12px; transition: transform 0.2s; }
.faq-item.open .faq-q::after { content: '−'; }
.faq-a { padding: 0 20px 18px; font-size: 0.85rem; color: #8090a8; line-height: 1.7; display: none; }
.faq-item.open .faq-a { display: block; }

/* Methodology & Citation */
.methodology { background: #0a1020; border: 1px solid #152040; border-radius: 14px; padding: 28px 24px; margin-bottom: 30px; }
.methodology h3 { font-size: 1rem; font-weight: 700; color: #e0e8f0; margin-bottom: 12px; }
.methodology p, .methodology li { font-size: 0.82rem; color: #6a8090; line-height: 1.7; }
.methodology ul { padding-left: 20px; margin-top: 8px; }

.citation { background: #0a1020; border: 1px solid #152040; border-radius: 14px; padding: 24px; margin-bottom: 30px; }
.citation h3 { font-size: 0.9rem; font-weight: 700; color: #e0e8f0; margin-bottom: 10px; }
.citation code { display: block; background: #060a12; border: 1px solid #152040; border-radius: 8px; padding: 14px; font-family: 'JetBrains Mono', monospace; font-size: 0.72rem; color: #6a8ab0; line-height: 1.6; white-space: pre-wrap; word-break: break-all; }

.footer { text-align: center; padding: 50px 24px; font-size: 0.75rem; color: #253040; border-top: 1px solid #101828; margin-top: 40px; }
.footer a { color: #4a8fe7; }
.disclaimer { max-width: 600px; margin: 12px auto 0; color: #1e2a3a; font-size: 0.68rem; line-height: 1.5; }

