let sortCol = 'rank', sortDir = 1;

async function init() {
  renderStats();
  renderConcentration();
  renderFindings();
  renderBarChart();
  renderSectors();
  populateFilters();
  renderTable();
  renderFAQ();
}

function fmt(n, d=2) { return n != null ? n.toLocaleString('en-US', {minimumFractionDigits:d, maximumFractionDigits:d}) : '—'; }
function fmtInt(n) { return n != null ? n.toLocaleString('en-US') : '—'; }

function renderStats() {
  const c = DATA.concentration;
  const stats = [
    { num: DATA.totalCompanies, label: 'Companies Tracked' },
    { num: fmt(c.top10WeightPct,1) + '%', label: 'Top 10 Weight' },
    { num: fmt(c.top5WeightPct,1) + '%', label: 'Top 5 Weight' },
    { num: fmt(c.top50WeightPct,1) + '%', label: 'Top 50 Weight' },
  ];
  document.getElementById('stats-row').innerHTML = stats.map(s =>
    `<div class="stat-card"><span class="stat-number">${s.num}</span><span class="stat-label">${s.label}</span></div>`
  ).join('');
}

function renderConcentration() {
  const c = DATA.concentration;
  const segments = [
    { label: 'Top 5', pct: c.top5WeightPct, color: '#1565C0' },
    { label: '#6–10', pct: c.top10WeightPct - c.top5WeightPct, color: '#1976D2' },
    { label: '#11–20', pct: c.top20WeightPct - c.top10WeightPct, color: '#2196F3' },
    { label: '#21–50', pct: c.top50WeightPct - c.top20WeightPct, color: '#42A5F5' },
    { label: '#51–503', pct: 100 - c.top50WeightPct, color: '#152040' },
  ];
  document.getElementById('conc-bar').innerHTML = segments.map(s =>
    `<div class="conc-segment" style="width:${s.pct}%;background:${s.color}" title="${s.label}: ${fmt(s.pct,1)}%">${s.pct > 6 ? fmt(s.pct,1)+'%' : ''}</div>`
  ).join('');
  document.getElementById('conc-legend').innerHTML = segments.map(s =>
    `<div class="conc-legend-item"><div class="conc-dot" style="background:${s.color}"></div>${s.label} — ${fmt(s.pct,1)}%</div>`
  ).join('');
}

function renderFindings() {
  const c = DATA.concentration;
  const top = DATA.results[0];
  const topSector = DATA.sectorBreakdown[0];
  const bottom400 = c.bottomRemaining;
  const findings = [
    `<strong>Extreme top-heaviness:</strong> The top 10 stocks control ${fmt(c.top10WeightPct,1)}% of the S&P 500 — meaning just 2% of companies drive over a third of the index's returns.`,
    `<strong>${top.ticker} leads:</strong> ${top.company} alone has a ${fmt(top.weightPct,2)}% weight, making a single stock more influential than entire sectors like Real Estate or Materials.`,
    `<strong>Technology dominance:</strong> The ${topSector.sector} sector holds ${fmt(topSector.weightPct,1)}% of the index across ${topSector.count} companies — nearly 3× the weight of the next largest sector.`,
    `<strong>The long tail problem:</strong> The bottom ${bottom400.count} companies share just ${fmt(bottom400.weightPct,1)}% — averaging ${fmt(bottom400.weightPct / bottom400.count, 3)}% each. Their performance is essentially invisible to index investors.`,
    `<strong>Top 50 = majority:</strong> Just 50 stocks (10% of the index) control ${fmt(c.top50WeightPct,1)}% of total weight. An equal-weight approach would give every stock ~0.2% — dramatically different exposure.`,
  ];
  document.getElementById('findings').innerHTML = findings.map(f =>
    `<div class="finding">${f}</div>`
  ).join('');
}

function renderBarChart() {
  const top20 = DATA.results.slice(0, 20);
  const maxW = top20[0].weightPct;
  document.getElementById('bar-chart').innerHTML = top20.map(r =>
    `<div class="bar-row">
      <div class="bar-label">${r.ticker}</div>
      <div class="bar-track"><div class="bar-fill" style="width:${(r.weightPct/maxW*75)}%"><span class="bar-value">${fmt(r.weightPct,2)}%</span></div></div>
      <div class="bar-company">${r.company || ''}</div>
    </div>`
  ).join('');
}

function renderSectors() {
  const maxW = DATA.sectorBreakdown[0].weightPct;
  document.getElementById('sector-grid').innerHTML = DATA.sectorBreakdown.map(s =>
    `<div class="sector-card">
      <div><div class="sector-name">${s.sector}</div><div style="height:4px;background:#152040;border-radius:2px;margin-top:8px;width:200px;"><div style="height:100%;background:#4a8fe7;border-radius:2px;width:${(s.weightPct/maxW*100)}%"></div></div></div>
      <div class="sector-meta"><div class="sector-weight">${fmt(s.weightPct,1)}%</div><div class="sector-count">${s.count} stocks</div></div>
    </div>`
  ).join('');
}

function populateFilters() {
  const sectors = [...new Set(DATA.results.map(r => r.sector).filter(Boolean))].sort();
  const sel = document.getElementById('sector-filter');
  sectors.forEach(s => { const o = document.createElement('option'); o.value = s; o.textContent = s; sel.appendChild(o); });
  sel.addEventListener('change', renderTable);
  document.getElementById('search').addEventListener('input', renderTable);
}

function renderTable() {
  const search = document.getElementById('search').value.toLowerCase();
  const sector = document.getElementById('sector-filter').value;
  let rows = DATA.results.filter(r => r.weightPct != null);
  if (search) rows = rows.filter(r => (r.ticker||'').toLowerCase().includes(search) || (r.company||'').toLowerCase().includes(search));
  if (sector) rows = rows.filter(r => r.sector === sector);

  rows.sort((a, b) => {
    let va = a[sortCol], vb = b[sortCol];
    if (va == null) return 1; if (vb == null) return -1;
    if (typeof va === 'string') return va.localeCompare(vb) * sortDir;
    return (va - vb) * sortDir;
  });

  document.getElementById('result-count').textContent = `${rows.length} companies`;

  document.getElementById('table-body').innerHTML = rows.map(r =>
    `<tr class="${r.rank && r.rank <= 10 ? 'top10-row' : ''}">
      <td class="num-cell">${r.rank || '—'}</td>
      <td class="ticker-cell">${r.ticker}</td>
      <td>${r.company || '—'}</td>
      <td style="font-size:0.75rem;color:#5a7090">${r.sector || '—'}</td>
      <td class="weight-cell">${fmt(r.weightPct, 3)}</td>
      <td class="num-cell">${r.marketCapB ? fmt(r.marketCapB, 1) : '—'}</td>
      <td class="num-cell">${r.peRatio ? fmt(r.peRatio, 1) : '—'}</td>

    </tr>`
  ).join('');

  // Update sort indicators
  document.querySelectorAll('thead th').forEach(th => {
    th.classList.remove('sorted-asc', 'sorted-desc');
    if (th.dataset.col === sortCol) th.classList.add(sortDir === 1 ? 'sorted-asc' : 'sorted-desc');
  });
}

// Sort handlers
document.querySelectorAll('thead th').forEach(th => {
  th.addEventListener('click', () => {
    const col = th.dataset.col;
    if (!col) return;
    if (sortCol === col) sortDir *= -1;
    else { sortCol = col; sortDir = 1; }
    renderTable();
  });
});

// FAQ
function renderFAQ() {
  const faqs = [
    { q: 'What percentage of the S&P 500 is the top 10 stocks?', a: `As of March 2026, the top 10 stocks represent approximately ${fmt(DATA.concentration.top10WeightPct,1)}% of the S&P 500 by market cap weight. The top 5 alone account for ${fmt(DATA.concentration.top5WeightPct,1)}%. This level of concentration is historically elevated — in 2015, the top 10 held roughly 18% of the index.` },
    { q: 'Is the S&P 500 too concentrated?', a: `The S&P 500's concentration is at elevated levels. The top 20 stocks control ${fmt(DATA.concentration.top20WeightPct,1)}% of the index, meaning 4% of companies drive nearly half the returns. This creates risk if large-cap leadership rotates. However, concentration isn't inherently bad — it reflects the market's view that these companies deserve premium valuations. The key risk is that a decline in a handful of mega-caps can drag the entire index lower, even if most stocks are performing well.` },
    { q: 'Which stock has the highest weight in the S&P 500?', a: `${DATA.results[0].company} (${DATA.results[0].ticker}) has the highest weight at ${fmt(DATA.results[0].weightPct,2)}%, followed by ${DATA.results[1].company} (${DATA.results[1].ticker}) at ${fmt(DATA.results[1].weightPct,2)}% and ${DATA.results[2].company} (${DATA.results[2].ticker}) at ${fmt(DATA.results[2].weightPct,2)}%. The top 3 stocks alone represent ${fmt(DATA.results[0].weightPct + DATA.results[1].weightPct + DATA.results[2].weightPct, 1)}% of the index.` },
    { q: 'What is market cap weighting?', a: 'Market cap weighting means each company\'s influence on the index is proportional to its total market value (share price × shares outstanding). A $4 trillion company has roughly 700× more influence on the index than a $6 billion company. This is why the S&P 500 can rise even when the majority of its stocks fall — if mega-caps go up, they pull the index higher.' },
    { q: 'Should I invest in equal-weight S&P 500 instead?', a: 'The Invesco S&P 500 Equal Weight ETF (RSP) gives each stock approximately 0.2% weight regardless of size. This reduces concentration risk and increases mid-cap exposure. Equal-weight has historically outperformed during periods of leadership rotation (value over growth) but underperformed during mega-cap rallies (2020–2024). Consider it a complement to, rather than replacement for, cap-weighted exposure.' },
  ];
  document.getElementById('faq-list').innerHTML = faqs.map(f =>
    `<div class="faq-item"><div class="faq-q">${f.q}</div><div class="faq-a">${f.a}</div></div>`
  ).join('');
  document.querySelectorAll('.faq-item').forEach(item => {
    item.querySelector('.faq-q').addEventListener('click', () => item.classList.toggle('open'));
  });
}

init();
  </script>

