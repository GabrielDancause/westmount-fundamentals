  <script is:inline>
// Set dynamic year
    document.getElementById('copyright').innerHTML = `&copy; ${new Date().getFullYear()} <a href="/">westmount-research</a> · A GAB Ventures property`;

    // Calculator Logic
    function updateCalculator() {
        const initial = parseFloat(document.getElementById('calc-initial').value) || 0;
        const annual = parseFloat(document.getElementById('calc-annual').value) || 0;
        const rate = (parseFloat(document.getElementById('calc-return').value) || 0) / 100;
        const years = parseFloat(document.getElementById('calc-years').value) || 0;
        const feeA = (parseFloat(document.getElementById('calc-fee-a').value) || 0) / 100;
        const feeB = (parseFloat(document.getElementById('calc-fee-b').value) || 0) / 100;

        const rateA = rate - feeA;
        const rateB = rate - feeB;

        // Future Value formulas
        // FV = P(1+r)^t + PMT * (((1+r)^t - 1) / r)
        let finalA = 0, finalB = 0, noFeeFinal = 0;

        if (rateA === 0) {
            finalA = initial + (annual * years);
        } else {
            finalA = initial * Math.pow(1 + rateA, years) + annual * ((Math.pow(1 + rateA, years) - 1) / rateA);
        }

        if (rateB === 0) {
            finalB = initial + (annual * years);
        } else {
            finalB = initial * Math.pow(1 + rateB, years) + annual * ((Math.pow(1 + rateB, years) - 1) / rateB);
        }

        if (rate === 0) {
            noFeeFinal = initial + (annual * years);
        } else {
            noFeeFinal = initial * Math.pow(1 + rate, years) + annual * ((Math.pow(1 + rate, years) - 1) / rate);
        }

        const feePaidA = noFeeFinal - finalA;
        const feePaidB = noFeeFinal - finalB;
        const difference = finalB - finalA; // Amount lost compared to A

        const formatter = new Intl.NumberFormat('en-US', {
            style: 'currency',
            currency: 'USD',
            maximumFractionDigits: 0
        });

        document.getElementById('res-bal-a').textContent = formatter.format(finalA);
        document.getElementById('res-fee-a').textContent = formatter.format(feePaidA);
        document.getElementById('res-bal-b').textContent = formatter.format(finalB);
        document.getElementById('res-fee-b').textContent = formatter.format(feePaidB);

        const diffEl = document.getElementById('res-diff');
        diffEl.textContent = formatter.format(difference);
        if (difference < 0) {
            diffEl.className = 'result-value negative';
        } else {
            diffEl.className = 'result-value';
        }
    }

    // Attach event listeners to calculator inputs
    const inputs = ['calc-initial', 'calc-annual', 'calc-return', 'calc-years', 'calc-fee-a', 'calc-fee-b'];
    inputs.forEach(id => {
        document.getElementById(id).addEventListener('input', updateCalculator);
    });

    // Initialize calculator
    updateCalculator();

    // Decision Tree Logic
    function dtHideAll() {
        document.querySelectorAll('.dt-step').forEach(el => el.classList.remove('active'));
        document.querySelectorAll('.dt-result-box').forEach(el => el.style.display = 'none');
    }

    function dtNext(currentStep, answer) {
        dtHideAll();
        if (currentStep === 1) {
            if (answer === 'taxable') {
                document.getElementById('dt-step-2a').classList.add('active');
            } else {
                document.getElementById('dt-step-2b').classList.add('active');
            }
        } else if (currentStep === 3) {
            if (answer === 'auto') {
                document.getElementById('dt-step-3').classList.add('active');
            }
        }
    }

    function dtShowResult(type, reason) {
        dtHideAll();
        if (type === 'etf') {
            document.getElementById('dt-result-etf').style.display = 'block';
        } else {
            document.getElementById('dt-result-index').style.display = 'block';
        }
    }

    function dtRestart() {
        dtHideAll();
        document.getElementById('dt-step-1').classList.add('active');
    }
  </script>
