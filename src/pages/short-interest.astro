// Stats
function renderStats() {
  const r = DATA.results;
  const avgShort = (r.reduce((a, s) => a + (s.shortInterestPct || 0), 0) / r.length).toFixed(1);
  const bioCount = r.filter(s => (s.sector || '').includes('Health')).length;
  const medianMcap = (() => {
    const caps = r.map(s => s.marketCapB).filter(Boolean).sort((a,b) => a-b);
    return caps.length ? caps[Math.floor(caps.length/2)].toFixed(1) : '—';
  })();
  const avgChange = (r.reduce((a, s) => a + (s.change1mo || 0), 0) / r.length).toFixed(1);

  document.getElementById('statsGrid').innerHTML = `
    <div class="stat-card"><div class="value">${r.length}</div><div class="label">Heavily Shorted Stocks</div></div>
    <div class="stat-card"><div class="value">${avgShort}%</div><div class="label">Average Short Interest</div></div>
    <div class="stat-card"><div class="value">${bioCount}</div><div class="label">Health Care / Biotech</div></div>
    <div class="stat-card"><div class="value">${avgChange}%</div><div class="label">Avg 1-Month Change</div></div>
  `;
}

// Bar chart
function renderChart() {
  const top20 = DATA.results.slice(0, 20);
  const maxVal = Math.max(...top20.map(s => s.shortInterestPct));
  
  const colors = [
    '#ef4444','#f97316','#eab308','#22c55e','#14b8a6',
    '#3b82f6','#6366f1','#8b5cf6','#a855f7','#ec4899'
  ];

  document.getElementById('barChart').innerHTML = top20.map((s, i) => {
    const pct = (s.shortInterestPct / maxVal * 100).toFixed(1);
    const color = colors[i % colors.length];
    return `<div class="bar-row">
      <div class="bar-label">${s.ticker}</div>
      <div class="bar-track">
        <div class="bar-fill" style="width:${pct}%;background:${color}">${s.shortInterestPct}%</div>
      </div>
      <div class="bar-company">${s.company}</div>
    </div>`;
  }).join('');
}

// Key findings
function renderFindings() {
  const r = DATA.results;
  const top = r[0];
  const sectors = {};
  r.forEach(s => {
    const sec = s.sector || 'Other';
    sectors[sec] = (sectors[sec] || 0) + 1;
  });
  const topSector = Object.entries(sectors).sort((a,b) => b[1] - a[1])[0];
  const decliners = r.filter(s => (s.change3mo || 0) < -20).length;
  const smallCap = r.filter(s => s.marketCapB && s.marketCapB < 1).length;
  const noPE = r.filter(s => !s.peRatio).length;

  const findings = [
    `<strong>${top.ticker}</strong> leads with ${top.shortInterestPct}% short interest — nearly half its float is sold short. The top 10 most shorted stocks all have short interest above 30%, indicating extreme bearish positioning.`,
    `<strong>${topSector[0]}</strong> dominates the most-shorted list with ${topSector[1]} out of ${r.length} stocks (${(topSector[1]/r.length*100).toFixed(0)}%). Biotech and pharmaceutical companies are frequent short targets due to binary clinical trial outcomes.`,
    `<strong>${noPE} out of ${r.length} stocks</strong> (${(noPE/r.length*100).toFixed(0)}%) have no meaningful P/E ratio, indicating negative or zero earnings. This is typical — short sellers often target unprofitable companies they believe will continue burning cash.`,
    `<strong>${decliners} stocks</strong> (${(decliners/r.length*100).toFixed(0)}%) have declined more than 20% over the past 3 months, validating bearish bets. However, the remaining stocks have held steady or risen despite heavy short pressure — potential squeeze candidates.`,
    `<strong>${smallCap} stocks</strong> (${(smallCap/r.length*100).toFixed(0)}%) have market caps under $1 billion. Small-cap stocks dominate the most-shorted list because they have lower liquidity and smaller floats, making short positions more impactful on the stock price.`
  ];

  document.getElementById('findingsContainer').innerHTML = findings.map((f, i) =>
    `<div class="finding"><div class="finding-num">${i+1}</div><div class="finding-text">${f}</div></div>`
  ).join('');
}

// Table
let sortCol = 'shortInterestPct';
let sortDir = 'desc';

function fmt(v, type) {
  if (v === null || v === undefined) return '<span style="color:var(--text-dim)">—</span>';
  if (type === 'pct') return (v >= 0 ? '+' : '') + v.toFixed(2) + '%';
  if (type === 'usd') return '$' + v.toLocaleString(undefined, {minimumFractionDigits:2, maximumFractionDigits:2});
  if (type === 'mcap') return '$' + v.toFixed(2) + 'B';
  if (type === 'change') {
    const cls = v >= 0 ? 'text-green' : 'text-red';
    return `<span class="${cls}">${v >= 0 ? '+' : ''}${v.toFixed(2)}%</span>`;
  }
  if (type === 'num2') return v.toFixed(2);
  if (type === 'num1') return v.toFixed(1);
  return v;
}

function renderTable() {
  const r = [...DATA.results];
  const sectorVal = document.getElementById('sectorFilter').value;
  const minShort = parseFloat(document.getElementById('minShort').value) || 0;
  const search = document.getElementById('searchInput').value.toLowerCase();

  let filtered = r.filter(s => {
    if (sectorVal && s.sector !== sectorVal) return false;
    if (s.shortInterestPct < minShort) return false;
    if (search && !s.ticker.toLowerCase().includes(search) && !(s.company || '').toLowerCase().includes(search)) return false;
    return true;
  });

  filtered.sort((a, b) => {
    let va = a[sortCol], vb = b[sortCol];
    if (va === null || va === undefined) va = sortDir === 'asc' ? Infinity : -Infinity;
    if (vb === null || vb === undefined) vb = sortDir === 'asc' ? Infinity : -Infinity;
    if (typeof va === 'string') return sortDir === 'asc' ? va.localeCompare(vb) : vb.localeCompare(va);
    return sortDir === 'asc' ? va - vb : vb - va;
  });

  const shortBarMax = Math.max(...filtered.map(s => s.shortInterestPct || 0));

  document.getElementById('tableBody').innerHTML = filtered.map((s, i) => {
    const barW = ((s.shortInterestPct || 0) / shortBarMax * 60).toFixed(0);
    const barColor = s.shortInterestPct > 35 ? 'var(--red)' : s.shortInterestPct > 25 ? 'var(--yellow)' : 'var(--accent-color)';
    return `<tr>
      <td class="mono text-right">${i+1}</td>
      <td class="ticker-cell">${s.ticker}</td>
      <td>${s.company || '—'}</td>
      <td style="font-size:12px;color:var(--text-dim)">${s.sector || '—'}</td>
      <td class="mono text-right"><span class="short-bar" style="width:${barW}px;background:${barColor}"></span>${s.shortInterestPct}%</td>
      <td class="mono text-right">${s.shortRatio !== null ? s.shortRatio : '—'}</td>
      <td class="mono text-right">${s.sharesShortM !== null ? s.sharesShortM.toFixed(1) : '—'}</td>
      <td class="mono text-right">${s.floatM !== null ? s.floatM.toFixed(1) : '—'}</td>
      <td class="mono text-right">${s.marketCapB ? fmt(s.marketCapB, 'mcap') : '—'}</td>
      <td class="mono text-right">${s.peRatio ? s.peRatio.toFixed(1) : '—'}</td>
      <td class="mono text-right">${s.priceUSD ? fmt(s.priceUSD, 'usd') : '—'}</td>
      <td class="mono text-right">${s.change1mo !== null ? fmt(s.change1mo, 'change') : '—'}</td>
      <td class="mono text-right">${s.change3mo !== null ? fmt(s.change3mo, 'change') : '—'}</td>
    </tr>`;
  }).join('');

  // Update sort indicators
  document.querySelectorAll('thead th').forEach(th => {
    th.classList.remove('sorted-asc', 'sorted-desc');
    if (th.dataset.col === sortCol) {
      th.classList.add(sortDir === 'asc' ? 'sorted-asc' : 'sorted-desc');
    }
  });
}

// Sector filter options
function initFilters() {
  const sectors = [...new Set(DATA.results.map(s => s.sector).filter(Boolean))].sort();
  const sel = document.getElementById('sectorFilter');
  sectors.forEach(s => {
    const opt = document.createElement('option');
    opt.value = s; opt.textContent = s;
    sel.appendChild(opt);
  });
}

// Sort
document.querySelectorAll('thead th').forEach(th => {
  th.addEventListener('click', () => {
    const col = th.dataset.col;
    if (!col) return;
    if (sortCol === col) {
      sortDir = sortDir === 'desc' ? 'asc' : 'desc';
    } else {
      sortCol = col;
      sortDir = th.dataset.type === 'num' ? 'desc' : 'asc';
    }
    renderTable();
  });
});

// Filter events
document.getElementById('sectorFilter').addEventListener('change', renderTable);
document.getElementById('minShort').addEventListener('input', renderTable);
document.getElementById('searchInput').addEventListener('input', renderTable);

// Init
initFilters();
renderStats();
renderChart();
renderFindings();
renderTable();
  </script>
</SiteLayout>
