<script is:inline>
  function initCalculator() {
    const inputs = [
      'optionType', 'position', 'contracts', 'strikePrice', 'premium', 'currentPrice'
    ].map(id => document.getElementById(id));

    const resBreakEven = document.getElementById('resBreakEven');
    const resInitialFlow = document.getElementById('resInitialFlow');
    const resMaxProfit = document.getElementById('resMaxProfit');
    const resMaxLoss = document.getElementById('resMaxLoss');
    const resCurrentPL = document.getElementById('resCurrentPL');

    function formatCurrency(num) {
      if (num === Infinity || num === "Unlimited") return "Unlimited";
      if (num === -Infinity || num === "-Unlimited") return "-Unlimited";
      if (isNaN(num)) return "$0.00";

      const isNegative = num < 0;
      const formatted = Math.abs(num).toLocaleString('en-US', {
        style: 'currency',
        currency: 'USD'
      });
      return isNegative ? `-${formatted}` : formatted;
    }

    function calculate() {
      // Validate elements exist
      if (inputs.some(input => !input)) return;

      const typeElement = document.getElementById('optionType');
      const posElement = document.getElementById('position');
      const contractsElement = document.getElementById('contracts');
      const strikeElement = document.getElementById('strikePrice');
      const premiumElement = document.getElementById('premium');
      const currentElement = document.getElementById('currentPrice');

      if (!typeElement || !posElement || !contractsElement || !strikeElement || !premiumElement || !currentElement) return;

      const type = typeElement.value;
      const pos = posElement.value;
      const contracts = parseFloat(contractsElement.value) || 0;
      const strike = parseFloat(strikeElement.value) || 0;
      const premium = parseFloat(premiumElement.value) || 0;
      const current = parseFloat(currentElement.value) || 0;

      const shares = contracts * 100;
      const totalPremium = premium * shares;

      let breakEven = 0;
      let initialFlow = 0;
      let maxProfit = 0;
      let maxLoss = 0;
      let currentPL = 0;

      if (pos === 'long') {
        initialFlow = -totalPremium;

        if (type === 'call') {
          breakEven = strike + premium;
          maxProfit = Infinity;
          maxLoss = totalPremium;

          const intrinsic = Math.max(current - strike, 0);
          currentPL = (intrinsic - premium) * shares;
        } else {
          breakEven = strike - premium;
          maxProfit = (strike - premium) * shares;
          maxLoss = totalPremium;

          const intrinsic = Math.max(strike - current, 0);
          currentPL = (intrinsic - premium) * shares;
        }
      } else {
        initialFlow = totalPremium;

        if (type === 'call') {
          breakEven = strike + premium;
          maxProfit = totalPremium;
          maxLoss = Infinity;

          const intrinsic = Math.max(current - strike, 0);
          currentPL = (premium - intrinsic) * shares;
        } else {
          breakEven = strike - premium;
          maxProfit = totalPremium;
          maxLoss = (strike - premium) * shares;

          const intrinsic = Math.max(strike - current, 0);
          currentPL = (premium - intrinsic) * shares;
        }
      }

      if (breakEven < 0) breakEven = 0;

      resBreakEven.textContent = breakEven > 0 ? formatCurrency(breakEven) : '$0.00';
      resInitialFlow.textContent = formatCurrency(initialFlow);

      resMaxProfit.textContent = maxProfit === Infinity ? 'Unlimited' : formatCurrency(maxProfit);
      resMaxLoss.textContent = maxLoss === Infinity ? 'Unlimited' : formatCurrency(maxLoss);

      resCurrentPL.textContent = formatCurrency(currentPL);

      // Add color formatting for P/L
      if (currentPL > 0) {
        resCurrentPL.style.color = 'var(--accent-color)';
      } else if (currentPL < 0) {
        resCurrentPL.style.color = 'color-mix(in srgb, var(--text-primary) 50%, var(--bg-color))';
      } else {
        resCurrentPL.style.color = 'var(--text-primary)';
      }
    }

    // Attach event listeners
    inputs.forEach(input => {
      if (input) {
        input.addEventListener('input', calculate);
        input.addEventListener('change', calculate);
      }
    });

    // Initial calculation
    calculate();
  }

  // Setup execution for Astro view transitions and initial load
  document.addEventListener('astro:page-load', initCalculator);
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initCalculator);
  } else {
    initCalculator();
  }
</script>
