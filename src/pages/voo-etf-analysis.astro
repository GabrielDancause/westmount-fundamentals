            <td><strong>Microsoft Corp.</strong></td>
            <td>MSFT</td>
            <td>6.4%</td>
            <td>Technology</td>
          </tr>
          <tr>
            <td>3</td>
            <td><strong>NVIDIA Corp.</strong></td>
            <td>NVDA</td>
            <td>5.8%</td>
            <td>Technology</td>
          </tr>
          <tr>
            <td>4</td>
            <td><strong>Amazon.com Inc.</strong></td>
            <td>AMZN</td>
            <td>3.9%</td>
            <td>Consumer Disc.</td>
          </tr>
          <tr>
            <td>5</td>
            <td><strong>Alphabet Inc. (Class A)</strong></td>
            <td>GOOGL</td>
            <td>2.3%</td>
            <td>Communication</td>
          </tr>
          <tr>
            <td>6</td>
            <td><strong>Meta Platforms Inc.</strong></td>
            <td>META</td>
            <td>2.7%</td>
            <td>Communication</td>
          </tr>
          <tr>
            <td>7</td>
            <td><strong>Berkshire Hathaway (B)</strong></td>
            <td>BRK.B</td>
