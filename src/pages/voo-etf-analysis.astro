          </tr>
          <tr>
            <td>9</td>
            <td><strong>Eli Lilly & Co.</strong></td>
            <td>LLY</td>
            <td>1.7%</td>
            <td>Healthcare</td>
          </tr>
          <tr>
            <td>10</td>
            <td><strong>Tesla Inc.</strong></td>
            <td>TSLA</td>
            <td>1.5%</td>
            <td>Consumer Disc.</td>
          </tr>
        </tbody>
