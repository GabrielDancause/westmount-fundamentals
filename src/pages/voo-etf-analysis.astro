  <script is:inline>
    /* Calculator */
    function calculateGrowth() {
      var initial = parseFloat(document.getElementById('calcInitial').value) || 0;
      var monthly = parseFloat(document.getElementById('calcMonthly').value) || 0;
      var years = parseInt(document.getElementById('calcYears').value) || 20;
      var rate = 0.105;
      var monthlyRate = rate / 12;
      var months = years * 12;
      var total = initial;
      for (var i = 0; i < months; i++) {
        total = total * (1 + monthlyRate) + monthly;
      }
      var contributions = initial + (monthly * months);
      var gains = total - contributions;
      var multiple = contributions > 0 ? (total / contributions) : 0;
      document.getElementById('crTotal').textContent = '$' + formatNum(total);
      document.getElementById('crContrib').textContent = '$' + formatNum(contributions);
      document.getElementById('crGain').textContent = '$' + formatNum(gains);
      document.getElementById('crMultiple').textContent = multiple.toFixed(1) + 'x';
      document.getElementById('calcResult').style.display = 'block';
    }
    function formatNum(n) {
      if (n >= 1000000) return (n / 1000000).toFixed(1) + 'M';
      if (n >= 1000) return (n / 1000).toFixed(0).replace(/\B(?=(\d{3})+(?!\d))/g, ',') + 'K';
      return n.toFixed(0);
    }

    /* FAQ toggle */
    function toggleFaq(el) {
      var item = el.parentElement;
      var isOpen = item.className.indexOf('open') !== -1;
      if (isOpen) {
        item.className = 'faq-item';
      } else {
        item.className = 'faq-item open';
      }
    }

