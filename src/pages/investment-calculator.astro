        <span class="calc-result-label">Total Earnings</span>
        <div style="font-size: 1.5rem; font-weight: 700; color: var(--accent-color);" id="totalInterest">$0.00</div>
      </div>
    </div>

    <div class="chart-container" style="margin-top: 2rem;">
      <h3 style="margin-top: 0; margin-bottom: 1rem;">Growth Schedule</h3>
      <div class="table-container" style="max-height: 400px; overflow-y: auto;">
        <table id="scheduleTable">
          <thead style="position: sticky; top: 0; z-index: 1;">
            <tr>
              <th>Year</th>
              <th>Contributions</th>
              <th>Total Earnings</th>
              <th>End Balance</th>
            </tr>
          </thead>
          <tbody>
            <!-- Populated by JS -->
          </tbody>
        </table>
