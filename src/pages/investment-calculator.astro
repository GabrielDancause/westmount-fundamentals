    <script is:inline>
      const formatCurrency = (num) => {
        return new Intl.NumberFormat('en-US', {
          style: 'currency',
          currency: 'USD',
          minimumFractionDigits: 0,
          maximumFractionDigits: 0,
        }).format(num);
      };

      const calculateInvestment = () => {
        const initial = Math.max(0, parseFloat(document.getElementById('initial').value) || 0);
        const monthly = Math.max(0, parseFloat(document.getElementById('monthly').value) || 0);
        let years = parseFloat(document.getElementById('years').value) || 0;
        let rate = parseFloat(document.getElementById('rate').value) || 0;

        // Cap years at 100 to prevent performance issues
        if (years > 100) {
            years = 100;
            document.getElementById('years').value = 100;
        }
        if (years < 0) years = 0;

        const r = rate / 100;
        const n = 12; // Compounded monthly

        let balance = initial;
        let totalContributions = initial;

        const tbody = document.querySelector('#scheduleTable tbody');
        tbody.innerHTML = '';

        let html = '';

        for (let year = 1; year <= years; year++) {
          let yearStartBalance = balance;
          let yearContributions = 0;

          for (let month = 1; month <= 12; month++) {
            balance += monthly;
            yearContributions += monthly;
            balance = balance * (1 + (r / n));
          }

          totalContributions += yearContributions;
          const yearInterest = balance - totalContributions;

          // Handle negative balance edge case
          if (balance < 0) balance = 0;
          if (totalContributions < 0) totalContributions = 0;

          html += `
            <tr>
              <td>${year}</td>
              <td>${formatCurrency(totalContributions)}</td>
              <td>${formatCurrency(yearInterest)}</td>
              <td style="color: var(--accent-color); font-weight: 600;">${formatCurrency(balance)}</td>
            </tr>
          `;
        }

        tbody.innerHTML = html;

        // Final updates
        document.getElementById('totalPrincipal').textContent = formatCurrency(totalContributions);

        const totalEarnings = balance - totalContributions;
        document.getElementById('totalInterest').textContent = formatCurrency(Math.max(0, totalEarnings));

        document.getElementById('finalBalance').textContent = formatCurrency(Math.max(0, balance));
      };

      // Add event listeners
      const inputs = ['initial', 'monthly', 'years', 'rate'];
      inputs.forEach(id => {
        document.getElementById(id).addEventListener('input', calculateInvestment);
      });

      // Initial calculation
      calculateInvestment();
    </script>

