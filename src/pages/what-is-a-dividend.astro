    <h2>Interactive Dividend Calculator</h2>
    <p>Use this tool to calculate your projected annual dividend income and yield on cost based on your specific investment parameters.</p>

    <div class="calculator-container" style="background: var(--card-bg); border: 1px solid var(--border-color); padding: 2rem; border-radius: 8px; margin: 2rem 0; box-shadow: 0 4px 6px var(--border-color);">
        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; margin-bottom: 1.5rem;">
            <div>
                <label for="calc-shares" style="display: block; font-weight: bold; margin-bottom: 0.5rem; color: var(--text-primary);">Number of Shares Owned</label>
                <input type="number" id="calc-shares" value="100" min="1" step="1" style="width: 100%; padding: 0.75rem; border: 1px solid var(--border-color); border-radius: 4px; background: var(--bg-color); color: var(--text-primary);">
            </div>
            <div>
                <label for="calc-price" style="display: block; font-weight: bold; margin-bottom: 0.5rem; color: var(--text-primary);">Average Purchase Price ($)</label>
                <input type="number" id="calc-price" value="50.00" min="0.01" step="0.01" style="width: 100%; padding: 0.75rem; border: 1px solid var(--border-color); border-radius: 4px; background: var(--bg-color); color: var(--text-primary);">
            </div>
            <div>
                <label for="calc-div-share" style="display: block; font-weight: bold; margin-bottom: 0.5rem; color: var(--text-primary);">Annual Dividend Per Share ($)</label>
                <input type="number" id="calc-div-share" value="2.50" min="0.01" step="0.01" style="width: 100%; padding: 0.75rem; border: 1px solid var(--border-color); border-radius: 4px; background: var(--bg-color); color: var(--text-primary);">
            </div>
        </div>

        <div style="background: var(--bg-color); border: 1px solid var(--border-color); padding: 1.5rem; border-radius: 4px;">
            <h4 style="margin-top: 0; color: var(--text-primary);">Your Results</h4>
            <div style="display: flex; justify-content: space-between; border-bottom: 1px solid var(--border-color); padding-bottom: 0.5rem; margin-bottom: 0.5rem;">
                <span style="color: var(--text-secondary);">Total Investment Cost:</span>
                <span id="res-total-cost" style="font-weight: bold; color: var(--text-primary);">$5,000.00</span>
            </div>
            <div style="display: flex; justify-content: space-between; border-bottom: 1px solid var(--border-color); padding-bottom: 0.5rem; margin-bottom: 0.5rem;">
                <span style="color: var(--text-secondary);">Annual Dividend Income:</span>
                <span id="res-annual-income" style="font-weight: bold; color: var(--accent-color);">$250.00</span>
            </div>
            <div style="display: flex; justify-content: space-between;">
                <span style="color: var(--text-secondary);">Yield on Cost:</span>
                <span id="res-yield" style="font-weight: bold; color: var(--accent-color);">5.00%</span>
            </div>
        </div>
    </div>

    <script is:inline>
        document.addEventListener('DOMContentLoaded', function() {
            const sharesInput = document.getElementById('calc-shares');
            const priceInput = document.getElementById('calc-price');
            const divInput = document.getElementById('calc-div-share');

            const resCost = document.getElementById('res-total-cost');
            const resIncome = document.getElementById('res-annual-income');
            const resYield = document.getElementById('res-yield');

            function updateCalculator() {
                const shares = parseFloat(sharesInput.value) || 0;
                const price = parseFloat(priceInput.value) || 0;
                const div = parseFloat(divInput.value) || 0;

                // Total Cost
                let totalCost = shares * price;
                let fixedCost = parseFloat(totalCost.toPrecision(14));
                if (Math.abs(fixedCost - Math.round(fixedCost)) < 1e-14) {
                    fixedCost = Math.round(fixedCost);
                }

                // Annual Income
                let annualIncome = shares * div;
                let fixedIncome = parseFloat(annualIncome.toPrecision(14));
                if (Math.abs(fixedIncome - Math.round(fixedIncome)) < 1e-14) {
                    fixedIncome = Math.round(fixedIncome);
                }

                // Yield
                let yieldPercent = 0;
                if (totalCost > 0) {
                    yieldPercent = (annualIncome / totalCost) * 100;
                }

                resCost.textContent = '$' + fixedCost.toLocaleString('en-US', {minimumFractionDigits: 2, maximumFractionDigits: 2});
                resIncome.textContent = '$' + fixedIncome.toLocaleString('en-US', {minimumFractionDigits: 2, maximumFractionDigits: 2});
                resYield.textContent = yieldPercent.toLocaleString('en-US', {minimumFractionDigits: 2, maximumFractionDigits: 2}) + '%';
            }

            sharesInput.addEventListener('input', updateCalculator);
            priceInput.addEventListener('input', updateCalculator);
            divInput.addEventListener('input', updateCalculator);

            // Initial call to set formatted values
            updateCalculator();
        });
    </script>

