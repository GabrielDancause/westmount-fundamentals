/* ═══════════════════════════════════════════════════════════════
   DATA FETCHING
   Since stockanalysis.com blocks direct automated requests (403 Forbidden),
   we dynamically fetch live data at build time using yfinance in an inline Python script.
   Null over fake data is strictly enforced.
   ═══════════════════════════════════════════════════════════════ */

let stockData = {
    price: null,
    shares: null,
    beta: null,
    fcf2024: null,
    totalDebt: null,
    cash: null,
    eps: null,
    revenue: null,
    operatingMargin: null
};

try {
    const pythonScript = `
import yfinance as yf
import json
import math

def safe_val(val):
    if val is None or (isinstance(val, float) and math.isnan(val)):
        return None
    return val

try:
    shw = yf.Ticker('SHW')
    info = shw.info

    data = {
        'price': safe_val(info.get('currentPrice')),
        'shares': safe_val(info.get('sharesOutstanding')),
        'beta': safe_val(info.get('beta')),
        'fcf2024': None,
        'totalDebt': None,
        'cash': None,
        'eps': safe_val(info.get('trailingEps')),
        'revenue': None,
        'operatingMargin': safe_val(info.get('operatingMargins'))
    }

    cf = shw.cashflow
    if cf is not None and not cf.empty and 'Free Cash Flow' in cf.index:
        fcf_series = cf.loc['Free Cash Flow'].dropna()
        if not fcf_series.empty:
            data['fcf2024'] = safe_val(fcf_series.iloc[0])

    bs = shw.balance_sheet
    if bs is not None and not bs.empty:
        if 'Total Debt' in bs.index:
            td_series = bs.loc['Total Debt'].dropna()
            if not td_series.empty:
                data['totalDebt'] = safe_val(td_series.iloc[0])
        if 'Cash And Cash Equivalents' in bs.index:
            c_series = bs.loc['Cash And Cash Equivalents'].dropna()
            if not c_series.empty:
                data['cash'] = safe_val(c_series.iloc[0])

    fin = shw.financials
    if fin is not None and not fin.empty:
        if 'Total Revenue' in fin.index:
            rev_series = fin.loc['Total Revenue'].dropna()
            if not rev_series.empty:
                data['revenue'] = safe_val(rev_series.iloc[0])

    print(json.dumps(data))
except Exception as e:
    print(json.dumps({}))
`;

    const rawData = execSync(`python3 -c "${pythonScript.replace(/"/g, '\\"')}"`).toString().trim();
    if (rawData) {
        const parsed = JSON.parse(rawData);
        stockData = { ...stockData, ...parsed };
    }
} catch (e) {
    console.error("Failed to fetch SHW data at build time:", e);
}

// Convert metrics from raw numbers to Millions (where appropriate)
const fcfBase = stockData.fcf2024 !== null ? stockData.fcf2024 / 1_000_000 : null; // in Millions
const sharesOutM = stockData.shares !== null ? stockData.shares / 1_000_000 : null; // in Millions
const cashM = stockData.cash !== null ? stockData.cash / 1_000_000 : null; // in Millions
const debtM = stockData.totalDebt !== null ? stockData.totalDebt / 1_000_000 : null; // in Millions
const revenueM = stockData.revenue !== null ? stockData.revenue / 1_000_000 : null; // in Millions
const netCashM = (cashM !== null && debtM !== null) ? cashM - debtM : null;

// --- ASSUMPTIONS ---
const growthRatePhase1 = 0.08;         // 8% FCF growth, Years 1-5 (Solid steady compounder)
const growthRateTerminal = 0.03;       // 3% perpetuity growth (terminal)
const discountRate = 0.10;             // 10% WACC / required return (Given 10Y=4.18% and Beta=1.24, CAPM ~11%, we use 10% as standard institutional hurdle)
const treasuryRate = "4.18%";          // 10Y Treasury (Provided)

// --- PHASE 1: PROJECT FCF FOR YEARS 1-5 ---
const projectedFCF = [];
let enterpriseValue = null;
let pvPhase1 = 0;
let terminalValue = null;
let pvTerminalValue = null;
let equityValue = null;
let intrinsicValuePerShare = null;
let roundedIV = null;

let marginOfSafety = null;
let verdictText = "N/A";
let verdictColor = "#5a6a80";

if (fcfBase !== null && sharesOutM !== null && netCashM !== null && stockData.price !== null) {
  let fcf = fcfBase;
  for (let yr = 1; yr <= 5; yr++) {
    fcf = fcf * (1 + growthRatePhase1);
    const pvFactor = 1 / Math.pow(1 + discountRate, yr);
    const pvFCF = Math.round(fcf * pvFactor);
    projectedFCF.push({ year: yr, fcf: Math.round(fcf), pvFactor, pvFCF });
    pvPhase1 += pvFCF;
  }

  // --- PHASE 2: TERMINAL VALUE (Gordon Growth Model) ---
  const fcfYear6 = projectedFCF[4].fcf * (1 + growthRateTerminal);
  terminalValue = Math.round(fcfYear6 / (discountRate - growthRateTerminal));
  pvTerminalValue = Math.round(terminalValue * projectedFCF[4].pvFactor);

  // --- ENTERPRISE VALUE ---
  enterpriseValue = pvPhase1 + pvTerminalValue;

  // --- EQUITY VALUE ---
  equityValue = enterpriseValue + netCashM;
  intrinsicValuePerShare = equityValue / sharesOutM;
  roundedIV = Math.round(intrinsicValuePerShare * 100) / 100;

  marginOfSafety = (((roundedIV - stockData.price) / stockData.price) * 100).toFixed(1);
  verdictText = roundedIV > stockData.price ? "Undervalued" : "Overvalued";
  verdictColor = roundedIV > stockData.price ? "#10b981" : "#ef4444";
}

// Sensitivity analysis
const sensitivityRates = [0.08, 0.09, 0.10, 0.11, 0.12];
const sensitivityGrowth = [0.04, 0.06, 0.08, 0.10, 0.12];
let sensitivityTable = [];

if (fcfBase !== null && sharesOutM !== null && netCashM !== null) {
    sensitivityTable = sensitivityRates.map(dr => {
      return {
        dr,
        values: sensitivityGrowth.map(gr => {
          let f = fcfBase;
          let pvSum = 0;
          for (let y = 1; y <= 5; y++) {
            f = f * (1 + gr);
            pvSum += f / Math.pow(1 + dr, y);
          }
          const f6 = f * (1 + growthRateTerminal);
          const tv = f6 / (dr - growthRateTerminal);
          const pvTV = tv / Math.pow(1 + dr, 5);
          return Math.round((pvSum + pvTV + netCashM) / sharesOutM);
        })
      };
    });
}
