---
import SiteLayout from "../layouts/SiteLayout.astro";
import * as cheerio from 'cheerio';

const schema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": "Capital One Financial (COF) Intrinsic Value: A DCF Analysis",
  "description": "A transparent, step-by-step discounted cash flow valuation of Capital One Financial. Using actual financials to arrive at a single fair value estimate for COF shares.",
  "datePublished": "2026-03-24",
  "dateModified": "2026-03-24",
  "author": {
    "@type": "Organization",
    "name": "Westmount Research",
    "url": "https://westmountfundamentals.com"
  },
  "publisher": {
    "@type": "Organization",
    "name": "Westmount Research",
    "url": "https://westmountfundamentals.com"
  },
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": "https://westmountfundamentals.com/capital-one-intrinsic-value"
  }
};

export const meta = {
  title: "Capital One (COF) Intrinsic Value: A DCF Analysis",
  description: "We ran a full discounted cash flow on Capital One. One number. Every assumption disclosed. Here's what COF is really worth.",
  category: "study",
  published: "2026-03-24",
};

/* ═══════════════════════════════════════════════════════════════
   DATA FETCHING FROM STOCKANALYSIS.COM
   ═══════════════════════════════════════════════════════════════ */
const headers = {
  'User-Agent': 'Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36'
};

const ticker = 'cof';
let currentPrice = null;
let beta = null;
let epsRow = [];
let revenueRow = [];
let sharesRow = [];
let fcfRow = [];
let ocfRow = [];
let cashRow = [];
let debtRow = [];

try {
  // 1. Ticker price and beta
  const priceRes = await fetch(`https://stockanalysis.com/stocks/${ticker}/`, { headers });
  if (priceRes.ok) {
    const priceHtml = await priceRes.text();
    const priceMatch = priceHtml.match(/<div class="[^"]*text-4xl[^"]*"[^>]*>([\d\.,]+)<\/div>/);
    currentPrice = priceMatch ? parseFloat(priceMatch[1].replace(/,/g, '')) : null;

    const betaMatch = priceHtml.match(/beta:"([\d\.]+)"/);
    if (betaMatch) {
        beta = parseFloat(betaMatch[1]);
    } else {
        const betaMatch2 = priceHtml.match(/Beta.*?([\d\.]+)/i);
        if (betaMatch2) beta = parseFloat(betaMatch2[1]);
    }
  }

  // 2. Financials (Income Statement)
  const finRes = await fetch(`https://stockanalysis.com/stocks/${ticker}/financials/`, { headers });
  if (finRes.ok) {
    const finHtml = await finRes.text();
    const $fin = cheerio.load(finHtml);

    const getRow = ($doc, label) => {
      let row = [];
      $doc('table tbody tr').each((i, el) => {
        const text = $doc(el).find('td').first().text().trim();
        if (text === label || text.includes(label)) {
          if (row.length === 0) { // take first match
            $doc(el).find('td').each((j, td) => {
              if (j > 0) {
                  let val = $doc(td).text().trim().replace(/,/g, '');
                  if (val === '-' || val === '') row.push(null);
                  else row.push(parseFloat(val));
              }
            });
          }
        }
      });
      return row;
    };

    epsRow = getRow($fin, 'EPS (Diluted)');
    revenueRow = getRow($fin, 'Revenue');
    sharesRow = getRow($fin, 'Shares Outstanding (Diluted)');
  }

  // 3. Cash Flow
  const cfRes = await fetch(`https://stockanalysis.com/stocks/${ticker}/financials/cash-flow-statement/`, { headers });
  if (cfRes.ok) {
    const cfHtml = await cfRes.text();
    const $cf = cheerio.load(cfHtml);

    const getRow = ($doc, label) => {
      let row = [];
      $doc('table tbody tr').each((i, el) => {
        const text = $doc(el).find('td').first().text().trim();
        if (text === label || text.includes(label)) {
          if (row.length === 0) { // take first match
            $doc(el).find('td').each((j, td) => {
              if (j > 0) {
                  let val = $doc(td).text().trim().replace(/,/g, '');
                  if (val === '-' || val === '') row.push(null);
                  else row.push(parseFloat(val));
              }
            });
          }
        }
      });
      return row;
    };

    fcfRow = getRow($cf, 'Free Cash Flow');
    ocfRow = getRow($cf, 'Operating Cash Flow');
  }

  // 4. Balance Sheet
  const bsRes = await fetch(`https://stockanalysis.com/stocks/${ticker}/financials/balance-sheet/`, { headers });
  if (bsRes.ok) {
    const bsHtml = await bsRes.text();
    const $bs = cheerio.load(bsHtml);

    const getRow = ($doc, label) => {
      let row = [];
      $doc('table tbody tr').each((i, el) => {
        const text = $doc(el).find('td').first().text().trim();
        if (text === label || text.includes(label)) {
          if (row.length === 0) { // take first match
            $doc(el).find('td').each((j, td) => {
              if (j > 0) {
                  let val = $doc(td).text().trim().replace(/,/g, '');
                  if (val === '-' || val === '') row.push(null);
                  else row.push(parseFloat(val));
              }
            });
          }
        }
      });
      return row;
    };

    cashRow = getRow($bs, 'Cash & Equivalents');
    debtRow = getRow($bs, 'Total Debt');
  }

} catch (err) {
  console.error("Error fetching data:", err);
}

/* ═══════════════════════════════════════════════════════════════
   DCF MODEL — ALL INPUTS AND CALCULATIONS
   ═══════════════════════════════════════════════════════════════ */

// Use TTM or latest fiscal year data (first element in array)
const baseFCF = fcfRow[0] !== undefined && fcfRow[0] !== null ? fcfRow[0] : null;
const baseOCF = ocfRow[0] !== undefined && ocfRow[0] !== null ? ocfRow[0] : null;

// Financials/Banks often have distorted Free Cash Flow metrics due to loan originations/repayments
// being classified in operating/investing. For this exercise, we strictly adhere to using the scraped FCF
// if positive, otherwise fall back to Operating Cash Flow as a proxy, or use FCF if both are derived.
// Looking at our scrape: FCF for COF is positive (e.g. 26140).
const startingCashFlow = baseFCF !== null && baseFCF > 0 ? baseFCF : baseOCF;

const sharesOutstanding = sharesRow[0] !== undefined && sharesRow[0] !== null ? sharesRow[0] : null;
const cashAndInvestments = cashRow[0] !== undefined && cashRow[0] !== null ? cashRow[0] : null;
const totalDebt = debtRow[0] !== undefined && debtRow[0] !== null ? debtRow[0] : null;
const netCash = (cashAndInvestments !== null && totalDebt !== null) ? cashAndInvestments - totalDebt : null;

// Derive Growth Rates
// Historical 3-Year CAGR (Revenue or FCF as proxy)
let growthRatePhase1 = 0.05; // Fallback
if (revenueRow.length >= 4 && revenueRow[0] !== null && revenueRow[3] !== null) {
    const revCAGR = Math.pow(revenueRow[0] / revenueRow[3], 1/3) - 1;
    // Cap aggressive growth for phase 1 between 2% and 15%
    growthRatePhase1 = Math.max(0.02, Math.min(revCAGR, 0.15));
}

// Discount Rate (WACC derivation)
// CAPM = Risk Free Rate + Beta * Equity Risk Premium
const riskFreeRate = 0.0418; // 10Y Treasury: 4.18%
const equityRiskPremium = 0.055; // Standard assumption
const derivedBeta = beta !== null ? beta : 1.14;
const costOfEquity = riskFreeRate + (derivedBeta * equityRiskPremium);
const discountRate = parseFloat(costOfEquity.toFixed(3));

// Terminal Growth Rate
// Capped by risk-free rate, standard is ~2.5% - 3.5%
const terminalGrowthRate = 0.025;

// --- PHASE 1: PROJECT FCF FOR YEARS 1-5 ---
const projectedFCF = [];
let fcf = startingCashFlow;
if (fcf !== null && discountRate !== null) {
    for (let yr = 1; yr <= 5; yr++) {
      fcf = fcf * (1 + growthRatePhase1);
      projectedFCF.push({ year: yr, fcf: Math.round(fcf), pvFactor: 1 / Math.pow(1 + discountRate, yr) });
    }
    projectedFCF.forEach(p => { p.pvFCF = Math.round(p.fcf * p.pvFactor); });
}

// --- PHASE 2: TERMINAL VALUE ---
let fcfYear6 = null;
let terminalValue = null;
let pvTerminalValue = null;
let pvPhase1 = null;
let enterpriseValue = null;
let equityValue = null;
let roundedIV = null;
let marginOfSafety = null;

if (projectedFCF.length === 5) {
    fcfYear6 = projectedFCF[4].fcf * (1 + terminalGrowthRate);
    terminalValue = Math.round(fcfYear6 / (discountRate - terminalGrowthRate));
    pvTerminalValue = Math.round(terminalValue * projectedFCF[4].pvFactor);

    pvPhase1 = projectedFCF.reduce((sum, p) => sum + p.pvFCF, 0);
    enterpriseValue = pvPhase1 + pvTerminalValue;

    if (netCash !== null && sharesOutstanding !== null && sharesOutstanding > 0) {
        equityValue = enterpriseValue + netCash;
        const intrinsicValuePerShare = equityValue / sharesOutstanding;
        roundedIV = Math.round(intrinsicValuePerShare * 100) / 100;

        if (currentPrice !== null && currentPrice > 0) {
            marginOfSafety = ((roundedIV - currentPrice) / currentPrice * 100).toFixed(1);
        }
    }
}

const verdictText = (roundedIV !== null && currentPrice !== null) ? (roundedIV > currentPrice ? "Undervalued" : "Overvalued") : "N/A";
const verdictColor = (roundedIV !== null && currentPrice !== null) ? (roundedIV > currentPrice ? "#10b981" : "#ef4444") : "#7a8a9e";

// Historical arrays mapping


// Sensitivity analysis
const sensitivityRates = [discountRate - 0.02, discountRate - 0.01, discountRate, discountRate + 0.01, discountRate + 0.02];
const sensitivityGrowth = [growthRatePhase1 - 0.04, growthRatePhase1 - 0.02, growthRatePhase1, growthRatePhase1 + 0.02, growthRatePhase1 + 0.04];
const sensitivityTable = sensitivityRates.map(dr => {
  return {
    dr: parseFloat(dr.toFixed(3)),
    values: sensitivityGrowth.map(gr => {
      if (startingCashFlow === null || netCash === null || sharesOutstanding === null) return null;
      let f = startingCashFlow;
      let pvSum = 0;
      for (let y = 1; y <= 5; y++) {
        f = f * (1 + gr);
        pvSum += f / Math.pow(1 + dr, y);
      }
      const f6 = f * (1 + terminalGrowthRate);
      const tv = f6 / (dr - terminalGrowthRate);
      const pvTV = tv / Math.pow(1 + dr, 5);
      return Math.round((pvSum + pvTV + netCash) / sharesOutstanding);
    })
  };
});
