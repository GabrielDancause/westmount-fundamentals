---
import SiteLayout from "../layouts/SiteLayout.astro";

export const meta = { title: "Dividend Yield Calculator — Calculate Dividend Income & Growth | Westmount Fundamentals", description: "Free dividend yield calculator with dividend income projector, payout ratio analysis, yield on cost tracker, and DRIP growth charts. Learn the dividend yield formula and how to calculate dividend yield.", category: "study", published: "2026-03-20" };

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": "Dividend Yield Calculator — How to Calculate Dividend Yield",
    "description": meta.description,
    "author": { "@type": "Organization", "name": "Westmount Fundamentals" },
    "publisher": { "@type": "Organization", "name": "Westmount Fundamentals" },
    "datePublished": "2026-03-20"
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "What is dividend yield?",
        "acceptedAnswer": { "@type": "Answer", "text": "Dividend yield is the annual dividend payment divided by the current stock price, expressed as a percentage. It tells investors how much cash flow they receive for each dollar invested in a stock." }
      },
      {
        "@type": "Question",
        "name": "What is the dividend yield formula?",
        "acceptedAnswer": { "@type": "Answer", "text": "The dividend yield formula is: Dividend Yield = (Annual Dividend per Share ÷ Current Stock Price) × 100. For example, a stock paying $2.00 annually at a $50 share price has a 4.0% dividend yield." }
      },
      {
        "@type": "Question",
        "name": "What is a good dividend yield?",
        "acceptedAnswer": { "@type": "Answer", "text": "A good dividend yield typically falls between 2% and 6%. Yields below 2% may not provide meaningful income, while yields above 6% may signal elevated risk. The S&P 500 average dividend yield is approximately 1.3% as of 2026." }
      },
      {
        "@type": "Question",
        "name": "What is dividend payout ratio and why does it matter?",
        "acceptedAnswer": { "@type": "Answer", "text": "The dividend payout ratio measures the percentage of net income paid out as dividends. A ratio below 60% is generally sustainable, 60-80% warrants monitoring, and above 80% may indicate the dividend is at risk of being cut." }
      },
      {
        "@type": "Question",
        "name": "What is a dividend yield trap?",
        "acceptedAnswer": { "@type": "Answer", "text": "A dividend yield trap occurs when a stock's yield appears attractively high but is unsustainable. Common causes include a falling stock price inflating the yield, debt-funded dividends, declining earnings, or one-time special dividends that won't recur." }
      }
    ]
  }
];
---
<SiteLayout
  title={meta.title}
  description={meta.description}
  site="westmount"
  canonical="https://westmountfundamentals.com/dividend-yield-calculator/"
  schema={schema}
>

<style is:inline>
  :root { --accent: #4a8fe7; --positive: #10b981; --negative: #ef4444; --bg-card: #0d1117; --border: #30363d; }
  .dyc-hero { text-align: center; padding: 3rem 1rem 2rem; background: linear-gradient(135deg, rgba(74,143,231,0.08), rgba(74,143,231,0.02)); border-bottom: 1px solid rgba(74,143,231,0.15); }
  .dyc-hero h1 { font-size: 2.2rem; margin-bottom: 0.5rem; color: #e8eaed; }
  .dyc-hero .subtitle { color: #9aa0a6; font-size: 1.1rem; max-width: 700px; margin: 0 auto; }
  .stat-row { display: flex; gap: 1.5rem; justify-content: center; flex-wrap: wrap; margin-top: 1.5rem; }
  .stat-card { background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1); border-radius: 12px; padding: 1rem 1.5rem; min-width: 150px; text-align: center; }
  .stat-card .stat-value { font-size: 1.8rem; font-weight: 700; color: var(--accent); }
  .stat-card .stat-label { font-size: 0.8rem; color: #9aa0a6; text-transform: uppercase; letter-spacing: 0.05em; }
  .dyc-section { max-width: 900px; margin: 0 auto; padding: 2rem 1rem; }
  .dyc-section h2 { font-size: 1.6rem; color: #e8eaed; margin-bottom: 1rem; border-bottom: 2px solid var(--accent); padding-bottom: 0.5rem; display: inline-block; }
  .dyc-section h3 { font-size: 1.2rem; color: #c9d1d9; margin-top: 1.5rem; margin-bottom: 0.75rem; }
  .dyc-section p, .dyc-section li { color: #9aa0a6; line-height: 1.7; }
  .calc-box { background: var(--bg-card); border: 1px solid var(--border); border-radius: 12px; padding: 1.5rem; margin: 1.5rem 0; }
  .calc-box label { display: block; color: #c9d1d9; font-size: 0.9rem; margin-bottom: 0.3rem; margin-top: 0.8rem; }
  .calc-box label:first-child { margin-top: 0; }
  .calc-box input[type="number"], .calc-box select { width: 100%; background: rgba(255,255,255,0.06); border: 1px solid var(--border); border-radius: 8px; padding: 0.6rem 0.8rem; color: #e8eaed; font-size: 1rem; box-sizing: border-box; }
  .calc-box input[type="number"]:focus { border-color: var(--accent); outline: none; }
  .calc-btn { display: inline-block; background: var(--accent); color: #fff; border: none; border-radius: 8px; padding: 0.65rem 1.5rem; font-size: 0.95rem; cursor: pointer; margin-top: 1rem; font-weight: 600; }
  .calc-btn:hover { opacity: 0.9; }
  .calc-result { margin-top: 1rem; padding: 1rem; border-radius: 8px; background: rgba(74,143,231,0.08); border: 1px solid rgba(74,143,231,0.2); }
  .calc-result .big-num { font-size: 2rem; font-weight: 700; color: var(--accent); }
  .calc-result .sub-num { font-size: 1rem; color: #c9d1d9; margin-top: 0.3rem; }
  .result-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(140px, 1fr)); gap: 0.75rem; margin-top: 0.75rem; }
  .result-grid .rg-item { text-align: center; padding: 0.75rem; background: rgba(255,255,255,0.04); border-radius: 8px; }
  .result-grid .rg-item .rg-val { font-size: 1.3rem; font-weight: 700; color: var(--accent); }
  .result-grid .rg-item .rg-lbl { font-size: 0.75rem; color: #9aa0a6; text-transform: uppercase; }
  .payout-badge { display: inline-block; padding: 0.3rem 0.8rem; border-radius: 6px; font-weight: 600; font-size: 0.85rem; margin-top: 0.5rem; }
  .payout-badge.sustainable { background: rgba(16,185,129,0.15); color: var(--positive); }
  .payout-badge.watch { background: rgba(251,191,36,0.15); color: #fbbf24; }
  .payout-badge.risky { background: rgba(239,68,68,0.15); color: var(--negative); }
  .chart-container { background: var(--bg-card); border: 1px solid var(--border); border-radius: 12px; padding: 1.5rem; margin: 1.5rem 0; }
  .chart-container canvas { max-height: 400px; }
  .insight-list { list-style: none; padding: 0; }
  .insight-list li { background: var(--bg-card); border: 1px solid var(--border); border-radius: 10px; padding: 1rem 1.25rem; margin-bottom: 0.75rem; }
  .insight-list li strong { color: var(--accent); }
  .trap-list { list-style: none; padding: 0; }
  .trap-list li { padding: 0.8rem 1rem; margin-bottom: 0.5rem; background: rgba(239,68,68,0.06); border-left: 3px solid var(--negative); border-radius: 0 8px 8px 0; color: #c9d1d9; }
  .faq-section details { border: 1px solid var(--border); border-radius: 8px; margin-bottom: 0.5rem; }
  .faq-section summary { padding: 1rem; cursor: pointer; color: #e8eaed; font-weight: 600; }
  .faq-section details[open] summary { border-bottom: 1px solid var(--border); }
  .faq-section .faq-body { padding: 1rem; color: #9aa0a6; line-height: 1.7; }
  .formula-block { background: rgba(74,143,231,0.06); border: 1px solid rgba(74,143,231,0.15); border-radius: 8px; padding: 1rem 1.25rem; font-family: monospace; font-size: 1rem; color: var(--accent); text-align: center; margin: 1rem 0; }
  .checkbox-row { display: flex; align-items: center; gap: 0.5rem; margin-top: 0.8rem; color: #c9d1d9; font-size: 0.9rem; }
  .checkbox-row input[type="checkbox"] { accent-color: var(--accent); }
  @media(max-width:600px) {
    .dyc-hero h1 { font-size: 1.5rem; }
    .stat-card { min-width: 120px; padding: 0.75rem 1rem; }
    .stat-card .stat-value { font-size: 1.4rem; }
    .result-grid { grid-template-columns: 1fr 1fr; }
  }
</style>

<!-- Hero -->
<section class="dyc-hero">
  <h1>Dividend Yield Calculator</h1>
  <p class="subtitle">Calculate dividend yield, project dividend income growth with DRIP reinvestment, and analyze payout sustainability — all in one place.</p>
  <div class="stat-row">
    <div class="stat-card"><div class="stat-value">1.3%</div><div class="stat-label">S&P 500 Avg Yield</div></div>
    <div class="stat-card"><div class="stat-value">~$18T</div><div class="stat-label">Annual Global Dividends</div></div>
    <div class="stat-card"><div class="stat-value">65%</div><div class="stat-label">S&P 500 Payers</div></div>
    <div class="stat-card"><div class="stat-value">7.1%</div><div class="stat-label">Avg DRIP Return (30yr)</div></div>
  </div>
</section>

<!-- 1. Dividend Yield Calculator -->
<section class="dyc-section">
  <h2>1. Dividend Yield Calculator</h2>
  <p>Use the <strong>dividend yield formula</strong> to find out how much income a stock generates relative to its price. Enter the annual dividend per share and the current stock price.</p>
  <div class="formula-block">Dividend Yield = (Annual Dividend per Share &divide; Stock Price) &times; 100</div>
  <div class="calc-box" id="yieldCalc">
    <label for="yc-div">Annual Dividend per Share ($)</label>
    <input type="number" id="yc-div" placeholder="e.g. 2.50" step="0.01" min="0">
    <label for="yc-price">Current Stock Price ($)</label>
    <input type="number" id="yc-price" placeholder="e.g. 55.00" step="0.01" min="0.01">
    <button class="calc-btn" onclick="calcYield()">Calculate Yield</button>
    <div class="calc-result" id="yc-result" style="display:none"></div>
  </div>
</section>

<!-- 2. Dividend Income Calculator -->
<section class="dyc-section">
  <h2>2. Dividend Income Calculator</h2>
  <p>Estimate your <strong>annual, quarterly, and monthly dividend income</strong> based on your holdings or investment amount.</p>
  <div class="calc-box" id="incomeCalc">
    <label for="ic-mode">Input Method</label>
    <select id="ic-mode" onchange="toggleIncomeMode()">
      <option value="shares">Shares Owned</option>
      <option value="dollars">Dollars Invested</option>
    </select>
    <div id="ic-shares-row">
      <label for="ic-shares">Number of Shares</label>
      <input type="number" id="ic-shares" placeholder="e.g. 100" step="1" min="0">
      <label for="ic-divps">Annual Dividend per Share ($)</label>
      <input type="number" id="ic-divps" placeholder="e.g. 3.20" step="0.01" min="0">
    </div>
    <div id="ic-dollars-row" style="display:none">
      <label for="ic-invested">Amount Invested ($)</label>
      <input type="number" id="ic-invested" placeholder="e.g. 10000" step="1" min="0">
      <label for="ic-yld">Dividend Yield (%)</label>
      <input type="number" id="ic-yld" placeholder="e.g. 3.5" step="0.01" min="0">
    </div>
    <button class="calc-btn" onclick="calcIncome()">Calculate Income</button>
    <div class="calc-result" id="ic-result" style="display:none"></div>
  </div>
</section>

<!-- 3. Dividend Growth Projector -->
<section class="dyc-section">
  <h2>3. Dividend Growth Projector</h2>
  <p>Project how your dividend income grows over time. Toggle <strong>DRIP reinvestment</strong> to see the compounding effect of reinvesting dividends.</p>
  <div class="calc-box" id="growthCalc">
    <label for="gc-shares">Shares Owned</label>
    <input type="number" id="gc-shares" placeholder="e.g. 200" step="1" min="1">
    <label for="gc-div">Current Annual Dividend per Share ($)</label>
    <input type="number" id="gc-div" placeholder="e.g. 2.00" step="0.01" min="0">
    <label for="gc-price">Current Share Price ($) — for DRIP</label>
    <input type="number" id="gc-price" placeholder="e.g. 50.00" step="0.01" min="0.01">
    <label for="gc-growth">Dividend Growth Rate (% / year)</label>
    <input type="number" id="gc-growth" placeholder="e.g. 5" step="0.1" min="0">
    <label for="gc-priceGrowth">Share Price Growth Rate (% / year)</label>
    <input type="number" id="gc-priceGrowth" placeholder="e.g. 3" step="0.1" min="0" value="3">
    <label for="gc-years">Projection Years</label>
    <input type="number" id="gc-years" placeholder="e.g. 20" step="1" min="1" max="50" value="20">
    <div class="checkbox-row">
      <input type="checkbox" id="gc-drip" checked>
      <label for="gc-drip" style="margin:0;color:#c9d1d9">Enable DRIP (Dividend Reinvestment)</label>
    </div>
    <button class="calc-btn" onclick="calcGrowth()">Project Growth</button>
    <div class="calc-result" id="gc-result" style="display:none"></div>
  </div>

  <!-- Line Chart: Dividend Income Growth -->
  <div class="chart-container">
    <h3 style="color:#e8eaed;margin-top:0">Dividend Income Growth: DRIP vs No DRIP</h3>
    <canvas id="growthChart"></canvas>
  </div>
</section>

<!-- 4. Dividend Yield by S&P 500 Sector -->
<section class="dyc-section">
  <h2>4. Dividend Yield by S&P 500 Sector</h2>
  <p>Not all sectors are created equal when it comes to dividends. Energy and Utilities lead, while Technology lags — but offers higher growth.</p>
  <div class="chart-container">
    <canvas id="sectorChart"></canvas>
  </div>
</section>

<!-- 5. Dividend Payout Ratio Calculator -->
<section class="dyc-section">
  <h2>5. Dividend Payout Ratio Calculator</h2>
  <p>The <strong>dividend payout ratio</strong> reveals what percentage of earnings a company distributes as dividends. A high ratio may signal risk; a low ratio suggests room for dividend growth.</p>
  <div class="formula-block">Payout Ratio = (Total Dividends Paid &divide; Net Income) &times; 100</div>
  <div class="calc-box" id="payoutCalc">
    <label for="pc-divs">Total Dividends Paid ($)</label>
    <input type="number" id="pc-divs" placeholder="e.g. 500000000" step="1" min="0">
    <label for="pc-net">Net Income ($)</label>
    <input type="number" id="pc-net" placeholder="e.g. 1200000000" step="1" min="0.01">
    <button class="calc-btn" onclick="calcPayout()">Calculate Payout Ratio</button>
    <div class="calc-result" id="pc-result" style="display:none"></div>
  </div>
</section>

<!-- 6. Yield on Cost Calculator -->
<section class="dyc-section">
  <h2>6. Yield on Cost Calculator</h2>
  <p><strong>Yield on Cost (YOC)</strong> measures dividend yield relative to your original purchase price — a powerful metric for long-term investors who bought early.</p>
  <div class="formula-block">Yield on Cost = (Current Annual Dividend &divide; Original Buy Price) &times; 100</div>
  <div class="calc-box" id="yocCalc">
    <label for="yoc-buy">Original Buy Price per Share ($)</label>
    <input type="number" id="yoc-buy" placeholder="e.g. 25.00" step="0.01" min="0.01">
    <label for="yoc-div">Current Annual Dividend per Share ($)</label>
    <input type="number" id="yoc-div" placeholder="e.g. 3.50" step="0.01" min="0">
    <button class="calc-btn" onclick="calcYOC()">Calculate YOC</button>
    <div class="calc-result" id="yoc-result" style="display:none"></div>
  </div>
</section>

<!-- 7. What is Dividend Yield -->
<section class="dyc-section">
  <h2>What Is Dividend Yield?</h2>
  <p><strong>Dividend yield</strong> is one of the most widely used metrics in income investing. It expresses the annual dividend payment as a percentage of the stock's current market price, giving investors a quick snapshot of the cash return they can expect.</p>
  <p>For example, if a company pays an annual dividend of <strong>$3.00 per share</strong> and the stock trades at <strong>$75.00</strong>, the dividend yield is <strong>4.0%</strong>. This means for every $100 you invest, you receive $4.00 in annual dividend income.</p>
  <h3>How to Calculate Dividend Yield</h3>
  <p>The calculation is straightforward:</p>
  <div class="formula-block">Dividend Yield = (Annual Dividend per Share &divide; Current Stock Price) &times; 100</div>
  <p>Most financial platforms display the <strong>trailing twelve-month (TTM)</strong> dividend yield, which uses the sum of dividends paid over the last four quarters. The <strong>forward dividend yield</strong> uses the company's declared future dividend — useful when a company has just raised its payout.</p>
  <h3>Why Dividend Yield Matters</h3>
  <p>Dividend yield helps investors compare income potential across stocks, sectors, and asset classes. A stock yielding 4% generates more immediate cash flow than one yielding 1%, but yield alone doesn't tell the whole story — you also need to assess <strong>payout sustainability</strong>, <strong>earnings growth</strong>, and <strong>dividend history</strong>.</p>
  <p>For retirees and income-focused portfolios, dividend yield is often the primary selection criterion. For growth investors, a rising dividend (even if the yield is modest) can signal financial health and management confidence.</p>
</section>

<!-- 8. Dividend Yield Traps -->
<section class="dyc-section">
  <h2>Dividend Yield Traps: When High Yield Is a Red Flag</h2>
  <p>An unusually high dividend yield can look attractive — but it's often a warning sign. Here are the most common <strong>dividend yield traps</strong>:</p>
  <ul class="trap-list">
    <li><strong>Falling stock price inflating yield:</strong> A stock drops from $80 to $40 while paying the same $4 dividend. The yield jumps from 5% to 10% — but the company may be in trouble, and a dividend cut is likely next.</li>
    <li><strong>Debt-funded dividends:</strong> Some companies borrow money to maintain their dividend, especially during earnings downturns. This is unsustainable and often precedes a cut. Check the payout ratio and free cash flow.</li>
    <li><strong>Declining earnings:</strong> If earnings are shrinking while dividends stay flat, the payout ratio is expanding. Eventually something has to give — usually the dividend.</li>
    <li><strong>One-time special dividends:</strong> A company pays a large special dividend (e.g., from an asset sale). Trailing yield spikes, but it won't repeat. Always check whether the yield is based on regular or special dividends.</li>
    <li><strong>Cyclical industry peak:</strong> Energy and materials companies may have high yields at the top of a commodity cycle. When prices fall, so do earnings and dividends.</li>
  </ul>
  <p style="margin-top:1rem"><strong>Rule of thumb:</strong> If a yield looks too good to be true (above 8-10% for a common stock), investigate before investing. Cross-check with the payout ratio calculator above.</p>
</section>

<!-- 9. Key Insights -->
<section class="dyc-section">
  <h2>5 Key Dividend Investing Insights</h2>
  <ul class="insight-list">
    <li><strong>DRIP is the silent wealth builder.</strong> Reinvesting dividends can double or triple your income over a 20-year period compared to taking cash. The compounding effect accelerates over time as you accumulate more shares that generate more dividends.</li>
    <li><strong>Yield alone is misleading.</strong> A 7% yield from a declining company is worse than a 2% yield from one growing dividends at 10% per year. After 10 years of 10% dividend growth, that 2% yield on cost becomes 5.2%.</li>
    <li><strong>Dividend Aristocrats outperform.</strong> Companies that have raised dividends for 25+ consecutive years (S&P 500 Dividend Aristocrats) have historically outperformed the broader market with lower volatility.</li>
    <li><strong>Sector diversification matters.</strong> Utilities and REITs offer high current income, while Technology and Healthcare offer lower yields but faster dividend growth. A balanced portfolio captures both income and appreciation.</li>
    <li><strong>Tax efficiency varies.</strong> Qualified dividends are taxed at lower capital gains rates (0%, 15%, or 20%), while non-qualified dividends are taxed as ordinary income. Holding period and account type (taxable vs. IRA) significantly impact after-tax returns.</li>
  </ul>
</section>

<!-- 10. FAQ -->
<section class="dyc-section faq-section">
  <h2>Frequently Asked Questions</h2>
  <details>
    <summary>What is dividend yield?</summary>
    <div class="faq-body">Dividend yield is the annual dividend payment divided by the current stock price, expressed as a percentage. It tells investors how much cash flow they receive for each dollar invested in a stock. A stock trading at $50 with a $2.00 annual dividend has a 4.0% yield.</div>
  </details>
  <details>
    <summary>What is the dividend yield formula?</summary>
    <div class="faq-body">The dividend yield formula is: <strong>Dividend Yield = (Annual Dividend per Share &divide; Current Stock Price) &times; 100</strong>. For example, a stock paying $2.00 annually at a $50 share price has a 4.0% dividend yield.</div>
  </details>
  <details>
    <summary>What is a good dividend yield?</summary>
    <div class="faq-body">A good dividend yield typically falls between 2% and 6%. Yields below 2% may not provide meaningful income, while yields above 6% may signal elevated risk. The S&P 500 average dividend yield is approximately 1.3% as of 2026. Individual targets depend on your investment goals — income investors may prefer 3-5%, while growth investors may accept 1-2%.</div>
  </details>
  <details>
    <summary>What is dividend payout ratio and why does it matter?</summary>
    <div class="faq-body">The dividend payout ratio measures the percentage of net income paid out as dividends. A ratio below 60% is generally sustainable and leaves room for dividend growth. A ratio of 60-80% warrants monitoring, and above 80% may indicate the dividend is at risk of being cut if earnings decline.</div>
  </details>
  <details>
    <summary>What is a dividend yield trap?</summary>
    <div class="faq-body">A dividend yield trap occurs when a stock's yield appears attractively high but is unsustainable. Common causes include a falling stock price inflating the yield, debt-funded dividends, declining earnings, or one-time special dividends that won't recur. Always investigate yields above 8-10% before investing.</div>
  </details>
</section>

<script is:inline src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script is:inline>
  /* --- 1. Dividend Yield Calculator --- */
  function calcYield() {
    var d = parseFloat(document.getElementById("yc-div").value);
    var p = parseFloat(document.getElementById("yc-price").value);
    var el = document.getElementById("yc-result");
    if (!d || !p || p <= 0) { el.style.display = "block"; el.innerHTML = "<span style='color:#ef4444'>Please enter valid values.</span>"; return; }
    var yld = (d / p) * 100;
    el.style.display = "block";
    el.innerHTML = '<div class="big-num">' + yld.toFixed(2) + '% Yield</div><div class="sub-num">$' + d.toFixed(2) + ' annual dividend on a $' + p.toFixed(2) + ' stock</div>';
  }

  /* --- 2. Dividend Income Calculator --- */
  function toggleIncomeMode() {
    var mode = document.getElementById("ic-mode").value;
    document.getElementById("ic-shares-row").style.display = mode === "shares" ? "block" : "none";
    document.getElementById("ic-dollars-row").style.display = mode === "dollars" ? "block" : "none";
  }
  function calcIncome() {
    var mode = document.getElementById("ic-mode").value;
    var annual = 0;
    if (mode === "shares") {
      var shares = parseFloat(document.getElementById("ic-shares").value);
      var divps = parseFloat(document.getElementById("ic-divps").value);
      if (!shares || !divps) { showIncomeErr(); return; }
      annual = shares * divps;
    } else {
      var invested = parseFloat(document.getElementById("ic-invested").value);
      var yld = parseFloat(document.getElementById("ic-yld").value);
      if (!invested || !yld) { showIncomeErr(); return; }
      annual = invested * (yld / 100);
    }
    var el = document.getElementById("ic-result");
    el.style.display = "block";
    el.innerHTML = '<div class="result-grid"><div class="rg-item"><div class="rg-val">$' + annual.toFixed(2) + '</div><div class="rg-lbl">Annual</div></div><div class="rg-item"><div class="rg-val">$' + (annual / 4).toFixed(2) + '</div><div class="rg-lbl">Quarterly</div></div><div class="rg-item"><div class="rg-val">$' + (annual / 12).toFixed(2) + '</div><div class="rg-lbl">Monthly</div></div></div>';
  }
  function showIncomeErr() { var el = document.getElementById("ic-result"); el.style.display = "block"; el.innerHTML = "<span style='color:#ef4444'>Please enter valid values.</span>"; }

  /* --- 3. Dividend Growth Projector --- */
  var growthChartInstance = null;
  function calcGrowth() {
    var shares = parseFloat(document.getElementById("gc-shares").value);
    var div0 = parseFloat(document.getElementById("gc-div").value);
    var price0 = parseFloat(document.getElementById("gc-price").value);
    var gr = parseFloat(document.getElementById("gc-growth").value);
    var pgr = parseFloat(document.getElementById("gc-priceGrowth").value) || 0;
    var years = parseInt(document.getElementById("gc-years").value) || 20;
    var drip = document.getElementById("gc-drip").checked;
    var el = document.getElementById("gc-result");
    if (!shares || !div0 || !price0 || isNaN(gr)) { el.style.display = "block"; el.innerHTML = "<span style='color:#ef4444'>Please fill in all fields.</span>"; return; }

    var labelsArr = [];
    var noDripData = [];
    var dripData = [];
    var curShares = shares;
    var curSharesNoDrip = shares;
    var curDiv = div0;
    var curPrice = price0;
    var finalDripIncome = 0;
    var finalNoDripIncome = 0;

    for (var y = 0; y <= years; y++) {
      labelsArr.push("Year " + y);
      var incomeNoDrip = curSharesNoDrip * curDiv;
      var incomeDrip = curShares * curDiv;
      noDripData.push(Math.round(incomeNoDrip * 100) / 100);
      dripData.push(Math.round(incomeDrip * 100) / 100);
      if (y === years) { finalDripIncome = incomeDrip; finalNoDripIncome = incomeNoDrip; break; }
      /* DRIP: reinvest dividends at current price */
      if (drip && curPrice > 0) {
        var newShares = incomeDrip / curPrice;
        curShares = curShares + newShares;
      }
      curDiv = curDiv * (1 + gr / 100);
      curPrice = curPrice * (1 + pgr / 100);
    }

    el.style.display = "block";
    var html = '<div class="result-grid">';
    html += '<div class="rg-item"><div class="rg-val">$' + finalNoDripIncome.toFixed(2) + '</div><div class="rg-lbl">Year ' + years + ' (No DRIP)</div></div>';
    if (drip) { html += '<div class="rg-item"><div class="rg-val" style="color:#10b981">$' + finalDripIncome.toFixed(2) + '</div><div class="rg-lbl">Year ' + years + ' (DRIP)</div></div>'; }
    html += '<div class="rg-item"><div class="rg-val">$' + curDiv.toFixed(2) + '</div><div class="rg-lbl">Projected DPS</div></div>';
    if (drip) { html += '<div class="rg-item"><div class="rg-val">' + curShares.toFixed(1) + '</div><div class="rg-lbl">Total Shares (DRIP)</div></div>'; }
    html += '</div>';
    el.innerHTML = html;

    /* Chart */
    var ctx = document.getElementById("growthChart").getContext("2d");
    if (growthChartInstance) { growthChartInstance.destroy(); }
    var datasets = [{ label: "No DRIP", data: noDripData, borderColor: "#4a8fe7", backgroundColor: "rgba(74,143,231,0.1)", fill: true, tension: 0.3 }];
    if (drip) { datasets.push({ label: "With DRIP", data: dripData, borderColor: "#10b981", backgroundColor: "rgba(16,185,129,0.1)", fill: true, tension: 0.3 }); }
    growthChartInstance = new Chart(ctx, {
      type: "line",
      data: { labels: labelsArr, datasets: datasets },
      options: { responsive: true, plugins: { legend: { labels: { color: "#9aa0a6" } } }, scales: { x: { ticks: { color: "#9aa0a6" }, grid: { color: "rgba(255,255,255,0.05)" } }, y: { ticks: { color: "#9aa0a6", callback: function(v) { return "$" + v.toLocaleString(); } }, grid: { color: "rgba(255,255,255,0.05)" } } } }
    });
  }

  /* --- 4. Sector Yield Chart --- */
  (function() {
    var sCtx = document.getElementById("sectorChart").getContext("2d");
    var sectorLabels = ["Energy", "Utilities", "Real Estate", "Financials", "Consumer Staples", "Materials", "Industrials", "Healthcare", "Comm. Services", "Consumer Disc.", "Technology"];
    var sectorYields = [3.5, 3.2, 3.0, 2.1, 2.0, 1.9, 1.7, 1.6, 1.1, 0.9, 0.8];
    var colors = sectorYields.map(function(v) { return v >= 3.0 ? "#10b981" : v >= 2.0 ? "#4a8fe7" : "#9aa0a6"; });
    new Chart(sCtx, {
      type: "bar",
      data: { labels: sectorLabels, datasets: [{ label: "Avg Dividend Yield %", data: sectorYields, backgroundColor: colors, borderRadius: 6 }] },
      options: { indexAxis: "y", responsive: true, plugins: { legend: { display: false } }, scales: { x: { ticks: { color: "#9aa0a6", callback: function(v) { return v + "%"; } }, grid: { color: "rgba(255,255,255,0.05)" } }, y: { ticks: { color: "#c9d1d9" }, grid: { display: false } } } }
    });
  })();

  /* --- 5. Payout Ratio Calculator --- */
  function calcPayout() {
    var divs = parseFloat(document.getElementById("pc-divs").value);
    var net = parseFloat(document.getElementById("pc-net").value);
    var el = document.getElementById("pc-result");
    if (!divs || !net || net <= 0) { el.style.display = "block"; el.innerHTML = "<span style='color:#ef4444'>Please enter valid values.</span>"; return; }
    var ratio = (divs / net) * 100;
    var cls = "sustainable";
    var label = "Sustainable";
    var desc = "The company retains a healthy portion of earnings for growth and stability.";
    if (ratio > 80) { cls = "risky"; label = "Risky"; desc = "The company is paying out most of its earnings. Dividend cuts are possible if earnings decline."; }
    else if (ratio > 60) { cls = "watch"; label = "Watch"; desc = "Payout is elevated. Monitor earnings trends to ensure sustainability."; }
    el.style.display = "block";
    el.innerHTML = '<div class="big-num">' + ratio.toFixed(1) + '% Payout Ratio</div><div><span class="payout-badge ' + cls + '">' + label + '</span></div><div class="sub-num" style="margin-top:0.5rem">' + desc + '</div>';
  }

  /* --- 6. Yield on Cost Calculator --- */
  function calcYOC() {
    var buy = parseFloat(document.getElementById("yoc-buy").value);
    var div2 = parseFloat(document.getElementById("yoc-div").value);
    var el = document.getElementById("yoc-result");
    if (!buy || !div2 || buy <= 0) { el.style.display = "block"; el.innerHTML = "<span style='color:#ef4444'>Please enter valid values.</span>"; return; }
    var yoc = (div2 / buy) * 100;
    el.style.display = "block";
    el.innerHTML = '<div class="big-num">' + yoc.toFixed(2) + '% Yield on Cost</div><div class="sub-num">Your original $' + buy.toFixed(2) + ' investment now yields ' + yoc.toFixed(2) + '% annually.</div>';
  }
</script>

</SiteLayout>
