  }
};

/* ═══════════════════════════════════════════════════════════════
   DATA FETCHING & PARSING
   ═══════════════════════════════════════════════════════════════ */
const headers = {
  "User-Agent": "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36",
  "Accept": "text/html,application/xhtml+xml,application/xml;q=0.9,image/webp,*/*;q=0.8",
  "Accept-Language": "en-US,en;q=0.5"
};

async function fetchPage(url: string) {
  try {
    const res = await fetch(url, { headers });
    if (!res.ok) throw new Error(`HTTP ${res.status}`);
    return await res.text();
  } catch (e) {
    console.error(`Error fetching ${url}:`, e);
    return null;
  }
}

function parseTable(html: string | null, rowNames: string[]) {
  if (!html) return {};
  const $ = cheerio.load(html);
  const data: Record<string, (number | null)[]> = {};

  const years: string[] = [];
  $('table thead tr th').each((i, el) => {
    if (i > 0) {
      const text = $(el).text().trim();
      if (text.match(/20\d\d/)) {
        years.push(text);
      }
    }
  });
  data.years = years as any;

  $('table tbody tr').each((i, el) => {
    const firstTd = $(el).find('td').first().text().trim();
    for (const name of rowNames) {
      if (firstTd === name) {
        const values: (number | null)[] = [];
        $(el).find('td').each((j, td) => {
          if (j > 0) {
            let val = $(td).text().trim().replace(/,/g, '');
            if (val === '-' || val === '') {
              values.push(null);
            } else {
              values.push(parseFloat(val));
            }
          }
        });
        data[name] = values;
      }
    }
  });
  return data;
}

const finHtml = await fetchPage('https://stockanalysis.com/stocks/fcx/financials/');
const cfHtml = await fetchPage('https://stockanalysis.com/stocks/fcx/financials/cash-flow-statement/');
const bsHtml = await fetchPage('https://stockanalysis.com/stocks/fcx/financials/balance-sheet/');

const priceMatch = finHtml ? finHtml.match(/<div class="[^"]*text-4xl[^"]*"[^>]*>([\d\.,]+)<\/div>/) : null;
const currentPrice = priceMatch ? parseFloat(priceMatch[1].replace(/,/g, '')) : 55.45;

const finData = parseTable(finHtml, ['Revenue', 'Operating Income', 'Net Income', 'EPS (Diluted)', 'Shares Outstanding (Diluted)']);
const cfData = parseTable(cfHtml, ['Free Cash Flow', 'Operating Cash Flow']);
const bsData = parseTable(bsHtml, ['Cash & Equivalents', 'Total Debt']);

// Extract recent year values
// We use the first element since the table is typically sorted newest to oldest.
const revenueBase = finData['Revenue']?.[0] !== undefined ? finData['Revenue'][0] : null;
const operatingIncomeBase = finData['Operating Income']?.[0] !== undefined ? finData['Operating Income'][0] : null;
const netIncomeBase = finData['Net Income']?.[0] !== undefined ? finData['Net Income'][0] : null;
const epsBase = finData['EPS (Diluted)']?.[0] !== undefined ? finData['EPS (Diluted)'][0] : null;
const sharesOutstandingBase = finData['Shares Outstanding (Diluted)']?.[0] !== undefined ? finData['Shares Outstanding (Diluted)'][0] : null;
const fcfBase = cfData['Free Cash Flow']?.[0] !== undefined ? cfData['Free Cash Flow'][0] : null;
const ocfBase = cfData['Operating Cash Flow']?.[0] !== undefined ? cfData['Operating Cash Flow'][0] : null;
const cashBase = bsData['Cash & Equivalents']?.[0] !== undefined ? bsData['Cash & Equivalents'][0] : null;
const debtBase = bsData['Total Debt']?.[0] !== undefined ? bsData['Total Debt'][0] : null;

// Validate essential data
if (fcfBase === null || sharesOutstandingBase === null || cashBase === null || debtBase === null || ocfBase === null) {
    throw new Error("Failed to extract essential financial data from stockanalysis.com");
}

/* ═══════════════════════════════════════════════════════════════
   DCF MODEL — ALL INPUTS AND CALCULATIONS
   ═══════════════════════════════════════════════════════════════ */

// --- INPUTS (all in millions USD unless noted) ---
// Freeport-McMoRan is a capital intensive mining company, FCF can be volatile.
// Operating Cash Flow (OCF) gives a smoother baseline.
// We will use a baseline "Normalized FCF" approach using average OCF minus Maintenance CapEx, or use a more conservative FCF base.
// The actual FY25 FCF was 1116, while OCF was 5610. Let's use the actual FCF for a conservative base case, or average FCF.
// Given the prompt suggests OCF $5,610M and FCF $1,116M, and FCF can be volatile due to CapEx timing,
// using a single year's FCF for a mining co can be misleading, but to stay true to "actuals" we will project from the actual FCF base but acknowledge the OCF.
// Actually, mining companies' CapEx is massive and necessary. FCF is the true return.
const fcfStart = fcfBase; // Using actual FY2025 FCF as starting point.

const sharesOutstanding = sharesOutstandingBase;
const cashAndInvestments = cashBase;
const totalDebt = debtBase;
const netCash = cashAndInvestments - totalDebt;

// --- ASSUMPTIONS ---
const growthRatePhase1 = 0.08;         // 8% FCF growth, Years 1-5
const growthRateTerminal = 0.025;      // 2.5% perpetuity growth (terminal)
const discountRate = 0.11;             // 11% WACC / required return

// --- PHASE 1: PROJECT FCF FOR YEARS 1-5 ---
const projectedFCF = [];
let fcf = fcfStart;
for (let yr = 1; yr <= 5; yr++) {
  fcf = fcf * (1 + growthRatePhase1);
  projectedFCF.push({ year: yr, fcf: Math.round(fcf), pvFactor: 1 / Math.pow(1 + discountRate, yr) });
}
projectedFCF.forEach(p => { p.pvFCF = Math.round(p.fcf * p.pvFactor); });

// --- PHASE 2: TERMINAL VALUE (Gordon Growth Model) ---
const fcfYear6 = projectedFCF[4].fcf * (1 + growthRateTerminal);
const terminalValue = Math.round(fcfYear6 / (discountRate - growthRateTerminal));
const pvTerminalValue = Math.round(terminalValue * projectedFCF[4].pvFactor);

// --- ENTERPRISE VALUE ---
const pvPhase1 = projectedFCF.reduce((sum, p) => sum + p.pvFCF, 0);
const enterpriseValue = pvPhase1 + pvTerminalValue;

// --- EQUITY VALUE ---
const equityValue = enterpriseValue + netCash;
const intrinsicValuePerShare = equityValue / sharesOutstanding;
const roundedIV = Math.round(intrinsicValuePerShare * 100) / 100;

// Market comparison
const marginOfSafety = ((roundedIV - currentPrice) / currentPrice * 100).toFixed(1);
const verdictText = roundedIV > currentPrice ? "Undervalued" : "Overvalued";
const verdictColor = roundedIV > currentPrice ? "#10b981" : "#ef4444";

// --- HISTORICAL DATA for charts ---
// Reconstruct arrays starting from the oldest available (index 4 to 0 usually for 5 years)
const yearsArr = finData.years ? Object.values(finData.years).slice(0, 5).reverse() : ['2021', '2022', '2023', '2024', '2025'];

const extractHistory = (arr: (number | null)[] | undefined) => {
  if (!arr) return [null, null, null, null, null];
  return arr.slice(0, 5).reverse();
};

const revHist = extractHistory(finData['Revenue']);
const fcfHist = extractHistory(cfData['Free Cash Flow']);
const epsHist = extractHistory(finData['EPS (Diluted)']);
const opIncHist = extractHistory(finData['Operating Income']);
const netIncHist = extractHistory(finData['Net Income']);

const revenueHistory = yearsArr.map((y, i) => ({ year: y, value: revHist[i] }));
const fcfHistory = yearsArr.map((y, i) => ({ year: y, value: fcfHist[i] }));
const epsHistory = yearsArr.map((y, i) => ({ year: y, value: epsHist[i] }));

const marginHistory = yearsArr.map((y, i) => {
  const rev = revHist[i];
  const op = opIncHist[i];
  const net = netIncHist[i];
  const fc = fcfHist[i];

  return {
    year: y,
    operating: rev && op ? ((op / rev) * 100).toFixed(2) : 'N/A',
    profit: rev && net ? ((net / rev) * 100).toFixed(2) : 'N/A',
    fcfMargin: rev && fc ? ((fc / rev) * 100).toFixed(2) : 'N/A'
  };
});

// Sensitivity analysis
const sensitivityRates = [0.09, 0.10, 0.11, 0.12, 0.13];
const sensitivityGrowth = [0.04, 0.06, 0.08, 0.10, 0.12];
const sensitivityTable = sensitivityRates.map(dr => {
  return {
    dr,
    values: sensitivityGrowth.map(gr => {
      let f = fcfStart;
      let pvSum = 0;
      for (let y = 1; y <= 5; y++) {
        f = f * (1 + gr);
        pvSum += f / Math.pow(1 + dr, y);
      }
      const f6 = f * (1 + growthRateTerminal);
      const tv = f6 / (dr - growthRateTerminal);
      const pvTV = tv / Math.pow(1 + dr, 5);
      return Math.round((pvSum + pvTV + netCash) / sharesOutstanding);
    })
  };
});
