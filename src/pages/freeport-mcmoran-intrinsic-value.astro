export const meta = {
  title: "Freeport-McMoRan (FCX) Intrinsic Value: A DCF Analysis",
  description: "We ran a full discounted cash flow on Freeport-McMoRan using FY2025 actuals. One number. Every assumption disclosed. Here's what FCX is really worth.",
  category: "study",
  published: "2026-03-18",
};

import SiteLayout from "../layouts/SiteLayout.astro";
import * as cheerio from 'cheerio';

const schema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": "Freeport-McMoRan (FCX) Intrinsic Value: A DCF Analysis",
  "description": "A transparent, step-by-step discounted cash flow valuation of Freeport-McMoRan. Using actual FY2025 financials to arrive at a single fair value estimate for FCX shares.",
  "datePublished": "2026-03-18",
  "dateModified": "2026-03-18",
  "author": {
    "@type": "Organization",
    "name": "Westmount Research",
    "url": "https://westmountfundamentals.com"
  },
