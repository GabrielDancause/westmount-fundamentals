    "@id": "https://westmountfundamentals.com/blackstone-intrinsic-value"
  }
};

export const meta = {
  title: "Blackstone Inc. (BX) Intrinsic Value",
  description: "A step-by-step discounted cash flow valuation of Blackstone Inc. using actual FY2025 financials to arrive at a single fair value estimate for BX shares.",
  category: "study",
  published: "2026-03-18",
};

/* ═══════════════════════════════════════════════════════════════
   DCF MODEL — ALL INPUTS AND CALCULATIONS
   Every number is sourced from Blackstone's FY2025 financials.
   We use a two-stage DCF: high-growth phase (Years 1-5) then terminal value.
   ═══════════════════════════════════════════════════════════════ */

// --- INPUTS (all in millions USD unless noted) ---
const fcf2025 = 4547;                  // FY2025 Free Cash Flow ($M)
const sharesOutstanding = 780;         // Diluted shares outstanding ($M) — FY2025
const cashAndInvestments = 2631;       // Cash + short-term investments ($M)
const totalDebt = 13306;               // Total debt ($M)
const netCash = cashAndInvestments - totalDebt; // -$10,675M

// --- ASSUMPTIONS (fully disclosed below) ---
const growthRatePhase1 = 0.15;         // 15% FCF growth, Years 1-5
const growthRateTerminal = 0.035;      // 3.5% perpetuity growth (terminal)
const discountRate = 0.10;             // 10% WACC / required return

// --- PHASE 1: PROJECT FCF FOR YEARS 1-5 ---
const projectedFCF = [];
let fcf = fcf2025;
for (let yr = 1; yr <= 5; yr++) {
  fcf = fcf * (1 + growthRatePhase1);
  projectedFCF.push({ year: yr, fcf: Math.round(fcf), pvFactor: 1 / Math.pow(1 + discountRate, yr) });
}
projectedFCF.forEach(p => { p.pvFCF = Math.round(p.fcf * p.pvFactor); });

// --- PHASE 2: TERMINAL VALUE (Gordon Growth Model) ---
const fcfYear6 = projectedFCF[4].fcf * (1 + growthRateTerminal);
const terminalValue = Math.round(fcfYear6 / (discountRate - growthRateTerminal));
const pvTerminalValue = Math.round(terminalValue * projectedFCF[4].pvFactor);

// --- ENTERPRISE VALUE ---
const pvPhase1 = projectedFCF.reduce((sum, p) => sum + p.pvFCF, 0);
const enterpriseValue = pvPhase1 + pvTerminalValue;

// --- EQUITY VALUE ---
const equityValue = enterpriseValue + netCash;
const intrinsicValuePerShare = equityValue / sharesOutstanding;
const roundedIV = Math.round(intrinsicValuePerShare * 100) / 100;

// Market comparison
const currentPrice = null;
const marginOfSafety = currentPrice ? ((roundedIV - currentPrice) / currentPrice * 100).toFixed(1) : null;
const verdictText = currentPrice ? (roundedIV > currentPrice ? "Undervalued" : "Overvalued") : "N/A";
const verdictColor = currentPrice ? (roundedIV > currentPrice ? "#10b981" : "#ef4444") : "#7a8a9e";

// --- HISTORICAL DATA for charts ---
const revenueHistory = [
  { year: 2021, value: 22577 },
  { year: 2022, value: 8518 },
  { year: 2023, value: 8023 },
  { year: 2024, value: 13230 },
  { year: 2025, value: 14450 },
];
const fcfHistory = [
  { year: 2021, value: 3922 },
  { year: 2022, value: 6101 },
  { year: 2023, value: 3833 },
  { year: 2024, value: 3420 },
  { year: 2025, value: 4547 },
];
const epsHistory = [
  { year: 2021, value: 8.13 },
  { year: 2022, value: 2.36 },
  { year: 2023, value: 1.84 },
  { year: 2024, value: 3.62 },
  { year: 2025, value: 3.87 },
];
const marginHistory = [
  { year: 2021, operating: 58.90, profit: 54.81, fcfMargin: 17.37 },
  { year: 2022, operating: 45.34, profit: 35.09, fcfMargin: 71.62 },
  { year: 2023, operating: 43.30, profit: 30.47, fcfMargin: 47.78 },
  { year: 2024, operating: 51.81, profit: 41.10, fcfMargin: 25.85 },
  { year: 2025, operating: 50.21, profit: 41.84, fcfMargin: 31.47 },
];

// Sensitivity analysis
const sensitivityRates = [0.08, 0.09, 0.10, 0.11, 0.12];
const sensitivityGrowth = [0.11, 0.13, 0.15, 0.17, 0.19];
const sensitivityTable = sensitivityRates.map(dr => {
  return {
    dr,
    values: sensitivityGrowth.map(gr => {
      let f = fcf2025;
      let pvSum = 0;
      for (let y = 1; y <= 5; y++) {
        f = f * (1 + gr);
        pvSum += f / Math.pow(1 + dr, y);
      }
      const f6 = f * (1 + growthRateTerminal);
      const tv = f6 / (dr - growthRateTerminal);
      const pvTV = tv / Math.pow(1 + dr, 5);
      return Math.round((pvSum + pvTV + netCash) / sharesOutstanding);
    })
  };
});
