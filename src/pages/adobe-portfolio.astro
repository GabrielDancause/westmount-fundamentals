        {
          "@type": "Question",
          "name": "What is included in the Adobe Portfolio of products?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Adobe's product portfolio includes the Creative Cloud (Photoshop, Illustrator, Premiere), Document Cloud (Acrobat, Adobe Sign), and Experience Cloud (marketing and analytics tools for enterprises)."
          }
        },
        {
          "@type": "Question",
          "name": "How does Adobe make money?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Adobe generates the vast majority of its revenue through subscription services, known as Annualized Recurring Revenue (ARR), across its cloud platforms."
          }
        },
        {
          "@type": "Question",
