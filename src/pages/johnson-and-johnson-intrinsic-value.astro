---
import SiteLayout from "../layouts/SiteLayout.astro";

// --- METADATA ---
export const meta = {
  title: "Johnson & Johnson (JNJ) Intrinsic Value - Gemini's DCF Analysis",
  description: "An independent discounted cash flow (DCF) intrinsic value analysis of Johnson & Johnson (JNJ) compiled entirely by Gemini 3.1.",
  category: "study",
  published: "2026-03-18",
};

// --- DATA & ASSUMPTIONS (FY2025 Actuals via S&P Global Market Intelligence) ---
// FCF Growth (Y1-Y5): 5.5%. As a mature healthcare conglomerate, JNJ has steady but slow growth, mostly driven by its pharmaceutical pipeline and MedTech acquisitions post-Kenvue spin-off.
// Discount Rate (WACC): 6.5%. JNJ is one of only two companies with a AAA credit rating. Its beta is incredibly low (0.55). With a 4.18% 10-Year Treasury rate, the WACC is minimal because the company is considered one of the safest equity investments in the world.
// Terminal Growth: 2.5%. Reflects long-term inflation and healthcare spending growth matching GDP.

const baseFCF = 19313; // in Millions
const sharesOut = 2410; // in Millions
const currentPrice = 238.96;
const netCash = -27831; // Cash & ST investments - Total Debt (in Millions)

const fcfGrowthRate = 0.055;
const discountRate = 0.065;
const terminalGrowthRate = 0.025;

// --- YEAR 1 TO 5 PROJECTIONS ---
const projections = [];
let prevFCF = baseFCF;

for (let i = 1; i <= 5; i++) {
  const projectedFCF = prevFCF * (1 + fcfGrowthRate);
  const discountFactor = Math.pow(1 + discountRate, i);
  const pvOfFCF = projectedFCF / discountFactor;

  projections.push({
    year: `Year ${i}`,
    fcf: projectedFCF,
    pv: pvOfFCF
  });

  prevFCF = projectedFCF;
}

const sumPvFcf = projections.reduce((sum, p) => sum + p.pv, 0);

// --- TERMINAL VALUE ---
const year5FCF = projections[4].fcf;
const terminalValue = (year5FCF * (1 + terminalGrowthRate)) / (discountRate - terminalGrowthRate);
const pvTerminalValue = terminalValue / Math.pow(1 + discountRate, 5);

// --- INTRINSIC VALUE CALCULATION ---
const enterpriseValue = sumPvFcf + pvTerminalValue;
const totalEquityValue = enterpriseValue + netCash;
const intrinsicValuePerShare = totalEquityValue / sharesOut;

// Value vs Current Price
const marginOfSafety = ((intrinsicValuePerShare - currentPrice) / currentPrice) * 100;
const isUndervalued = intrinsicValuePerShare > currentPrice;

// --- SENSITIVITY MATRIX ---
const sensitivityDiscountRates = [0.055, 0.060, 0.065, 0.070, 0.075];
const sensitivityGrowthRates = [0.015, 0.020, 0.025, 0.030, 0.035];

const sensitivityMatrix = sensitivityGrowthRates.map(g => {
  return {
    growthRate: g,
    values: sensitivityDiscountRates.map(d => {
      const currentTerminalValue = (year5FCF * (1 + g)) / (d - g);
      const currentPvTerminalValue = currentTerminalValue / Math.pow(1 + d, 5);

      let currentSumPvFcf = 0;
      let tempFcf = baseFCF;
      for (let i = 1; i <= 5; i++) {
        tempFcf = tempFcf * (1 + fcfGrowthRate);
        currentSumPvFcf += tempFcf / Math.pow(1 + d, i);
      }

      const currentEV = currentSumPvFcf + currentPvTerminalValue;
      const currentEquity = currentEV + netCash;
      const currentIV = currentEquity / sharesOut;

      return currentIV;
    })
  };
});

// Formatting helpers
const formatMoney = (val) => new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD', minimumFractionDigits: 2, maximumFractionDigits: 2 }).format(val);
const formatMillions = (val) => '$' + new Intl.NumberFormat('en-US', { maximumFractionDigits: 0 }).format(val) + 'M';
const formatPercent = (val) => (val * 100).toFixed(1) + '%';

// --- SCHEMA ---
const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Article",
      "headline": meta.title,
      "description": meta.description,
      "author": {
        "@type": "Organization",
        "name": "Gemini 3.1"
      },
      "publisher": {
        "@type": "Organization",
        "name": "Westmount Fundamentals",
        "logo": {
          "@type": "ImageObject",
          "url": "https://westmountfundamentals.com/logo.png"
        }
      },
      "mainEntityOfPage": {
        "@type": "WebPage",
        "@id": "https://westmountfundamentals.com/johnson-and-johnson-intrinsic-value"
      }
    },
    {
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "Why did Gemini pick a 5.5% growth rate for Johnson & Johnson?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Gemini models a conservative 5.5% growth rate to reflect JNJ's massive scale and maturity as an established healthcare provider. While the MedTech and Innovative Medicine divisions post-Kenvue spin-off are highly profitable, they are difficult to grow at double-digit rates without aggressive M&A."
          }
        },
        {
          "@type": "Question",
          "name": "What discount rate was used for JNJ's DCF?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "A 6.5% discount rate was used. JNJ's AAA credit rating, deep economic moat, and 0.55 beta make it one of the least volatile investments in the market, allowing for a WACC very close to the risk-free rate."
          }
        },
        {
          "@type": "Question",
          "name": "Why does JNJ have negative net cash in the model?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "JNJ carries significant long-term debt to finance operations and large acquisitions (like Abiomed and Shockwave Medical). With around $47.9B in debt against roughly $20B in cash, the net cash is -$27.8B, which reduces the final equity value."
          }
        }
      ]
    }
  ]
};
---
<SiteLayout site="westmount" title={meta.title} description={meta.description} canonical="https://westmountfundamentals.com/johnson-and-johnson-intrinsic-value" schema={schema}>
  <div class="page-content">
    <div class="container">

      <div class="gemini-header">
        <div class="gemini-badge">COMPILED BY GEMINI 2.5 PRO</div>
        <h1>Johnson & Johnson (JNJ) Intrinsic Value</h1>
        <p class="subtitle">An independent two-stage DCF analysis by a frontier AI model.</p>
      </div>

      <div class="verdict-card">
        <div class="verdict-header">
          <h2>Fair Value Estimate</h2>
        </div>
        <div class="verdict-body">
          <div class="verdict-main">
            <span class="iv-value">{formatMoney(intrinsicValuePerShare)}</span>
            <span class="iv-label">per share</span>
          </div>
          <div class="verdict-stats">
            <div class="stat">
              <span class="stat-label">Current Price</span>
              <span class="stat-value">{formatMoney(currentPrice)}</span>
            </div>
            <div class="stat">
              <span class="stat-label">Margin of Safety</span>
              <span class={`stat-value ${isUndervalued ? 'positive' : 'negative'}`}>
                {isUndervalued ? '+' : ''}{marginOfSafety.toFixed(2)}%
              </span>
            </div>
            <div class="stat">
              <span class="stat-label">Verdict</span>
              <span class={`badge ${isUndervalued ? 'positive' : 'negative'}`}>
                {isUndervalued ? 'UNDERVALUED' : 'OVERVALUED'}
              </span>
            </div>
          </div>
        </div>
        <div class="verdict-footer">
          <p>Based on FY2025 actuals. Data via S&P Global (Mar 18, 2026).</p>
        </div>
      </div>

      <section class="content-section">
        <h2>The AI Thesis: Safe Haven Reliability</h2>
        <p>Johnson & Johnson represents the ultimate defensive stock. As one of only two U.S. corporations retaining an elite AAA credit rating, it is often viewed as being as financially secure as the U.S. government. Following the spin-off of its consumer health division (Kenvue), JNJ is now a highly focused, higher-margin entity concentrating exclusively on Innovative Medicine and MedTech.</p>
        <p>This valuation model doesn't assume hyper-growth; rather, it prices in the immense value of certainty. In an increasingly volatile macro environment, JNJ's ability to consistently generate nearly $20B in Free Cash Flow annually commands a premium multiple by way of a heavily discounted WACC.</p>
      </section>

      <section class="content-section">
        <h2>My Assumptions & Rationale</h2>

        <div class="assumption-grid">
          <div class="assumption-card">
            <div class="card-title">FCF Growth Rate (Y1-Y5)</div>
            <div class="card-value">{formatPercent(fcfGrowthRate)}</div>
            <p><strong>Rationale:</strong> 5.5% reflects realistic, single-digit expansion for a mature titan. The company's pipeline and strategic acquisitions in cardiovascular tech (like Shockwave Medical) provide steady upside, perfectly offsetting the inevitable patent cliffs of blockbuster drugs like Stelara. The scale of JNJ prevents explosive percentage growth.</p>
          </div>

          <div class="assumption-card">
            <div class="card-title">Discount Rate (WACC)</div>
            <div class="card-value">{formatPercent(discountRate)}</div>
            <p><strong>Rationale:</strong> 6.5% is exceptionally low, but mathematically sound. Given the 10-Year Treasury rate of 4.18% and JNJ's extremely low 0.55 beta, the Capital Asset Pricing Model dictates a minimal risk premium. Investors demand very little excess return for owning JNJ compared to holding risk-free bonds.</p>
          </div>

          <div class="assumption-card">
            <div class="card-title">Terminal Growth Rate</div>
            <div class="card-value">{formatPercent(terminalGrowthRate)}</div>
            <p><strong>Rationale:</strong> 2.5% is an alignment with global healthcare spending and long-term inflation. JNJ is fundamentally tied to the aging demographics of the developed world. It will continue to grow at or slightly above global GDP in perpetuity.</p>
          </div>
        </div>
      </section>

      <section class="content-section">
        <h2>Discounted Cash Flow (DCF) Projections</h2>
        <p>Starting with the FY2025 base FCF of {formatMillions(baseFCF)}, the table below outlines the 5-year projection discounted back to Present Value (PV) using the {formatPercent(discountRate)} WACC.</p>

        <div class="table-container">
          <table>
            <thead>
              <tr>
                <th>Period</th>
                <th>Projected FCF</th>
                <th>PV Factor ({formatPercent(discountRate)})</th>
                <th>Present Value</th>
              </tr>
            </thead>
            <tbody>
              {projections.map((p, index) => (
                <tr>
                  <td>{p.year}</td>
                  <td>{formatMillions(p.fcf)}</td>
                  <td>{(1 / Math.pow(1 + discountRate, index + 1)).toFixed(4)}</td>
                  <td>{formatMillions(p.pv)}</td>
                </tr>
              ))}
              <tr class="highlight-row">
                <td colspan="3"><strong>Sum of PV of FCFs (Years 1-5)</strong></td>
                <td><strong>{formatMillions(sumPvFcf)}</strong></td>
              </tr>
            </tbody>
          </table>
        </div>
      </section>

      <section class="content-section">
        <h2>Terminal & Final Valuation Math</h2>
        <p>The Terminal Value accounts for all cash flows from Year 6 into perpetuity, calculated using the Gordon Growth Model.</p>

        <div class="math-card">
          <div class="math-row">
            <span>Year 5 FCF</span>
            <span>{formatMillions(year5FCF)}</span>
          </div>
          <div class="math-row">
            <span>Terminal Value (TV) Calculation</span>
            <span>({formatMillions(year5FCF)} * {1 + terminalGrowthRate}) / ({discountRate} - {terminalGrowthRate})</span>
          </div>
          <div class="math-row">
            <span>Terminal Value</span>
            <span>{formatMillions(terminalValue)}</span>
          </div>
          <div class="math-row highlight">
            <span>PV of Terminal Value</span>
            <span>{formatMillions(pvTerminalValue)}</span>
          </div>
        </div>

        <p style="margin-top: 2rem;">Adding it all together with Net Cash (Cash minus Total Debt):</p>

        <div class="math-card">
          <div class="math-row">
            <span>Sum of PV of FCFs (Years 1-5)</span>
            <span>{formatMillions(sumPvFcf)}</span>
          </div>
          <div class="math-row">
            <span>+ PV of Terminal Value</span>
            <span>{formatMillions(pvTerminalValue)}</span>
          </div>
          <div class="math-row">
            <span><strong>= Enterprise Value</strong></span>
            <span><strong>{formatMillions(enterpriseValue)}</strong></span>
          </div>
          <div class="math-row">
            <span>+ Net Cash (Cash - Debt)</span>
            <span>{formatMillions(netCash)}</span>
          </div>
          <div class="math-row highlight">
            <span><strong>= Total Equity Value</strong></span>
            <span><strong>{formatMillions(totalEquityValue)}</strong></span>
          </div>
          <div class="math-row">
            <span>÷ Shares Outstanding</span>
            <span>{sharesOut.toLocaleString()}M</span>
          </div>
          <div class="math-row result">
            <span><strong>Intrinsic Value Per Share</strong></span>
            <span><strong>{formatMoney(intrinsicValuePerShare)}</strong></span>
          </div>
        </div>
      </section>

      <section class="content-section">
        <h2>Sensitivity Matrix</h2>
        <p>A single intrinsic value relies on rigid assumptions. The sensitivity matrix below demonstrates how the intrinsic value changes when we adjust the Discount Rate (WACC) and the Terminal Growth Rate.</p>

        <div class="table-container sensitivity-table">
          <table>
            <thead>
              <tr>
                <th rowspan="2" class="corner-cell">Terminal<br/>Growth</th>
                <th colspan="5" class="header-cell">Discount Rate (WACC)</th>
              </tr>
              <tr>
                {sensitivityDiscountRates.map(d => <th>{formatPercent(d)}</th>)}
              </tr>
            </thead>
            <tbody>
              {sensitivityMatrix.map(row => (
                <tr>
                  <th class="row-header">{formatPercent(row.growthRate)}</th>
                  {row.values.map(val => (
                    <td class={
                      val > currentPrice * 1.10 ? "cell-undervalued" :
                      val < currentPrice * 0.90 ? "cell-overvalued" :
                      "cell-neutral"
                    }>
                      {formatMoney(val)}
                    </td>
                  ))}
                </tr>
              ))}
            </tbody>
          </table>
          <div class="matrix-legend">
            <span class="legend-item"><span class="color-box cell-undervalued"></span> Undervalued (>10% Margin)</span>
            <span class="legend-item"><span class="color-box cell-neutral"></span> Fair Value</span>
            <span class="legend-item"><span class="color-box cell-overvalued"></span> Overvalued (&lt;-10% Margin)</span>
          </div>
        </div>
      </section>

      <section class="content-section risks-section">
        <h2>Risks & Bear Case</h2>
        <p>Even a AAA-rated titan carries specific operational and macro vulnerabilities:</p>
        <div class="risk-grid">
          <div class="risk-card">
            <h3>1. The Patent Cliff</h3>
            <p>JNJ generates a massive portion of its revenues from blockbuster drugs like Stelara. As key patents expire in international markets and face biosimilar competition, defending revenue run-rates requires near-perfect execution on their upcoming drug pipeline.</p>
          </div>
          <div class="risk-card">
            <h3>2. Litigation Liabilities</h3>
            <p>While the spin-off of Kenvue insulated JNJ from talc liabilities, the broader pharmaceutical sector is always exposed to massive multi-district litigation over product safety. Unforeseen side effects of new treatments remain an existential, multi-billion-dollar tail risk.</p>
          </div>
          <div class="risk-card">
            <h3>3. High-Interest Rate Sensitivity</h3>
            <p>Because JNJ is heavily prized for its reliable dividend and low-risk profile, its stock acts much like a high-yield bond. If the 10-Year Treasury yield remains structurally higher for longer, the relative attractiveness of JNJ's dividend diminishes, causing multiple compression.</p>
          </div>
        </div>
      </section>

      <section class="content-section faq-section">
        <h2>Frequently Asked Questions</h2>

        <div class="faq-item">
          <h3>Why did Gemini pick a 5.5% growth rate for Johnson & Johnson?</h3>
          <p>Gemini models a conservative 5.5% growth rate to reflect JNJ's massive scale and maturity as an established healthcare provider. While the MedTech and Innovative Medicine divisions post-Kenvue spin-off are highly profitable, they are difficult to grow at double-digit rates without aggressive M&A.</p>
        </div>

        <div class="faq-item">
          <h3>What discount rate was used for JNJ's DCF?</h3>
          <p>A 6.5% discount rate was used. JNJ's AAA credit rating, deep economic moat, and 0.55 beta make it one of the least volatile investments in the market, allowing for a WACC very close to the risk-free rate.</p>
        </div>

        <div class="faq-item">
          <h3>Why does JNJ have negative net cash in the model?</h3>
          <p>JNJ carries significant long-term debt to finance operations and large acquisitions (like Abiomed and Shockwave Medical). With around $47.9B in debt against roughly $20B in cash, the net cash is -$27.8B, which reduces the final equity value.</p>
        </div>
      </section>

      <div class="disclaimer-box">
        <p><strong>Disclaimer:</strong> The numbers presented on this page are for educational and entertainment purposes only. They are the result of a deterministic mathematical model fed with assumptions generated by an Artificial Intelligence (Gemini 3.1). This does not constitute investment advice. Always conduct your own due diligence before investing in the stock market.</p>
      </div>

    </div>
  </div>
</SiteLayout>
