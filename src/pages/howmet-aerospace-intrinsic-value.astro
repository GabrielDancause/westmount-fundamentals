.dcf-bar-fill.dcf-revenue { background: linear-gradient(90deg, #1a3a6e, #4a8fe7); }
.dcf-bar-fill.dcf-fcf { background: linear-gradient(90deg, #1a5a3e, #10b981); }
.dcf-bar-fill.dcf-eps { background: linear-gradient(90deg, #5a3a7e, #a78bfa); }

/* Methodology */
