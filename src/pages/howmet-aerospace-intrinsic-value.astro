/* Tables */
.dcf-table-wrap { overflow-x: auto; margin: 24px 0 40px; border-radius: 14px; border: 1px solid #152040; background: #0a1020; }
.dcf-table-wrap table { width: 100%; border-collapse: collapse; }
.dcf-table-wrap th { background: #0d1428; padding: 14px 16px; font-size: 0.75rem; color: #5a6a80; font-weight: 700; text-transform: uppercase; letter-spacing: 1px; text-align: right; border-bottom: 2px solid #152040; white-space: nowrap; }
.dcf-table-wrap th:first-child { text-align: left; }
.dcf-table-wrap td { padding: 14px 16px; font-size: 0.9rem; color: #c8d0de; text-align: right; border-bottom: 1px solid #0d1428; font-family: 'JetBrains Mono', monospace; }
.dcf-table-wrap td:first-child { text-align: left; font-family: 'Inter', sans-serif; color: #a0aab8; font-weight: 600; }
.dcf-table-wrap tr:hover td { background: rgba(74,143,231,0.03); }
.dcf-row-total td { font-weight: 800; color: #fff; border-top: 2px solid #1a2a40; background: rgba(74,143,231,0.04); }
.dcf-highlight-cell { color: #4a8fe7; font-weight: 700; }

/* Sensitivity */
.dcf-sensitivity-table th.dcf-current { background: rgba(74,143,231,0.15); color: #4a8fe7; }
.dcf-sensitivity-table td.dcf-current { background: rgba(74,143,231,0.08); color: #4a8fe7; font-weight: 700; }

/* Chart bars */
.dcf-bar-chart { margin: 24px 0 40px; }
.dcf-bar-row { display: flex; align-items: center; gap: 12px; margin-bottom: 10px; }
.dcf-bar-label { width: 48px; font-size: 0.85rem; color: #5a6a80; font-weight: 600; text-align: right; flex-shrink: 0; }
