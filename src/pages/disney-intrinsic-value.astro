---
import SiteLayout from "../layouts/SiteLayout.astro";

const schema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": "Disney (DIS) Intrinsic Value: A DCF Analysis",
  "description": "A transparent, step-by-step discounted cash flow valuation of The Walt Disney Company. Using recent financials to arrive at a single fair value estimate for DIS shares.",
  "datePublished": "2026-03-18",
  "dateModified": "2026-03-18",
  "author": {
    "@type": "Organization",
    "name": "Westmount Research",
    "url": "https://westmountfundamentals.com"
  },
  "publisher": {
    "@type": "Organization",
    "name": "Westmount Research",
    "url": "https://westmountfundamentals.com"
  },
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": "https://westmountfundamentals.com/disney-intrinsic-value"
  }
};

export const meta = {
  title: "Disney (DIS) Intrinsic Value: A DCF Analysis",
  description: "We ran a full discounted cash flow on The Walt Disney Company. One number. Every assumption disclosed. Here's what Disney is really worth.",
  category: "study",
  published: "2026-03-18",
};

/* ═══════════════════════════════════════════════════════════════
   DATA FETCHING & PARSING
   ═══════════════════════════════════════════════════════════════ */

let fin = null;
let bs = null;
let currentPrice = 110.00; // Fallback price

async function fetchAndExtract(url) {
    try {
        const res = await fetch(url, { headers: { 'User-Agent': 'Mozilla/5.0 (Windows NT 10.0; Win64; x64)' } });
        if (!res.ok) return null;
        const html = await res.text();
        const startIdx = html.indexOf('financialData:');
        if (startIdx !== -1) {
            let openBraces = 0;
            let objStr = '';
            let started = false;
            // Scan through to properly match nested braces
            for (let i = startIdx + 14; i < html.length; i++) {
                const char = html[i];
                if (char === '{') {
                    openBraces++;
                    started = true;
                } else if (char === '}') {
                    openBraces--;
                }
                if (started) {
                    objStr += char;
                    if (openBraces === 0) {
                        break;
                    }
                }
            }
            if (objStr) {
                return eval('(' + objStr + ')');
            }
        }
    } catch (e) {
        console.error("Error fetching", url, e);
    }
    return null;
}

try {
  const [finData, cfsData, bsData, quoteRes] = await Promise.all([
    fetchAndExtract('https://stockanalysis.com/stocks/dis/financials/'),
    fetchAndExtract('https://stockanalysis.com/stocks/dis/financials/cash-flow-statement/'),
    fetchAndExtract('https://stockanalysis.com/stocks/dis/financials/balance-sheet/'),
    fetch('https://stockanalysis.com/stocks/dis/', { headers: { 'User-Agent': 'Mozilla/5.0' } })
  ]);
  fin = finData;
  if (finData && cfsData) {
      // Merge FCF data from cash flow statement if needed
      fin.fcf = cfsData.fcf || fin.fcf;
      fin.fcfMargin = cfsData.fcfMargin || fin.fcfMargin;
  }
  bs = bsData;

  if (quoteRes && quoteRes.ok) {
    const quoteHtml = await quoteRes.text();
    // Use regex to extract the current price from HTML (e.g., <div class="text-4xl font-bold inline-block svelte-x...">110.00</div>)
    const priceMatch = quoteHtml.match(/class="text-4xl font-bold inline-block.*?">([\d,\.]+)<\/div>/);
    if (priceMatch && priceMatch[1]) {
        currentPrice = parseFloat(priceMatch[1].replace(/,/g, ''));
    }
  }
} catch (error) {
  console.error("Failed to fetch data:", error);
}

// Ensure arrays have fallbacks
const safeSlice = (arr, num) => (arr && Array.isArray(arr) ? arr.slice(0, num) : []);

// Find the most recent full year data (skip TTM if present to ensure alignment, or use index 0)
let recentIdx = 0;
if (fin && fin.fiscalYear && fin.fiscalYear[0] === 'TTM') {
  recentIdx = 1; // You could also just use TTM, but full year is often preferred for "FY2025" style. We'll use index 0 (TTM/latest) for most up to date.
}

// --- INPUTS (all in millions USD unless noted) ---
// Fallback data if fetch fails
const baseYear = fin && fin.fiscalYear ? fin.fiscalYear[recentIdx] : "2026";
const fcfLatestRaw = fin && fin.fcf ? fin.fcf[recentIdx] : 7060000000;
const revenueLatestRaw = fin && fin.revenue ? fin.revenue[recentIdx] : 95716000000;
const epsLatestRaw = fin && fin.epsDiluted ? fin.epsDiluted[recentIdx] : 6.80;
const opmLatestRaw = fin && fin.operatingMargin ? fin.operatingMargin[recentIdx] : 0.135;

const sharesOutstandingRaw = fin && fin.sharesDiluted ? fin.sharesDiluted[recentIdx] : 1804500000;

const totalCashRaw = bs && bs.totalcash ? bs.totalcash[0] : 5678000000;
const totalDebtRaw = bs && bs.debt ? bs.debt[0] : 46640000000;

// Convert to Millions for DCF model (like Google reference)
const fcfBase = Math.round(fcfLatestRaw / 1000000);
const sharesOutstanding = Math.round(sharesOutstandingRaw / 1000000);
const cashAndInvestments = Math.round(totalCashRaw / 1000000);
const totalDebt = Math.round(totalDebtRaw / 1000000);
const netCash = cashAndInvestments - totalDebt;

// --- ASSUMPTIONS (fully disclosed below) ---
// 10Y Treasury is 4.18%. Cost of capital for DIS usually around 9%.
const growthRatePhase1 = 0.08;         // 8% FCF growth, Years 1-5 (recovering parks, streaming profitability)
const growthRateTerminal = 0.025;      // 2.5% perpetuity growth (terminal)
const discountRate = 0.09;             // 9% WACC / required return

// --- PHASE 1: PROJECT FCF FOR YEARS 1-5 ---
const projectedFCF = [];
let fcf = fcfBase;
for (let yr = 1; yr <= 5; yr++) {
  fcf = fcf * (1 + growthRatePhase1);
  projectedFCF.push({ year: yr, fcf: Math.round(fcf), pvFactor: 1 / Math.pow(1 + discountRate, yr) });
}
projectedFCF.forEach(p => { p.pvFCF = Math.round(p.fcf * p.pvFactor); });

// --- PHASE 2: TERMINAL VALUE (Gordon Growth Model) ---
const fcfYear6 = projectedFCF[4].fcf * (1 + growthRateTerminal);
const terminalValue = Math.round(fcfYear6 / (discountRate - growthRateTerminal));
const pvTerminalValue = Math.round(terminalValue * projectedFCF[4].pvFactor);

// --- ENTERPRISE VALUE ---
const pvPhase1 = projectedFCF.reduce((sum, p) => sum + p.pvFCF, 0);
const enterpriseValue = pvPhase1 + pvTerminalValue;

// --- EQUITY VALUE ---
const equityValue = enterpriseValue + netCash;
const intrinsicValuePerShare = equityValue / sharesOutstanding;
const roundedIV = Math.round(intrinsicValuePerShare * 100) / 100;

// Market comparison
const marginOfSafety = ((roundedIV - currentPrice) / currentPrice * 100).toFixed(1);
const verdictText = roundedIV > currentPrice ? "Undervalued" : "Overvalued";
const verdictColor = roundedIV > currentPrice ? "#10b981" : "#ef4444";

// --- HISTORICAL DATA for charts ---
let revenueHistory = [
  { year: 2022, value: 82722 },
  { year: 2023, value: 88898 },
  { year: 2024, value: 91361 },
  { year: 2025, value: 94425 },
  { year: 2026, value: 95716 }
];
let fcfHistory = [
  { year: 2022, value: 1059 },
  { year: 2023, value: 4897 },
  { year: 2024, value: 8559 },
  { year: 2025, value: 10077 },
  { year: 2026, value: 7060 }
];
let epsHistory = [
  { year: 2022, value: 1.72 },
  { year: 2023, value: 1.29 },
  { year: 2024, value: 2.72 },
  { year: 2025, value: 6.85 },
  { year: 2026, value: 6.80 }
];
let marginHistory = [
  { year: 2022, operating: 8.4, profit: 3.8, fcfMargin: 1.3 },
  { year: 2023, operating: 10.1, profit: 2.6, fcfMargin: 5.5 },
  { year: 2024, operating: 12.3, profit: 5.4, fcfMargin: 9.4 },
  { year: 2025, operating: 13.5, profit: 13.1, fcfMargin: 10.7 },
  { year: 2026, operating: 13.5, profit: 12.8, fcfMargin: 7.4 }
];

if (fin && fin.fiscalYear) {
    const revs = safeSlice(fin.revenue, 5).reverse();
    const fcfs = safeSlice(fin.fcf, 5).reverse();
    const epses = safeSlice(fin.epsDiluted, 5).reverse();
    const ops = safeSlice(fin.operatingMargin, 5).reverse();
    const profs = safeSlice(fin.profitMargin, 5).reverse();
    const fcfms = safeSlice(fin.fcfMargin, 5).reverse();
    const yrs = safeSlice(fin.fiscalYear, 5).reverse();

    if (yrs.length === 5) {
        revenueHistory = yrs.map((y, i) => ({ year: y, value: Math.round(revs[i] / 1000000) }));
        fcfHistory = yrs.map((y, i) => ({ year: y, value: Math.round(fcfs[i] / 1000000) }));
        epsHistory = yrs.map((y, i) => ({ year: y, value: epses[i] }));
        marginHistory = yrs.map((y, i) => ({ year: y, operating: Math.round(ops[i] * 1000) / 10, profit: Math.round(profs[i] * 1000) / 10, fcfMargin: Math.round(fcfms[i] * 1000) / 10 }));
    }
}

// Sensitivity analysis
const sensitivityRates = [0.07, 0.08, 0.09, 0.10, 0.11];
const sensitivityGrowth = [0.04, 0.06, 0.08, 0.10, 0.12];
const sensitivityTable = sensitivityRates.map(dr => {
  return {
    dr,
    values: sensitivityGrowth.map(gr => {
      let f = fcfBase;
      let pvSum = 0;
      for (let y = 1; y <= 5; y++) {
        f = f * (1 + gr);
        pvSum += f / Math.pow(1 + dr, y);
      }
      const f6 = f * (1 + growthRateTerminal);
      const tv = f6 / (dr - growthRateTerminal);
      const pvTV = tv / Math.pow(1 + dr, 5);
      return Math.round((pvSum + pvTV + netCash) / sharesOutstanding);
    })
  };
});
