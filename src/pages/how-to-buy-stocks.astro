<script>
  function initCalculator() {
    const stockPriceInput = document.getElementById('stockPrice');
    const investmentAmountInput = document.getElementById('investmentAmount');
    const sharesOutputInput = document.getElementById('sharesOutput');

    if (!stockPriceInput || !investmentAmountInput || !sharesOutputInput) return;

    function calculateShares() {
      const price = parseFloat(stockPriceInput.value);
      const investment = parseFloat(investmentAmountInput.value);

      if (price > 0 && investment >= 0) {
        sharesOutputInput.value = (investment / price).toFixed(5);
      } else {
        sharesOutputInput.value = "0.00000";
      }
    }

    function calculateInvestment() {
      const price = parseFloat(stockPriceInput.value);
      const shares = parseFloat(sharesOutputInput.value);

      if (price > 0 && shares >= 0) {
        investmentAmountInput.value = (price * shares).toFixed(2);
      } else {
        investmentAmountInput.value = "0.00";
      }
    }

    stockPriceInput.addEventListener('input', calculateShares);
    investmentAmountInput.addEventListener('input', calculateShares);
    sharesOutputInput.addEventListener('input', calculateInvestment);
  }

  // Initialize on direct load
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initCalculator);
  } else {
    initCalculator();
  }

  // Support Astro View Transitions
  document.addEventListener('astro:page-load', initCalculator);
</script>
