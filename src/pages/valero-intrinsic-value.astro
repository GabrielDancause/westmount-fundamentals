};

export const meta = {
  title: "Valero Energy (VLO) Intrinsic Value: A DCF Analysis",
  description: "We ran a full discounted cash flow on Valero using FY2025 actuals. One number. Every assumption disclosed. Here's what Valero is really worth.",
  category: "study",
  published: "2026-03-18",
};

/* ═══════════════════════════════════════════════════════════════
   DCF MODEL — ALL INPUTS AND CALCULATIONS
   Every number is sourced from Valero's FY2025 financials.
   We use a two-stage DCF: steady growth phase (Years 1-5) then terminal value.
   ═══════════════════════════════════════════════════════════════ */

// --- INPUTS (all in millions USD unless noted) ---

async function fetchFromStockAnalysis(url, extractors) {
    try {
        const res = await fetch(url, { headers: { 'User-Agent': 'Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36' } });
        if (!res.ok) throw new Error(`HTTP ${res.status}`);
        const html = await res.text();
        const results = {};
        for (const [key, extractor] of Object.entries(extractors)) {
            results[key] = extractor(html);
        }
        return results;
    } catch (e) {
        console.error("Error fetching " + url, e);
        return null;
    }
}

const extractors = {
    fcf: (html) => {
        const match = html.match(/<tr[^>]*>[\s\S]*?Free Cash Flow[\s\S]*?<\/tr>/i);
        if (!match) return null;
        const tds = match[0].match(/<td[^>]*>(.*?)<\/td>/g);
        if (tds && tds.length > 1) {
            const val = parseFloat(tds[1].replace(/<[^>]+>/g, '').replace(/,/g, ''));
            return isNaN(val) ? null : val;
        }
        return null;
    },
    shares: (html) => {
        const match = html.match(/<tr[^>]*>[\s\S]*?Shares Outstanding \(Basic\)[\s\S]*?<\/tr>/i);
        if (!match) return null;
        const tds = match[0].match(/<td[^>]*>(.*?)<\/td>/g);
        if (tds && tds.length > 1) {
            const val = parseFloat(tds[1].replace(/<[^>]+>/g, '').replace(/,/g, ''));
            return isNaN(val) ? null : val;
        }
        return null;
    },
    cash: (html) => {
        const match = html.match(/<tr[^>]*>[\s\S]*?Cash &amp; Equivalents[\s\S]*?<\/tr>/i) || html.match(/<tr[^>]*>[\s\S]*?Cash & Equivalents[\s\S]*?<\/tr>/i);
        if (!match) return null;
        const tds = match[0].match(/<td[^>]*>(.*?)<\/td>/g);
        if (tds && tds.length > 1) {
            const val = parseFloat(tds[1].replace(/<[^>]+>/g, '').replace(/,/g, ''));
            return isNaN(val) ? null : val;
        }
        return null;
    },
    debt: (html) => {
        const match = html.match(/<tr[^>]*>[\s\S]*?Total Debt[\s\S]*?<\/tr>/i);
        if (!match) return null;
        const tds = match[0].match(/<td[^>]*>(.*?)<\/td>/g);
        if (tds && tds.length > 1) {
            const val = parseFloat(tds[1].replace(/<[^>]+>/g, '').replace(/,/g, ''));
            return isNaN(val) ? null : val;
        }
        return null;
    }
};

const [incomeData, balanceData, cashflowData] = await Promise.all([
    fetchFromStockAnalysis('https://stockanalysis.com/stocks/vlo/financials/', { shares: extractors.shares }),
    fetchFromStockAnalysis('https://stockanalysis.com/stocks/vlo/financials/balance-sheet/', { cash: extractors.cash, debt: extractors.debt }),
    fetchFromStockAnalysis('https://stockanalysis.com/stocks/vlo/financials/cash-flow-statement/', { fcf: extractors.fcf })
]);

const fcf2025 = cashflowData?.fcf ?? null;
const sharesOutstanding = incomeData?.shares ?? null;
const cashAndInvestments = balanceData?.cash ?? null;
const totalDebt = balanceData?.debt ?? null;
const netCash = (cashAndInvestments !== null && totalDebt !== null) ? cashAndInvestments - totalDebt : null;

const hasData = fcf2025 !== null && sharesOutstanding !== null && netCash !== null;

// --- ASSUMPTIONS (fully disclosed below) ---
const growthRatePhase1 = 0.03;         // 3% FCF growth, Years 1-5
const growthRateTerminal = 0.02;       // 2% perpetuity growth (terminal)
const discountRate = 0.10;             // 10% WACC / required return

// --- PHASE 1: PROJECT FCF FOR YEARS 1-5 ---
const projectedFCF = [];
let fcf = fcf2025;
if (hasData) {
    for (let yr = 1; yr <= 5; yr++) {
        fcf = fcf * (1 + growthRatePhase1);
        projectedFCF.push({ year: yr, fcf: Math.round(fcf), pvFactor: 1 / Math.pow(1 + discountRate, yr) });
    }
    projectedFCF.forEach(p => { p.pvFCF = Math.round(p.fcf * p.pvFactor); });
}

// --- PHASE 2: TERMINAL VALUE (Gordon Growth Model) ---
const fcfYear6 = hasData ? projectedFCF[4].fcf * (1 + growthRateTerminal) : null;
const terminalValue = hasData ? Math.round(fcfYear6 / (discountRate - growthRateTerminal)) : null;
const pvTerminalValue = hasData ? Math.round(terminalValue * projectedFCF[4].pvFactor) : null;

// --- ENTERPRISE VALUE ---
const pvPhase1 = hasData ? projectedFCF.reduce((sum, p) => sum + p.pvFCF, 0) : null;
const enterpriseValue = hasData ? pvPhase1 + pvTerminalValue : null;

// --- EQUITY VALUE ---
const equityValue = hasData ? enterpriseValue + netCash : null;
const intrinsicValuePerShare = hasData ? equityValue / sharesOutstanding : null;
const roundedIV = hasData ? Math.round(intrinsicValuePerShare * 100) / 100 : null;

// Market comparison
const currentPrice = 237.63;
const marginOfSafety = hasData ? ((roundedIV - currentPrice) / currentPrice * 100).toFixed(1) : null;
const verdictText = !hasData ? "N/A" : (roundedIV > currentPrice ? "Undervalued" : "Overvalued");
const verdictColor = !hasData ? "#5a6a80" : (roundedIV > currentPrice ? "#10b981" : "#ef4444");

// --- HISTORICAL DATA for charts ---
const revenueHistory = [
  { year: 2021, value: 113984 },
  { year: 2022, value: 176383 },
  { year: 2023, value: 144766 },
  { year: 2024, value: 129881 },
  { year: 2025, value: 122687 },
];
const fcfHistory = [
  { year: 2021, value: 2864 },
  { year: 2022, value: 10893 },
  { year: 2023, value: 8318 },
  { year: 2024, value: 5776 },
  { year: 2025, value: 5030 },
];
const epsHistory = [
  { year: 2021, value: 2.27 },
  { year: 2022, value: 29.05 },
  { year: 2023, value: 24.93 },
  { year: 2024, value: 8.58 },
  { year: 2025, value: 7.57 },
];
const marginHistory = [
  { year: 2021, operating: (3755/113984*100).toFixed(2), profit: (2770/113984*100).toFixed(2), fcfMargin: (2864/113984*100).toFixed(2) },
  { year: 2022, operating: (15751/176383*100).toFixed(2), profit: (11528/176383*100).toFixed(2), fcfMargin: (10893/176383*100).toFixed(2) },
  { year: 2023, operating: (11858/144766*100).toFixed(2), profit: (8835/144766*100).toFixed(2), fcfMargin: (8318/144766*100).toFixed(2) },
  { year: 2024, operating: (3755/129881*100).toFixed(2), profit: (2770/129881*100).toFixed(2), fcfMargin: (5776/129881*100).toFixed(2) },
  { year: 2025, operating: (4312/122687*100).toFixed(2), profit: (2348/122687*100).toFixed(2), fcfMargin: (5030/122687*100).toFixed(2) },
];

// Sensitivity analysis
const sensitivityRates = [0.08, 0.09, 0.10, 0.11, 0.12];
const sensitivityGrowth = [-0.02, 0.00, 0.03, 0.05, 0.07];
const sensitivityTable = sensitivityRates.map(dr => {
  return {
    dr,
    values: sensitivityGrowth.map(gr => {
      if (!hasData) return null;
      let f = fcf2025;
      let pvSum = 0;
      for (let y = 1; y <= 5; y++) {
        f = f * (1 + gr);
        pvSum += f / Math.pow(1 + dr, y);
      }
      const f6 = f * (1 + growthRateTerminal);
      const tv = f6 / (dr - growthRateTerminal);
      const pvTV = tv / Math.pow(1 + dr, 5);
      return Math.round((pvSum + pvTV + netCash) / sharesOutstanding);
    })
  };
});
