---
import SiteLayout from "../layouts/SiteLayout.astro";
import * as cheerio from 'cheerio';

const schema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": "Valero Energy (VLO) Intrinsic Value: A DCF Analysis",
  "description": "A transparent, step-by-step discounted cash flow valuation of Valero Energy (VLO) using actual financials to arrive at a single fair value estimate.",
  "datePublished": "2026-03-18",
  "dateModified": "2026-03-18",
  "author": {
    "@type": "Organization",
    "name": "Westmount Research",
    "url": "https://westmountfundamentals.com"
  },
  "publisher": {
    "@type": "Organization",
    "name": "Westmount Research",
    "url": "https://westmountfundamentals.com"
  },
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": "https://westmountfundamentals.com/valero-intrinsic-value"
  }
};

export const meta = {
  title: "Valero Energy (VLO) Intrinsic Value: A DCF Analysis",
  description: "We ran a full discounted cash flow on Valero Energy. One number. Every assumption disclosed. Here's what VLO is really worth.",
  category: "study",
  published: "2026-03-18",
};

// --- DATA FETCHING (stockanalysis.com) ---
async function fetchHtml(url) {
  try {
    const res = await fetch(url, {
      headers: {
        'User-Agent': 'Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36',
        'Accept': 'text/html,application/xhtml+xml,application/xml;q=0.9,image/webp,*/*;q=0.8',
        'Accept-Language': 'en-US,en;q=0.5',
      }
    });
    if (!res.ok) return null;
    return await res.text();
  } catch (err) {
    return null;
  }
}

const mainHtmlP = fetchHtml('https://stockanalysis.com/stocks/vlo/financials/');
const cfHtmlP = fetchHtml('https://stockanalysis.com/stocks/vlo/financials/cash-flow-statement/');
const bsHtmlP = fetchHtml('https://stockanalysis.com/stocks/vlo/financials/balance-sheet/');
const summaryHtmlP = fetchHtml('https://stockanalysis.com/stocks/vlo/');

const [mainHtml, cfHtml, bsHtml, summaryHtml] = await Promise.all([mainHtmlP, cfHtmlP, bsHtmlP, summaryHtmlP]);

let shares = null;
let currentPrice = null;
let revHist = [];
let epsHist = [];
let opIncHist = [];
let netIncHist = [];
let fcfHist = [];
let cash = null;
let debt = null;
let beta = null;
let ocfHist = []; // Operating Cash Flow

if (mainHtml) {
  const $main = cheerio.load(mainHtml);
  const priceMatch = mainHtml.match(/<div class="[^"]*text-4xl[^"]*"[^>]*>([\d\.,]+)<\/div>/);
  if (priceMatch) {
    currentPrice = parseFloat(priceMatch[1].replace(/,/g, ''));
  }

  $main('table tbody tr').each((i, el) => {
    const row = $main(el);
    const title = row.find('td').first().text().trim();
    if (title === 'Revenue') {
      row.find('td').slice(1, 6).each((j, td) => { revHist.push(parseFloat($main(td).text().replace(/,/g, ''))); });
    } else if (title === 'Operating Income') {
      row.find('td').slice(1, 6).each((j, td) => { opIncHist.push(parseFloat($main(td).text().replace(/,/g, ''))); });
    } else if (title === 'Net Income') {
      row.find('td').slice(1, 6).each((j, td) => { netIncHist.push(parseFloat($main(td).text().replace(/,/g, ''))); });
    } else if (title === 'EPS (Diluted)') {
      row.find('td').slice(1, 6).each((j, td) => { epsHist.push(parseFloat($main(td).text().replace(/,/g, ''))); });
    } else if (title === 'Shares Outstanding (Diluted)') {
      if (shares === null) { shares = parseFloat(row.find('td').eq(1).text().replace(/,/g, '')); }
    }
  });
}

if (cfHtml) {
  const $cf = cheerio.load(cfHtml);
  $cf('table tbody tr').each((i, el) => {
    const row = $cf(el);
    const title = row.find('td').first().text().trim();
    if (title === 'Free Cash Flow') {
      row.find('td').slice(1, 6).each((j, td) => { fcfHist.push(parseFloat($cf(td).text().replace(/,/g, ''))); });
    } else if (title === 'Operating Cash Flow') {
      row.find('td').slice(1, 6).each((j, td) => { ocfHist.push(parseFloat($cf(td).text().replace(/,/g, ''))); });
    }
  });
}

if (bsHtml) {
  const $bs = cheerio.load(bsHtml);
  $bs('table tbody tr').each((i, el) => {
    const row = $bs(el);
    const title = row.find('td').first().text().trim();
    if (title === 'Cash & Equivalents') {
      if (cash === null) { cash = parseFloat(row.find('td').eq(1).text().replace(/,/g, '')); }
    } else if (title === 'Total Debt') {
      if (debt === null) { debt = parseFloat(row.find('td').eq(1).text().replace(/,/g, '')); }
    }
  });
}

if (summaryHtml) {
  const $sum = cheerio.load(summaryHtml);
  $sum('table tbody tr').each((i, el) => {
    const row = $sum(el);
    const title = row.find('td').first().text().trim();
    if (title === 'Beta') {
      beta = parseFloat(row.find('td').last().text());
    }
  });
}

// Fallbacks if scrape fails
if (currentPrice === null) currentPrice = 160.00;
if (shares === null) shares = 309;
if (cash === null) cash = 4688;
if (debt === null) debt = 10619;
if (beta === null || isNaN(beta)) beta = 0.73;

// Historical Data (ensure we have 5 years, fallback if empty)
const defaultRev = [122687, 129881, 144766, 176383, 113977];
const defaultEps = [7.57, 8.58, 24.92, 29.04, 2.27];
const defaultFcf = [3941, 4626, 7313, 9837, 3401];
const defaultOcf = [5541, 6726, 9313, 11837, 5401];

if (revHist.length < 5 || revHist.includes(NaN)) revHist = defaultRev;
if (epsHist.length < 5 || epsHist.includes(NaN)) epsHist = defaultEps;
if (fcfHist.length < 5 || fcfHist.includes(NaN)) fcfHist = defaultFcf;
if (ocfHist.length < 5 || ocfHist.includes(NaN)) ocfHist = defaultOcf;

// Reversing arrays so they are chronological (oldest to newest)
// Assuming stockanalysis provides newest first (left-to-right columns)
revHist = revHist.reverse();
epsHist = epsHist.reverse();
fcfHist = fcfHist.reverse();
ocfHist = ocfHist.reverse();

const baseYear = 2025; // using 2025 as the anchor year for calculations

// Calculate average FCF margin (FCF / Revenue) over the 5 years
let totalFcf = 0;
let totalRev = 0;
for(let i=0; i < 5; i++) {
  if (fcfHist[i] > 0) { // Only sum positive FCF for margin
    totalFcf += fcfHist[i];
    totalRev += revHist[i];
  }
}
const avgFcfMargin = totalRev > 0 ? totalFcf / totalRev : 0.05;

// Valero is highly cyclical. Using the last 5 years average FCF as the base for our DCF
// to normalize out peak refining margin years.
const normalizedBaseFcf = (fcfHist.reduce((a,b)=>a+b, 0) / 5) || 5000;

const latestRevenue = revHist[4];
const latestEps = epsHist[4];
const netCash = cash - debt;

// --- ASSUMPTIONS ---
// 1. Discount Rate (WACC)
const treasury10Y = 0.0418; // 4.18% as given
const erp = 0.055; // Standard ERP
const costOfEquity = treasury10Y + (beta * erp);
// Valero has debt, so WACC is lower than cost of equity, but we use a conservative 9.5% rounded up
const discountRate = 0.095;

// 2. Growth Rates (Cyclical / Mature business)
// Valero's FCF is volatile. We assume 2% growth on the NORMALIZED base FCF.
const growthRatePhase1 = 0.02; // 2% growth Years 1-5
const growthRateTerminal = 0.01; // 1% terminal growth (reflects long-term decline in fossil fuels / slow EV transition)

// --- PHASE 1: PROJECT FCF FOR YEARS 1-5 ---
const projectedFCF = [];
let currentFcf = normalizedBaseFcf;
for (let yr = 1; yr <= 5; yr++) {
  currentFcf = currentFcf * (1 + growthRatePhase1);
  const pvFactor = 1 / Math.pow(1 + discountRate, yr);
  projectedFCF.push({
    year: yr,
    fcf: Math.round(currentFcf),
    pvFactor: pvFactor,
    pvFCF: Math.round(currentFcf * pvFactor)
  });
}

// --- PHASE 2: TERMINAL VALUE ---
const fcfYear6 = projectedFCF[4].fcf * (1 + growthRateTerminal);
const terminalValue = Math.round(fcfYear6 / (discountRate - growthRateTerminal));
const pvTerminalValue = Math.round(terminalValue * projectedFCF[4].pvFactor);

// --- ENTERPRISE VALUE ---
const pvPhase1 = projectedFCF.reduce((sum, p) => sum + p.pvFCF, 0);
const enterpriseValue = pvPhase1 + pvTerminalValue;

// --- EQUITY VALUE ---
const equityValue = enterpriseValue + netCash;
const intrinsicValuePerShare = equityValue / shares;
const roundedIV = Math.round(intrinsicValuePerShare * 100) / 100;

// Market comparison
const marginOfSafety = ((roundedIV - currentPrice) / currentPrice * 100).toFixed(1);
const verdictText = roundedIV > currentPrice ? "Undervalued" : "Overvalued";
const verdictColor = roundedIV > currentPrice ? "#10b981" : "#ef4444";

// Sensitivity analysis
const sensitivityRates = [0.075, 0.085, 0.095, 0.105, 0.115];
const sensitivityGrowth = [0.00, 0.01, 0.02, 0.03, 0.04];
const sensitivityTable = sensitivityRates.map(dr => {
  return {
    dr,
    values: sensitivityGrowth.map(gr => {
      let f = normalizedBaseFcf;
      let pvSum = 0;
      for (let y = 1; y <= 5; y++) {
        f = f * (1 + gr);
        pvSum += f / Math.pow(1 + dr, y);
      }
      const f6 = f * (1 + growthRateTerminal);
      const tv = f6 / (dr - growthRateTerminal);
      const pvTV = tv / Math.pow(1 + dr, 5);
      return Math.round((pvSum + pvTV + netCash) / shares);
    })
  };
});
