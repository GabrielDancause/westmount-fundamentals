---
import SiteLayout from "../layouts/SiteLayout.astro";
import * as cheerio from 'cheerio';

const schema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": "Moody's (MCO) Intrinsic Value: A DCF Analysis",
  "description": "A transparent, step-by-step discounted cash flow valuation of Moody's Corporation. Using actual financials to arrive at a single fair value estimate for MCO shares.",
  "datePublished": new Date().toISOString().split('T')[0],
  "dateModified": new Date().toISOString().split('T')[0],
  "author": {
    "@type": "Organization",
    "name": "Compiled by Gemini 3.1"
  },
  "publisher": {
    "@type": "Organization",
    "name": "Compiled by Gemini 3.1"
  },
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": "https://example.com/moodys-intrinsic-value"
  }
};

export const meta = {
  title: "Moody's (MCO) Intrinsic Value: A DCF Analysis",
  description: "We ran a full discounted cash flow on Moody's. One number. Every assumption disclosed. Here's what Moody's is really worth.",
  category: "study",
  published: new Date().toISOString().split('T')[0],
};

// ==========================================
// DATA FETCHING & PARSING
// ==========================================
let sharesOutstanding = null;
let eps = null;
let currentPrice = null;
let cashAndEquivalents = null;
let totalDebt = null;
let revenueHistory = [];
let fcfHistory = [];

const fetchOptions = {
  headers: {
    'User-Agent': 'Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/115.0.0.0 Safari/537.36',
    'Accept': 'text/html'
  }
};

try {
  // Fetch Quote page for price
  const quoteRes = await fetch('https://stockanalysis.com/stocks/mco/', fetchOptions);
  if (quoteRes.ok) {
    const quoteHtml = await quoteRes.text();
    const priceMatch = quoteHtml.match(/<div class="[^"]*text-4xl[^"]*"[^>]*>([\d\.,]+)<\/div>/);
    if (priceMatch) {
      currentPrice = parseFloat(priceMatch[1].replace(/,/g, ''));
    }
  }

  // Fetch Financials (Income Statement)
  const finRes = await fetch('https://stockanalysis.com/stocks/mco/financials/', fetchOptions);
  if (finRes.ok) {
    const finHtml = await finRes.text();
    const $ = cheerio.load(finHtml);

    // Parse Shares
    const sharesText = $('table tbody tr').filter((i, el) => $(el).find('td').first().text().trim().includes('Shares Outstanding (Diluted)')).find('td').eq(1).text().trim();
    if (sharesText && sharesText !== '-') sharesOutstanding = parseFloat(sharesText.replace(/,/g, ''));

    // Parse EPS
    const epsText = $('table tbody tr').filter((i, el) => $(el).find('td').first().text().trim().includes('EPS (Diluted)')).find('td').eq(1).text().trim();
    if (epsText && epsText !== '-') eps = parseFloat(epsText.replace(/,/g, ''));

    // Parse Revenue History
    const revRow = $('table tbody tr').filter((i, el) => $(el).find('td').first().text().trim() === 'Revenue');
    if (revRow.length > 0) {
      for(let i=1; i<=5; i++) {
        const val = revRow.find('td').eq(i).text().trim();
        if (val && val !== '-') revenueHistory.push(parseFloat(val.replace(/,/g, '')));
      }
    }
  }

  // Fetch Cash Flow Statement
  const cfRes = await fetch('https://stockanalysis.com/stocks/mco/financials/cash-flow-statement/', fetchOptions);
  if (cfRes.ok) {
    const cfHtml = await cfRes.text();
    const $ = cheerio.load(cfHtml);

    // Parse FCF History
    const fcfRow = $('table tbody tr').filter((i, el) => $(el).find('td').first().text().trim() === 'Free Cash Flow');
    if (fcfRow.length > 0) {
      for(let i=1; i<=5; i++) {
        const val = fcfRow.find('td').eq(i).text().trim();
        if (val && val !== '-') fcfHistory.push(parseFloat(val.replace(/,/g, '')));
      }
    }
  }

  // Fetch Balance Sheet
  const bsRes = await fetch('https://stockanalysis.com/stocks/mco/financials/balance-sheet/', fetchOptions);
  if (bsRes.ok) {
    const bsHtml = await bsRes.text();
    const $ = cheerio.load(bsHtml);

    const cashText = $('table tbody tr').filter((i, el) => $(el).find('td').first().text().trim() === 'Cash & Equivalents').find('td').eq(1).text().trim();
    if (cashText && cashText !== '-') cashAndEquivalents = parseFloat(cashText.replace(/,/g, ''));

    const debtText = $('table tbody tr').filter((i, el) => $(el).find('td').first().text().trim() === 'Total Debt').find('td').eq(1).text().trim();
    if (debtText && debtText !== '-') totalDebt = parseFloat(debtText.replace(/,/g, ''));
  }

} catch (e) {
  console.error("Error fetching data:", e);
}

// ==========================================
// MATHEMATICAL DERIVATIONS & ASSUMPTIONS
// ==========================================

// Ensure we have required data
const isDataComplete = sharesOutstanding !== null && fcfHistory.length >= 2 && revenueHistory.length >= 2 && cashAndEquivalents !== null && totalDebt !== null;

// Base FCF
const currentFCF = fcfHistory.length > 0 ? fcfHistory[0] : null;

// Deriving Growth Rate (Phase 1)
// We calculate the CAGR of FCF over the available historical period
let derivedGrowthRate = 0;
if (fcfHistory.length > 1 && fcfHistory[fcfHistory.length - 1] > 0 && currentFCF > 0) {
  const years = fcfHistory.length - 1;
  const oldestFCF = fcfHistory[years];
  derivedGrowthRate = Math.pow(currentFCF / oldestFCF, 1 / years) - 1;
} else if (revenueHistory.length > 1 && revenueHistory[revenueHistory.length - 1] > 0 && revenueHistory[0] > 0) {
   // Fallback to Revenue CAGR if FCF is negative or erratic
   const years = revenueHistory.length - 1;
   const oldestRev = revenueHistory[years];
   derivedGrowthRate = Math.pow(revenueHistory[0] / oldestRev, 1 / years) - 1;
}

// Cap growth rate to a reasonable maximum (e.g., 20%) to avoid explosive DCF from weird base year effects
const growthRatePhase1 = Math.min(Math.max(derivedGrowthRate, 0.02), 0.20); // between 2% and 20%

// Deriving Discount Rate (WACC proxy)
const treasury10Y = 0.0418; // 4.18% as given
const equityRiskPremium = 0.05; // Standard ERP
// A basic CAPM derivation. Assuming beta ~1.1 for a financial data company like MCO
const beta = 1.1;
const costOfEquity = treasury10Y + (beta * equityRiskPremium);
const discountRate = costOfEquity; // Using Cost of Equity as a proxy for WACC given mostly equity-driven value for such firms

// Terminal Growth Rate
// Cannot exceed long-term GDP growth. Derived from 10Y Treasury as a proxy for long-term nominal GDP.
const terminalGrowthRate = Math.min(treasury10Y * 0.8, 0.035); // Max 3.5%

// ==========================================
// DCF CALCULATIONS
// ==========================================
let projectedFCF = [];
let pvPhase1 = 0;
let fcfYear6 = 0;
let terminalValue = 0;
let pvTerminalValue = 0;
let enterpriseValue = 0;
let equityValue = 0;
let intrinsicValuePerShare = 0;
let marginOfSafety = 0;
let roundedIV = 0;
let verdictText = "N/A";
let verdictColor = "#7a8a9e";
let netCash = 0;

if (isDataComplete && currentFCF !== null) {
  netCash = cashAndEquivalents - totalDebt;

  // Phase 1: Years 1-5
  let fcf = currentFCF;
  for (let yr = 1; yr <= 5; yr++) {
    fcf = fcf * (1 + growthRatePhase1);
    const pvFactor = 1 / Math.pow(1 + discountRate, yr);
    const pvFCF = fcf * pvFactor;
    projectedFCF.push({ year: yr, fcf: fcf, pvFactor: pvFactor, pvFCF: pvFCF });
    pvPhase1 += pvFCF;
  }

  // Phase 2: Terminal Value
  fcfYear6 = projectedFCF[4].fcf * (1 + terminalGrowthRate);
  terminalValue = fcfYear6 / (discountRate - terminalGrowthRate);
  pvTerminalValue = terminalValue * projectedFCF[4].pvFactor;

  // Enterprise & Equity Value
  enterpriseValue = pvPhase1 + pvTerminalValue;
  equityValue = enterpriseValue + netCash;
  intrinsicValuePerShare = equityValue / sharesOutstanding;
  roundedIV = Math.round(intrinsicValuePerShare * 100) / 100;

  if (currentPrice !== null) {
    marginOfSafety = ((roundedIV - currentPrice) / currentPrice * 100);
    verdictText = roundedIV > currentPrice ? "Undervalued" : "Overvalued";
    verdictColor = roundedIV > currentPrice ? "#10b981" : "#ef4444";
  }
}

// ==========================================
// SENSITIVITY ANALYSIS
// ==========================================
let sensitivityTable = [];
let sensitivityRates = [];
let sensitivityGrowth = [];

if (isDataComplete) {
  // Generate arrays around the base rates
  sensitivityRates = [
    discountRate - 0.02,
    discountRate - 0.01,
    discountRate,
    discountRate + 0.01,
    discountRate + 0.02
  ];

  sensitivityGrowth = [
    growthRatePhase1 - 0.04,
    growthRatePhase1 - 0.02,
    growthRatePhase1,
    growthRatePhase1 + 0.02,
    growthRatePhase1 + 0.04
  ];

  sensitivityTable = sensitivityRates.map(dr => {
    return {
      dr: dr,
      values: sensitivityGrowth.map(gr => {
        let f = currentFCF;
        let pvSum = 0;
        for (let y = 1; y <= 5; y++) {
          f = f * (1 + gr);
          pvSum += f / Math.pow(1 + dr, y);
        }
        const f6 = f * (1 + terminalGrowthRate);
        const tv = f6 / (dr - terminalGrowthRate);
        const pvTV = tv / Math.pow(1 + dr, 5);
        const eqVal = pvSum + pvTV + netCash;
        return Math.max(0, Math.round(eqVal / sharesOutstanding));
      })
    };
  });
}

// Chart Data mapping (Years 0 to 4 back in time, 0 is most recent)
const currentYear = new Date().getFullYear();
const chartDataRev = revenueHistory.map((val, i) => ({ year: currentYear - 1 - i, value: val })).reverse();
const chartDataFCF = fcfHistory.map((val, i) => ({ year: currentYear - 1 - i, value: val })).reverse();
---

<SiteLayout
  site="westmount"
  title="Moody's (MCO) Intrinsic Value: A DCF Analysis"
  description="We ran a full discounted cash flow on Moody's. One number. Every assumption disclosed. Here's what Moody's is really worth."
  canonical="https://example.com/moodys-intrinsic-value"
  schema={schema}
>
<style is:global>
@import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800;900&family=JetBrains+Mono:wght@400;700;800&display=swap');

*, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
body { font-family: 'Inter', -apple-system, sans-serif; background: #060a12; color: #c8d0de; line-height: 1.7; }
a { color: #4a8fe7; text-decoration: none; }
a:hover { text-decoration: underline; }
.mco-container { max-width: 900px; margin: 0 auto; padding: 0 24px; }

/* Header */
.mco-header { text-align: center; padding: 80px 24px 60px; background: linear-gradient(180deg, #0a1628 0%, #060a12 100%); position: relative; border-bottom: 1px solid #152040; }
.mco-header::before { content: ''; position: absolute; inset: 0; background: radial-gradient(circle at 50% 40%, rgba(74,143,231,0.06) 0%, transparent 60%); }
.mco-header-content { position: relative; z-index: 1; }
.mco-tag { display: inline-block; background: rgba(74,143,231,0.12); color: #4a8fe7; font-size: 0.75rem; font-weight: 800; padding: 6px 16px; border-radius: 20px; letter-spacing: 1.5px; text-transform: uppercase; margin-bottom: 16px; }
.mco-header h1 { font-size: 2.8rem; font-weight: 900; color: #fff; letter-spacing: -1.2px; margin-bottom: 16px; line-height: 1.1; }
@media (max-width: 640px) { .mco-header h1 { font-size: 2rem; } }
.mco-subtitle { color: #7a8a9e; font-size: 1.1rem; max-width: 700px; margin: 0 auto 16px; }
.mco-date { color: #3a4a60; font-size: 0.85rem; font-weight: 600; letter-spacing: 1px; }
.mco-compiled { font-family: 'JetBrains Mono', monospace; font-size: 0.8rem; color: #4a8fe7; margin-top: 12px; font-weight: 700; text-transform: uppercase; letter-spacing: 1px; }

/* Big verdict */
.verdict-card { max-width: 560px; margin: 60px auto 0; background: linear-gradient(135deg, #0a1628 0%, #0d1830 100%); border: 2px solid #152040; border-radius: 20px; padding: 48px 32px; text-align: center; box-shadow: 0 20px 60px rgba(0,0,0,0.4); position: relative; overflow: hidden; }
.verdict-card::before { content: ''; position: absolute; top: -60%; left: -20%; width: 140%; height: 120%; background: radial-gradient(ellipse, rgba(74,143,231,0.04) 0%, transparent 70%); }
.verdict-label { font-size: 0.8rem; color: #5a6a80; font-weight: 700; text-transform: uppercase; letter-spacing: 2px; margin-bottom: 12px; position: relative; }
.verdict-price { font-family: 'JetBrains Mono', monospace; font-size: 4.5rem; font-weight: 800; color: #fff; line-height: 1; margin-bottom: 8px; position: relative; }
@media (max-width: 640px) { .verdict-price { font-size: 3rem; } }
.verdict-vs { font-size: 0.95rem; color: #5a6a80; margin-bottom: 20px; position: relative; }
.verdict-badge { display: inline-block; padding: 8px 24px; border-radius: 30px; font-weight: 800; font-size: 0.9rem; letter-spacing: 1px; text-transform: uppercase; position: relative; }

/* Stats */
.stats-row { display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); gap: 16px; margin: 40px auto; max-width: 900px; }
.stat-card { background: #0a1020; border: 1px solid #152040; border-radius: 14px; padding: 24px 16px; text-align: center; }
.stat-value { font-family: 'JetBrains Mono', monospace; font-size: 1.8rem; font-weight: 700; color: #4a8fe7; margin-bottom: 4px; }
.stat-label { font-size: 0.78rem; color: #5a6a80; font-weight: 600; text-transform: uppercase; letter-spacing: 0.5px; }

/* Sections */
.mco-container h2 { font-size: 1.8rem; font-weight: 800; color: #fff; margin: 60px 0 20px; letter-spacing: -0.5px; border-bottom: 2px solid #152040; padding-bottom: 12px; }
.mco-container h3 { font-size: 1.3rem; font-weight: 700; color: #e0e6f0; margin: 32px 0 12px; }
.mco-container p, .mco-container li { color: #a0aab8; font-size: 1rem; margin-bottom: 16px; }
.mco-container ul, .mco-container ol { padding-left: 24px; }
.mco-container li { margin-bottom: 8px; }
.mco-container strong { color: #e0e6f0; }

/* Assumption cards */
.assumption-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); gap: 16px; margin: 24px 0 40px; }
.assumption-card { background: #0a1020; border: 1px solid #152040; border-radius: 14px; padding: 24px; }
.assumption-card .label { font-size: 0.75rem; color: #5a6a80; font-weight: 700; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 8px; }
.assumption-card .value { font-family: 'JetBrains Mono', monospace; font-size: 2rem; font-weight: 700; color: #fff; margin-bottom: 8px; }
.assumption-card .rationale { font-size: 0.85rem; color: #7a8a9e; line-height: 1.5; }

/* Tables */
.table-wrap { overflow-x: auto; margin: 24px 0 40px; border-radius: 14px; border: 1px solid #152040; background: #0a1020; }
.mco-table { width: 100%; border-collapse: collapse; }
.mco-table th { background: #0d1428; padding: 14px 16px; font-size: 0.75rem; color: #5a6a80; font-weight: 700; text-transform: uppercase; letter-spacing: 1px; text-align: right; border-bottom: 2px solid #152040; white-space: nowrap; }
.mco-table th:first-child { text-align: left; }
.mco-table td { padding: 14px 16px; font-size: 0.9rem; color: #c8d0de; text-align: right; border-bottom: 1px solid #0d1428; font-family: 'JetBrains Mono', monospace; }
.mco-table td:first-child { text-align: left; font-family: 'Inter', sans-serif; color: #a0aab8; font-weight: 600; }
.mco-table tr:hover td { background: rgba(74,143,231,0.03); }
.mco-table .row-total td { font-weight: 800; color: #fff; border-top: 2px solid #1a2a40; background: rgba(74,143,231,0.04); }
.mco-table td.highlight-cell { color: #4a8fe7; font-weight: 700; }

/* Sensitivity */
.sensitivity-table th.current { background: rgba(74,143,231,0.15); color: #4a8fe7; }
.sensitivity-table td.current { background: rgba(74,143,231,0.08); color: #4a8fe7; font-weight: 700; }

/* Chart bars */
.bar-chart { margin: 24px 0 40px; }
.bar-row { display: flex; align-items: center; gap: 12px; margin-bottom: 10px; }
.bar-label { width: 48px; font-size: 0.85rem; color: #5a6a80; font-weight: 600; text-align: right; flex-shrink: 0; }
.bar-track { flex: 1; background: #0a1020; border-radius: 8px; height: 32px; overflow: hidden; position: relative; }
.bar-fill { height: 100%; border-radius: 8px; display: flex; align-items: center; padding-left: 12px; font-size: 0.8rem; font-weight: 700; color: #fff; font-family: 'JetBrains Mono', monospace; min-width: 80px; transition: width 0.6s ease; }
.bar-fill.revenue { background: linear-gradient(90deg, #1a3a6e, #4a8fe7); }
.bar-fill.fcf { background: linear-gradient(90deg, #1a5a3e, #10b981); }

/* Methodology */
.method-step { display: flex; gap: 16px; margin-bottom: 24px; padding: 20px; background: #0a1020; border: 1px solid #152040; border-radius: 14px; }
.step-num { width: 40px; height: 40px; background: rgba(74,143,231,0.12); color: #4a8fe7; font-weight: 800; font-size: 1.1rem; border-radius: 50%; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
.step-content { flex: 1; }
.step-content h4 { color: #e0e6f0; font-size: 1rem; margin-bottom: 6px; }
.step-content p { margin-bottom: 0; font-size: 0.9rem; }

/* Disclaimer */
.disclaimer { margin: 60px 0 0; padding: 24px; background: rgba(239,68,68,0.05); border: 1px solid rgba(239,68,68,0.15); border-radius: 14px; }
.disclaimer h4 { color: #ef4444; margin-bottom: 8px; font-size: 0.85rem; text-transform: uppercase; letter-spacing: 1px; }
.disclaimer p { font-size: 0.85rem; color: #7a8a9e; margin-bottom: 0; }

/* FAQ */
.faq { margin: 40px 0; }
.faq details { background: #0a1020; border: 1px solid #152040; border-radius: 14px; margin-bottom: 12px; overflow: hidden; }
.faq summary { padding: 18px 20px; cursor: pointer; font-weight: 700; color: #e0e6f0; font-size: 1rem; list-style: none; display: flex; justify-content: space-between; align-items: center; }
.faq summary::after { content: '+'; font-size: 1.2rem; color: #4a8fe7; transition: transform 0.2s; }
.faq details[open] summary::after { content: '−'; }
.faq .faq-answer { padding: 0 20px 18px; font-size: 0.9rem; color: #a0aab8; }

.error-card { background: rgba(239,68,68,0.1); border: 1px solid #ef4444; color: #ef4444; padding: 20px; border-radius: 14px; text-align: center; margin-top: 40px; }

@media (max-width: 640px) {
  .stats-row { grid-template-columns: repeat(2, 1fr); }
  .assumption-grid { grid-template-columns: 1fr; }
  .verdict-card { padding: 32px 20px; }
}
</style>

<div class="mco-header">
  <div class="mco-header-content">
    <div class="mco-tag">DCF Valuation</div>
    <h1>Moody's (MCO)<br/>Intrinsic Value</h1>
    <p class="mco-subtitle">A transparent, two-stage discounted cash flow valuation of Moody's Corporation. Calculated mathematically from historical fundamentals.</p>
    <div class="mco-compiled">Compiled by Gemini 3.1</div>
  </div>
</div>

<div class="mco-container">
  {isDataComplete ? (
    <>
      <!-- ═══ THE VERDICT ═══ -->
      <div class="verdict-card">
        <div class="verdict-label">Estimated Intrinsic Value Per Share</div>
        <div class="verdict-price">${roundedIV.toFixed(2)}</div>
        {currentPrice !== null && (
          <div class="verdict-vs">vs. market price of ${currentPrice.toFixed(2)} ({marginOfSafety > 0 ? '+' : ''}{marginOfSafety.toFixed(1)}%)</div>
        )}
        <div class="verdict-badge" style={`background: ${verdictColor}22; color: ${verdictColor}; border: 1px solid ${verdictColor}44;`}>
          {verdictText}
        </div>
      </div>

      <!-- ═══ KEY METRICS ═══ -->
      <div class="stats-row">
        <div class="stat-card">
          <div class="stat-value">${revenueHistory[0] !== null ? revenueHistory[0].toLocaleString() : 'N/A'}M</div>
          <div class="stat-label">TTM Revenue</div>
        </div>
        <div class="stat-card">
          <div class="stat-value">${currentFCF !== null ? currentFCF.toLocaleString() : 'N/A'}M</div>
          <div class="stat-label">TTM Free Cash Flow</div>
        </div>
        <div class="stat-card">
          <div class="stat-value">${eps !== null ? eps.toFixed(2) : 'N/A'}</div>
          <div class="stat-label">EPS (Diluted)</div>
        </div>
        <div class="stat-card">
          <div class="stat-value">${netCash !== null ? netCash.toLocaleString() : 'N/A'}M</div>
          <div class="stat-label">Net Cash / (Debt)</div>
        </div>
        <div class="stat-card">
          <div class="stat-value">{sharesOutstanding !== null ? sharesOutstanding.toLocaleString() : 'N/A'}M</div>
          <div class="stat-label">Shares Out.</div>
        </div>
      </div>

      <!-- ═══ METHODOLOGY ═══ -->
      <h2>Methodology: Two-Stage DCF</h2>
      <p>We use a <strong>two-stage discounted cash flow (DCF)</strong> model. We derive future growth based on historical mathematical averages, projecting cash flows into the future and discounting them to today's present value.</p>

      <div class="method-step">
        <div class="step-num">1</div>
        <div class="step-content">
          <h4>Base Cash Flow</h4>
          <p>We start with Moody's Trailing Twelve Months (TTM) Free Cash Flow of <strong>${currentFCF.toLocaleString()}M</strong>. FCF represents the actual cash available to be returned to shareholders after maintaining operations.</p>
        </div>
      </div>

      <div class="method-step">
        <div class="step-num">2</div>
        <div class="step-content">
          <h4>Phase 1: 5-Year High Growth</h4>
          <p>We project FCF to grow at a mathematically derived CAGR of <strong>{(growthRatePhase1 * 100).toFixed(1)}%</strong> for the next 5 years, calculated directly from the company's own historical financial performance over the past 5 years.</p>
        </div>
      </div>

      <div class="method-step">
        <div class="step-num">3</div>
        <div class="step-content">
          <h4>Phase 2: Terminal Value</h4>
          <p>Beyond year 5, we assume a perpetual growth rate of <strong>{(terminalGrowthRate * 100).toFixed(1)}%</strong>. We calculate the Terminal Value using the Gordon Growth Model to capture the value of all cash flows from year 6 to infinity.</p>
        </div>
      </div>

      <div class="method-step">
        <div class="step-num">4</div>
        <div class="step-content">
          <h4>Discounting to Present Value</h4>
          <p>We discount all future cash flows back to today using a derived cost of equity (proxy for WACC) of <strong>{(discountRate * 100).toFixed(1)}%</strong>. This accounts for the time value of money and the risk of the investment relative to the 10Y Treasury yield.</p>
        </div>
      </div>

      <!-- ═══ THE THREE ASSUMPTIONS ═══ -->
      <h2>The Assumptions That Drive Everything</h2>
      <p>A DCF model is driven by growth and discount rates. Here are the mathematically derived inputs used in this valuation.</p>

      <div class="assumption-grid">
        <div class="assumption-card">
          <div class="label">Phase 1 FCF Growth Rate</div>
          <div class="value">{(growthRatePhase1 * 100).toFixed(1)}%</div>
          <div class="rationale">
            Derived directly from the Compound Annual Growth Rate (CAGR) of Moody's historical financials over the last 5 years. This assumes the company can maintain its historical growth trajectory for the next 5 years.
          </div>
        </div>
        <div class="assumption-card">
          <div class="label">Discount Rate (Required Return)</div>
          <div class="value">{(discountRate * 100).toFixed(1)}%</div>
          <div class="rationale">
            Derived using the Capital Asset Pricing Model (CAPM). Based on the 10-Year Treasury yield of {(treasury10Y * 100).toFixed(2)}%, an assumed beta of {beta}, and an equity risk premium of {(equityRiskPremium * 100).toFixed(1)}%.
          </div>
        </div>
        <div class="assumption-card">
          <div class="label">Terminal Growth Rate</div>
          <div class="value">{(terminalGrowthRate * 100).toFixed(1)}%</div>
          <div class="rationale">
            The long-term growth rate applied after year 5. Derived as a percentage of the 10Y Treasury yield to approximate long-term nominal GDP growth, capped at 3.5% to ensure it does not exceed economic growth.
          </div>
        </div>
      </div>

      <!-- ═══ FCF PROJECTIONS TABLE ═══ -->
      <h2>Projected Free Cash Flows (Phase 1)</h2>
      <div class="table-wrap">
        <table class="mco-table">
          <thead>
            <tr>
              <th style="text-align:left">Year</th>
              <th>Projected FCF ($M)</th>
              <th>PV Factor</th>
              <th>Present Value ($M)</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td>Base (Year 0)</td>
              <td>${currentFCF.toLocaleString()}</td>
              <td>—</td>
              <td>—</td>
            </tr>
            {projectedFCF.map(p => (
              <tr>
                <td>Year {p.year}</td>
                <td>${Math.round(p.fcf).toLocaleString()}</td>
                <td>{p.pvFactor.toFixed(4)}</td>
                <td>${Math.round(p.pvFCF).toLocaleString()}</td>
              </tr>
            ))}
            <tr class="row-total">
              <td colspan="3">Sum of Phase 1 Present Value</td>
              <td class="highlight-cell">${Math.round(pvPhase1).toLocaleString()}</td>
            </tr>
          </tbody>
        </table>
      </div>

      <!-- ═══ TERMINAL VALUE ═══ -->
      <h3>Terminal Value Calculation (Phase 2)</h3>
      <div class="table-wrap">
        <table class="mco-table">
          <thead>
            <tr>
              <th style="text-align:left">Component</th>
              <th>Value ($M)</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td>Year 6 FCF (Year 5 × (1 + {(terminalGrowthRate * 100).toFixed(1)}%))</td>
              <td>${Math.round(fcfYear6).toLocaleString()}</td>
            </tr>
            <tr>
              <td>Terminal Value (FCF₆ ÷ ({(discountRate * 100).toFixed(1)}% − {(terminalGrowthRate * 100).toFixed(1)}%))</td>
              <td>${Math.round(terminalValue).toLocaleString()}</td>
            </tr>
            <tr class="row-total">
              <td>Present Value of Terminal Value</td>
              <td class="highlight-cell">${Math.round(pvTerminalValue).toLocaleString()}</td>
            </tr>
          </tbody>
        </table>
      </div>

      <!-- ═══ FINAL CALCULATION ═══ -->
      <h3>Enterprise to Equity Value</h3>
      <div class="table-wrap">
        <table class="mco-table">
          <thead>
            <tr>
              <th style="text-align:left">Component</th>
              <th>Value ($M)</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td>PV of Phase 1 Cash Flows</td>
              <td>${Math.round(pvPhase1).toLocaleString()}</td>
            </tr>
            <tr>
              <td>PV of Terminal Value</td>
              <td>${Math.round(pvTerminalValue).toLocaleString()}</td>
            </tr>
            <tr class="row-total">
              <td>= Enterprise Value</td>
              <td>${Math.round(enterpriseValue).toLocaleString()}</td>
            </tr>
            <tr>
              <td>+ Net Cash (Cash & Eq. − Total Debt)</td>
              <td>${Math.round(netCash).toLocaleString()}</td>
            </tr>
            <tr class="row-total">
              <td>= Equity Value</td>
              <td>${Math.round(equityValue).toLocaleString()}</td>
            </tr>
            <tr>
              <td>÷ Shares Outstanding (Diluted)</td>
              <td>{sharesOutstanding.toLocaleString()}</td>
            </tr>
            <tr class="row-total">
              <td>Intrinsic Value Per Share</td>
              <td class="highlight-cell">${roundedIV.toFixed(2)}</td>
            </tr>
          </tbody>
        </table>
      </div>

      <!-- ═══ SENSITIVITY ANALYSIS ═══ -->
      <h2>Sensitivity Analysis</h2>
      <p>The matrix below shows how changes in the discount rate and short-term growth rate impact the intrinsic value per share.</p>

      <div class="table-wrap">
        <table class="mco-table sensitivity-table">
          <thead>
            <tr>
              <th style="text-align:left">Discount Rate ↓ / Growth →</th>
              {sensitivityGrowth.map(g => (
                <th class={Math.abs(g - growthRatePhase1) < 0.001 ? 'current' : ''}>{(g * 100).toFixed(1)}%</th>
              ))}
            </tr>
          </thead>
          <tbody>
            {sensitivityTable.map(row => (
              <tr>
                <td>{(row.dr * 100).toFixed(1)}%</td>
                {row.values.map((v, i) => (
                  <td class={Math.abs(row.dr - discountRate) < 0.001 && Math.abs(sensitivityGrowth[i] - growthRatePhase1) < 0.001 ? 'current' : ''}>
                    ${v}
                  </td>
                ))}
              </tr>
            ))}
          </tbody>
        </table>
      </div>

      <!-- ═══ HISTORICAL CHARTS ═══ -->
      <h2>Historical Performance</h2>
      <p>Understanding the past helps contextualize the projections.</p>

      <h3>Revenue ($M)</h3>
      <div class="bar-chart">
        {chartDataRev.map(r => (
          <div class="bar-row">
            <div class="bar-label">{r.year}</div>
            <div class="bar-track">
              <div class="bar-fill revenue" style={`width: ${(r.value / Math.max(...chartDataRev.map(d => d.value))) * 100}%`}>
                ${r.value.toLocaleString()}
              </div>
            </div>
          </div>
        ))}
      </div>

      <h3>Free Cash Flow ($M)</h3>
      <div class="bar-chart">
        {chartDataFCF.map(r => (
          <div class="bar-row">
            <div class="bar-label">{r.year}</div>
            <div class="bar-track">
              <div class="bar-fill fcf" style={`width: ${(r.value / Math.max(...chartDataFCF.map(d => d.value))) * 100}%`}>
                ${r.value.toLocaleString()}
              </div>
            </div>
          </div>
        ))}
      </div>

      <!-- ═══ RISKS ═══ -->
      <h2>Risks to Valuation</h2>
      <ul>
        <li><strong>Macroeconomic Sensitivity:</strong> Moody's ratings issuance is highly correlated with global debt issuance volume, which fluctuates based on interest rates and macroeconomic stability.</li>
        <li><strong>Regulatory Environment:</strong> Credit rating agencies are heavily regulated. Changes in regulations or legal liabilities could negatively impact margins and cash flow.</li>
        <li><strong>Competition:</strong> Although forming a near-duopoly with S&P Global, competition for data, analytics, and non-rating services is intense.</li>
        <li><strong>Interest Rates:</strong> A prolonged high-interest-rate environment could suppress corporate debt issuance over an extended period, slowing growth.</li>
      </ul>

      <!-- ═══ FAQ ═══ -->
      <h2>Frequently Asked Questions</h2>
      <div class="faq">
        <details>
          <summary>Why use Free Cash Flow instead of Net Income?</summary>
          <div class="faq-answer">Free Cash Flow removes non-cash accounting expenses and accounts for capital expenditures. It represents the true cash generated by the business that can be used to pay dividends, buy back stock, or reinvest.</div>
        </details>
        <details>
          <summary>How was the growth rate determined?</summary>
          <div class="faq-answer">The phase 1 growth rate of {(growthRatePhase1 * 100).toFixed(1)}% was derived mathematically from the compound annual growth rate of the company's historical financial performance over the past five years.</div>
        </details>
        <details>
          <summary>What is the Margin of Safety?</summary>
          <div class="faq-answer">The margin of safety is the difference between the intrinsic value and the current market price. A larger positive margin indicates a potentially undervalued stock, providing a buffer against errors in calculation or adverse market events.</div>
        </details>
      </div>

      <!-- ═══ DISCLAIMER ═══ -->
      <div class="disclaimer">
        <h4>⚠️ Disclaimer</h4>
        <p>This automated Discounted Cash Flow analysis is compiled for educational and informational purposes only. It relies on mathematically derived historical data and base assumptions. It is not financial advice, a recommendation to buy or sell, or a complete assessment of the company's qualitative moats or risks. Always perform your own due diligence.</p>
      </div>
    </>
  ) : (
    <div class="error-card">
      <h2>Data Unavailable</h2>
      <p>Unable to fetch complete financial data for Moody's (MCO) to perform the DCF calculation at this time.</p>
