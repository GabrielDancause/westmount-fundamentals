---
import SiteLayout from "../layouts/SiteLayout.astro";

export const meta = { title: "Margin of Safety Calculator — Find Undervalued Stocks", description: "Free margin of safety calculator for value investors. Use Benjamin Graham's formula to compare intrinsic value vs market price for 168 S&P 500 stocks.", category: "study", published: "2026-03-20" };

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Article",
      "headline": "Margin of Safety Calculator — Find Undervalued Stocks",
      "description": "Free margin of safety calculator for value investors. Use Benjamin Graham's formula to compare intrinsic value vs market price for 168 S&P 500 stocks.",
      "author": { "@type": "Organization", "name": "Westmount Fundamentals" },
      "datePublished": "2026-03-20",
      "publisher": { "@type": "Organization", "name": "Westmount Fundamentals" }
    },
    {
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "What is margin of safety in investing?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Margin of safety is the difference between a stock's intrinsic value and its market price, expressed as a percentage. Coined by Benjamin Graham in The Intelligent Investor, it measures how much a stock is undervalued. A higher margin of safety means lower downside risk and greater potential for returns."
          }
        },
        {
          "@type": "Question",
          "name": "How do you calculate margin of safety?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "The margin of safety formula is: ((Intrinsic Value - Market Price) / Intrinsic Value) × 100. For example, if a stock's intrinsic value is $100 and its current price is $70, the margin of safety is 30%. This means the stock is trading 30% below its estimated fair value."
          }
        },
        {
          "@type": "Question",
          "name": "What is a good margin of safety for stocks?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Benjamin Graham recommended a margin of safety of at least 33%. Warren Buffett typically looks for 25% or more. Growth investors may accept 15%. The ideal margin depends on the quality and predictability of the business — riskier businesses warrant a higher margin of safety."
          }
        },
        {
          "@type": "Question",
          "name": "What is the difference between margin of safety and intrinsic value?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Intrinsic value is the estimated true worth of a stock based on fundamentals like earnings, cash flow, and growth. Margin of safety is the percentage discount at which the stock trades below that intrinsic value. Intrinsic value is the anchor; margin of safety is the buffer."
          }
        },
        {
          "@type": "Question",
          "name": "Can margin of safety be negative?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Yes. A negative margin of safety means the stock is trading above its estimated intrinsic value — it is overvalued. For example, if intrinsic value is $80 and the price is $100, the margin of safety is -25%. This signals higher risk and lower expected returns."
          }
        }
      ]
    }
  ]
};
---
<SiteLayout site="westmount" title="Margin of Safety Calculator — Find Undervalued Stocks" description="Free margin of safety calculator for value investors. Use Benjamin Graham's formula to compare intrinsic value vs market price for 168 S&P 500 stocks." canonical="https://westmountfundamentals.com/margin-of-safety-calculator/" schema={schema}>
  <div style="max-width:1280px;margin:0 auto;padding:16px 24px 0;display:flex;justify-content:space-between;align-items:center;font-size:13px;color:var(--text-dim,#94a3b8)">
    <nav aria-label="Breadcrumb"><a href="/" style="color:var(--text-dim,#94a3b8);text-decoration:none">Home</a> <span style="margin:0 6px;opacity:0.5">›</span> <a href="/studies/" style="color:var(--text-dim,#94a3b8);text-decoration:none">Studies</a> <span style="margin:0 6px;opacity:0.5">›</span> <span style="color:var(--text-primary,#c8d0de)">Margin of Safety Calculator</span></nav>
    <span>8 min read</span>
  </div>
  <div class="page-content">
    <div class="hero">
      <h1>Margin of Safety Calculator</h1>
      <p class="subtitle">Benjamin Graham's most powerful concept, applied to 168 S&P 500 stocks. Calculate how much downside protection you have before you invest.</p>
    </div>

    <!-- Stat Cards -->
    <div class="mos-stats" id="statCards">
      <div class="stat-card"><div class="stat-value" id="statAvgMos">—</div><div class="stat-label">Avg Margin of Safety</div></div>
      <div class="stat-card"><div class="stat-value" style="color:var(--positive)" id="statUndervalued">—</div><div class="stat-label">Undervalued Stocks</div></div>
      <div class="stat-card"><div class="stat-value" style="color:var(--negative)" id="statOvervalued">—</div><div class="stat-label">Overvalued Stocks</div></div>
      <div class="stat-card"><div class="stat-value" style="color:var(--positive)" id="statHighest">—</div><div class="stat-label">Highest MoS Ticker</div></div>
    </div>

    <!-- Calculator Section -->
    <section>
      <h2>Interactive Margin of Safety Calculator</h2>
      <p>Enter a <strong>ticker symbol</strong> to auto-fill with our intrinsic value estimates, or manually input your own intrinsic value and market price.</p>

      <div class="calc-wrapper">
        <div class="calc-inputs">
          <div class="input-group">
            <label for="tickerInput">Ticker Lookup</label>
            <input type="text" id="tickerInput" placeholder="e.g. AAPL, MSFT, TSLA" autocomplete="off" style="text-transform:uppercase">
            <div id="tickerSuggestions" class="ticker-suggestions"></div>
          </div>
          <div id="tickerInfo" class="ticker-info" style="display:none">
            <div class="ticker-name" id="tickerName"></div>
            <div class="ticker-details">
              <span>Our IV: <strong id="tickerIV"></strong></span>
              <span>Price: <strong id="tickerPrice"></strong></span>
            </div>
          </div>
          <div class="input-row">
            <div class="input-group">
              <label for="ivInput">Intrinsic Value ($)</label>
              <input type="number" id="ivInput" placeholder="e.g. 150.00" step="0.01" min="0">
            </div>
            <div class="input-group">
              <label for="priceInput">Current Market Price ($)</label>
              <input type="number" id="priceInput" placeholder="e.g. 120.00" step="0.01" min="0">
            </div>
          </div>
          <button id="calcBtn" class="calc-btn">Calculate Margin of Safety</button>
        </div>

        <div class="calc-result" id="calcResult" style="display:none">
          <div class="mos-big" id="mosValue">—</div>
          <div class="mos-verdict" id="mosVerdict">—</div>
          <canvas id="mosGauge" width="400" height="200"></canvas>
        </div>
      </div>
    </section>

    <!-- Formula Section -->
    <section>
      <h2>Margin of Safety Formula</h2>
      <div class="formula-box">
        <div class="formula">Margin of Safety = ((Intrinsic Value − Market Price) / Intrinsic Value) × 100</div>
      </div>
      <p>The formula is elegantly simple. If a stock has an intrinsic value of <strong>$100</strong> and trades at <strong>$70</strong>, your margin of safety is <strong>30%</strong>. That 30% is your buffer — room for error in your analysis, unexpected market shocks, or temporary business headwinds.</p>
      <div class="callout">
        <strong>Example:</strong> If you estimate Apple's intrinsic value at $206.86 and it trades at $252.38, the margin of safety is <strong>−22.0%</strong> — meaning the stock is trading <em>above</em> your estimated fair value with no safety cushion.
      </div>
    </section>

    <!-- Top 10 Undervalued -->
    <section>
      <h2>Top 10 Most Undervalued S&P 500 Stocks</h2>
      <p>These stocks have the <strong>highest positive margin of safety</strong> in our universe — trading well below our intrinsic value estimates.</p>
      <div class="table-scroll">
        <table class="mos-table" id="topUndervalued">
          <thead><tr><th>Ticker</th><th>Company</th><th>Intrinsic Value</th><th>Current Price</th><th>MoS %</th></tr></thead>
          <tbody></tbody>
        </table>
      </div>
    </section>

    <!-- Top 10 Overvalued -->
    <section>
      <h2>Top 10 Most Overvalued S&P 500 Stocks</h2>
      <p>These stocks trade <strong>furthest above</strong> our intrinsic value estimates — negative margin of safety signals potential downside risk.</p>
      <div class="table-scroll">
        <table class="mos-table" id="topOvervalued">
          <thead><tr><th>Ticker</th><th>Company</th><th>Intrinsic Value</th><th>Current Price</th><th>MoS %</th></tr></thead>
          <tbody></tbody>
        </table>
      </div>
    </section>

    <!-- Scatter Plot -->
    <section>
      <h2>Intrinsic Value vs Market Price — All 168 Stocks</h2>
      <p>Stocks <strong>above the diagonal</strong> are undervalued (IV &gt; Price). Stocks <strong>below the line</strong> are overvalued. The further from the line, the greater the mispricing.</p>
      <div class="chart-container">
        <canvas id="scatterChart"></canvas>
      </div>
    </section>

    <!-- What is MoS -->
    <section>
      <h2>What Is Margin of Safety?</h2>
      <p>The <strong>margin of safety</strong> is the foundational concept of value investing, introduced by <strong>Benjamin Graham</strong> in his 1949 masterwork <em>The Intelligent Investor</em>. It represents the discount at which a security trades relative to its intrinsic (or fair) value.</p>
      <p>Graham argued that no analyst can precisely determine a company's true worth. Earnings estimates can be wrong. Growth rates can stall. Management can make mistakes. The margin of safety accounts for all of these uncertainties by demanding that investors only buy when the price is <em>significantly</em> below the estimated value.</p>
      <p><strong>Warren Buffett</strong>, Graham's most famous student, has called margin of safety the "three most important words in all of investing." Buffett refined the concept: instead of buying mediocre businesses at deep discounts (Graham's cigar-butt approach), he buys <em>wonderful businesses at fair prices</em> — but still insists on a meaningful margin of safety before committing capital.</p>

      <div class="callout">
        <strong>Graham's Analogy:</strong> "Confronted with a challenge to distill the secret of sound investment into three words, we venture the motto: Margin of Safety." — <em>The Intelligent Investor</em>, Chapter 20
      </div>
    </section>

    <!-- Different Thresholds -->
    <section>
      <h2>What Margin of Safety Should You Use?</h2>
      <p>Different investors use different thresholds depending on their risk tolerance, the quality of the business, and the predictability of earnings:</p>
      <div class="threshold-grid">
        <div class="threshold-card">
          <div class="threshold-pct">33%+</div>
          <div class="threshold-who">Benjamin Graham</div>
          <div class="threshold-why">Deep value. Buy net-nets and statistically cheap stocks. High margin required because the businesses are often mediocre.</div>
        </div>
        <div class="threshold-card">
          <div class="threshold-pct">25%+</div>
          <div class="threshold-who">Warren Buffett</div>
          <div class="threshold-why">Quality at a discount. Seeks wonderful companies with durable competitive advantages, but won't overpay.</div>
        </div>
        <div class="threshold-card">
          <div class="threshold-pct">15%+</div>
          <div class="threshold-who">Growth Investors</div>
          <div class="threshold-why">Accepts slimmer margins for high-growth, high-quality compounders where future earnings justify a premium valuation.</div>
        </div>
      </div>
      <p>The key insight: <strong>the riskier or less predictable the business, the higher the margin of safety you should demand.</strong> A utility company with stable cash flows might only need 15%. A cyclical commodity producer might need 40%+.</p>
    </section>

    <!-- Key Insights -->
    <section>
      <h2>5 Key Insights</h2>
      <div class="insights-list">
        <div class="insight">
          <div class="insight-num">1</div>
          <div class="insight-text"><strong>Margin of safety protects against analytical error.</strong> Even the best DCF model is built on assumptions. A 30% margin of safety means your thesis can be 30% wrong and you still break even.</div>
        </div>
        <div class="insight">
          <div class="insight-num">2</div>
          <div class="insight-text"><strong>Negative MoS does not always mean "sell."</strong> Some great companies trade above IV for years because the market prices in future growth your model may not capture. Context matters.</div>
        </div>
        <div class="insight">
          <div class="insight-num">3</div>
          <div class="insight-text"><strong>Intrinsic value is a range, not a point.</strong> Any single IV estimate is imprecise. Use margin of safety as a probability filter, not a binary signal.</div>
        </div>
        <div class="insight">
          <div class="insight-num">4</div>
          <div class="insight-text"><strong>The best time to find wide margins of safety is during market panic.</strong> In 2008, 2020, and every major correction, high-quality stocks briefly traded at 40-50% discounts to fair value. Those were generational buying opportunities.</div>
        </div>
        <div class="insight">
          <div class="insight-num">5</div>
          <div class="insight-text"><strong>Pair MoS with quality metrics.</strong> A 50% margin of safety on a company with declining revenues and rising debt is not value investing — it's a value trap. Always check the moat, management, and balance sheet.</div>
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section>
      <h2>Frequently Asked Questions</h2>
      <div class="faq-list">
        <details class="faq-item"><summary>What is margin of safety in investing?</summary><p>Margin of safety is the difference between a stock's intrinsic value and its market price, expressed as a percentage. Coined by Benjamin Graham in <em>The Intelligent Investor</em>, it measures how much a stock is undervalued. A higher margin of safety means lower downside risk and greater potential for returns.</p></details>
        <details class="faq-item"><summary>How do you calculate margin of safety?</summary><p>The margin of safety formula is: ((Intrinsic Value − Market Price) / Intrinsic Value) × 100. For example, if a stock's intrinsic value is $100 and its current price is $70, the margin of safety is 30%.</p></details>
        <details class="faq-item"><summary>What is a good margin of safety for stocks?</summary><p>Benjamin Graham recommended at least 33%. Warren Buffett typically looks for 25% or more. Growth investors may accept 15%. The ideal margin depends on the quality and predictability of the business.</p></details>
        <details class="faq-item"><summary>What is the difference between margin of safety and intrinsic value?</summary><p>Intrinsic value is the estimated true worth of a stock based on fundamentals. Margin of safety is the percentage discount at which the stock trades below that intrinsic value. Intrinsic value is the anchor; margin of safety is the buffer.</p></details>
        <details class="faq-item"><summary>Can margin of safety be negative?</summary><p>Yes. A negative margin of safety means the stock is trading above its estimated intrinsic value — it is overvalued. This signals higher risk and lower expected returns for the investor.</p></details>
      </div>
    </section>
  </div>

