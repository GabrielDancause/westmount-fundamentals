(function(){
  var tickers = [];
  var k;
  for (k in IV_DATA) {
    if (IV_DATA.hasOwnProperty(k)) {
      var d = IV_DATA[k];
      var mos = ((d.iv - d.p) / d.iv) * 100;
      tickers.push({ t: k, n: d.n, iv: d.iv, p: d.p, mos: Math.round(mos * 100) / 100 });
    }
  }

  // Sort by MoS descending
  tickers.sort(function(a, b) { return b.mos - a.mos; });

  // Stats
  var totalMos = 0;
  var undervalued = 0;
  var overvalued = 0;
  var highestTicker = tickers[0];
  for (var i = 0; i < tickers.length; i++) {
    totalMos += tickers[i].mos;
    if (tickers[i].mos > 0) undervalued++;
    else overvalued++;
  }
  var avgMos = Math.round((totalMos / tickers.length) * 10) / 10;

  document.getElementById("statAvgMos").textContent = avgMos + "%";
  document.getElementById("statAvgMos").style.color = avgMos >= 0 ? "var(--positive)" : "var(--negative)";
  document.getElementById("statUndervalued").textContent = undervalued;
  document.getElementById("statOvervalued").textContent = overvalued;
  document.getElementById("statHighest").textContent = highestTicker.t + " (" + highestTicker.mos + "%)";

  // Top 10 tables
  function buildTable(id, items) {
    var tbody = document.getElementById(id).querySelector("tbody");
    var html = "";
    for (var j = 0; j < items.length; j++) {
      var r = items[j];
      var cls = r.mos >= 0 ? "mos-pos" : "mos-neg";
      html += "<tr><td><strong>" + r.t + "</strong></td><td>" + r.n + "</td><td>$" + r.iv.toLocaleString() + "</td><td>$" + r.p.toLocaleString() + "</td><td class=\"" + cls + "\">" + r.mos + "%</td></tr>";
    }
    tbody.innerHTML = html;
  }

  buildTable("topUndervalued", tickers.slice(0, 10));
  var overSorted = tickers.slice().sort(function(a, b) { return a.mos - b.mos; });
  buildTable("topOvervalued", overSorted.slice(0, 10));

  // Scatter chart - cap at 2000 for readability
  var scatterData = [];
  var scatterColors = [];
  var scatterLabels = [];
  var maxVal = 0;
  for (var s = 0; s < tickers.length; s++) {
    var st = tickers[s];
    if (st.p > 2000 || st.iv > 2000) continue; // skip extreme outliers for chart clarity
    scatterData.push({ x: st.p, y: st.iv });
    scatterLabels.push(st.t);
    scatterColors.push(st.mos > 0 ? "#10b981" : "#ef4444");
    if (st.p > maxVal) maxVal = st.p;
    if (st.iv > maxVal) maxVal = st.iv;
  }

  var scatterCtx = document.getElementById("scatterChart").getContext("2d");
  new Chart(scatterCtx, {
    type: "scatter",
    data: {
      datasets: [
        {
          label: "Stocks",
          data: scatterData,
          backgroundColor: scatterColors,
          pointRadius: 5,
          pointHoverRadius: 8
        },
        {
          label: "Fair Value Line",
          data: [{ x: 0, y: 0 }, { x: maxVal, y: maxVal }],
          type: "line",
          borderColor: "#4a8fe7",
          borderWidth: 2,
          borderDash: [6, 4],
          pointRadius: 0,
          fill: false
        }
      ]
    },
    options: {
      responsive: true,
      plugins: {
        legend: { display: true, labels: { color: "#8b949e" } },
        tooltip: {
          callbacks: {
            label: function(ctx) {
              if (ctx.datasetIndex === 1) return "";
              var idx = ctx.dataIndex;
              return scatterLabels[idx] + " — Price: $" + ctx.parsed.x + ", IV: $" + ctx.parsed.y;
            }
          }
        }
      },
      scales: {
        x: { title: { display: true, text: "Current Price ($)", color: "#8b949e" }, grid: { color: "#21262d" }, ticks: { color: "#8b949e" } },
        y: { title: { display: true, text: "Intrinsic Value ($)", color: "#8b949e" }, grid: { color: "#21262d" }, ticks: { color: "#8b949e" } }
      }
    }
  });

  // Calculator
  var tickerInput = document.getElementById("tickerInput");
  var sugBox = document.getElementById("tickerSuggestions");
  var ivInput = document.getElementById("ivInput");
  var priceInput = document.getElementById("priceInput");
  var calcBtn = document.getElementById("calcBtn");
  var calcResult = document.getElementById("calcResult");
  var mosValueEl = document.getElementById("mosValue");
  var mosVerdictEl = document.getElementById("mosVerdict");
  var tickerInfo = document.getElementById("tickerInfo");

  tickerInput.addEventListener("input", function() {
    var val = tickerInput.value.toUpperCase().replace(/[^A-Z.]/g, "");
    tickerInput.value = val;
    if (val.length === 0) { sugBox.style.display = "none"; tickerInfo.style.display = "none"; return; }
    var matches = [];
    for (var mk in IV_DATA) {
      if (IV_DATA.hasOwnProperty(mk) && mk.indexOf(val) === 0) {
        matches.push(mk);
      }
    }
    if (matches.length === 0) { sugBox.style.display = "none"; return; }
    // If exact match, auto-fill
    if (IV_DATA[val]) {
      fillTicker(val);
      sugBox.style.display = "none";
      return;
    }
    var sugHtml = "";
    for (var mi = 0; mi < Math.min(matches.length, 8); mi++) {
      sugHtml += "<div class=\"sug-item\" data-ticker=\"" + matches[mi] + "\">" + matches[mi] + " — " + IV_DATA[matches[mi]].n + "</div>";
    }
    sugBox.innerHTML = sugHtml;
    sugBox.style.display = "block";
    var sugItems = sugBox.querySelectorAll(".sug-item");
    for (var si = 0; si < sugItems.length; si++) {
      sugItems[si].addEventListener("click", function() {
        var tk = this.getAttribute("data-ticker");
        tickerInput.value = tk;
        fillTicker(tk);
        sugBox.style.display = "none";
      });
    }
  });

  function fillTicker(tk) {
    var data = IV_DATA[tk];
    if (!data) return;
    document.getElementById("tickerName").textContent = data.n + " (" + tk + ")";
    document.getElementById("tickerIV").textContent = "$" + data.iv;
    document.getElementById("tickerPrice").textContent = "$" + data.p;
    tickerInfo.style.display = "block";
    ivInput.value = data.iv;
    priceInput.value = data.p;
  }

  document.addEventListener("click", function(e) {
    if (e.target.id !== "tickerInput") sugBox.style.display = "none";
  });

  calcBtn.addEventListener("click", function() {
    var iv = parseFloat(ivInput.value);
    var price = parseFloat(priceInput.value);
    if (!iv || iv <= 0 || !price || price <= 0) { alert("Please enter valid Intrinsic Value and Market Price."); return; }
    var mos = ((iv - price) / iv) * 100;
    mos = Math.round(mos * 100) / 100;
    calcResult.style.display = "flex";
    mosValueEl.textContent = mos + "%";
    var verdict, vColor;
    if (mos > 30) { verdict = "Attractive — Strong margin of safety"; vColor = "#10b981"; }
    else if (mos > 15) { verdict = "Moderate — Reasonable cushion"; vColor = "#eab308"; }
    else if (mos > 0) { verdict = "Slim — Limited protection"; vColor = "#f97316"; }
    else { verdict = "No Margin — Stock appears overvalued"; vColor = "#ef4444"; }
    mosValueEl.style.color = vColor;
    mosVerdictEl.textContent = verdict;
    mosVerdictEl.style.color = vColor;
    drawGauge(mos);
  });

  function drawGauge(mos) {
    var canvas = document.getElementById("mosGauge");
    var ctx = canvas.getContext("2d");
    var w = canvas.width;
    var h = canvas.height;
    ctx.clearRect(0, 0, w, h);
    var cx = w / 2;
    var cy = h - 20;
    var r = Math.min(cx, cy) - 20;

    // Draw arc zones
    var zones = [
      { start: -Math.PI, end: -Math.PI * 0.65, color: "#ef4444" },
      { start: -Math.PI * 0.65, end: -Math.PI * 0.35, color: "#f97316" },
      { start: -Math.PI * 0.35, end: -Math.PI * 0.15, color: "#eab308" },
      { start: -Math.PI * 0.15, end: 0, color: "#10b981" }
    ];
    for (var zi = 0; zi < zones.length; zi++) {
      ctx.beginPath();
      ctx.arc(cx, cy, r, zones[zi].start, zones[zi].end);
      ctx.lineWidth = 20;
      ctx.strokeStyle = zones[zi].color;
      ctx.globalAlpha = 0.3;
      ctx.stroke();
      ctx.globalAlpha = 1;
    }

    // Needle
    var clampedMos = Math.max(-50, Math.min(50, mos));
    var angle = -Math.PI + ((clampedMos + 50) / 100) * Math.PI;
    ctx.beginPath();
    ctx.moveTo(cx, cy);
    ctx.lineTo(cx + Math.cos(angle) * (r - 10), cy + Math.sin(angle) * (r - 10));
    ctx.lineWidth = 3;
    ctx.strokeStyle = "#e6edf3";
    ctx.stroke();
    ctx.beginPath();
    ctx.arc(cx, cy, 6, 0, Math.PI * 2);
    ctx.fillStyle = "#e6edf3";
    ctx.fill();

    // Labels
    ctx.font = "12px sans-serif";
    ctx.fillStyle = "#8b949e";
    ctx.textAlign = "left";
    ctx.fillText("<0% Risky", cx - r - 10, cy + 15);
    ctx.textAlign = "right";
    ctx.fillText(">30% Safe", cx + r + 10, cy + 15);
  }
})();
</script>
