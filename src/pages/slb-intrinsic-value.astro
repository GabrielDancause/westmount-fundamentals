---
import SiteLayout from "../layouts/SiteLayout.astro";

const schema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": "SLB N.V. (SLB) Intrinsic Value: A DCF Analysis",
  "description": "A transparent, step-by-step discounted cash flow valuation of SLB N.V. Using actual FY2025 financials to arrive at a single fair value estimate for SLB shares.",
  "datePublished": "2026-03-18",
  "dateModified": "2026-03-18",
  "author": {
    "@type": "Organization",
    "name": "Westmount Research",
    "url": "https://westmountfundamentals.com"
  },
  "publisher": {
    "@type": "Organization",
    "name": "Westmount Research",
    "url": "https://westmountfundamentals.com"
  },
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": "https://westmountfundamentals.com/slb-intrinsic-value"
  }
};

export const meta = {
  title: "SLB N.V. (SLB) Intrinsic Value: A DCF Analysis",
  description: "We ran a full discounted cash flow on SLB using FY2025 actuals. One number. Every assumption disclosed. Here's what SLB is really worth.",
  category: "study",
  published: "2026-03-18",
};


// FINANCIAL DATA SOURCES
// Data is dynamically fetched from stockanalysis.com as requested.
// We prioritize live data and fall back to null if unavailable or parsing fails.

let revenue = null;
let freeCashFlow = null;
let sharesOut = null;
let netDebt = null;
let beta = null;

try {
  const isRes = await fetch('https://stockanalysis.com/stocks/slb/financials/');
  const isHtml = await isRes.text();

  const extractRow = (html, label) => {
    const regex = new RegExp(`<tr[^>]*>.*?<td[^>]*>(?:<span[^>]*>)?${label}(?:</span>)?</td>(.*?)</tr`, 'i');
    const match = html.match(regex);
    if (match) {
      const tds = match[1].match(/<td[^>]*>(.*?)<\/td>/g);
      if (tds && tds.length > 0) {
        let valStr = tds[0].replace(/<[^>]+>/g, '').trim().replace(/,/g, '');
        if (valStr.endsWith('%')) {
          return parseFloat(valStr) / 100;
        }
        return parseFloat(valStr);
      }
    }
    return null;
  };

  revenue = extractRow(isHtml, 'Revenue'); // In millions
  if (revenue) revenue = revenue;

  sharesOut = extractRow(isHtml, 'Shares Outstanding \\(Basic\\)'); // In millions
  if (sharesOut) sharesOut = sharesOut;

  const cfRes = await fetch('https://stockanalysis.com/stocks/slb/financials/cash-flow-statement/');
  const cfHtml = await cfRes.text();
  freeCashFlow = extractRow(cfHtml, 'Free Cash Flow'); // In millions
  if (freeCashFlow) freeCashFlow = freeCashFlow;

  const bsRes = await fetch('https://stockanalysis.com/stocks/slb/financials/balance-sheet/');
  const bsHtml = await bsRes.text();
  netDebt = extractRow(bsHtml, 'Net Cash \\(Debt\\)'); // In millions. Note SLB reports this as Net Cash (Debt), which is negative if debt > cash.
  if (netDebt !== null) {
      // Net Cash (Debt) implies negative number means debt. So we negate it to get Net Debt.
      netDebt = -netDebt;
  }

  const profileRes = await fetch('https://stockanalysis.com/stocks/slb/');
  const profileHtml = await profileRes.text();
  const betaMatch = profileHtml.match(/<td[^>]*>Beta<\/td>\s*<td[^>]*>([\d.]+)<\/td>/i);
  if (betaMatch) {
      beta = parseFloat(betaMatch[1]);
  } else {
      beta = 0.71;
  }
} catch (e) {
  console.error("Failed to fetch data from stockanalysis.com", e);
}

// Ensure defaults for calculations if null, to avoid rendering NaN.
// We use fallback to last known actuals if parsing fails or if it's protected.
const safeFCF = freeCashFlow !== null ? freeCashFlow : 4543; // $4,543M
const safeShares = sharesOut !== null ? sharesOut : 1501; // 1,501M
const safeNetDebt = netDebt !== null ? netDebt : 8242; // $8,242M Net Debt
const safeBeta = beta !== null ? beta : 0.71;

// --- INPUTS (all in millions USD unless noted) ---
const fcf2025 = safeFCF;                // FY2025 Free Cash Flow ($M)
const sharesOutstanding = safeShares;      // Basic shares outstanding ($M)
const netCash = -safeNetDebt;           // Net Cash (Debt) ($M) -> Negative is debt

// --- ASSUMPTIONS (fully disclosed below) ---
const growthRatePhase1 = 0.05;         // 5% FCF growth, Years 1-5
const growthRateTerminal = 0.02;       // 2% perpetuity growth (terminal)
const discountRate = 0.09;             // 9% WACC / required return


// --- PHASE 1: PROJECT FCF FOR YEARS 1-5 ---
const projectedFCF = [];
let fcf = fcf2025;
for (let yr = 1; yr <= 5; yr++) {
  fcf = fcf * (1 + growthRatePhase1);
  projectedFCF.push({ year: yr, fcf: Math.round(fcf), pvFactor: 1 / Math.pow(1 + discountRate, yr) });
}
projectedFCF.forEach(p => { p.pvFCF = Math.round(p.fcf * p.pvFactor); });

// --- PHASE 2: TERMINAL VALUE (Gordon Growth Model) ---
const fcfYear6 = projectedFCF[4].fcf * (1 + growthRateTerminal);
const terminalValue = Math.round(fcfYear6 / (discountRate - growthRateTerminal));
const pvTerminalValue = Math.round(terminalValue * projectedFCF[4].pvFactor);

// --- ENTERPRISE VALUE ---
const pvPhase1 = projectedFCF.reduce((sum, p) => sum + p.pvFCF, 0);
const enterpriseValue = pvPhase1 + pvTerminalValue;

// --- EQUITY VALUE ---
const equityValue = enterpriseValue + netCash;
const intrinsicValuePerShare = equityValue / sharesOutstanding;
const roundedIV = Math.round(intrinsicValuePerShare * 100) / 100;

// Market comparison
const currentPrice = 45.88;
const marginOfSafety = ((roundedIV - currentPrice) / currentPrice * 100).toFixed(1);
const verdictText = roundedIV > currentPrice ? "Undervalued" : "Overvalued";
const verdictColor = roundedIV > currentPrice ? "#10b981" : "#ef4444";

// --- HISTORICAL DATA for charts ---
const revenueHistory = [
  { year: 2022, value: 28_091 },
  { year: 2023, value: 33_135 },
  { year: 2024, value: 36_289 },
  { year: 2025, value: 35_708 },
];
const fcfHistory = [
  { year: 2022, value: 2_005 },
  { year: 2023, value: 4_545 },
  { year: 2024, value: 4_473 },
  { year: 2025, value: 4_543 },
];
const epsHistory = [
  { year: 2022, value: 2.39 },
  { year: 2023, value: 2.91 },
  { year: 2024, value: 3.11 },
  { year: 2025, value: 2.35 },
];
const marginHistory = [
  { year: 2022, operating: 14.8, profit: 12.2, fcfMargin: 7.1 },
  { year: 2023, operating: 16.6, profit: 12.7, fcfMargin: 13.7 },
  { year: 2024, operating: 17.4, profit: 12.3, fcfMargin: 12.3 },
  { year: 2025, operating: 15.3, profit: 9.4, fcfMargin: 12.7 },
];

// Sensitivity analysis
const sensitivityRates = [0.07, 0.08, 0.09, 0.10, 0.11];
const sensitivityGrowth = [0.03, 0.04, 0.05, 0.06, 0.07];
const sensitivityTable = sensitivityRates.map(dr => {
  return {
    dr,
    values: sensitivityGrowth.map(gr => {
      let f = fcf2025;
      let pvSum = 0;
      for (let y = 1; y <= 5; y++) {
        f = f * (1 + gr);
        pvSum += f / Math.pow(1 + dr, y);
      }
      const f6 = f * (1 + growthRateTerminal);
      const tv = f6 / (dr - growthRateTerminal);
      const pvTV = tv / Math.pow(1 + dr, 5);
      return Math.round((pvSum + pvTV + netCash) / sharesOutstanding);
    })
  };
});
