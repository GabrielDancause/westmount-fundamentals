---
import SiteLayout from "../layouts/SiteLayout.astro";

const schema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": "CSX Corporation (CSX) Intrinsic Value: A DCF Analysis",
  "description": "A transparent, step-by-step discounted cash flow valuation of CSX Corporation. Using actual FY2024 financials to arrive at a single fair value estimate for CSX shares.",
  "datePublished": "2024-03-18",
  "dateModified": "2024-03-18",
  "author": {
    "@type": "Organization",
    "name": "Westmount Research",
    "url": "https://westmountfundamentals.com"
  },
  "publisher": {
    "@type": "Organization",
    "name": "Westmount Research",
    "url": "https://westmountfundamentals.com"
  },
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": "https://westmountfundamentals.com/csx-intrinsic-value"
  }
};

export const meta = {
  title: "CSX Corporation (CSX) Intrinsic Value: A DCF Analysis",
  description: "We ran a full discounted cash flow on CSX using FY2024 actuals. One number. Every assumption disclosed. Here's what CSX is really worth.",
  category: "study",
  published: "2024-03-18",
};

import * as cheerio from "cheerio";

/* ═══════════════════════════════════════════════════════════════
   DATA FETCHING FROM STOCKANALYSIS.COM
   ═══════════════════════════════════════════════════════════════ */
const headers = { "User-Agent": "Mozilla/5.0 (Windows NT 10.0; Win64; x64)" };

async function fetchMetric(url, rowLabel, colIndex = 2) {
  try {
    const res = await fetch(url, { headers });
    if (!res.ok) return null;
    const html = await res.text();
    const $ = cheerio.load(html);
    let value = null;
    $("table tbody tr").each((i, el) => {
      const tds = $(el).find("td").map((j, e) => $(e).text().trim()).get();
      if (tds[0] === rowLabel && tds.length > colIndex) {
        value = parseFloat(tds[colIndex].replace(/,/g, ""));
      }
    });
    return value;
  } catch (err) {
    return null;
  }
}

async function fetchPrice(url) {
  try {
    const res = await fetch(url, { headers });
    if (!res.ok) return null;
    const html = await res.text();
    const $ = cheerio.load(html);
    const priceStr = $(".text-4xl.font-bold").first().text().trim();
    return priceStr ? parseFloat(priceStr.replace(/,/g, "")) : null;
  } catch (err) {
    return null;
  }
}

// URLs
const isUrl = "https://stockanalysis.com/stocks/csx/financials/";
const cfUrl = "https://stockanalysis.com/stocks/csx/financials/cash-flow-statement/";
const bsUrl = "https://stockanalysis.com/stocks/csx/financials/balance-sheet/";
const profileUrl = "https://stockanalysis.com/stocks/csx/";

// Parallel fetching
// We use colIndex = 2 to fetch the FY2024 (latest annual) column instead of TTM (colIndex = 1).
const [
  fcfFetched,
  sharesFetched,
  cashFetched,
  debtFetched,
  priceFetched,
] = await Promise.all([
  fetchMetric(cfUrl, "Free Cash Flow", 2),
  fetchMetric(isUrl, "Shares Outstanding (Diluted)", 2),
  fetchMetric(bsUrl, "Cash & Equivalents", 2),
  fetchMetric(bsUrl, "Total Debt", 2),
  fetchPrice(profileUrl),
]);

/* ═══════════════════════════════════════════════════════════════
   DCF MODEL — ALL INPUTS AND CALCULATIONS
   We use a two-stage DCF: stable growth phase (Years 1-5) then terminal value.
   ═══════════════════════════════════════════════════════════════ */

// --- INPUTS (all in millions USD unless noted) ---
// Using exact constraints: null over fake data. If fetch fails, we use null.
const fcfBase = fcfFetched !== null ? fcfFetched : null;
const sharesOutstanding = sharesFetched !== null ? sharesFetched : null;
const cashAndInvestments = cashFetched !== null ? cashFetched : null;
const totalDebt = debtFetched !== null ? debtFetched : null;
const currentPrice = priceFetched !== null ? priceFetched : null;

let netCash = null;
if (cashAndInvestments !== null && totalDebt !== null) {
  netCash = cashAndInvestments - totalDebt;
}

// --- ASSUMPTIONS (fully disclosed below) ---
const growthRatePhase1 = 0.05;         // 5% FCF growth, Years 1-5
const growthRateTerminal = 0.025;      // 2.5% perpetuity growth (terminal)
const discountRate = 0.085;            // 8.5% WACC / required return

// --- PHASE 1: PROJECT FCF FOR YEARS 1-5 ---
const projectedFCF = [];
let pvPhase1 = null;
let enterpriseValue = null;
let fcfYear6 = null;
let terminalValue = null;
let pvTerminalValue = null;

if (fcfBase !== null) {
  let fcf = fcfBase;
  for (let yr = 1; yr <= 5; yr++) {
    fcf = fcf * (1 + growthRatePhase1);
    projectedFCF.push({ year: yr, fcf: Math.round(fcf), pvFactor: 1 / Math.pow(1 + discountRate, yr) });
  }
  projectedFCF.forEach(p => { p.pvFCF = Math.round(p.fcf * p.pvFactor); });

  // --- PHASE 2: TERMINAL VALUE (Gordon Growth Model) ---
  fcfYear6 = projectedFCF[4].fcf * (1 + growthRateTerminal);
  terminalValue = Math.round(fcfYear6 / (discountRate - growthRateTerminal));
  pvTerminalValue = Math.round(terminalValue * projectedFCF[4].pvFactor);

  // --- ENTERPRISE VALUE ---
  pvPhase1 = projectedFCF.reduce((sum, p) => sum + p.pvFCF, 0);
  enterpriseValue = pvPhase1 + pvTerminalValue;
}

// --- EQUITY VALUE ---
let equityValue = null;
let intrinsicValuePerShare = null;
let roundedIV = null;
let marginOfSafety = null;
let verdictText = "N/A";
let verdictColor = "#5a6a80";

if (enterpriseValue !== null && netCash !== null && sharesOutstanding !== null && sharesOutstanding > 0) {
  equityValue = enterpriseValue + netCash;
  intrinsicValuePerShare = equityValue / sharesOutstanding;
  roundedIV = Math.round(intrinsicValuePerShare * 100) / 100;

  if (currentPrice !== null && currentPrice > 0) {
    marginOfSafety = ((roundedIV - currentPrice) / currentPrice * 100).toFixed(1);
    verdictText = roundedIV > currentPrice ? "Undervalued" : "Overvalued";
    verdictColor = roundedIV > currentPrice ? "#10b981" : "#ef4444";
  }
}

// --- HISTORICAL DATA for charts ---
// From yfinance: 2020 to 2024 (using 2021-2025 labeled indices actually mapped to 2020-2024 periods roughly or FY21-FY24). Let's use clean data from yfinance query:
const revenueHistory = [
  { year: 2021, value: 12522 },
  { year: 2022, value: 14853 },
  { year: 2023, value: 14657 },
  { year: 2024, value: 14540 },
];
const fcfHistory = [
  { year: 2021, value: 3796 },
  { year: 2022, value: 3413 },
  { year: 2023, value: 3257 },
  { year: 2024, value: 2718 },
];
const epsHistory = [
  { year: 2021, value: 1.68 },
  { year: 2022, value: 1.95 },
  { year: 2023, value: 1.85 },
  { year: 2024, value: 1.79 },
];
const marginHistory = [
  { year: 2021, operating: 45.4, profit: 30.2, fcfMargin: 30.3 },
  { year: 2022, operating: 39.0, profit: 27.7, fcfMargin: 23.0 },
  { year: 2023, operating: 37.7, profit: 25.0, fcfMargin: 22.2 },
  { year: 2024, operating: 37.2, profit: 23.9, fcfMargin: 18.7 },
];

// Sensitivity analysis
const sensitivityRates = [0.075, 0.080, 0.085, 0.090, 0.095];
const sensitivityGrowth = [0.03, 0.04, 0.05, 0.06, 0.07];
let sensitivityTable = [];

if (fcfBase !== null && netCash !== null && sharesOutstanding !== null) {
  sensitivityTable = sensitivityRates.map(dr => {
    return {
      dr,
      values: sensitivityGrowth.map(gr => {
        let f = fcfBase;
        let pvSum = 0;
        for (let y = 1; y <= 5; y++) {
          f = f * (1 + gr);
          pvSum += f / Math.pow(1 + dr, y);
        }
        const f6 = f * (1 + growthRateTerminal);
        const tv = f6 / (dr - growthRateTerminal);
        const pvTV = tv / Math.pow(1 + dr, 5);
        return Math.round((pvSum + pvTV + netCash) / sharesOutstanding);
      })
    };
  });
}
