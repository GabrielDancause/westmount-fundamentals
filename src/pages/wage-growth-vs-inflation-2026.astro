        // Setup Chart
        const ctx = document.getElementById('mainChart').getContext('2d');
        const labels = chartData.yoy['CPI'].map(d => d.date);

        // Colors
        const colors = {
            'CPI': 'rgba(239, 68, 68, 0.8)', // Red
            'Total Private': 'rgba(16, 185, 129, 0.8)', // Green
            'Median Income': 'rgba(245, 158, 11, 0.8)', // Orange
            'Bachelors Degree or Higher': 'rgba(59, 130, 246, 0.8)' // Blue
        };

        const datasets = [
            {
                label: 'CPI Inflation (YoY)',
                data: chartData.yoy['CPI'].map(d => d.yoy),
                borderColor: colors['CPI'],
                backgroundColor: 'transparent',
                borderWidth: 2,
                tension: 0.4,
                borderDash: [5, 5]
            },
            {
                label: 'Nominal Wage Growth: Total Private',
                data: chartData.real['Total Private'].map(d => d.nominalYoy),
                borderColor: colors['Total Private'],
                backgroundColor: 'transparent',
                borderWidth: 2,
                tension: 0.4
            },
            {
                label: 'Real Wage Growth: Total Private',
                data: chartData.real['Total Private'].map(d => d.realYoy),
                borderColor: 'rgba(74, 143, 231, 1)', // Accent
                backgroundColor: 'rgba(74, 143, 231, 0.1)',
                borderWidth: 3,
                fill: true,
                tension: 0.4
            }
        ];

        new Chart(ctx, {
            type: 'line',
            data: { labels, datasets },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                interaction: {
                    mode: 'index',
                    intersect: false,
                },
                plugins: {
                    legend: {
                        labels: { color: '#e2e8f0', font: { family: 'Inter' } }
                    },
                    tooltip: {
                        backgroundColor: 'rgba(10, 16, 32, 0.9)',
                        titleColor: '#e2e8f0',
                        bodyColor: '#e2e8f0',
                        borderColor: '#152040',
                        borderWidth: 1,
                        padding: 10,
                        callbacks: {
                            label: function(context) {
                                return context.dataset.label + ': ' + context.parsed.y.toFixed(2) + '%';
                            }
                        }
                    }
                },
                scales: {
                    x: {
                        grid: { color: '#152040' },
                        ticks: { color: '#94a3b8', maxTicksLimit: 12 }
                    },
                    y: {
                        grid: { color: '#152040' },
                        ticks: {
                            color: '#94a3b8',
                            callback: function(value) { return value + '%'; }
                        }
                    }
                }
            }
        });

        // Setup Table Data
        let tableData = [];
        for (const [category, data] of Object.entries(chartData.real)) {
            data.forEach(item => {
                tableData.push({
                    date: item.date,
                    category: category,
                    nominal: item.nominalYoy,
                    cpi: item.cpiYoy,
                    real: item.realYoy
                });
            });
        }

        // Sort initial data by date desc
        tableData.sort((a, b) => new Date(b.date) - new Date(a.date));

        const tbody = document.getElementById('tableBody');
        const searchInput = document.getElementById('searchInput');
        const categoryFilter = document.getElementById('categoryFilter');

        function renderTable(data) {
            tbody.innerHTML = '';
            data.forEach(row => {
                const tr = document.createElement('tr');
                const realClass = row.real >= 0 ? 'positive-cell' : 'negative-cell';
                tr.innerHTML = `
                    <td>${row.date}</td>
                    <td>${row.category}</td>
                    <td>${row.nominal.toFixed(2)}%</td>
                    <td>${row.cpi.toFixed(2)}%</td>
                    <td class="${realClass}">${row.real > 0 ? '+' : ''}${row.real.toFixed(2)}%</td>
                `;
                tbody.appendChild(tr);
            });
        }

        function filterData() {
            const search = searchInput.value.toLowerCase();
            const category = categoryFilter.value;

            const filtered = tableData.filter(row => {
                const matchesSearch = row.date.toLowerCase().includes(search) || row.category.toLowerCase().includes(search);
                const matchesCategory = category === 'All' || row.category === category;
                return matchesSearch && matchesCategory;
            });
            renderTable(filtered);
        }

        searchInput.addEventListener('input', filterData);
        categoryFilter.addEventListener('change', filterData);

        // Sorting logic
        let currentSort = { col: 'date', dir: 'desc' };
        document.querySelectorAll('th').forEach(th => {
            th.addEventListener('click', () => {
                const col = th.dataset.sort;
                if (currentSort.col === col) {
                    currentSort.dir = currentSort.dir === 'asc' ? 'desc' : 'asc';
                } else {
                    currentSort = { col, dir: 'desc' };
                }

                tableData.sort((a, b) => {
                    let valA = a[col];
                    let valB = b[col];

                    if (col === 'date' || col === 'category') {
                        valA = valA.toString().toLowerCase();
                        valB = valB.toString().toLowerCase();
                        if (valA < valB) return currentSort.dir === 'asc' ? -1 : 1;
                        if (valA > valB) return currentSort.dir === 'asc' ? 1 : -1;
                        return 0;
                    } else {
                        return currentSort.dir === 'asc' ? valA - valB : valB - valA;
                    }
                });
                filterData(); // re-render with current filters
            });
        });

        // Initial render
        renderTable(tableData);
  </script>
