---
import SiteLayout from "../layouts/SiteLayout.astro";
import * as cheerio from 'cheerio';

export const meta = {
  title: "Prologis (PLD) Intrinsic Value: A DCF Analysis",
  description: "A transparent, step-by-step discounted cash flow valuation of Prologis Inc. Using latest financials to arrive at a single fair value estimate for PLD shares.",
  category: "study",
  published: "2026-03-18",
};

const schema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": "Prologis (PLD) Intrinsic Value: A DCF Analysis",
  "description": "A transparent, step-by-step discounted cash flow valuation of Prologis Inc. Using latest financials to arrive at a single fair value estimate for PLD shares.",
  "datePublished": "2026-03-18",
  "dateModified": "2026-03-18",
  "author": {
    "@type": "Organization",
    "name": "Westmount Research",
    "url": "https://westmountfundamentals.com"
  },
  "publisher": {
    "@type": "Organization",
    "name": "Westmount Research",
    "url": "https://westmountfundamentals.com"
  },
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": "https://westmountfundamentals.com/prologis-intrinsic-value"
  }
};

const parseNum = (str) => {
  if (!str || str === '-') return null;
  return parseFloat(str.replace(/,/g, ''));
};

let currentPrice = null;
let beta = null;
let revHist = [];
let fcfHist = [];
let ocfHist = [];
let epsHist = [];
let sharesHist = [];
let margins = [];
let cash = 0;
let debt = 0;
let years = [];

try {
  const [finRes, cfsRes, bsRes, tickerRes] = await Promise.all([
    fetch('https://stockanalysis.com/stocks/pld/financials/', { headers: { 'User-Agent': 'Mozilla/5.0' }}),
    fetch('https://stockanalysis.com/stocks/pld/financials/cash-flow-statement/', { headers: { 'User-Agent': 'Mozilla/5.0' }}),
    fetch('https://stockanalysis.com/stocks/pld/financials/balance-sheet/', { headers: { 'User-Agent': 'Mozilla/5.0' }}),
    fetch('https://stockanalysis.com/stocks/pld/', { headers: { 'User-Agent': 'Mozilla/5.0' }}),
  ]);

  const [finHtml, cfsHtml, bsHtml, tickerHtml] = await Promise.all([
    finRes.text(), cfsRes.text(), bsRes.text(), tickerRes.text()
  ]);

  const $fin = cheerio.load(finHtml);
  const $cfs = cheerio.load(cfsHtml);
  const $bs = cheerio.load(bsHtml);
  const $ticker = cheerio.load(tickerHtml);

  const extractRow = ($, rowName) => {
    let rowData = null;
    $('table tbody tr').each((i, el) => {
      const title = $(el).find('td').first().text().trim();
      if (title === rowName) {
        rowData = [];
        $(el).find('td').slice(1).each((j, td) => {
          rowData.push($(td).text().trim());
        });
      }
    });
    return rowData;
  };

  $fin('table thead tr th').slice(1, 6).each((i, el) => {
    years.push($fin(el).text().trim());
  });
  years.reverse();

  const revData = extractRow($fin, 'Revenue');
  const epsData = extractRow($fin, 'EPS (Diluted)');
  const sharesData = extractRow($fin, 'Shares Outstanding (Diluted)');
  const opMarginData = extractRow($fin, 'Operating Margin');
  const profitMarginData = extractRow($fin, 'Profit Margin');
  const fcfMarginData = extractRow($fin, 'FCF Margin');

  const fcfData = extractRow($cfs, 'Free Cash Flow');
  const ocfData = extractRow($cfs, 'Operating Cash Flow');

  const cashData = extractRow($bs, 'Cash & Equivalents');
  const debtData = extractRow($bs, 'Total Debt');

  if (revData) revHist = revData.slice(0, 5).reverse().map(parseNum);
  if (epsData) epsHist = epsData.slice(0, 5).reverse().map(parseNum);
  if (sharesData) sharesHist = sharesData.slice(0, 5).reverse().map(parseNum);
  if (fcfData) fcfHist = fcfData.slice(0, 5).reverse().map(parseNum);
  if (ocfData) ocfHist = ocfData.slice(0, 5).reverse().map(parseNum);

  if (opMarginData && profitMarginData && fcfMarginData) {
    const op = opMarginData.slice(0, 5).reverse().map(parseNum);
    const pr = profitMarginData.slice(0, 5).reverse().map(parseNum);
    const fc = fcfMarginData.slice(0, 5).reverse().map(parseNum);
    for (let i = 0; i < 5; i++) {
      margins.push({ year: years[i], operating: op[i], profit: pr[i], fcfMargin: fc[i] });
    }
  }

  cash = cashData ? (parseNum(cashData[0]) || 0) : 0;
  debt = debtData ? (parseNum(debtData[0]) || 0) : 0;

  currentPrice = parseNum($ticker('.text-4xl.font-bold').first().text().trim());

  $ticker('td').each((i, el) => {
    if ($ticker(el).text().includes('Beta')) {
      beta = parseNum($ticker(el).next().text().trim());
    }
  });

} catch (e) {
  console.error("Error fetching data:", e);
}

// ═══════════════════════════════════════════════════════════════
// DCF MODEL — CALCULATIONS
// ═══════════════════════════════════════════════════════════════

const latestFCF = fcfHist.length > 0 ? fcfHist[fcfHist.length - 1] : 0;
const latestOCF = ocfHist.length > 0 ? ocfHist[ocfHist.length - 1] : 0;
const latestShares = sharesHist.length > 0 ? sharesHist[sharesHist.length - 1] : 1;
const latestRev = revHist.length > 0 ? revHist[revHist.length - 1] : 0;
const latestEPS = epsHist.length > 0 ? epsHist[epsHist.length - 1] : 0;
const latestOpMargin = margins.length > 0 ? margins[margins.length - 1].operating : 0;

const netCash = cash - debt;

// Calculate Base Cash Flow
// Prologis is a REIT with heavy capex resulting in volatile FCF. However, actual FCF was positive in recent years. We'll use actual FCF, or proxy with OCF if needed.
const baseCashFlow = latestFCF !== null && latestFCF > 0 ? latestFCF : latestOCF;
const baseCashFlowLabel = latestFCF !== null && latestFCF > 0 ? 'Free Cash Flow' : 'Operating Cash Flow (Proxy)';

// --- MATHEMATHICAL DERIVATIONS ---
const riskFreeRate = 0.0418; // 10Y Treasury
const equityRiskPremium = 0.0418; // Derived ERP equal to Risk Free Rate (as per conservative baseline)
const discountRate = riskFreeRate + (beta !== null ? beta * equityRiskPremium : 1.0 * equityRiskPremium);

// Historical FCF CAGR (Year 1 to Year 5)
let growthRatePhase1 = 0;
if (fcfHist.length >= 5 && fcfHist[0] > 0 && fcfHist[4] > 0) {
    growthRatePhase1 = Math.pow(fcfHist[4] / fcfHist[0], 1/4) - 1;
} else if (ocfHist.length >= 5 && ocfHist[0] > 0 && ocfHist[4] > 0) {
    growthRatePhase1 = Math.pow(ocfHist[4] / ocfHist[0], 1/4) - 1;
} else if (revHist.length >= 5 && revHist[0] > 0 && revHist[4] > 0) {
    growthRatePhase1 = Math.pow(revHist[4] / revHist[0], 1/4) - 1;
} else {
    growthRatePhase1 = 0.05; // Fallback math
}
// Cap the growth rate to reasonable bounds (0% to 15%)
growthRatePhase1 = Math.max(0, Math.min(growthRatePhase1, 0.15));

// Terminal Growth Rate mathematically tied to GDP proxy (e.g. half of risk-free rate, or risk-free rate minus a spread)
const growthRateTerminal = Math.min(0.025, riskFreeRate * 0.6); // Cap at 2.5%

// --- PHASE 1: PROJECT FCF FOR YEARS 1-5 ---
const projectedFCF = [];
let fcf = baseCashFlow;
for (let yr = 1; yr <= 5; yr++) {
  fcf = fcf * (1 + growthRatePhase1);
  projectedFCF.push({ year: yr, fcf: Math.round(fcf), pvFactor: 1 / Math.pow(1 + discountRate, yr) });
}
projectedFCF.forEach(p => { p.pvFCF = Math.round(p.fcf * p.pvFactor); });

// --- PHASE 2: TERMINAL VALUE ---
const fcfYear6 = projectedFCF[4].fcf * (1 + growthRateTerminal);
const terminalValue = Math.round(fcfYear6 / (discountRate - growthRateTerminal));
const pvTerminalValue = Math.round(terminalValue * projectedFCF[4].pvFactor);

// --- ENTERPRISE VALUE ---
const pvPhase1 = projectedFCF.reduce((sum, p) => sum + p.pvFCF, 0);
const enterpriseValue = pvPhase1 + pvTerminalValue;

// --- EQUITY VALUE ---
const equityValue = enterpriseValue + netCash;
const intrinsicValuePerShare = latestShares > 0 ? (equityValue / latestShares) : 0;
const roundedIV = Math.round(intrinsicValuePerShare * 100) / 100;

// Market comparison
const marginOfSafety = currentPrice > 0 ? (((roundedIV - currentPrice) / currentPrice) * 100).toFixed(1) : 0;
const verdictText = roundedIV > currentPrice ? "Undervalued" : "Overvalued";
const verdictColor = roundedIV > currentPrice ? "#10b981" : "#ef4444";

// Sensitivity analysis
const drBase = Math.round(discountRate * 100) / 100;
const grBase = Math.round(growthRatePhase1 * 100) / 100;
const sensitivityRates = [drBase - 0.02, drBase - 0.01, drBase, drBase + 0.01, drBase + 0.02];
const sensitivityGrowth = [Math.max(0, grBase - 0.02), Math.max(0, grBase - 0.01), grBase, grBase + 0.01, grBase + 0.02];

const sensitivityTable = sensitivityRates.map(dr => {
  return {
    dr,
    values: sensitivityGrowth.map(gr => {
      let f = baseCashFlow;
      let pvSum = 0;
      for (let y = 1; y <= 5; y++) {
        f = f * (1 + gr);
        pvSum += f / Math.pow(1 + dr, y);
      }
      const f6 = f * (1 + growthRateTerminal);
      const tv = f6 / (dr - growthRateTerminal);
      const pvTV = tv / Math.pow(1 + dr, 5);
      return Math.round((pvSum + pvTV + netCash) / latestShares);
    })
  };
});
