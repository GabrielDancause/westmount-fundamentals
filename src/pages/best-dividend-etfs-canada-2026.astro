        // Initialize App
        let currentSort = { column: 'yield', asc: false };

        function formatNumber(num, decimals = 2) {
            if (num === null || num === undefined) return 'N/A';
            return Number(num).toFixed(decimals);
        }

        function initStats() {
            const vdy = etfData.find(e => e.symbol === 'VDY');
            const sortedByYield = [...etfData].sort((a,b) => (b.yield || 0) - (a.yield || 0));
            const sortedByReturn = [...etfData].sort((a,b) => (b.fiveYearReturn || 0) - (a.fiveYearReturn || 0));

            const highestYield = sortedByYield[0];
            const bestReturn = sortedByReturn[0];

            const grid = document.getElementById('statsGrid');
            grid.innerHTML = `
                <div class="stat-card">
                    <div class="stat-value">${vdy ? formatNumber(vdy.yield) + '%' : 'N/A'}</div>
                    <div class="stat-label">VDY Dividend Yield</div>
                </div>
                <div class="stat-card">
                    <div class="stat-value">${highestYield ? highestYield.symbol : 'N/A'}</div>
                    <div class="stat-label">Highest Yield ETF (${highestYield ? formatNumber(highestYield.yield)+'%' : ''})</div>
                </div>
                <div class="stat-card">
                    <div class="stat-value">${bestReturn ? bestReturn.symbol : 'N/A'}</div>
                    <div class="stat-label">Best 5Y Return (${bestReturn ? formatNumber(bestReturn.fiveYearReturn)+'%' : ''})</div>
                </div>
            `;
        }

        function renderTable(data) {
            const tbody = document.getElementById('tableBody');
            tbody.innerHTML = '';

            data.forEach(etf => {
                let topH = 'N/A';
                if (etf.topHoldings && etf.topHoldings.length >= 3) {
                    topH = etf.topHoldings.slice(0,3).map(h => h.symbol.replace('.TO', '')).join(', ');
                }

                const tr = document.createElement('tr');
                tr.innerHTML = `
                    <td>
                        <span class="symbol">${etf.symbol}</span>
                        <span class="name">${etf.name}</span>
                    </td>
                    <td>$${formatNumber(etf.price)}</td>
                    <td class="positive">${formatNumber(etf.yield)}%</td>
                    <td>${formatNumber(etf.expenseRatio)}%</td>
                    <td class="${etf.fiveYearReturn >= 0 ? 'positive' : 'negative'}">${etf.fiveYearReturn > 0 ? '+' : ''}${formatNumber(etf.fiveYearReturn)}%</td>
                    <td style="font-size:0.85rem; color:var(--text-muted);">${topH}</td>
                `;
                tbody.appendChild(tr);
            });
        }

        function filterAndSortData() {
            const term = document.getElementById('searchInput').value.toLowerCase();
            let filtered = etfData.filter(e =>
                e.symbol.toLowerCase().includes(term) ||
                e.name.toLowerCase().includes(term)
            );

            filtered.sort((a, b) => {
                let valA = a[currentSort.column];
                let valB = b[currentSort.column];

                if (valA === null) valA = -999999;
                if (valB === null) valB = -999999;

                if (typeof valA === 'string') {
                    return currentSort.asc ? valA.localeCompare(valB) : valB.localeCompare(valA);
                } else {
                    return currentSort.asc ? valA - valB : valB - valA;
                }
            });

            renderTable(filtered);
        }

        function initSortListeners() {
            document.querySelectorAll('th[data-sort]').forEach(th => {
                th.addEventListener('click', () => {
                    const col = th.getAttribute('data-sort');
                    if (currentSort.column === col) {
                        currentSort.asc = !currentSort.asc;
                    } else {
                        currentSort.column = col;
                        currentSort.asc = false;
                    }
                    filterAndSortData();
                });
            });
            document.getElementById('searchInput').addEventListener('input', filterAndSortData);
        }

        function initChart() {
            const ctx = document.getElementById('returnChart').getContext('2d');

            // Rebase chart data to 100 for easy comparison if they have enough data
            const datasets = [];
            const colors = ['#4a8fe7', '#10b981', '#f59e0b', '#ef4444', '#8b5cf6', '#06b6d4'];

            // Assume VDY chartData has full date range as base
            let labels = [];
            const vdy = etfData.find(e => e.symbol === 'VDY');
            if (vdy && vdy.chartData) {
                labels = vdy.chartData.map(d => new Date(d.date).toLocaleDateString(undefined, {month:'short', year:'2-digit'}));
            }

            etfData.forEach((etf, i) => {
                if (etf.chartData && etf.chartData.length > 0) {
                    const firstPrice = etf.chartData[0].close;
                    const data = etf.chartData.map(d => (d.close / firstPrice) * 10000); // 10k growth

                    datasets.push({
                        label: etf.symbol,
                        data: data,
                        borderColor: colors[i % colors.length],
                        backgroundColor: 'transparent',
                        borderWidth: 2,
                        tension: 0.1,
                        pointRadius: 0,
                        pointHoverRadius: 5
                    });
                }
            });

            new Chart(ctx, {
                type: 'line',
                data: { labels, datasets },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    interaction: {
                        mode: 'index',
                        intersect: false,
                    },
                    plugins: {
                        legend: { labels: { color: '#94a3b8' } },
                        tooltip: {
                            callbacks: {
                                label: function(context) {
                                    let label = context.dataset.label || '';
                                    if (label) {
                                        label += ': ';
                                    }
                                    if (context.parsed.y !== null) {
                                        label += new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD' }).format(context.parsed.y);
                                    }
                                    return label;
                                }
                            }
                        }
                    },
                    scales: {
                        x: { grid: { color: '#152040' }, ticks: { color: '#94a3b8', maxTicksLimit: 12 } },
                        y: {
                            grid: { color: '#152040' },
                            ticks: {
                                color: '#94a3b8',
                                callback: function(value) {
                                    return '$' + value.toLocaleString();
                                }
                            }
                        }
                    }
                }
            });
        }

        // Run
        initStats();
        initSortListeners();
        filterAndSortData();
        initChart();
  </script>

  
