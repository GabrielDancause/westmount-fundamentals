---
import SiteLayout from "../layouts/SiteLayout.astro";

// JSON-LD Schema
const schema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": "Union Pacific (UNP) Intrinsic Value: A DCF Analysis",
  "description": "We ran a full discounted cash flow on Union Pacific Corporation using FY2025 actuals. One number. Every assumption disclosed.",
  "image": "https://westmountfundamentals.com/images/unp-og.jpg",
  "datePublished": "2026-03-18",
  "dateModified": "2026-03-18",
  "author": {
    "@type": "Organization",
    "name": "Westmount Research",
    "url": "https://westmountfundamentals.com"
  },
  "publisher": {
    "@type": "Organization",
    "name": "Westmount Research",
    "url": "https://westmountfundamentals.com"
  },
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": "https://westmountfundamentals.com/union-pacific-intrinsic-value"
  }
};

export const meta = {
  title: "Union Pacific (UNP) Intrinsic Value: A DCF Analysis",
  description: "We ran a full discounted cash flow on Union Pacific Corporation using FY2025 actuals. One number. Every assumption disclosed.",
  category: "study",
  published: "2026-03-18",
};

/* ═══════════════════════════════════════════════════════════════
   DCF MODEL — ALL INPUTS AND CALCULATIONS
   Every number is sourced from Union Pacific's FY2025 10-K.
   We use a two-stage DCF: steady-growth phase (Years 1-5) then terminal value.
   ═══════════════════════════════════════════════════════════════ */

// --- INPUTS (all in millions USD unless noted) ---
const fcf2025 = 5499;                  // FY2025 Free Cash Flow ($M)
const sharesOutstanding = 593;          // Basic shares outstanding ($M) — FY2025
const cashAndInvestments = 1516;        // Cash + short-term investments ($M)
const totalDebt = 32822;               // Total debt ($M)
const netCash = cashAndInvestments - totalDebt; // -$31,306M

// --- ASSUMPTIONS (fully disclosed below) ---
const growthRatePhase1 = 0.05;         // 5% FCF growth, Years 1-5
const growthRateTerminal = 0.025;      // 2.5% perpetuity growth (terminal)
const discountRate = 0.08;             // 8% WACC / required return

// --- PHASE 1: PROJECT FCF FOR YEARS 1-5 ---
const projectedFCF = [];
let fcf = fcf2025;
for (let yr = 1; yr <= 5; yr++) {
  fcf = fcf * (1 + growthRatePhase1);
  projectedFCF.push({ year: yr, fcf: Math.round(fcf), pvFactor: 1 / Math.pow(1 + discountRate, yr) });
}
projectedFCF.forEach(p => { p.pvFCF = Math.round(p.fcf * p.pvFactor); });

// --- PHASE 2: TERMINAL VALUE (Gordon Growth Model) ---
const fcfYear6 = projectedFCF[4].fcf * (1 + growthRateTerminal);
const terminalValue = Math.round(fcfYear6 / (discountRate - growthRateTerminal));
const pvTerminalValue = Math.round(terminalValue * projectedFCF[4].pvFactor);

// --- ENTERPRISE VALUE ---
const pvPhase1 = projectedFCF.reduce((sum, p) => sum + p.pvFCF, 0);
const enterpriseValue = pvPhase1 + pvTerminalValue;

// --- EQUITY VALUE ---
const equityValue = enterpriseValue + netCash;
const intrinsicValuePerShare = equityValue / sharesOutstanding;
const roundedIV = Math.round(intrinsicValuePerShare * 100) / 100;

// Market comparison
const currentPrice = 238.12;
const marginOfSafety = ((roundedIV - currentPrice) / currentPrice * 100).toFixed(1);
const verdictText = roundedIV > currentPrice ? "Undervalued" : "Overvalued";
const verdictColor = roundedIV > currentPrice ? "#10b981" : "#ef4444";

// --- HISTORICAL DATA for charts ---
const revenueHistory = [
  { year: 2021, value: 21804 },
  { year: 2022, value: 24875 },
  { year: 2023, value: 24119 },
  { year: 2024, value: 24250 },
  { year: 2025, value: 24510 },
];
const fcfHistory = [
  { year: 2021, value: 6010 },
  { year: 2022, value: 5742 },
  { year: 2023, value: 4773 },
  { year: 2024, value: 5894 },
  { year: 2025, value: 5499 },
];
const epsHistory = [
  { year: 2021, value: 9.95 },
  { year: 2022, value: 11.21 },
  { year: 2023, value: 10.45 },
  { year: 2024, value: 11.09 },
  { year: 2025, value: 11.98 },
];
const marginHistory = [
  { year: 2021, operating: 42.6, profit: 29.9, fcfMargin: 27.6 },
  { year: 2022, operating: 39.9, profit: 28.1, fcfMargin: 23.1 },
  { year: 2023, operating: 37.7, profit: 26.4, fcfMargin: 19.8 },
  { year: 2024, operating: 40.1, profit: 27.8, fcfMargin: 24.3 },
  { year: 2025, operating: 40.2, profit: 29.1, fcfMargin: 22.4 },
];

// Sensitivity analysis
const sensitivityRates = [0.06, 0.07, 0.08, 0.09, 0.10];
const sensitivityGrowth = [0.03, 0.04, 0.05, 0.06, 0.07];
const sensitivityTable = sensitivityRates.map(dr => {
  return {
    dr,
    values: sensitivityGrowth.map(gr => {
      let f = fcf2025;
      let pvSum = 0;
      for (let y = 1; y <= 5; y++) {
        f = f * (1 + gr);
        pvSum += f / Math.pow(1 + dr, y);
      }
      const f6 = f * (1 + growthRateTerminal);
      const tv = f6 / (dr - growthRateTerminal);
      const pvTV = tv / Math.pow(1 + dr, 5);
      return Math.round((pvSum + pvTV + netCash) / sharesOutstanding);
    })
  };
});
