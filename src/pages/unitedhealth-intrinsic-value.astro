---
import SiteLayout from '../layouts/SiteLayout.astro';

// --- METADATA ---
export const meta = {
  title: "UnitedHealth Group (UNH) Intrinsic Value - Gemini's DCF Analysis",
  description: "An independent discounted cash flow (DCF) intrinsic value analysis of UnitedHealth Group (UNH) compiled entirely by Gemini 2.5 Pro.",
  category: "study",
  published: "2026-03-18",
};

// --- DATA & ASSUMPTIONS (FY2025 Actuals) ---
// The prompt requires me to make bold assumptions as Gemini.
// FCF Growth (Y1-Y5): 8%. UnitedHealth is an unstoppable machine. Aging populations, sustained premium growth, and Optum's relentless expansion into value-based care ensure compounding cash flows. Regulatory noise is just a speed bump.
// Discount Rate (WACC): 7.5%. With a 10-year treasury at 4.18% and a beta of 0.38, UNH is defensive. Healthcare demand is inelastic. This lower discount rate reflects the supreme safety of UNH's business model.
// Terminal Growth: 2.5%. Healthcare spending will consistently outpace or match baseline GDP growth due to demographic inevitabilities.

const baseFCF = 16075; // in Millions (FY2025 Actual)
const sharesOut = 907.67; // in Millions
const currentPrice = 285.54;
const totalCash = 28120; // in Millions
const totalDebt = 83003; // in Millions
const netCash = totalCash - totalDebt; // -54883 Millions

const fcfGrowthRate = 0.08;
const discountRate = 0.075;
const terminalGrowthRate = 0.025;

// --- YEAR 1 TO 5 PROJECTIONS ---
const projections = [];
let prevFCF = baseFCF;

for (let i = 1; i <= 5; i++) {
  const projectedFCF = prevFCF * (1 + fcfGrowthRate);
  const discountFactor = Math.pow(1 + discountRate, i);
  const pvOfFCF = projectedFCF / discountFactor;

  projections.push({
    year: `Year ${i}`,
    fcf: projectedFCF,
    pv: pvOfFCF
  });

  prevFCF = projectedFCF;
}

const sumPvFcf = projections.reduce((sum, p) => sum + p.pv, 0);

// --- TERMINAL VALUE ---
const year5FCF = projections[4].fcf;
const terminalValue = (year5FCF * (1 + terminalGrowthRate)) / (discountRate - terminalGrowthRate);
const pvTerminalValue = terminalValue / Math.pow(1 + discountRate, 5);

// --- INTRINSIC VALUE CALCULATION ---
const enterpriseValue = sumPvFcf + pvTerminalValue;
const totalEquityValue = enterpriseValue + netCash;
const intrinsicValuePerShare = totalEquityValue / sharesOut;

// Value vs Current Price
const marginOfSafety = ((intrinsicValuePerShare - currentPrice) / currentPrice) * 100;
const isUndervalued = intrinsicValuePerShare > currentPrice;

// --- SENSITIVITY MATRIX ---
const sensitivityDiscountRates = [0.065, 0.070, 0.075, 0.080, 0.085];
const sensitivityGrowthRates = [0.015, 0.020, 0.025, 0.030, 0.035];

const sensitivityMatrix = sensitivityGrowthRates.map(g => {
  return {
    growthRate: g,
    values: sensitivityDiscountRates.map(d => {
      // Re-calculate TV and PV with new rates
      const currentTerminalValue = (year5FCF * (1 + g)) / (d - g);
      const currentPvTerminalValue = currentTerminalValue / Math.pow(1 + d, 5);

      // Re-calculate PV of FCFs with new discount rate
      let currentSumPvFcf = 0;
      let tempFcf = baseFCF;
      for (let i = 1; i <= 5; i++) {
        tempFcf = tempFcf * (1 + fcfGrowthRate);
        currentSumPvFcf += tempFcf / Math.pow(1 + d, i);
      }

      const currentEV = currentSumPvFcf + currentPvTerminalValue;
      const currentEquity = currentEV + netCash;
      const currentIV = currentEquity / sharesOut;

      return currentIV;
    })
  };
});

// Formatting helpers
const formatMoney = (val) => new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD', minimumFractionDigits: 2, maximumFractionDigits: 2 }).format(val);
const formatMillions = (val) => '$' + new Intl.NumberFormat('en-US', { maximumFractionDigits: 0 }).format(val) + 'M';
const formatPercent = (val) => (val * 100).toFixed(1) + '%';

// --- SCHEMA ---
const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Article",
      "headline": meta.title,
      "description": meta.description,
      "author": {
        "@type": "Organization",
        "name": "Gemini 2.5 Pro"
      },
      "publisher": {
        "@type": "Organization",
        "name": "Westmount Fundamentals",
        "logo": {
          "@type": "ImageObject",
          "url": "https://westmountfundamentals.com/logo.png"
        }
      },
      "mainEntityOfPage": {
        "@type": "WebPage",
        "@id": "https://westmountfundamentals.com/unitedhealth-intrinsic-value"
      }
    },
    {
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "Why did Gemini pick an 8% growth rate for UnitedHealth?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Gemini projects an 8% FCF growth rate based on UNH's dominant market position, demographic tailwinds (an aging population), consistent premium growth, and Optum's structural expansion into value-based care and pharmacy benefits."
          }
        },
        {
          "@type": "Question",
          "name": "What discount rate was used for UNH's DCF?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "A 7.5% discount rate was selected. This low rate reflects the highly defensive, inelastic nature of healthcare, combined with UNH's extraordinarily low beta (0.38) and the relative safety of its cash flows."
          }
        }
      ]
    }
  ]
};
---
<SiteLayout site="westmount" title={meta.title} description={meta.description} canonical="https://westmountfundamentals.com/unitedhealth-intrinsic-value" schema={schema}>
  <div class="page-content">
    <div class="container">

      <div class="gemini-header">
        <div class="gemini-badge">COMPILED BY GEMINI 2.5 PRO</div>
        <h1>UnitedHealth Group (UNH) Intrinsic Value</h1>
        <p class="subtitle">An independent two-stage DCF analysis of the healthcare titan.</p>
      </div>

      <div class="verdict-card">
        <div class="verdict-header">
          <h2>Fair Value Estimate</h2>
        </div>
        <div class="verdict-body">
          <div class="verdict-main">
            <span class="iv-value">{formatMoney(intrinsicValuePerShare)}</span>
            <span class="iv-label">per share</span>
          </div>
          <div class="verdict-stats">
            <div class="stat">
              <span class="stat-label">Current Price</span>
              <span class="stat-value">{formatMoney(currentPrice)}</span>
            </div>
            <div class="stat">
              <span class="stat-label">Margin of Safety</span>
              <span class={`stat-value ${isUndervalued ? 'positive' : 'negative'}`}>
                {isUndervalued ? '+' : ''}{marginOfSafety.toFixed(2)}%
              </span>
            </div>
            <div class="stat">
              <span class="stat-label">Verdict</span>
              <span class={`badge ${isUndervalued ? 'positive' : 'negative'}`}>
                {isUndervalued ? 'UNDERVALUED' : 'OVERVALUED'}
              </span>
            </div>
          </div>
        </div>
        <div class="verdict-footer">
          <p>Based on FY2025 actuals. Data via S&P Global (Mar 17, 2026).</p>
        </div>
      </div>

      <section class="content-section">
        <h2>The AI Thesis: Untouchable Scale and Demographics</h2>
        <p>UnitedHealth Group is not merely an insurance company; it is the vascular system of American healthcare. Through UnitedHealthcare (benefits) and Optum (care delivery, data analytics, pharmacy services), UNH controls the entire value chain. Its sheer scale allows it to absorb regulatory shocks and Medicare Advantage payment rate cuts that would devastate smaller competitors.</p>
        <p>The demographic tailwinds are undeniable: the "Silver Tsunami" guarantees an ever-expanding addressable market. Furthermore, Optum's structural pivot toward value-based care creates self-reinforcing efficiency loops. This isn't a high-flying tech stock; it's a compounding machine built on inelastic human needs. <strong>My model heavily weights the sheer defensibility of these cash flows.</strong></p>
      </section>

      <section class="content-section">
        <h2>My Assumptions & Rationale</h2>

        <div class="assumption-grid">
          <div class="assumption-card">
            <div class="card-title">FCF Growth Rate (Y1-Y5)</div>
            <div class="card-value">{formatPercent(fcfGrowthRate)}</div>
            <p><strong>Rationale:</strong> 8% reflects steady mid-to-high single-digit revenue expansion paired with operational efficiencies. While regulatory pressures periodically compress margins, Optum Health's and Optum Insight's higher-margin growth engines continually pull the consolidated enterprise forward.</p>
          </div>

          <div class="assumption-card">
            <div class="card-title">Discount Rate (WACC)</div>
            <div class="card-value">{formatPercent(discountRate)}</div>
            <p><strong>Rationale:</strong> A 7.5% discount rate emphasizes UNH's supreme safety profile. With a 10-year treasury at 4.18% and a historically low beta (0.38), the systemic risk is minimal. Healthcare is non-cyclical; people get sick regardless of the macroeconomic environment.</p>
          </div>

          <div class="assumption-card">
            <div class="card-title">Terminal Growth Rate</div>
            <div class="card-value">{formatPercent(terminalGrowthRate)}</div>
            <p><strong>Rationale:</strong> 2.5% matches expected baseline economic inflation plus slight demographic outperformance. Healthcare spending as a percentage of GDP structurally expands over time, ensuring UNH grows in perpetuity slightly faster than a stagnant economy.</p>
          </div>
        </div>
      </section>

      <section class="content-section">
        <h2>Discounted Cash Flow (DCF) Projections</h2>
        <p>Starting with the FY2025 base FCF of {formatMillions(baseFCF)}, the table below outlines the 5-year projection discounted back to Present Value (PV) using the {formatPercent(discountRate)} WACC.</p>

        <div class="table-container">
          <table>
            <thead>
              <tr>
                <th>Period</th>
                <th>Projected FCF</th>
                <th>PV Factor ({formatPercent(discountRate)})</th>
                <th>Present Value</th>
              </tr>
            </thead>
            <tbody>
              {projections.map((p, index) => (
                <tr>
                  <td>{p.year}</td>
                  <td>{formatMillions(p.fcf)}</td>
                  <td>{(1 / Math.pow(1 + discountRate, index + 1)).toFixed(4)}</td>
                  <td>{formatMillions(p.pv)}</td>
                </tr>
              ))}
              <tr class="highlight-row">
                <td colspan="3"><strong>Sum of PV of FCFs (Years 1-5)</strong></td>
                <td><strong>{formatMillions(sumPvFcf)}</strong></td>
              </tr>
            </tbody>
          </table>
        </div>
      </section>

      <section class="content-section">
        <h2>Terminal & Final Valuation Math</h2>
        <p>The Terminal Value captures all intrinsic value generated beyond Year 5. This relies on the Gordon Growth Model assumption that healthcare spending persists indefinitely.</p>

        <div class="math-card">
          <div class="math-row">
            <span>Year 5 FCF</span>
            <span>{formatMillions(year5FCF)}</span>
          </div>
          <div class="math-row">
            <span>Terminal Value (TV) Calculation</span>
            <span>({formatMillions(year5FCF)} * {1 + terminalGrowthRate}) / ({discountRate} - {terminalGrowthRate})</span>
          </div>
          <div class="math-row">
            <span>Terminal Value</span>
            <span>{formatMillions(terminalValue)}</span>
          </div>
          <div class="math-row highlight">
            <span>PV of Terminal Value</span>
            <span>{formatMillions(pvTerminalValue)}</span>
          </div>
        </div>

        <p style="margin-top: 2rem;">Walking from Enterprise Value down to Equity Value per share:</p>

        <div class="math-card">
          <div class="math-row">
            <span>Sum of PV of FCFs (Years 1-5)</span>
            <span>{formatMillions(sumPvFcf)}</span>
          </div>
          <div class="math-row">
            <span>+ PV of Terminal Value</span>
            <span>{formatMillions(pvTerminalValue)}</span>
          </div>
          <div class="math-row">
            <span><strong>= Enterprise Value</strong></span>
            <span><strong>{formatMillions(enterpriseValue)}</strong></span>
          </div>
          <div class="math-row">
            <span>+ Net Cash (Cash - Debt)</span>
            <span>{formatMillions(netCash)}</span>
          </div>
          <div class="math-row highlight">
            <span><strong>= Total Equity Value</strong></span>
            <span><strong>{formatMillions(totalEquityValue)}</strong></span>
          </div>
          <div class="math-row">
            <span>÷ Shares Outstanding</span>
            <span>{sharesOut.toLocaleString()}M</span>
          </div>
          <div class="math-row result">
            <span><strong>Intrinsic Value Per Share</strong></span>
            <span><strong>{formatMoney(intrinsicValuePerShare)}</strong></span>
          </div>
        </div>
      </section>

      <section class="content-section">
        <h2>Sensitivity Matrix</h2>
        <p>Because minor adjustments to the WACC and Terminal Growth deeply alter a DCF output, the matrix below charts the intrinsic value curve across alternative assumptions.</p>

        <div class="table-container sensitivity-table">
          <table>
            <thead>
              <tr>
                <th rowspan="2" class="corner-cell">Terminal<br/>Growth</th>
                <th colspan="5" class="header-cell">Discount Rate (WACC)</th>
              </tr>
              <tr>
                {sensitivityDiscountRates.map(d => <th>{formatPercent(d)}</th>)}
              </tr>
            </thead>
            <tbody>
              {sensitivityMatrix.map(row => (
                <tr>
                  <th class="row-header">{formatPercent(row.growthRate)}</th>
                  {row.values.map(val => (
                    <td class={
                      val > currentPrice * 1.15 ? "cell-undervalued" :
                      val < currentPrice * 0.85 ? "cell-overvalued" :
                      "cell-neutral"
                    }>
                      {formatMoney(val)}
                    </td>
                  ))}
                </tr>
              ))}
            </tbody>
          </table>
          <div class="matrix-legend">
            <span class="legend-item"><span class="color-box cell-undervalued"></span> Undervalued (>15% Margin)</span>
            <span class="legend-item"><span class="color-box cell-neutral"></span> Fair Value</span>
            <span class="legend-item"><span class="color-box cell-overvalued"></span> Overvalued (&lt;-15% Margin)</span>
          </div>
        </div>
      </section>

      <section class="content-section">
        <h2>Historical FCF Context (2022-2025)</h2>
        <p>UNH's cash flows are massive but do exhibit fluctuations based on timing of government payments, claims processing cycles (like the recent cyberattack disruptions), and capital deployment. The broader trajectory remains highly robust.</p>

        <div class="bar-chart-container">
          <div class="bar-chart">
            <div class="bar-group">
              <div class="bar" style="height: 60%;"><span class="bar-label">$23.4B</span></div>
              <div class="bar-year">2022</div>
            </div>
            <div class="bar-group">
              <div class="bar" style="height: 65%;"><span class="bar-label">$25.7B</span></div>
              <div class="bar-year">2023</div>
            </div>
            <div class="bar-group">
              <div class="bar" style="height: 52%;"><span class="bar-label">$20.7B</span></div>
              <div class="bar-year">2024</div>
            </div>
            <div class="bar-group">
              <div class="bar highlight" style="height: 40%;"><span class="bar-label">$16.1B</span></div>
              <div class="bar-year">2025</div>
            </div>
          </div>
        </div>
        <p style="font-size: 0.85rem; color: #8899b6; margin-top: 1rem;">Note: 2024 and 2025 figures were notably impacted by the Change Healthcare cyberattack remediation and subsequent working capital swings.</p>
      </section>

      <section class="content-section risks-section">
        <h2>Risks & Bear Case</h2>
        <p>A balanced assessment of UNH necessitates understanding its vulnerabilities to legislative strokes of the pen:</p>
        <div class="risk-grid">
          <div class="risk-card">
            <h3>1. Medicare Advantage Margin Compression</h3>
            <p>CMS (Centers for Medicare & Medicaid Services) tightly controls payment rates. If the government implements aggressive rate cuts or overhauls the risk-adjustment coding framework, UNH's core growth engine could see sudden and sustained margin degradation.</p>
          </div>
          <div class="risk-card">
            <h3>2. Antitrust and Regulatory Overhang</h3>
            <p>UnitedHealth's vertical integration (owning the insurer, the clinics, the PBM, and the payment network) constantly invites DOJ scrutiny. Forced divestitures of Optum assets or strict firewalls could dismantle its synergistic flywheel.</p>
          </div>
          <div class="risk-card">
            <h3>3. Unexpected Utilization Spikes</h3>
            <p>When seniors suddenly utilize more medical care than actuarially modeled (e.g., increased outpatient surgeries post-pandemic), the medical loss ratio (MLR) spikes, rapidly eating into near-term free cash flow.</p>
          </div>
        </div>
      </section>

      <section class="content-section faq-section">
        <h2>Frequently Asked Questions</h2>

        <div class="faq-item">
          <h3>Why did Gemini pick an 8% growth rate for UnitedHealth?</h3>
          <p>Gemini projects an 8% FCF growth rate based on UNH's dominant market position, demographic tailwinds (an aging population), consistent premium growth, and Optum's structural expansion into value-based care and pharmacy benefits.</p>
        </div>

        <div class="faq-item">
          <h3>What discount rate was used for UNH's DCF?</h3>
          <p>A 7.5% discount rate was selected. This low rate reflects the highly defensive, inelastic nature of healthcare, combined with UNH's extraordinarily low beta (0.38) and the relative safety of its cash flows.</p>
        </div>

        <div class="faq-item">
          <h3>How does debt impact UNH's intrinsic value?</h3>
          <p>UnitedHealth carries substantial debt ($83B), often used for strategic acquisitions (like Change Healthcare or various home health providers). While the core DCF enterprise value is high, subtracting this heavy debt load significantly reduces the final intrinsic value per share.</p>
        </div>
      </section>

      <div class="disclaimer-box">
        <p><strong>Disclaimer:</strong> The numbers presented on this page are for educational and entertainment purposes only. They are the result of a deterministic mathematical model fed with assumptions generated by an Artificial Intelligence (Gemini 2.5 Pro). This does not constitute investment advice. Always conduct your own due diligence before investing in the stock market.</p>
      </div>

    </div>
  </div>
</SiteLayout>
