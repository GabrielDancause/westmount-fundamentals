}
.finding-text { font-size: 15px; line-height: 1.5; }
.finding-text strong { color: var(--text-bright); }

/* Sector chart */
.sector-chart {
  background: var(--card-bg); border: 1px solid var(--border-color);
  border-radius: 12px; padding: 32px; margin: 40px 0;
}
.sector-chart h2 { font-size: 20px; color: var(--text-bright); margin-bottom: 24px; }
.sector-bars { display: flex; flex-direction: column; gap: 12px; }
.sector-row { display: flex; align-items: center; gap: 12px; }
.sector-name {
  width: 200px; font-size: 13px; color: var(--text-dim); flex-shrink: 0;
  text-align: right;
}
.sector-bar-track {
  flex: 1; height: 32px; background: rgba(74,143,231,0.06);
  border-radius: 4px; overflow: hidden;
}
.sector-bar-fill {
  height: 100%; border-radius: 4px; display: flex; align-items: center;
  padding-left: 10px; font-size: 12px; font-weight: 600;
