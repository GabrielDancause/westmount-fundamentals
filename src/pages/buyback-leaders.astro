---
import SiteLayout from "../layouts/SiteLayout.astro";
import registry from "../data/pages-registry.json";

const page = (registry as any)["buyback-leaders"];
export const meta = { title: "Top Stock Buyback Leaders 2026 — 106 Companies Ranked", description: "One tech giant spent $94B on buybacks alone. See which 106 companies are repurchasing the most stock in 2026, ranked by buyback yield.", category: "study", published: "2026-03-15" };

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Article",
      "headline": "Stock Buyback Leaders 2026: Who Is Repurchasing the Most Shares?",
      "description": "Complete ranking of 106 companies by share buyback volume, yield, and share count reduction. Analysis of $709.5 billion in trailing 12-month buybacks.",
      "datePublished": "2026-03-09",
      "dateModified": "2026-03-20",
      "author": {
        "@type": "Organization",
        "name": "Westmount Research"
      },
      "publisher": {
        "@type": "Organization",
        "name": "Westmount Research",
        "url": "https://westmountfundamentals.com"
      },
      "mainEntityOfPage": "https://westmountfundamentals.com/buyback-leaders"
    },
    {
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "Which company buys back the most stock?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Apple (AAPL) is the undisputed buyback king, repurchasing approximately $94 billion in shares over the trailing 12 months — more than the next two companies combined. Alphabet (GOOGL) follows at $62 billion and Meta Platforms (META) at $48 billion."
          }
        },
        {
          "@type": "Question",
          "name": "Are stock buybacks good for investors?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Stock buybacks can be excellent for investors when executed at reasonable valuations. They reduce shares outstanding, boosting earnings per share (EPS) and each remaining share's ownership claim. However, buybacks are only value-creating when the stock is fairly or undervalued."
          }
        },
        {
          "@type": "Question",
          "name": "What is buyback yield?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Buyback yield measures how much of its market capitalization a company spends on share repurchases annually. Formula: (Annual Buybacks ÷ Market Cap) × 100. A 5% buyback yield means the company is repurchasing 5% of its market value in shares each year."
          }
        },
        {
          "@type": "Question",
          "name": "Do buybacks increase EPS?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Yes, buybacks mechanically increase EPS by reducing the denominator (shares outstanding). If a company earns $1 billion with 100 million shares, EPS is $10. After buying back 10 million shares, the same earnings yield $11.11 EPS — an 11.1% boost with zero change in actual profitability."
          }
        },
        {
          "@type": "Question",
          "name": "Are buybacks better than dividends?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Neither is universally better — they serve different purposes. Buybacks are tax-efficient, flexible, and boost EPS. Dividends provide predictable income and signal confidence. For total capital return, look at both together."
          }
        }
      ]
    }
  ]
};

---

 · Updated March 2026<SiteLayout
  site="westmount"
  title={page.title}
  description={page.description}
  canonical={`https://westmountfundamentals.com/${page.slug}/`} schema={schema}
>
  <style is:global>
*, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
:root {
  --green: #22c55e; --red: #ef4444; --yellow: #eab308;
}
body {
  background: var(--bg-color); color: var(--text-primary);
  font-family: 'Inter', -apple-system, sans-serif;
  line-height: 1.6; min-height: 100vh;
}
.container { max-width: 1280px; margin: 0 auto; padding: 0 24px; }
a { color: var(--accent-color); text-decoration: none; }
a:hover { text-decoration: underline; }
header { border-bottom: 1px solid var(--border-color); padding: 20px 0; }
.header-inner { display: flex; align-items: center; justify-content: space-between; }
.logo { font-size: 18px; font-weight: 700; color: var(--text-bright); letter-spacing: -0.5px; }
.logo span { color: var(--accent-color); }
nav a { color: var(--text-dim); margin-left: 24px; font-size: 14px; font-weight: 500; }
nav a:hover { color: var(--text-bright); text-decoration: none; }
.hero { padding: 60px 0 40px; }
.tag {
  display: inline-block; background: var(--accent-dim);
  color: var(--accent-color); font-size: 12px; font-weight: 600;
  padding: 4px 12px; border-radius: 4px; margin-bottom: 16px;
  letter-spacing: 0.5px; text-transform: uppercase;
}
.hero h1 {
  font-size: clamp(28px, 4vw, 44px); font-weight: 800;
  color: var(--text-bright); line-height: 1.15; margin-bottom: 12px;
  letter-spacing: -1px;
}
.hero .subtitle { font-size: 18px; color: var(--text-dim); max-width: 680px; }
.hero .meta {
  margin-top: 16px; font-size: 13px; color: var(--text-dim);
  font-family: 'JetBrains Mono', monospace;
}
.stats-grid {
  display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
  gap: 16px; margin: 40px 0;
}
.stat-card {
  background: var(--card-bg); border: 1px solid var(--border-color);
  border-radius: 12px; padding: 24px; text-align: center;
}
.stat-card .value {
  font-size: 32px; font-weight: 800; color: var(--accent-color);
  font-family: 'JetBrains Mono', monospace;
}
.stat-card .label { font-size: 13px; color: var(--text-dim); margin-top: 4px; }
.chart-section {
  background: var(--card-bg); border: 1px solid var(--border-color);
  border-radius: 12px; padding: 32px; margin: 40px 0;
}
.chart-section h2 { font-size: 20px; color: var(--text-bright); margin-bottom: 24px; }
.bar-chart { display: flex; flex-direction: column; gap: 8px; }
.bar-row { display: flex; align-items: center; gap: 12px; font-size: 13px; }
.bar-label {
  width: 80px; text-align: right; font-family: 'JetBrains Mono', monospace;
  font-weight: 500; color: var(--text-bright); flex-shrink: 0;
}
.bar-track {
  flex: 1; height: 28px; background: rgba(74,143,231,0.08);
  border-radius: 4px; overflow: hidden; position: relative;
}
.bar-fill {
  height: 100%; border-radius: 4px; display: flex; align-items: center;
  padding-left: 8px; font-size: 12px; font-weight: 600;
  font-family: 'JetBrains Mono', monospace; color: var(--text-bright);
