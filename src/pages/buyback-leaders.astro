// ========== Table ==========
var sortCol = 'buybackAmountB';
var sortDir = 'desc';

function renderTable() {
  var r = DATA.results.slice();
  var sectorVal = document.getElementById('sectorFilter').value;
  var search = document.getElementById('searchInput').value.toLowerCase();

  var filtered = r.filter(function(s) {
    if (sectorVal && s.sector !== sectorVal) return false;
    if (search && s.ticker.toLowerCase().indexOf(search) === -1 && (s.company || '').toLowerCase().indexOf(search) === -1) return false;
    return true;
  });

  filtered.sort(function(a, b) {
    var va = a[sortCol], vb = b[sortCol];
    if (va === null || va === undefined) va = sortDir === 'asc' ? Infinity : -Infinity;
    if (vb === null || vb === undefined) vb = sortDir === 'asc' ? Infinity : -Infinity;
    if (typeof va === 'string') return sortDir === 'asc' ? va.localeCompare(vb) : vb.localeCompare(va);
    return sortDir === 'asc' ? va - vb : vb - va;
  });

  var maxYield = Math.max.apply(null, filtered.map(function(s) { return s.buybackYield || 0; }));

  document.getElementById('tableBody').innerHTML = filtered.map(function(s, i) {
    var yieldW = ((s.buybackYield || 0) / maxYield * 60).toFixed(0);
    var yieldColor = (s.buybackYield || 0) > 5 ? 'var(--green)' : (s.buybackYield || 0) > 2 ? 'var(--accent-color)' : 'var(--text-dim)';
    return '<tr>' +
      '<td class="mono text-right">' + (i + 1) + '</td>' +
      '<td class="ticker-cell">' + s.ticker + '</td>' +
      '<td>' + (s.company || '—') + '</td>' +
      '<td style="font-size:12px;color:var(--text-dim)">' + (s.sector || '—') + '</td>' +
      '<td class="mono text-right">$' + s.buybackAmountB + 'B</td>' +
      '<td class="mono text-right"><span class="yield-bar" style="width:' + yieldW + 'px;background:' + yieldColor + '"></span>' + (s.buybackYield !== null ? s.buybackYield + '%' : '—') + '</td>' +
      '<td class="mono text-right">' + (s.sharesReductionPct !== null ? s.sharesReductionPct + '%' : '—') + '</td>' +
      '<td class="mono text-right" style="color:var(--green)">' + (s.totalReturnYield !== null ? s.totalReturnYield + '%' : '—') + '</td>' +
      '<td class="mono text-right">' + (s.dividendYield !== null ? s.dividendYield + '%' : '—') + '</td>' +
      '<td class="mono text-right">' + (s.marketCapB ? '$' + s.marketCapB.toLocaleString() + 'B' : '—') + '</td>' +
      '<td class="mono text-right">' + (s.peRatio !== null ? s.peRatio : '—') + '</td>' +
      '<td class="mono text-right" style="color:var(--green)">' + (s.epsGrowth !== null ? '+' + s.epsGrowth + '%' : '—') + '</td>' +
    '</tr>';
  }).join('');

  document.querySelectorAll('thead th').forEach(function(th) {
    th.classList.remove('sorted-asc', 'sorted-desc');
    if (th.dataset.col === sortCol) th.classList.add(sortDir === 'asc' ? 'sorted-asc' : 'sorted-desc');
  });
}

// ========== Init filters ==========
function initFilters() {
  var sectorSet = {};
  DATA.results.forEach(function(s) { if (s.sector) sectorSet[s.sector] = true; });
  var sectors = Object.keys(sectorSet).sort();
  var sel = document.getElementById('sectorFilter');
  sectors.forEach(function(s) {
    var opt = document.createElement('option');
    opt.value = s; opt.textContent = s;
    sel.appendChild(opt);
  });
}

// ========== Sort handlers ==========
document.querySelectorAll('thead th').forEach(function(th) {
  th.addEventListener('click', function() {
    var col = th.dataset.col;
    if (!col) return;
    if (sortCol === col) sortDir = sortDir === 'desc' ? 'asc' : 'desc';
    else { sortCol = col; sortDir = th.dataset.type === 'num' ? 'desc' : 'asc'; }
    renderTable();
  });
});

document.getElementById('sectorFilter').addEventListener('change', renderTable);
document.getElementById('searchInput').addEventListener('input', renderTable);
document.getElementById('sortPreset').addEventListener('change', function() {
  sortCol = this.value;
  sortDir = 'desc';
  renderTable();
});

// Embed copy button
document.getElementById('copy-btn-buyback-leaders').addEventListener('click', function() {
  var code = document.getElementById('embed-code-buyback-leaders').textContent;
  navigator.clipboard.writeText(code);
  this.textContent = 'Copied!';
  var btn = this;
  setTimeout(function() { btn.textContent = 'Copy Code'; }, 2000);
});

// ========== Init everything ==========
initFilters();
renderStats();
initTSRCalculator();
renderBarChart();
renderYieldChart();
renderSectorBars();
renderInsights();
renderFindings();
renderTable();

// Scatter plot needs Chart.js to be loaded
if (typeof Chart !== 'undefined') {
  renderScatterPlot();
} else {
  // Wait for Chart.js to load
  var checkChart = setInterval(function() {
    if (typeof Chart !== 'undefined') {
      clearInterval(checkChart);
      renderScatterPlot();
    }
  }, 100);
}
  </script>
</SiteLayout>