  color: var(--text-primary); padding: 8px 12px; border-radius: 8px;
  font-size: 13px; font-family: 'Inter', sans-serif;
}
.filters select:focus, .filters input:focus { outline: none; border-color: var(--accent-color); }
.table-wrap {
  background: var(--card-bg); border: 1px solid var(--border-color);
  border-radius: 12px; overflow: hidden; margin: 40px 0;
}
.table-scroll { overflow-x: auto; }
table { width: 100%; border-collapse: collapse; font-size: 13px; }
thead th {
  background: rgba(74,143,231,0.08); padding: 12px 16px;
  text-align: left; font-weight: 600; color: var(--text-dim);
  font-size: 11px; text-transform: uppercase; letter-spacing: 0.5px;
  cursor: pointer; user-select: none; white-space: nowrap;
  border-bottom: 1px solid var(--border-color); position: sticky; top: 0;
}
thead th:hover { color: var(--accent-color); }
thead th.sorted-asc::after { content: ' ▲'; color: var(--accent-color); }
thead th.sorted-desc::after { content: ' ▼'; color: var(--accent-color); }
tbody td {
  padding: 10px 16px; border-bottom: 1px solid var(--border-color); white-space: nowrap;
}
tbody tr:hover { background: rgba(74,143,231,0.04); }
tbody tr:last-child td { border-bottom: none; }
.mono { font-family: 'JetBrains Mono', monospace; font-size: 12px; }
.text-right { text-align: right; }
.text-green { color: var(--green); }
.text-red { color: var(--red); }
.ticker-cell { font-weight: 700; color: var(--accent-color); font-family: 'JetBrains Mono', monospace; }
.yield-bar {
  display: inline-block; height: 8px; border-radius: 4px;
  margin-right: 8px; vertical-align: middle;
}
.faq-section {
  background: var(--card-bg); border: 1px solid var(--border-color);
  border-radius: 12px; padding: 32px; margin: 40px 0;
}
.faq-section h2 { font-size: 20px; color: var(--text-bright); margin-bottom: 24px; }
.faq-item { border-bottom: 1px solid var(--border-color); padding: 16px 0; }
.faq-item:last-child { border-bottom: none; }
.faq-q {
  font-weight: 600; color: var(--text-bright); font-size: 15px;
  cursor: pointer; display: flex; justify-content: space-between; align-items: center;
}
.faq-q::after { content: '+'; font-size: 20px; color: var(--accent-color); }
.faq-item.open .faq-q::after { content: '−'; }
.faq-a {
