.methodology p { font-size: 14px; color: var(--text-dim); line-height: 1.7; margin-bottom: 12px; }
.citation {
  background: var(--card-bg); border: 1px solid var(--border-color);
  border-radius: 12px; padding: 24px; margin: 40px 0;
}
.citation h3 { font-size: 14px; color: var(--text-dim); margin-bottom: 8px; }
.citation code {
  display: block; background: var(--bg-color); padding: 16px;
  border-radius: 8px; font-size: 13px; color: var(--text-primary);
  font-family: 'JetBrains Mono', monospace; white-space: pre-wrap; word-break: break-all;
}
.disclaimer {
  text-align: center; padding: 20px; font-size: 12px;
  color: var(--text-dim); font-style: italic;
  border-top: 1px solid var(--border-color); margin-top: 20px;
}
footer {
  border-top: 1px solid var(--border-color); padding: 24px 0;
  text-align: center; font-size: 13px; color: var(--text-dim);
}

/* TSR Calculator */
.tsr-calculator {
  background: var(--card-bg); border: 1px solid var(--border-color);
  border-radius: 12px; padding: 32px; margin: 40px 0;
  position: relative; overflow: hidden;
}
.tsr-calculator::before {
  content: ''; position: absolute; top: 0; left: 0; right: 0; height: 3px;
  background: linear-gradient(90deg, var(--accent-color), #22c55e, #eab308);
}
.tsr-calculator h2 { font-size: 20px; color: var(--text-bright); margin-bottom: 8px; }
.tsr-calculator .calc-subtitle { font-size: 14px; color: var(--text-dim); margin-bottom: 24px; }
.calc-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 24px; }
.calc-left { display: flex; flex-direction: column; gap: 16px; }
.calc-select-wrap { position: relative; }
.calc-select-wrap select {
  width: 100%; background: var(--bg-color); border: 1px solid var(--border-color);
  color: var(--text-primary); padding: 12px 16px; border-radius: 8px;
  font-size: 14px; font-family: 'Inter', sans-serif; cursor: pointer;
  appearance: none; -webkit-appearance: none;
}
.calc-select-wrap::after {
  content: '▾'; position: absolute; right: 16px; top: 50%;
  transform: translateY(-50%); color: var(--text-dim); pointer-events: none;
}
.calc-results { display: flex; flex-direction: column; gap: 12px; }
.calc-result-row {
  display: flex; justify-content: space-between; align-items: center;
  padding: 12px 16px; background: var(--bg-color); border-radius: 8px;
}
.calc-result-label { font-size: 13px; color: var(--text-dim); }
.calc-result-value { font-size: 18px; font-weight: 700; font-family: 'JetBrains Mono', monospace; }
.calc-total-row {
  display: flex; justify-content: space-between; align-items: center;
  padding: 16px; background: linear-gradient(135deg, rgba(34,197,94,0.1), rgba(74,143,231,0.1));
  border: 1px solid rgba(34,197,94,0.2); border-radius: 8px;
}
.calc-total-label { font-size: 14px; font-weight: 600; color: var(--text-bright); }
.calc-total-value { font-size: 24px; font-weight: 800; color: var(--green); font-family: 'JetBrains Mono', monospace; }
.calc-right { display: flex; flex-direction: column; gap: 16px; }
.calc-stacked-bar {
  height: 48px; border-radius: 8px; overflow: hidden; display: flex;
  position: relative;
}
.calc-stacked-bar .bar-buyback {
  height: 100%; display: flex; align-items: center; justify-content: center;
  font-size: 12px; font-weight: 600; color: #fff; transition: width 0.4s ease;
  background: var(--accent-color);
}
.calc-stacked-bar .bar-dividend {
  height: 100%; display: flex; align-items: center; justify-content: center;
  font-size: 12px; font-weight: 600; color: #fff; transition: width 0.4s ease;
  background: var(--green);
}
.calc-bar-legend { display: flex; gap: 16px; font-size: 12px; color: var(--text-dim); }
.calc-bar-legend span { display: flex; align-items: center; gap: 6px; }
.calc-bar-legend .dot { width: 10px; height: 10px; border-radius: 50%; }
.calc-projection {
  padding: 16px; background: rgba(234,179,8,0.08); border: 1px solid rgba(234,179,8,0.2);
  border-radius: 8px; font-size: 14px; color: var(--text-primary); line-height: 1.6;
}
.calc-projection strong { color: var(--yellow); }
.calc-sp500 {
  padding: 16px; background: var(--bg-color); border-radius: 8px;
}
.calc-sp500-header { font-size: 12px; color: var(--text-dim); margin-bottom: 8px; text-transform: uppercase; letter-spacing: 0.5px; }
.calc-sp500-compare { display: flex; gap: 12px; align-items: center; }
.calc-sp500-bar {
  flex: 1; height: 24px; background: rgba(74,143,231,0.08); border-radius: 4px; overflow: hidden;
}
.calc-sp500-bar .fill {
  height: 100%; border-radius: 4px; display: flex; align-items: center;
  padding-left: 8px; font-size: 11px; font-weight: 600; color: #fff;
  font-family: 'JetBrains Mono', monospace; transition: width 0.4s ease;
}
.calc-sp500-label { font-size: 12px; color: var(--text-dim); width: 80px; text-align: right; flex-shrink: 0; }

/* Scatter plot */
.scatter-section {
  background: var(--card-bg); border: 1px solid var(--border-color);
  border-radius: 12px; padding: 32px; margin: 40px 0;
}
.scatter-section h2 { font-size: 20px; color: var(--text-bright); margin-bottom: 8px; }
.scatter-section .scatter-subtitle { font-size: 14px; color: var(--text-dim); margin-bottom: 24px; }
.scatter-canvas-wrap { position: relative; width: 100%; max-width: 800px; margin: 0 auto; }
.scatter-canvas-wrap canvas { width: 100% !important; height: auto !important; }
.quadrant-labels { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; margin-top: 16px; max-width: 600px; margin-left: auto; margin-right: auto; }
.quadrant-label { padding: 8px 12px; border-radius: 6px; font-size: 12px; text-align: center; }
.ql-tl { background: rgba(74,143,231,0.1); color: var(--accent-color); }
.ql-tr { background: rgba(34,197,94,0.1); color: var(--green); }
.ql-bl { background: rgba(148,163,184,0.1); color: var(--text-dim); }
.ql-br { background: rgba(234,179,8,0.1); color: var(--yellow); }

/* Key Insights */
.insights-section {
  background: var(--card-bg); border: 1px solid var(--border-color);
  border-radius: 12px; padding: 32px; margin: 40px 0;
}
.insights-section h2 { font-size: 20px; color: var(--text-bright); margin-bottom: 24px; }
.insight-cards { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 16px; }
.insight-card {
  padding: 20px; background: var(--bg-color); border-radius: 10px;
  border-left: 3px solid var(--accent-color);
}
.insight-card .insight-icon { font-size: 24px; margin-bottom: 8px; }
.insight-card .insight-stat {
  font-size: 22px; font-weight: 800; color: var(--text-bright);
  font-family: 'JetBrains Mono', monospace; margin-bottom: 4px;
}
.insight-card .insight-text { font-size: 13px; color: var(--text-dim); line-height: 1.5; }

@media (max-width: 768px) {
  .stats-grid { grid-template-columns: repeat(2, 1fr); }
  .bar-company { display: none; }
  .bar-label { width: 60px; font-size: 11px; }
  .sector-name { width: 120px; font-size: 12px; }
  .sector-count { display: none; }
  .hero h1 { font-size: 24px; }
  .hero .subtitle { font-size: 15px; }
  .filters { flex-direction: column; align-items: stretch; }
  .calc-grid { grid-template-columns: 1fr; }
  .quadrant-labels { grid-template-columns: 1fr; }
  .insight-cards { grid-template-columns: 1fr; }
}
  </style>

<main class="container">
  <div style="max-width:1280px;margin:0 auto;padding:16px 24px 0;display:flex;justify-content:space-between;align-items:center;font-size:13px;color:var(--text-dim,#94a3b8)">
    <nav aria-label="Breadcrumb"><a href="/" style="color:var(--text-dim,#94a3b8);text-decoration:none">Home</a> <span style="margin:0 6px;opacity:0.5">›</span> <a href="/studies/" style="color:var(--text-dim,#94a3b8);text-decoration:none">Studies</a> <span style="margin:0 6px;opacity:0.5">›</span> <span style="color:var(--text-primary,#c8d0de)">Top Stock Buyback Leaders 2026</span></nav>
    <span>8 min read</span>
  </div>
  <section class="hero">
    <div class="tag">Original Research</div>
    <h1>{page.h1}</h1>
    <p class="subtitle">Who is repurchasing the most shares? 106 companies ranked by buyback volume, buyback yield, and share count reduction — $709.5 billion in total repurchases tracked.</p>
    <p class="meta">Published March 9, 2026 · SEC filings & earnings reports · 106 companies analyzed</p>
  </section>

  <!-- Stats Grid -->
  <section class="stats-grid" id="statsGrid"></section>

  <!-- TSR Calculator (NEW) -->
  <section class="tsr-calculator" id="tsrCalculator">
    <h2>📊 Total Shareholder Return Calculator</h2>
    <p class="calc-subtitle">Select any company to see its combined capital return from buybacks and dividends — and how it compares to the S&P 500 average.</p>
    <div class="calc-grid">
      <div class="calc-left">
        <div class="calc-select-wrap">
          <select id="tsrSelect">
            <option value="">Choose a company…</option>
          </select>
        </div>
        <div class="calc-results" id="tsrResults" style="display:none">
          <div class="calc-result-row">
            <span class="calc-result-label">Buyback Yield</span>
            <span class="calc-result-value" id="tsrBuyback" style="color:var(--accent-color)">—</span>
          </div>
          <div class="calc-result-row">
            <span class="calc-result-label">Dividend Yield</span>
            <span class="calc-result-value" id="tsrDividend" style="color:var(--green)">—</span>
          </div>
          <div class="calc-total-row">
            <span class="calc-total-label">Total Shareholder Return</span>
            <span class="calc-total-value" id="tsrTotal">—</span>
          </div>
        </div>
      </div>
      <div class="calc-right" id="tsrVisuals" style="display:none">
        <div>
          <div class="calc-bar-legend">
            <span><span class="dot" style="background:var(--accent-color)"></span> Buyback Yield</span>
            <span><span class="dot" style="background:var(--green)"></span> Dividend Yield</span>
          </div>
          <div class="calc-stacked-bar" id="tsrStackedBar" style="margin-top:8px">
            <div class="bar-buyback" id="tsrBarBuyback"></div>
            <div class="bar-dividend" id="tsrBarDividend"></div>
          </div>
        </div>
        <div class="calc-projection" id="tsrProjection"></div>
        <div class="calc-sp500" id="tsrSp500Compare">
          <div class="calc-sp500-header">vs S&P 500 Average Total Return</div>
          <div style="display:flex;flex-direction:column;gap:6px">
            <div class="calc-sp500-compare">
              <div class="calc-sp500-label" id="tsrCompanyLabel">—</div>
              <div class="calc-sp500-bar"><div class="fill" id="tsrCompanyBar" style="background:var(--green)"></div></div>
            </div>
            <div class="calc-sp500-compare">
              <div class="calc-sp500-label">S&P 500</div>
              <div class="calc-sp500-bar"><div class="fill" id="tsrSp500Bar" style="background:var(--text-dim)"></div></div>
            </div>
          </div>
