// ========== TSR Calculator ==========
function initTSRCalculator() {
  var select = document.getElementById('tsrSelect');
  var valid = DATA.results.filter(function(s) { return s.buybackYield !== null && s.totalReturnYield !== null; });
  valid.sort(function(a, b) { return a.ticker.localeCompare(b.ticker); });
  valid.forEach(function(s) {
    var opt = document.createElement('option');
    opt.value = s.ticker;
    opt.textContent = s.ticker + ' — ' + s.company;
    select.appendChild(opt);
  });

  select.addEventListener('change', function() {
    var ticker = this.value;
    if (!ticker) {
      document.getElementById('tsrResults').style.display = 'none';
      document.getElementById('tsrVisuals').style.display = 'none';
      return;
    }
    var company = DATA.results.find(function(s) { return s.ticker === ticker; });
    if (!company) return;

    var buybackY = company.buybackYield || 0;
    var divY = company.dividendYield || 0;
    var totalY = company.totalReturnYield || (buybackY + divY);

    document.getElementById('tsrBuyback').textContent = buybackY.toFixed(2) + '%';
    document.getElementById('tsrDividend').textContent = divY.toFixed(2) + '%';
    document.getElementById('tsrTotal').textContent = totalY.toFixed(2) + '%';

    // Stacked bar
    var maxBar = Math.max(totalY, SP500_AVG_TSR, 1);
    var buybackPct = (buybackY / maxBar * 100);
    var divPct = (divY / maxBar * 100);
    document.getElementById('tsrBarBuyback').style.width = buybackPct + '%';
    document.getElementById('tsrBarBuyback').textContent = buybackY > 0.5 ? buybackY.toFixed(1) + '%' : '';
    document.getElementById('tsrBarDividend').style.width = divPct + '%';
    document.getElementById('tsrBarDividend').textContent = divY > 0.5 ? divY.toFixed(1) + '%' : '';

    // Projection
    var shareReduction = company.sharesReductionPct || 0;
    var fiveYearReduction = (1 - Math.pow(1 - shareReduction / 100, 5)) * 100;
    document.getElementById('tsrProjection').innerHTML =
      '<strong>📉 5-Year Share Reduction Projection</strong><br>' +
      'If <strong>' + company.company + '</strong> continues at ' + shareReduction + '% annual reduction, ' +
      '<strong>' + fiveYearReduction.toFixed(1) + '%</strong> of shares will be retired in 5 years — ' +
      'boosting per-share value for remaining shareholders.';

    // S&P 500 compare
    var compMaxBar = Math.max(totalY, SP500_AVG_TSR);
    document.getElementById('tsrCompanyLabel').textContent = company.ticker;
    document.getElementById('tsrCompanyBar').style.width = (totalY / compMaxBar * 100).toFixed(1) + '%';
    document.getElementById('tsrCompanyBar').textContent = totalY.toFixed(2) + '%';
    document.getElementById('tsrCompanyBar').style.background = totalY >= SP500_AVG_TSR ? 'var(--green)' : 'var(--red)';
    document.getElementById('tsrSp500Bar').style.width = (SP500_AVG_TSR / compMaxBar * 100).toFixed(1) + '%';
    document.getElementById('tsrSp500Bar').textContent = SP500_AVG_TSR.toFixed(2) + '%';

    document.getElementById('tsrResults').style.display = 'flex';
    document.getElementById('tsrVisuals').style.display = 'flex';
  });
}

// ========== Bar chart - Top 20 by amount ==========
function renderBarChart() {
  var top20 = DATA.results.slice(0, 20);
  var maxVal = Math.max.apply(null, top20.map(function(s) { return s.buybackAmountB; }));
  var colors = ['#4a8fe7','#3b82f6','#2563eb','#1d4ed8','#6366f1','#818cf8','#22c55e','#14b8a6','#06b6d4','#0ea5e9','#8b5cf6','#a855f7','#ec4899','#f43f5e','#ef4444','#f97316','#eab308','#84cc16','#10b981','#06b6d4'];

  document.getElementById('barChart').innerHTML = top20.map(function(s, i) {
    var pct = (s.buybackAmountB / maxVal * 100).toFixed(1);
    return '<div class="bar-row">' +
      '<div class="bar-label">' + s.ticker + '</div>' +
      '<div class="bar-track">' +
        '<div class="bar-fill" style="width:' + pct + '%;background:' + colors[i % colors.length] + '">$' + s.buybackAmountB + 'B</div>' +
      '</div>' +
      '<div class="bar-company">' + s.company + '</div>' +
    '</div>';
  }).join('');
}

// ========== Yield chart ==========
function renderYieldChart() {
  var byYield = DATA.results.slice().sort(function(a, b) { return (b.buybackYield || 0) - (a.buybackYield || 0); }).slice(0, 20);
  var maxVal = Math.max.apply(null, byYield.map(function(s) { return s.buybackYield || 0; }));
  var colors = ['#22c55e','#16a34a','#15803d','#14532d','#10b981','#059669','#047857','#065f46','#34d399','#6ee7b7','#a7f3d0','#84cc16','#65a30d','#4d7c0f','#22d3ee','#06b6d4','#0891b2','#0e7490','#155e75','#164e63'];

  document.getElementById('yieldChart').innerHTML = byYield.map(function(s, i) {
    var pct = ((s.buybackYield || 0) / maxVal * 100).toFixed(1);
    return '<div class="bar-row">' +
      '<div class="bar-label">' + s.ticker + '</div>' +
      '<div class="bar-track">' +
        '<div class="bar-fill" style="width:' + pct + '%;background:' + colors[i % colors.length] + '">' + s.buybackYield + '%</div>' +
      '</div>' +
      '<div class="bar-company">' + s.company + '</div>' +
