  }).join('');
}

// ========== Scatter Plot ==========
function renderScatterPlot() {
  var ctx = document.getElementById('scatterChart').getContext('2d');
  var sectors = Object.keys(SECTOR_COLORS);
  var datasets = sectors.map(function(sector) {
    var items = DATA.results.filter(function(s) {
      return s.sector === sector && s.buybackYield !== null && s.dividendYield !== null;
    });
    return {
      label: sector,
      data: items.map(function(s) {
        return {
          x: s.dividendYield || 0,
          y: s.buybackYield || 0,
          r: Math.max(3, Math.sqrt(s.buybackAmountB) * 4),
          ticker: s.ticker,
          company: s.company,
          totalReturn: s.totalReturnYield || 0
        };
      }),
      backgroundColor: SECTOR_COLORS[sector] + '99',
      borderColor: SECTOR_COLORS[sector],
      borderWidth: 1
    };
  });

  new Chart(ctx, {
    type: 'bubble',
    data: { datasets: datasets },
    options: {
      responsive: true,
      maintainAspectRatio: true,
      scales: {
        x: {
          title: { display: true, text: 'Dividend Yield (%)', color: '#94a3b8', font: { size: 13 } },
          grid: { color: 'rgba(74,143,231,0.08)' },
          ticks: { color: '#94a3b8', callback: function(v) { return v + '%'; } },
          min: -0.5,
          max: 7.5
        },
        y: {
          title: { display: true, text: 'Buyback Yield (%)', color: '#94a3b8', font: { size: 13 } },
          grid: { color: 'rgba(74,143,231,0.08)' },
          ticks: { color: '#94a3b8', callback: function(v) { return v + '%'; } },
          min: -0.5,
          max: 17
        }
      },
      plugins: {
        legend: {
          position: 'bottom',
          labels: { color: '#94a3b8', usePointStyle: true, pointStyle: 'circle', padding: 16, font: { size: 11 } }
        },
        tooltip: {
          callbacks: {
            label: function(context) {
              var d = context.raw;
              return d.ticker + ' (' + d.company + ') — Buyback: ' + d.y.toFixed(2) + '%, Div: ' + d.x.toFixed(2) + '%, Total: ' + d.totalReturn.toFixed(2) + '%';
            }
          },
          backgroundColor: '#0a1020',
          titleColor: '#fff',
          bodyColor: '#c8d0de',
          borderColor: '#152040',
          borderWidth: 1
        }
      }
    }
  });
}

