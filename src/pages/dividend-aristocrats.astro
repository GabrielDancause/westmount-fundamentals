// Populate yield chart (top 20)
function buildYieldChart() {
    const sorted = [...DATA.results].sort((a, b) => b.currentYield - a.currentYield).slice(0, 20);
    const maxYield = sorted[0].currentYield;
    const container = document.getElementById('yieldChart');
    let html = '';
    sorted.forEach(s => {
        const pct = (s.currentYield / maxYield) * 100;
        html += `<div class="chart-bar-row">
            <span class="chart-label">${s.ticker}</span>
            <div class="chart-bar" style="width:${pct}%" title="${s.company}: ${s.currentYield}%">
                <span class="chart-bar-val">${s.currentYield.toFixed(2)}%</span>
            </div>
        </div>`;
    });
    html += '<div class="chart-note">Dividend yield as of March 2026</div>';
    container.innerHTML = html;
}

// Key findings
function buildFindings() {
    const sorted = [...DATA.results].sort((a, b) => b.currentYield - a.currentYield);
    const avgYield = DATA.averageYield;
    const highYieldCount = sorted.filter(s => s.currentYield >= 4).length;
    const avgPe = DATA.results.filter(r => r.peRatio).reduce((sum, r) => sum + r.peRatio, 0) / DATA.results.filter(r => r.peRatio).length;
    const totalMcap = DATA.results.filter(r => r.marketCapB).reduce((sum, r) => sum + r.marketCapB, 0);
    
    // Sector with highest avg yield
    const sectorYields = {};
    DATA.results.forEach(r => {
        if (!sectorYields[r.sector]) sectorYields[r.sector] = [];
        sectorYields[r.sector].push(r.currentYield);
    });
    let bestSector = '', bestAvg = 0;
    for (const [s, ys] of Object.entries(sectorYields)) {
        const avg = ys.reduce((a, b) => a + b, 0) / ys.length;
        if (avg > bestAvg) { bestAvg = avg; bestSector = s; }
    }

    const findings = [
        { num: '01', text: `The average Dividend Aristocrat yields <strong>${avgYield}%</strong> — nearly double the S&P 500's ~1.3% yield. ${highYieldCount} aristocrats yield above 4%.` },
        { num: '02', text: `Industrials and Consumer Staples dominate with <strong>16</strong> and <strong>15</strong> companies respectively, accounting for 46% of all aristocrats.` },
        { num: '03', text: `${bestSector} is the highest-yielding sector among aristocrats with an average yield of <strong>${bestAvg.toFixed(2)}%</strong>.` },
        { num: '04', text: `The median dividend growth streak is <strong>${DATA.medianYearsIncreasing} years</strong>. Dover Corporation leads with 71 consecutive years of increases — spanning back to 1955.` },
        { num: '05', text: `The average P/E ratio across aristocrats is <strong>${avgPe.toFixed(1)}</strong>. Combined market cap exceeds <strong>$${(totalMcap/1000).toFixed(1)} trillion</strong>.` },
    ];
    const container = document.getElementById('findings');
    container.innerHTML = findings.map(f => `
        <div class="finding">
            <div class="finding-num">FINDING ${f.num}</div>
            <div class="finding-text">${f.text}</div>
        </div>
    `).join('');
}

// Sector grid
function buildSectorGrid() {
    const sectors = DATA.sectorBreakdown;
    const container = document.getElementById('sectorGrid');
    const total = DATA.totalCompanies;
    container.innerHTML = Object.entries(sectors).map(([name, count]) => `
        <div class="sector-card">
            <div class="sector-name">${name}</div>
            <div class="sector-count">${count}</div>
            <div class="sector-pct">${((count/total)*100).toFixed(0)}% of aristocrats</div>
        </div>
    `).join('');
    
    // Populate filter dropdown
    const select = document.getElementById('sectorFilter');
    Object.keys(sectors).sort().forEach(s => {
        const opt = document.createElement('option');
        opt.value = s; opt.textContent = s;
        select.appendChild(opt);
    });
}

// Table
let currentSort = { col: 'yearsIncreasing', dir: 'desc' };
let filteredData = [...DATA.results];

function fmt(val, dec=2) {
    if (val === null || val === undefined) return '<span class="null-val">—</span>';
    return typeof val === 'number' ? val.toFixed(dec) : val;
}

function renderTable() {
    const tbody = document.getElementById('tableBody');
    tbody.innerHTML = filteredData.map(r => {
        const yieldClass = r.currentYield >= 4 ? 'yield-high' : (r.currentYield < 1 ? 'yield-low' : '');
        return `<tr>
            <td class="ticker">${r.ticker}</td>
            <td class="company-name">${r.company}</td>
            <td><span class="sector-tag">${r.sector || '—'}</span></td>
            <td class="num">${r.yearsIncreasing}</td>
            <td class="num ${yieldClass}">${r.currentYield.toFixed(2)}%</td>
            <td class="num">${fmt(r.peRatio)}</td>
            <td class="num">${fmt(r.forwardPe)}</td>
            <td class="num">${fmt(r.marketCapB)}</td>
            <td class="num">${fmt(r.priceUSD)}</td>
            <td class="num">${fmt(r.beta)}</td>
        </tr>`;
    }).join('');
    document.getElementById('resultCount').textContent = `${filteredData.length} companies`;
}

function sortTable(col) {
    if (currentSort.col === col) {
        currentSort.dir = currentSort.dir === 'asc' ? 'desc' : 'asc';
    } else {
        currentSort = { col, dir: 'desc' };
    }
    filteredData.sort((a, b) => {
        let va = a[col], vb = b[col];
        if (va === null || va === undefined) return 1;
        if (vb === null || vb === undefined) return -1;
        if (typeof va === 'string') return currentSort.dir === 'asc' ? va.localeCompare(vb) : vb.localeCompare(va);
        return currentSort.dir === 'asc' ? va - vb : vb - va;
    });
    
    // Update header classes
    document.querySelectorAll('th').forEach(th => {
        th.classList.remove('sorted-asc', 'sorted-desc');
        if (th.dataset.col === col) th.classList.add(currentSort.dir === 'asc' ? 'sorted-asc' : 'sorted-desc');
    });
    renderTable();
}

function applyFilters() {
    const search = document.getElementById('searchInput').value.toLowerCase();
    const sector = document.getElementById('sectorFilter').value;
    const yieldRange = document.getElementById('yieldFilter').value;
    
    filteredData = DATA.results.filter(r => {
        if (search && !r.ticker.toLowerCase().includes(search) && !r.company.toLowerCase().includes(search)) return false;
        if (sector && r.sector !== sector) return false;
        if (yieldRange) {
            const y = r.currentYield;
            if (yieldRange === '4+' && y < 4) return false;
            if (yieldRange === '3-4' && (y < 3 || y >= 4)) return false;
            if (yieldRange === '2-3' && (y < 2 || y >= 3)) return false;
            if (yieldRange === '1-2' && (y < 1 || y >= 2)) return false;
            if (yieldRange === '<1' && y >= 1) return false;
        }
        return true;
    });
    
    // Re-apply current sort
    sortTable(currentSort.col);
}

// Yield Rank Grid (sorted by yield)
function buildYieldRankGrid() {
    const sorted = [...DATA.results].sort((a, b) => b.currentYield - a.currentYield);
    const container = document.getElementById('yieldRankGrid');
    container.innerHTML = sorted.map((r, i) => `
        <div class="yield-rank-item">
            <span class="yield-rank-num">${i + 1}</span>
            <span class="yield-rank-ticker">${r.ticker}</span>
            <span class="yield-rank-name">${r.company}</span>
            <span class="yield-rank-yield">${r.currentYield.toFixed(2)}%</span>
        </div>
    `).join('');
}

// High yield content (top 10)
function buildHighYieldContent() {
    const sorted = [...DATA.results].sort((a, b) => b.currentYield - a.currentYield).slice(0, 10);
    const container = document.getElementById('highYieldContent');
    let html = '<ol style="padding-left:20px; margin: 12px 0;">';
    sorted.forEach(r => {
        html += `<li style="color:#8a9ab0; line-height:1.8;"><strong style="color:#c8d0de;">${r.company} (${r.ticker})</strong> — <span style="color:#48bb78; font-family:JetBrains Mono,monospace;">${r.currentYield.toFixed(2)}%</span> yield, ${r.yearsIncreasing} years of increases</li>`;
    });
    html += '</ol>';
    container.innerHTML = html;
}

// Event listeners
document.querySelectorAll('th[data-col]').forEach(th => {
    th.addEventListener('click', () => sortTable(th.dataset.col));
});
document.getElementById('searchInput').addEventListener('input', applyFilters);
document.getElementById('sectorFilter').addEventListener('change', applyFilters);
document.getElementById('yieldFilter').addEventListener('change', applyFilters);

// Quick sort buttons
document.querySelectorAll('.sort-btn').forEach(btn => {
    btn.addEventListener('click', () => {
        document.querySelectorAll('.sort-btn').forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        const col = btn.dataset.sort;
        const dir = btn.dataset.dir;
        currentSort = { col, dir };
        filteredData.sort((a, b) => {
            let va = a[col], vb = b[col];
            if (va === null || va === undefined) return 1;
            if (vb === null || vb === undefined) return -1;
            if (typeof va === 'string') return dir === 'asc' ? va.localeCompare(vb) : vb.localeCompare(va);
            return dir === 'asc' ? va - vb : vb - va;
        });
        document.querySelectorAll('th').forEach(th => {
            th.classList.remove('sorted-asc', 'sorted-desc');
            if (th.dataset.col === col) th.classList.add(dir === 'asc' ? 'sorted-asc' : 'sorted-desc');
        });
        renderTable();
    });
});

// Init
buildYieldChart();
buildFindings();
buildSectorGrid();
buildYieldRankGrid();
buildHighYieldContent();
sortTable('yearsIncreasing');
  </script>

  
