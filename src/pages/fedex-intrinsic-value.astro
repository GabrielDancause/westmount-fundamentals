---
export const meta = {
  title: "FedEx (FDX) Intrinsic Value: A DCF Analysis",
  description: "We ran a full discounted cash flow on FedEx using FY2025 actuals. One number. Every assumption disclosed. Here's what FedEx is really worth.",
  category: "study",
  published: "2026-03-18",
};

import SiteLayout from "../layouts/SiteLayout.astro";
import * as cheerio from 'cheerio';

const schema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": "FedEx (FDX) Intrinsic Value: A DCF Analysis",
  "description": "A transparent, step-by-step discounted cash flow valuation of FedEx Corporation. Using actual FY2025 financials to arrive at a single fair value estimate for FDX shares.",
  "datePublished": "2026-03-18",
  "dateModified": "2026-03-18",
  "author": {
    "@type": "Organization",
    "name": "Westmount Research",
    "url": "https://westmountfundamentals.com"
  },
  "publisher": {
    "@type": "Organization",
    "name": "Westmount Research",
    "url": "https://westmountfundamentals.com"
  },
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": "https://westmountfundamentals.com/fedex-intrinsic-value"
  }
};

let rawData = {
  price: null,
  shares: null,
  fcf2025: null,
  revenue2025: null,
  netCash2025: null,
  eps2025: null,
  operatingIncome2025: null,
  netIncome2025: null,
  totalDebt2025: null,
  history: {
    revenue: [],
    fcf: [],
    eps: [],
    operatingMargin: [],
    profitMargin: [],
    fcfMargin: []
  }
};

try {
  const headers = {
    'User-Agent': 'Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/115.0.0.0 Safari/537.36',
    'Accept': 'text/html,application/xhtml+xml,application/xml;q=0.9,image/avif,image/webp,image/apng,*/*;q=0.8',
    'Accept-Language': 'en-US,en;q=0.9',
  };

  const [res1, res2, res3] = await Promise.all([
    fetch('https://stockanalysis.com/stocks/fdx/financials/', { headers }),
    fetch('https://stockanalysis.com/stocks/fdx/financials/cash-flow-statement/', { headers }),
    fetch('https://stockanalysis.com/stocks/fdx/financials/balance-sheet/', { headers })
  ]);

  const html1 = await res1.text();
  const html2 = await res2.text();
  const html3 = await res3.text();

  const $1 = cheerio.load(html1);
  const $2 = cheerio.load(html2);
  const $3 = cheerio.load(html3);

  const parseArray = (selector, targetHeader) => {
    let result = null;
    selector('table tbody tr').each((_, el) => {
      const firstTd = selector(el).find('td').first().text().trim();
      if (firstTd === targetHeader) {
        const vals = [];
        selector(el).find('td').each((i, td) => {
          if (i > 0) vals.push(selector(td).text().trim());
        });
        result = vals;
      }
    });
    return result;
  };

  const getVal = (arr, i) => arr && arr[i] ? parseFloat(arr[i].replace(/,/g, '')) : null;

  const ttmPriceMatch = html1.match(/<div class="[^"]*text-4xl[^"]*"[^>]*>([\d\.,]+)<\/div>/);
  if (ttmPriceMatch) {
    rawData.price = parseFloat(ttmPriceMatch[1].replace(/,/g, ''));
  }

  const sharesArr = parseArray($1, 'Shares Outstanding (Diluted)');
  const revArr = parseArray($1, 'Revenue');
  const opIncArr = parseArray($1, 'Operating Income');
  const netIncArr = parseArray($1, 'Net Income');
  const epsArr = parseArray($1, 'EPS (Diluted)');
  const fcfArr = parseArray($2, 'Free Cash Flow');
  const netCashArr = parseArray($3, 'Net Cash (Debt)');
  const totalDebtArr = parseArray($3, 'Total Debt');

  rawData.shares = getVal(sharesArr, 0) !== null ? getVal(sharesArr, 0) : getVal(sharesArr, 1);
  rawData.fcf2025 = getVal(fcfArr, 1);
  rawData.revenue2025 = getVal(revArr, 1);
  rawData.eps2025 = getVal(epsArr, 1);
  rawData.operatingIncome2025 = getVal(opIncArr, 1);
  rawData.netIncome2025 = getVal(netIncArr, 1);
  rawData.netCash2025 = getVal(netCashArr, 1);
  rawData.totalDebt2025 = getVal(totalDebtArr, 1);

  for (let i = 5; i >= 1; i--) {
    const year = 2025 - (i - 1);
    const r = getVal(revArr, i);
    const f = getVal(fcfArr, i);
    const e = getVal(epsArr, i);
    const op = getVal(opIncArr, i);
    const ni = getVal(netIncArr, i);

    if (r !== null) rawData.history.revenue.push({ year, value: r });
    if (f !== null) rawData.history.fcf.push({ year, value: f });
    if (e !== null) rawData.history.eps.push({ year, value: e });

    if (r && op !== null && ni !== null && f !== null) {
      rawData.history.operatingMargin.push(parseFloat(((op / r) * 100).toFixed(2)));
      rawData.history.profitMargin.push(parseFloat(((ni / r) * 100).toFixed(2)));
      rawData.history.fcfMargin.push(parseFloat(((f / r) * 100).toFixed(2)));
    }
  }
} catch (e) {
  console.error("Error fetching financial data:", e);
}

const currentPrice = rawData.price !== null ? rawData.price : 0;
const fcf2025 = rawData.fcf2025 !== null ? rawData.fcf2025 : 0;
const sharesOutstanding = rawData.shares !== null ? rawData.shares : 0;
const netCash = rawData.netCash2025 !== null ? rawData.netCash2025 : 0;

// ASSUMPTIONS
const growthRatePhase1 = 0.05;         // 5% FCF growth, Years 1-5 (Conservative due to capex intensity and cyclical nature)
const growthRateTerminal = 0.025;      // 2.5% perpetuity growth (terminal)
const discountRate = 0.095;            // 9.5% WACC (FedEx has a higher beta and debt load, but 10Y Treasury is 4.18%)

// PHASE 1: PROJECT FCF FOR YEARS 1-5
const projectedFCF = [];
let fcf = fcf2025;
for (let yr = 1; yr <= 5; yr++) {
  fcf = fcf * (1 + growthRatePhase1);
  projectedFCF.push({ year: yr, fcf: Math.round(fcf), pvFactor: 1 / Math.pow(1 + discountRate, yr) });
}
projectedFCF.forEach(p => { p.pvFCF = Math.round(p.fcf * p.pvFactor); });

// PHASE 2: TERMINAL VALUE
const fcfYear6 = projectedFCF[4] ? projectedFCF[4].fcf * (1 + growthRateTerminal) : 0;
const terminalValue = projectedFCF[4] ? Math.round(fcfYear6 / (discountRate - growthRateTerminal)) : 0;
const pvTerminalValue = projectedFCF[4] ? Math.round(terminalValue * projectedFCF[4].pvFactor) : 0;

// ENTERPRISE VALUE & EQUITY VALUE
const pvPhase1 = projectedFCF.reduce((sum, p) => sum + p.pvFCF, 0);
const enterpriseValue = pvPhase1 + pvTerminalValue;
const equityValue = enterpriseValue + netCash;
const intrinsicValuePerShare = sharesOutstanding > 0 ? equityValue / sharesOutstanding : 0;
const roundedIV = Math.round(intrinsicValuePerShare * 100) / 100;

// Market comparison
const marginOfSafety = currentPrice > 0 ? ((roundedIV - currentPrice) / currentPrice * 100).toFixed(1) : "0.0";
const verdictText = roundedIV > currentPrice ? "Undervalued" : "Overvalued";
const verdictColor = roundedIV > currentPrice ? "#10b981" : "#ef4444";

// Sensitivity Analysis
const sensitivityRates = [0.075, 0.085, 0.095, 0.105, 0.115];
const sensitivityGrowth = [0.01, 0.03, 0.05, 0.07, 0.09];
const sensitivityTable = sensitivityRates.map(dr => {
  return {
    dr,
    values: sensitivityGrowth.map(gr => {
      let f = fcf2025;
      let pvSum = 0;
      for (let y = 1; y <= 5; y++) {
        f = f * (1 + gr);
        pvSum += f / Math.pow(1 + dr, y);
      }
      const f6 = f * (1 + growthRateTerminal);
      const tv = f6 / (dr - growthRateTerminal);
      const pvTV = tv / Math.pow(1 + dr, 5);
      return sharesOutstanding > 0 ? Math.round((pvSum + pvTV + netCash) / sharesOutstanding) : 0;
    })
  };
});

// Presentation formatting helpers
const fmt = (num) => num !== null && num !== undefined && !isNaN(num) ? num.toLocaleString() : 'N/A';
const fmtB = (num) => num !== null && num !== undefined && !isNaN(num) ? (num / 1000).toFixed(1) : 'N/A';
const maxRev = rawData.history.revenue.length > 0 ? Math.max(...rawData.history.revenue.map(r => r.value)) : 100000;
const maxFcf = rawData.history.fcf.length > 0 ? Math.max(...rawData.history.fcf.map(r => r.value)) : 5000;
const maxEps = rawData.history.eps.length > 0 ? Math.max(...rawData.history.eps.map(r => r.value)) : 20;

---

<SiteLayout
  site="westmount"
  title="FedEx (FDX) Intrinsic Value: A DCF Analysis"
  description="We ran a full discounted cash flow on FedEx using FY2025 actuals. One number. Every assumption disclosed. Here's what FedEx is really worth."
  canonical="https://westmountfundamentals.com/fedex-intrinsic-value"
  schema={schema}
>
<style is:global>
@import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800;900&family=JetBrains+Mono:wght@400;700;800&display=swap');

*, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
body { font-family: 'Inter', -apple-system, sans-serif; background: #060a12; color: #c8d0de; line-height: 1.7; }
a { color: #4a8fe7; text-decoration: none; }
a:hover { text-decoration: underline; }

.dcf-wrapper { max-width: 900px; margin: 0 auto; padding: 0 24px; }

/* Header */
.header { text-align: center; padding: 80px 24px 60px; background: linear-gradient(180deg, #0a1628 0%, #060a12 100%); position: relative; border-bottom: 1px solid #152040; }
.header::before { content: ''; position: absolute; inset: 0; background: radial-gradient(circle at 50% 40%, rgba(74,143,231,0.06) 0%, transparent 60%); }
.header-content { position: relative; z-index: 1; }
.tag { display: inline-block; background: rgba(74,143,231,0.12); color: #4a8fe7; font-size: 0.75rem; font-weight: 800; padding: 6px 16px; border-radius: 20px; letter-spacing: 1.5px; text-transform: uppercase; margin-bottom: 16px; }
.header-h1 { font-size: 2.8rem; font-weight: 900; color: #fff; letter-spacing: -1.2px; margin-bottom: 16px; line-height: 1.1; }
@media (max-width: 640px) { .header-h1 { font-size: 2rem; } }
.subtitle { color: #7a8a9e; font-size: 1.1rem; max-width: 700px; margin: 0 auto 16px; }
.date { color: #3a4a60; font-size: 0.85rem; font-weight: 600; letter-spacing: 1px; }

/* Big verdict */
.verdict-card { max-width: 560px; margin: 60px auto 0; background: linear-gradient(135deg, #0a1628 0%, #0d1830 100%); border: 2px solid #152040; border-radius: 20px; padding: 48px 32px; text-align: center; box-shadow: 0 20px 60px rgba(0,0,0,0.4); position: relative; overflow: hidden; }
.verdict-card::before { content: ''; position: absolute; top: -60%; left: -20%; width: 140%; height: 120%; background: radial-gradient(ellipse, rgba(74,143,231,0.04) 0%, transparent 70%); }
.verdict-label { font-size: 0.8rem; color: #5a6a80; font-weight: 700; text-transform: uppercase; letter-spacing: 2px; margin-bottom: 12px; position: relative; }
.verdict-price { font-family: 'JetBrains Mono', monospace; font-size: 4.5rem; font-weight: 800; color: #fff; line-height: 1; margin-bottom: 8px; position: relative; }
@media (max-width: 640px) { .verdict-price { font-size: 3rem; } }
.verdict-vs { font-size: 0.95rem; color: #5a6a80; margin-bottom: 20px; position: relative; }
.verdict-badge { display: inline-block; padding: 8px 24px; border-radius: 30px; font-weight: 800; font-size: 0.9rem; letter-spacing: 1px; text-transform: uppercase; position: relative; }

/* Stats */
.stats-row { display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); gap: 16px; margin: 40px auto; max-width: 900px; }
.stat-card { background: #0a1020; border: 1px solid #152040; border-radius: 14px; padding: 24px 16px; text-align: center; }
.stat-value { font-family: 'JetBrains Mono', monospace; font-size: 1.8rem; font-weight: 700; color: #4a8fe7; margin-bottom: 4px; }
.stat-label { font-size: 0.78rem; color: #5a6a80; font-weight: 600; text-transform: uppercase; letter-spacing: 0.5px; }

/* Sections */
.dcf-wrapper h2 { font-size: 1.8rem; font-weight: 800; color: #fff; margin: 60px 0 20px; letter-spacing: -0.5px; border-bottom: 2px solid #152040; padding-bottom: 12px; }
.dcf-wrapper h3 { font-size: 1.3rem; font-weight: 700; color: #e0e6f0; margin: 32px 0 12px; }
.dcf-wrapper p, .dcf-wrapper li { color: #a0aab8; font-size: 1rem; margin-bottom: 16px; }
.dcf-wrapper ul, .dcf-wrapper ol { padding-left: 24px; }
.dcf-wrapper li { margin-bottom: 8px; }
.dcf-wrapper strong { color: #e0e6f0; }

/* Assumption cards */
.assumption-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); gap: 16px; margin: 24px 0 40px; }
.assumption-card { background: #0a1020; border: 1px solid #152040; border-radius: 14px; padding: 24px; }
.assumption-card .label { font-size: 0.75rem; color: #5a6a80; font-weight: 700; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 8px; }
.assumption-card .value { font-family: 'JetBrains Mono', monospace; font-size: 2rem; font-weight: 700; color: #fff; margin-bottom: 8px; }
.assumption-card .rationale { font-size: 0.85rem; color: #7a8a9e; line-height: 1.5; }

/* Tables */
.table-wrap { overflow-x: auto; margin: 24px 0 40px; border-radius: 14px; border: 1px solid #152040; background: #0a1020; }
.dcf-wrapper table { width: 100%; border-collapse: collapse; }
.dcf-wrapper th { background: #0d1428; padding: 14px 16px; font-size: 0.75rem; color: #5a6a80; font-weight: 700; text-transform: uppercase; letter-spacing: 1px; text-align: right; border-bottom: 2px solid #152040; white-space: nowrap; }
.dcf-wrapper th:first-child { text-align: left; }
.dcf-wrapper td { padding: 14px 16px; font-size: 0.9rem; color: #c8d0de; text-align: right; border-bottom: 1px solid #0d1428; font-family: 'JetBrains Mono', monospace; }
.dcf-wrapper td:first-child { text-align: left; font-family: 'Inter', sans-serif; color: #a0aab8; font-weight: 600; }
.dcf-wrapper tr:hover td { background: rgba(74,143,231,0.03); }
.row-total td { font-weight: 800; color: #fff; border-top: 2px solid #1a2a40; background: rgba(74,143,231,0.04); }
td.highlight-cell { color: #4a8fe7; font-weight: 700; }

/* Sensitivity */
.sensitivity-table th.current { background: rgba(74,143,231,0.15); color: #4a8fe7; }
.sensitivity-table td.current { background: rgba(74,143,231,0.08); color: #4a8fe7; font-weight: 700; }

/* Chart bars */
.bar-chart { margin: 24px 0 40px; }
.bar-row { display: flex; align-items: center; gap: 12px; margin-bottom: 10px; }
.bar-label { width: 48px; font-size: 0.85rem; color: #5a6a80; font-weight: 600; text-align: right; flex-shrink: 0; }
.bar-track { flex: 1; background: #0a1020; border-radius: 8px; height: 32px; overflow: hidden; position: relative; }
.bar-fill { height: 100%; border-radius: 8px; display: flex; align-items: center; padding-left: 12px; font-size: 0.8rem; font-weight: 700; color: #fff; font-family: 'JetBrains Mono', monospace; min-width: 80px; transition: width 0.6s ease; }
.bar-fill.revenue { background: linear-gradient(90deg, #1a3a6e, #4a8fe7); }
.bar-fill.fcf { background: linear-gradient(90deg, #1a5a3e, #10b981); }
.bar-fill.eps { background: linear-gradient(90deg, #5a3a7e, #a78bfa); }

/* Methodology */
.method-step { display: flex; gap: 16px; margin-bottom: 24px; padding: 20px; background: #0a1020; border: 1px solid #152040; border-radius: 14px; }
.step-num { width: 40px; height: 40px; background: rgba(74,143,231,0.12); color: #4a8fe7; font-weight: 800; font-size: 1.1rem; border-radius: 50%; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
.step-content { flex: 1; }
.step-content h4 { color: #e0e6f0; font-size: 1rem; margin-bottom: 6px; }
.step-content p { margin-bottom: 0; font-size: 0.9rem; }

/* Disclaimer */
.disclaimer { margin: 60px 0 0; padding: 24px; background: rgba(239,68,68,0.05); border: 1px solid rgba(239,68,68,0.15); border-radius: 14px; }
.disclaimer h4 { color: #ef4444; margin-bottom: 8px; font-size: 0.85rem; text-transform: uppercase; letter-spacing: 1px; }
.disclaimer p { font-size: 0.85rem; color: #7a8a9e; margin-bottom: 0; }

/* Sources */
.sources { margin: 40px 0 60px; padding: 24px; background: #0a1020; border: 1px solid #152040; border-radius: 14px; }
.sources h4 { color: #e0e6f0; margin-bottom: 12px; }
.sources ul { list-style: none; padding: 0; }
.sources li { font-size: 0.85rem; color: #5a6a80; margin-bottom: 6px; padding-left: 16px; position: relative; }
.sources li::before { content: '→'; position: absolute; left: 0; color: #4a8fe7; }

/* Cite */
.cite-block { margin: 40px 0; padding: 20px 24px; background: #0a1020; border-left: 3px solid #4a8fe7; border-radius: 0 14px 14px 0; }
.cite-block h4 { color: #e0e6f0; margin-bottom: 8px; font-size: 0.85rem; }
.cite-block p { font-size: 0.85rem; color: #7a8a9e; margin-bottom: 0; font-family: 'JetBrains Mono', monospace; }

/* FAQ */
.faq { margin: 40px 0; }
.faq details { background: #0a1020; border: 1px solid #152040; border-radius: 14px; margin-bottom: 12px; overflow: hidden; }
.faq summary { padding: 18px 20px; cursor: pointer; font-weight: 700; color: #e0e6f0; font-size: 1rem; list-style: none; display: flex; justify-content: space-between; align-items: center; }
.faq summary::after { content: '+'; font-size: 1.2rem; color: #4a8fe7; transition: transform 0.2s; }
.faq details[open] summary::after { content: '−'; }
.faq .faq-answer { padding: 0 20px 18px; font-size: 0.9rem; color: #a0aab8; }

@media (max-width: 640px) {
  .stats-row { grid-template-columns: repeat(2, 1fr); }
  .assumption-grid { grid-template-columns: 1fr; }
  .verdict-card { padding: 32px 20px; }
}
</style>

<div class="header">
  <div class="header-content">
    <div class="tag">Original Research</div>
    <h1 class="header-h1">FedEx (FDX)<br/>Intrinsic Value</h1>
    <p class="subtitle">A transparent, two-stage discounted cash flow valuation of FedEx Corporation — using FY2025 actuals, disclosed assumptions, and one final number.</p>
    <p class="date">Compiled by Gemini 3.1 · Updated March 18, 2026 · Data: FY2025 10-K</p>
  </div>
</div>

<div class="dcf-wrapper">
  <!-- ═══ THE VERDICT ═══ -->
  <div class="verdict-card">
    <div class="verdict-label">Estimated Intrinsic Value Per Share</div>
    <div class="verdict-price">${roundedIV.toFixed(2)}</div>
    <div class="verdict-vs">vs. market price of ${currentPrice.toFixed(2)} ({marginOfSafety}%)</div>
    <div class="verdict-badge" style={`background: ${verdictColor}22; color: ${verdictColor}; border: 1px solid ${verdictColor}44;`}>
      {verdictText}
    </div>
  </div>

  <!-- ═══ KEY METRICS ═══ -->
  <div class="stats-row">
    <div class="stat-card">
      <div class="stat-value">${fmtB(rawData.revenue2025)}B</div>
      <div class="stat-label">FY2025 Revenue</div>
    </div>
    <div class="stat-card">
      <div class="stat-value">${fmtB(fcf2025)}B</div>
      <div class="stat-label">Free Cash Flow</div>
    </div>
    <div class="stat-card">
      <div class="stat-value">${rawData.eps2025 !== null ? rawData.eps2025.toFixed(2) : 'N/A'}</div>
      <div class="stat-label">EPS (Diluted)</div>
    </div>
    <div class="stat-card">
      <div class="stat-value">
        {rawData.operatingIncome2025 !== null && rawData.revenue2025 ? ((rawData.operatingIncome2025 / rawData.revenue2025) * 100).toFixed(1) : 'N/A'}%
      </div>
      <div class="stat-label">Operating Margin</div>
    </div>
    <div class="stat-card">
      <div class="stat-value">${fmtB(netCash)}B</div>
      <div class="stat-label">Net Cash (Debt)</div>
    </div>
  </div>

  <!-- ═══ METHODOLOGY ═══ -->
  <h2>Methodology: Two-Stage DCF</h2>
  <p>We use a <strong>two-stage discounted cash flow (DCF)</strong> model to calculate intrinsic value. No multiples, no comparables. Just future cash flows discounted to today.</p>

  <div class="method-step">
    <div class="step-num">1</div>
    <div class="step-content">
      <h4>Start with actual Free Cash Flow</h4>
      <p>FedEx generated <strong>${fmtB(fcf2025)} billion</strong> in free cash flow in FY2025. This is the operating cash flow minus capital expenditures — representing the real cash the business produces after reinvesting in its massive global logistics network.</p>
    </div>
  </div>

  <div class="method-step">
    <div class="step-num">2</div>
    <div class="step-content">
      <h4>Project FCF growth for 5 years (Phase 1)</h4>
      <p>We grow FCF at <strong>5% per year</strong> for 5 years. FedEx operates in a mature, highly competitive, and capital-intensive industry. While DRIVE initiatives aim to improve profitability and reduce structural costs, cyclical macroeconomic factors and ongoing fleet modernization cap outsized free cash flow growth.</p>
    </div>
  </div>

  <div class="method-step">
    <div class="step-num">3</div>
    <div class="step-content">
      <h4>Calculate terminal value (Phase 2)</h4>
      <p>After Year 5, we assume FCF grows at <strong>2.5% forever</strong>. This is slightly below long-term GDP growth, reflecting the capital intensity of the logistics and transportation sector and the constant need for fleet maintenance and upgrades. We use the Gordon Growth Model.</p>
    </div>
  </div>

  <div class="method-step">
    <div class="step-num">4</div>
    <div class="step-content">
      <h4>Discount everything to present value</h4>
      <p>All future cash flows are discounted at <strong>9.5%</strong>. With the 10Y Treasury at 4.18%, an equity risk premium of ~5.5%, and a standard beta for transportation stalwarts, 9.5% provides a reasonable hurdle rate that accounts for macroeconomic sensitivity.</p>
    </div>
  </div>

  <div class="method-step">
    <div class="step-num">5</div>
    <div class="step-content">
      <h4>Add net cash, divide by shares</h4>
      <p>Enterprise Value + Net Cash (Debt) = Equity Value. Divide by shares outstanding ({fmt(sharesOutstanding)}M) for the per-share intrinsic value. FedEx carries significant debt, so Net Cash is heavily negative, reducing equity value appropriately.</p>
    </div>
  </div>

  <!-- ═══ THE THREE ASSUMPTIONS ═══ -->
  <h2>The Three Assumptions That Drive Everything</h2>
  <p>A DCF relies heavily on judgment calls for the future. Here are our core assumptions and the rationale behind them.</p>

  <div class="assumption-grid">
    <div class="assumption-card">
      <div class="label">FCF Growth Rate (Years 1-5)</div>
      <div class="value">{(growthRatePhase1 * 100).toFixed(1)}%</div>
      <div class="rationale">
        FedEx is currently engaged in its "DRIVE" transformation program, aimed at structural cost reductions and network consolidation (combining Express and Ground). While margins may expand, top-line growth is tied to global GDP and e-commerce trends. 5% FCF growth balances cost-savings execution with cyclical economic risks and ongoing capex needs.
      </div>
    </div>
    <div class="assumption-card">
      <div class="label">Discount Rate (WACC)</div>
      <div class="value">{(discountRate * 100).toFixed(1)}%</div>
      <div class="rationale">
        10Y Treasury: 4.18%. FedEx is highly sensitive to global economic cycles, fuel prices, and labor markets. A 9.5% discount rate represents the required return to compensate investors for the economic cyclicality and capital intensity inherent in a global airline and trucking fleet.
      </div>
    </div>
    <div class="assumption-card">
      <div class="label">Terminal Growth Rate</div>
      <div class="value">{(growthRateTerminal * 100).toFixed(1)}%</div>
      <div class="rationale">
        Logistics is a physical business requiring physical assets. We assume 2.5% terminal growth, slightly below standard nominal GDP growth, to account for the continuous capital expenditure required to maintain planes, hubs, and vehicles in perpetuity.
      </div>
    </div>
  </div>

