        const formatMoney = (val) => {
            if (!val) return 'N/A';
            if (val >= 1e12) return '$' + (val / 1e12).toFixed(2) + 'T';
            if (val >= 1e9) return '$' + (val / 1e9).toFixed(2) + 'B';
            if (val >= 1e6) return '$' + (val / 1e6).toFixed(2) + 'M';
            return '$' + val.toLocaleString();
        };

        const formatPct = (val) => {
            if (val === null || val === undefined) return 'N/A';
            return val.toFixed(2) + '%';
        };

        const getColorClass = (val) => {
            if (val === null || val === undefined) return '';
            return val >= 0 ? 'value-green' : 'value-red';
        };

        const chartColors = ['#4a8fe7', '#10b981', '#f59e0b'];
        let returnsChartObj = null;
        let sectorsChartObj = null;

        function init() {
            const select1 = document.getElementById('etf1');
            const select2 = document.getElementById('etf2');
            const select3 = document.getElementById('etf3');

            const tickers = Object.keys(etfData).sort();

            tickers.forEach(t => {
                const name = etfData[t].name || t;
                const optText = `${t} - ${name.length > 30 ? name.substring(0,30)+'...' : name}`;

                select1.add(new Option(optText, t));
                select2.add(new Option(optText, t));
                select3.add(new Option(optText, t));
            });

            // Defaults
            select1.value = 'VOO';
            select2.value = 'VTI';
            select3.value = 'QQQ';

            updateComparison();
        }

        function updateComparison() {
            const t1 = document.getElementById('etf1').value;
            const t2 = document.getElementById('etf2').value;
            const t3 = document.getElementById('etf3').value;

            const selected = [t1, t2, t3].filter(t => t !== '');
            renderGrid(selected);
            renderCharts(selected);
        }

        function renderGrid(tickers) {
            const container = document.getElementById('comparison-container');

            // Calculate grid columns based on number of selected ETFs
            const gridTemplate = `200px repeat(${tickers.length}, minmax(200px, 1fr))`;

            let html = `<div class="comparison-grid" style="grid-template-columns: ${gridTemplate}">`;

            // Headers
            html += `<div class="grid-cell grid-header" style="background:transparent; border-bottom: none;"></div>`;
            tickers.forEach(t => {
                html += `<div class="grid-cell grid-header">${t}</div>`;
            });

            // Fundamentals Section
            html += `<div class="section-header">Key Fundamentals</div>`;

            // Name
            html += `<div class="grid-cell grid-label">Fund Name</div>`;
            tickers.forEach(t => html += `<div class="grid-cell grid-value" style="font-family:'Inter',sans-serif;font-size:0.9rem;">${etfData[t].name}</div>`);

            // Expense Ratio
            html += `<div class="grid-cell grid-label">Expense Ratio</div>`;
            tickers.forEach(t => html += `<div class="grid-cell grid-value">${formatPct(etfData[t].expenseRatio)}</div>`);

            // Yield
            html += `<div class="grid-cell grid-label">Dividend Yield</div>`;
            tickers.forEach(t => html += `<div class="grid-cell grid-value">${formatPct(etfData[t].yield)}</div>`);

            // AUM
            html += `<div class="grid-cell grid-label">AUM</div>`;
            tickers.forEach(t => html += `<div class="grid-cell grid-value">${formatMoney(etfData[t].aum)}</div>`);

            // Performance Section
            html += `<div class="section-header">Trailing Returns</div>`;

            ['oneYear', 'threeYear', 'fiveYear'].forEach(period => {
                const label = period === 'oneYear' ? '1 Year' : period === 'threeYear' ? '3 Year' : '5 Year';
                html += `<div class="grid-cell grid-label">${label} Return</div>`;
                tickers.forEach(t => {
                    const val = etfData[t].returns[period];
                    html += `<div class="grid-cell grid-value ${getColorClass(val)}">${formatPct(val)}</div>`;
                });
            });

            // Top Holdings Section
            html += `<div class="section-header">Top 10 Holdings</div>`;
            html += `<div class="grid-cell grid-label" style="align-items:flex-start; padding-top:1.5rem;">Largest Positions</div>`;
            tickers.forEach(t => {
                const holdings = etfData[t].holdings || [];
                let hHtml = '<ul class="holdings-list">';
                holdings.forEach(h => {
                    hHtml += `<li><span class="h-symbol">${h.symbol}</span> <span class="h-percent">${(h.percent*100).toFixed(2)}%</span></li>`;
                });
                hHtml += '</ul>';
                if(holdings.length === 0) hHtml = '<div style="text-align:right;color:#94a3b8;">Data unavailable</div>';
                html += `<div class="grid-cell">${hHtml}</div>`;
            });

            html += `</div>`;
            container.innerHTML = html;
        }

        function renderCharts(tickers) {
            // Returns Chart
            const returnsCtx = document.getElementById('returnsChart').getContext('2d');
            if (returnsChartObj) returnsChartObj.destroy();

            const datasets = tickers.map((t, i) => ({
                label: t,
                data: [
                    etfData[t].returns.oneYear || 0,
                    etfData[t].returns.threeYear || 0,
                    etfData[t].returns.fiveYear || 0
                ],
                backgroundColor: chartColors[i % chartColors.length]
            }));

            returnsChartObj = new Chart(returnsCtx, {
                type: 'bar',
                data: {
                    labels: ['1 Year', '3 Year', '5 Year'],
                    datasets: datasets
                },
                options: {
                    responsive: true,
                    scales: {
                        y: {
                            ticks: {
                                callback: function(value) { return value + '%'; },
                                color: '#94a3b8'
                            },
                            grid: { color: '#152040' }
                        },
                        x: {
                            ticks: { color: '#94a3b8' },
                            grid: { display: false }
                        }
                    },
                    plugins: {
                        legend: { labels: { color: '#e2e8f0' } }
                    }
                }
            });

            // Sectors Chart (Radar)
            const sectorsCtx = document.getElementById('sectorsChart').getContext('2d');
            if (sectorsChartObj) sectorsChartObj.destroy();

            // Collect all unique sectors across selected ETFs
            const allSectors = new Set();
            tickers.forEach(t => {
                Object.keys(etfData[t].sectors || {}).forEach(s => allSectors.add(s));
            });
            const sectorLabels = Array.from(allSectors).map(s => {
                // Formatting sector names: 'technology' -> 'Technology'
                return s.replace(/_/g, ' ').replace(/\b\w/g, l => l.toUpperCase());
            });

            const sectorDatasets = tickers.map((t, i) => {
                const data = Array.from(allSectors).map(s => {
                    return (etfData[t].sectors && etfData[t].sectors[s]) ? etfData[t].sectors[s] * 100 : 0;
                });

                // Convert hex to rgba for radar fill
                let hex = chartColors[i % chartColors.length];
                let r = parseInt(hex.slice(1, 3), 16),
                    g = parseInt(hex.slice(3, 5), 16),
                    b = parseInt(hex.slice(5, 7), 16);

                return {
                    label: t,
                    data: data,
                    backgroundColor: `rgba(${r}, ${g}, ${b}, 0.2)`,
                    borderColor: hex,
                    pointBackgroundColor: hex,
                    borderWidth: 2
                };
            });

            sectorsChartObj = new Chart(sectorsCtx, {
                type: 'radar',
                data: {
                    labels: sectorLabels,
                    datasets: sectorDatasets
                },
                options: {
                    responsive: true,
                    scales: {
                        r: {
                            angleLines: { color: '#152040' },
                            grid: { color: '#152040' },
                            pointLabels: { color: '#94a3b8', font: { size: 11 } },
                            ticks: { display: false, min: 0 }
                        }
                    },
                    plugins: {
                        legend: { labels: { color: '#e2e8f0' } }
                    }
                }
            });
        }

        // Initialize on load
        window.onload = init;
  </script>
