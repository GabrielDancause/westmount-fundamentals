  <script is:inline>
    (function() {
      const initialEl = document.getElementById('initial-balance');
      const monthlyEl = document.getElementById('monthly-contribution');
      const yearsEl = document.getElementById('years-to-grow');
      const rateEl = document.getElementById('expected-return');
      const errorMsg = document.getElementById('error-msg');

      const resFuture = document.getElementById('res-future-value');
      const resPrincipal = document.getElementById('res-total-principal');
      const resInterest = document.getElementById('res-total-interest');

      const inputs = [initialEl, monthlyEl, yearsEl, rateEl];

      inputs.forEach(input => {
        input.addEventListener('input', calculate);
      });

      function calculate() {
        const p = parseFloat(initialEl.value);
        const pmt = parseFloat(monthlyEl.value);
        const t = parseFloat(yearsEl.value);
        const rPercent = parseFloat(rateEl.value);

        if (isNaN(p) || isNaN(pmt) || isNaN(t) || isNaN(rPercent) || p < 0 || pmt < 0 || t <= 0 || rPercent < 0) {
          errorMsg.textContent = 'Please enter valid positive numbers for all fields.';
          errorMsg.style.display = 'block';
          resFuture.textContent = '$0.00';
          resPrincipal.textContent = '$0.00';
          resInterest.textContent = '$0.00';
          return;
        }

        errorMsg.style.display = 'none';

        const r = rPercent / 100;
        const n = 12; // Compounded monthly

        let futureValue = 0;

        // Compound interest formula for principal
        const compoundPrincipal = p * Math.pow(1 + (r / n), n * t);

        // Future value of a series formula for monthly contributions
        // FV = PMT * [((1 + r/n)^(nt) - 1) / (r/n)]
        const compoundContributions = pmt * ((Math.pow(1 + (r / n), n * t) - 1) / (r / n));

        if (r === 0) {
           // If interest rate is 0, just add up principal and contributions
           futureValue = p + (pmt * n * t);
        } else {
           futureValue = compoundPrincipal + compoundContributions;
        }

        const totalPrincipal = p + (pmt * n * t);
        const totalInterest = Math.max(0, futureValue - totalPrincipal);

        const formatter = new Intl.NumberFormat('en-US', {
          style: 'currency',
          currency: 'USD',
          maximumFractionDigits: 0
        });

        resFuture.textContent = formatter.format(futureValue);
        resPrincipal.textContent = formatter.format(totalPrincipal);
        resInterest.textContent = formatter.format(totalInterest);
      }

      // Initialize
      calculate();
    })();
  </script>

