---
import SiteLayout from "../layouts/SiteLayout.astro";

export const meta = { title: "Earnings Per Share Calculator | EPS Formula, Diluted EPS & Growth Rate", description: "Calculate basic EPS, diluted EPS, EPS growth rate (CAGR), and P/E ratio with our free earnings per share calculator. Compare Magnificent 7 EPS with interactive charts.", category: "study", published: "2026-03-20" };

const schema = JSON.stringify([
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": "Earnings Per Share Calculator | EPS Formula, Diluted EPS & Growth Rate",
    "description": "Calculate basic EPS, diluted EPS, EPS growth rate, and P/E ratio. Compare Magnificent 7 EPS and track S&P 500 EPS growth with interactive Chart.js visualizations.",
    "author": { "@type": "Organization", "name": "Westmount Fundamentals" },
    "publisher": { "@type": "Organization", "name": "Westmount Fundamentals", "url": "https://westmountfundamentals.com" },
    "datePublished": "2026-03-20",
    "mainEntityOfPage": "https://westmountfundamentals.com/earnings-per-share-calculator/"
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "What is earnings per share (EPS)?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Earnings per share (EPS) measures the portion of a company's net profit allocated to each outstanding share of common stock. It is calculated as (Net Income − Preferred Dividends) ÷ Weighted Average Shares Outstanding. EPS is the single most widely followed profitability metric on Wall Street and forms the denominator of the P/E ratio."
        }
      },
      {
        "@type": "Question",
        "name": "How do you calculate diluted EPS?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Diluted EPS accounts for all potentially dilutive securities — stock options, convertible bonds, and warrants — that could increase the share count. The treasury stock method assumes in-the-money options are exercised and proceeds are used to buy back shares at the average market price. Diluted EPS = (Net Income − Preferred Dividends) ÷ (Weighted Average Shares + Net Dilutive Shares)."
        }
      },
      {
        "@type": "Question",
        "name": "What is the difference between basic and diluted EPS?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Basic EPS uses only the actual shares outstanding, while diluted EPS includes the impact of all potentially dilutive securities (options, warrants, convertible bonds). Diluted EPS is always less than or equal to basic EPS. A large gap between the two signals significant potential dilution, which is common in tech companies with heavy stock-based compensation."
        }
      },
      {
        "@type": "Question",
        "name": "How do you calculate EPS growth rate?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Year-over-year EPS growth is calculated as ((Current EPS − Prior EPS) ÷ |Prior EPS|) × 100. For multi-year growth, use the compound annual growth rate (CAGR) formula: ((Ending EPS ÷ Beginning EPS)^(1/n) − 1) × 100, where n is the number of years. Consistent double-digit EPS growth is a hallmark of high-quality compounders."
        }
      },
      {
        "@type": "Question",
        "name": "Can EPS be manipulated?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes. Companies can inflate EPS through share buybacks (reducing share count without improving profits), one-time gains, aggressive revenue recognition, or excluding recurring costs as 'non-recurring.' Always compare GAAP EPS to non-GAAP EPS, check if buyback-driven EPS growth outpaces actual net income growth, and examine cash flow from operations for confirmation."
        }
      }
    ]
  }
]);
---

<SiteLayout site="westmount" title={meta.title} description={meta.description} canonical="https://westmountfundamentals.com/earnings-per-share-calculator/" schema={schema}>
  <div style="max-width:1280px;margin:0 auto;padding:16px 24px 0;display:flex;justify-content:space-between;align-items:center;font-size:13px;color:var(--text-dim,#94a3b8)">
    <nav aria-label="Breadcrumb"><a href="/" style="color:var(--text-dim,#94a3b8);text-decoration:none">Home</a> <span style="margin:0 6px;opacity:0.5">›</span> <a href="/study/" style="color:var(--text-dim,#94a3b8);text-decoration:none">Study</a> <span style="margin:0 6px;opacity:0.5">›</span> <span style="color:var(--text-primary,#c8d0de)">Earnings Per Share Calculator</span></nav>
    <span>10 min read</span>
  </div>

  <div class="container page-content">
    <h1>Earnings Per Share Calculator</h1>
    <p style="text-align:center;max-width:680px;margin:0 auto 2.5rem;color:var(--text-secondary,#94a3b8)">Calculate basic EPS, diluted EPS, EPS growth rate (CAGR), and P/E ratio. The most important profitability metric on Wall Street — explained and calculated for free.</p>

    <!-- Stat Cards -->
    <div class="stats-grid">
      <div class="stat-card">
        <span class="stat-number">$240</span>
        <span class="stat-label">S&P 500 EPS (2025 est.)</span>
      </div>
      <div class="stat-card">
        <span class="stat-number">22×</span>
        <span class="stat-label">S&P 500 Forward P/E</span>
      </div>
      <div class="stat-card">
        <span class="stat-number">8.5%</span>
        <span class="stat-label">10-Year S&P 500 EPS CAGR</span>
      </div>
      <div class="stat-card">
        <span class="stat-number">$22.10</span>
        <span class="stat-label">Highest Mag 7 EPS (META)</span>
      </div>
    </div>

    <!-- Basic EPS Calculator -->
    <div class="calculator-card" id="basic-eps-calculator">
      <h2>Basic EPS Calculator</h2>
      <p class="calc-desc">Calculate basic earnings per share using the EPS formula: <strong>(Net Income − Preferred Dividends) ÷ Weighted Average Shares Outstanding</strong>.</p>
      <div class="calc-grid">
        <div class="input-panel">
          <div class="input-group">
            <label for="eps-net-income">Net Income</label>
            <div class="input-wrapper"><span class="prefix">$</span><input type="number" id="eps-net-income" value="500000000" min="0" step="1000000"></div>
          </div>
          <div class="input-group">
            <label for="eps-preferred-div">Preferred Dividends</label>
            <div class="input-wrapper"><span class="prefix">$</span><input type="number" id="eps-preferred-div" value="0" min="0" step="100000"></div>
          </div>
          <div class="input-group">
            <label for="eps-shares">Weighted Average Shares Outstanding</label>
            <div class="input-wrapper"><input type="number" id="eps-shares" value="100000000" min="1" step="1000000"><span class="suffix">shares</span></div>
          </div>
        </div>
        <div class="results-panel">
          <div class="result-box primary-result">
            <span class="calc-result-label">Basic Earnings Per Share</span>
            <span class="calc-result-value" id="basic-eps-result">$5.00</span>
          </div>
          <div class="secondary-results">
            <div class="result-item"><span class="result-label">Net Income Available to Common</span><span class="result-value" id="eps-net-available">$500,000,000</span></div>
            <div class="result-item"><span class="result-label">Annual Earnings (per share)</span><span class="result-value" id="eps-annual">$5.00</span></div>
          </div>
        </div>
      </div>
    </div>

    <!-- Diluted EPS Calculator -->
    <div class="calculator-card" id="diluted-eps-calculator">
      <h2>Diluted EPS Calculator</h2>
      <p class="calc-desc">Calculate diluted EPS using the treasury stock method. Add potentially dilutive securities to see the impact on earnings per share.</p>
      <div class="calc-grid">
        <div class="input-panel">
          <div class="input-group">
            <label for="dil-options">Stock Options (in-the-money)</label>
            <div class="input-wrapper"><input type="number" id="dil-options" value="5000000" min="0" step="100000"><span class="suffix">shares</span></div>
          </div>
          <div class="input-group">
            <label for="dil-option-price">Average Option Exercise Price</label>
            <div class="input-wrapper"><span class="prefix">$</span><input type="number" id="dil-option-price" value="30" min="0" step="1"></div>
          </div>
