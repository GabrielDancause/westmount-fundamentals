            <div class="input-wrapper"><span class="prefix">$</span><input type="number" id="growth-eps1" value="3.50" min="0" step="0.01"></div>
          </div>
          <div class="input-group">
            <label for="growth-eps2">Year 2 EPS (later)</label>
            <div class="input-wrapper"><span class="prefix">$</span><input type="number" id="growth-eps2" value="5.00" min="0" step="0.01"></div>
          </div>
