          </div>
          <div class="input-group">
            <label for="dil-convertible">Convertible Bond Shares</label>
            <div class="input-wrapper"><input type="number" id="dil-convertible" value="2000000" min="0" step="100000"><span class="suffix">shares</span></div>
          </div>
          <div class="input-group">
            <label for="dil-warrants">Warrant Shares</label>
            <div class="input-wrapper"><input type="number" id="dil-warrants" value="1000000" min="0" step="100000"><span class="suffix">shares</span></div>
          </div>
          <div class="input-group">
            <label for="dil-warrant-price">Average Warrant Exercise Price</label>
