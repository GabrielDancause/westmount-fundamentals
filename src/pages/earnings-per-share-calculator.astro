  }
  input[type="number"]::-webkit-outer-spin-button,
  input[type="number"]::-webkit-inner-spin-button {
    -webkit-appearance: none;
    margin: 0;
  }
  input[type="number"]:focus {
    outline: none;
    border-color: var(--accent, #4a8fe7);
  }
  .results-panel {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    background: var(--bg-color, #010409);
    border: 1px solid var(--border, #30363d);
    border-radius: 12px;
    padding: 1.5rem;
  }
  .result-box.primary-result {
    text-align: center;
    padding: 1.5rem 0;
  }
  .calc-result-label {
    display: block;
    font-size: 0.85rem;
    color: var(--text-secondary, #94a3b8);
    margin-bottom: 0.5rem;
  }
  .calc-result-value {
    display: block;
    font-size: 2.2rem;
    font-weight: 700;
    color: var(--accent, #4a8fe7);
    font-family: var(--font-mono, monospace);
  }
  .secondary-results {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  .result-item {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.5rem 0;
    border-top: 1px solid var(--border, #30363d);
  }
  .result-label {
    font-size: 0.85rem;
    color: var(--text-secondary, #94a3b8);
  }
  .result-value {
    font-family: var(--font-mono, monospace);
    font-weight: 600;
    color: var(--text-primary, #c8d0de);
  }
  .multi-year-divider {
    text-align: center;
    padding: 0.75rem 0 0.25rem;
    font-size: 0.82rem;
    color: var(--text-secondary, #94a3b8);
    border-top: 1px solid var(--border, #30363d);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  .chart-container {
    background: var(--bg-card, #0d1117);
    border: 1px solid var(--border, #30363d);
    border-radius: 12px;
    padding: 1.5rem;
    margin: 1.5rem 0;
    max-height: 500px;
  }
  .content-section {
    margin: 3rem 0;
  }
  .highlight-box {
    background: var(--bg-card, #0d1117);
    border: 1px solid var(--border, #30363d);
    border-left: 4px solid var(--accent, #4a8fe7);
    border-radius: 8px;
    padding: 1.5rem;
    margin: 1.5rem 0;
  }
  .highlight-box code {
    display: block;
    font-size: 1.1rem;
    color: var(--accent, #4a8fe7);
    margin-top: 0.5rem;
  }
  .two-col {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
    margin: 1.5rem 0;
  }
  .col-card {
    border: 1px solid var(--border, #30363d);
    border-radius: 12px;
    padding: 1.5rem;
    background: var(--bg-card, #0d1117);
  }
  .col-card h3 { margin-top: 0; font-size: 1.1rem; }
  .col-card ul { padding-left: 1.2rem; }
  .col-card li { margin-bottom: 0.75rem; font-size: 0.9rem; line-height: 1.5; color: var(--text-secondary, #94a3b8); }
  .positive-card { border-left: 3px solid var(--positive, #10b981); }
  .negative-card { border-left: 3px solid var(--negative, #ef4444); }
  .red-flags-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.25rem;
    margin: 1.5rem 0;
  }
  .flag-card {
    background: var(--bg-card, #0d1117);
    border: 1px solid var(--border, #30363d);
    border-radius: 12px;
    padding: 1.5rem;
    border-top: 3px solid var(--negative, #ef4444);
  }
  .flag-icon {
    font-size: 1.5rem;
    display: block;
    margin-bottom: 0.5rem;
  }
  .flag-card h4 {
    margin: 0 0 0.5rem;
    font-size: 1rem;
    color: var(--text-primary, #c8d0de);
  }
  .flag-card p {
    margin: 0;
    font-size: 0.88rem;
    color: var(--text-secondary, #94a3b8);
    line-height: 1.5;
  }
  .insights-list {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }
  .insight-item {
    display: flex;
    gap: 1.25rem;
    align-items: flex-start;
    background: var(--bg-card, #0d1117);
    border: 1px solid var(--border, #30363d);
    border-radius: 10px;
    padding: 1.25rem;
  }
  .insight-num {
    display: flex;
    align-items: center;
    justify-content: center;
    min-width: 2.5rem;
    height: 2.5rem;
    border-radius: 50%;
    background: var(--accent, #4a8fe7);
    color: #fff;
    font-weight: 700;
    font-size: 1.1rem;
    flex-shrink: 0;
  }
  .insight-item h4 {
    margin: 0 0 0.4rem;
    font-size: 1rem;
  }
  .insight-item p {
    margin: 0;
    font-size: 0.88rem;
    color: var(--text-secondary, #94a3b8);
    line-height: 1.5;
  }
  .faq-list {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  .faq-item {
    background: var(--bg-card, #0d1117);
    border: 1px solid var(--border, #30363d);
    border-radius: 10px;
    padding: 1rem 1.25rem;
  }
  .faq-item summary {
    cursor: pointer;
    font-weight: 600;
    font-size: 0.95rem;
    list-style: none;
  }
  .faq-item summary::-webkit-details-marker { display: none; }
  .faq-item summary::before {
    content: "+";
    display: inline-block;
    width: 1.5rem;
    font-weight: 700;
    color: var(--accent, #4a8fe7);
  }
  .faq-item[open] summary::before { content: "\2212"; }
  .faq-item p {
    margin: 0.75rem 0 0 1.5rem;
    font-size: 0.9rem;
    color: var(--text-secondary, #94a3b8);
    line-height: 1.6;
  }
  @media (max-width: 900px) {
    .stats-grid { grid-template-columns: repeat(2, 1fr); }
    .calc-grid { grid-template-columns: 1fr; }
    .two-col { grid-template-columns: 1fr; }
    .red-flags-grid { grid-template-columns: 1fr; }
  }
  @media (max-width: 600px) {
    .stats-grid { grid-template-columns: 1fr 1fr; }
  }
</style>

<script is:inline src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script is:inline>
  document.addEventListener("DOMContentLoaded", function() {
    var fmt = new Intl.NumberFormat("en-US", { style: "currency", currency: "USD", maximumFractionDigits: 2 });
    var fmtLarge = new Intl.NumberFormat("en-US", { style: "currency", currency: "USD", maximumFractionDigits: 0 });
    var fmtNum = new Intl.NumberFormat("en-US");

    // --- Basic EPS Calculator ---
    var epsNetIncome = document.getElementById("eps-net-income");
    var epsPrefDiv = document.getElementById("eps-preferred-div");
    var epsShares = document.getElementById("eps-shares");
    var basicEpsResult = document.getElementById("basic-eps-result");
    var epsNetAvailable = document.getElementById("eps-net-available");
    var epsAnnual = document.getElementById("eps-annual");

    // Diluted EPS fields
    var dilOptions = document.getElementById("dil-options");
    var dilOptionPrice = document.getElementById("dil-option-price");
    var dilMarketPrice = document.getElementById("dil-market-price");
    var dilConvertible = document.getElementById("dil-convertible");
    var dilWarrants = document.getElementById("dil-warrants");
    var dilWarrantPrice = document.getElementById("dil-warrant-price");
    var dilutedEpsResult = document.getElementById("diluted-eps-result");
    var dilBasicRef = document.getElementById("dil-basic-ref");
    var dilNetShares = document.getElementById("dil-net-shares");
    var dilTotalShares = document.getElementById("dil-total-shares");
    var dilImpact = document.getElementById("dil-impact");

    // Growth fields
    var growthEps1 = document.getElementById("growth-eps1");
    var growthEps2 = document.getElementById("growth-eps2");
    var growthEps3 = document.getElementById("growth-eps3");
    var growthEps4 = document.getElementById("growth-eps4");
    var growthEps5 = document.getElementById("growth-eps5");
    var growthYoyResult = document.getElementById("growth-yoy-result");
    var growthChange = document.getElementById("growth-change");
    var growthCagr = document.getElementById("growth-cagr");
    var growthYears = document.getElementById("growth-years");

    // P/E fields
    var peStockPrice = document.getElementById("pe-stock-price");
    var peEps = document.getElementById("pe-eps");
    var peResult = document.getElementById("pe-result");
    var peInterp = document.getElementById("pe-interpretation");
    var peEarningsYield = document.getElementById("pe-earnings-yield");

    function calcBasicEPS() {
      var netIncome = parseFloat(epsNetIncome.value) || 0;
      var prefDiv = parseFloat(epsPrefDiv.value) || 0;
      var shares = parseFloat(epsShares.value) || 1;
      if (shares < 1) shares = 1;

      var available = netIncome - prefDiv;
      var eps = available / shares;

      basicEpsResult.textContent = fmt.format(eps);
      epsNetAvailable.textContent = fmtLarge.format(available);
      epsAnnual.textContent = fmt.format(eps);

      // Auto-fill P/E calculator
      peEps.value = eps.toFixed(2);
      calcPE();
      calcDilutedEPS();
    }

    function calcDilutedEPS() {
      var netIncome = parseFloat(epsNetIncome.value) || 0;
      var prefDiv = parseFloat(epsPrefDiv.value) || 0;
      var shares = parseFloat(epsShares.value) || 1;
      if (shares < 1) shares = 1;
      var available = netIncome - prefDiv;
      var basicEps = available / shares;

      var options = parseFloat(dilOptions.value) || 0;
      var optionPrice = parseFloat(dilOptionPrice.value) || 0;
      var marketPrice = parseFloat(dilMarketPrice.value) || 0.01;
      if (marketPrice <= 0) marketPrice = 0.01;
      var convertible = parseFloat(dilConvertible.value) || 0;
      var warrants = parseFloat(dilWarrants.value) || 0;
      var warrantPrice = parseFloat(dilWarrantPrice.value) || 0;

      // Treasury stock method for options
      var netOptionShares = 0;
      if (optionPrice < marketPrice && options > 0) {
        var buybackShares = Math.floor((options * optionPrice) / marketPrice);
        netOptionShares = options - buybackShares;
      }

      // Treasury stock method for warrants
      var netWarrantShares = 0;
      if (warrantPrice < marketPrice && warrants > 0) {
        var warrantBuyback = Math.floor((warrants * warrantPrice) / marketPrice);
        netWarrantShares = warrants - warrantBuyback;
      }

      var totalDilutiveShares = netOptionShares + convertible + netWarrantShares;
      var dilutedShareCount = shares + totalDilutiveShares;
      var dilEps = available / dilutedShareCount;

      dilutedEpsResult.textContent = fmt.format(dilEps);
      dilBasicRef.textContent = fmt.format(basicEps);
      dilNetShares.textContent = fmtNum.format(totalDilutiveShares);
      dilTotalShares.textContent = fmtNum.format(dilutedShareCount);

      var impact = basicEps !== 0 ? ((dilEps - basicEps) / Math.abs(basicEps)) * 100 : 0;
      dilImpact.textContent = impact.toFixed(1) + "%";
      dilImpact.style.color = impact < 0 ? "var(--negative, #ef4444)" : "var(--positive, #10b981)";
    }

    function calcGrowth() {
      var eps1 = parseFloat(growthEps1.value);
      var eps2 = parseFloat(growthEps2.value);

      if (isNaN(eps1) || isNaN(eps2) || eps1 === 0) {
        growthYoyResult.textContent = "\u2014";
        growthChange.textContent = "\u2014";
        growthCagr.textContent = "\u2014";
        growthYears.textContent = "\u2014";
        return;
      }

      var yoyGrowth = ((eps2 - eps1) / Math.abs(eps1)) * 100;
      var change = eps2 - eps1;
      var sign = yoyGrowth >= 0 ? "+" : "";
      growthYoyResult.textContent = sign + yoyGrowth.toFixed(1) + "%";
      growthYoyResult.style.color = yoyGrowth >= 0 ? "var(--positive, #10b981)" : "var(--negative, #ef4444)";
      growthChange.textContent = (change >= 0 ? "+" : "") + fmt.format(change);
      growthChange.style.color = change >= 0 ? "var(--positive, #10b981)" : "var(--negative, #ef4444)";

      // Multi-year CAGR
      var epsValues = [eps1, eps2];
      var eps3 = parseFloat(growthEps3.value);
      var eps4 = parseFloat(growthEps4.value);
      var eps5 = parseFloat(growthEps5.value);
      if (!isNaN(eps3) && growthEps3.value !== "") epsValues.push(eps3);
      if (!isNaN(eps4) && growthEps4.value !== "") epsValues.push(eps4);
      if (!isNaN(eps5) && growthEps5.value !== "") epsValues.push(eps5);

      if (epsValues.length >= 3) {
        var first = epsValues[0];
        var last = epsValues[epsValues.length - 1];
        var n = epsValues.length - 1;
        if (first > 0 && last > 0) {
          var cagr = (Math.pow(last / first, 1 / n) - 1) * 100;
          var cagrSign = cagr >= 0 ? "+" : "";
          growthCagr.textContent = cagrSign + cagr.toFixed(1) + "%";
          growthCagr.style.color = cagr >= 0 ? "var(--positive, #10b981)" : "var(--negative, #ef4444)";
          growthYears.textContent = n + " years";
        } else {
          growthCagr.textContent = "N/A (negative EPS)";
          growthCagr.style.color = "var(--text-secondary, #94a3b8)";
          growthYears.textContent = n + " years";
        }
      } else {
        growthCagr.textContent = "\u2014";
        growthCagr.style.color = "var(--text-secondary, #94a3b8)";
        growthYears.textContent = "\u2014";
      }
    }

    function calcPE() {
      var price = parseFloat(peStockPrice.value) || 0;
      var eps = parseFloat(peEps.value) || 0;

      if (eps <= 0) {
        peResult.textContent = "N/A";
        peInterp.textContent = "Negative or zero EPS \u2014 P/E not meaningful";
        peEarningsYield.textContent = "\u2014";
        return;
      }

      var pe = price / eps;
      peResult.textContent = pe.toFixed(1) + "\u00d7";

      var interp = "";
      if (pe < 10) {
        interp = "Deep value \u2014 low expectations or cyclical trough";
        peResult.style.color = "var(--positive, #10b981)";
      } else if (pe < 20) {
        interp = "Reasonably valued \u2014 moderate growth expectations";
        peResult.style.color = "var(--accent, #4a8fe7)";
      } else if (pe < 35) {
        interp = "Growth premium \u2014 market expects above-average earnings growth";
        peResult.style.color = "#f59e0b";
      } else {
        interp = "Expensive \u2014 very high growth expectations or speculative";
        peResult.style.color = "var(--negative, #ef4444)";
      }
      peInterp.textContent = interp;

      var earningsYield = (eps / price) * 100;
      peEarningsYield.textContent = earningsYield.toFixed(1) + "%";
    }

    // Attach listeners
    var basicInputs = [epsNetIncome, epsPrefDiv, epsShares];
    for (var i = 0; i < basicInputs.length; i++) {
      basicInputs[i].addEventListener("input", calcBasicEPS);
    }

    var dilInputs = [dilOptions, dilOptionPrice, dilMarketPrice, dilConvertible, dilWarrants, dilWarrantPrice];
    for (var j = 0; j < dilInputs.length; j++) {
      dilInputs[j].addEventListener("input", calcDilutedEPS);
    }

    var growthInputs = [growthEps1, growthEps2, growthEps3, growthEps4, growthEps5];
    for (var k = 0; k < growthInputs.length; k++) {
      growthInputs[k].addEventListener("input", calcGrowth);
    }

    peStockPrice.addEventListener("input", calcPE);
    peEps.addEventListener("input", calcPE);

    // Initial calculations
    calcBasicEPS();
    calcGrowth();

    // --- Charts ---

    // Magnificent 7 EPS Bar Chart
    var mag7Ctx = document.getElementById("mag7Chart").getContext("2d");
    new Chart(mag7Ctx, {
      type: "bar",
      data: {
        labels: ["META", "MSFT", "GOOGL", "AAPL", "AMZN", "NVDA", "TSLA"],
        datasets: [{
          label: "EPS (TTM)",
          data: [22.10, 12.40, 7.50, 6.75, 5.50, 2.94, 2.50],
          backgroundColor: [
            "#4a8fe7", "#10b981", "#f59e0b", "#94a3b8", "#ef4444", "#8b5cf6", "#ec4899"
          ],
          borderRadius: 6,
          barThickness: 40
        }]
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        plugins: {
          legend: { display: false },
          tooltip: {
            callbacks: {
              label: function(ctx) { return "EPS: $" + ctx.parsed.y.toFixed(2); }
            }
          }
        },
        scales: {
          y: {
            title: { display: true, text: "Earnings Per Share ($)", color: "#94a3b8" },
            grid: { color: "rgba(48,54,61,0.5)" },
            ticks: { color: "#94a3b8", callback: function(v) { return "$" + v; } },
            beginAtZero: true
          },
          x: {
            grid: { display: false },
            ticks: { color: "#c8d0de", font: { size: 13, weight: "bold" } }
          }
        }
      }
    });

    // S&P 500 EPS Growth Line Chart
    var sp500Ctx = document.getElementById("sp500EpsChart").getContext("2d");
    new Chart(sp500Ctx, {
      type: "line",
      data: {
        labels: ["2015", "2016", "2017", "2018", "2019", "2020", "2021", "2022", "2023", "2024", "2025E"],
        datasets: [{
          label: "S&P 500 EPS",
          data: [100, 106, 124, 152, 160, 136, 197, 218, 221, 235, 240],
          borderColor: "#4a8fe7",
          backgroundColor: "rgba(74,143,231,0.1)",
          borderWidth: 3,
          pointRadius: 5,
          pointBackgroundColor: "#4a8fe7",
          pointBorderColor: "#0d1117",
          pointBorderWidth: 2,
          fill: true,
          tension: 0.3
        }]
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        plugins: {
          legend: { display: false },
          tooltip: {
            callbacks: {
              label: function(ctx) { return "EPS: $" + ctx.parsed.y; }
            }
          }
        },
        scales: {
          y: {
            title: { display: true, text: "Earnings Per Share ($)", color: "#94a3b8" },
            grid: { color: "rgba(48,54,61,0.5)" },
            ticks: { color: "#94a3b8", callback: function(v) { return "$" + v; } },
            min: 80,
            max: 260
          },
          x: {
            grid: { color: "rgba(48,54,61,0.3)" },
            ticks: { color: "#c8d0de" }
          }
        }
      }
    });
  });
</script>
