          </div>
        </div>
        <div class="results-panel">
          <div class="result-box primary-result">
            <span class="calc-result-label">Diluted Earnings Per Share</span>
            <span class="calc-result-value" id="diluted-eps-result">$4.50</span>
          </div>
          <div class="secondary-results">
            <div class="result-item"><span class="result-label">Basic EPS</span><span class="result-value" id="dil-basic-ref">$5.00</span></div>
            <div class="result-item"><span class="result-label">Net Dilutive Shares (Treasury Method)</span><span class="result-value" id="dil-net-shares">5,000,000</span></div>
            <div class="result-item"><span class="result-label">Total Diluted Shares</span><span class="result-value" id="dil-total-shares">105,000,000</span></div>
            <div class="result-item"><span class="result-label">Dilution Impact</span><span class="result-value" id="dil-impact">-10.0%</span></div>
          </div>
        </div>
      </div>
    </div>

    <!-- EPS Growth Rate Calculator -->
    <div class="calculator-card" id="eps-growth-calculator">
      <h2>EPS Growth Rate Calculator</h2>
      <p class="calc-desc">Calculate year-over-year EPS growth or multi-year compound annual growth rate (CAGR). Enter EPS for two years or up to five years for a CAGR calculation.</p>
