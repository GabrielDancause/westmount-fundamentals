---
import SiteLayout from "../layouts/SiteLayout.astro";

export const meta = { title: "Book Value Per Share Calculator | BVPS, P/B Ratio & Tangible Book Value", description: "Calculate book value per share (BVPS), price-to-book (P/B) ratio, and tangible book value with our free calculator. Compare P/B ratios by sector with interactive charts.", category: "study", published: "2026-03-20" };

const schema = JSON.stringify([
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": "Book Value Per Share Calculator | BVPS, P/B Ratio & Tangible Book Value",
    "description": "Calculate book value per share (BVPS), price-to-book (P/B) ratio, and tangible book value. Compare sector P/B ratios with interactive Chart.js visualizations.",
    "author": { "@type": "Organization", "name": "Westmount Fundamentals" },
    "publisher": { "@type": "Organization", "name": "Westmount Fundamentals", "url": "https://westmountfundamentals.com" },
    "datePublished": "2026-03-20",
    "mainEntityOfPage": "https://westmountfundamentals.com/book-value-per-share-calculator/"
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "What is book value per share (BVPS)?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Book value per share (BVPS) represents the net asset value of a company on a per-share basis. It is calculated as (Total Assets − Total Liabilities − Preferred Equity) ÷ Common Shares Outstanding. BVPS tells investors how much equity each share would theoretically receive if the company were liquidated at balance sheet values."
        }
      },
      {
        "@type": "Question",
        "name": "How do you calculate the price-to-book (P/B) ratio?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "The price-to-book ratio is calculated by dividing the current market price per share by the book value per share (BVPS). A P/B ratio below 1.0 may indicate that the stock is undervalued relative to its net assets, while a ratio above 1.0 suggests the market values the company above its accounting book value."
        }
      },
      {
        "@type": "Question",
        "name": "What is tangible book value?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Tangible book value removes intangible assets (patents, trademarks, goodwill) from the standard book value calculation. The formula is: Total Assets − Intangible Assets − Goodwill − Total Liabilities − Preferred Equity. This provides a more conservative estimate of what shareholders would receive in a liquidation scenario."
        }
      },
      {
        "@type": "Question",
        "name": "Why do tech stocks have high P/B ratios?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Technology companies typically have high P/B ratios (often 10x or more) because their most valuable assets—intellectual property, brand equity, network effects, and human capital—are largely intangible and not fully reflected on the balance sheet. Their high returns on equity (ROE) also justify premium valuations over book value."
        }
      },
      {
        "@type": "Question",
        "name": "When is book value most useful for investors?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Book value is most meaningful for asset-heavy industries like banking, insurance, and real estate (REITs), where balance sheet assets closely approximate economic value. Banks hold financial assets at or near market value, making their P/B ratio a reliable gauge of whether a stock is cheap or expensive relative to its tangible net worth."
        }
      }
    ]
  }
]);
---

<SiteLayout site="westmount" title={meta.title} description={meta.description} canonical="https://westmountfundamentals.com/book-value-per-share-calculator/" schema={schema}>
  <div style="max-width:1280px;margin:0 auto;padding:16px 24px 0;display:flex;justify-content:space-between;align-items:center;font-size:13px;color:var(--text-dim,#94a3b8)">
    <nav aria-label="Breadcrumb"><a href="/" style="color:var(--text-dim,#94a3b8);text-decoration:none">Home</a> <span style="margin:0 6px;opacity:0.5">›</span> <a href="/study/" style="color:var(--text-dim,#94a3b8);text-decoration:none">Study</a> <span style="margin:0 6px;opacity:0.5">›</span> <span style="color:var(--text-primary,#c8d0de)">Book Value Per Share Calculator</span></nav>
    <span>8 min read</span>
  </div>

  <div class="container page-content">
    <h1>Book Value Per Share Calculator</h1>
    <p style="text-align:center;max-width:680px;margin:0 auto 2.5rem;color:var(--text-secondary,#94a3b8)">Calculate BVPS, price-to-book ratio, and tangible book value. Understand what book value means and when it matters most for stock analysis.</p>

    <!-- Stat Cards -->
    <div class="stats-grid">
      <div class="stat-card">
        <span class="stat-number">1.5×</span>
        <span class="stat-label">S&P 500 Financials Avg P/B</span>
      </div>
      <div class="stat-card">
