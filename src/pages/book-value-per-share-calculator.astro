    font-size: 0.9rem;
    pointer-events: none;
  }
  input[type="number"] {
    width: 100%;
    background: var(--bg-color, #010409);
    border: 1px solid var(--border, #30363d);
    color: var(--text-primary, #c8d0de);
    font-family: var(--font-mono, monospace);
    font-size: 1.05rem;
    padding: 0.75rem 1rem 0.75rem 2rem;
    border-radius: 8px;
    transition: border-color 0.2s;
    appearance: none;
    -moz-appearance: textfield;
  }
  input[type="number"]::-webkit-outer-spin-button,
  input[type="number"]::-webkit-inner-spin-button {
    -webkit-appearance: none;
    margin: 0;
  }
  input[type="number"]:focus {
    outline: none;
    border-color: var(--accent, #4a8fe7);
  }
  .results-panel {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    background: var(--bg-color, #010409);
    border: 1px solid var(--border, #30363d);
    border-radius: 12px;
    padding: 1.5rem;
  }
  .result-box.primary-result {
    text-align: center;
    padding: 1.5rem 0;
  }
  .calc-result-label {
    display: block;
    font-size: 0.85rem;
    color: var(--text-secondary, #94a3b8);
    margin-bottom: 0.5rem;
  }
  .calc-result-value {
    display: block;
    font-size: 2.2rem;
    font-weight: 700;
    color: var(--accent, #4a8fe7);
    font-family: var(--font-mono, monospace);
  }
  .secondary-results {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  .result-item {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.5rem 0;
    border-top: 1px solid var(--border, #30363d);
  }
  .result-label {
    font-size: 0.85rem;
    color: var(--text-secondary, #94a3b8);
  }
  .result-value {
    font-family: var(--font-mono, monospace);
    font-weight: 600;
    color: var(--text-primary, #c8d0de);
  }

  /* Interpretation grid */
  .interpretation-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1rem;
    margin: 1.5rem 0;
  }
  .interp-card {
    border-radius: 10px;
    padding: 1.25rem;
    border: 1px solid var(--border, #30363d);
    background: var(--bg-card, #0d1117);
  }
  .interp-range {
    display: block;
    font-size: 1.5rem;
    font-weight: 700;
    font-family: var(--font-mono, monospace);
    margin-bottom: 0.25rem;
  }
  .interp-title {
    display: block;
    font-weight: 600;
    font-size: 0.95rem;
    margin-bottom: 0.5rem;
  }
  .interp-card p {
    font-size: 0.82rem;
    color: var(--text-secondary, #94a3b8);
    line-height: 1.5;
    margin: 0;
  }
  .interp-green .interp-range { color: var(--positive, #10b981); }
  .interp-green .interp-title { color: var(--positive, #10b981); }
  .interp-blue .interp-range { color: var(--accent, #4a8fe7); }
  .interp-blue .interp-title { color: var(--accent, #4a8fe7); }
  .interp-yellow .interp-range { color: #f59e0b; }
  .interp-yellow .interp-title { color: #f59e0b; }
  .interp-red .interp-range { color: var(--negative, #ef4444); }
  .interp-red .interp-title { color: var(--negative, #ef4444); }

  /* Sector table */
  .sector-table {
    border: 1px solid var(--border, #30363d);
    border-radius: 10px;
    overflow: hidden;
    margin: 1.5rem 0;
  }
  .sector-row {
    display: grid;
    grid-template-columns: 1.5fr 1fr 0.8fr 1.2fr;
    padding: 0.75rem 1rem;
    align-items: center;
    font-size: 0.9rem;
    border-bottom: 1px solid var(--border, #30363d);
  }
  .sector-row:last-child { border-bottom: none; }
  .header-row {
    background: var(--bg-card, #0d1117);
    font-weight: 600;
    font-size: 0.82rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--text-secondary, #94a3b8);
  }
  .mono { font-family: var(--font-mono, monospace); }
  .badge {
    display: inline-block;
    padding: 0.2rem 0.6rem;
    border-radius: 6px;
    font-size: 0.75rem;
    font-weight: 600;
  }
  .badge-green { background: rgba(16,185,129,0.15); color: var(--positive, #10b981); }
  .badge-blue { background: rgba(74,143,231,0.15); color: var(--accent, #4a8fe7); }
  .badge-yellow { background: rgba(245,158,11,0.15); color: #f59e0b; }
  .badge-red { background: rgba(239,68,68,0.15); color: var(--negative, #ef4444); }

  /* Chart */
  .chart-container {
    background: var(--bg-card, #0d1117);
    border: 1px solid var(--border, #30363d);
    border-radius: 12px;
    padding: 1.5rem;
    margin: 1.5rem 0;
    max-height: 500px;
  }

  /* Content sections */
  .content-section {
    margin: 3rem 0;
  }
  .highlight-box {
    background: var(--bg-card, #0d1117);
    border: 1px solid var(--border, #30363d);
    border-left: 4px solid var(--accent, #4a8fe7);
    border-radius: 8px;
    padding: 1.5rem;
    margin: 1.5rem 0;
  }
  .highlight-box code {
    display: block;
    font-size: 1.1rem;
    color: var(--accent, #4a8fe7);
    margin-top: 0.5rem;
  }

  /* Two column layout */
  .two-col {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
    margin: 1.5rem 0;
  }
  .col-card {
    border: 1px solid var(--border, #30363d);
    border-radius: 12px;
    padding: 1.5rem;
    background: var(--bg-card, #0d1117);
  }
  .col-card h3 { margin-top: 0; font-size: 1.1rem; }
  .col-card ul { padding-left: 1.2rem; }
  .col-card li { margin-bottom: 0.75rem; font-size: 0.9rem; line-height: 1.5; color: var(--text-secondary, #94a3b8); }
  .positive-card { border-left: 3px solid var(--positive, #10b981); }
  .negative-card { border-left: 3px solid var(--negative, #ef4444); }

  /* Insights */
  .insights-list {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }
  .insight-item {
    display: flex;
    gap: 1.25rem;
    align-items: flex-start;
    background: var(--bg-card, #0d1117);
    border: 1px solid var(--border, #30363d);
    border-radius: 10px;
    padding: 1.25rem;
  }
  .insight-num {
    display: flex;
    align-items: center;
    justify-content: center;
    min-width: 2.5rem;
    height: 2.5rem;
    border-radius: 50%;
    background: var(--accent, #4a8fe7);
    color: #fff;
    font-weight: 700;
    font-size: 1.1rem;
    flex-shrink: 0;
  }
  .insight-item h4 {
    margin: 0 0 0.4rem;
    font-size: 1rem;
  }
  .insight-item p {
    margin: 0;
    font-size: 0.88rem;
    color: var(--text-secondary, #94a3b8);
    line-height: 1.5;
  }

  /* FAQ */
  .faq-list {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  .faq-item {
    background: var(--bg-card, #0d1117);
    border: 1px solid var(--border, #30363d);
    border-radius: 10px;
    padding: 1rem 1.25rem;
  }
  .faq-item summary {
    cursor: pointer;
    font-weight: 600;
    font-size: 0.95rem;
    list-style: none;
  }
  .faq-item summary::-webkit-details-marker { display: none; }
  .faq-item summary::before {
    content: "+";
    display: inline-block;
    width: 1.5rem;
    font-weight: 700;
    color: var(--accent, #4a8fe7);
  }
  .faq-item[open] summary::before { content: "−"; }
  .faq-item p {
    margin: 0.75rem 0 0 1.5rem;
    font-size: 0.9rem;
    color: var(--text-secondary, #94a3b8);
    line-height: 1.6;
  }

  /* Responsive */
  @media (max-width: 900px) {
    .stats-grid { grid-template-columns: repeat(2, 1fr); }
    .calc-grid { grid-template-columns: 1fr; }
    .interpretation-grid { grid-template-columns: repeat(2, 1fr); }
    .two-col { grid-template-columns: 1fr; }
    .sector-row { font-size: 0.8rem; grid-template-columns: 1.2fr 0.8fr 0.6fr 1fr; }
  }
  @media (max-width: 600px) {
    .stats-grid { grid-template-columns: 1fr 1fr; }
    .interpretation-grid { grid-template-columns: 1fr; }
    .sector-row { grid-template-columns: 1fr 1fr; }
    .sector-row .badge { display: none; }
    .header-row span:nth-child(4) { display: none; }
  }
</style>

<script is:inline src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script is:inline>
  document.addEventListener("DOMContentLoaded", function() {
    // --- Formatters ---
    var fmt = new Intl.NumberFormat("en-US", { style: "currency", currency: "USD", maximumFractionDigits: 2 });
    var fmtLarge = new Intl.NumberFormat("en-US", { style: "currency", currency: "USD", maximumFractionDigits: 0 });

    // --- BVPS Calculator ---
    var bvpsAssets = document.getElementById("bvps-assets");
    var bvpsLiab = document.getElementById("bvps-liabilities");
    var bvpsPref = document.getElementById("bvps-preferred");
    var bvpsShares = document.getElementById("bvps-shares");
    var bvpsResult = document.getElementById("bvps-result");
    var bvpsEquity = document.getElementById("bvps-equity");
    var bvpsNet = document.getElementById("bvps-net");

    // P/B calculator fields
    var pbPrice = document.getElementById("pb-price");
    var pbBvps = document.getElementById("pb-bvps");
    var pbResult = document.getElementById("pb-result");
    var pbInterp = document.getElementById("pb-interpretation");
    var pbPremium = document.getElementById("pb-premium");

    // TBV calculator fields
    var tbvIntangibles = document.getElementById("tbv-intangibles");
    var tbvGoodwill = document.getElementById("tbv-goodwill");
    var tbvResult = document.getElementById("tbv-result");
    var tbvTotal = document.getElementById("tbv-total");
    var tbvPct = document.getElementById("tbv-pct");

    function calcBVPS() {
      var assets = parseFloat(bvpsAssets.value) || 0;
      var liab = parseFloat(bvpsLiab.value) || 0;
      var pref = parseFloat(bvpsPref.value) || 0;
      var shares = parseFloat(bvpsShares.value) || 1;
      if (shares < 1) shares = 1;

      var equity = assets - liab;
      var netBook = equity - pref;
      var bvps = netBook / shares;

      bvpsResult.textContent = fmt.format(bvps);
      bvpsEquity.textContent = fmtLarge.format(equity);
      bvpsNet.textContent = fmtLarge.format(netBook);

      // Auto-fill P/B calculator BVPS
      pbBvps.value = bvps.toFixed(2);
      calcPB();
      calcTBV();
    }

    function calcPB() {
      var price = parseFloat(pbPrice.value) || 0;
      var bvps = parseFloat(pbBvps.value) || 0.01;
      if (bvps <= 0) bvps = 0.01;

      var pb = price / bvps;
      pbResult.textContent = pb.toFixed(2) + "\u00d7";

      // Interpretation
      var interp = "";
      if (pb < 1) {
        interp = "Potentially undervalued \u2014 trading below book value";
        pbResult.style.color = "var(--positive, #10b981)";
      } else if (pb < 3) {
        interp = "Fair value range \u2014 moderate premium to book";
        pbResult.style.color = "var(--accent, #4a8fe7)";
      } else if (pb < 10) {
        interp = "Growth premium \u2014 market values above book";
        pbResult.style.color = "#f59e0b";
      } else {
        interp = "Extreme premium \u2014 book value largely irrelevant";
        pbResult.style.color = "var(--negative, #ef4444)";
      }
      pbInterp.textContent = interp;

      var premium = ((price / bvps) - 1) * 100;
      var sign = premium >= 0 ? "+" : "";
      pbPremium.textContent = sign + premium.toFixed(1) + "%";
      pbPremium.style.color = premium >= 0 ? "var(--positive, #10b981)" : "var(--negative, #ef4444)";
    }

    function calcTBV() {
      var assets = parseFloat(bvpsAssets.value) || 0;
      var liab = parseFloat(bvpsLiab.value) || 0;
      var pref = parseFloat(bvpsPref.value) || 0;
      var shares = parseFloat(bvpsShares.value) || 1;
      var intang = parseFloat(tbvIntangibles.value) || 0;
      var gw = parseFloat(tbvGoodwill.value) || 0;
      if (shares < 1) shares = 1;

      var equity = assets - liab - pref;
      var tangible = equity - intang - gw;
      var tbvPerShare = tangible / shares;

      tbvResult.textContent = fmt.format(tbvPerShare);
      tbvTotal.textContent = fmtLarge.format(tangible);

      var pctIntang = equity > 0 ? ((intang + gw) / equity) * 100 : 0;
      tbvPct.textContent = pctIntang.toFixed(1) + "%";
    }

    // Attach event listeners
    var bvpsInputs = [bvpsAssets, bvpsLiab, bvpsPref, bvpsShares];
    for (var i = 0; i < bvpsInputs.length; i++) {
      bvpsInputs[i].addEventListener("input", calcBVPS);
    }
    pbPrice.addEventListener("input", calcPB);
    pbBvps.addEventListener("input", calcPB);
    tbvIntangibles.addEventListener("input", calcTBV);
    tbvGoodwill.addEventListener("input", calcTBV);

    // Initial calculations
    calcBVPS();

    // --- Charts ---
    var sectorLabels = ["Technology", "Consumer Disc.", "Consumer Staples", "Healthcare", "Industrials", "Comm. Services", "Materials", "Real Estate", "Energy", "Utilities", "Financials"];
    var pbValues = [12, 8, 6, 5, 5, 4, 3, 2.5, 2, 2, 1.5];
    var roeValues = [35, 28, 25, 22, 20, 18, 15, 8, 14, 10, 12];

    var barColors = [
      "#ef4444", "#f59e0b", "#f59e0b", "#f59e0b", "#f59e0b",
      "#4a8fe7", "#4a8fe7", "#4a8fe7", "#4a8fe7", "#4a8fe7", "#10b981"
    ];

    // Horizontal Bar Chart
    var barCtx = document.getElementById("pbSectorChart").getContext("2d");
    new Chart(barCtx, {
      type: "bar",
      data: {
        labels: sectorLabels,
        datasets: [{
          label: "P/B Ratio",
          data: pbValues,
          backgroundColor: barColors,
          borderRadius: 4,
          barThickness: 22
        }]
      },
      options: {
        indexAxis: "y",
        responsive: true,
        maintainAspectRatio: false,
        plugins: {
          legend: { display: false },
          tooltip: {
            callbacks: {
              label: function(ctx) { return "P/B: " + ctx.parsed.x + "\u00d7"; }
            }
          }
        },
        scales: {
          x: {
            title: { display: true, text: "P/B Ratio", color: "#94a3b8" },
            grid: { color: "rgba(48,54,61,0.5)" },
            ticks: { color: "#94a3b8" }
          },
          y: {
            grid: { display: false },
            ticks: { color: "#c8d0de", font: { size: 12 } }
          }
        }
      }
    });

    // Scatter Plot: P/B vs ROE
    var scatterData = [];
    for (var j = 0; j < sectorLabels.length; j++) {
      scatterData.push({ x: roeValues[j], y: pbValues[j], label: sectorLabels[j] });
    }

    var scatterCtx = document.getElementById("pbRoeChart").getContext("2d");
    new Chart(scatterCtx, {
      type: "scatter",
      data: {
        datasets: [{
          label: "Sectors",
          data: scatterData,
          backgroundColor: barColors,
          pointRadius: 8,
          pointHoverRadius: 11
        }]
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        plugins: {
          legend: { display: false },
          tooltip: {
            callbacks: {
              label: function(ctx) {
                var pt = ctx.raw;
                return pt.label + ": ROE " + pt.x + "%, P/B " + pt.y + "\u00d7";
              }
            }
          }
        },
        scales: {
          x: {
            title: { display: true, text: "Return on Equity (ROE %)", color: "#94a3b8" },
            grid: { color: "rgba(48,54,61,0.5)" },
            ticks: { color: "#94a3b8", callback: function(v) { return v + "%"; } },
            min: 5,
            max: 40
          },
          y: {
            title: { display: true, text: "P/B Ratio", color: "#94a3b8" },
            grid: { color: "rgba(48,54,61,0.5)" },
            ticks: { color: "#94a3b8", callback: function(v) { return v + "\u00d7"; } },
            min: 0,
            max: 14
          }
        }
      }
    });
  });
</script>
