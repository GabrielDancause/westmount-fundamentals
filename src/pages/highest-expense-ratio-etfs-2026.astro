        document.addEventListener('DOMContentLoaded', () => {
            const etfData = window.__INITIAL_DATA__;

            // Format percentages
            const formatPct = (val) => {
                if (val === undefined || val === null) return 'N/A';
                return (val * 100).toFixed(2) + '%';
            };

            // Escape HTML
            const esc = (str) => {
                if (!str) return '';
                return String(str).replace(/[&<>'"]/g,
                    tag => ({
                        '&': '&amp;',
                        '<': '<',
                        '>': '>',
                        "'": '&#39;',
                        '"': '&quot;'
                    }[tag])
                );
            };

            // Build categories
            const categories = [...new Set(etfData.map(d => d.category))];
            const filterContainer = document.getElementById('category-filters');
            categories.forEach(cat => {
                const btn = document.createElement('button');
                btn.className = 'filter-btn';
                btn.dataset.cat = cat;
                btn.textContent = cat;
                filterContainer.appendChild(btn);
            });

            // Render Table
            const renderTable = (filterCat = 'all') => {
                const tbody = document.querySelector('#etf-table tbody');
                tbody.innerHTML = '';

                etfData.forEach(item => {
                    if (filterCat !== 'all' && item.category !== filterCat) return;

                    const tr = document.createElement('tr');
                    tr.innerHTML = `
                        <td>
                            <div class="ticker mono">${esc(item.ticker)}</div>
                            <div style="font-size: 0.8rem; color: var(--text-muted); max-width: 200px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;" title="${esc(item.name)}">${esc(item.name)}</div>
                        </td>
                        <td class="fee-high mono">${formatPct(item.expenseRatio)}</td>
                        <td class="mono" style="font-size: 0.85rem; color: var(--text-muted);">${formatCompactAUM(item.totalAssets)}</td>
                        <td><span style="font-size: 0.8rem; background: var(--border-color); padding: 0.2rem 0.5rem; border-radius: 4px;">${esc(item.category)}</span></td>
                        <td>
                            <div class="ticker mono" style="color: var(--success);"><span class="alt-ticker" style="background: rgba(16, 185, 129, 0.1); color: var(--success);">${esc(item.alternative.ticker)}</span></div>
                            <div style="font-size: 0.8rem; color: var(--text-muted); max-width: 200px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;" title="${esc(item.alternative.name)}">${esc(item.alternative.name)}</div>
                        </td>
                        <td class="fee-low mono">${formatPct(item.alternative.expenseRatio)}</td>
                    `;
                    tbody.appendChild(tr);
                });
            };

            // Setup filters
            document.querySelectorAll('.filter-btn').forEach(btn => {
                btn.addEventListener('click', (e) => {
                    document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
                    e.target.classList.add('active');
                    renderTable(e.target.dataset.cat);
                });
            });

            renderTable();

            // Setup Calculator
            const calcSelect = document.getElementById('calc-etf-select');
            etfData.forEach((item, index) => {
                const option = document.createElement('option');
                option.value = index;
                option.textContent = `${item.ticker} (${formatPct(item.expenseRatio)}) vs ${item.alternative.ticker} (${formatPct(item.alternative.expenseRatio)})`;
                calcSelect.appendChild(option);
            });

            let feeChart = null;

            const updateCalculator = () => {
                const itemIndex = parseInt(calcSelect.value);
                const item = etfData[itemIndex];
                const principal = parseFloat(document.getElementById('calc-amount').value) || 10000;
                const years = parseInt(document.getElementById('calc-years').value) || 20;
                const grossReturn = (parseFloat(document.getElementById('calc-growth').value) || 8) / 100;

                document.getElementById('calc-years-display').textContent = `${years} Years`;

                const expFee = item.expenseRatio || 0;
                const altFee = item.alternative.expenseRatio || 0;

                const labels = [];
                const expData = [];
                const altData = [];

                let expBalance = principal;
                let altBalance = principal;

                let totalExpFees = 0;

                for (let i = 0; i <= years; i++) {
                    labels.push(`Year ${i}`);
                    expData.push(expBalance);
                    altData.push(altBalance);

                    if (i < years) {
                        // Apply growth
                        let expGrowth = expBalance * grossReturn;
                        let altGrowth = altBalance * grossReturn;

                        // Apply fees (simplified end of year deduction)
                        let expFeeAmount = (expBalance + expGrowth) * expFee;
                        let altFeeAmount = (altBalance + altGrowth) * altFee;

                        totalExpFees += expFeeAmount;

                        expBalance = expBalance + expGrowth - expFeeAmount;
                        altBalance = altBalance + altGrowth - altFeeAmount;
                    }
                }

                const diff = altBalance - expBalance;

                const fmt = new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD', maximumFractionDigits: 0 });

                document.getElementById('calc-lost-fees').textContent = fmt.format(totalExpFees);
                document.getElementById('calc-diff').textContent = fmt.format(diff) + ' more with ' + item.alternative.ticker;

                updateChart(labels, expData, altData, item.ticker, item.alternative.ticker);
            };

            const updateChart = (labels, expData, altData, expTicker, altTicker) => {
                const ctx = document.getElementById('feeChart').getContext('2d');

                if (feeChart) {
                    feeChart.destroy();
                }

                feeChart = new Chart(ctx, {
                    type: 'line',
                    data: {
                        labels: labels,
                        datasets: [
                            {
                                label: `${altTicker} (Low Fee)`,
                                data: altData,
                                borderColor: '#10b981',
                                backgroundColor: 'rgba(16, 185, 129, 0.2)',
                                fill: true,
                                tension: 0.4
                            },
                            {
                                label: `${expTicker} (High Fee)`,
                                data: expData,
                                borderColor: '#ef4444',
                                backgroundColor: 'rgba(239, 68, 68, 0.2)',
                                fill: true,
                                tension: 0.4
                            }
                        ]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        interaction: {
                            mode: 'index',
                            intersect: false,
                        },
                        plugins: {
                            legend: {
                                labels: { color: '#e2e8f0', font: { family: 'Inter' } }
                            },
                            tooltip: {
                                callbacks: {
                                    label: function(context) {
                                        let label = context.dataset.label || '';
                                        if (label) {
                                            label += ': ';
                                        }
                                        if (context.parsed.y !== null) {
                                            label += new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD', maximumFractionDigits: 0 }).format(context.parsed.y);
                                        }
                                        return label;
                                    }
                                }
                            }
                        },
                        scales: {
                            y: {
                                ticks: {
                                    color: '#94a3b8',
                                    callback: function(value) {
                                        if (value >= 1000000) return '$' + (value / 1000000).toFixed(1) + 'M';
                                        if (value >= 1000) return '$' + (value / 1000).toFixed(0) + 'k';
                                        return '$' + value;
                                    }
                                },
                                grid: { color: 'rgba(255, 255, 255, 0.05)' }
                            },
                            x: {
                                ticks: { color: '#94a3b8', maxTicksLimit: 6 },
                                grid: { color: 'rgba(255, 255, 255, 0.05)' }
                            }
                        }
                    }
                });
            };

            // Listeners
            document.getElementById('calc-etf-select').addEventListener('change', updateCalculator);
            document.getElementById('calc-amount').addEventListener('input', updateCalculator);
            document.getElementById('calc-growth').addEventListener('input', updateCalculator);
            document.getElementById('calc-years').addEventListener('input', updateCalculator);

            // Initial render
            setTimeout(updateCalculator, 100);
        });
  </script>
</SiteLayout>
