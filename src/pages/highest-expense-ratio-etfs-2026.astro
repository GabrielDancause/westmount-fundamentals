        .mono { font-family: 'JetBrains Mono', monospace; }
        .ticker { font-weight: 600; color: var(--accent-color); }
        .fee-high { color: var(--danger); font-weight: 600; }
        .fee-low { color: var(--success); font-weight: 600; }
        .alt-ticker { font-size: 0.8rem; background: var(--border-color); padding: 0.2rem 0.5rem; border-radius: 4px; color: var(--text-main); text-decoration: none; }

        .calculator-form { display: flex; flex-direction: column; gap: 1rem; }
        .form-group { display: flex; flex-direction: column; gap: 0.5rem; }
        label { font-size: 0.9rem; font-weight: 500; color: var(--text-muted); }
        select, input {
            background: var(--bg-color);
            border: 1px solid var(--border-color);
            color: var(--text-main);
            padding: 0.75rem;
            border-radius: 6px;
            font-family: inherit;
            font-size: 1rem;
        }
        select:focus, input:focus { outline: none; border-color: var(--accent-color); }

        .chart-container { position: relative; height: 300px; width: 100%; margin-top: 1.5rem; }

        .stats-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin-top: 1.5rem; }
        .stat-box { background: var(--bg-color); border: 1px solid var(--border-color); padding: 1rem; border-radius: 8px; text-align: center; }
        .stat-label { font-size: 0.8rem; color: var(--text-muted); text-transform: uppercase; }
        .stat-value { font-size: 1.25rem; font-weight: 700; font-family: 'JetBrains Mono', monospace; margin-top: 0.25rem; }
        .stat-value.red { color: var(--danger); }

        .faq-section { margin-top: 4rem; }
        .faq-item { margin-bottom: 1.5rem; border-bottom: 1px solid var(--border-color); padding-bottom: 1.5rem; }
        .faq-question { font-weight: 600; font-size: 1.1rem; margin-bottom: 0.5rem; }
        .faq-answer { color: var(--text-muted); }

        footer {
            margin-top: 4rem;
            padding: 2rem;
            text-align: center;
            border-top: 1px solid var(--border-color);
            color: var(--text-muted);
            font-size: 0.9rem;
        }

        .disclaimer { margin-top: 0.5rem; font-size: 0.8rem; opacity: 0.7; }

        /* Filter controls */
