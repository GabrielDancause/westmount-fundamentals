  <script is:inline>
document.addEventListener('DOMContentLoaded', () => {
      const data = window.__INITIAL_DATA__;
      if (!data) return;

      // Formatting utils
      const pct = (val) => {
          if (val === null || val === undefined) return '--';
          return (val * 100).toFixed(2) + '%';
      };

      const formatCell = (val) => {
          if (val === null || val === undefined) return '<td>--</td>';
          const cssClass = val >= 0 ? 'pos' : 'neg';
          const sign = val > 0 ? '+' : '';
          return `<td class="${cssClass}">${sign}${pct(val)}</td>`;
      };

      // Populate Stats
      if (data.stats && data.stats.returnWithDiv) {
          const s = data.stats.returnWithDiv;
          document.getElementById('stat-10y').innerText = pct(s.r10);
          document.getElementById('stat-20y').innerText = pct(s.r20);
          document.getElementById('stat-30y').innerText = pct(s.r30);
          document.getElementById('stat-all').innerText = pct(s[`r${data.historical.length}`]);
      }

      // Populate Table
      let tableData = [...data.historical].reverse();
      const tbody = document.getElementById('dataTableBody');
      let currentSort = { col: 'year', desc: true };

      const renderTable = (items) => {
          tbody.innerHTML = '';
          items.forEach(row => {
              const tr = document.createElement('tr');
              tr.innerHTML = `
                  <td>${row.year}</td>
                  ${formatCell(row.returnWithDiv)}
                  <td>${pct(row.inflation)}</td>
                  ${formatCell(row.realReturnWithDiv)}
              `;
              tbody.appendChild(tr);
          });
      };

      renderTable(tableData);

      // Search
      document.getElementById('yearSearch').addEventListener('input', (e) => {
          const q = e.target.value.trim();
          if (!q) {
              renderTable(tableData);
              return;
          }
          const filtered = tableData.filter(d => d.year.toString().includes(q));
          renderTable(filtered);
      });

      // Sort
      const headers = document.querySelectorAll('th[data-sort]');
      headers.forEach(th => {
          th.addEventListener('click', () => {
              const col = th.dataset.sort;
              if (currentSort.col === col) {
                  currentSort.desc = !currentSort.desc;
              } else {
                  currentSort.col = col;
                  currentSort.desc = true;
              }

              tableData.sort((a, b) => {
                  let valA, valB;
                  if (col === 'year') { valA = a.year; valB = b.year; }
                  if (col === 'nominal') { valA = a.returnWithDiv; valB = b.returnWithDiv; }
                  if (col === 'inflation') { valA = a.inflation; valB = b.inflation; }
                  if (col === 'real') { valA = a.realReturnWithDiv; valB = b.realReturnWithDiv; }

                  if (valA === undefined || valA === null) valA = -Infinity;
                  if (valB === undefined || valB === null) valB = -Infinity;

                  return currentSort.desc ? valB - valA : valA - valB;
              });

              renderTable(tableData);
          });
      });

      // Render Chart
      if (data.rolling10Year && data.rolling10Year.length > 0) {
          const ctx = document.getElementById('rollingChart').getContext('2d');
          const labels = data.rolling10Year.map(d => d.year);
          const values = data.rolling10Year.map(d => d.returnWithDiv10Y * 100);

          new Chart(ctx, {
              type: 'line',
              data: {
                  labels,
                  datasets: [{
                      label: '10-Year Annualized Return (%)',
                      data: values,
                      borderColor: '#4a8fe7',
                      backgroundColor: 'rgba(74, 143, 231, 0.1)',
                      borderWidth: 2,
                      pointRadius: 0,
                      pointHoverRadius: 4,
                      fill: true,
                      tension: 0.3
                  }]
              },
              options: {
                  responsive: true,
                  maintainAspectRatio: false,
                  interaction: { mode: 'index', intersect: false },
                  plugins: {
                      legend: { display: false },
                      tooltip: {
                          callbacks: {
                              label: function(context) {
                                  return context.parsed.y.toFixed(2) + '%';
                              }
                          }
                      }
                  },
                  scales: {
                      y: {
                          grid: { color: '#152040' },
                          ticks: { color: '#8a9ab0', callback: val => val + '%' }
                      },
                      x: {
                          grid: { display: false },
                          ticks: { color: '#8a9ab0', maxTicksLimit: 10 }
                      }
                  }
              }
          });
      }
    });
  </script>

  
