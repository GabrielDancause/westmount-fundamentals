    {ticker:'ED',company:'Consolidated Edison, Inc.',sector:'Utilities',deRatio:1.17,totalDebt:28.4e9,totalEquity:24.2e9},
    {ticker:'BLDR',company:'Builders FirstSource, Inc.',sector:'Industrials',deRatio:1.17,totalDebt:5.1e9,totalEquity:4.4e9},
    {ticker:'BR',company:'Broadridge Financial Solutions, Inc.',sector:'Technology',deRatio:1.17,totalDebt:3.4e9,totalEquity:2.9e9}
  ];

  // Utility functions
  function fmt$(n) {
    if (n === 0) return '$0';
    var abs = Math.abs(n);
    var prefix = n < 0 ? '-$' : '$';
    if (abs >= 1e12) return prefix + (abs/1e12).toFixed(1) + 'T';
    if (abs >= 1e9) return prefix + (abs/1e9).toFixed(1) + 'B';
    if (abs >= 1e6) return prefix + (abs/1e6).toFixed(1) + 'M';
    if (abs >= 1e3) return prefix + (abs/1e3).toFixed(0) + 'K';
    return prefix + abs.toFixed(0);
  }

  function deColor(ratio) {
    if (ratio === null) return 'de-purple';
    if (ratio < 0.5) return 'de-green';
    if (ratio <= 1.0) return 'de-yellow';
    if (ratio <= 2.0) return 'de-orange';
    return 'de-red';
  }

  function deColorHex(ratio) {
    if (ratio === null) return '#a855f7';
    if (ratio < 0.5) return '#22c55e';
    if (ratio <= 1.0) return '#eab308';
    if (ratio <= 2.0) return '#f97316';
    return '#ef4444';
  }

  function sortVal(d, col) {
    if (col === 'rank') return d._rank;
    if (col === 'company') return d.company.toLowerCase();
    if (col === 'sector') return d.sector.toLowerCase();
    if (col === 'deRatio') return d.deRatio === null ? 9999 : d.deRatio;
    if (col === 'totalDebt') return d.totalDebt;
    if (col === 'totalEquity') return d.totalEquity;
    return 0;
  }

  // Assign ranks
  DE_DATA.forEach(function(d,i) { d._rank = i + 1; });

  // Stats
  var withRatio = DE_DATA.filter(function(d) { return d.deRatio !== null; });
  var negEquity = DE_DATA.filter(function(d) { return d.totalEquity < 0; });
  var avgDE = withRatio.reduce(function(s,d) { return s + d.deRatio; }, 0) / withRatio.length;
  var maxDE = withRatio.reduce(function(a,b) { return a.deRatio > b.deRatio ? a : b; });
  var minDE = withRatio.reduce(function(a,b) { return a.deRatio < b.deRatio ? a : b; });

  document.getElementById('statAvg').textContent = avgDE.toFixed(2) + '×';
  document.getElementById('statAvgSub').textContent = 'Across ' + withRatio.length + ' companies';
  document.getElementById('statMax').textContent = maxDE.deRatio.toFixed(2) + '×';
  document.getElementById('statMaxSub').textContent = maxDE.ticker + ' (' + maxDE.company.split(' ').slice(0,3).join(' ') + ')';
  document.getElementById('statMin').textContent = minDE.deRatio.toFixed(2) + '×';
  document.getElementById('statMinSub').textContent = minDE.ticker + ' (' + minDE.company.split(' ').slice(0,3).join(' ') + ')';
  document.getElementById('statNeg').textContent = negEquity.length;

  // Key Insights
  var sectors = {};
  withRatio.forEach(function(d) {
    if (!sectors[d.sector]) sectors[d.sector] = [];
    sectors[d.sector].push(d.deRatio);
  });
  var sectorAvgs = Object.keys(sectors).map(function(s) {
    var avg = sectors[s].reduce(function(a,b){return a+b;},0) / sectors[s].length;
    return {sector: s, avg: avg, count: sectors[s].length};
  }).sort(function(a,b) { return b.avg - a.avg; });

  var highLev = DE_DATA.filter(function(d) { return d.deRatio === null || d.deRatio > 2; }).length;
  var pctHigh = ((highLev / DE_DATA.length) * 100).toFixed(0);

  var insights = [
    {icon:'⚡', title: sectorAvgs[0].sector + ' leads in leverage', text: 'With an average D/E of ' + sectorAvgs[0].avg.toFixed(2) + '×, ' + sectorAvgs[0].sector + ' is the most leveraged sector among the top 150 companies. This reflects ' + (sectorAvgs[0].sector === 'Utilities' ? 'regulated, stable cash flows that support higher debt loads.' : 'capital-intensive business models.')},
    {icon:'🟣', title: negEquity.length + ' companies have negative equity', text: 'Companies like ' + negEquity.map(function(d){return d.ticker;}).join(', ') + ' have bought back so many shares (or accumulated losses) that total equity is below zero — making them technically infinitely leveraged.'},
    {icon:'📊', title: pctHigh + '% of top 150 have D/E above 2.0', text: highLev + ' out of ' + DE_DATA.length + ' companies carry debt exceeding twice their equity. These companies are more sensitive to interest rate changes and economic downturns.'},
    {icon:'🏢', title: sectorAvgs[sectorAvgs.length-1].sector + ' is least leveraged', text: 'With an average D/E of just ' + sectorAvgs[sectorAvgs.length-1].avg.toFixed(2) + '×, ' + sectorAvgs[sectorAvgs.length-1].sector + ' companies tend to run leaner balance sheets.'},
    {icon:'💰', title: 'Median D/E is ' + withRatio[Math.floor(withRatio.length/2)].deRatio.toFixed(2) + '×', text: 'Half of the ranked companies have a D/E ratio below ' + withRatio[Math.floor(withRatio.length/2)].deRatio.toFixed(2) + '× — significantly lower than the average of ' + avgDE.toFixed(2) + '×, showing that a few extreme outliers pull the average up.'}
  ];

  var insightsHtml = '';
  insights.forEach(function(ins) {
    insightsHtml += '<div class="insight-card"><div class="insight-icon">' + ins.icon + '</div><div class="insight-title">' + ins.title + '</div><div class="insight-text">' + ins.text + '</div></div>';
  });
  document.getElementById('insightsGrid').innerHTML = insightsHtml;

  // Calculator
  var calcDebt = document.getElementById('calcDebt');
  var calcEquity = document.getElementById('calcEquity');

  function parseNum(s) {
    s = s.replace(/[^0-9.\-]/g, '');
    return parseFloat(s) || 0;
  }

  function updateCalc() {
    var debt = parseNum(calcDebt.value);
    var equity = parseNum(calcEquity.value);
    var ratioEl = document.getElementById('calcRatio');
    var interpEl = document.getElementById('calcInterp');
    var rankEl = document.getElementById('calcRank');
    var gauge = document.getElementById('calcGauge');
    var gaugeFill = document.getElementById('calcGaugeFill');
    var gaugeMarker = document.getElementById('calcGaugeMarker');
    var gaugeLabels = document.getElementById('calcGaugeLabels');

    if (!debt && !equity) {
      ratioEl.textContent = '—';
      ratioEl.style.color = '';
      interpEl.textContent = 'Enter values to calculate';
      rankEl.textContent = '';
      gauge.style.display = 'none';
      gaugeLabels.style.display = 'none';
      return;
    }

    if (equity <= 0) {
      ratioEl.textContent = equity < 0 ? 'N/A' : '∞';
      ratioEl.style.color = '#a855f7';
      interpEl.textContent = equity < 0 ? 'Negative equity — company is entirely debt-financed' : 'Zero equity — infinite leverage';
      var negCount = DE_DATA.filter(function(d){return d.totalEquity <= 0;}).length;
      rankEl.textContent = 'Joins ' + negCount + ' S&P 500 companies with negative or zero equity';
      gauge.style.display = 'block';
      gaugeLabels.style.display = 'flex';
      gaugeFill.style.width = '100%';
      gaugeFill.style.background = '#a855f7';
      gaugeMarker.style.left = '100%';
      return;
    }

    var ratio = debt / equity;
    ratioEl.textContent = ratio.toFixed(2) + '×';
    ratioEl.style.color = deColorHex(ratio);

    if (ratio < 0.5) interpEl.textContent = 'Low leverage — conservative balance sheet';
    else if (ratio <= 1.0) interpEl.textContent = 'Moderate leverage — well balanced';
    else if (ratio <= 2.0) interpEl.textContent = 'Above average leverage — watch interest costs';
    else if (ratio <= 5.0) interpEl.textContent = 'High leverage — significant debt load';
    else interpEl.textContent = 'Extreme leverage — very high risk profile';

    // Rank
    var rank = 1;
    DE_DATA.forEach(function(d) {
      var dRatio = d.deRatio === null ? 9999 : d.deRatio;
      if (ratio < dRatio) rank++;
    });
    rank = DE_DATA.length + 1 - rank + 1;
    rankEl.textContent = 'A D/E of ' + ratio.toFixed(2) + '× would rank #' + Math.min(rank, DE_DATA.length) + ' out of ' + DE_DATA.length + ' S&P 500 companies';

    // Gauge
    gauge.style.display = 'block';
    gaugeLabels.style.display = 'flex';
    var pct = Math.min(ratio / 10, 1) * 100;
    gaugeFill.style.width = pct + '%';
    gaugeFill.style.background = 'linear-gradient(to right, #22c55e, #eab308, #f97316, #ef4444)';
    gaugeMarker.style.left = pct + '%';
  }

  calcDebt.addEventListener('input', updateCalc);
  calcEquity.addEventListener('input', updateCalc);

  // Sector Chart
  var sectorCtx = document.getElementById('sectorChart').getContext('2d');
  var sortedSectors = sectorAvgs.sort(function(a,b){return a.avg - b.avg;});
  new Chart(sectorCtx, {
    type: 'bar',
    data: {
      labels: sortedSectors.map(function(s){return s.sector + ' (' + s.count + ')';}),
      datasets: [{
        data: sortedSectors.map(function(s){return parseFloat(s.avg.toFixed(2));}),
        backgroundColor: sortedSectors.map(function(s){return deColorHex(s.avg);}),
        borderRadius: 4,
        barThickness: 20
      }]
    },
    options: {
      indexAxis: 'y',
      responsive: true,
      maintainAspectRatio: false,
      plugins: { legend: { display: false }, tooltip: { callbacks: { label: function(ctx) { return ctx.raw + '× avg D/E'; } } } },
      scales: {
        x: { grid: { color: 'rgba(255,255,255,0.05)' }, ticks: { color: '#94a3b8' } },
        y: { grid: { display: false }, ticks: { color: '#c8d0de', font: { size: 11 } } }
      }
    }
  });

  // Distribution Chart
  var bins = [
    {label: 'Neg Equity', min: -Infinity, max: -0.001, count: 0},
    {label: '0–0.5', min: 0, max: 0.5, count: 0},
    {label: '0.5–1.0', min: 0.5, max: 1.0, count: 0},
    {label: '1.0–2.0', min: 1.0, max: 2.0, count: 0},
    {label: '2.0–5.0', min: 2.0, max: 5.0, count: 0},
    {label: '5.0+', min: 5.0, max: Infinity, count: 0}
  ];
  DE_DATA.forEach(function(d) {
    if (d.deRatio === null || d.totalEquity < 0) { bins[0].count++; return; }
    for (var i = 1; i < bins.length; i++) {
      if (d.deRatio >= bins[i].min && (d.deRatio < bins[i].max || (i === bins.length-1 && d.deRatio >= bins[i].min))) {
        bins[i].count++;
        break;
      }
    }
  });
  var binColors = ['#a855f7','#22c55e','#eab308','#f97316','#ef4444','#dc2626'];
  var distCtx = document.getElementById('distChart').getContext('2d');
  new Chart(distCtx, {
    type: 'bar',
    data: {
      labels: bins.map(function(b){return b.label;}),
      datasets: [{
        data: bins.map(function(b){return b.count;}),
        backgroundColor: binColors,
        borderRadius: 4
      }]
    },
    options: {
      responsive: true,
      maintainAspectRatio: false,
      plugins: { legend: { display: false }, tooltip: { callbacks: { label: function(ctx) { return ctx.raw + ' companies'; } } } },
      scales: {
        x: { grid: { display: false }, ticks: { color: '#c8d0de' } },
        y: { grid: { color: 'rgba(255,255,255,0.05)' }, ticks: { color: '#94a3b8' } }
      }
    }
  });

  // Interactive Table
  var SHOW_INCREMENT = 50;
  var showCount = SHOW_INCREMENT;
  var currentSort = {col: 'rank', asc: true};
  var filtered = DE_DATA.slice();

  // Populate sector filter
  var sectorNames = [];
  DE_DATA.forEach(function(d) { if (sectorNames.indexOf(d.sector) === -1) sectorNames.push(d.sector); });
  sectorNames.sort();
  var sectorSelect = document.getElementById('sectorFilter');
  sectorNames.forEach(function(s) {
    var opt = document.createElement('option');
    opt.value = s;
    opt.textContent = s;
    sectorSelect.appendChild(opt);
  });

  function renderTable() {
    var search = document.getElementById('searchInput').value.toLowerCase();
    var sector = sectorSelect.value;

    filtered = DE_DATA.filter(function(d) {
      if (sector && d.sector !== sector) return false;
      if (search && d.company.toLowerCase().indexOf(search) === -1 && d.ticker.toLowerCase().indexOf(search) === -1) return false;
      return true;
    });

    // Sort
    filtered.sort(function(a,b) {
      var va = sortVal(a, currentSort.col);
      var vb = sortVal(b, currentSort.col);
      if (typeof va === 'string') return currentSort.asc ? va.localeCompare(vb) : vb.localeCompare(va);
      return currentSort.asc ? va - vb : vb - va;
    });

    var visible = filtered.slice(0, showCount);
    var tbody = document.getElementById('deTableBody');
    var html = '';
    visible.forEach(function(d) {
      var deDisplay = d.deRatio === null ? 'N/A (Neg)' : d.deRatio.toFixed(2) + '×';
      var colorClass = deColor(d.deRatio);
      var negFlag = d.totalEquity < 0 ? ' <span class="flag">Neg Equity</span>' : '';
      html += '<tr>' +
        '<td class="num">' + d._rank + '</td>' +
        '<td><div class="company-name">' + d.company + '</div><div class="company-ticker">' + d.ticker + ' <span class="sector-tag">' + d.sector + '</span>' + negFlag + '</div></td>' +
        '<td class="num" style="display:none;">' + d.sector + '</td>' +
        '<td><span class="de-badge ' + colorClass + '">' + deDisplay + '</span></td>' +
        '<td class="num">' + fmt$(d.totalDebt) + '</td>' +
        '<td class="num">' + fmt$(d.totalEquity) + '</td>' +
        '</tr>';
    });
    tbody.innerHTML = html;

    document.getElementById('resultCount').textContent = filtered.length + ' companies' + (search || sector ? ' (filtered)' : '');
    
    var btn = document.getElementById('showMoreBtn');
    if (showCount >= filtered.length) {
      btn.style.display = 'none';
    } else {
      btn.style.display = 'block';
      btn.textContent = 'Show More (' + Math.min(SHOW_INCREMENT, filtered.length - showCount) + ' more of ' + filtered.length + ')';
    }
  }

  // Hide the sector column header from display (sector shown inline with company)
  // Keep the data-col for sorting
  document.querySelector('th[data-col="sector"]').style.display = 'none';

  document.getElementById('searchInput').addEventListener('input', function() { showCount = SHOW_INCREMENT; renderTable(); });
  sectorSelect.addEventListener('change', function() { showCount = SHOW_INCREMENT; renderTable(); });
  document.getElementById('showMoreBtn').addEventListener('click', function() { showCount += SHOW_INCREMENT; renderTable(); });

  // Column sorting
  document.querySelectorAll('#deTable th[data-col]').forEach(function(th) {
    th.addEventListener('click', function() {
      var col = this.getAttribute('data-col');
      if (col === 'sector') return; // sector is hidden
      if (currentSort.col === col) {
        currentSort.asc = !currentSort.asc;
      } else {
        currentSort = {col: col, asc: col === 'company' || col === 'sector'};
      }
      // Update arrows
      document.querySelectorAll('#deTable th').forEach(function(h) { h.classList.remove('sorted'); });
      this.classList.add('sorted');
      this.querySelector('.sort-arrow').textContent = currentSort.asc ? '▲' : '▼';
      renderTable();
    });
  });

  renderTable();
})();
</script>

</SiteLayout>
