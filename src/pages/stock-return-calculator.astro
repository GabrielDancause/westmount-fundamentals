  }

  .comparison-table {
    width: 100%;
    border-collapse: collapse;
    margin-top: 1rem;
    background: var(--card-bg);
    border-radius: 8px;
    overflow: hidden;
    border: 1px solid var(--border-color);
  }

  .comparison-table th,
  .comparison-table td {
    padding: 1rem;
    text-align: left;
    border-bottom: 1px solid var(--border-color);
  }

  .comparison-table th {
    background: var(--bg-color);
    color: var(--text-secondary);
    font-weight: 500;
    font-size: 0.9rem;
  }

  .comparison-table tr:last-child td {
    border-bottom: none;
  }

  .comparison-table td {
    color: var(--text-primary);
    font-weight: 600;
  }

  .table-value {
    text-align: right;
  }
</style>

<script is:inline>
  document.addEventListener("DOMContentLoaded", function() {
    const inputs = [
      document.getElementById('initial-investment'),
      document.getElementById('monthly-contrib'),
      document.getElementById('final-value'),
      document.getElementById('time-period')
    ];

    const elements = {
      roiPercentage: document.getElementById('roi-percentage'),
      annualizedRoi: document.getElementById('annualized-roi'),
      tableInvested: document.getElementById('table-invested'),
      tableFinal: document.getElementById('table-final'),
      tableProfit: document.getElementById('table-profit')
    };

    function formatCurrency(num) {
      return new Intl.NumberFormat('en-US', {
        style: 'currency',
        currency: 'USD',
        minimumFractionDigits: 2,
        maximumFractionDigits: 2
      }).format(num);
    }

    function formatPercent(num) {
      return new Intl.NumberFormat('en-US', {
        style: 'percent',
        minimumFractionDigits: 2,
        maximumFractionDigits: 2
      }).format(num / 100);
    }

    function calculate() {
      let initialStr = inputs[0].value;
      let monthlyStr = inputs[1].value;
      let finalStr = inputs[2].value;
      let yearsStr = inputs[3].value;

      let initial = parseFloat(initialStr);
      let monthly = parseFloat(monthlyStr);
      let final = parseFloat(finalStr);
      let years = parseFloat(yearsStr);

      let valid = true;
      if (isNaN(initial) || initial < 0) { inputs[0].classList.add('input-error'); valid = false; initial = 0; } else { inputs[0].classList.remove('input-error'); }
      if (isNaN(monthly) || monthly < 0) { inputs[1].classList.add('input-error'); monthly = 0; } else { inputs[1].classList.remove('input-error'); }
      if (isNaN(final) || final < 0) { inputs[2].classList.add('input-error'); valid = false; final = 0; } else { inputs[2].classList.remove('input-error'); }
      if (isNaN(years) || years <= 0) { inputs[3].classList.add('input-error'); valid = false; years = 1; } else { inputs[3].classList.remove('input-error'); }

      if (!valid) {
        elements.roiPercentage.textContent = 'N/A';
        elements.annualizedRoi.textContent = 'N/A';
        elements.roiPercentage.className = 'result-value';
        elements.annualizedRoi.className = 'result-value';

        elements.tableInvested.textContent = 'N/A';
        elements.tableFinal.textContent = 'N/A';
        elements.tableProfit.textContent = 'N/A';
        return;
      }

      const totalMonths = years * 12;
      const totalContributions = monthly * totalMonths;
      const totalInvested = initial + totalContributions;

      if (totalInvested <= 0) {
        elements.roiPercentage.textContent = 'N/A';
        elements.annualizedRoi.textContent = 'N/A';
        elements.roiPercentage.className = 'result-value';
        elements.annualizedRoi.className = 'result-value';

        elements.tableInvested.textContent = formatCurrency(totalInvested);
        elements.tableFinal.textContent = formatCurrency(final);
        elements.tableProfit.textContent = formatCurrency(final - totalInvested);
        return;
      }

      const profit = final - totalInvested;
      let roi = (profit / totalInvested) * 100;

      // Float precision fix
      let fixedRoi = parseFloat(roi.toPrecision(14));
      if (Math.abs(fixedRoi - Math.round(fixedRoi)) < 1e-14) {
        roi = Math.round(fixedRoi);
      } else {
        roi = fixedRoi;
      }

      elements.roiPercentage.textContent = formatPercent(roi);
      elements.roiPercentage.className = 'result-value ' + (roi > 0 ? 'positive' : (roi < 0 ? 'negative' : ''));

      if (years > 0) {
        let cagr = 0;

        // Complex internal rate of return calculation approximation if monthly contributions exist
        if (monthly > 0) {
            // Newton-Raphson method for IRR
            let r = 0.05; // Initial guess 5%
            const maxIters = 100;
            let converged = false;

            for (let i = 0; i < maxIters; i++) {
                let f = initial * Math.pow(1 + r, totalMonths);
                let df = totalMonths * initial * Math.pow(1 + r, totalMonths - 1);

                if (r === 0) {
                    f += monthly * totalMonths;
                    df += monthly * (totalMonths * (totalMonths + 1)) / 2;
                } else {
                    f += monthly * ((Math.pow(1 + r, totalMonths) - 1) / r);
                    df += monthly * ( (totalMonths * r * Math.pow(1 + r, totalMonths - 1) - Math.pow(1 + r, totalMonths) + 1) / (r * r) );
                }

                f -= final;

                let nextR = r - f / df;
                if (Math.abs(nextR - r) < 1e-7) {
                    r = nextR;
                    converged = true;
                    break;
                }
                r = nextR;
            }

            if (converged && r > -1) {
                // convert monthly IRR to Annualized CAGR
                cagr = (Math.pow(1 + r, 12) - 1) * 100;
            } else {
                // Fallback to simple CAGR if IRR fails to converge
                cagr = (Math.pow(final / totalInvested, 1 / years) - 1) * 100;
            }
        } else {
            // Standard CAGR
            if (final > 0) {
                cagr = (Math.pow(final / initial, 1 / years) - 1) * 100;
            } else if (final === 0) {
                cagr = -100;
            }
        }

        if (isNaN(cagr) || !isFinite(cagr)) {
            elements.annualizedRoi.textContent = 'N/A';
            elements.annualizedRoi.className = 'result-value';
        } else {
            let fixedCagr = parseFloat(cagr.toPrecision(14));
            if (Math.abs(fixedCagr - Math.round(fixedCagr)) < 1e-14) {
                cagr = Math.round(fixedCagr);
            } else {
                cagr = fixedCagr;
            }
            elements.annualizedRoi.textContent = formatPercent(cagr);
            elements.annualizedRoi.className = 'result-value ' + (cagr > 0 ? 'positive' : (cagr < 0 ? 'negative' : ''));
        }
      } else {
        elements.annualizedRoi.textContent = 'N/A';
        elements.annualizedRoi.className = 'result-value';
      }

      elements.tableInvested.textContent = formatCurrency(totalInvested);
      elements.tableFinal.textContent = formatCurrency(final);
      elements.tableProfit.textContent = formatCurrency(profit);

      elements.tableProfit.style.color = profit > 0 ? 'var(--accent-color)' : (profit < 0 ? 'var(--text-secondary)' : 'var(--text-primary)');
    }

    inputs.forEach(input => {
      if (input) {
        input.addEventListener('input', calculate);
      }
    });

    // Initial calculation
    calculate();
  });
</script>

  
  
  <section style="max-width:800px;margin:40px auto;padding:0 24px">
    <div style="background:var(--card-bg,#0a1020);border:1px solid var(--border-color,#152040);border-radius:12px;padding:24px">
      <h3 style="font-size:16px;color:var(--text-bright,#fff);margin-bottom:12px">Data Sources & Methodology</h3>
      <p style="font-size:14px;color:var(--text-dim,#94a3b8);line-height:1.7;margin:0">Market data sourced from S&P Global, Federal Reserve Economic Data (FRED), and historical datasets maintained by academic researchers. Returns include both price appreciation and reinvested dividends unless otherwise noted.</p>
    </div>
  </section>

  <section style="max-width:800px;margin:40px auto;padding:0 24px">
    <div style="background:var(--card-bg,#0a1020);border:1px solid var(--border-color,#152040);border-radius:12px;padding:24px">
      <h3 style="font-size:14px;color:var(--text-dim,#94a3b8);margin-bottom:8px;text-transform:uppercase;letter-spacing:0.5px">Cite This Page</h3>
      <code style="display:block;background:var(--bg-color,#060a12);padding:16px;border-radius:8px;font-size:13px;color:var(--text-primary,#c8d0de);font-family:monospace;white-space:pre-wrap;word-break:break-all">Westmount Fundamentals. "Stock Return Calculator: True Annualized Profit Simulator." westmountfundamentals.com/stock-return-calculator, 2026.</code>
    </div>
  </section>

  <section style="max-width:800px;margin:40px auto;padding:0 24px">
    <h2 style="font-size:20px;color:var(--text-bright,#fff);margin-bottom:16px">Related Pages</h2>
    <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:12px">
      <a href="/stock-split-calculator/" style="display:block;padding:16px;background:var(--card-bg,#0a1020);border:1px solid var(--border-color,#152040);border-radius:8px;text-decoration:none;color:var(--text-primary,#c8d0de);transition:transform 0.2s" onmouseover="this.style.transform='translateY(-2px)'" onmouseout="this.style.transform='none'">Stock Split Calculator & Guide: How Forward and Reverse Spli</a>
