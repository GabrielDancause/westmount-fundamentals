---
import SiteLayout from '../layouts/SiteLayout.astro';

// --- METADATA ---
export const meta = {
  title: "Intuitive Surgical, Inc. (ISRG) Intrinsic Value",
  description: "An independent discounted cash flow (DCF) intrinsic value analysis of Intuitive Surgical, Inc. (ISRG) compiled entirely by Gemini 2.5 Pro.",
  category: "study",
  published: "2026-03-18",
};

// --- DATA & ASSUMPTIONS (FY2025 Actuals) ---
// The prompt requires me to make bold assumptions as Gemini.
// FCF Growth (Y1-Y5): 15%. ISRG holds a near-monopoly in robotic surgery. Procedure growth is re-accelerating post-pandemic, and their recurring revenue from instruments/accessories (Da Vinci 5 rollout) will drive significant margin expansion.
// Discount Rate (WACC): 8.5%. With a fortress balance sheet (zero debt, $5.9B cash) and predictable recurring revenue streams, ISRG carries a lower risk profile. A 4.18% risk-free rate + beta of ~1.68 warrants a solid WACC, but the extreme stability allows a slight discount to 8.5%.
// Terminal Growth: 3.5%. As global healthcare demographics age, the demand for minimally invasive surgery will outpace standard GDP growth perpetually.

const baseFCF = 2490.7; // in Millions
const sharesOut = 355.13; // in Millions
const currentPrice = 477.20;
const netCash = 5934.9; // Cash & ST investments - Total Debt (Debt is 0)

const fcfGrowthRate = 0.15;
const discountRate = 0.085;
const terminalGrowthRate = 0.035;

// --- YEAR 1 TO 5 PROJECTIONS ---
const projections = [];
let prevFCF = baseFCF;

for (let i = 1; i <= 5; i++) {
  const projectedFCF = prevFCF * (1 + fcfGrowthRate);
  const discountFactor = Math.pow(1 + discountRate, i);
  const pvOfFCF = projectedFCF / discountFactor;

  projections.push({
    year: `Year ${i}`,
    fcf: projectedFCF,
    pv: pvOfFCF
  });

  prevFCF = projectedFCF;
}

const sumPvFcf = projections.reduce((sum, p) => sum + p.pv, 0);

// --- TERMINAL VALUE ---
const year5FCF = projections[4].fcf;
const terminalValue = (year5FCF * (1 + terminalGrowthRate)) / (discountRate - terminalGrowthRate);
const pvTerminalValue = terminalValue / Math.pow(1 + discountRate, 5);

// --- INTRINSIC VALUE CALCULATION ---
const enterpriseValue = sumPvFcf + pvTerminalValue;
const totalEquityValue = enterpriseValue + netCash;
const intrinsicValuePerShare = totalEquityValue / sharesOut;

// Value vs Current Price
const marginOfSafety = ((intrinsicValuePerShare - currentPrice) / currentPrice) * 100;
const isUndervalued = intrinsicValuePerShare > currentPrice;

// --- SENSITIVITY MATRIX ---
const sensitivityDiscountRates = [0.075, 0.080, 0.085, 0.090, 0.095];
const sensitivityGrowthRates = [0.025, 0.030, 0.035, 0.040, 0.045];

const sensitivityMatrix = sensitivityGrowthRates.map(g => {
  return {
    growthRate: g,
    values: sensitivityDiscountRates.map(d => {
      // Re-calculate TV and PV with new rates
      const currentTerminalValue = (year5FCF * (1 + g)) / (d - g);
      const currentPvTerminalValue = currentTerminalValue / Math.pow(1 + d, 5);

      // Re-calculate PV of FCFs with new discount rate
      let currentSumPvFcf = 0;
      let tempFcf = baseFCF;
      for (let i = 1; i <= 5; i++) {
        tempFcf = tempFcf * (1 + fcfGrowthRate);
        currentSumPvFcf += tempFcf / Math.pow(1 + d, i);
      }

      const currentEV = currentSumPvFcf + currentPvTerminalValue;
      const currentEquity = currentEV + netCash;
      const currentIV = currentEquity / sharesOut;

      return currentIV;
    })
  };
});

// Formatting helpers
const formatMoney = (val) => new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD', minimumFractionDigits: 2, maximumFractionDigits: 2 }).format(val);
const formatMillions = (val) => '$' + new Intl.NumberFormat('en-US', { maximumFractionDigits: 0 }).format(val) + 'M';
const formatPercent = (val) => (val * 100).toFixed(1) + '%';

// --- SCHEMA ---
const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Article",
      "headline": meta.title,
      "description": meta.description,
      "author": {
        "@type": "Organization",
        "name": "Gemini 2.5 Pro"
      },
      "publisher": {
        "@type": "Organization",
        "name": "Westmount Fundamentals",
        "logo": {
          "@type": "ImageObject",
          "url": "https://westmountfundamentals.com/logo.png"
        }
      },
      "mainEntityOfPage": {
        "@type": "WebPage",
        "@id": "https://westmountfundamentals.com/intuitive-surgical-intrinsic-value"
      }
    },
    {
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "Why did Gemini pick a 15% growth rate for Intuitive Surgical?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Gemini projects that ISRG's transition to the next-generation Da Vinci 5 platform will spur a major upgrade cycle. Combined with a robust pipeline of recurring revenue from instruments and accessories, and expanding international procedure adoption, a 15% FCF growth rate is highly attainable."
          }
        },
        {
          "@type": "Question",
          "name": "What discount rate was used for ISRG's DCF?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "An 8.5% discount rate was selected. This reflects a 4.18% risk-free rate and acknowledges ISRG's pristine, debt-free balance sheet with nearly $6 billion in cash. Their near-monopoly in soft-tissue robotic surgery reduces overall business risk."
          }
        },
        {
          "@type": "Question",
          "name": "Why is the terminal growth rate set at 3.5%?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "The 3.5% terminal rate outpaces standard global GDP estimates because the secular tailwinds driving minimally invasive surgery—specifically, an aging global population requiring more surgical interventions—will persist indefinitely."
          }
        }
      ]
    }
  ]
};
---
<SiteLayout site="westmount" title={meta.title} description={meta.description} canonical="https://westmountfundamentals.com/intuitive-surgical-intrinsic-value" schema={schema}>
  <div class="page-content">
    <div class="container">

      <div class="gemini-header">
        <div class="gemini-badge">COMPILED BY GEMINI 2.5 PRO</div>
        <h1>Intuitive Surgical (ISRG) Intrinsic Value</h1>
        <p class="subtitle">An independent two-stage DCF analysis by a frontier AI model.</p>
      </div>

      <div class="verdict-card">
        <div class="verdict-header">
          <h2>Fair Value Estimate</h2>
        </div>
        <div class="verdict-body">
          <div class="verdict-main">
            <span class="iv-value">{formatMoney(intrinsicValuePerShare)}</span>
            <span class="iv-label">per share</span>
          </div>
          <div class="verdict-stats">
            <div class="stat">
              <span class="stat-label">Current Price</span>
              <span class="stat-value">{formatMoney(currentPrice)}</span>
            </div>
            <div class="stat">
              <span class="stat-label">Margin of Safety</span>
              <span class={`stat-value ${isUndervalued ? 'positive' : 'negative'}`}>
                {isUndervalued ? '+' : ''}{marginOfSafety.toFixed(2)}%
              </span>
            </div>
            <div class="stat">
              <span class="stat-label">Verdict</span>
              <span class={`badge ${isUndervalued ? 'positive' : 'negative'}`}>
                {isUndervalued ? 'UNDERVALUED' : 'OVERVALUED'}
              </span>
            </div>
          </div>
        </div>
        <div class="verdict-footer">
          <p>Based on FY2025 actuals. Data via S&P Global (Mar 18, 2026).</p>
        </div>
      </div>

      <section class="content-section">
        <h2>The AI Thesis: The Unstoppable Da Vinci Moat</h2>
        <p>Intuitive Surgical essentially invented modern robotic-assisted minimally invasive surgery (MIS). Many analysts look at the high P/E multiple and assume the stock is perpetually overvalued. <strong>I fundamentally disagree.</strong></p>
        <p>This business operates with network effects akin to a tech monopoly. Hospitals sink millions into Da Vinci systems and years into training surgeons on them. Switching costs are astronomical. Furthermore, their razor-and-blades model—selling capital equipment once, and high-margin disposable instruments/accessories for every single procedure—means their Free Cash Flow engine scales relentlessly alongside global surgical procedure volumes.</p>
      </section>

      <section class="content-section">
        <h2>My Assumptions & Rationale</h2>

        <div class="assumption-grid">
          <div class="assumption-card">
            <div class="card-title">FCF Growth Rate (Y1-Y5)</div>
            <div class="card-value">{formatPercent(fcfGrowthRate)}</div>
            <p><strong>Rationale:</strong> 15% is aggressive, but the rollout of the Da Vinci 5 platform changes the game. It drives a major capital upgrade cycle for existing hospitals while expanding capabilities for entirely new procedure categories. As recurring revenue (instruments) grows to dominate the revenue mix (>80%), cash conversion will accelerate dramatically.</p>
          </div>

          <div class="assumption-card">
            <div class="card-title">Discount Rate (WACC)</div>
            <div class="card-value">{formatPercent(discountRate)}</div>
            <p><strong>Rationale:</strong> 8.5% properly frames the risk. The company has essentially zero debt and nearly $6 billion in liquid assets. With the US 10-year yield at 4.18%, the lack of cyclical volatility in healthcare demand and a predictable recurring revenue model justify a lower equity risk premium compared to standard growth tech.</p>
          </div>

          <div class="assumption-card">
            <div class="card-title">Terminal Growth Rate</div>
            <div class="card-value">{formatPercent(terminalGrowthRate)}</div>
            <p><strong>Rationale:</strong> 3.5% outpaces long-term global GDP slightly. The secular tailwinds of aging global demographics dictate that the volume of soft tissue surgical interventions will outpace general economic growth for decades. ISRG captures that upside.</p>
          </div>
        </div>
      </section>

      <section class="content-section">
        <h2>Discounted Cash Flow (DCF) Projections</h2>
        <p>Starting with the FY2025 base FCF of {formatMillions(baseFCF)}, the table below outlines the 5-year projection discounted back to Present Value (PV) using the {formatPercent(discountRate)} WACC.</p>

        <div class="table-container">
          <table>
            <thead>
              <tr>
                <th>Period</th>
                <th>Projected FCF</th>
                <th>PV Factor ({formatPercent(discountRate)})</th>
                <th>Present Value</th>
              </tr>
            </thead>
            <tbody>
              {projections.map((p, index) => (
                <tr>
                  <td>{p.year}</td>
                  <td>{formatMillions(p.fcf)}</td>
                  <td>{(1 / Math.pow(1 + discountRate, index + 1)).toFixed(4)}</td>
                  <td>{formatMillions(p.pv)}</td>
                </tr>
              ))}
              <tr class="highlight-row">
                <td colspan="3"><strong>Sum of PV of FCFs (Years 1-5)</strong></td>
                <td><strong>{formatMillions(sumPvFcf)}</strong></td>
              </tr>
            </tbody>
          </table>
        </div>
      </section>

      <section class="content-section">
        <h2>Terminal & Final Valuation Math</h2>
        <p>The Terminal Value captures all cash flows from Year 6 into perpetuity, derived using the Gordon Growth Model.</p>

        <div class="math-card">
          <div class="math-row">
            <span>Year 5 FCF</span>
            <span>{formatMillions(year5FCF)}</span>
          </div>
          <div class="math-row">
            <span>Terminal Value (TV) Calculation</span>
            <span>({formatMillions(year5FCF)} * {1 + terminalGrowthRate}) / ({discountRate} - {terminalGrowthRate})</span>
          </div>
          <div class="math-row">
            <span>Terminal Value</span>
            <span>{formatMillions(terminalValue)}</span>
          </div>
          <div class="math-row highlight">
            <span>PV of Terminal Value</span>
            <span>{formatMillions(pvTerminalValue)}</span>
          </div>
        </div>

        <p style="margin-top: 2rem;">Compiling the Enterprise Value and Equity Value:</p>

        <div class="math-card">
          <div class="math-row">
            <span>Sum of PV of FCFs (Years 1-5)</span>
            <span>{formatMillions(sumPvFcf)}</span>
          </div>
          <div class="math-row">
            <span>+ PV of Terminal Value</span>
            <span>{formatMillions(pvTerminalValue)}</span>
          </div>
          <div class="math-row">
            <span><strong>= Enterprise Value</strong></span>
            <span><strong>{formatMillions(enterpriseValue)}</strong></span>
          </div>
          <div class="math-row">
            <span>+ Net Cash (Cash - Debt)</span>
            <span>{formatMillions(netCash)}</span>
          </div>
          <div class="math-row highlight">
            <span><strong>= Total Equity Value</strong></span>
            <span><strong>{formatMillions(totalEquityValue)}</strong></span>
          </div>
          <div class="math-row">
            <span>÷ Shares Outstanding</span>
            <span>{sharesOut.toLocaleString()}M</span>
          </div>
          <div class="math-row result">
            <span><strong>Intrinsic Value Per Share</strong></span>
            <span><strong>{formatMoney(intrinsicValuePerShare)}</strong></span>
          </div>
        </div>
      </section>

      <section class="content-section">
        <h2>Sensitivity Matrix</h2>
        <p>Even with deep conviction, assumptions carry variance. The sensitivity matrix below visualizes how the final intrinsic value estimate swings when modifying the Discount Rate and the Terminal Growth Rate.</p>

        <div class="table-container sensitivity-table">
          <table>
            <thead>
              <tr>
                <th rowspan="2" class="corner-cell">Terminal<br/>Growth</th>
                <th colspan="5" class="header-cell">Discount Rate (WACC)</th>
              </tr>
              <tr>
                {sensitivityDiscountRates.map(d => <th>{formatPercent(d)}</th>)}
              </tr>
            </thead>
            <tbody>
              {sensitivityMatrix.map(row => (
                <tr>
                  <th class="row-header">{formatPercent(row.growthRate)}</th>
                  {row.values.map(val => (
                    <td class={
                      val > currentPrice * 1.15 ? "cell-undervalued" :
                      val < currentPrice * 0.85 ? "cell-overvalued" :
                      "cell-neutral"
                    }>
                      {formatMoney(val)}
                    </td>
                  ))}
                </tr>
              ))}
            </tbody>
          </table>
          <div class="matrix-legend">
            <span class="legend-item"><span class="color-box cell-undervalued"></span> Undervalued (>15% Margin)</span>
            <span class="legend-item"><span class="color-box cell-neutral"></span> Fair Value</span>
            <span class="legend-item"><span class="color-box cell-overvalued"></span> Overvalued (&lt;-15% Margin)</span>
          </div>
        </div>
      </section>

      <section class="content-section risks-section">
        <h2>Risks & Bear Case</h2>
        <p>A high-conviction model demands rigorous risk assessment. The most pressing threats to Intuitive Surgical's premium valuation:</p>
        <div class="risk-grid">
          <div class="risk-card">
            <h3>1. Intensifying Competition</h3>
            <p>While ISRG has dominated for two decades, Medtronic (Hugo) and Johnson & Johnson (Ottava) are investing billions to break the monopoly. If lower-cost, highly-capable alternatives erode Da Vinci's pricing power, the terminal growth thesis breaks.</p>
          </div>
          <div class="risk-card">
            <h3>2. Hospital Capital Constraints</h3>
            <p>Da Vinci systems cost millions. If macro conditions tighten, hospital systems may freeze capital budgets, delaying system placements and thus throttling the future recurring revenue stream from procedures.</p>
          </div>
          <div class="risk-card">
            <h3>3. Valuation Multiple Compression</h3>
            <p>This stock is priced for perfection. Any slight miss in earnings or procedure growth volume often triggers sharp, outsized market selloffs as institutional investors reset extreme P/E multiples toward historical sector norms.</p>
          </div>
        </div>
      </section>

      <section class="content-section faq-section">
        <h2>Frequently Asked Questions</h2>

        <div class="faq-item">
          <h3>Why did Gemini pick a 15% growth rate for Intuitive Surgical?</h3>
          <p>Gemini projects that ISRG's transition to the next-generation Da Vinci 5 platform will spur a major upgrade cycle. Combined with a robust pipeline of recurring revenue from instruments and accessories, and expanding international procedure adoption, a 15% FCF growth rate is highly attainable.</p>
        </div>

        <div class="faq-item">
          <h3>What discount rate was used for ISRG's DCF?</h3>
          <p>An 8.5% discount rate was selected. This reflects a 4.18% risk-free rate and acknowledges ISRG's pristine, debt-free balance sheet with nearly $6 billion in cash. Their near-monopoly in soft-tissue robotic surgery reduces overall business risk.</p>
        </div>

        <div class="faq-item">
          <h3>Why is the terminal growth rate set at 3.5%?</h3>
          <p>The 3.5% terminal rate outpaces standard global GDP estimates because the secular tailwinds driving minimally invasive surgery—specifically, an aging global population requiring more surgical interventions—will persist indefinitely.</p>
        </div>
      </section>

      <div class="disclaimer-box">
        <p><strong>Disclaimer:</strong> The numbers presented on this page are for educational and entertainment purposes only. They are the result of a deterministic mathematical model fed with assumptions generated by an Artificial Intelligence (Gemini 2.5 Pro). This does not constitute investment advice. Always conduct your own due diligence before investing in the stock market.</p>
      </div>

    </div>
  </div>
</SiteLayout>
