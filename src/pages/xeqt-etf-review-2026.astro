---
import SiteLayout from "../layouts/SiteLayout.astro";

const schema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Is XEQT a good investment for 2026?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes, XEQT remains a strong choice for long-term investors seeking a globally diversified, 100% equity portfolio in a single ETF with a low management fee."
      }
    },
    {
      "@type": "Question",
      "name": "What is the difference between XEQT and VEQT?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Both are 100% equity ETFs, but XEQT has a slightly higher US allocation (approx. 45% vs 43%), lower Canadian allocation (25% vs 30%), and a slightly lower MER."
      }
    },
    {
      "@type": "Question",
      "name": "What is the MER of XEQT?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "XEQT has a Management Expense Ratio (MER) of 0.20%, which is very competitive for an all-in-one global equity portfolio."
      }
    },
    {
      "@type": "Question",
      "name": "Does XEQT pay a dividend?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes, XEQT pays distributions on a quarterly basis. The yield fluctuates based on the underlying global holdings."
      }
    },
    {
      "@type": "Question",
      "name": "What are the underlying ETFs in XEQT?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "XEQT is a fund of funds that holds four other iShares ETFs: ITOT (US equity), XIC (Canadian equity), XEF (International equity), and IEMG (Emerging Markets equity)."
      }
    }
  ]
};

export const meta = {
  title: "XEQT ETF Review 2026: iShares All Equity ETF vs VEQT",
  description: "Complete 2026 review of XEQT (iShares Core Equity ETF). See performance vs VEQT, MER, asset allocation, underlying ETFs, and if it's the best ETF.",
  category: "tool",
  published: "2026-03-15",
};
---

<SiteLayout
  site="westmount"
  title="XEQT ETF Review 2026: iShares All Equity ETF vs VEQT"
  description="Complete 2026 review of XEQT (iShares Core Equity ETF). See performance vs VEQT, MER, asset allocation, underlying ETFs, and if it's the best ETF."
  canonical="https://westmountfundamentals.com/xeqt-etf-review-2026" schema={schema}
>
  <style>

    * {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }

    body {
      font-family: 'Inter', sans-serif;
      background-color: var(--bg-color);
      color: var(--text-main);
      line-height: 1.6;
    }

    /* Sticky Nav */
    nav {
      position: sticky;
      top: 0;
      z-index: 1000;
      background-color: rgba(6, 10, 18, 0.85);
      backdrop-filter: blur(10px);
      border-bottom: 1px solid var(--border-color);
      padding: 1rem 2rem;
      display: flex;
      justify-content: space-between;
      align-items: center;
    }
    nav a {
      color: var(--text-main);
      text-decoration: none;
      font-weight: 500;
    }
    nav .brand {
      font-weight: 700;
      font-size: 1.2rem;
      color: var(--accent-color);
    }
    nav .links {
      display: flex;
      gap: 1.5rem;
    }
    nav .links a:hover {
      color: var(--accent-color);
    }

    .container {
      max-width: 1000px;
      margin: 0 auto;
      padding: 3rem 1.5rem;
    }

    h1 {
      font-size: 2.5rem;
      margin-bottom: 1rem;
      background: linear-gradient(90deg, #e2e8f0, var(--accent-color));
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      line-height: 1.2;
    }

    h2 {
      font-size: 1.8rem;
      margin: 2.5rem 0 1rem;
      color: #fff;
    }

    h3 {
      font-size: 1.4rem;
      margin: 1.5rem 0 0.5rem;
      color: #fff;
    }

    p {
      margin-bottom: 1rem;
      color: var(--text-muted);
    }

    /* Stats Cards */
    .stats-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
      gap: 1.5rem;
      margin: 2rem 0;
    }
    .stat-card {
      background-color: var(--card-bg);
      border: 1px solid var(--border-color);
      border-radius: 8px;
      padding: 1.5rem;
      text-align: center;
    }
    .stat-value {
      font-family: 'JetBrains Mono', monospace;
      font-size: 1.8rem;
      font-weight: 700;
      color: var(--accent-color);
      margin-bottom: 0.5rem;
    }
    .stat-label {
      font-size: 0.9rem;
      color: var(--text-muted);
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }

    /* Content Sections */
    .section-card {
      background-color: var(--card-bg);
      border: 1px solid var(--border-color);
      border-radius: 8px;
      padding: 2rem;
      margin-bottom: 2rem;
    }

    /* Charts */
    .chart-container {
      position: relative;
      height: 300px;
      width: 100%;
      margin: 2rem 0;
    }

    /* Data Table */
    .table-controls {
      display: flex;
      justify-content: space-between;
      margin-bottom: 1rem;
      flex-wrap: wrap;
      gap: 1rem;
    }
    input[type="text"] {
      padding: 0.5rem 1rem;
      border-radius: 4px;
      border: 1px solid var(--border-color);
      background-color: #060a12;
      color: var(--text-main);
      width: 100%;
      max-width: 300px;
    }
    input[type="text"]:focus {
      outline: none;
      border-color: var(--accent-color);
    }
    table {
      width: 100%;
      border-collapse: collapse;
      font-size: 0.95rem;
    }
    th, td {
      padding: 1rem;
      text-align: left;
      border-bottom: 1px solid var(--border-color);
    }
    th {
      font-weight: 600;
      color: #fff;
      cursor: pointer;
      user-select: none;
    }
    th:hover {
      color: var(--accent-color);
    }
    td.mono {
      font-family: 'JetBrains Mono', monospace;
    }
    tbody tr:hover {
      background-color: rgba(255, 255, 255, 0.02);
    }

    /* FAQ */
    .faq-item {
      margin-bottom: 1.5rem;
      padding-bottom: 1.5rem;
      border-bottom: 1px solid var(--border-color);
    }
    .faq-item:last-child {
      border-bottom: none;
      margin-bottom: 0;
      padding-bottom: 0;
    }
    .faq-q {
      font-weight: 600;
      color: #fff;
      margin-bottom: 0.5rem;
    }
    .faq-a {
      color: var(--text-muted);
    }

    /* Footer */
    footer {
      text-align: center;
      padding: 2rem;
      margin-top: 3rem;
      border-top: 1px solid var(--border-color);
      color: var(--text-muted);
      font-size: 0.85rem;
    }

    @media (max-width: 768px) {
      nav {
        flex-direction: column;
        gap: 1rem;
        padding: 1rem;
      }
      h1 {
        font-size: 2rem;
      }
      .chart-container {
        height: 250px;
      }
      .table-responsive {
        overflow-x: auto;
      }
    }
  </style>

<div class="container">
    <h1>XEQT ETF Review 2026: The Ultimate All-Equity ETF?</h1>
    <p>A comprehensive review of the iShares Core Equity ETF Portfolio (XEQT), comparing its performance, asset allocation, and underlying holdings against Vanguard's VEQT.</p>

    <div class="stats-grid">
      <div class="stat-card">
        <div class="stat-value" id="val-price">...</div>
        <div class="stat-label">Price (CAD)</div>
      </div>
      <div class="stat-card">
        <div class="stat-value" id="val-aum">...</div>
        <div class="stat-label">AUM</div>
      </div>
      <div class="stat-card">
        <div class="stat-value" id="val-mer">0.20%</div>
        <div class="stat-label">MER</div>
      </div>
      <div class="stat-card">
        <div class="stat-value" id="val-1y">...</div>
        <div class="stat-label">1-Year Return</div>
      </div>
    </div>

    <div class="section-card">
      <h2>Asset Allocation Breakdown</h2>
      <p>XEQT is designed to be a one-ticket solution for aggressive investors seeking 100% equity exposure. It achieves global diversification by holding four underlying iShares ETFs.</p>

      <div class="chart-container">
        <canvas id="allocationChart"></canvas>
      </div>

      <h3>Underlying Holdings</h3>
      <div class="table-responsive">
        <table>
          <thead>
            <tr>
              <th>Underlying ETF</th>
              <th>Region</th>
              <th>Target Allocation</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td>ITOT (iShares Core S&P Total US Stock Mkt)</td>
              <td>United States</td>
              <td class="mono">~45%</td>
            </tr>
            <tr>
              <td>XIC (iShares Core S&P/TSX Capped Composite)</td>
              <td>Canada</td>
              <td class="mono">~25%</td>
            </tr>
            <tr>
              <td>XEF (iShares Core MSCI EAFE IMI)</td>
              <td>International (Dev)</td>
              <td class="mono">~25%</td>
            </tr>
            <tr>
              <td>IEMG (iShares Core MSCI Emerging Markets)</td>
              <td>Emerging Markets</td>
              <td class="mono">~5%</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>

    <div class="section-card">
      <h2>XEQT vs VEQT: Performance Comparison</h2>
      <p>The primary competitor to XEQT is Vanguard's All-Equity ETF Portfolio (VEQT). While both aim to provide global equity exposure, they have slight differences in geographical allocation and fees.</p>

      <div class="table-responsive">
        <table id="performanceTable">
          <thead>
            <tr>
              <th data-sort="metric">Metric</th>
              <th data-sort="xeqt">XEQT (iShares)</th>
              <th data-sort="veqt">VEQT (Vanguard)</th>
            </tr>
          </thead>
          <tbody id="performanceBody">
            <!-- Populated via JS -->
          </tbody>
        </table>
      </div>
    </div>

    <div class="section-card">
      <h2>Underlying ETFs Details</h2>
      <div class="table-controls">
        <input type="text" id="etfSearch" placeholder="Search ETFs...">
      </div>
      <div class="table-responsive">
        <table id="etfTable">
          <thead>
            <tr>
              <th data-sort="ticker">Ticker</th>
              <th data-sort="name">Name</th>
              <th data-sort="price">Price</th>
              <th data-sort="yield">Yield</th>
            </tr>
          </thead>
          <tbody id="etfBody">
            <!-- Populated via JS -->
          </tbody>
        </table>
      </div>
    </div>

    <div class="section-card">
      <h2>Frequently Asked Questions</h2>

      <div class="faq-item">
        <div class="faq-q">Is XEQT a good investment for 2026?</div>
        <div class="faq-a">Yes, XEQT remains a strong choice for long-term investors seeking a globally diversified, 100% equity portfolio in a single ETF with a low management fee.</div>
      </div>

      <div class="faq-item">
        <div class="faq-q">What is the difference between XEQT and VEQT?</div>
        <div class="faq-a">Both are 100% equity ETFs, but XEQT has a slightly higher US allocation (approx. 45% vs 43%), lower Canadian allocation (25% vs 30%), and a slightly lower MER.</div>
      </div>

      <div class="faq-item">
        <div class="faq-q">What is the MER of XEQT?</div>
        <div class="faq-a">XEQT has a Management Expense Ratio (MER) of 0.20%, which is very competitive for an all-in-one global equity portfolio.</div>
      </div>

      <div class="faq-item">
        <div class="faq-q">Does XEQT pay a dividend?</div>
        <div class="faq-a">Yes, XEQT pays distributions on a quarterly basis. The yield fluctuates based on the underlying global holdings.</div>
      </div>

      <div class="faq-item">
        <div class="faq-q">What are the underlying ETFs in XEQT?</div>
        <div class="faq-a">XEQT is a fund of funds that holds four other iShares ETFs: ITOT (US equity), XIC (Canadian equity), XEF (International equity), and IEMG (Emerging Markets equity).</div>
      </div>
    </div>

    <div class="section-card">
      <h2>Methodology & Data Sources</h2>
      <p>Data presented on this page is sourced from Yahoo Finance API via yahoo-finance2. Returns are calculated using monthly adjusted close prices over trailing 1, 3, and 5-year periods. Asset allocation targets are based on the fund's stated mandate from iShares by BlackRock. Performance metrics are backward-looking and do not guarantee future results.</p>
    </div>

  </div>
  <script is:inline>
// Data injected at build time
    const PAGE_DATA = {"xeqt":{"price":39.97,"yield":null,"aum":14832646144,"returns":{"1Y":22.57538613150675,"3Y":60.75370578711414,"5Y":72.32773613496694}},"veqt":{"price":53.85,"yield":null,"aum":12165570560,"returns":{"1Y":23.790016931572524,"3Y":61.58811420052399,"5Y":73.78723714386982}},"itot":{"price":145.34,"yield":0.843659,"aum":82422431744},"xic":{"price":52.56,"yield":1.3711806,"aum":26922676224},"xef":{"price":46.68,"yield":null,"aum":19624194048},"iemg":{"price":69.97,"yield":1.605092,"aum":148632256512}};

    document.addEventListener('DOMContentLoaded', () => {
      if (!PAGE_DATA || !PAGE_DATA.xeqt) return;

      // Formatters
      const formatCurrency = (val) => val != null ? '$' + val.toFixed(2) : 'N/A';
      const formatPercent = (val) => val != null ? val.toFixed(2) + '%' : 'N/A';
      const formatAUM = (val) => {
        if (val == null) return 'N/A';
        if (val >= 1e9) return '$' + (val / 1e9).toFixed(2) + 'B';
        if (val >= 1e6) return '$' + (val / 1e6).toFixed(2) + 'M';
        return '$' + val;
      };

      // Populate Stats
      document.getElementById('val-price').textContent = formatCurrency(PAGE_DATA.xeqt.price);
      document.getElementById('val-aum').textContent = formatAUM(PAGE_DATA.xeqt.aum);
      document.getElementById('val-1y').textContent = formatPercent(PAGE_DATA.xeqt.returns['1Y']);

      // Setup Allocation Chart
      const ctx = document.getElementById('allocationChart').getContext('2d');
      new Chart(ctx, {
        type: 'doughnut',
        data: {
          labels: ['US Equity (ITOT)', 'Canadian Equity (XIC)', 'International Dev (XEF)', 'Emerging Markets (IEMG)'],
          datasets: [{
            data: [45, 25, 25, 5],
            backgroundColor: [
              '#4a8fe7',
              '#e74a4a',
              '#4ae78f',
              '#e7b44a'
            ],
            borderColor: '#060a12',
            borderWidth: 2
          }]
        },
        options: {
          responsive: true,
          maintainAspectRatio: false,
          plugins: {
            legend: {
              position: 'right',
              labels: { color: '#e2e8f0' }
            }
          }
        }
      });

      // Populate Performance Table
      const perfData = [
        { metric: 'Price (CAD)', xeqt: formatCurrency(PAGE_DATA.xeqt.price), veqt: formatCurrency(PAGE_DATA.veqt.price) },
        { metric: 'AUM', xeqt: formatAUM(PAGE_DATA.xeqt.aum), veqt: formatAUM(PAGE_DATA.veqt.aum) },
        { metric: 'Yield', xeqt: formatPercent(PAGE_DATA.xeqt.yield), veqt: formatPercent(PAGE_DATA.veqt.yield) },
        { metric: '1-Year Return', xeqt: formatPercent(PAGE_DATA.xeqt.returns['1Y']), veqt: formatPercent(PAGE_DATA.veqt.returns['1Y']) },
        { metric: '3-Year Return', xeqt: formatPercent(PAGE_DATA.xeqt.returns['3Y']), veqt: formatPercent(PAGE_DATA.veqt.returns['3Y']) },
        { metric: '5-Year Return', xeqt: formatPercent(PAGE_DATA.xeqt.returns['5Y']), veqt: formatPercent(PAGE_DATA.veqt.returns['5Y']) }
      ];

      const perfBody = document.getElementById('performanceBody');
      perfData.forEach(row => {
        const tr = document.createElement('tr');
        tr.innerHTML = `
          <td>${row.metric}</td>
          <td class="mono">${row.xeqt}</td>
          <td class="mono">${row.veqt}</td>
        `;
        perfBody.appendChild(tr);
      });

      // Populate Underlying ETFs Table
      const etfData = [
        { ticker: 'ITOT', name: 'iShares Core S&P Total US Stock Mkt', price: PAGE_DATA.itot.price, yield: PAGE_DATA.itot.yield },
        { ticker: 'XIC.TO', name: 'iShares Core S&P/TSX Capped Composite', price: PAGE_DATA.xic.price, yield: PAGE_DATA.xic.yield },
        { ticker: 'XEF.TO', name: 'iShares Core MSCI EAFE IMI', price: PAGE_DATA.xef.price, yield: PAGE_DATA.xef.yield },
        { ticker: 'IEMG', name: 'iShares Core MSCI Emerging Markets', price: PAGE_DATA.iemg.price, yield: PAGE_DATA.iemg.yield }
      ];

      const etfBody = document.getElementById('etfBody');
      const renderEtfTable = (data) => {
        etfBody.innerHTML = '';
        data.forEach(etf => {
          const tr = document.createElement('tr');
          tr.innerHTML = `
            <td class="mono">${etf.ticker}</td>
            <td>${etf.name}</td>
            <td class="mono">${formatCurrency(etf.price)}</td>
            <td class="mono">${formatPercent(etf.yield)}</td>
          `;
          etfBody.appendChild(tr);
        });
      };

      renderEtfTable(etfData);

      // Search functionality
      document.getElementById('etfSearch').addEventListener('keyup', (e) => {
        const query = e.target.value.toLowerCase();
        const filtered = etfData.filter(etf =>
          etf.ticker.toLowerCase().includes(query) ||
          etf.name.toLowerCase().includes(query)
        );
        renderEtfTable(filtered);
      });

      // Sort functionality
      let sortCol = '';
      let sortAsc = true;
      document.querySelectorAll('#etfTable th').forEach(th => {
        th.addEventListener('click', () => {
          const col = th.dataset.sort;
          if (sortCol === col) {
            sortAsc = !sortAsc;
          } else {
            sortCol = col;
            sortAsc = true;
          }

          const sorted = [...etfData].sort((a, b) => {
            let valA = a[col];
            let valB = b[col];
            if (typeof valA === 'string') valA = valA.toLowerCase();
            if (typeof valB === 'string') valB = valB.toLowerCase();

            if (valA < valB) return sortAsc ? -1 : 1;
            if (valA > valB) return sortAsc ? 1 : -1;
            return 0;
          });
          renderEtfTable(sorted);
        });
      });
    });
  </script>
</SiteLayout>
