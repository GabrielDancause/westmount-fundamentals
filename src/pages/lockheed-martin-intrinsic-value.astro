            </div>
          </div>
          <div class="assumption-card">
            <div class="label">Terminal Growth Rate</div>
            <div class="value">{(terminalGrowthRate * 100).toFixed(2)}%</div>
            <div class="rationale">
              Calculated as exactly half of the current 10-Year Treasury Yield ({(riskFreeRate * 100).toFixed(2)}%).
            </div>
          </div>
        </div>

