---
import SiteLayout from "../layouts/SiteLayout.astro";
import * as cheerio from "cheerio";

const schema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": "Lockheed Martin (LMT) Intrinsic Value: A DCF Analysis",
  "description": "A transparent, step-by-step discounted cash flow valuation of Lockheed Martin. Using actual FY financials to arrive at a single fair value estimate for LMT shares.",
  "datePublished": "2026-03-18",
  "dateModified": "2026-03-18",
  "author": {
    "@type": "Organization",
    "name": "Westmount Research",
    "url": "https://westmountfundamentals.com"
  },
  "publisher": {
    "@type": "Organization",
    "name": "Westmount Research",
    "url": "https://westmountfundamentals.com"
  },
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": "https://westmountfundamentals.com/lockheed-martin-intrinsic-value"
  }
};

export const meta = {
  title: "Lockheed Martin (LMT) Intrinsic Value: A DCF Analysis",
  description: "We ran a full discounted cash flow on Lockheed Martin using FY actuals. One number. Every assumption disclosed. Here's what LMT is really worth.",
  category: "study",
  published: "2026-03-18",
};

/* ═══════════════════════════════════════════════════════════════
   DATA FETCHING (Web Scraping via Cheerio)
   ═══════════════════════════════════════════════════════════════ */

async function fetchHtml(url) {
  try {
    const res = await fetch(url, {
      headers: {
        'User-Agent': 'Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36'
      }
    });
    if (!res.ok) return null;
    return await res.text();
  } catch (e) {
    return null;
  }
}

function parseRow($, rowHeaderToFind) {
  let values = null;
  $('table tbody tr').each((i, tr) => {
    const header = $(tr).find('td').first().text().trim();
    if (header === rowHeaderToFind) {
      values = [];
      $(tr).find('td').each((j, td) => {
        if (j > 0) {
          const text = $(td).text().trim().replace(/,/g, '');
          values.push(text === '-' ? 0 : parseFloat(text));
        }
      });
    }
  });
  return values;
}

let beta = null;
let currentPrice = null;

const tickerHtml = await fetchHtml('https://stockanalysis.com/stocks/lmt/');
if (tickerHtml) {
  const $ticker = cheerio.load(tickerHtml);
  currentPrice = parseFloat($ticker('.text-4xl.font-bold').text().trim().replace(/,/g, ''));
  $ticker('table tbody tr').each((i, tr) => {
    const header = $ticker(tr).find('td').first().text().trim();
    if (header === 'Beta') {
      beta = parseFloat($ticker(tr).find('td').last().text().trim());
    }
  });
}

let revenue = [], opIncome = [], netIncome = [], eps = [], sharesOut = [];
const finHtml = await fetchHtml('https://stockanalysis.com/stocks/lmt/financials/');
if (finHtml) {
  const $fin = cheerio.load(finHtml);
  revenue = parseRow($fin, 'Revenue') || [];
  opIncome = parseRow($fin, 'Operating Income') || [];
  netIncome = parseRow($fin, 'Net Income') || [];
  eps = parseRow($fin, 'EPS (Diluted)') || [];
  sharesOut = parseRow($fin, 'Shares Outstanding (Diluted)') || [];
}

let fcf = [], opCashFlow = [];
const cfHtml = await fetchHtml('https://stockanalysis.com/stocks/lmt/financials/cash-flow-statement/');
if (cfHtml) {
  const $cf = cheerio.load(cfHtml);
  fcf = parseRow($cf, 'Free Cash Flow') || [];
  opCashFlow = parseRow($cf, 'Operating Cash Flow') || [];
}

let cashAndEq = [], totalDebt = [];
const bsHtml = await fetchHtml('https://stockanalysis.com/stocks/lmt/financials/balance-sheet/');
if (bsHtml) {
  const $bs = cheerio.load(bsHtml);
  cashAndEq = parseRow($bs, 'Cash & Equivalents') || [];
  totalDebt = parseRow($bs, 'Total Debt') || [];
}

/* ═══════════════════════════════════════════════════════════════
   DCF MODEL — ALL INPUTS AND CALCULATIONS
   ═══════════════════════════════════════════════════════════════ */

const hasData = revenue.length > 0 && fcf.length > 0 && cashAndEq.length > 0 && totalDebt.length > 0 && sharesOut.length > 0 && eps.length > 0 && currentPrice !== null && beta !== null;

const latestFCF = hasData ? fcf[0] : null;
const latestShares = hasData ? sharesOut[0] : null;
const latestCash = hasData ? cashAndEq[0] : null;
const latestDebt = hasData ? totalDebt[0] : null;
const latestEPS = hasData ? eps[0] : null;
const latestRevenue = hasData ? revenue[0] : null;
const netCashVal = (latestCash !== null && latestDebt !== null) ? (latestCash - latestDebt) : null;

const riskFreeRate = 0.0418; // 10Y Treasury 4.18%
let phase1GrowthRate = null;
let terminalGrowthRate = null;
let wacc = null;
let erp = null;
let peRatio = null;
let earningsYield = null;

if (hasData) {
  // Phase 1 Growth Rate: Average of historical 4-year FCF growth
  let fcfGrowthSum = 0;
  let yearsCount = 0;
  for (let i = 0; i < Math.min(4, fcf.length - 1); i++) {
    if (fcf[i+1] > 0) {
      fcfGrowthSum += (fcf[i] - fcf[i+1]) / fcf[i+1];
      yearsCount++;
    }
  }
  phase1GrowthRate = yearsCount > 0 ? (fcfGrowthSum / yearsCount) : 0.05;
  if (phase1GrowthRate < 0) phase1GrowthRate = 0.03;

  // Terminal Growth: Half of the 10Y Treasury
  terminalGrowthRate = riskFreeRate / 2;

  // WACC: CAPM Math. Risk-free + Beta * ERP
  peRatio = currentPrice / latestEPS;
  earningsYield = 1 / peRatio;
  erp = Math.max(0.04, earningsYield - riskFreeRate);
  wacc = riskFreeRate + (beta * erp);
}

const projectedFCF = [];
let enterpriseValue = null;
let equityValue = null;
let intrinsicValuePerShare = null;
let pvPhase1 = 0;
let pvTerminalValue = 0;
let terminalValue = 0;
let fcfYear6 = 0;

if (hasData) {
  let currentFCF = latestFCF;
  for (let yr = 1; yr <= 5; yr++) {
    currentFCF = currentFCF * (1 + phase1GrowthRate);
    const pvFactor = 1 / Math.pow(1 + wacc, yr);
    const pvFCF = currentFCF * pvFactor;
    projectedFCF.push({ year: yr, fcf: currentFCF, pvFactor, pvFCF });
    pvPhase1 += pvFCF;
  }

  fcfYear6 = projectedFCF[4].fcf * (1 + terminalGrowthRate);
  terminalValue = fcfYear6 / (wacc - terminalGrowthRate);
  pvTerminalValue = terminalValue * projectedFCF[4].pvFactor;

  enterpriseValue = pvPhase1 + pvTerminalValue;
  equityValue = enterpriseValue + netCashVal;
  intrinsicValuePerShare = equityValue / latestShares;
}

const roundedIV = intrinsicValuePerShare !== null ? Math.round(intrinsicValuePerShare * 100) / 100 : null;
const marginOfSafety = (roundedIV !== null && currentPrice !== null) ? ((roundedIV - currentPrice) / currentPrice * 100).toFixed(1) : null;
const verdictText = (roundedIV !== null && currentPrice !== null) ? (roundedIV > currentPrice ? "Undervalued" : "Overvalued") : "N/A";
const verdictColor = (roundedIV !== null && currentPrice !== null) ? (roundedIV > currentPrice ? "#10b981" : "#ef4444") : "#5a6a80";

const revHistory = [];
const fcfHistory = [];
const epsHistory = [];
const marginHistory = [];

if (hasData) {
  for (let i = 0; i < Math.min(5, revenue.length); i++) {
    const yr = 2025 - i;
    revHistory.unshift({ year: yr, value: revenue[i] });
    fcfHistory.unshift({ year: yr, value: fcf[i] });
    epsHistory.unshift({ year: yr, value: eps[i] });
    marginHistory.unshift({
      year: yr,
      operating: ((opIncome[i] / revenue[i]) * 100).toFixed(1),
      profit: ((netIncome[i] / revenue[i]) * 100).toFixed(1),
      fcfMargin: ((fcf[i] / revenue[i]) * 100).toFixed(1)
    });
  }
}

const sensitivityRates = wacc !== null ? [wacc - 0.02, wacc - 0.01, wacc, wacc + 0.01, wacc + 0.02] : [];
const sensitivityGrowth = phase1GrowthRate !== null ? [Math.max(0, phase1GrowthRate - 0.02), Math.max(0.01, phase1GrowthRate - 0.01), phase1GrowthRate, phase1GrowthRate + 0.01, phase1GrowthRate + 0.02] : [];
const sensitivityTable = [];

if (hasData) {
  sensitivityRates.forEach(dr => {
    const row = { dr, values: [] };
    sensitivityGrowth.forEach(gr => {
      let f = latestFCF;
      let pvSum = 0;
      for (let y = 1; y <= 5; y++) {
        f = f * (1 + gr);
        pvSum += f / Math.pow(1 + dr, y);
      }
      const f6 = f * (1 + terminalGrowthRate);
      const tv = f6 / (dr - terminalGrowthRate);
      const pvTV = tv / Math.pow(1 + dr, 5);
      row.values.push(Math.round((pvSum + pvTV + netCashVal) / latestShares));
    });
    sensitivityTable.push(row);
  });
}
---

<SiteLayout
  site="westmount"
  title="Lockheed Martin (LMT) Intrinsic Value: A DCF Analysis"
  description="We ran a full discounted cash flow on Lockheed Martin using FY actuals. One number. Every assumption disclosed. Here's what LMT is really worth."
