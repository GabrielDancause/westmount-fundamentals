  <script>
    function initDripCalculator() {
      const container = document.getElementById('drip-calc-container');
      if (!container || container.dataset.initialized) return;
      container.dataset.initialized = 'true';

      const inputs = {
        initial: document.getElementById('initial-investment'),
        contribution: document.getElementById('annual-contribution'),
        yield: document.getElementById('dividend-yield'),
        appreciation: document.getElementById('annual-appreciation'),
        years: document.getElementById('years'),
        frequency: document.getElementById('dividend-frequency'),
        drip: document.getElementById('reinvest-dividends')
      };

      const outputs = {
        finalValue: document.getElementById('final-value'),
        totalContributions: document.getElementById('total-contributions'),
        totalDividends: document.getElementById('total-dividends'),
        totalAppreciation: document.getElementById('total-appreciation'),
        annualIncome: document.getElementById('final-annual-income'),
        advantage: document.getElementById('drip-advantage')
      };

      const formatCurrency = (val) => new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD' }).format(val);

      function calculateDrip() {
        // Parse inputs
        const initial = Math.max(0, parseFloat(inputs.initial.value) || 0);
        const annualContribution = Math.max(0, parseFloat(inputs.contribution.value) || 0);
        const dividendYield = parseFloat(inputs.yield.value) || 0;
        const appreciation = parseFloat(inputs.appreciation.value) || 0;
        const years = Math.max(1, Math.min(100, parseInt(inputs.years.value) || 0));
        const freq = parseInt(inputs.frequency.value) || 4;
        const isDrip = inputs.drip.checked;

        // Convert rates to periodic
        const periodicYield = dividendYield / 100 / freq;
        const periodicAppreciation = appreciation / 100 / freq;
        const periodicContribution = annualContribution / freq;
        const totalPeriods = years * freq;

        let currentPortfolioValue = initial;
        let nonDripPortfolioValue = initial;

        let totalDividends = 0;
        let nonDripTotalDividends = 0;
        let totalPrincipal = initial;

        for (let period = 1; period <= totalPeriods; period++) {
          // Add contributions
          currentPortfolioValue += periodicContribution;
          nonDripPortfolioValue += periodicContribution;
          totalPrincipal += periodicContribution;

          // Calculate appreciation for the period
          const appreciationGained = currentPortfolioValue * periodicAppreciation;
          const nonDripAppreciationGained = nonDripPortfolioValue * periodicAppreciation;

          currentPortfolioValue += appreciationGained;
          nonDripPortfolioValue += nonDripAppreciationGained;

          // Calculate dividends
          const periodDividend = currentPortfolioValue * periodicYield;
          const nonDripPeriodDividend = nonDripPortfolioValue * periodicYield;

          totalDividends += periodDividend;
          nonDripTotalDividends += nonDripPeriodDividend;

          if (isDrip) {
            currentPortfolioValue += periodDividend;
          }
        }

        const finalAnnualIncome = currentPortfolioValue * (dividendYield / 100);
        const totalAppreciation = currentPortfolioValue - totalPrincipal - (isDrip ? totalDividends : 0);

        outputs.finalValue.textContent = formatCurrency(currentPortfolioValue);
        outputs.totalContributions.textContent = formatCurrency(totalPrincipal);
        outputs.totalDividends.textContent = formatCurrency(totalDividends);
        outputs.totalAppreciation.textContent = formatCurrency(Math.max(0, totalAppreciation));
        outputs.annualIncome.textContent = formatCurrency(finalAnnualIncome);

        if (isDrip) {
          const advantageAmount = currentPortfolioValue - (nonDripPortfolioValue + nonDripTotalDividends);
          if (advantageAmount > 0) {
            outputs.advantage.textContent = `+${formatCurrency(advantageAmount)} advantage vs taking cash dividends`;
            outputs.advantage.style.color = 'var(--success-color, #22c55e)';
          } else {
            outputs.advantage.textContent = '';
          }
        } else {
          outputs.advantage.textContent = `Note: Final value does not include ${formatCurrency(totalDividends)} in cash dividends taken.`;
          outputs.advantage.style.color = 'var(--text-secondary)';
        }
      }

      // Attach event listeners to all inputs
      Object.values(inputs).forEach(input => {
        if (input) {
          input.addEventListener('input', calculateDrip);
          if (input.type === 'checkbox') {
            input.addEventListener('change', calculateDrip);
          }
        }
      });

      // Initial calculation
      calculateDrip();
    }

    document.addEventListener('DOMContentLoaded', initDripCalculator);
    document.addEventListener('astro:page-load', initDripCalculator);
  </script>
