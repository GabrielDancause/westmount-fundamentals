      <div class="stat-value">$10.6B</div>
      <div class="stat-label">FY2025 Revenue</div>
    </div>
    <div class="stat-card">
      <div class="stat-value">$3.78B</div>
      <div class="stat-label">Free Cash Flow</div>
    </div>
    <div class="stat-card">
      <div class="stat-value">$5.40</div>
      <div class="stat-label">EPS (Diluted)</div>
    </div>
