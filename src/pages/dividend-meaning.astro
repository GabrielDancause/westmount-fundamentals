          <div style="display: flex; justify-content: space-between; border-bottom: 1px solid var(--border-color); padding-bottom: 0.5rem; margin-bottom: 0.5rem;">
            <span style="color: var(--text-secondary);">Total Contributions:</span>
            <span id="result-contributions" style="font-weight: bold; color: var(--text-primary);">$34,000.00</span>
          </div>

          <div style="display: flex; justify-content: space-between; border-bottom: 1px solid var(--border-color); padding-bottom: 0.5rem; margin-bottom: 0.5rem;">
            <span style="color: var(--text-secondary);">Final Portfolio Value (No DRIP):</span>
            <span id="result-no-drip" style="font-weight: bold; color: var(--text-primary);">$75,640.12</span>
          </div>

          <div style="display: flex; justify-content: space-between; border-bottom: 1px solid var(--border-color); padding-bottom: 0.5rem; margin-bottom: 0.5rem;">
            <span style="color: var(--text-secondary);">Final Portfolio Value (With DRIP):</span>
            <span id="result-with-drip" style="font-weight: bold; color: var(--accent-color); font-size: 1.2rem;">$123,456.78</span>
          </div>

          <div style="margin-top: 1rem; text-align: right;">
            <span style="font-style: italic; color: var(--text-secondary);">Extra Wealth from DRIP: </span>
            <span id="result-difference" style="font-weight: bold; color: var(--accent-color);">+$47,816.66</span>
          </div>
        </div>
      </div>
    </section>

    <script is:inline>
      document.addEventListener('DOMContentLoaded', () => {
        const initialInvestmentInput = document.getElementById('initial-investment');
        const annualContributionInput = document.getElementById('annual-contribution');
        const dividendYieldInput = document.getElementById('dividend-yield');
        const sharePriceAppreciationInput = document.getElementById('share-price-appreciation');
        const yearsInput = document.getElementById('years');

        const displayYears = document.getElementById('display-years');
        const resultContributions = document.getElementById('result-contributions');
        const resultNoDrip = document.getElementById('result-no-drip');
        const resultWithDrip = document.getElementById('result-with-drip');
        const resultDifference = document.getElementById('result-difference');

        const formatCurrency = (value) => {
          return new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD' }).format(value);
        };

        const calculateDRIP = () => {
          const initial = parseFloat(initialInvestmentInput.value) || 0;
          const annualCont = parseFloat(annualContributionInput.value) || 0;
          const divYield = (parseFloat(dividendYieldInput.value) || 0) / 100;
          const appreciation = (parseFloat(sharePriceAppreciationInput.value) || 0) / 100;
          const years = parseInt(yearsInput.value) || 0;

          const totalContributions = initial + (annualCont * years);

          // Calculate No DRIP (capital appreciation only)
          let balanceNoDrip = initial;
          for (let i = 0; i < years; i++) {
            balanceNoDrip = (balanceNoDrip + annualCont) * (1 + appreciation);
          }

          // Calculate With DRIP (capital appreciation + dividend reinvestment)
          // Effectively the total growth rate is appreciation + yield
          const totalReturnRate = appreciation + divYield;
          let balanceWithDrip = initial;
          for (let i = 0; i < years; i++) {
            balanceWithDrip = (balanceWithDrip + annualCont) * (1 + totalReturnRate);
          }

          const difference = balanceWithDrip - balanceNoDrip;

          // Update DOM
          displayYears.textContent = years;
          resultContributions.textContent = formatCurrency(totalContributions);
          resultNoDrip.textContent = formatCurrency(balanceNoDrip);
          resultWithDrip.textContent = formatCurrency(balanceWithDrip);
          resultDifference.textContent = '+' + formatCurrency(Math.max(0, difference));
        };

        // Attach event listeners for real-time calculation
        [initialInvestmentInput, annualContributionInput, dividendYieldInput, sharePriceAppreciationInput, yearsInput].forEach(input => {
          input.addEventListener('input', calculateDRIP);
        });

        // Initial calculation
        calculateDRIP();

        // FAQ Accordion Logic
        const faqQuestions = document.querySelectorAll('.faq-question');
        faqQuestions.forEach(question => {
          question.addEventListener('click', () => {
            const answer = question.nextElementSibling;
            const isOpen = answer.style.display === 'block';

            // Close all other answers
            document.querySelectorAll('.faq-answer').forEach(a => {
              a.style.display = 'none';
              a.previousElementSibling.classList.remove('active');
            });

            // Toggle current answer
            if (!isOpen) {
              answer.style.display = 'block';
              question.classList.add('active');
            }
          });
        });
      });
    </script>

    <style>
      .faq-section {
        margin: 3rem 0;
      }
      .faq-item {
        margin-bottom: 1rem;
        border: 1px solid var(--border-color);
        border-radius: 8px;
        overflow: hidden;
      }
      .faq-question {
        width: 100%;
