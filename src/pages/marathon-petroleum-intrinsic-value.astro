export const meta = {
  title: "Marathon Petroleum (MPC) Intrinsic Value: A DCF Analysis",
  description: "We ran a full discounted cash flow on Marathon Petroleum using FY2025 actuals. One number. Every assumption disclosed. Here's what MPC is really worth.",
  category: "study",
  published: "2026-03-18",
};

/* ═══════════════════════════════════════════════════════════════
   DCF MODEL — ALL INPUTS AND CALCULATIONS
   Every number is sourced from Marathon Petroleum's FY2025 10-K.
   We use a two-stage DCF: high-growth phase (Years 1-5) then terminal value.
   ═══════════════════════════════════════════════════════════════ */


// --- DATA FETCHING (stockanalysis.com) ---

// --- DATA FETCHING (stockanalysis.com) ---
let fcf2025 = 4767;

let sharesOutstanding = 306;
let cashAndInvestments = 3672;
let totalDebt = 34358;
let currentPrice = 237.99;
let revenueHistory = [
  { year: 2021, value: 119983 },
  { year: 2022, value: 177453 },
  { year: 2023, value: 148379 },
  { year: 2024, value: 138864 },
  { year: 2025, value: 132699 },
];
let fcfHistory = [
  { year: 2021, value: 11280 },
  { year: 2022, value: 30260 },
  { year: 2023, value: 12227 },
  { year: 2024, value: 6132 },
  { year: 2025, value: 4767 },
];
let epsHistory = [
  { year: 2021, value: 15.24 },
  { year: 2022, value: 28.12 },
  { year: 2023, value: 23.63 },
  { year: 2024, value: 10.08 },
  { year: 2025, value: 13.22 },
];
let marginHistory = [
  { year: 2021, operating: 2.79, profit: 2.13, fcfMargin: 9.40 },
  { year: 2022, operating: 10.69, profit: 9.00, fcfMargin: 17.05 },
  { year: 2023, operating: 9.78, profit: 7.53, fcfMargin: 8.24 },
  { year: 2024, operating: 4.89, profit: 3.65, fcfMargin: 4.42 },
  { year: 2025, operating: 6.25, profit: 4.43, fcfMargin: 3.59 },
];
let netIncome2025 = 4047;
let operatingIncome2025 = 8291;
let revenue2025 = 132699;

try {
  // We use Cheerio to extract the data array script from StockAnalysis
  const [isRes, bsRes] = await Promise.all([
    fetch('https://stockanalysis.com/stocks/mpc/financials/'),
    fetch('https://stockanalysis.com/stocks/mpc/financials/balance-sheet/')
  ]);

  if (isRes.ok && bsRes.ok) {
    const isHtml = await isRes.text();
    const bsHtml = await bsRes.text();

    const extractArray = (html, key) => {
      const match = html.match(new RegExp(`${key}:\[(.*?)\]`));
      return match ? match[1].split(',').map(n => n === 'null' ? null : Number(n)) : null;
    };

    const isDataMatch = isHtml.match(/financialData:(\{.*?\})/);
    const bsDataMatch = bsHtml.match(/financialData:(\{.*?\})/);

    if (isDataMatch && bsDataMatch) {
      const isDataStr = isDataMatch[1];
      const bsDataStr = bsDataMatch[1];

      const datesMatch = isDataStr.match(/"?datekey"?:\[(.*?)\]/);
      if (!datesMatch) throw new Error("Could not find dates array.");
      const isDates = datesMatch[1].split(',').map(s => s.replace(/"/g, ''));
      const years = isDates.map(d => d === 'TTM' ? 2025 : parseInt(d.split('-')[0])).filter(y => !isNaN(y));

      const fcfArr = extractArray(isDataStr, 'fcf');
      const sharesArr = extractArray(isDataStr, 'sharesDiluted') || extractArray(isDataStr, 'sharesBasic');
      const revArr = extractArray(isDataStr, 'revenue');
      const epsArr = extractArray(isDataStr, 'epsDiluted');
      const netIncArr = extractArray(isDataStr, 'netIncome');
      const opIncArr = extractArray(isDataStr, 'operatingIncome');

      const cashArr = extractArray(bsDataStr, 'cashneq') || extractArray(bsDataStr, 'cash');
      const stInvestArr = extractArray(bsDataStr, 'investmentsc');
      // Debt often has multiple matches, total debt is usually the last one or named 'debt'
      const debtMatches = [...bsDataStr.matchAll(/debt[^:]*:\\[(.*?)\\]/g)];
      const totalDebtArr = debtMatches.length > 0 ? debtMatches[debtMatches.length - 1][1].split(',').map(Number) : null;

      // Update inputs with actual TTM/latest data (index 1 is usually the latest full year if TTM is 0)
      // StockAnalysis usually puts TTM at index 0. If we want FY2025 or TTM, index 0 is best.
      let latestIdx = isDates[0] === 'TTM' ? 0 : 0;

      if (fcfArr && fcfArr[latestIdx]) fcf2025 = fcfArr[latestIdx] / 1000000;
      if (sharesArr && sharesArr[latestIdx]) sharesOutstanding = sharesArr[latestIdx] / 1000000;
      if (revArr && revArr[latestIdx]) revenue2025 = revArr[latestIdx] / 1000000;
      if (epsArr && epsArr[latestIdx]) epsHistory[4].value = epsArr[latestIdx];

      let cash = cashArr && cashArr[latestIdx] ? cashArr[latestIdx] : 0;
      let stInvest = stInvestArr && stInvestArr[latestIdx] ? stInvestArr[latestIdx] : 0;
      if (cash || stInvest) cashAndInvestments = (cash + (isNaN(stInvest) ? 0 : stInvest)) / 1000000;

      if (totalDebtArr && totalDebtArr[latestIdx]) totalDebt = totalDebtArr[latestIdx] / 1000000;

      // Try to extract price
      const quoteMatch = isHtml.match(/quote:(\{.*?\})/);
      if (quoteMatch) {
         const pMatch = quoteMatch[1].match(/p:([0-9.]+)/);
         if (pMatch) currentPrice = parseFloat(pMatch[1]);
      }

      // Rebuild history arrays
      if (revArr && fcfArr && epsArr && years.length >= 6) {
        revenueHistory = [];
        fcfHistory = [];
        epsHistory = [];
        marginHistory = [];
        // Loop backwards to get oldest to newest (indices 5 to 1)
        for (let i = 5; i >= 1; i--) {
           if (years[i]) {
             revenueHistory.push({ year: years[i], value: revArr[i] ? revArr[i]/1000000 : 0 });
             fcfHistory.push({ year: years[i], value: fcfArr[i] ? fcfArr[i]/1000000 : 0 });
             epsHistory.push({ year: years[i], value: epsArr[i] || 0 });

             let opMargin = opIncArr && revArr[i] ? (opIncArr[i]/revArr[i])*100 : 0;
             let pMargin = netIncArr && revArr[i] ? (netIncArr[i]/revArr[i])*100 : 0;
             let fcfMargin = fcfArr && revArr[i] ? (fcfArr[i]/revArr[i])*100 : 0;
             marginHistory.push({
               year: years[i],
               operating: opMargin,
               profit: pMargin,
               fcfMargin: fcfMargin
             });
           }
        }
      }
    }
  }
} catch (e) {
  console.error("Error fetching MPC data:", e);
}

const netCash = cashAndInvestments - totalDebt; // Net Debt

// --- ASSUMPTIONS (fully disclosed below) ---
const growthRatePhase1 = 0.02;         // 2% FCF growth, Years 1-5 (Conservative due to recent FCF drops)
const growthRateTerminal = 0.015;      // 1.5% perpetuity growth (terminal)
const discountRate = 0.09;             // 9% WACC / required return

// --- PHASE 1: PROJECT FCF FOR YEARS 1-5 ---
const projectedFCF = [];
let fcf = fcf2025;
for (let yr = 1; yr <= 5; yr++) {
  fcf = fcf * (1 + growthRatePhase1);
  projectedFCF.push({ year: yr, fcf: Math.round(fcf), pvFactor: 1 / Math.pow(1 + discountRate, yr) });
}
projectedFCF.forEach(p => { p.pvFCF = Math.round(p.fcf * p.pvFactor); });

// --- PHASE 2: TERMINAL VALUE (Gordon Growth Model) ---
const fcfYear6 = projectedFCF[4].fcf * (1 + growthRateTerminal);
const terminalValue = Math.round(fcfYear6 / (discountRate - growthRateTerminal));
const pvTerminalValue = Math.round(terminalValue * projectedFCF[4].pvFactor);

// --- ENTERPRISE VALUE ---
const pvPhase1 = projectedFCF.reduce((sum, p) => sum + p.pvFCF, 0);
const enterpriseValue = pvPhase1 + pvTerminalValue;

// --- EQUITY VALUE ---
const equityValue = enterpriseValue + netCash;
const intrinsicValuePerShare = equityValue / sharesOutstanding;
const roundedIV = Math.round(intrinsicValuePerShare * 100) / 100;

// Market comparison

const marginOfSafety = ((roundedIV - currentPrice) / currentPrice * 100).toFixed(1);
const verdictText = roundedIV > currentPrice ? "Undervalued" : "Overvalued";
const verdictColor = roundedIV > currentPrice ? "#10b981" : "#ef4444";

// --- HISTORICAL DATA for charts ---
// (populated from fetch above)

// Sensitivity analysis
const sensitivityRates = [0.07, 0.08, 0.09, 0.10, 0.11];
const sensitivityGrowth = [0.00, 0.01, 0.02, 0.03, 0.04];
const sensitivityTable = sensitivityRates.map(dr => {
  return {
    dr,
    values: sensitivityGrowth.map(gr => {
      let f = fcf2025;
      let pvSum = 0;
      for (let y = 1; y <= 5; y++) {
        f = f * (1 + gr);
        pvSum += f / Math.pow(1 + dr, y);
      }
      const f6 = f * (1 + growthRateTerminal);
      const tv = f6 / (dr - growthRateTerminal);
      const pvTV = tv / Math.pow(1 + dr, 5);
      return Math.round((pvSum + pvTV + netCash) / sharesOutstanding);
    })
  };
});
