---
import SiteLayout from "../layouts/SiteLayout.astro";
import * as cheerio from 'cheerio';

const schema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": "Lowe's (LOW) Intrinsic Value: A DCF Analysis",
  "description": "A transparent, step-by-step discounted cash flow valuation of Lowe's Companies, Inc. (LOW). Using actual financials to arrive at a single fair value estimate.",
  "datePublished": new Date().toISOString().split('T')[0],
  "dateModified": new Date().toISOString().split('T')[0],
  "author": {
    "@type": "Organization",
    "name": "Westmount Research",
    "url": "https://westmountfundamentals.com"
  },
  "publisher": {
    "@type": "Organization",
    "name": "Westmount Research",
    "url": "https://westmountfundamentals.com"
  },
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": "https://westmountfundamentals.com/lowes-intrinsic-value"
  }
};

export const meta = {
  title: "Lowe's (LOW) Intrinsic Value: A DCF Analysis",
  description: "We ran a full discounted cash flow on Lowe's using actuals. One number. Every assumption disclosed. Here's what LOW is really worth.",
  category: "study",
  published: new Date().toISOString().split('T')[0],
};

/* ═══════════════════════════════════════════════════════════════
   DATA FETCHING (Build-time)
   ═══════════════════════════════════════════════════════════════ */
const stockUrl = 'https://stockanalysis.com/stocks/low/';
const finUrl = 'https://stockanalysis.com/stocks/low/financials/';
const cfUrl = 'https://stockanalysis.com/stocks/low/financials/cash-flow-statement/';
const bsUrl = 'https://stockanalysis.com/stocks/low/financials/balance-sheet/';

const headers = { 'User-Agent': 'Mozilla/5.0 (Windows NT 10.0; Win64; x64)' };
let currentPrice = null;
let fcfData = [];
let revData = [];
let epsData = [];
let opMarginData = [];
let profitMarginData = [];
let cashData = [];
let debtData = [];
let sharesData = [];
let yearsData = [];

try {
  const [stockHtml, finHtml, cfHtml, bsHtml] = await Promise.all([
    fetch(stockUrl, { headers }).then(r => r.text()),
    fetch(finUrl, { headers }).then(r => r.text()),
    fetch(cfUrl, { headers }).then(r => r.text()),
    fetch(bsUrl, { headers }).then(r => r.text())
  ]);

  const $ = cheerio.load(stockHtml);
  currentPrice = parseFloat($('.text-4xl.font-bold').first().text().trim());

  const parseTable = (html) => {
    const $c = cheerio.load(html);
    const years = [];
    $c('table thead tr th').each((i, el) => {
      const text = $c(el).text().trim();
      if (text.match(/20\\d{2}/) || text.includes('TTM') || text.includes('Current')) {
        let yrMatch = text.match(/20\\d{2}/);
        years.push(yrMatch ? yrMatch[0] : text);
      }
    });

    const data = {};
    $c('table tbody tr').each((i, el) => {
      const rowName = $c(el).find('td').first().text().trim();
      const rowData = [];
      $c(el).find('td').each((j, td) => {
         if (j > 0) rowData.push($c(td).text().trim());
      });
      data[rowName] = { years, rowData };
    });
    return data;
  };

  const fin = parseTable(finHtml);
  const cf = parseTable(cfHtml);
  const bs = parseTable(bsHtml);

  const getRow = (data, key) => data[key] ? data[key].rowData : [];
  const cleanNum = (str) => {
    if (!str || str === '-') return null;
    let multiplier = 1;
    if (str.includes('B')) { multiplier = 1000; str = str.replace('B', ''); }
    else if (str.includes('M')) { multiplier = 1; str = str.replace('M', ''); }
    else if (str.includes('T')) { multiplier = 1000000; str = str.replace('T', ''); }
    const val = parseFloat(str.replace(/,/g, ''));
    return isNaN(val) ? null : val * multiplier;
  };

  const parseNum = (str) => {
    if (!str || str === '-') return null;
    const val = parseFloat(str.replace(/,/g, '').replace('%', ''));
    return isNaN(val) ? null : val;
  };

  if (fin['Revenue']) yearsData = fin['Revenue'].years;
  revData = getRow(fin, 'Revenue').map(cleanNum);
  epsData = getRow(fin, 'EPS (Diluted)').map(parseNum);
  sharesData = getRow(fin, 'Shares Outstanding (Diluted)').map(cleanNum);
  fcfData = getRow(cf, 'Free Cash Flow').map(cleanNum);
  opMarginData = getRow(fin, 'Operating Margin').map(parseNum);
  profitMarginData = getRow(fin, 'Profit Margin').map(parseNum);
  cashData = getRow(bs, 'Cash & Equivalents').map(cleanNum);
  debtData = getRow(bs, 'Total Debt').map(cleanNum);

} catch (e) {
  console.error("Failed to fetch or parse stock data:", e);
}

/* ═══════════════════════════════════════════════════════════════
   DCF MODEL — ALL INPUTS AND CALCULATIONS
   ═══════════════════════════════════════════════════════════════ */

// --- INPUTS (all in millions USD unless noted) ---
const fcfBase = fcfData[0] !== undefined && fcfData[0] !== null ? fcfData[0] : null;
const sharesOutstanding = sharesData[0] !== undefined && sharesData[0] !== null ? sharesData[0] : null;
const cashAndInvestments = cashData[0] !== undefined && cashData[0] !== null ? cashData[0] : null;
const totalDebt = debtData[0] !== undefined && debtData[0] !== null ? debtData[0] : null;
const netCash = (cashAndInvestments !== null && totalDebt !== null) ? cashAndInvestments - totalDebt : null;
const recentRev = revData[0] !== undefined && revData[0] !== null ? revData[0] : null;
const recentEPS = epsData[0] !== undefined && epsData[0] !== null ? epsData[0] : null;
const recentOpMargin = opMarginData[0] !== undefined && opMarginData[0] !== null ? opMarginData[0] : null;

// --- ASSUMPTIONS (fully disclosed below) ---
const growthRatePhase1 = 0.05;         // 5% FCF growth, Years 1-5
const growthRateTerminal = 0.025;      // 2.5% perpetuity growth (terminal)
const discountRate = 0.09;             // 9% WACC / required return

// --- PHASE 1: PROJECT FCF FOR YEARS 1-5 ---
const projectedFCF = [];
let fcf = fcfBase;
if (fcf !== null) {
  for (let yr = 1; yr <= 5; yr++) {
    fcf = fcf * (1 + growthRatePhase1);
    const pvFactor = 1 / Math.pow(1 + discountRate, yr);
    const pvFCF = Math.round(fcf * pvFactor);
    projectedFCF.push({ year: yr, fcf: Math.round(fcf), pvFactor, pvFCF });
  }
}

// --- PHASE 2: TERMINAL VALUE (Gordon Growth Model) ---
let fcfYear6 = null;
let terminalValue = null;
let pvTerminalValue = 0;
if (projectedFCF.length === 5) {
  fcfYear6 = projectedFCF[4].fcf * (1 + growthRateTerminal);
  terminalValue = Math.round(fcfYear6 / (discountRate - growthRateTerminal));
  pvTerminalValue = Math.round(terminalValue * projectedFCF[4].pvFactor);
}

// --- ENTERPRISE VALUE ---
const pvPhase1Total = projectedFCF.reduce((sum, p) => sum + p.pvFCF, 0);
const enterpriseValue = (pvPhase1Total !== null && pvTerminalValue !== null) ? pvPhase1Total + pvTerminalValue : null;

// --- EQUITY VALUE ---
let equityValue = null;
let intrinsicValuePerShare = null;
let roundedIV = null;
if (enterpriseValue !== null && netCash !== null) {
  equityValue = enterpriseValue + netCash;
  if (sharesOutstanding) {
    intrinsicValuePerShare = equityValue / sharesOutstanding;
    roundedIV = Math.round(intrinsicValuePerShare * 100) / 100;
  }
}

// Market comparison
let marginOfSafety = null;
let verdictText = "N/A";
let verdictColor = "#7a8a9e";
if (roundedIV !== null && currentPrice !== null && !isNaN(currentPrice)) {
  marginOfSafety = ((roundedIV - currentPrice) / currentPrice * 100).toFixed(1);
  verdictText = roundedIV > currentPrice ? "Undervalued" : "Overvalued";
  verdictColor = roundedIV > currentPrice ? "#10b981" : "#ef4444";
}

// --- HISTORICAL DATA for charts ---
// Reverse arrays to be chronological (oldest to newest) and take up to 5 years
const getHistory = (dataArr) => {
  if (!dataArr || dataArr.length === 0) return [];
  const limit = Math.min(5, dataArr.length, yearsData.length);
  const result = [];
  for (let i = limit - 1; i >= 0; i--) {
    result.push({ year: yearsData[i], value: dataArr[i] });
  }
  return result;
};

const revenueHistory = getHistory(revData);
const fcfHistory = getHistory(fcfData);
const epsHistory = getHistory(epsData);
const marginHistory = [];
const marginLimit = Math.min(5, yearsData.length, opMarginData.length, profitMarginData.length);
for (let i = marginLimit - 1; i >= 0; i--) {
  marginHistory.push({
    year: yearsData[i],
    operating: opMarginData[i],
    profit: profitMarginData[i],
  });
}

// Sensitivity analysis
const sensitivityRates = [0.07, 0.08, 0.09, 0.10, 0.11];
const sensitivityGrowth = [0.03, 0.04, 0.05, 0.06, 0.07];
const sensitivityTable = sensitivityRates.map(dr => {
  return {
    dr,
    values: sensitivityGrowth.map(gr => {
      if (fcfBase === null || netCash === null || sharesOutstanding === null) return null;
      let f = fcfBase;
      let pvSum = 0;
      for (let y = 1; y <= 5; y++) {
        f = f * (1 + gr);
        pvSum += f / Math.pow(1 + dr, y);
      }
      const f6 = f * (1 + growthRateTerminal);
      const tv = f6 / (dr - growthRateTerminal);
      const pvTV = tv / Math.pow(1 + dr, 5);
      return Math.round((pvSum + pvTV + netCash) / sharesOutstanding);
    })
  };
});
