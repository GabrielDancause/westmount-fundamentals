const chartData = [{"year":1960,"yield":3.43,"treasury":4.72},{"year":1961,"yield":2.82,"treasury":3.84},{"year":1962,"yield":3.4,"treasury":4.08},{"year":1963,"yield":3.07,"treasury":3.83},{"year":1964,"yield":2.98,"treasury":4.17},{"year":1965,"yield":2.97,"treasury":4.19},{"year":1966,"yield":3.53,"treasury":4.61},{"year":1967,"yield":3.06,"treasury":4.58},{"year":1968,"yield":2.88,"treasury":5.53},{"year":1969,"yield":3.47,"treasury":6.04},{"year":1970,"yield":3.49,"treasury":7.79},{"year":1971,"yield":3.1,"treasury":6.24},{"year":1972,"yield":2.68,"treasury":5.95},{"year":1973,"yield":3.57,"treasury":6.46},{"year":1974,"yield":5.37,"treasury":6.99},{"year":1975,"yield":4.15,"treasury":7.5},{"year":1976,"yield":3.87,"treasury":7.74},{"year":1977,"yield":4.98,"treasury":7.21},{"year":1978,"yield":5.28,"treasury":7.96},{"year":1979,"yield":5.24,"treasury":9.1},{"year":1980,"yield":4.61,"treasury":10.8},{"year":1981,"yield":5.36,"treasury":12.57},{"year":1982,"yield":4.93,"treasury":14.59},{"year":1983,"yield":4.31,"treasury":10.46},{"year":1984,"yield":4.58,"treasury":11.67},{"year":1985,"yield":3.81,"treasury":11.38},{"year":1986,"yield":3.33,"treasury":9.19},{"year":1987,"yield":3.66,"treasury":7.08},{"year":1988,"yield":3.53,"treasury":8.67},{"year":1989,"yield":3.17,"treasury":9.09},{"year":1990,"yield":3.68,"treasury":8.21},{"year":1991,"yield":3.14,"treasury":8.09},{"year":1992,"yield":2.84,"treasury":7.03},{"year":1993,"yield":2.7,"treasury":6.6},{"year":1994,"yield":2.89,"treasury":5.75},{"year":1995,"yield":2.24,"treasury":7.78},{"year":1996,"yield":2,"treasury":5.65},{"year":1997,"yield":1.61,"treasury":6.58},{"year":1998,"yield":1.36,"treasury":5.54},{"year":1999,"yield":1.17,"treasury":4.72},{"year":2000,"yield":1.22,"treasury":6.66},{"year":2001,"yield":1.37,"treasury":5.16},{"year":2002,"yield":1.79,"treasury":5.04},{"year":2003,"yield":1.61,"treasury":4.05},{"year":2004,"yield":1.62,"treasury":4.15},{"year":2005,"yield":1.76,"treasury":4.22},{"year":2006,"yield":1.76,"treasury":4.42},{"year":2007,"yield":1.87,"treasury":4.76},{"year":2008,"yield":3.23,"treasury":3.74},{"year":2009,"yield":2.02,"treasury":2.52},{"year":2010,"yield":1.83,"treasury":3.73},{"year":2011,"yield":2.13,"treasury":3.39},{"year":2012,"yield":2.2,"treasury":1.97},{"year":2013,"yield":1.94,"treasury":1.91},{"year":2014,"yield":1.92,"treasury":2.86},{"year":2015,"yield":2.11,"treasury":1.88},{"year":2016,"yield":2.03,"treasury":2.09},{"year":2017,"yield":1.84,"treasury":2.43},{"year":2018,"yield":2.09,"treasury":2.58},{"year":2019,"yield":1.83,"treasury":2.71},{"year":2020,"yield":1.58,"treasury":1.76},{"year":2021,"yield":1.29,"treasury":1.08},{"year":2022,"yield":1.71,"treasury":1.76},{"year":2023,"yield":1.5,"treasury":3.53},{"year":2024,"yield":1.24,"treasury":4.06},{"year":2025,"yield":1.15,"treasury":4.63},{"year":2026,"yield":1.16,"treasury":4.18}];

        // Approximate US Recessions
        const recessions = [
            { start: 1960, end: 1961 },
            { start: 1969, end: 1970 },
            { start: 1973, end: 1975 },
            { start: 1980, end: 1980.5 },
            { start: 1981, end: 1982 },
            { start: 1990, end: 1991 },
            { start: 2001, end: 2001 },
            { start: 2007, end: 2009 },
            { start: 2020, end: 2020 }
        ];

        document.addEventListener("DOMContentLoaded", () => {
            const canvas = document.getElementById('yieldChart');
            const ctx = canvas.getContext('2d');
            const wrapper = document.getElementById('chart-wrapper');
            const tooltip = document.getElementById('chart-tooltip');

            let width, height;
            const padding = { top: 20, right: 20, bottom: 40, left: 50 };

            // Extract values
            const years = chartData.map(d => d.year);
            const yields = chartData.map(d => d.yield);
            const treasuries = chartData.map(d => d.treasury).filter(v => v !== null);

            const minYear = Math.min(...years);
            const maxYear = Math.max(...years);
            const maxVal = Math.max(...yields, ...treasuries);

            function resizeCanvas() {
                // Get display size (css pixels)
                const displayWidth = wrapper.clientWidth;
                const displayHeight = wrapper.clientHeight;

                // Set actual size in memory (scaled to account for extra pixel density)
                const scale = window.devicePixelRatio || 1;
                canvas.width = displayWidth * scale;
                canvas.height = displayHeight * scale;

                // Normalize coordinate system to use css pixels
                ctx.scale(scale, scale);

                width = displayWidth;
                height = displayHeight;

                drawChart();
            }

            function drawChart() {
                ctx.clearRect(0, 0, width, height);

                const plotWidth = width - padding.left - padding.right;
                const plotHeight = height - padding.top - padding.bottom;

                // Helpers
                const getX = year => padding.left + ((year - minYear) / (maxYear - minYear)) * plotWidth;
                const getY = val => padding.top + plotHeight - ((val / Math.ceil(maxVal + 1)) * plotHeight);

                // Draw recessions
                ctx.fillStyle = 'rgba(255, 255, 255, 0.04)';
                recessions.forEach(r => {
                    const xStart = Math.max(padding.left, getX(r.start));
                    const xEnd = Math.min(width - padding.right, getX(r.end));
                    if (xStart < width - padding.right && xEnd > padding.left) {
                        ctx.fillRect(xStart, padding.top, xEnd - xStart, plotHeight);
                    }
                });

                // Draw Grid & Axes
                ctx.strokeStyle = 'rgba(255, 255, 255, 0.1)';
                ctx.lineWidth = 1;
                ctx.beginPath();

                // Y-axis grid
                const maxValCeil = Math.ceil(maxVal + 1);
                for (let i = 0; i <= maxValCeil; i += 2) {
                    const y = getY(i);
                    ctx.moveTo(padding.left, y);
                    ctx.lineTo(width - padding.right, y);

                    ctx.fillStyle = '#94a3b8';
                    ctx.font = '12px Inter, sans-serif';
                    ctx.textAlign = 'right';
                    ctx.textBaseline = 'middle';
                    ctx.fillText(i + '%', padding.left - 10, y);
                }

                // X-axis grid
                for (let y = Math.ceil(minYear / 10) * 10; y <= maxYear; y += 10) {
                    const x = getX(y);
                    ctx.moveTo(x, padding.top);
                    ctx.lineTo(x, height - padding.bottom);

                    ctx.fillStyle = '#94a3b8';
                    ctx.textAlign = 'center';
                    ctx.textBaseline = 'top';
                    ctx.fillText(y, x, height - padding.bottom + 10);
                }
                ctx.stroke();

                // Draw Area (S&P 500 Yield)
                ctx.beginPath();
                ctx.moveTo(getX(chartData[0].year), getY(0));
                chartData.forEach(d => {
                    ctx.lineTo(getX(d.year), getY(d.yield));
                });
                ctx.lineTo(getX(chartData[chartData.length - 1].year), getY(0));
                ctx.closePath();
                ctx.fillStyle = 'rgba(74, 143, 231, 0.2)';
                ctx.fill();

                // Draw Line (S&P 500 Yield)
                ctx.beginPath();
                chartData.forEach((d, i) => {
                    const x = getX(d.year);
                    const y = getY(d.yield);
                    if (i === 0) ctx.moveTo(x, y);
                    else ctx.lineTo(x, y);
                });
                ctx.strokeStyle = '#4a8fe7';
                ctx.lineWidth = 2;
                ctx.stroke();

                // Draw Line (Treasury Yield)
                ctx.beginPath();
                ctx.setLineDash([5, 5]);
                let firstT = true;
                chartData.forEach(d => {
                    if (d.treasury !== null) {
                        const x = getX(d.year);
                        const y = getY(d.treasury);
                        if (firstT) {
                            ctx.moveTo(x, y);
                            firstT = false;
                        } else {
                            ctx.lineTo(x, y);
                        }
                    }
                });
                ctx.strokeStyle = '#f59e0b';
                ctx.lineWidth = 2;
                ctx.stroke();
                ctx.setLineDash([]); // Reset
            }

            // Interactive Tooltip
            wrapper.addEventListener('mousemove', (e) => {
                const rect = canvas.getBoundingClientRect();
                const mouseX = e.clientX - rect.left;

                const plotWidth = width - padding.left - padding.right;
                if (mouseX < padding.left || mouseX > width - padding.right) {
                    tooltip.style.opacity = '0';
                    drawChart();
                    return;
                }

                const yearHover = minYear + ((mouseX - padding.left) / plotWidth) * (maxYear - minYear);
                const closestData = chartData.reduce((prev, curr) =>
                    Math.abs(curr.year - yearHover) < Math.abs(prev.year - yearHover) ? curr : prev
                );

                // Redraw to clear previous hover line
                drawChart();

                const getX = year => padding.left + ((year - minYear) / (maxYear - minYear)) * plotWidth;
                const getY = val => padding.top + plotHeight - ((val / Math.ceil(maxVal + 1)) * plotHeight);
                const plotHeight = height - padding.top - padding.bottom;

                const cx = getX(closestData.year);

                // Draw vertical indicator line
                ctx.beginPath();
                ctx.moveTo(cx, padding.top);
                ctx.lineTo(cx, height - padding.bottom);
                ctx.strokeStyle = 'rgba(255, 255, 255, 0.2)';
                ctx.lineWidth = 1;
                ctx.stroke();

                // Draw points
                ctx.beginPath();
                ctx.arc(cx, getY(closestData.yield), 4, 0, Math.PI * 2);
                ctx.fillStyle = '#4a8fe7';
                ctx.fill();

                if (closestData.treasury !== null) {
                    ctx.beginPath();
                    ctx.arc(cx, getY(closestData.treasury), 4, 0, Math.PI * 2);
                    ctx.fillStyle = '#f59e0b';
                    ctx.fill();
                }

                // Tooltip content
                let html = `<div class="tooltip-year">${closestData.year}</div>`;
                html += `
                    <div class="tooltip-row">
                        <div class="tooltip-color" style="background:#4a8fe7"></div>
                        <span>S&P 500: ${closestData.yield.toFixed(2)}%</span>
                    </div>`;
                if (closestData.treasury !== null) {
                    html += `
                    <div class="tooltip-row">
                        <div class="tooltip-color" style="background:#f59e0b"></div>
                        <span>Treasury: ${closestData.treasury.toFixed(2)}%</span>
                    </div>`;
                }

                tooltip.innerHTML = html;
                tooltip.style.opacity = '1';

                // Position tooltip
                let tX = cx + 15;
                if (tX + tooltip.offsetWidth > width) {
                    tX = cx - tooltip.offsetWidth - 15;
                }
                tooltip.style.left = tX + 'px';
                tooltip.style.top = (padding.top + 20) + 'px';
            });

            wrapper.addEventListener('mouseleave', () => {
                tooltip.style.opacity = '0';
                drawChart();
            });

            window.addEventListener('resize', resizeCanvas);
            resizeCanvas();
        });
  </script>

  
  
