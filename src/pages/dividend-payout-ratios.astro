        .faq-a { color: #8a9bb0; }

        .footer {
            text-align: center;
            padding: 40px 24px;
            font-size: 0.85rem;
            color: #3a4a5a;
            border-top: 1px solid #152040;
            background: #040810;
        }
        .footer a { color: #4a8fe7; text-decoration: none; }
        .disclaimer { max-width: 800px; margin: 16px auto 0; color: #2a3a4a; font-size: 0.75rem; }
  </style>

