        tr:hover td { background: rgba(74, 143, 231, 0.05); }
        .ticker { color: #4a8fe7; font-weight: bold; }
        .company-name { font-family: 'Inter', sans-serif; font-weight: 600; color: #fff; }
        .sector-badge {
