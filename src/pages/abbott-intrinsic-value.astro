---
import SiteLayout from "../layouts/SiteLayout.astro";

const schema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": "Abbott Laboratories (ABT) Intrinsic Value: A DCF Analysis",
  "description": "A transparent, step-by-step discounted cash flow valuation of Abbott Laboratories. Using actual FY2025 financials to arrive at a single fair value estimate for ABT shares.",
  "datePublished": "2026-03-18",
  "dateModified": "2026-03-18",
  "author": {
    "@type": "Organization",
    "name": "Westmount Research",
    "url": "https://westmountfundamentals.com"
  },
  "publisher": {
    "@type": "Organization",
    "name": "Westmount Research",
    "url": "https://westmountfundamentals.com"
  },
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": "https://westmountfundamentals.com/abbott-intrinsic-value"
  }
};

const meta = {
  title: "Abbott Laboratories (ABT) Intrinsic Value: A DCF Analysis",
  description: "We ran a full discounted cash flow on Abbott Laboratories using FY2025 actuals. One number. Every assumption disclosed. Here's what ABT is really worth.",
  category: "study",
  published: "2026-03-18",
};

/* ═══════════════════════════════════════════════════════════════
   DATA FETCHING FROM STOCKANALYSIS.COM
   ═══════════════════════════════════════════════════════════════ */

async function fetchStockAnalysisData(url) {
  try {
    const res = await fetch(url, {
      headers: {
        'User-Agent': 'Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36',
        'Accept': 'text/html,application/xhtml+xml,application/xml;q=0.9,*/*;q=0.8',
      }
    });
    if (!res.ok) return null;
    const html = await res.text();
    const match = html.match(/financialData:(\{.*?\})/);
    if (match) {
      // Evaluate the JavaScript object literal safely
      return eval('(' + match[1] + ')');
    }
  } catch (e) {
    console.error("Fetch error for url:", url, e);
  }
  return null;
}

let inc = null;
let bs = null;

let cf = null;

try {
  [inc, bs, cf] = await Promise.all([
    fetchStockAnalysisData('https://stockanalysis.com/stocks/abt/financials/'),
    fetchStockAnalysisData('https://stockanalysis.com/stocks/abt/financials/balance-sheet/'),
    fetchStockAnalysisData('https://stockanalysis.com/stocks/abt/financials/cash-flow-statement/')
  ]);
} catch (e) {
  console.error("Error fetching concurrent requests:", e);
}

// Ensure fallbacks using standard "null over fake data" if fetch fails
const ext = (arr) => {
    if (!arr) return [null, null, null, null, null];
    // inc data normally has TTM at index 0, 2025 at index 1, 2024 at index 2... 2021 at index 5.
    // Return array: [2021, 2022, 2023, 2024, 2025]
    return [arr[5], arr[4], arr[3], arr[2], arr[1]];
};

const revArray = inc ? ext(inc.revenue) : [null, null, null, null, null];
const fcfArray = cf ? ext(cf.fcf) : (inc ? ext(inc.fcf) : [null, null, null, null, null]);
const epsArray = inc ? ext(inc.epsDiluted) : [null, null, null, null, null];
const opMarginArray = inc ? ext(inc.operatingMargin) : [null, null, null, null, null];
const profitMarginArray = inc ? ext(inc.profitMargin) : [null, null, null, null, null];
const fcfMarginArray = inc ? ext(inc.fcfMargin) : [null, null, null, null, null];

const latestFCF = inc?.fcf?.[1] ?? null;
const latestShares = inc?.sharesDiluted?.[1] ?? null;

const cashTotal = bs?.totalcash?.[1] ?? null;
const debtTotal = bs?.debt?.[1] ?? null;

/* ═══════════════════════════════════════════════════════════════
   DCF MODEL — ALL INPUTS AND CALCULATIONS
   ═══════════════════════════════════════════════════════════════ */

// Fallbacks if data fails to fetch:
// based on previous analysis of the scraped data:
// FCF 2025: 7,395,000,000
// Shares 2025: 1,748,000,000
// Cash 2025: 8,939,000,000
// Debt 2025: 12,929,000,000

// We convert inputs to millions
const fcf2025 = latestFCF !== null ? Math.round(latestFCF / 1000000) : 7395;
const sharesOutstanding = latestShares !== null ? Math.round(latestShares / 1000000) : 1748;
const cashAndInvestments = cashTotal !== null ? Math.round(cashTotal / 1000000) : 8939;
const totalDebt = debtTotal !== null ? Math.round(debtTotal / 1000000) : 12929;
const netCash = cashAndInvestments - totalDebt;

// --- ASSUMPTIONS (fully disclosed below) ---
const growthRatePhase1 = 0.08;         // 8% FCF growth, Years 1-5
const growthRateTerminal = 0.030;      // 3.0% perpetuity growth (terminal)
const discountRate = 0.085;            // 8.5% WACC / required return

// --- PHASE 1: PROJECT FCF FOR YEARS 1-5 ---
const projectedFCF = [];
let fcf = fcf2025;
for (let yr = 1; yr <= 5; yr++) {
  fcf = fcf * (1 + growthRatePhase1);
  projectedFCF.push({ year: yr, fcf: Math.round(fcf), pvFactor: 1 / Math.pow(1 + discountRate, yr) });
}
projectedFCF.forEach(p => { p.pvFCF = Math.round(p.fcf * p.pvFactor); });

// --- PHASE 2: TERMINAL VALUE (Gordon Growth Model) ---
const fcfYear6 = projectedFCF[4].fcf * (1 + growthRateTerminal);
const terminalValue = Math.round(fcfYear6 / (discountRate - growthRateTerminal));
const pvTerminalValue = Math.round(terminalValue * projectedFCF[4].pvFactor);

// --- ENTERPRISE VALUE ---
const pvPhase1 = projectedFCF.reduce((sum, p) => sum + p.pvFCF, 0);
const enterpriseValue = pvPhase1 + pvTerminalValue;

// --- EQUITY VALUE ---
const equityValue = enterpriseValue + netCash;
const intrinsicValuePerShare = equityValue / sharesOutstanding;
const roundedIV = Math.round(intrinsicValuePerShare * 100) / 100;

// Market comparison (Using a static current price since we lack dynamic live price fetching robustly in sandboxes, but we know it's around 108.83 based on our script)
const currentPrice = 108.83;
const marginOfSafety = ((roundedIV - currentPrice) / currentPrice * 100).toFixed(1);
const verdictText = roundedIV > currentPrice ? "Undervalued" : "Overvalued";
const verdictColor = roundedIV > currentPrice ? "#10b981" : "#ef4444";

// --- HISTORICAL DATA for charts ---
// Use null over fake data if the fetch failed
const revenueHistory = [
  { year: 2021, value: revArray[0] !== null ? Math.round(revArray[0] / 1000000) : null },
  { year: 2022, value: revArray[1] !== null ? Math.round(revArray[1] / 1000000) : null },
  { year: 2023, value: revArray[2] !== null ? Math.round(revArray[2] / 1000000) : null },
  { year: 2024, value: revArray[3] !== null ? Math.round(revArray[3] / 1000000) : null },
  { year: 2025, value: revArray[4] !== null ? Math.round(revArray[4] / 1000000) : null },
];
const fcfHistory = [
  { year: 2021, value: fcfArray[0] !== null ? Math.round(fcfArray[0] / 1000000) : null },
  { year: 2022, value: fcfArray[1] !== null ? Math.round(fcfArray[1] / 1000000) : null },
  { year: 2023, value: fcfArray[2] !== null ? Math.round(fcfArray[2] / 1000000) : null },
  { year: 2024, value: fcfArray[3] !== null ? Math.round(fcfArray[3] / 1000000) : null },
  { year: 2025, value: fcfArray[4] !== null ? Math.round(fcfArray[4] / 1000000) : null },
];
const epsHistory = [
  { year: 2021, value: epsArray[0] },
  { year: 2022, value: epsArray[1] },
  { year: 2023, value: epsArray[2] },
  { year: 2024, value: epsArray[3] },
  { year: 2025, value: epsArray[4] },
];

const roundMargin = (val) => val !== null ? (val * 100).toFixed(1) : null;
const marginHistory = [
  { year: 2021, operating: roundMargin(opMarginArray[0]), profit: roundMargin(profitMarginArray[0]), fcfMargin: roundMargin(fcfMarginArray[0]) },
  { year: 2022, operating: roundMargin(opMarginArray[1]), profit: roundMargin(profitMarginArray[1]), fcfMargin: roundMargin(fcfMarginArray[1]) },
  { year: 2023, operating: roundMargin(opMarginArray[2]), profit: roundMargin(profitMarginArray[2]), fcfMargin: roundMargin(fcfMarginArray[2]) },
  { year: 2024, operating: roundMargin(opMarginArray[3]), profit: roundMargin(profitMarginArray[3]), fcfMargin: roundMargin(fcfMarginArray[3]) },
  { year: 2025, operating: roundMargin(opMarginArray[4]), profit: roundMargin(profitMarginArray[4]), fcfMargin: roundMargin(fcfMarginArray[4]) },
];

// Formatting helpers
const formatRevenue2025 = revArray[4] !== null ? "$" + (revArray[4] / 1000000000).toFixed(1) + "B" : "N/A";
const formatEPS2025 = epsArray[4] !== null ? "$" + epsArray[4].toFixed(2) : "N/A";
const formatOpMargin2025 = opMarginArray[4] !== null ? (opMarginArray[4] * 100).toFixed(1) + "%" : "N/A";

// Sensitivity analysis
const sensitivityRates = [0.065, 0.075, 0.085, 0.095, 0.105];
const sensitivityGrowth = [0.04, 0.06, 0.08, 0.10, 0.12];
const sensitivityTable = sensitivityRates.map(dr => {
  return {
    dr,
    values: sensitivityGrowth.map(gr => {
      let f = fcf2025;
      let pvSum = 0;
      for (let y = 1; y <= 5; y++) {
        f = f * (1 + gr);
        pvSum += f / Math.pow(1 + dr, y);
      }
      const f6 = f * (1 + growthRateTerminal);
      const tv = f6 / (dr - growthRateTerminal);
      const pvTV = tv / Math.pow(1 + dr, 5);
      return Math.round((pvSum + pvTV + netCash) / sharesOutstanding);
    })
  };
});
