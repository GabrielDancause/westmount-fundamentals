            </tr>

            <tr>
              <td class="highlight-ticker">AMZN</td>
              <td style="font-family: 'Inter', sans-serif;">Amazon.com Inc</td>
              <td style="text-align: right;">3.87%</td>
            </tr>

            <tr>
