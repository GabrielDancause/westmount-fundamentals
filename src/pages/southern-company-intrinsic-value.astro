      </thead>
      <tbody>
        <tr>
          <td>Base (Recent)</td>
          <td>${baseOCF.toLocaleString()}</td>
          <td>—</td>
          <td>—</td>
        </tr>
        {projectedOCF.map(p => (
          <tr>
            <td>Year {p.year}</td>
            <td>${p.ocf.toLocaleString()}</td>
            <td>{p.pvFactor.toFixed(4)}</td>
            <td>${p.pvOCF.toLocaleString()}</td>
          </tr>
        ))}
        <tr class="row-total">
          <td colspan="3">Sum of Phase 1 PV</td>
          <td class="highlight-cell">${pvPhase1.toLocaleString()}</td>
        </tr>
      </tbody>
    </table>
  </div>

  <!-- ═══ TERMINAL VALUE ═══ -->
