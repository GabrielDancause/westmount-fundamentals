---
import SiteLayout from "../layouts/SiteLayout.astro";
import * as cheerio from 'cheerio';

const schema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": "Southern Company (SO) Intrinsic Value: A DCF Analysis",
  "description": "A transparent, step-by-step discounted cash flow valuation of Southern Company (SO) using Operating Cash Flow.",
  "datePublished": "2026-03-18",
  "dateModified": "2026-03-18",
  "author": {
    "@type": "Organization",
    "name": "Westmount Research",
    "url": "https://westmountfundamentals.com"
  },
  "publisher": {
    "@type": "Organization",
    "name": "Westmount Research",
    "url": "https://westmountfundamentals.com"
  },
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": "https://westmountfundamentals.com/southern-company-intrinsic-value"
  }
};

export const meta = {
  title: "Southern Company (SO) Intrinsic Value: A DCF Analysis",
  description: "We ran a full discounted cash flow on Southern Company using actual financials. One number. Every assumption disclosed.",
  category: "study",
  published: "2026-03-18",
};

/* ═══════════════════════════════════════════════════════════════
   DATA FETCHING
   ═══════════════════════════════════════════════════════════════ */

function parseNumber(str) {
  if (!str || str === '-') return null;
  return parseFloat(str.replace(/,/g, ''));
}

async function fetchHtml(url) {
  const res = await fetch(url, {
    headers: {
      'User-Agent': 'Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/115.0.0.0 Safari/537.36',
      'Accept': 'text/html,application/xhtml+xml,application/xml;q=0.9,image/webp,*/*;q=0.8',
      'Accept-Language': 'en-US,en;q=0.5'
    }
  });
  if (!res.ok) throw new Error(`Failed to fetch ${url}`);
  return await res.text();
}

let revenue = [null, null, null, null, null];
let operatingIncome = [null, null, null, null, null];
let netIncome = [null, null, null, null, null];
let eps = [null, null, null, null, null];
let shares = [null, null, null, null, null];
let fcf = [null, null, null, null, null];
let ocf = [null, null, null, null, null];
let cash = [null, null, null, null, null];
let totalDebt = [null, null, null, null, null];
let currentPrice = null;

try {
  const [finHtml, cfHtml, bsHtml] = await Promise.all([
    fetchHtml('https://stockanalysis.com/stocks/so/financials/'),
    fetchHtml('https://stockanalysis.com/stocks/so/financials/cash-flow-statement/'),
    fetchHtml('https://stockanalysis.com/stocks/so/financials/balance-sheet/')
  ]);

  const $fin = cheerio.load(finHtml);
  const $cf = cheerio.load(cfHtml);
  const $bs = cheerio.load(bsHtml);

  function getRow($doc, rowName) {
    let result = [];
    $doc('table tbody tr').each((i, el) => {
      if ($doc(el).find('td').first().text().trim() === rowName) {
        result = $doc(el).find('td').map((j, td) => $doc(td).text().trim()).get().slice(1);
      }
    });
    return result.map(parseNumber);
  }

  const r = getRow($fin, 'Revenue');
  if (r.length >= 5) revenue = r.slice(0, 5);

  const oi = getRow($fin, 'Operating Income');
  if (oi.length >= 5) operatingIncome = oi.slice(0, 5);

  const ni = getRow($fin, 'Net Income');
  if (ni.length >= 5) netIncome = ni.slice(0, 5);

  const e = getRow($fin, 'EPS (Diluted)');
  if (e.length >= 5) eps = e.slice(0, 5);

  const s = getRow($fin, 'Shares Outstanding (Diluted)');
  if (s.length >= 5) shares = s.slice(0, 5);

  const o = getRow($cf, 'Operating Cash Flow');
  if (o.length >= 5) ocf = o.slice(0, 5);

  const f = getRow($cf, 'Free Cash Flow');
  if (f.length >= 5) fcf = f.slice(0, 5);

  const c = getRow($bs, 'Cash & Equivalents');
  if (c.length >= 5) cash = c.slice(0, 5);

  const d = getRow($bs, 'Total Debt');
  if (d.length >= 5) totalDebt = d.slice(0, 5);

  const priceMatch = finHtml.match(/<div class="[^"]*text-4xl[^"]*"[^>]*>([\d\.,]+)<\/div>/);
  if (priceMatch) {
    currentPrice = parseNumber(priceMatch[1]);
  }
} catch (err) {
  console.error(err);
}

/* ═══════════════════════════════════════════════════════════════
   DCF MODEL — ALL INPUTS AND CALCULATIONS
   ═══════════════════════════════════════════════════════════════ */

// 10Y Treasury provided
const tenYearTreasury = 0.0418;

// DCF Inputs (in millions)
const baseOCF = ocf[0] !== null ? ocf[0] : 0;
const currentShares = shares[0] !== null ? shares[0] : 0;
const currentCash = cash[0] !== null ? cash[0] : 0;
const currentDebt = totalDebt[0] !== null ? totalDebt[0] : 0;
const netCash = currentCash - currentDebt;

// Calculate historical CAGR of OCF (from Year 4 to Year 0)
let ocfCagr = 0;
if (ocf[4] !== null && ocf[0] !== null && ocf[4] > 0 && ocf[0] > 0) {
  ocfCagr = Math.pow(ocf[0] / ocf[4], 1/4) - 1;
}

// Derive assumptions strictly mathematically
// Growth Phase 1: Use OCF CAGR if positive, else use 10Y Treasury rate.
const growthRatePhase1 = ocfCagr > 0 ? ocfCagr : tenYearTreasury;
// Discount Rate (WACC): 10Y Treasury * 1.5 proxy for utility stable risk.
const discountRate = tenYearTreasury * 1.5;
// Terminal Growth: 10Y Treasury * 0.5 proxy.
const growthRateTerminal = tenYearTreasury * 0.5;

// Phase 1: Project OCF for Years 1-5
const projectedOCF = [];
let projected = baseOCF;
for (let yr = 1; yr <= 5; yr++) {
  projected = projected * (1 + growthRatePhase1);
  projectedOCF.push({
    year: yr,
    ocf: Math.round(projected),
    pvFactor: 1 / Math.pow(1 + discountRate, yr)
  });
}
projectedOCF.forEach(p => { p.pvOCF = Math.round(p.ocf * p.pvFactor); });

// Phase 2: Terminal Value
const ocfYear6 = projectedOCF[4].ocf * (1 + growthRateTerminal);
const terminalValue = Math.round(ocfYear6 / (discountRate - growthRateTerminal));
const pvTerminalValue = Math.round(terminalValue * projectedOCF[4].pvFactor);

// Enterprise Value
const pvPhase1 = projectedOCF.reduce((sum, p) => sum + p.pvOCF, 0);
const enterpriseValue = pvPhase1 + pvTerminalValue;

// Equity Value
const equityValue = enterpriseValue + netCash;
const intrinsicValuePerShare = currentShares > 0 ? equityValue / currentShares : 0;
const roundedIV = Math.round(intrinsicValuePerShare * 100) / 100;

// Market comparison
const currentMarketPrice = currentPrice !== null ? currentPrice : 0;
let marginOfSafety = 0;
let verdictText = "N/A";
let verdictColor = "#888888";

if (currentMarketPrice > 0 && roundedIV > 0) {
  marginOfSafety = (((roundedIV - currentMarketPrice) / currentMarketPrice) * 100).toFixed(1);
  verdictText = roundedIV > currentMarketPrice ? "Undervalued" : "Overvalued";
  verdictColor = roundedIV > currentMarketPrice ? "#10b981" : "#ef4444";
}

// Historical data for charts
const currentYear = new Date().getFullYear();
const yearsArr = [currentYear - 1, currentYear - 2, currentYear - 3, currentYear - 4, currentYear - 5];
const revenueHistory = yearsArr.map((y, i) => ({ year: y, value: revenue[i] })).reverse();
const ocfHistory = yearsArr.map((y, i) => ({ year: y, value: ocf[i] })).reverse();
const epsHistory = yearsArr.map((y, i) => ({ year: y, value: eps[i] })).reverse();

const marginHistory = yearsArr.map((y, i) => {
  const rev = revenue[i];
  const oi = operatingIncome[i];
  const ni = netIncome[i];
  const ocfVal = ocf[i];
  return {
    year: y,
    operating: rev !== null && oi !== null ? ((oi / rev) * 100).toFixed(2) : "N/A",
    profit: rev !== null && ni !== null ? ((ni / rev) * 100).toFixed(2) : "N/A",
    ocfMargin: rev !== null && ocfVal !== null ? ((ocfVal / rev) * 100).toFixed(2) : "N/A"
  };
}).reverse();

// Sensitivity analysis
const sensitivityRates = [
  discountRate - 0.02,
  discountRate - 0.01,
  discountRate,
  discountRate + 0.01,
  discountRate + 0.02
];
const sensitivityGrowth = [
  growthRatePhase1 - 0.04,
  growthRatePhase1 - 0.02,
  growthRatePhase1,
  growthRatePhase1 + 0.02,
  growthRatePhase1 + 0.04
];

const sensitivityTable = sensitivityRates.map(dr => {
  return {
    dr,
    values: sensitivityGrowth.map(gr => {
      if (currentShares === 0) return 0;
      let f = baseOCF;
      let pvSum = 0;
      for (let y = 1; y <= 5; y++) {
        f = f * (1 + gr);
        pvSum += f / Math.pow(1 + dr, y);
      }
      const f6 = f * (1 + growthRateTerminal);
      const tv = f6 / (dr - growthRateTerminal);
      const pvTV = tv / Math.pow(1 + dr, 5);
      return Math.round((pvSum + pvTV + netCash) / currentShares);
    })
  };
});
