  <!-- ═══ HISTORICAL CHARTS ═══ -->
  <h2>Financial Track Record</h2>

  <h3>Revenue ($M)</h3>
  <div class="bar-chart">
    {revenueHistory.map((r, index) => r.value !== null ? (
      <div class="bar-row">
        <div class="bar-label">Y{index + 1}</div>
        <div class="bar-track">
          <div class="bar-fill revenue" style={`width: ${(r.value / Math.max(...revenue.filter(v => v !== null))) * 100}%`}>
