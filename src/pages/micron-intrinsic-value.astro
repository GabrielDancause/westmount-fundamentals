          <td class="highlight-cell">${roundedIV.toFixed(2)}</td>
        </tr>
      </tbody>
    </table>
  </div>

  <!-- ═══ HISTORICAL CHARTS ═══ -->
  <h2>Financial Track Record</h2>
  <p>Micron is a classic boom-and-bust semiconductor stock. Looking at its 5-year track record illustrates the extreme volatility of its financials.</p>

  <h3>Revenue ($B)</h3>
  <div class="bar-chart">
    {revenueHistory.map(r => (
      <div class="bar-row">
        <div class="bar-label">{r.year}</div>
        <div class="bar-track">
          <div class="bar-fill revenue" style={`width: ${Math.max((r.value / 37378) * 100, 2)}%`}>
            ${(r.value / 1000).toFixed(1)}B
          </div>
        </div>
      </div>
    ))}
  </div>

