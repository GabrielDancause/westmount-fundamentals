  }
};

export const meta = {
  title: "Micron Technology (MU) Intrinsic Value: A DCF Analysis",
  description: "We ran a full discounted cash flow on Micron using FY2025 actuals. One number. Every assumption disclosed. Here's what Micron is really worth.",
  category: "study",
  published: "2026-03-18",
};

/* ═══════════════════════════════════════════════════════════════
   DCF MODEL — ALL INPUTS AND CALCULATIONS
   Every number is sourced from Micron's FY2025 Financials (via StockAnalysis.com).
   We use a two-stage DCF: high-growth phase (Years 1-5) then terminal value.
   ═══════════════════════════════════════════════════════════════ */

// --- INPUTS (all in millions USD unless noted) ---
const fcf2025 = 1668;                  // FY2025 Free Cash Flow ($M)
const sharesOutstanding = 1126;         // Basic shares outstanding ($M) — FY2025
const cashAndInvestments = 9642;        // Cash + short-term investments ($M)
const totalDebt = 15278;               // Total debt ($M)
const netCash = cashAndInvestments - totalDebt; // -$5,636M

// --- ASSUMPTIONS (fully disclosed below) ---
const growthRatePhase1 = 0.18;         // 18% FCF growth, Years 1-5 (driven by HBM / AI demand)
const growthRateTerminal = 0.03;       // 3% perpetuity growth (terminal)
const discountRate = 0.11;             // 11% WACC / required return (semi-cap cyclicality)

// --- PHASE 1: PROJECT FCF FOR YEARS 1-5 ---
const projectedFCF = [];
let fcf = fcf2025;
for (let yr = 1; yr <= 5; yr++) {
  fcf = fcf * (1 + growthRatePhase1);
  projectedFCF.push({ year: yr, fcf: Math.round(fcf), pvFactor: 1 / Math.pow(1 + discountRate, yr) });
}
projectedFCF.forEach(p => { p.pvFCF = Math.round(p.fcf * p.pvFactor); });

// --- PHASE 2: TERMINAL VALUE (Gordon Growth Model) ---
const fcfYear6 = projectedFCF[4].fcf * (1 + growthRateTerminal);
const terminalValue = Math.round(fcfYear6 / (discountRate - growthRateTerminal));
const pvTerminalValue = Math.round(terminalValue * projectedFCF[4].pvFactor);

// --- ENTERPRISE VALUE ---
const pvPhase1 = projectedFCF.reduce((sum, p) => sum + p.pvFCF, 0);
const enterpriseValue = pvPhase1 + pvTerminalValue;

// --- EQUITY VALUE ---
const equityValue = enterpriseValue + netCash;
const intrinsicValuePerShare = equityValue / sharesOutstanding;
const roundedIV = Math.round(intrinsicValuePerShare * 100) / 100;

// Market comparison
const currentPrice = 465.71;
const marginOfSafety = ((roundedIV - currentPrice) / currentPrice * 100).toFixed(1);
const verdictText = roundedIV > currentPrice ? "Undervalued" : "Overvalued";
const verdictColor = roundedIV > currentPrice ? "#10b981" : "#ef4444";

// --- HISTORICAL DATA for charts ---
const revenueHistory = [
  { year: 2021, value: 27705 },
  { year: 2022, value: 30758 },
  { year: 2023, value: 15540 },
  { year: 2024, value: 25111 },
  { year: 2025, value: 37378 },
];
const fcfHistory = [
  { year: 2021, value: 2435 },
  { year: 2022, value: 3114 },
  { year: 2023, value: -6117 },
  { year: 2024, value: 121 },
  { year: 2025, value: 1668 },
];
const epsHistory = [
  { year: 2021, value: 5.14 },
  { year: 2022, value: 7.75 },
  { year: 2023, value: -5.34 },
  { year: 2024, value: 0.70 },
  { year: 2025, value: 7.59 },
];
const marginHistory = [
  { year: 2021, operating: 26.20, profit: 21.15, fcfMargin: 8.79 },
  { year: 2022, operating: 31.57, profit: 28.24, fcfMargin: 10.12 },
  { year: 2023, operating: -34.78, profit: -37.54, fcfMargin: -39.36 },
  { year: 2024, operating: 5.20, profit: 3.10, fcfMargin: 0.48 },
  { year: 2025, operating: 26.24, profit: 22.84, fcfMargin: 4.46 },
];

// Sensitivity analysis
const sensitivityRates = [0.09, 0.10, 0.11, 0.12, 0.13];
const sensitivityGrowth = [0.14, 0.16, 0.18, 0.20, 0.22];
const sensitivityTable = sensitivityRates.map(dr => {
  return {
    dr,
    values: sensitivityGrowth.map(gr => {
      let f = fcf2025;
      let pvSum = 0;
      for (let y = 1; y <= 5; y++) {
        f = f * (1 + gr);
        pvSum += f / Math.pow(1 + dr, y);
      }
      const termFcf = f * (1 + growthRateTerminal);
      const tv = termFcf / (dr - growthRateTerminal);
      const pvTv = tv / Math.pow(1 + dr, 5);
      const ev = pvSum + pvTv;
      const eq = ev + netCash;
      return (Math.round((eq / sharesOutstanding) * 100) / 100).toFixed(2);
    })
  };
});
