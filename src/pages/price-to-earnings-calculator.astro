<script is:inline>
  document.addEventListener('DOMContentLoaded', function() {
    /* ============================================
       CALCULATOR 1: P/E RATIO
       ============================================ */
    var peMethod = document.getElementById('pe-method');
    var pePrice = document.getElementById('pe-price');
    var peEps = document.getElementById('pe-eps');
    var peMcap = document.getElementById('pe-mcap');
    var peIncome = document.getElementById('pe-income');
    var peResult = document.getElementById('pe-result');
    var peInterpret = document.getElementById('pe-interpret');
    var peEarningsYield = document.getElementById('pe-earnings-yield');
    var peCategory = document.getElementById('pe-category');

    function getPeClass(pe) {
      if (pe < 10) return { label: 'Deep Value', cls: 'status-deep-value', cat: 'Deep Value (<10x)' };
      if (pe < 15) return { label: 'Value', cls: 'status-value', cat: 'Value (10-15x)' };
      if (pe < 20) return { label: 'Fair Value', cls: 'status-fair', cat: 'Fair Value (15-20x)' };
      if (pe < 30) return { label: 'Growth', cls: 'status-growth', cat: 'Growth Premium (20-30x)' };
      return { label: 'Expensive', cls: 'status-expensive', cat: 'Expensive (>30x)' };
    }

    function calcPE() {
      var method = peMethod.value;
      var pe = 0;
      if (method === 'price-eps') {
        var price = parseFloat(pePrice.value) || 0;
        var eps = parseFloat(peEps.value) || 0;
        if (eps > 0) pe = price / eps;
      } else {
        var mcap = parseFloat(peMcap.value) || 0;
        var income = parseFloat(peIncome.value) || 0;
        if (income > 0) pe = mcap / income;
      }
      if (pe > 0) {
        var info = getPeClass(pe);
        peResult.textContent = pe.toFixed(2) + 'x';
        peInterpret.textContent = info.label;
        peInterpret.className = 'price-status ' + info.cls;
        peEarningsYield.textContent = (1 / pe * 100).toFixed(2) + '%';
        peCategory.textContent = info.cat;
      } else {
        peResult.textContent = 'N/A';
        peInterpret.textContent = 'Invalid';
        peInterpret.className = 'price-status status-neutral';
        peEarningsYield.textContent = '—';
        peCategory.textContent = '—';
      }
    }

    peMethod.addEventListener('change', function() {
      var isPriceEps = peMethod.value === 'price-eps';
      document.getElementById('pe-price-group').style.display = isPriceEps ? '' : 'none';
      document.getElementById('pe-eps-group').style.display = isPriceEps ? '' : 'none';
      document.getElementById('pe-mcap-group').style.display = isPriceEps ? 'none' : '';
      document.getElementById('pe-income-group').style.display = isPriceEps ? 'none' : '';
      calcPE();
    });

    [pePrice, peEps, peMcap, peIncome].forEach(function(el) { el.addEventListener('input', calcPE); });
    calcPE();

    /* ============================================
       CALCULATOR 2: FORWARD P/E
       ============================================ */
    var fpePrice = document.getElementById('fpe-price');
    var fpeEps = document.getElementById('fpe-eps');
    var fpeResult = document.getElementById('fpe-result');
    var fpeInterpret = document.getElementById('fpe-interpret');
    var fpeYield = document.getElementById('fpe-yield');
    var fpeGrowth = document.getElementById('fpe-growth');

    function calcFPE() {
      var price = parseFloat(fpePrice.value) || 0;
      var eps = parseFloat(fpeEps.value) || 0;
      if (eps > 0 && price > 0) {
        var fpe = price / eps;
        var info = getPeClass(fpe);
        fpeResult.textContent = fpe.toFixed(2) + 'x';
        fpeInterpret.textContent = info.label;
        fpeInterpret.className = 'price-status ' + info.cls;
        fpeYield.textContent = (1 / fpe * 100).toFixed(2) + '%';
        // Implied growth vs trailing
        var trailingEps = parseFloat(peEps.value) || 0;
        if (trailingEps > 0 && eps !== trailingEps) {
          var growth = ((eps - trailingEps) / trailingEps * 100);
          fpeGrowth.textContent = (growth >= 0 ? '+' : '') + growth.toFixed(1) + '%';
        } else {
          fpeGrowth.textContent = '—';
        }
      } else {
        fpeResult.textContent = 'N/A';
        fpeInterpret.textContent = 'Invalid';
        fpeInterpret.className = 'price-status status-neutral';
        fpeYield.textContent = '—';
        fpeGrowth.textContent = '—';
      }
    }

    [fpePrice, fpeEps].forEach(function(el) { el.addEventListener('input', calcFPE); });
    calcFPE();

    /* ============================================
       CALCULATOR 3: PEG RATIO
       ============================================ */
    var pegPe = document.getElementById('peg-pe');
    var pegGrowthInput = document.getElementById('peg-growth');
    var pegResult = document.getElementById('peg-result');
    var pegInterpret = document.getElementById('peg-interpret');
    var pegAssess = document.getElementById('peg-assess');
    var pegFair = document.getElementById('peg-fair');

    function calcPEG() {
      var pe = parseFloat(pegPe.value) || 0;
      var growth = parseFloat(pegGrowthInput.value) || 0;
      if (pe > 0 && growth > 0) {
        var peg = pe / growth;
        pegResult.textContent = peg.toFixed(2);
        pegFair.textContent = growth.toFixed(2) + 'x';
        if (peg < 0.5) {
          pegInterpret.textContent = 'Very Undervalued';
          pegInterpret.className = 'price-status status-deep-value';
          pegAssess.textContent = 'Strong bargain vs growth rate';
        } else if (peg < 1.0) {
          pegInterpret.textContent = 'Undervalued';
          pegInterpret.className = 'price-status status-value';
          pegAssess.textContent = 'Attractively priced vs growth';
        } else if (peg < 1.2) {
          pegInterpret.textContent = 'Fairly Valued';
          pegInterpret.className = 'price-status status-fair';
          pegAssess.textContent = 'Roughly in line with growth';
        } else if (peg < 2.0) {
          pegInterpret.textContent = 'Overvalued';
          pegInterpret.className = 'price-status status-growth';
          pegAssess.textContent = 'Premium to growth rate';
        } else {
          pegInterpret.textContent = 'Very Overvalued';
          pegInterpret.className = 'price-status status-expensive';
          pegAssess.textContent = 'P/E far exceeds growth rate';
        }
      } else {
        pegResult.textContent = 'N/A';
        pegInterpret.textContent = 'Invalid';
        pegInterpret.className = 'price-status status-neutral';
        pegAssess.textContent = '—';
        pegFair.textContent = '—';
      }
    }

    [pegPe, pegGrowthInput].forEach(function(el) { el.addEventListener('input', calcPEG); });
    calcPEG();

    /* ============================================
       CALCULATOR 4: EARNINGS YIELD
       ============================================ */
    var eyPe = document.getElementById('ey-pe');
    var eyBond = document.getElementById('ey-bond');
    var eyResult = document.getElementById('ey-result');
    var eyInterpret = document.getElementById('ey-interpret');
    var eyPremium = document.getElementById('ey-premium');
    var eyVerdict = document.getElementById('ey-verdict');

    function calcEY() {
      var pe = parseFloat(eyPe.value) || 0;
      var bond = parseFloat(eyBond.value) || 0;
      if (pe > 0) {
        var ey = 1 / pe * 100;
        var premium = ey - bond;
        eyResult.textContent = ey.toFixed(2) + '%';
        eyPremium.textContent = (premium >= 0 ? '+' : '') + premium.toFixed(2) + '%';
        if (premium > 3) {
          eyInterpret.textContent = 'Stocks Attractive';
          eyInterpret.className = 'price-status status-value';
          eyVerdict.textContent = 'Wide equity risk premium';
        } else if (premium > 1) {
          eyInterpret.textContent = 'Above Bond Yield';
          eyInterpret.className = 'price-status status-fair';
          eyVerdict.textContent = 'Moderate equity premium';
        } else if (premium > 0) {
          eyInterpret.textContent = 'Slim Premium';
          eyInterpret.className = 'price-status status-growth';
          eyVerdict.textContent = 'Stocks offer slim premium';
        } else {
          eyInterpret.textContent = 'Bonds More Attractive';
          eyInterpret.className = 'price-status status-expensive';
          eyVerdict.textContent = 'Negative equity risk premium';
        }
      } else {
        eyResult.textContent = 'N/A';
        eyInterpret.textContent = 'Invalid';
        eyInterpret.className = 'price-status status-neutral';
        eyPremium.textContent = '—';
        eyVerdict.textContent = '—';
      }
    }

    [eyPe, eyBond].forEach(function(el) { el.addEventListener('input', calcEY); });
    calcEY();

    /* ============================================
       CHART 1: S&P 500 P/E HISTORY
       ============================================ */
    var histCtx = document.getElementById('pe-history-chart');
    if (histCtx) {
      var years = [];
      var peData = [];
      var rawData = {
        1990:20,1991:26,1992:22,1993:21,1994:15,1995:18,1996:19,1997:24,1998:33,1999:44,
        2000:45,2001:37,2002:29,2003:22,2004:20,2005:18,2006:17,2007:22,2008:18,2009:10,
        2010:16,2011:14,2012:15,2013:17,2014:19,2015:21,2016:23,2017:24,2018:20,2019:23,
        2020:40,2021:35,2022:20,2023:23,2024:25,2025:24
      };
      for (var y in rawData) {
        if (rawData.hasOwnProperty(y)) {
          years.push(y);
          peData.push(rawData[y]);
        }
      }
      new Chart(histCtx, {
        type: 'line',
        data: {
          labels: years,
          datasets: [{
            label: 'S&P 500 Trailing P/E',
            data: peData,
            borderColor: '#60a5fa',
            backgroundColor: 'rgba(96,165,250,0.1)',
            fill: true,
            tension: 0.3,
            pointRadius: 2,
            pointHoverRadius: 6,
            borderWidth: 2
          }]
        },
        options: {
          responsive: true,
          maintainAspectRatio: true,
          plugins: {
            legend: { display: false },
            tooltip: {
              callbacks: {
                label: function(ctx) { return 'P/E: ' + ctx.parsed.y + 'x'; }
              }
            },
            annotation: undefined
          },
          scales: {
            x: {
              grid: { color: 'rgba(148,163,184,0.08)' },
              ticks: { color: '#94a3b8', maxTicksLimit: 12 }
            },
            y: {
              grid: { color: 'rgba(148,163,184,0.08)' },
              ticks: { color: '#94a3b8', callback: function(v) { return v + 'x'; } },
              beginAtZero: true,
              suggestedMax: 50
            }
          }
        }
      });
    }

    /* ============================================
       CHART 2: P/E BY SECTOR
       ============================================ */
    var sectorCtx = document.getElementById('pe-sector-chart');
    if (sectorCtx) {
      var sectorLabels = ['Information Technology', 'Consumer Discretionary', 'Healthcare', 'Communication Services', 'Industrials', 'Consumer Staples', 'Utilities', 'Materials', 'Financials', 'Real Estate', 'Energy'];
      var sectorPE = [35, 28, 22, 20, 19, 21, 18, 16, 15, 35, 12];
      var sectorColors = ['#60a5fa','#818cf8','#f472b6','#fb923c','#a78bfa','#34d399','#fbbf24','#94a3b8','#22d3ee','#e879f9','#f87171'];
      new Chart(sectorCtx, {
        type: 'bar',
        data: {
          labels: sectorLabels,
          datasets: [{
            label: 'Trailing P/E',
            data: sectorPE,
            backgroundColor: sectorColors,
            borderRadius: 4,
            barThickness: 22
          }]
        },
        options: {
          indexAxis: 'y',
          responsive: true,
          maintainAspectRatio: true,
          plugins: {
            legend: { display: false },
            tooltip: {
              callbacks: {
                label: function(ctx) { return ctx.parsed.x + 'x P/E'; }
              }
            }
          },
          scales: {
            x: {
              grid: { color: 'rgba(148,163,184,0.08)' },
              ticks: { color: '#94a3b8', callback: function(v) { return v + 'x'; } },
              beginAtZero: true,
              suggestedMax: 40
            },
            y: {
              grid: { display: false },
              ticks: { color: '#c8d0de', font: { size: 12 } }
            }
          }
        }
      });
    }
  });
</script>
