atio":25.97,"beta":1.249,"debtToEquity":48.404,"roe":15.285000000000002,"score":95.02,"sector":"Industrials"},{"symbol":"KO","name":"The Coca-Cola Company","price":77.61,"yield":2.6500002,"payoutRatio":67.11,"beta":0.332,"debtToEquity":139.793,"roe":43.323,"score":91.8007,"sector":"Consumer Defensive"},{"symbol":"ITW","name":"Illinois Tool Works Inc.","price":265.62,"yield":2.3699999,"payoutRatio":59.290003999999996,"beta":1.123,"debtToEquity":285.524,"roe":93.718004,"score":88.9876,"sector":"Industrials"},{"symbol":"HD","name":"The Home Depot, Inc.","price":338.93,"yield":2.6600001,"payoutRatio":64.64999999999999,"beta":1.044,"debtToEquity":510.029,"roe":145.541,"score":58.81710000000002,"sector":"Consumer Cyclical"},{"symbol":"SYY","name":"Sysco Corporation","price":84.91,"yield":2.55,"payoutRatio":57.410000000000004,"beta":0.595,"debtToEquity":640.248,"roe":82.345,"score":55.975199999999994,"sector":"Consumer Defensive"},{"symbol":"PEP","name":"PepsiCo, Inc.","price":158.86,"yield":3.55,"payoutRatio":93.71000000000001,"beta":0.375,"debtToEquity":258.081,"roe":42.848000000000006,"score":26.77189999999998,"sector":"Consumer Defensive"},{"symbol":"CVX","name":"Chevron Corporation","price":196.97,"yield":3.7100002,"payoutRatio":103.17,"beta":0.658,"debtToEquity":24.323,"roe":7.231,"score":13.659999999999997,"sector":"Energy"},{"symbol":"CL","name":"Colgate-Palmolive Company","price":87.95,"yield":2.32,"payoutRatio":78.330004,"beta":0.264,"debtToEquity":2343.562,"roe":497.47,"score":0,"sector":"Consumer Defensive"},{"symbol":"KMB","name":"Kimberly-Clark Corporation","price":97.82,"yield":5.12,"payoutRatio":103.69999999999999,"beta":0.234,"debtToEquity":464.785,"roe":126.603,"score":0,"sector":"Consumer Defensive"},{"symbol":"GPC","name":"Genuine Parts Company","price":107.01,"yield":3.8900003,"payoutRatio":876.6,"beta":0.734,"debtToEquity":156.063,"roe":1.5,"score":0,"sector":"Consumer Cyclical"}];

    let currentSort = { column: 'score', direction: -1 };

    function formatNumber(num, decimals = 2) {
        if (num === null || num === undefined || isNaN(num)) return '-';
        return Number(num).toLocaleString(undefined, { minimumFractionDigits: decimals, maximumFractionDigits: decimals });
    }

    function getScoreClass(score) {
        if (score >= 90) return 'score-high';
        if (score >= 70) return 'score-med';
        return 'score-low';
    }

    function renderTable(dataToRender) {
        const tbody = document.getElementById('tableBody');
        tbody.innerHTML = '';

        dataToRender.forEach(stock => {
            const tr = document.createElement('tr');
            tr.innerHTML = `
                <td>
                    <span class="ticker">${stock.symbol}</span>
                    <span class="name">${stock.name}</span>
                </td>
                <td>${stock.sector || 'N/A'}</td>
                <td>${formatNumber(stock.yield, 2)}%</td>
                <td>${formatNumber(stock.payoutRatio, 2)}%</td>
                <td>${formatNumber(stock.beta, 2)}</td>
                <td>${formatNumber(stock.debtToEquity, 2)}</td>
                <td class="${getScoreClass(stock.score)}">${formatNumber(stock.score, 1)}</td>
            `;
            tbody.appendChild(tr);
        });
    }

    function updateStats(data) {
        if (data.length === 0) return;

        const avgYield = data.reduce((sum, s) => sum + (s.yield || 0), 0) / data.length;
        document.getElementById('statAvgYield').textContent = formatNumber(avgYield, 2) + '%';

        const validPayouts = data.filter(s => s.payoutRatio !== null && !isNaN(s.payoutRatio));
        const avgPayout = validPayouts.reduce((sum, s) => sum + s.payoutRatio, 0) / validPayouts.length;
        document.getElementById('statAvgPayout').textContent = formatNumber(avgPayout, 1) + '%';

        const sectors = {};
        data.forEach(s => {
            const sec = s.sector || 'Unknown';
            sectors[sec] = (sectors[sec] || 0) + 1;
        });

        let topSector = 'N/A';
        let maxCount = 0;
        for (const [sec, count] of Object.entries(sectors)) {
            if (count > maxCount && sec !== 'N/A' && sec !== 'Unknown') {
                maxCount = count;
                topSector = sec;
            }
        }
        document.getElementById('statTopSector').textContent = topSector;

        return sectors;
    }

    function renderChart(sectors) {
        const ctx = document.getElementById('sectorChart').getContext('2d');

        // Remove N/A or Unknown for cleaner chart
        const labels = [];
        const data = [];
        for (const [sec, count] of Object.entries(sectors)) {
            if (sec !== 'N/A' && sec !== 'Unknown') {
                labels.push(sec);
                data.push(count);
            }
        }

        new Chart(ctx, {
            type: 'doughnut',
            data: {
                labels: labels,
                datasets: [{
                    data: data,
                    backgroundColor: [
                        '#4a8fe7', '#6ba3f0', '#2d5a9e', '#1e3c6a', '#a0b0c0', '#5a6a80'
                    ],
                    borderColor: '#0a1020',
                    borderWidth: 2
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: {
                        position: 'right',
                        labels: { color: '#c8d0de', font: { family: "'Inter', sans-serif" } }
                    },
                    title: {
                        display: true,
                        text: 'Sector Breakdown',
                        color: '#fff',
                        font: { size: 16, family: "'Inter', sans-serif" }
                    }
                }
            }
        });
    }

    function filterAndSort() {
        const term = document.getElementById('searchInput').value.toLowerCase();
        const sector = document.getElementById('sectorFilter').value;

        let filtered = stockData.filter(s => {
            const matchTerm = s.symbol.toLowerCase().includes(term) || s.name.toLowerCase().includes(term);
            const matchSector = sector === 'all' || s.sector === sector;
            return matchTerm && matchSector;
        });

        filtered.sort((a, b) => {
            let valA = a[currentSort.column];
            let valB = b[currentSort.column];

            // Handle nulls
            if (valA === null) valA = currentSort.direction === 1 ? Infinity : -Infinity;
            if (valB === null) valB = currentSort.direction === 1 ? Infinity : -Infinity;

            if (typeof valA === 'string') valA = valA.toLowerCase();
            if (typeof valB === 'string') valB = valB.toLowerCase();

            if (valA < valB) return -1 * currentSort.direction;
            if (valA > valB) return 1 * currentSort.direction;
            return 0;
        });

        renderTable(filtered);
    }

    // Init
    document.addEventListener('DOMContentLoaded', () => {
        // Populate sector filter
        const sectors = new Set(stockData.map(s => s.sector).filter(s => s && s !== 'N/A'));
        const filterSelect = document.getElementById('sectorFilter');
        sectors.forEach(sec => {
            const opt = document.createElement('option');
            opt.value = sec;
            opt.textContent = sec;
            filterSelect.appendChild(opt);
        });

        // Event listeners
        document.getElementById('searchInput').addEventListener('input', filterAndSort);
        document.getElementById('sectorFilter').addEventListener('change', filterAndSort);

        document.querySelectorAll('th[data-sort]').forEach(th => {
            th.addEventListener('click', () => {
                const col = th.dataset.sort;
                if (currentSort.column === col) {
                    currentSort.direction *= -1;
                } else {
                    currentSort.column = col;
                    currentSort.direction = 1;
                }
                filterAndSort();
            });
        });

        // Initial render
        const sectorCounts = updateStats(stockData);
        renderTable(stockData);
        if(sectorCounts && Object.keys(sectorCounts).length > 0) {
            renderChart(sectorCounts);
        }
    });
  </script>
</SiteLayout>
