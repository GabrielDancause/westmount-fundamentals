---
import SiteLayout from "../layouts/SiteLayout.astro";
import * as cheerio from 'cheerio';

const schema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": "Amphenol (APH) Intrinsic Value: A DCF Analysis",
  "description": "A transparent, step-by-step discounted cash flow valuation of Amphenol Corporation. Using actual FY2025 financials to arrive at a single fair value estimate for APH shares.",
  "datePublished": new Date().toISOString().split('T')[0],
  "dateModified": new Date().toISOString().split('T')[0],
  "author": {
    "@type": "Organization",
    "name": "Westmount Research",
    "url": "https://westmountfundamentals.com"
  },
  "publisher": {
    "@type": "Organization",
    "name": "Westmount Research",
    "url": "https://westmountfundamentals.com"
  },
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": "https://westmountfundamentals.com/amphenol-intrinsic-value"
  }
};

export const meta = {
  title: "Amphenol (APH) Intrinsic Value: A DCF Analysis",
  description: "We ran a full discounted cash flow on Amphenol using FY2025 actuals. One number. Every assumption disclosed. Here's what Amphenol is really worth.",
  category: "study",
  published: new Date().toISOString().split('T')[0],
};

// Data fetching helper using Cheerio to reliably parse the table rows
async function fetchFinancials(url) {
  try {
    const res = await fetch(url, {
      headers: { 'User-Agent': 'Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36' }
    });
    const html = await res.text();
    const $ = cheerio.load(html);
    const data = {};
    $('table tbody tr').each((i, el) => {
      const title = $(el).find('td').first().text().trim();
      const valText = $(el).find('td').eq(1).text().trim().replace(/,/g, '');
      const val = parseFloat(valText);
      if (title && !isNaN(val)) {
        data[title] = val;
      }
    });
    return data;
  } catch (err) {
    console.error(`Failed to fetch ${url}`, err);
    return null;
  }
}

async function fetchPrice() {
  try {
    const res = await fetch('https://stockanalysis.com/stocks/aph/', {
      headers: { 'User-Agent': 'Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36' }
    });
    const html = await res.text();
    const $ = cheerio.load(html);
    const priceText = $('div.text-4xl.font-bold').first().text().replace(/[^0-9.]/g, '');
    const price = parseFloat(priceText);
    return isNaN(price) ? null : price;
  } catch (err) {
    console.error("Failed to fetch price", err);
    return null;
  }
}

const isData = await fetchFinancials('https://stockanalysis.com/stocks/aph/financials/');
const bsData = await fetchFinancials('https://stockanalysis.com/stocks/aph/financials/balance-sheet/');
const cfData = await fetchFinancials('https://stockanalysis.com/stocks/aph/financials/cash-flow-statement/');

// Defaults or null
let fcf2025 = null;
let sharesOutstanding = null;
let cashAndInvestments = null;
let totalDebt = null;
let netCash = null;
let currentPrice = await fetchPrice();
let fyRevenue = null;
let fyEps = null;
let fyOpMargin = null;

let revenueHistory = [];
let fcfHistory = [];
let epsHistory = [];
let marginHistory = [];

if (cfData && cfData['Free Cash Flow'] !== undefined) {
  fcf2025 = cfData['Free Cash Flow'];
} else if (isData && isData['Free Cash Flow'] !== undefined) {
  fcf2025 = isData['Free Cash Flow'];
}

if (isData) {
  if (isData['Shares Outstanding (Diluted)']) {
      sharesOutstanding = isData['Shares Outstanding (Diluted)'];
  } else if (isData['Shares Outstanding (Basic)']) {
      sharesOutstanding = isData['Shares Outstanding (Basic)'];
  }
  if (isData['Revenue']) fyRevenue = isData['Revenue'];
  if (isData['EPS (Diluted)']) {
      fyEps = isData['EPS (Diluted)'];
  } else if (isData['EPS (Basic)']) {
      fyEps = isData['EPS (Basic)'];
  }
  if (isData['Operating Margin']) {
      // Cheerio parsed it as text potentially? Wait, the regex replace(/,/g, '') and parseFloat strips %.
      // Wait, Cheerio parsed: 25.41% as 25.41.
      fyOpMargin = isData['Operating Margin'] / 100;
  }
}

if (bsData) {
  if (bsData['Cash & Short-Term Investments'] !== undefined) {
    cashAndInvestments = bsData['Cash & Short-Term Investments'];
  } else if (bsData['Cash & Equivalents'] !== undefined) {
    cashAndInvestments = bsData['Cash & Equivalents'];
  }

  if (bsData['Total Debt'] !== undefined) {
    totalDebt = bsData['Total Debt'];
  }
  if (cashAndInvestments !== null && totalDebt !== null) {
    netCash = cashAndInvestments - totalDebt;
  }
}

// --- ASSUMPTIONS ---
const growthRatePhase1 = 0.10;         // 10% FCF growth, Years 1-5
const growthRateTerminal = 0.035;      // 3.5% perpetuity growth (terminal)
const discountRate = 0.10;             // 10% WACC / required return

// --- DCF MATH ---
let projectedFCF = [];
let terminalValue = null;
let pvTerminalValue = null;
let pvPhase1 = null;
let enterpriseValue = null;
let equityValue = null;
let roundedIV = null;
let marginOfSafety = null;
let verdictText = "Unknown";
let verdictColor = "#7a8a9e";
let fcfYear6 = null;

if (fcf2025 !== null && sharesOutstanding !== null && netCash !== null && currentPrice !== null) {
  let fcf = fcf2025;
  for (let yr = 1; yr <= 5; yr++) {
    fcf = fcf * (1 + growthRatePhase1);
    projectedFCF.push({ year: yr, fcf: Math.round(fcf), pvFactor: 1 / Math.pow(1 + discountRate, yr) });
  }
  projectedFCF.forEach(p => { p.pvFCF = Math.round(p.fcf * p.pvFactor); });

  fcfYear6 = projectedFCF[4].fcf * (1 + growthRateTerminal);
  terminalValue = Math.round(fcfYear6 / (discountRate - growthRateTerminal));
  pvTerminalValue = Math.round(terminalValue * projectedFCF[4].pvFactor);

  pvPhase1 = projectedFCF.reduce((sum, p) => sum + p.pvFCF, 0);
  enterpriseValue = pvPhase1 + pvTerminalValue;

  equityValue = enterpriseValue + netCash;
  const intrinsicValuePerShare = equityValue / sharesOutstanding;
  roundedIV = Math.round(intrinsicValuePerShare * 100) / 100;

  marginOfSafety = ((roundedIV - currentPrice) / currentPrice * 100).toFixed(1);
  verdictText = roundedIV > currentPrice ? "Undervalued" : "Overvalued";
  verdictColor = roundedIV > currentPrice ? "#10b981" : "#ef4444";
} else {
  // Try to calculate what we can even without currentPrice to show IV
  if (fcf2025 !== null && sharesOutstanding !== null && netCash !== null) {
    let fcf = fcf2025;
    for (let yr = 1; yr <= 5; yr++) {
      fcf = fcf * (1 + growthRatePhase1);
      projectedFCF.push({ year: yr, fcf: Math.round(fcf), pvFactor: 1 / Math.pow(1 + discountRate, yr) });
    }
    projectedFCF.forEach(p => { p.pvFCF = Math.round(p.fcf * p.pvFactor); });

    fcfYear6 = projectedFCF[4].fcf * (1 + growthRateTerminal);
    terminalValue = Math.round(fcfYear6 / (discountRate - growthRateTerminal));
    pvTerminalValue = Math.round(terminalValue * projectedFCF[4].pvFactor);

    pvPhase1 = projectedFCF.reduce((sum, p) => sum + p.pvFCF, 0);
    enterpriseValue = pvPhase1 + pvTerminalValue;

    equityValue = enterpriseValue + netCash;
    const intrinsicValuePerShare = equityValue / sharesOutstanding;
    roundedIV = Math.round(intrinsicValuePerShare * 100) / 100;
  }
}

// Sensitivity analysis
const sensitivityRates = [0.08, 0.09, 0.10, 0.11, 0.12];
const sensitivityGrowth = [0.06, 0.08, 0.10, 0.12, 0.14];
let sensitivityTable = [];
if (fcf2025 !== null && sharesOutstanding !== null && netCash !== null) {
  sensitivityTable = sensitivityRates.map(dr => {
    return {
      dr,
      values: sensitivityGrowth.map(gr => {
        let f = fcf2025;
        let pvSum = 0;
        for (let y = 1; y <= 5; y++) {
          f = f * (1 + gr);
          pvSum += f / Math.pow(1 + dr, y);
        }
        const f6 = f * (1 + growthRateTerminal);
        const tv = f6 / (dr - growthRateTerminal);
        const pvTV = tv / Math.pow(1 + dr, 5);
        return Math.round((pvSum + pvTV + netCash) / sharesOutstanding);
      })
    };
  });
}
