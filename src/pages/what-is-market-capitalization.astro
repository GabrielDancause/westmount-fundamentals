      }
    },
    {
      "@type": "Question",
      "name": "Does market capitalization include debt?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "No, market capitalization only calculates the total value of a company's outstanding equity (shares of stock). It does not factor in the company's debt. To see a valuation that includes both equity and debt, investors use a metric called Enterprise Value (EV)."
      }
    },
    {
      "@type": "Question",
      "name": "Why do stock prices change but market cap stays the same during a split?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "During a stock split, a company increases its total number of shares while proportionally decreasing the price of each share. Because market cap is calculated by multiplying the share price by the number of shares, these two changes cancel each other out mathematically, leaving the total market capitalization unchanged."
      }
    },
    {
      "@type": "Question",
      "name": "Can a company's market capitalization decrease?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes, a company's market capitalization decreases whenever its share price drops or if the company reduces its number of outstanding shares (though buybacks usually increase the share price, offsetting the reduction). Because share prices fluctuate constantly, market capitalization changes every minute the market is open."
      }
    },
    {
      "@type": "Question",
      "name": "What is the difference between market cap and enterprise value?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Market cap represents only the equity value of a company (share price multiplied by outstanding shares). Enterprise Value (EV) is a more comprehensive measure that takes the market cap, adds all total debt, and subtracts cash and cash equivalents. EV is often considered a more accurate representation of a company's total true value, especially in acquisitions."
      }
    }
  ]
};

const schemaString = JSON.stringify(schema);
