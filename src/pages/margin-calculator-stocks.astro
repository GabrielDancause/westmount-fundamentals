  <script is:inline>
    document.addEventListener('DOMContentLoaded', () => {
      const inputs = {
        price: document.getElementById('stockPrice'),
        shares: document.getElementById('numShares'),
        initial: document.getElementById('initialMargin'),
        maintenance: document.getElementById('maintenanceMargin'),
        interest: document.getElementById('marginInterest'),
        cash: document.getElementById('availableCash')
      };

      const errors = {
        price: document.getElementById('error-price'),
        shares: document.getElementById('error-shares'),
        initial: document.getElementById('error-initial'),
        maintenance: document.getElementById('error-maintenance'),
        interest: document.getElementById('error-interest'),
        cash: document.getElementById('error-cash')
      };

      const warningBox = document.getElementById('warningBox');

      const formatCurrency = (value) => {
        return new Intl.NumberFormat('en-US', {
          style: 'currency',
          currency: 'USD',
          minimumFractionDigits: 2,
          maximumFractionDigits: 2
        }).format(value);
      };

      const formatPercent = (value) => {
        return new Intl.NumberFormat('en-US', {
          style: 'percent',
          minimumFractionDigits: 2,
          maximumFractionDigits: 2
        }).format(value);
      };

      const validateInputs = () => {
        let isValid = true;

        const price = parseFloat(inputs.price.value);
        if (isNaN(price) || price <= 0) {
          errors.price.style.display = 'block';
          isValid = false;
        } else {
          errors.price.style.display = 'none';
        }

        const shares = parseInt(inputs.shares.value);
        if (isNaN(shares) || shares <= 0) {
          errors.shares.style.display = 'block';
          isValid = false;
        } else {
          errors.shares.style.display = 'none';
        }

        const initial = parseFloat(inputs.initial.value);
        if (isNaN(initial) || initial < 1 || initial > 100) {
          errors.initial.style.display = 'block';
          isValid = false;
        } else {
          errors.initial.style.display = 'none';
        }

        const maintenance = parseFloat(inputs.maintenance.value);
        if (isNaN(maintenance) || maintenance < 1 || maintenance > 100) {
          errors.maintenance.style.display = 'block';
          isValid = false;
        } else {
          errors.maintenance.style.display = 'none';
        }

        const interest = parseFloat(inputs.interest.value);
        if (isNaN(interest) || interest < 0) {
          errors.interest.style.display = 'block';
          isValid = false;
        } else {
          errors.interest.style.display = 'none';
        }

        const cash = parseFloat(inputs.cash.value);
        if (isNaN(cash) || cash < 0) {
          errors.cash.style.display = 'block';
          isValid = false;
        } else {
          errors.cash.style.display = 'none';
        }

        // Maintenance margin cannot be higher than initial margin logically
        if (isValid && maintenance > initial) {
            errors.maintenance.textContent = 'Maintenance margin cannot exceed initial margin.';
            errors.maintenance.style.display = 'block';
            isValid = false;
        }

        return isValid ? {
          price,
          shares,
          initial: initial / 100,
          maintenance: maintenance / 100,
          interest: interest / 100,
          cash
        } : null;
      };

      const calculate = () => {
        const vals = validateInputs();
        if (!vals) return;

        const totalValue = vals.price * vals.shares;
        const requiredCash = totalValue * vals.initial;

        // Determine how much cash is actually being used for the trade
        // Cap the cash used at the total value of the trade (no margin used)
        const cashInvested = Math.min(vals.cash, totalValue);

        // Check if user has enough cash for the initial requirement
        if (vals.cash < requiredCash) {
            warningBox.style.display = 'block';
        } else {
            warningBox.style.display = 'none';
        }

        const loanAmount = Math.max(0, totalValue - cashInvested);
        const annualInterest = loanAmount * vals.interest;
        const leverageRatio = totalValue > 0 && cashInvested > 0 ? totalValue / cashInvested : 1;

        // Margin Call Price Calculation
        // MC Price = Loan Amount / (Shares * (1 - Maintenance Margin Requirement))
        let marginCallPrice = 0;
        let dropNeeded = 0;

        if (loanAmount > 0) {
            marginCallPrice = loanAmount / (vals.shares * (1 - vals.maintenance));
            dropNeeded = (vals.price - marginCallPrice) / vals.price;
        }

        // Update DOM
        document.getElementById('totalValue').textContent = formatCurrency(totalValue);
        document.getElementById('yourEquity').textContent = formatCurrency(cashInvested);

        if (loanAmount === 0) {
            document.getElementById('marginCallPrice').textContent = 'N/A';
            document.getElementById('dropNeeded').textContent = 'No Margin Used';
        } else {
            document.getElementById('marginCallPrice').textContent = formatCurrency(marginCallPrice);
            document.getElementById('dropNeeded').textContent = formatPercent(dropNeeded);
        }

        document.getElementById('requiredCash').textContent = formatCurrency(requiredCash);
        document.getElementById('loanAmount').textContent = formatCurrency(loanAmount);
        document.getElementById('leverageRatio').textContent = leverageRatio.toFixed(2) + 'x';
        document.getElementById('annualInterest').textContent = formatCurrency(annualInterest);
      };

      // Add event listeners to all inputs
      Object.values(inputs).forEach(input => {
        input.addEventListener('input', calculate);
      });

      // Initial calculation
      calculate();
    });
  </script>

