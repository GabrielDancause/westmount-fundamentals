---
import SiteLayout from "../layouts/SiteLayout.astro";

const schema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": "NIKE (NKE) Intrinsic Value: A DCF Analysis",
  "description": "A transparent, step-by-step discounted cash flow valuation of NIKE, Inc. Using actual FY2024 financials to arrive at a single fair value estimate for NKE shares.",
  "datePublished": "2026-03-18",
  "dateModified": "2026-03-18",
  "author": {
    "@type": "Organization",
    "name": "Westmount Research",
    "url": "https://westmountfundamentals.com"
  },
  "publisher": {
    "@type": "Organization",
    "name": "Westmount Research",
    "url": "https://westmountfundamentals.com"
  },
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": "https://westmountfundamentals.com/nike-intrinsic-value"
  }
};

export const meta = {
  title: "NIKE (NKE) Intrinsic Value: A DCF Analysis",
  description: "We ran a full discounted cash flow on Nike using FY2024 actuals. One number. Every assumption disclosed. Here's what Nike is really worth.",
  category: "study",
  published: "2026-03-18",
};

import * as cheerio from 'cheerio';

async function parseNumber(val) {
  if (!val || val === '-') return null;
  val = val.replace(/,/g, '');
  return parseFloat(val);
}

// Fallback numbers (FY 2024 actuals from StockAnalysis) in case fetch fails
let fcfData = 6617;
let sharesData = 1530;
let cashAndEquivalents = 9860;
let shortTermInvestments = 1722;
let totalDebtData = 11952;
let revData = [46710, 51217, 51362]; // 2022, 2023, 2024
let fcfHistory = [4430, 4872, 6617];
let epsHistory = [3.75, 3.23, 3.73];

try {
  const urls = [
    'https://stockanalysis.com/stocks/nke/financials/',
    'https://stockanalysis.com/stocks/nke/financials/cash-flow-statement/',
    'https://stockanalysis.com/stocks/nke/financials/balance-sheet/'
  ];

  const fetches = await Promise.all(urls.map(url => fetch(url).then(res => res.text()).catch(() => null)));

  for (const html of fetches) {
    if (!html) continue;
    const $ = cheerio.load(html);
    const rows = $('table').first().find('tbody tr');

    for (let i = 0; i < rows.length; i++) {
      const el = rows[i];
      const label = $(el).find('td').first().text().trim();
      const tds = $(el).find('td');

      // Stockanalysis FY 2024 is at index 3, FY 2023 at index 4, FY 2022 at index 5.
      if (label === 'Revenue') {
        revData = [
          await parseNumber($(tds[5]).text()) || revData[0],
          await parseNumber($(tds[4]).text()) || revData[1],
          await parseNumber($(tds[3]).text()) || revData[2]
        ];
      }
      if (label === 'EPS (Diluted)') {
        epsHistory = [
          await parseNumber($(tds[5]).text()) || epsHistory[0],
          await parseNumber($(tds[4]).text()) || epsHistory[1],
          await parseNumber($(tds[3]).text()) || epsHistory[2]
        ];
      }
      if (label === 'Shares Outstanding (Diluted)') {
        sharesData = await parseNumber($(tds[3]).text()) || sharesData;
      }
      if (label === 'Free Cash Flow') {
        fcfHistory = [
          await parseNumber($(tds[5]).text()) || fcfHistory[0],
          await parseNumber($(tds[4]).text()) || fcfHistory[1],
          await parseNumber($(tds[3]).text()) || fcfHistory[2]
        ];
        fcfData = await parseNumber($(tds[3]).text()) || fcfData;
      }
      if (label === 'Cash & Equivalents') {
        cashAndEquivalents = await parseNumber($(tds[3]).text()) || cashAndEquivalents;
      }
      if (label === 'Short-Term Investments') {
        shortTermInvestments = await parseNumber($(tds[3]).text()) || shortTermInvestments;
      }
      if (label === 'Total Debt') {
        totalDebtData = await parseNumber($(tds[3]).text()) || totalDebtData;
      }
    }
  }
} catch (error) {
  console.error("Error fetching financial data:", error);
}

/* ═══════════════════════════════════════════════════════════════
   DCF MODEL — ALL INPUTS AND CALCULATIONS
   We use a two-stage DCF: turnaround phase (Years 1-5) then terminal value.
   ═══════════════════════════════════════════════════════════════ */

// --- INPUTS (all in millions USD unless noted) ---
const fcf2025 = fcfData;               // TTM/FY2024 Free Cash Flow ($M)
const sharesOutstanding = sharesData;  // Basic shares outstanding ($M)
const cashAndInvestments = cashAndEquivalents + shortTermInvestments; // Cash + short-term investments ($M)
const totalDebt = totalDebtData;       // Total debt ($M)
const netCash = cashAndInvestments - totalDebt;

// --- ASSUMPTIONS (fully disclosed below) ---
const growthRatePhase1 = 0.06;         // 6% FCF growth, Years 1-5
const growthRateTerminal = 0.025;      // 2.5% perpetuity growth (terminal)
const discountRate = 0.09;             // 9% WACC / required return

// --- PHASE 1: PROJECT FCF FOR YEARS 1-5 ---
const projectedFCF = [];
let fcf = fcf2025;
for (let yr = 1; yr <= 5; yr++) {
  fcf = fcf * (1 + growthRatePhase1);
  projectedFCF.push({ year: yr, fcf: Math.round(fcf), pvFactor: 1 / Math.pow(1 + discountRate, yr) });
}
projectedFCF.forEach(p => { p.pvFCF = Math.round(p.fcf * p.pvFactor); });

// --- PHASE 2: TERMINAL VALUE (Gordon Growth Model) ---
const fcfYear6 = projectedFCF[4].fcf * (1 + growthRateTerminal);
const terminalValue = Math.round(fcfYear6 / (discountRate - growthRateTerminal));
const pvTerminalValue = Math.round(terminalValue * projectedFCF[4].pvFactor);

// --- ENTERPRISE VALUE ---
const pvPhase1 = projectedFCF.reduce((sum, p) => sum + p.pvFCF, 0);
const enterpriseValue = pvPhase1 + pvTerminalValue;

// --- EQUITY VALUE ---
const equityValue = enterpriseValue + netCash;
const intrinsicValuePerShare = equityValue / sharesOutstanding;
const roundedIV = Math.round(intrinsicValuePerShare * 100) / 100;

// Market comparison
const currentPrice = 53.91;
const marginOfSafety = ((roundedIV - currentPrice) / currentPrice * 100).toFixed(1);
const verdictText = roundedIV > currentPrice ? "Undervalued" : "Overvalued";
const verdictColor = roundedIV > currentPrice ? "#10b981" : "#ef4444";

// --- HISTORICAL DATA for charts ---
const revenueHistory = [
  { year: 2022, value: revData[0] },
  { year: 2023, value: revData[1] },
  { year: 2024, value: revData[2] },
];
const fcfHistoryChart = [
  { year: 2022, value: fcfHistory[0] },
  { year: 2023, value: fcfHistory[1] },
  { year: 2024, value: fcfHistory[2] },
];
const epsHistoryChart = [
  { year: 2022, value: epsHistory[0] },
  { year: 2023, value: epsHistory[1] },
  { year: 2024, value: epsHistory[2] },
];
const marginHistory = [
  { year: 2022, operating: 14.29, profit: 12.94, fcfMargin: 9.48 },
  { year: 2023, operating: 11.55, profit: 9.90, fcfMargin: 9.51 },
  { year: 2024, operating: 12.29, profit: 11.10, fcfMargin: 12.88 },
];

// Sensitivity analysis
const sensitivityRates = [0.07, 0.08, 0.09, 0.10, 0.11];
const sensitivityGrowth = [0.02, 0.04, 0.06, 0.08, 0.10];
const sensitivityTable = sensitivityRates.map(dr => {
  return {
    dr,
    values: sensitivityGrowth.map(gr => {
      let f = fcfData;
      let pvSum = 0;
      for (let y = 1; y <= 5; y++) {
        f = f * (1 + gr);
        pvSum += f / Math.pow(1 + dr, y);
      }
      const f6 = f * (1 + growthRateTerminal);
      const tv = f6 / (dr - growthRateTerminal);
      const pvTV = tv / Math.pow(1 + dr, 5);
      return Math.round((pvSum + pvTV + netCash) / sharesOutstanding);
    })
  };
});
---

<SiteLayout
  site="westmount"
  title="NIKE (NKE) Intrinsic Value: A DCF Analysis"
  description="We ran a full discounted cash flow on Nike using FY2024 actuals. One number. Every assumption disclosed. Here's what Nike is really worth."
  canonical="https://westmountfundamentals.com/nike-intrinsic-value"
  schema={schema}
>

<div class="header">
  <div class="header-content">
    <div class="tag">Compiled by Gemini 3.1</div>
    <h1>NIKE (NKE)<br/>Intrinsic Value</h1>
    <p class="subtitle">A transparent, two-stage discounted cash flow valuation of NIKE, Inc. — using FY2024 actuals, disclosed assumptions, and one final number.</p>
    <p class="date">Updated March 18, 2026 · Data: FY2024 10-K</p>
  </div>
</div>

<div class="container">
  <!-- ═══ THE VERDICT ═══ -->
  <div class="verdict-card">
    <div class="verdict-label">Estimated Intrinsic Value Per Share</div>
    <div class="verdict-price">${roundedIV.toFixed(2)}</div>
    <div class="verdict-vs">vs. market price of ${currentPrice.toFixed(2)} ({marginOfSafety}%)</div>
    <div class="verdict-badge" style={`background: ${verdictColor}22; color: ${verdictColor}; border: 1px solid ${verdictColor}44;`}>
      {verdictText}
    </div>
  </div>

  <!-- ═══ KEY METRICS ═══ -->
  <div class="stats-row">
    <div class="stat-card">
      <div class="stat-value">${(revData[2] / 1000).toFixed(1)}B</div>
      <div class="stat-label">FY2024 Revenue</div>
    </div>
    <div class="stat-card">
      <div class="stat-value">${(fcfData / 1000).toFixed(1)}B</div>
      <div class="stat-label">Free Cash Flow</div>
    </div>
    <div class="stat-card">
      <div class="stat-value">${epsHistory[2].toFixed(2)}</div>
      <div class="stat-label">EPS (Diluted)</div>
    </div>
    <div class="stat-card">
      <div class="stat-value">{marginHistory[2].operating.toFixed(1)}%</div>
      <div class="stat-label">Operating Margin</div>
    </div>
    <div class="stat-card">
      <div class="stat-value">${(netCash / 1000).toFixed(1)}B</div>
      <div class="stat-label">Net Cash</div>
    </div>
  </div>

  <!-- ═══ METHODOLOGY ═══ -->
  <h2>Methodology: Two-Stage DCF</h2>
  <p>We use a <strong>two-stage discounted cash flow (DCF)</strong> model — the gold standard of intrinsic valuation. No multiples, no comparables, no vibes. Just future cash flows discounted to today.</p>

  <div class="method-step">
    <div class="step-num">1</div>
    <div class="step-content">
      <h4>Start with actual Free Cash Flow</h4>
      <p>Nike generated <strong>${fcfData.toLocaleString()} million</strong> in free cash flow in FY2024. This is operating cash flow minus capital expenditures. This is real cash the business produces after paying for everything.</p>
    </div>
  </div>

  <div class="method-step">
    <div class="step-num">2</div>
    <div class="step-content">
      <h4>Project FCF growth for 5 years (Phase 1)</h4>
      <p>We project FCF to grow at <strong>6% per year</strong> for 5 years. This reflects a turnaround phase due to strong competition and strategic missteps in direct-to-consumer distribution.</p>
    </div>
  </div>

  <div class="method-step">
    <div class="step-num">3</div>
    <div class="step-content">
      <h4>Calculate terminal value (Phase 2)</h4>
      <p>After Year 5, we assume FCF grows at <strong>2.5% forever</strong> — slightly below long-term GDP growth. We use the <strong>Gordon Growth Model</strong>: Terminal Value = FCF₆ ÷ (discount rate − terminal growth rate). This captures all value from Year 6 to infinity.</p>
    </div>
  </div>

  <div class="method-step">
    <div class="step-num">4</div>
    <div class="step-content">
      <h4>Discount everything to present value</h4>
      <p>All future cash flows are discounted at <strong>9%</strong> — our required rate of return based on the 10Y Treasury (4.18%) plus a reasonable equity risk premium.</p>
    </div>
  </div>

  <div class="method-step">
    <div class="step-num">5</div>
    <div class="step-content">
      <h4>Add net cash, divide by shares</h4>
      <p>Enterprise Value + Net Cash (${(netCash / 1000).toFixed(2)}B) = Equity Value. Divide by shares outstanding ({(sharesOutstanding / 1000).toFixed(2)}B) for the per-share intrinsic value. Note that Nike has more debt than cash, which reduces equity value.</p>
    </div>
  </div>

  <!-- ═══ THE THREE ASSUMPTIONS ═══ -->
  <h2>The Three Assumptions That Drive Everything</h2>
  <p>A DCF is only as good as its inputs. We're making exactly <strong>three</strong> judgment calls — everything else is math. Here's what we chose and why.</p>

  <div class="assumption-grid">
    <div class="assumption-card">
      <div class="label">FCF Growth Rate (Years 1-5)</div>
      <div class="value">6%</div>
      <div class="rationale">
        Nike is in turnaround mode. While short-term challenges remain (competition from On, Hoka), 6% FCF growth models a gradual recovery in margins and brand heat over the next 5 years.
      </div>
    </div>
    <div class="assumption-card">
      <div class="label">Discount Rate (WACC)</div>
      <div class="value">9%</div>
      <div class="rationale">
        10Y Treasury: 4.18%. Equity risk premium: ~4.5%. With an average beta around 1.1-1.3, we use 9% as a required rate of return for a consumer discretionary giant with strong brand moat but cyclical exposure.
      </div>
    </div>
    <div class="assumption-card">
      <div class="label">Terminal Growth Rate</div>
      <div class="value">2.5%</div>
      <div class="rationale">
        Long-term nominal GDP growth is ~3%. 2.5% reflects a mature consumer apparel business that maintains its moat but slowly cedes high-growth segments to newer competitors.
      </div>
    </div>
  </div>

  <!-- ═══ FCF PROJECTIONS TABLE ═══ -->
  <h2>Projected Free Cash Flows</h2>
  <div class="table-wrap">
    <table>
      <thead>
        <tr>
          <th style="text-align:left">Year</th>
          <th>FCF ($M)</th>
          <th>PV Factor</th>
          <th>Present Value ($M)</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td>Base (FY2024)</td>
          <td>${fcfData.toLocaleString()}</td>
          <td>—</td>
          <td>—</td>
        </tr>
        {projectedFCF.map(p => (
          <tr>
            <td>Year {p.year} ({2024 + p.year})</td>
            <td>${p.fcf.toLocaleString()}</td>
            <td>{p.pvFactor.toFixed(4)}</td>
            <td>${p.pvFCF.toLocaleString()}</td>
          </tr>
        ))}
        <tr class="row-total">
          <td colspan="3">Sum of Phase 1 PV</td>
          <td class="highlight-cell">${pvPhase1.toLocaleString()}</td>
        </tr>
      </tbody>
    </table>
  </div>

  <!-- ═══ TERMINAL VALUE ═══ -->
  <h3>Terminal Value</h3>
  <div class="table-wrap">
    <table>
      <thead>
        <tr>
          <th style="text-align:left">Component</th>
          <th>Value ($M)</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td>Year 6 FCF (Year 5 × 1.025)</td>
          <td>${Math.round(fcfYear6).toLocaleString()}</td>
        </tr>
        <tr>
          <td>Terminal Value (FCF₆ ÷ (9% − 2.5%))</td>
          <td>${terminalValue.toLocaleString()}</td>
        </tr>
        <tr class="row-total">
          <td>PV of Terminal Value</td>
          <td class="highlight-cell">${pvTerminalValue.toLocaleString()}</td>
        </tr>
      </tbody>
    </table>
  </div>

  <!-- ═══ FINAL CALCULATION ═══ -->
  <h3>Final Valuation</h3>
  <div class="table-wrap">
    <table>
      <thead>
        <tr>
          <th style="text-align:left">Component</th>
          <th>Value ($M)</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td>PV of Phase 1 Cash Flows</td>
          <td>${pvPhase1.toLocaleString()}</td>
        </tr>
        <tr>
          <td>PV of Terminal Value</td>
          <td>${pvTerminalValue.toLocaleString()}</td>
        </tr>
        <tr>
          <td>= Enterprise Value</td>
          <td>${enterpriseValue.toLocaleString()}</td>
        </tr>
        <tr>
          <td>+ Net Cash (Cash − Debt)</td>
          <td>${netCash.toLocaleString()}</td>
        </tr>
        <tr>
          <td>= Equity Value</td>
          <td>${equityValue.toLocaleString()}</td>
        </tr>
        <tr>
          <td>÷ Shares Outstanding</td>
          <td>{sharesOutstanding.toLocaleString()}</td>
        </tr>
        <tr class="row-total">
          <td>Intrinsic Value Per Share</td>
          <td class="highlight-cell">${roundedIV.toFixed(2)}</td>
        </tr>
      </tbody>
    </table>
  </div>

  <!-- ═══ HISTORICAL CHARTS ═══ -->
  <h2>Financial Track Record</h2>
  <p>Nike is currently navigating a cyclical downturn. Here's the 4-year performance.</p>

  <h3>Revenue ($B)</h3>
  <div class="bar-chart">
    {revenueHistory.map(r => (
      <div class="bar-row">
        <div class="bar-label">{r.year}</div>
        <div class="bar-track">
          <div class="bar-fill revenue" style={`width: ${(r.value / 51362) * 100}%`}>
            ${r.value ? (r.value / 1000).toFixed(1) : '0'}B
          </div>
        </div>
      </div>
    ))}
  </div>

  <h3>Free Cash Flow ($B)</h3>
  <div class="bar-chart">
    {fcfHistoryChart.map(r => (
      <div class="bar-row">
        <div class="bar-label">{r.year}</div>
        <div class="bar-track">
          <div class="bar-fill fcf" style={`width: ${(r.value / 6617) * 100}%`}>
            ${r.value ? (r.value / 1000).toFixed(1) : '0'}B
          </div>
        </div>
      </div>
    ))}
  </div>

  <h3>Earnings Per Share (Diluted)</h3>
  <div class="bar-chart">
    {epsHistoryChart.map(r => (
      <div class="bar-row">
        <div class="bar-label">{r.year}</div>
        <div class="bar-track">
          <div class="bar-fill eps" style={`width: ${(r.value / 3.83) * 100}%`}>
            ${r.value ? r.value.toFixed(2) : '0'}
          </div>
        </div>
      </div>
    ))}
  </div>

  <!-- ═══ MARGIN TRENDS ═══ -->
  <h3>Margin Trends</h3>
  <div class="table-wrap">
    <table>
      <thead>
        <tr>
          <th style="text-align:left">Year</th>
          <th>Operating Margin</th>
          <th>Profit Margin</th>
          <th>FCF Margin</th>
        </tr>
      </thead>
      <tbody>
        {marginHistory.map(m => (
          <tr>
            <td>{m.year}</td>
            <td>{m.operating.toFixed(1)}%</td>
            <td>{m.profit.toFixed(1)}%</td>
            <td>{m.fcfMargin.toFixed(1)}%</td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>

  <!-- ═══ SENSITIVITY ANALYSIS ═══ -->
  <h2>Sensitivity Analysis</h2>
  <p>Our base case uses 6% growth and a 9% discount rate. Here's what the intrinsic value looks like under different assumptions.</p>

  <div class="table-wrap">
    <table class="sensitivity-table">
      <thead>
        <tr>
          <th style="text-align:left">Discount Rate ↓ / Growth →</th>
          {sensitivityGrowth.map(g => (
            <th class={g === growthRatePhase1 ? 'current' : ''}>{(g * 100)}%</th>
          ))}
        </tr>
      </thead>
      <tbody>
        {sensitivityTable.map(row => (
          <tr>
            <td>{(row.dr * 100)}%</td>
            {row.values.map((v, i) => (
              <td class={row.dr === discountRate && sensitivityGrowth[i] === growthRatePhase1 ? 'current' : ''}>
                ${v}
              </td>
            ))}
          </tr>
        ))}
      </tbody>
    </table>
  </div>

  <!-- ═══ WHAT THE MODEL DOESN'T CAPTURE ═══ -->
  <h2>What This Model Doesn't Capture</h2>

  <h3>Upside risks</h3>
  <ul>
    <li><strong>Wholesale pivot success:</strong> If Nike's return to strong wholesale partnerships rapidly recovers lost market share, revenue and margins could expand faster than 6%.</li>
    <li><strong>Olympics/Innovation cycle:</strong> A successful new product innovation cycle could reignite brand momentum globally.</li>
  </ul>

  <h3>Downside risks</h3>
  <ul>
    <li><strong>Permanent loss of share:</strong> Challengers like HOKA, On, and New Balance might have permanently captured structural market share in running and lifestyle.</li>
    <li><strong>China weakness:</strong> Sustained macro weakness or domestic preference shifts in Greater China could permanently impair a major historical growth engine.</li>
  </ul>

  <!-- ═══ FAQ ═══ -->
  <h2>Frequently Asked Questions</h2>
  <div class="faq">
    <details>
      <summary>Why use DCF instead of a P/E multiple?</summary>
      <div class="faq-answer">Multiples tell you what the market <em>is</em> paying — not what a company is <em>worth</em>. A DCF connects cash flow generation directly to value, filtering out market sentiment.</div>
    </details>
    <details>
      <summary>Why 6% FCF growth when FCF dropped significantly recently?</summary>
      <div class="faq-answer">The 6% assumption represents a mid-cycle turnaround. We expect Nike to stabilize its revenue base and gradually recover margins, bringing FCF back up over a 5-year horizon.</div>
    </details>
    <details>
      <summary>Why is Net Cash negative?</summary>
      <div class="faq-answer">Nike currently carries more Total Debt ($11.0B) than Cash and Short-Term Investments ($9.2B). This means the enterprise value must be reduced to find the equity value available to shareholders.</div>
    </details>
  </div>

  <!-- ═══ DISCLAIMER ═══ -->
  <div class="disclaimer">
    <h4>⚠️ Important Disclaimer</h4>
    <p>This analysis is for educational and informational purposes only. It is not investment advice, a recommendation to buy or sell securities, or a solicitation of any kind. The intrinsic value estimate is based on assumptions that may prove incorrect. Past performance does not guarantee future results. All investments carry risk, including the loss of principal. Always conduct your own due diligence and consult a licensed financial advisor before making investment decisions.</p>
  </div>
</div>
</SiteLayout>

<style>
*, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
body { font-family: 'Inter', -apple-system, sans-serif; background: #060a12; color: #c8d0de; line-height: 1.7; }
a { color: #4a8fe7; text-decoration: none; }
a:hover { text-decoration: underline; }
.container { max-width: 900px; margin: 0 auto; padding: 0 24px; }

/* Header */
.header { text-align: center; padding: 80px 24px 60px; background: linear-gradient(180deg, #0a1628 0%, #060a12 100%); position: relative; border-bottom: 1px solid #152040; }
.header::before { content: ''; position: absolute; inset: 0; background: radial-gradient(circle at 50% 40%, rgba(74,143,231,0.06) 0%, transparent 60%); }
.header-content { position: relative; z-index: 1; }
.tag { display: inline-block; background: rgba(74,143,231,0.12); color: #4a8fe7; font-size: 0.75rem; font-weight: 800; padding: 6px 16px; border-radius: 20px; letter-spacing: 1.5px; text-transform: uppercase; margin-bottom: 16px; }
h1 { font-size: 2.8rem; font-weight: 900; color: #fff; letter-spacing: -1.2px; margin-bottom: 16px; line-height: 1.1; }
@media (max-width: 640px) { h1 { font-size: 2rem; } }
.subtitle { color: #7a8a9e; font-size: 1.1rem; max-width: 700px; margin: 0 auto 16px; }
