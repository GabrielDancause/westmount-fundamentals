const schema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": "Progressive (PGR) Intrinsic Value: A DCF Analysis",
  "description": "An intrinsic value estimate for The Progressive Corporation (PGR) using a two-stage discounted cash flow model based on FY2025 financials.",
  "datePublished": "2026-03-18",
  "dateModified": "2026-03-18",
  "author": {
    "@type": "Organization",
    "name": "Gemini 2.5 Pro",
    "url": "https://westmountfundamentals.com"
  },
  "publisher": {
    "@type": "Organization",
    "name": "Westmount Research",
    "url": "https://westmountfundamentals.com"
  },
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": "https://westmountfundamentals.com/progressive-intrinsic-value"
  }
};

export const meta = {
  title: "Progressive (PGR) Intrinsic Value: A DCF Analysis",
  description: "We ran a full discounted cash flow on Progressive using FY2025 actuals. Compiled by Gemini 2.5 Pro.",
  category: "study",
  published: "2026-03-18",
};

/* ═══════════════════════════════════════════════════════════════
   DCF MODEL — ALL INPUTS AND CALCULATIONS
   Every number is sourced from Progressive's FY2025 actuals.
   We use a two-stage DCF: high-growth phase (Years 1-5) then terminal value.
   ═══════════════════════════════════════════════════════════════ */

// --- INPUTS (all in millions USD unless noted) ---
const fcf2025 = 17_200;                // FY2025 Free Cash Flow ($M)
const sharesOutstanding = 588;          // Diluted shares outstanding ($M) — FY2025
const cashAndInvestments = 97_373 + 138; // Total Investments + Cash & Equivalents ($M)
const totalDebt = 6_897;                // Total debt ($M)
const netCash = cashAndInvestments - totalDebt; // $90,614M

// --- ASSUMPTIONS (fully disclosed below) ---
// Progressive has grown FCF at a 15.95% rate YoY in FY25, and 42% in FY24.
// We model a conservative 8% growth as they scale.
const growthRatePhase1 = 0.08;         // 8% FCF growth, Years 1-5
const growthRateTerminal = 0.03;       // 3% perpetuity growth (terminal) - conservative for insurance
const discountRate = 0.09;             // 9% WACC / required return (reflects lower beta but equity risk premium)

// --- PHASE 1: PROJECT FCF FOR YEARS 1-5 ---
const projectedFCF = [];
let fcf = fcf2025;
for (let yr = 1; yr <= 5; yr++) {
  fcf = fcf * (1 + growthRatePhase1);
  projectedFCF.push({ year: yr, fcf: Math.round(fcf), pvFactor: 1 / Math.pow(1 + discountRate, yr) });
}
projectedFCF.forEach(p => { p.pvFCF = Math.round(p.fcf * p.pvFactor); });

// --- PHASE 2: TERMINAL VALUE (Gordon Growth Model) ---
const fcfYear6 = projectedFCF[4].fcf * (1 + growthRateTerminal);
const terminalValue = Math.round(fcfYear6 / (discountRate - growthRateTerminal));
const pvTerminalValue = Math.round(terminalValue * projectedFCF[4].pvFactor);

// --- ENTERPRISE VALUE ---
const pvPhase1 = projectedFCF.reduce((sum, p) => sum + p.pvFCF, 0);
const enterpriseValue = pvPhase1 + pvTerminalValue;

// --- EQUITY VALUE ---
const equityValue = enterpriseValue + netCash;
const intrinsicValuePerShare = equityValue / sharesOutstanding;
const roundedIV = Math.round(intrinsicValuePerShare * 100) / 100;

// Market comparison
const currentPrice = 202.42;
const marginOfSafety = ((roundedIV - currentPrice) / currentPrice * 100).toFixed(1);
const verdictText = roundedIV > currentPrice ? "Undervalued" : "Overvalued";
const verdictColor = roundedIV > currentPrice ? "#10b981" : "#ef4444";

// --- HISTORICAL DATA for charts ---
const revenueHistory = [
  { year: 2021, value: 47_702 },
  { year: 2022, value: 49_611 },
  { year: 2023, value: 62_109 },
  { year: 2024, value: 75_372 },
  { year: 2025, value: 87_671 },
];
const fcfHistory = [
  { year: 2021, value: 7_518 },
  { year: 2022, value: 6_557 },
  { year: 2023, value: 10_391 },
  { year: 2024, value: 14_834 },
  { year: 2025, value: 17_200 },
];
const epsHistory = [
  { year: 2021, value: 5.69 },
  { year: 2022, value: 1.18 },
  { year: 2023, value: 6.58 },
  { year: 2024, value: 14.40 },
  { year: 2025, value: 19.23 },
];
const marginHistory = [
  { year: 2021, operating: 9.28, profit: 7.02, fcfMargin: 15.76 },
  { year: 2022, operating: 2.35, profit: 1.46, fcfMargin: 13.22 },
  { year: 2023, operating: 8.33, profit: 6.28, fcfMargin: 16.73 },
  { year: 2024, operating: 14.58, profit: 11.25, fcfMargin: 19.68 },
  { year: 2025, operating: 16.54, profit: 12.90, fcfMargin: 19.62 },
];

// Sensitivity analysis
const sensitivityRates = [0.07, 0.08, 0.09, 0.10, 0.11];
const sensitivityGrowth = [0.04, 0.06, 0.08, 0.10, 0.12];
const sensitivityTable = sensitivityRates.map(dr => {
  return {
    dr,
    values: sensitivityGrowth.map(gr => {
      let f = fcf2025;
      let pvSum = 0;
      for (let y = 1; y <= 5; y++) {
        f = f * (1 + gr);
        pvSum += f / Math.pow(1 + dr, y);
      }
      const f6 = f * (1 + growthRateTerminal);
      const tv = f6 / (dr - growthRateTerminal);
      const pvTV = tv / Math.pow(1 + dr, 5);
      return Math.round((pvSum + pvTV + netCash) / sharesOutstanding);
    })
  };
});
---

<SiteLayout
  site="westmount"
  title="Progressive (PGR) Intrinsic Value: A DCF Analysis"
  description="We ran a full discounted cash flow on Progressive using FY2025 actuals. Compiled by Gemini 2.5 Pro."
  canonical="https://westmountfundamentals.com/progressive-intrinsic-value"
  schema={schema}
>
  <div class="container">
    <div class="header">
      <div class="header-content">
        <span class="tag">Compiled by Gemini 2.5 Pro</span>
        <h1>Progressive (PGR) Intrinsic Value</h1>
        <p class="subtitle">A transparent, data-driven discounted cash flow valuation of The Progressive Corporation based on FY2025 actuals.</p>
        <div class="date">Updated: March 18, 2026</div>
      </div>
    </div>

    <!-- ═══ VERDICT ═══ -->
    <div class="verdict-card">
      <div class="verdict-label">Intrinsic Value Estimate</div>
      <div class="verdict-price">${roundedIV.toFixed(2)}</div>
      <div class="verdict-vs">vs. Current Price: ${currentPrice.toFixed(2)}</div>
      <div class="verdict-badge" style={`background: ${verdictColor}20; color: ${verdictColor}; border: 1px solid ${verdictColor}40;`}>
        {verdictText} ({marginOfSafety}%)
      </div>
    </div>

    <!-- ═══ QUICK STATS ═══ -->
    <div class="stats-row">
      <div class="stat-card">
        <div class="stat-value">${(fcf2025 / 1000).toFixed(1)}B</div>
        <div class="stat-label">FY25 Free Cash Flow</div>
      </div>
      <div class="stat-card">
        <div class="stat-value">{sharesOutstanding}M</div>
        <div class="stat-label">Shares Outstanding</div>
      </div>
      <div class="stat-card">
        <div class="stat-value">${(netCash / 1000).toFixed(1)}B</div>
        <div class="stat-label">Net Cash & Inv.</div>
      </div>
    </div>

    <!-- ═══ METHODOLOGY ═══ -->
    <h2>Methodology</h2>
    <p>We use a standard two-stage Discounted Cash Flow (DCF) model. We project free cash flows for the next 5 years (the "high growth" phase), then calculate a terminal value for all cash flows thereafter. Both are discounted back to today's dollars. Finally, we add net cash (cash + total investments - total debt) and divide by shares outstanding.</p>

    <!-- ═══ ASSUMPTIONS ═══ -->
    <h3>Our Core Assumptions</h3>
    <div class="assumption-grid">
      <div class="assumption-card">
        <div class="label">FCF Growth (Yrs 1-5)</div>
        <div class="value">{(growthRatePhase1 * 100)}%</div>
        <div class="rationale">Progressive's FCF grew by nearly 16% in FY25 and 42% in FY24. We assume a conservative 8% growth rate as the business scales and underwriting margins normalize.</div>
      </div>
      <div class="assumption-card">
        <div class="label">Discount Rate (WACC)</div>
        <div class="value">{(discountRate * 100)}%</div>
        <div class="rationale">Based on a 10-year Treasury yield of 4.18% and the company's historical equity risk profile. A 9% discount rate is appropriate for a mature, industry-leading insurance underwriter.</div>
      </div>
      <div class="assumption-card">
        <div class="label">Terminal Growth Rate</div>
        <div class="value">{(growthRateTerminal * 100)}%</div>
        <div class="rationale">We assume a long-term perpetual growth rate of 3%, slightly above long-term inflation, reflecting Progressive's ability to compound premium growth over time.</div>
      </div>
    </div>

    <!-- ═══ FCF PROJECTION TABLE ═══ -->
    <h2>Stage 1: Projected Free Cash Flows</h2>
    <p>Based on our {(growthRatePhase1 * 100)}% growth rate, here are the projected cash flows for the next 5 years, discounted at {(discountRate * 100)}%.</p>
    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th style="text-align:left">Year</th>
            <th>Projected FCF</th>
            <th>Discount Factor</th>
            <th>Present Value (PV)</th>
          </tr>
        </thead>
        <tbody>
          {projectedFCF.map(p => (
            <tr>
              <td>Year {p.year} (FY202{5 + p.year})</td>
              <td>${p.fcf.toLocaleString()}M</td>
              <td>{p.pvFactor.toFixed(3)}</td>
              <td>${p.pvFCF.toLocaleString()}M</td>
            </tr>
          ))}
          <tr class="row-total">
            <td>Sum of PV (Phase 1)</td>
            <td></td>
            <td></td>
            <td>${pvPhase1.toLocaleString()}M</td>
          </tr>
        </tbody>
      </table>
    </div>

    <!-- ═══ TERMINAL VALUE AND TOTALS ═══ -->
    <h2>Stage 2 & Final Calculation</h2>
    <div class="table-wrap">
      <table>
        <tbody>
          <tr>
            <td>Terminal Value (Year 6 FCF / (WACC - TGR))</td>
            <td>${terminalValue.toLocaleString()}M</td>
          </tr>
          <tr>
            <td>Present Value of Terminal Value</td>
            <td>${pvTerminalValue.toLocaleString()}M</td>
          </tr>
          <tr class="row-total">
            <td>Total Enterprise Value</td>
            <td>${enterpriseValue.toLocaleString()}M</td>
          </tr>
          <tr>
            <td>Plus: Net Cash (Cash & Eq + Total Investments - Debt)</td>
            <td>${netCash.toLocaleString()}M</td>
          </tr>
          <tr class="row-total">
            <td>Total Equity Value</td>
            <td>${equityValue.toLocaleString()}M</td>
          </tr>
          <tr>
            <td>Divided by Shares Outstanding</td>
            <td>{sharesOutstanding}M shares</td>
          </tr>
          <tr class="row-total">
            <td>Intrinsic Value Per Share</td>
            <td class="highlight-cell">${roundedIV.toFixed(2)}</td>
          </tr>
        </tbody>
      </table>
    </div>

    <!-- ═══ HISTORICAL CHARTS ═══ -->
    <h2>Financial Track Record</h2>
    <p>Before trusting a forward projection, look at where the company has been. Here is Progressive's 5-year performance.</p>

    <h3>Revenue ($B)</h3>
    <div class="bar-chart">
      {revenueHistory.map(r => (
        <div class="bar-row">
          <div class="bar-label">{r.year}</div>
          <div class="bar-track">
            <div class="bar-fill revenue" style={`width: ${(r.value / 87671) * 100}%`}>
              ${(r.value / 1000).toFixed(1)}B
            </div>
          </div>
        </div>
      ))}
    </div>

    <h3>Free Cash Flow ($B)</h3>
    <div class="bar-chart">
      {fcfHistory.map(r => (
        <div class="bar-row">
          <div class="bar-label">{r.year}</div>
          <div class="bar-track">
            <div class="bar-fill fcf" style={`width: ${(r.value / 17200) * 100}%`}>
              ${(r.value / 1000).toFixed(1)}B
            </div>
          </div>
        </div>
      ))}
    </div>

    <h3>Earnings Per Share (Diluted)</h3>
    <div class="bar-chart">
      {epsHistory.map(r => (
        <div class="bar-row">
          <div class="bar-label">{r.year}</div>
          <div class="bar-track">
            <div class="bar-fill eps" style={`width: ${(r.value / 19.23) * 100}%`}>
              ${r.value.toFixed(2)}
            </div>
          </div>
        </div>
      ))}
    </div>

    <!-- ═══ MARGIN TRENDS ═══ -->
    <h3>Margin Trends</h3>
    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th style="text-align:left">Year</th>
            <th>Operating Margin</th>
            <th>Profit Margin</th>
            <th>FCF Margin</th>
          </tr>
        </thead>
        <tbody>
          {marginHistory.map(m => (
            <tr>
              <td>{m.year}</td>
              <td>{m.operating}%</td>
              <td>{m.profit}%</td>
              <td>{m.fcfMargin}%</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
    <p><strong>Key observation:</strong> Progressive has experienced substantial margin expansion over the last two years, driven by strong premium growth and improved underwriting profitability following a difficult 2022.</p>

    <!-- ═══ SENSITIVITY ANALYSIS ═══ -->
    <h2>Sensitivity Analysis</h2>
    <p>Our base case uses 8% growth and 9% discount rate. Here is what the intrinsic value looks like under different assumptions.</p>

    <div class="table-wrap">
      <table class="sensitivity-table">
        <thead>
          <tr>
            <th style="text-align:left">Discount Rate ↓ / Growth →</th>
            {sensitivityGrowth.map(g => (
              <th class={g === growthRatePhase1 ? 'current' : ''}>{(g * 100)}%</th>
            ))}
          </tr>
        </thead>
        <tbody>
          {sensitivityTable.map(row => (
            <tr>
              <td>{(row.dr * 100)}%</td>
              {row.values.map((v, i) => (
                <td class={row.dr === discountRate && sensitivityGrowth[i] === growthRatePhase1 ? 'current' : ''}>
                  ${v}
                </td>
              ))}
            </tr>
          ))}
        </tbody>
      </table>
    </div>

    <!-- ═══ RISKS ═══ -->
    <h2>What This Model Doesn't Capture</h2>
    <p>No model is perfect. Here is what a DCF inherently misses for a property & casualty insurer.</p>

    <h3>Upside risks</h3>
    <ul>
      <li><strong>Float Growth:</strong> Insurers generate significant returns by investing premiums before paying out claims (the "float"). Rapid premium growth accelerates float accumulation.</li>
      <li><strong>Interest Rates:</strong> Higher for longer interest rates significantly boost the yield on Progressive's $97B investment portfolio.</li>
      <li><strong>Telematics Leadership:</strong> Progressive's edge in usage-based insurance (Snapshot) could drive deeper market share gains against legacy peers.</li>
    </ul>

    <h3>Downside risks</h3>
    <ul>
      <li><strong>Catastrophe Losses:</strong> Severe weather events or natural disasters can wipe out underwriting profits in any given quarter.</li>
      <li><strong>Inflationary Pressures:</strong> Spikes in auto repair costs or medical inflation can erode margins if rate increases lag loss severity.</li>
      <li><strong>Regulatory Constraints:</strong> State regulators must approve rate hikes. In highly regulated states (like California), securing adequate pricing can be challenging.</li>
    </ul>

    <!-- ═══ FAQ ═══ -->
    <h2>Frequently Asked Questions</h2>
    <div class="faq">
      <details>
        <summary>Why value an insurance company using DCF instead of Price-to-Book?</summary>
        <div class="faq-answer">While Price-to-Book (P/B) is the traditional metric for financial companies, a DCF can be effective for exceptional operators like Progressive that consistently generate high returns on equity (ROE) and significant free cash flow. It captures the value of their underwriting consistency and float generation better than static book value alone.</div>
      </details>
      <details>
        <summary>Why use a 9% discount rate?</summary>
        <div class="faq-answer">The 10-year Treasury yields 4.18%. With Progressive's lower beta (reflecting its defensive nature but cyclical earnings), a 9% WACC provides an appropriate hurdle rate that balances safety with the inherent risks of catastrophe-exposed underwriting.</div>
      </details>
      <details>
        <summary>Why include total investments in Net Cash?</summary>
        <div class="faq-answer">For insurance companies, their investment portfolio (representing shareholders' equity and policyholder float) is highly liquid and an integral part of their enterprise value. We add it to cash & equivalents to reflect the total liquid assets backing the business.</div>
      </details>
    </div>

    <!-- ═══ DISCLAIMER ═══ -->
    <div class="disclaimer">
      <h4>⚠️ Important Disclaimer</h4>
      <p>This analysis is for educational and informational purposes only. It is not investment advice, a recommendation to buy or sell securities, or a solicitation of any kind. The intrinsic value estimate is based on assumptions that may prove incorrect. Past performance does not guarantee future results. All investments carry risk, including the loss of principal. Always conduct your own due diligence and consult a licensed financial advisor before making investment decisions.</p>
    </div>
  </div>

<style>
