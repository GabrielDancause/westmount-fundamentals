  <script is:inline>
// Historical Asset Data (Gathered from Yahoo Finance)
  const assetData = {
    stocks: {
      ticker: "SPY",
      meanAnnual: 0.11163228857423181,
      stdAnnual: 0.15293468465131893
    },
    bonds: {
      ticker: "AGG",
      meanAnnual: 0.032726388315620025,
      stdAnnual: 0.04650921802353446
    }
  };

  // Assumed Stock-Bond Correlation
  const correlation = 0.1;

  // Box-Muller transform for standard normal random numbers
  function randn_bm() {
    let u = 0, v = 0;
    while(u === 0) u = Math.random();
    while(v === 0) v = Math.random();
    return Math.sqrt(-2.0 * Math.log(u)) * Math.cos(2.0 * Math.PI * v);
  }

  // Format currency
  const formatCurrency = (val) => {
    if (val < 0) return "-$" + Math.abs(val).toLocaleString(undefined, { maximumFractionDigits: 0 });
    return "$" + val.toLocaleString(undefined, { maximumFractionDigits: 0 });
  };

  let chartInstance = null;

  function runSimulation() {
    // 1. Get Inputs
    const initialBalance = parseFloat(document.getElementById('input-balance').value) || 0;
    const annualContribution = parseFloat(document.getElementById('input-contribution').value) || 0;
    const years = parseInt(document.getElementById('input-years').value) || 30;
    const inflation = (parseFloat(document.getElementById('input-inflation').value) || 0) / 100;

    const stockWeight = (parseFloat(document.getElementById('input-stocks').value) || 60) / 100;
    const bondWeight = 1 - stockWeight;

    // 2. Calculate Portfolio Mean and StdDev (Blended)
    const portMean = (stockWeight * assetData.stocks.meanAnnual) + (bondWeight * assetData.bonds.meanAnnual);

    // Portfolio Variance = w1^2*o1^2 + w2^2*o2^2 + 2*w1*w2*o1*o2*p
    const portVar = (Math.pow(stockWeight, 2) * Math.pow(assetData.stocks.stdAnnual, 2)) +
                    (Math.pow(bondWeight, 2) * Math.pow(assetData.bonds.stdAnnual, 2)) +
                    (2 * stockWeight * bondWeight * assetData.stocks.stdAnnual * assetData.bonds.stdAnnual * correlation);
    const portStdDev = Math.sqrt(portVar);

    // 3. Monte Carlo Simulation
    const NUM_SIMULATIONS = 1000;
    const results = []; // stores final balances
    const paths = []; // stores full year-by-year paths for all simulations

    let successCount = 0;

    for (let s = 0; s < NUM_SIMULATIONS; s++) {
      let balance = initialBalance;
      let currentPath = [balance];

      let isSuccess = true;

      for (let y = 1; y <= years; y++) {
        // Generate random nominal return for the year
        const nominalReturn = portMean + (randn_bm() * portStdDev);

        // Convert to real return (inflation-adjusted)
        const realReturn = (1 + nominalReturn) / (1 + inflation) - 1;

        // Apply return to balance
        balance = balance * (1 + realReturn);

        // Apply contribution/withdrawal (adjusting for inflation simplistically by keeping it constant in real terms)
        balance += annualContribution;

        if (balance < 0) {
          balance = 0;
          isSuccess = false;
        }

        currentPath.push(balance);
      }

      results.push(balance);
      paths.push(currentPath);
      if (isSuccess && balance > 0) successCount++;
    }

    // 4. Calculate Percentiles
    // Calculate percentiles at each year across all paths
    const yearPercentiles = {
      p10: [],
      p25: [],
      p50: [],
      p75: [],
      p90: []
    };

    for (let y = 0; y <= years; y++) {
      const yearValues = paths.map(p => p[y]).sort((a, b) => a - b);
      yearPercentiles.p10.push(yearValues[Math.floor(NUM_SIMULATIONS * 0.10)]);
      yearPercentiles.p25.push(yearValues[Math.floor(NUM_SIMULATIONS * 0.25)]);
      yearPercentiles.p50.push(yearValues[Math.floor(NUM_SIMULATIONS * 0.50)]);
      yearPercentiles.p75.push(yearValues[Math.floor(NUM_SIMULATIONS * 0.75)]);
      yearPercentiles.p90.push(yearValues[Math.floor(NUM_SIMULATIONS * 0.90)]);
    }

    // Sort final results for summary stats
    results.sort((a, b) => a - b);
    const final_p10 = results[Math.floor(NUM_SIMULATIONS * 0.10)];
    const final_p50 = results[Math.floor(NUM_SIMULATIONS * 0.50)];
    const final_p90 = results[Math.floor(NUM_SIMULATIONS * 0.90)];
    const probSuccess = (successCount / NUM_SIMULATIONS) * 100;

    // 5. Update UI Stats
    document.getElementById('val-prob').innerText = probSuccess.toFixed(1) + "%";
    document.getElementById('val-worst').innerText = formatCurrency(final_p10);
    document.getElementById('val-median').innerText = formatCurrency(final_p50);
    document.getElementById('val-best').innerText = formatCurrency(final_p90);

    // Color code probability
    const statProb = document.getElementById('stat-prob');
    statProb.className = 'stat-card'; // reset
    if (probSuccess >= 80) statProb.classList.add('success');
    else if (probSuccess >= 50) statProb.classList.add('warning');
    else statProb.classList.add('danger');

    // 6. Draw Chart
    drawChart(years, yearPercentiles);

    // 7. Render Table
    renderTable(years, yearPercentiles);
  }

  let tableData = [];
  let sortCol = 0;
  let sortAsc = true;

  function renderTable(years, percentiles) {
    tableData = [];
    for (let i = 0; i <= years; i++) {
      tableData.push({
        year: i,
        p10: percentiles.p10[i],
        p25: percentiles.p25[i],
        p50: percentiles.p50[i],
        p75: percentiles.p75[i],
        p90: percentiles.p90[i]
      });
    }
    updateTableUI();
  }

  function updateTableUI() {
    const tbody = document.getElementById('projection-table-body');
    const searchTerm = document.getElementById('table-search').value.toLowerCase();

    // Filter
    let filteredData = tableData.filter(row => {
      return row.year.toString().includes(searchTerm);
    });

    // Sort
    filteredData.sort((a, b) => {
      let valA, valB;
      switch(sortCol) {
        case 0: valA = a.year; valB = b.year; break;
        case 1: valA = a.p10; valB = b.p10; break;
        case 2: valA = a.p25; valB = b.p25; break;
        case 3: valA = a.p50; valB = b.p50; break;
        case 4: valA = a.p75; valB = b.p75; break;
        case 5: valA = a.p90; valB = b.p90; break;
      }
      return sortAsc ? valA - valB : valB - valA;
    });

    // Render
    tbody.innerHTML = '';
    filteredData.forEach(row => {
      const tr = document.createElement('tr');
      tr.style.borderBottom = '1px solid #152040';
      if (row.year % 5 === 0 && row.year !== 0) {
        tr.style.backgroundColor = 'rgba(74, 143, 231, 0.05)';
      }

      tr.innerHTML = `
        <td style="padding: 1rem; text-align: left; color: #94a3b8;">Year ${row.year}</td>
        <td style="padding: 1rem; color: #ef4444;">${formatCurrency(row.p10)}</td>
        <td style="padding: 1rem; color: #f59e0b;">${formatCurrency(row.p25)}</td>
        <td style="padding: 1rem; color: #4a8fe7; font-weight: 700;">${formatCurrency(row.p50)}</td>
        <td style="padding: 1rem; color: #10b981;">${formatCurrency(row.p75)}</td>
        <td style="padding: 1rem; color: #10b981;">${formatCurrency(row.p90)}</td>
      `;
      tbody.appendChild(tr);
    });
  }

  function sortTable(colIndex) {
    if (sortCol === colIndex) {
      sortAsc = !sortAsc;
    } else {
      sortCol = colIndex;
      sortAsc = true;
    }
    updateTableUI();
  }

  document.getElementById('table-search').addEventListener('input', updateTableUI);

  function drawChart(years, percentiles) {
    const ctx = document.getElementById('monteCarloChart').getContext('2d');

    if (chartInstance) {
      chartInstance.destroy();
    }

    const labels = Array.from({length: years + 1}, (_, i) => "Year " + i);

    chartInstance = new Chart(ctx, {
      type: 'line',
      data: {
        labels: labels,
        datasets: [
          {
            label: '10th Percentile (Worst Case)',
            data: percentiles.p10,
            borderColor: '#ef4444',
            backgroundColor: 'transparent',
            borderWidth: 2,
            borderDash: [5, 5],
            pointRadius: 0,
            tension: 0.1
          },
          {
            label: '25th Percentile',
            data: percentiles.p25,
            borderColor: 'rgba(245, 158, 11, 0.5)',
            backgroundColor: 'transparent',
            borderWidth: 1,
            pointRadius: 0,
            tension: 0.1
          },
          {
            label: '50th Percentile (Median)',
            data: percentiles.p50,
            borderColor: '#4a8fe7',
            backgroundColor: 'rgba(74, 143, 231, 0.1)',
            borderWidth: 3,
            fill: false,
            pointRadius: 0,
            tension: 0.1
          },
          {
            label: '75th Percentile',
            data: percentiles.p75,
            borderColor: 'rgba(16, 185, 129, 0.5)',
            backgroundColor: 'transparent',
            borderWidth: 1,
            pointRadius: 0,
            tension: 0.1
          },
          {
            label: '90th Percentile (Best Case)',
            data: percentiles.p90,
            borderColor: '#10b981',
            backgroundColor: 'transparent',
            borderWidth: 2,
            borderDash: [5, 5],
            pointRadius: 0,
            tension: 0.1
          }
        ]
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        interaction: {
          mode: 'index',
          intersect: false,
        },
        plugins: {
          legend: {
            position: 'bottom',
            labels: { color: '#94a3b8', font: { family: 'Inter' } }
          },
          tooltip: {
            backgroundColor: 'rgba(10, 16, 32, 0.9)',
            titleColor: '#fff',
            bodyColor: '#e2e8f0',
            borderColor: '#152040',
            borderWidth: 1,
            callbacks: {
              label: function(context) {
                let label = context.dataset.label || '';
                if (label) { label += ': '; }
                if (context.parsed.y !== null) {
                  label += formatCurrency(context.parsed.y);
                }
                return label;
              }
            }
          }
        },
        scales: {
          x: {
            grid: { color: '#152040' },
            ticks: { color: '#94a3b8', maxTicksLimit: 10 }
          },
          y: {
            grid: { color: '#152040' },
            ticks: {
              color: '#94a3b8',
              callback: function(value) {
                if (value >= 1000000) return '$' + (value / 1000000).toFixed(1) + 'M';
                if (value >= 1000) return '$' + (value / 1000).toFixed(0) + 'k';
                return '$' + value;
              }
            }
          }
        }
      }
    });
  }

  // Event Listeners
  document.getElementById('input-stocks').addEventListener('input', function(e) {
    const val = e.target.value;
    document.getElementById('alloc-stocks').innerText = val + "% Stocks";
    document.getElementById('alloc-bonds').innerText = (100 - val) + "% Bonds";
  });

  document.getElementById('run-btn').addEventListener('click', runSimulation);

  // Initial Run
  window.addEventListener('DOMContentLoaded', runSimulation);
  </script>
</SiteLayout>
