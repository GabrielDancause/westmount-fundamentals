---
import SiteLayout from '../layouts/SiteLayout.astro';

export const meta = {
  title: "AbbVie Inc. (ABBV) Intrinsic Value",
  description: "A comprehensive two-stage Discounted Cash Flow (DCF) intrinsic value estimate for AbbVie Inc. (ABBV), analyzing free cash flow, growth assumptions, and valuation metrics.",
  category: "study",
  published: "2026-03-18"
};

// --- FINANCIAL DATA & ASSUMPTIONS ---
const ticker = "ABBV";
const companyName = "AbbVie Inc.";
const currentPrice = 211.11;
const sharesOutstanding = 1768169012; // 1.768B
const marketCap = currentPrice * sharesOutstanding;

// From Latest Financials
const freeCashFlow = 17816000000; // $17.816B
const totalDebt = 67496000000; // $67.496B
const cashAndEquivalents = 5229000000; // $5.229B

// Assumptions for DCF
const wacc = 0.082; // 8.2% Discount Rate: Reflects patent cliff risks (Humira) but stable cash flows from Skyrizi/Rinvoq and strong dividend profile.
const fcfGrowthRate = 0.035; // 3.5% Years 1-5 Growth: Conservative growth factoring in Humira biosimilar erosion being fully absorbed, with immunology and oncology segments driving mid-single-digit expansion.
const terminalGrowthRate = 0.020; // 2.0% Terminal Growth: Mature pharma sector average, pacing slightly below long-term GDP growth.

// --- TWO-STAGE DCF CALCULATIONS ---
let projectedFCF = [];
let presentValueOfFCF = [];
let cumulativePV = 0;

// Stage 1: Explicit Forecast Period (5 Years)
for (let year = 1; year <= 5; year++) {
  const fcf = freeCashFlow * Math.pow(1 + fcfGrowthRate, year);
  projectedFCF.push(fcf);

  const pv = fcf / Math.pow(1 + wacc, year);
  presentValueOfFCF.push(pv);
  cumulativePV += pv;
}

// Stage 2: Terminal Value
const year5FCF = projectedFCF[4];
const terminalValue = (year5FCF * (1 + terminalGrowthRate)) / (wacc - terminalGrowthRate);
const pvOfTerminalValue = terminalValue / Math.pow(1 + wacc, 5);

// Enterprise Value & Equity Value
const enterpriseValue = cumulativePV + pvOfTerminalValue;
const equityValue = enterpriseValue + cashAndEquivalents - totalDebt;

// Intrinsic Value Per Share
const intrinsicValuePerShare = equityValue / sharesOutstanding;
const marginOfSafety = ((intrinsicValuePerShare - currentPrice) / currentPrice) * 100;

// Formatters
const formatCurrency = (val) => new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD', maximumFractionDigits: 2 }).format(val);
const formatBillions = (val) => `$${(val / 1000000000).toFixed(2)}B`;
const formatPercent = (val) => `${(val * 100).toFixed(2)}%`;

// Verdict Logic
const isUndervalued = intrinsicValuePerShare > currentPrice;
const verdictColor = isUndervalued ? '#22c55e' : '#ef4444';
const verdictText = isUndervalued ? 'Undervalued' : 'Overvalued';
const verdictBg = isUndervalued ? 'rgba(34, 197, 94, 0.1)' : 'rgba(239, 68, 68, 0.1)';

// Schema.org JSON-LD
const schema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": meta.title,
  "description": meta.description,
  "author": {
    "@type": "Person",
    "name": "Gemini 3.1"
  },
  "datePublished": meta.published,
  "publisher": {
    "@type": "Organization",
    "name": "Westmount Fundamentals",
    "logo": {
      "@type": "ImageObject",
      "url": "https://westmountfundamentals.com/logo.png"
    }
  }
};

// Sensitivity Matrix Data
const discountRates = [0.062, 0.072, 0.082, 0.092, 0.102];
const growthRates = [0.010, 0.015, 0.020, 0.025, 0.030];

function calculateSensitivityPrice(dRate, gRate) {
    let cumPV = 0;
    let finalFCF = freeCashFlow;

    // 5 years explicit
    for(let i=1; i<=5; i++) {
        finalFCF = finalFCF * (1 + fcfGrowthRate);
        cumPV += finalFCF / Math.pow(1 + dRate, i);
    }

    const tv = (finalFCF * (1 + gRate)) / (dRate - gRate);
    const pvTV = tv / Math.pow(1 + dRate, 5);

    const ev = cumPV + pvTV;
    const eqVal = ev + cashAndEquivalents - totalDebt;
    return eqVal / sharesOutstanding;
}

---

<SiteLayout
  site="westmount"
  title={meta.title}
  description={meta.description}
  canonical="https://westmountfundamentals.com/abbvie-intrinsic-value"
  schema={schema}
>
  <style>
    /* Dark Finance Theme - Westmount specifics */
    .study-header {
      text-align: center;
      margin-bottom: 3rem;
    }
    .study-meta {
      display: inline-block;
      background: rgba(74, 143, 231, 0.1);
      color: #4a8fe7;
      padding: 0.5rem 1rem;
      border-radius: 999px;
      font-size: 0.875rem;
      font-weight: 600;
      letter-spacing: 0.05em;
      text-transform: uppercase;
      margin-bottom: 1rem;
      border: 1px solid rgba(74, 143, 231, 0.2);
    }
    .study-title {
      font-size: 3rem;
      font-weight: 900;
      color: #c8d0de;
      margin-bottom: 0.5rem;
    }
    .study-subtitle {
      font-size: 1.25rem;
      color: #8b9bb4;
      font-weight: 400;
    }

    .verdict-card {
      background: #0a111f;
      border: 1px solid #1e293b;
      border-radius: 16px;
      padding: 2.5rem;
      display: flex;
      flex-direction: column;
      align-items: center;
      margin-bottom: 3rem;
      box-shadow: 0 10px 30px -10px rgba(0,0,0,0.5);
    }
    .verdict-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 2rem;
      width: 100%;
      text-align: center;
    }
    .verdict-item {
      padding: 1.5rem;
      background: rgba(255,255,255,0.02);
      border-radius: 12px;
      border: 1px solid rgba(255,255,255,0.05);
    }
    .verdict-label {
      font-size: 0.875rem;
      color: #8b9bb4;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      margin-bottom: 0.5rem;
      font-weight: 600;
    }
    .verdict-value {
      font-family: 'JetBrains Mono', monospace;
      font-size: 2.5rem;
      font-weight: 800;
      color: #c8d0de;
    }
    .verdict-result {
      grid-column: span 3;
      margin-top: 1rem;
      padding: 1.5rem;
      border-radius: 12px;
      font-weight: 700;
      font-size: 1.5rem;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 1rem;
    }
    .premium-discount {
      font-family: 'JetBrains Mono', monospace;
      font-size: 1.25rem;
      opacity: 0.9;
    }

    .section-title {
      font-size: 2rem;
      color: #4a8fe7;
      margin-top: 4rem;
      margin-bottom: 2rem;
      padding-bottom: 0.5rem;
      border-bottom: 1px solid #1e293b;
    }

    .assumptions-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
      gap: 1.5rem;
      margin-bottom: 3rem;
    }
    .assumption-card {
      background: #0a111f;
      border: 1px solid #1e293b;
      padding: 1.5rem;
      border-radius: 12px;
      border-top: 3px solid #4a8fe7;
    }
    .assumption-card h4 {
      margin-top: 0;
      color: #c8d0de;
      font-size: 1.125rem;
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 1rem;
    }
    .assumption-val {
      font-family: 'JetBrains Mono', monospace;
      color: #4a8fe7;
      background: rgba(74, 143, 231, 0.1);
      padding: 0.25rem 0.5rem;
      border-radius: 6px;
    }
    .assumption-card p {
      font-size: 0.95rem;
      color: #8b9bb4;
      line-height: 1.6;
      margin-bottom: 0;
    }

    .data-table-wrapper {
      background: #0a111f;
      border: 1px solid #1e293b;
      border-radius: 12px;
      overflow: hidden;
      margin-bottom: 2rem;
    }
    table {
      width: 100%;
      border-collapse: collapse;
    }
    th, td {
      padding: 1rem 1.5rem;
      text-align: right;
      border-bottom: 1px solid #1e293b;
    }
    th:first-child, td:first-child {
      text-align: left;
    }
    th {
      background: rgba(255,255,255,0.02);
      color: #8b9bb4;
      font-weight: 600;
      text-transform: uppercase;
      font-size: 0.75rem;
      letter-spacing: 0.05em;
    }
    td {
      font-family: 'JetBrains Mono', monospace;
      color: #c8d0de;
    }
    tr:last-child td {
      border-bottom: none;
    }
    .total-row td {
      background: rgba(74, 143, 231, 0.05);
      font-weight: 700;
      color: #4a8fe7;
    }

    .calc-step {
      display: flex;
      justify-content: space-between;
      padding: 1rem 0;
      border-bottom: 1px dashed #1e293b;
      font-size: 1.1rem;
    }
    .calc-step:last-child {
      border-bottom: none;
      font-weight: 800;
      font-size: 1.25rem;
      color: #4a8fe7;
      padding-top: 1.5rem;
      margin-top: 0.5rem;
      border-top: 2px solid #1e293b;
    }
    .calc-label {
      color: #8b9bb4;
    }
    .calc-value {
      font-family: 'JetBrains Mono', monospace;
      color: #c8d0de;
    }

    .sensitivity-matrix {
      width: 100%;
      border-collapse: separate;
      border-spacing: 4px;
      margin: 2rem 0;
    }
    .sensitivity-matrix th, .sensitivity-matrix td {
      border: none;
      text-align: center;
      padding: 0.75rem;
      border-radius: 6px;
    }
    .matrix-corner {
      background: transparent;
      color: #8b9bb4;
      font-size: 0.75rem;
      text-transform: uppercase;
      letter-spacing: 0.05em;
    }
    .matrix-header-row {
      background: #1e293b;
      color: #c8d0de;
      font-weight: 600;
    }
    .matrix-header-col {
      background: #1e293b;
      color: #c8d0de;
      font-weight: 600;
    }
    .matrix-cell {
      background: #0a111f;
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.95rem;
      transition: all 0.2s;
    }
    .matrix-cell:hover {
      background: #1e293b;
      cursor: default;
    }
    .matrix-highlight {
      background: rgba(74, 143, 231, 0.15);
      color: #4a8fe7;
      border: 1px solid rgba(74, 143, 231, 0.3);
    }

    .risks-list {
      list-style-type: none;
      padding: 0;
    }
    .risks-list li {
      position: relative;
      padding-left: 2rem;
      margin-bottom: 1.5rem;
      color: #8b9bb4;
      line-height: 1.6;
    }
    .risks-list li::before {
      content: "⚠️";
      position: absolute;
      left: 0;
      top: 0;
    }

