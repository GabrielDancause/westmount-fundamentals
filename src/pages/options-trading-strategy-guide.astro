---
import SiteLayout from "../layouts/SiteLayout.astro";

const schema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What is the difference between a simple option trade and a spread?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "A simple option trade involves buying or selling a single call or put. A spread involves buying and selling multiple options simultaneously (often with different strike prices or expirations) to limit risk, reduce cost, or define a specific payoff range."
      }
    },
    {
      "@type": "Question",
      "name": "How does an Iron Condor work?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "An Iron Condor is a neutral, non-directional strategy combining a bear call spread and a bull put spread. It profits when the underlying stock remains within a specific price range between the two short strikes through expiration."
      }
    },
    {
      "@type": "Question",
      "name": "What does 'breakeven point' mean in options strategies?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "The breakeven point is the exact price the underlying asset must reach at expiration for the strategy to have zero profit and zero loss. Complex strategies like Iron Condors have multiple breakeven points (upper and lower bounds)."
      }
    },
    {
      "@type": "Question",
      "name": "How does implied volatility (IV) impact options spreads?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "When IV is high, options premiums are expensive. Sellers often use strategies like Credit Spreads or Iron Condors to collect high premiums, hoping IV will crush (decrease). When IV is low, buying strategies like Debit Spreads or Straddles become relatively cheaper."
      }
    },
    {
      "@type": "Question",
      "name": "What are the core Greeks to monitor for an options strategy?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "The primary Greeks are Delta (directional risk), Gamma (acceleration of Delta), Theta (time decay), and Vega (sensitivity to volatility changes). Tracking net Greeks across a spread helps understand how the entire position will behave as market conditions change."
      }
    }
  ]
};

export const meta = {
  title: "Options Trading Strategy Guide | Westmount Fundamentals",
  description: "A comprehensive guide to options trading strategies from basic to advanced. Learn about covered calls, straddles, iron condors, risk/reward profiles, and...",
  category: "guide",
  published: "2026-03-15",
};
