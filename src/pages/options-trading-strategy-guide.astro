      document.querySelector('#result-volatile .desc').textContent = "You expect a massive move (e.g., upcoming earnings or FDA approval) but don't know the direction. You buy both an ATM Call and ATM Put.";

      buttons.forEach(button => {
        button.addEventListener('click', () => {
          // Remove active class from all buttons and results
          buttons.forEach(btn => btn.classList.remove('active'));
          results.forEach(res => res.classList.remove('active'));

          // Add active class to clicked button
          button.classList.add('active');

          // Show corresponding result
          const outlook = button.getAttribute('data-outlook');
          const targetResult = document.getElementById(`result-${outlook}`);
          if (targetResult) {
            targetResult.classList.add('active');
          }
        });
      });
    });
