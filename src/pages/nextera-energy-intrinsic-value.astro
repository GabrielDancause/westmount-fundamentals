/* ═══════════════════════════════════════════════════════════════
   DCF MODEL — ALL INPUTS AND CALCULATIONS
   Compiled by Gemini 3.1 using StockAnalysis.com FY2025 actuals.
   We use a two-stage DCF: high-growth phase (Years 1-5) then terminal value.
   ═══════════════════════════════════════════════════════════════ */

// --- INPUTS (all in millions USD unless noted) ---
const fcf2025 = 3764;                  // FY2025 Free Cash Flow ($M)
const sharesOutstanding = 2071;         // Diluted shares outstanding ($M) — FY2025
const cashAndInvestments = 2812;        // Cash & Equivalents ($M)
const totalDebt = 95619;               // Total debt ($M)
const netCash = cashAndInvestments - totalDebt; // -$92,807M

// --- ASSUMPTIONS (fully disclosed below) ---
const growthRatePhase1 = 0.25;         // 25% FCF growth, Years 1-5
const growthRateTerminal = 0.025;      // 2.5% perpetuity growth (terminal)
const discountRate = 0.06;             // 6% WACC / required return

// --- PHASE 1: PROJECT FCF FOR YEARS 1-5 ---
const projectedFCF = [];
let fcf = fcf2025;
for (let yr = 1; yr <= 5; yr++) {
  fcf = fcf * (1 + growthRatePhase1);
  projectedFCF.push({ year: yr, fcf: Math.round(fcf), pvFactor: 1 / Math.pow(1 + discountRate, yr) });
}
projectedFCF.forEach(p => { p.pvFCF = Math.round(p.fcf * p.pvFactor); });

// --- PHASE 2: TERMINAL VALUE (Gordon Growth Model) ---
const fcfYear6 = projectedFCF[4].fcf * (1 + growthRateTerminal);
const terminalValue = Math.round(fcfYear6 / (discountRate - growthRateTerminal));
const pvTerminalValue = Math.round(terminalValue * projectedFCF[4].pvFactor);

// --- ENTERPRISE VALUE ---
const pvPhase1 = projectedFCF.reduce((sum, p) => sum + p.pvFCF, 0);
const enterpriseValue = pvPhase1 + pvTerminalValue;

// --- EQUITY VALUE ---
const equityValue = enterpriseValue + netCash;
const intrinsicValuePerShare = equityValue / sharesOutstanding;
const roundedIV = Math.round(intrinsicValuePerShare * 100) / 100;

// Market comparison
const currentPrice = 91.04;
const marginOfSafety = ((roundedIV - currentPrice) / currentPrice * 100).toFixed(1);
const verdictText = roundedIV > currentPrice ? "Undervalued" : "Overvalued";
const verdictColor = roundedIV > currentPrice ? "#10b981" : "#ef4444";

// --- HISTORICAL DATA for charts ---
const revenueHistory = [
  { year: 2021, value: 17069 },
  { year: 2022, value: 20956 },
  { year: 2023, value: 28114 },
  { year: 2024, value: 24753 },
  { year: 2025, value: 27412 },
];
const fcfHistory = [
  { year: 2021, value: -2 },
  { year: 2022, value: -1257 },
  { year: 2023, value: 1938 },
  { year: 2024, value: 5145 },
  { year: 2025, value: 3764 },
];
const epsHistory = [
  { year: 2021, value: 1.81 },
  { year: 2022, value: 2.10 },
  { year: 2023, value: 3.60 },
  { year: 2024, value: 3.37 },
  { year: 2025, value: 3.30 },
];
const marginHistory = [
  { year: 2021, operating: 17.07, profit: 16.56, fcfMargin: -0.01 },
  { year: 2022, operating: 19.47, profit: 15.49, fcfMargin: -6.00 },
  { year: 2023, operating: 36.41, profit: 22.34, fcfMargin: 6.89 },
  { year: 2024, operating: 30.21, profit: 23.02, fcfMargin: 20.79 },
  { year: 2025, operating: 30.21, profit: 19.45, fcfMargin: 13.73 },
];

// Sensitivity analysis
const sensitivityRates = [0.04, 0.05, 0.06, 0.07, 0.08];
const sensitivityGrowth = [0.15, 0.20, 0.25, 0.30, 0.35];
const sensitivityTable = sensitivityRates.map(dr => {
  return {
    dr,
    values: sensitivityGrowth.map(gr => {
      let f = fcf2025;
      let pvSum = 0;
      for (let y = 1; y <= 5; y++) {
        f = f * (1 + gr);
        pvSum += f / Math.pow(1 + dr, y);
      }
      const f6 = f * (1 + growthRateTerminal);
      const tv = f6 / (dr - growthRateTerminal);
      const pvTV = tv / Math.pow(1 + dr, 5);
      return Math.round((pvSum + pvTV + netCash) / sharesOutstanding);
    })
  };
});
