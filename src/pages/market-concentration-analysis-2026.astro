        document.addEventListener('DOMContentLoaded', () => {
            const data = window.__INITIAL_DATA__;

            // Format percentages
            const formatPct = (val) => (val * 100).toFixed(2) + '%';

            // Render Holdings Table
            const renderTable = (symbol) => {
                const indexData = data[symbol];
                if (!indexData || !indexData.holdings) return;

                const totalWeight = indexData.holdings.reduce((sum, h) => sum + h.holdingPercent, 0);

                let html = `
                    <div style="margin-bottom: 1rem;">
                        <strong>Total Top 10 Weight: <span style="color: var(--accent-color);">${formatPct(totalWeight)}</span></strong>
                    </div>
                    <table>
                        <thead>
                            <tr>
                                <th>Symbol</th>
                                <th>Company</th>
                                <th>Weight</th>
                            </tr>
                        </thead>
                        <tbody>
                `;

                indexData.holdings.forEach(h => {
                    const pct = h.holdingPercent * 100;
                    html += `
                        <tr>
                            <td class="mono">${h.symbol}</td>
                            <td>${h.holdingName}</td>
                            <td>
                                ${pct.toFixed(2)}%
                                <div class="progress-bar">
                                    <div class="progress-fill" style="width: ${pct}%"></div>
                                </div>
                            </td>
                        </tr>
                    `;
                });

                html += '</tbody></table>';
                document.getElementById('holdingsContainer').innerHTML = html;
            };

            // Setup Tabs
            const tabs = document.querySelectorAll('.tab-btn');
            tabs.forEach(tab => {
                tab.addEventListener('click', (e) => {
                    tabs.forEach(t => t.classList.remove('active'));
                    e.target.classList.add('active');
                    renderTable(e.target.dataset.target);
                });
            });

            // Initial render
            renderTable('SPY');

            // Setup Historical Chart
            const ctxHist = document.getElementById('historicalChart').getContext('2d');
            const histData = data.historicalContext;

            new Chart(ctxHist, {
                type: 'line',
                data: {
                    labels: histData.spyTop10Weight.map(d => d.year),
                    datasets: [
                        {
                            label: 'S&P 500 Top 10 Weight %',
                            data: histData.spyTop10Weight.map(d => d.weight),
                            borderColor: '#4a8fe7',
                            backgroundColor: 'rgba(74, 143, 231, 0.2)',
                            fill: true,
                            tension: 0.3
                        },
                        {
                            label: 'NASDAQ 100 Top 10 Weight %',
                            data: histData.qqqTop10Weight.map(d => d.weight),
                            borderColor: '#e74c3c',
                            backgroundColor: 'rgba(231, 76, 60, 0.2)',
                            fill: true,
                            tension: 0.3
                        }
                    ]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: { labels: { color: '#e2e8f0' } }
                    },
                    scales: {
                        y: {
                            beginAtZero: true,
                            max: 60,
                            ticks: { color: '#94a3b8', callback: (val) => val + '%' },
                            grid: { color: '#152040' }
                        },
                        x: {
                            ticks: { color: '#94a3b8' },
                            grid: { color: '#152040' }
                        }
                    }
                }
            });

            // Setup Sector Chart
            const ctxSector = document.getElementById('sectorChart').getContext('2d');
            const spySectors = data['SPY'].sectorWeightings;

            // Process sector data
            const sectorLabels = [];
            const sectorData = [];

            // Format labels: basic_materials -> Basic Materials
            const formatSector = (str) => {
                return str.split('_').map(word => word.charAt(0).toUpperCase() + word.slice(1)).join(' ');
            };

            spySectors.forEach(s => {
                const key = Object.keys(s)[0];
                sectorLabels.push(formatSector(key));
                sectorData.push(s[key] * 100);
            });

            // Sort by weight
            const sortedIndices = sectorData.map((val, ind) => ind)
                .sort((a, b) => sectorData[b] - sectorData[a]);

            const sortedLabels = sortedIndices.map(i => sectorLabels[i]);
            const sortedVals = sortedIndices.map(i => sectorData[i]);

            new Chart(ctxSector, {
                type: 'doughnut',
                data: {
                    labels: sortedLabels,
                    datasets: [{
                        data: sortedVals,
                        backgroundColor: [
                            '#4a8fe7', '#3498db', '#2980b9', '#1abc9c', '#16a085',
                            '#f1c40f', '#f39c12', '#e67e22', '#d35400', '#e74c3c', '#c0392b'
                        ],
                        borderWidth: 1,
                        borderColor: '#060a12'
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: {
                            position: 'right',
                            labels: { color: '#e2e8f0', boxWidth: 12 }
                        },
                        tooltip: {
                            callbacks: {
                                label: function(context) {
                                    return ' ' + context.label + ': ' + context.raw.toFixed(1) + '%';
                                }
                            }
                        }
                    }
                }
            });
        });
  </script>

  
