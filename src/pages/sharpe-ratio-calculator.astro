      </div>
      <div class="field">
        <label for="so-dd">Downside Deviation (%)</label>
        <input type="number" id="so-dd" value="10" min="0.1" max="100" step="0.1">
      </div>
    </div>
    <button class="btn-calc" onclick="calcSortino()">Calculate Sortino Ratio</button>
