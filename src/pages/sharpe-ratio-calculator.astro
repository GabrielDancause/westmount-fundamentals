      </div>
      <div class="port-card">
        <h3>Portfolio B</h3>
        <div class="field"><label>Return (%)</label><input type="number" id="pb-ret" value="9" step="0.1"></div>
        <div class="field"><label>Risk-Free Rate (%)</label><input type="number" id="pb-rf" value="4.5" step="0.1"></div>
        <div class="field"><label>Std Deviation (%)</label><input type="number" id="pb-std" value="8" step="0.1"></div>
        <div class="port-result" id="pb-result"><div class="rv" style="color:#9aa0a6">—</div><div class="rl" style="font-size:0.75rem;color:#9aa0a6">SHARPE RATIO</div></div>
      </div>
      <div class="port-card">
        <h3>Portfolio C</h3>
        <div class="field"><label>Return (%)</label><input type="number" id="pc-ret" value="15" step="0.1"></div>
        <div class="field"><label>Risk-Free Rate (%)</label><input type="number" id="pc-rf" value="4.5" step="0.1"></div>
