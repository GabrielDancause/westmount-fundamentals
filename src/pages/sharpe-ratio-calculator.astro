</div>

<div class="sr-wrap">

  <!-- Stat Cards -->
  <div class="stat-row">
    <div class="stat-card">
      <div class="sv">0.5 – 0.7</div>
      <div class="sl">S&P 500 Historical Sharpe Ratio</div>
    </div>
    <div class="stat-card">
      <div class="sv">1990</div>
      <div class="sl">Nobel Prize — William F. Sharpe</div>
    </div>
