---
import SiteLayout from "../layouts/SiteLayout.astro";
import * as cheerio from 'cheerio';

const schema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": "Cadence Design Systems (CDNS) Intrinsic Value: A DCF Analysis",
  "description": "A transparent, step-by-step discounted cash flow valuation of Cadence Design Systems. Using actual recent financials to arrive at a single fair value estimate for CDNS shares.",
  "datePublished": "2026-03-18",
  "dateModified": "2026-03-18",
  "author": {
    "@type": "Organization",
    "name": "Westmount Research",
    "url": "https://westmountfundamentals.com"
  },
  "publisher": {
    "@type": "Organization",
    "name": "Westmount Research",
    "url": "https://westmountfundamentals.com"
  },
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": "https://westmountfundamentals.com/cadence-intrinsic-value"
  }
};

export const meta = {
  title: "Cadence Design Systems (CDNS) Intrinsic Value: A DCF Analysis",
  description: "We ran a full discounted cash flow on Cadence using actuals. One number. Every assumption disclosed. Here's what CDNS is really worth.",
  category: "study",
  published: "2026-03-18",
};

/* ═══════════════════════════════════════════════════════════════
   DATA FETCHING
   ═══════════════════════════════════════════════════════════════ */
async function fetchHTML(url) {
    try {
        const response = await fetch(url, {
            headers: {
                'User-Agent': 'Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36'
            }
        });
        if (!response.ok) return null;
        return await response.text();
    } catch (e) {
        return null;
    }
}

const finHtml = await fetchHTML('https://stockanalysis.com/stocks/cdns/financials/') || '';
const cfHtml = await fetchHTML('https://stockanalysis.com/stocks/cdns/financials/cash-flow-statement/') || '';
const bsHtml = await fetchHTML('https://stockanalysis.com/stocks/cdns/financials/balance-sheet/') || '';

const extractRow = (html, rowName) => {
    if (!html) return null;
    const $ = cheerio.load(html);
    let data = [];
    let found = false;
    $('table tbody tr').each((i, el) => {
        const firstCell = $(el).find('td').first().text().trim();
        if (!found && firstCell === rowName) {
            found = true;
            $(el).find('td').slice(1).each((j, td) => {
                let val = $(td).text().trim().replace(/,/g, '');
                if (val === '-' || val === '') data.push(null);
                else data.push(parseFloat(val));
            });
        }
    });
    return data.length ? data : null;
};

const currentPriceMatch = finHtml.match(/<div class="[^"]*text-4xl[^"]*"[^>]*>([\d\.,]+)<\/div>/);
let currentPrice = currentPriceMatch ? parseFloat(currentPriceMatch[1].replace(/,/g, '')) : null;

let revenueData = extractRow(finHtml, 'Revenue');
let fcfData = extractRow(cfHtml, 'Free Cash Flow');
let epsData = extractRow(finHtml, 'EPS (Diluted)');
let opIncomeData = extractRow(finHtml, 'Operating Income');
let sharesData = extractRow(finHtml, 'Shares Outstanding (Diluted)');
let netIncomeData = extractRow(finHtml, 'Net Income');
let opCashFlowData = extractRow(cfHtml, 'Operating Cash Flow');
let cashData = extractRow(bsHtml, 'Cash & Equivalents');
let debtData = extractRow(bsHtml, 'Total Debt');

// Failsafes using latest known data
if (!currentPrice) currentPrice = 289.64;

// All in millions USD except EPS
const sharesOutstanding = (sharesData && sharesData[0] !== null) ? sharesData[0] : 273;
const cashAndInvestments = (cashData && cashData[0] !== null) ? cashData[0] : 3001;
const totalDebt = (debtData && debtData[0] !== null) ? debtData[0] : 2480;
const netCash = cashAndInvestments - totalDebt;

const fcfCurrent = (fcfData && fcfData[0] !== null) ? fcfData[0] : 1587;
const revCurrent = (revenueData && revenueData[0] !== null) ? revenueData[0] : 5297;
const opIncomeCurrent = (opIncomeData && opIncomeData[0] !== null) ? opIncomeData[0] : 1492;
const epsCurrent = (epsData && epsData[0] !== null) ? epsData[0] : 4.06;

/* ═══════════════════════════════════════════════════════════════
   DCF MODEL — ALL INPUTS AND CALCULATIONS
   We use a two-stage DCF: high-growth phase (Years 1-5) then terminal value.
   ═══════════════════════════════════════════════════════════════ */

// --- ASSUMPTIONS ---
const growthRatePhase1 = 0.15;         // 15% FCF growth, Years 1-5. Electronic design automation (EDA) is essential for AI chips.
const growthRateTerminal = 0.035;      // 3.5% perpetuity growth (terminal). GDP + pricing power.
const discountRate = 0.095;            // 9.5% WACC. 10Y Treasury is 4.18%, CDNS has a beta around 1.1. Lower debt, stable duopoly.

// --- PHASE 1: PROJECT FCF FOR YEARS 1-5 ---
const projectedFCF = [];
let fcf = fcfCurrent;
for (let yr = 1; yr <= 5; yr++) {
  fcf = fcf * (1 + growthRatePhase1);
  projectedFCF.push({ year: yr, fcf: Math.round(fcf), pvFactor: 1 / Math.pow(1 + discountRate, yr) });
}
projectedFCF.forEach(p => { p.pvFCF = Math.round(p.fcf * p.pvFactor); });

// --- PHASE 2: TERMINAL VALUE (Gordon Growth Model) ---
const fcfYear6 = projectedFCF[4].fcf * (1 + growthRateTerminal);
const terminalValue = Math.round(fcfYear6 / (discountRate - growthRateTerminal));
const pvTerminalValue = Math.round(terminalValue * projectedFCF[4].pvFactor);

// --- ENTERPRISE VALUE ---
const pvPhase1 = projectedFCF.reduce((sum, p) => sum + p.pvFCF, 0);
const enterpriseValue = pvPhase1 + pvTerminalValue;

// --- EQUITY VALUE ---
const equityValue = enterpriseValue + netCash;
const intrinsicValuePerShare = equityValue / sharesOutstanding;
const roundedIV = Math.round(intrinsicValuePerShare * 100) / 100;

// Market comparison
const marginOfSafety = ((roundedIV - currentPrice) / currentPrice * 100).toFixed(1);
const verdictText = roundedIV > currentPrice ? "Undervalued" : "Overvalued";
const verdictColor = roundedIV > currentPrice ? "#10b981" : "#ef4444";

// --- HISTORICAL DATA for charts ---
// Generating 5-year history dynamically (from TTM/latest backwards)
let revenueHistory = [];
let fcfHistory = [];
let epsHistory = [];
let marginHistory = [];

const currentYear = new Date().getFullYear(); // e.g. 2024 or 2025

if (revenueData && fcfData && epsData && opIncomeData && netIncomeData) {
    for (let i = 0; i < 5; i++) {
        if (revenueData[i] !== null && revenueData[i] !== undefined) {
             // Arrays go from newest [0] to oldest
             const rev = revenueData[i];
             const fcfVal = fcfData[i];
             const eps = epsData[i];
             const opInc = opIncomeData[i];
             const netInc = netIncomeData[i];

             // Put newest year at end (so reverse order from scrape)
             revenueHistory.unshift({ year: currentYear - i, value: rev });
             fcfHistory.unshift({ year: currentYear - i, value: fcfVal });
             epsHistory.unshift({ year: currentYear - i, value: eps });

             if (rev > 0 && opInc !== null && netInc !== null && fcfVal !== null) {
                 marginHistory.unshift({
                     year: currentYear - i,
                     operating: ((opInc / rev) * 100).toFixed(1),
                     profit: ((netInc / rev) * 100).toFixed(1),
                     fcfMargin: ((fcfVal / rev) * 100).toFixed(1)
                 });
             }
        }
    }
}

// Fallback logic for historical data if null
if (revenueHistory.length === 0) {
  revenueHistory = [
    { year: currentYear - 4, value: 2988 },
    { year: currentYear - 3, value: 3562 },
    { year: currentYear - 2, value: 4090 },
    { year: currentYear - 1, value: 4641 },
    { year: currentYear, value: 5297 },
  ];
  fcfHistory = [
    { year: currentYear - 4, value: 1036 },
    { year: currentYear - 3, value: 1119 },
    { year: currentYear - 2, value: 1247 },
    { year: currentYear - 1, value: 1118 },
    { year: currentYear, value: 1587 },
  ];
  epsHistory = [
    { year: currentYear - 4, value: 2.50 },
    { year: currentYear - 3, value: 3.09 },
    { year: currentYear - 2, value: 3.82 },
    { year: currentYear - 1, value: 3.85 },
    { year: currentYear, value: 4.06 },
  ];
  marginHistory = [
    { year: currentYear - 4, operating: "26.1", profit: "23.3", fcfMargin: "34.7" },
    { year: currentYear - 3, operating: "30.1", profit: "23.8", fcfMargin: "31.4" },
    { year: currentYear - 2, operating: "30.6", profit: "25.5", fcfMargin: "30.5" },
    { year: currentYear - 1, operating: "29.1", profit: "22.7", fcfMargin: "24.1" },
    { year: currentYear, operating: "28.2", profit: "20.9", fcfMargin: "30.0" },
  ];
}

// Sensitivity analysis
const sensitivityRates = [0.075, 0.085, 0.095, 0.105, 0.115];
const sensitivityGrowth = [0.11, 0.13, 0.15, 0.17, 0.19];
const sensitivityTable = sensitivityRates.map(dr => {
  return {
    dr,
    values: sensitivityGrowth.map(gr => {
      let f = fcfCurrent;
      let pvSum = 0;
      for (let y = 1; y <= 5; y++) {
        f = f * (1 + gr);
        pvSum += f / Math.pow(1 + dr, y);
      }
      const f6 = f * (1 + growthRateTerminal);
      const tv = f6 / (dr - growthRateTerminal);
      const pvTV = tv / Math.pow(1 + dr, 5);
      return Math.round((pvSum + pvTV + netCash) / sharesOutstanding);
    })
  };
});
