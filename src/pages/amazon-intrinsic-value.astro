---
import SiteLayout from "../layouts/SiteLayout.astro";

// --- METADATA ---
export const meta = {
  title: "Amazon.com, Inc. (AMZN) Intrinsic Value",
  description: "An independent discounted cash flow (DCF) intrinsic value analysis of Amazon.com, Inc. (AMZN) compiled entirely by Gemini 2.5 Pro.",
  category: "study",
  published: "2026-03-18",
};

// --- DATA & ASSUMPTIONS (FY2025 Actuals) ---
// The prompt requires me to make bold assumptions as Gemini.
// FCF Growth (Y1-Y5): 18%. Amazon is highly optimizing its fulfillment network and reaping incredible margins from AWS as AI workloads scale massively. FCF is exploding.
// Discount Rate (WACC): 8.8%. Amazon's immense competitive moat, diversified revenue streams, and solid credit profile warrant a slightly lower WACC despite higher interest rates. It balances a 4.18% risk-free rate, ~1.15 beta, and a ~4.5% ERP.
// Terminal Growth: 4.0%. Amazon is woven into the fabric of the global economy (commerce and compute). 4.0% reflects sustained GDP+ growth as cloud and logistics moats become impenetrable.

const baseFCF = 7695; // In millions (2025 FCF)
const sharesOut = 10734; // In millions
const currentPrice = 211.56;
const netCash = -55518; // Net debt in millions (Cash - Total Debt)

const fcfGrowthRate = 0.18;
const discountRate = 0.088;
const terminalGrowthRate = 0.040;

// --- YEAR 1 TO 5 PROJECTIONS ---
const projections = [];
let prevFCF = baseFCF;

for (let i = 1; i <= 5; i++) {
  const projectedFCF = prevFCF * (1 + fcfGrowthRate);
  const discountFactor = Math.pow(1 + discountRate, i);
  const pvOfFCF = projectedFCF / discountFactor;

  projections.push({
    year: `Year ${i}`,
    fcf: projectedFCF,
    pv: pvOfFCF
  });

  prevFCF = projectedFCF;
}

const sumPvFcf = projections.reduce((sum, p) => sum + p.pv, 0);

// --- TERMINAL VALUE ---
const year5FCF = projections[4].fcf;
const terminalValue = (year5FCF * (1 + terminalGrowthRate)) / (discountRate - terminalGrowthRate);
const pvTerminalValue = terminalValue / Math.pow(1 + discountRate, 5);

// --- INTRINSIC VALUE CALCULATION ---
const enterpriseValue = sumPvFcf + pvTerminalValue;
const totalEquityValue = enterpriseValue + netCash;
const intrinsicValuePerShare = totalEquityValue / sharesOut;

// Value vs Current Price
const marginOfSafety = ((intrinsicValuePerShare - currentPrice) / currentPrice) * 100;
const isUndervalued = intrinsicValuePerShare > currentPrice;

// --- SENSITIVITY MATRIX ---
const sensitivityDiscountRates = [0.078, 0.083, 0.088, 0.093, 0.098];
const sensitivityGrowthRates = [0.030, 0.035, 0.040, 0.045, 0.050];

const sensitivityMatrix = sensitivityGrowthRates.map(g => {
  return {
    growthRate: g,
    values: sensitivityDiscountRates.map(d => {
      // Re-calculate TV and PV with new rates
      const currentTerminalValue = (year5FCF * (1 + g)) / (d - g);
      const currentPvTerminalValue = currentTerminalValue / Math.pow(1 + d, 5);

      // Re-calculate PV of FCFs with new discount rate
      let currentSumPvFcf = 0;
      let tempFcf = baseFCF;
      for (let i = 1; i <= 5; i++) {
        tempFcf = tempFcf * (1 + fcfGrowthRate);
        currentSumPvFcf += tempFcf / Math.pow(1 + d, i);
      }

      const currentEV = currentSumPvFcf + currentPvTerminalValue;
      const currentEquity = currentEV + netCash;
      const currentIV = currentEquity / sharesOut;

      return currentIV;
    })
  };
});

// Formatting helpers
const formatMoney = (val) => new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD', minimumFractionDigits: 2, maximumFractionDigits: 2 }).format(val);
const formatMillions = (val) => '$' + new Intl.NumberFormat('en-US', { maximumFractionDigits: 0 }).format(val) + 'M';
const formatPercent = (val) => (val * 100).toFixed(1) + '%';

// --- SCHEMA ---
const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Article",
      "headline": meta.title,
      "description": meta.description,
      "author": {
        "@type": "Organization",
        "name": "Gemini 2.5 Pro"
      },
      "publisher": {
        "@type": "Organization",
        "name": "Westmount Fundamentals",
        "logo": {
          "@type": "ImageObject",
          "url": "https://westmountfundamentals.com/logo.png"
        }
      },
      "mainEntityOfPage": {
        "@type": "WebPage",
        "@id": "https://westmountfundamentals.com/amazon-intrinsic-value"
      }
    },
    {
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "Why did Gemini pick an 18% growth rate for Amazon?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Gemini projects an 18% Free Cash Flow growth rate because Amazon's high-margin AWS business is scaling massively with AI workloads, and its massive investments in regionalizing its fulfillment network are significantly reducing cost-to-serve, unlocking unprecedented cash generation."
          }
        },
        {
          "@type": "Question",
          "name": "What discount rate was used for Amazon's DCF?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "An 8.8% discount rate was selected. This reflects Amazon's entrenched economic moat, diversified revenue streams across commerce and cloud, and a 4.18% risk-free rate."
          }
        },
        {
          "@type": "Question",
          "name": "Why is Amazon's terminal growth rate set at 4.0%?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "A 4.0% terminal growth rate reflects that Amazon's cloud and logistics infrastructure are fundamentally woven into the global economy, allowing it to sustain growth slightly above standard GDP rates in perpetuity."
          }
        }
      ]
    }
  ]
};
---
<SiteLayout site="westmount" title={meta.title} description={meta.description} canonical="https://westmountfundamentals.com/amazon-intrinsic-value" schema={schema}>
  <div class="page-content">
    <div class="container">

      <div class="gemini-header">
        <div class="gemini-badge">COMPILED BY GEMINI 2.5 PRO</div>
        <h1>Amazon.com, Inc. (AMZN) Intrinsic Value</h1>
        <p class="subtitle">An independent two-stage DCF analysis by a frontier AI model.</p>
      </div>

      <div class="verdict-card">
        <div class="verdict-header">
          <h2>Fair Value Estimate</h2>
        </div>
        <div class="verdict-body">
          <div class="verdict-main">
            <span class="iv-value">{formatMoney(intrinsicValuePerShare)}</span>
            <span class="iv-label">per share</span>
          </div>
          <div class="verdict-stats">
            <div class="stat">
              <span class="stat-label">Current Price</span>
              <span class="stat-value">{formatMoney(currentPrice)}</span>
            </div>
            <div class="stat">
              <span class="stat-label">Margin of Safety</span>
              <span class={`stat-value ${isUndervalued ? 'positive' : 'negative'}`}>
                {isUndervalued ? '+' : ''}{marginOfSafety.toFixed(2)}%
              </span>
            </div>
            <div class="stat">
              <span class="stat-label">Verdict</span>
              <span class={`badge ${isUndervalued ? 'positive' : 'negative'}`}>
                {isUndervalued ? 'UNDERVALUED' : 'OVERVALUED'}
              </span>
            </div>
          </div>
        </div>
        <div class="verdict-footer">
          <p>Based on FY2025 actuals. Data via S&P Global (Mar 18, 2026).</p>
        </div>
      </div>

      <section class="content-section">
        <h2>The AI Thesis: The Everything Engine Runs on Cash</h2>
        <p>Amazon (AMZN) is a beast of two worlds: global retail logistics and enterprise cloud infrastructure (AWS). After years of massive capital expenditures to double its fulfillment network and build out data centers, the company is shifting from an investment phase to a <strong>harvesting phase</strong>.</p>
        <p>While the retail business operates on razor-thin margins, its sheer volume provides the float. AWS, on the other hand, is a high-margin money printer. With the explosion of generative AI workloads, AWS is positioned to dominate the foundational compute layer. The combination of regionalizing its U.S. fulfillment network (slashing costs to serve) and accelerating AWS revenue translates to an explosive inflection point in Free Cash Flow (FCF). The market hasn't fully digested the scale of this cash generation machine.</p>
      </section>

      <section class="content-section">
        <h2>My Assumptions & Rationale</h2>

        <div class="assumption-grid">
          <div class="assumption-card">
            <div class="card-title">FCF Growth Rate (Y1-Y5)</div>
            <div class="card-value">{formatPercent(fcfGrowthRate)}</div>
            <p><strong>Rationale:</strong> 18% is a bold projection for a company of this size, but Amazon's FCF is deeply leveraged to its highest-margin businesses: AWS and Advertising. As AI workloads scale exponentially, AWS margins will expand. Simultaneously, cost efficiencies in logistics are dropping straight to the bottom line. This represents a structural shift in their cash conversion cycle.</p>
          </div>

          <div class="assumption-card">
            <div class="card-title">Discount Rate (WACC)</div>
            <div class="card-value">{formatPercent(discountRate)}</div>
            <p><strong>Rationale:</strong> An 8.8% discount rate reflects Amazon's unique position. While it operates in competitive markets, its infrastructure (both digital and physical) constitutes an almost insurmountable moat. Factoring in a 4.18% risk-free rate, a beta of ~1.15, and the company's massive scale, the risk of permanent capital impairment is remarkably low.</p>
          </div>

          <div class="assumption-card">
            <div class="card-title">Terminal Growth Rate</div>
            <div class="card-value">{formatPercent(terminalGrowthRate)}</div>
            <p><strong>Rationale:</strong> A 4.0% terminal growth rate assumes Amazon grows slightly faster than global GDP in perpetuity. Because AWS and Amazon Logistics are increasingly becoming the default operating systems for the modern digital and physical economies, they command long-term pricing power and structural growth advantages.</p>
          </div>
        </div>
      </section>

      <section class="content-section">
        <h2>Discounted Cash Flow (DCF) Projections</h2>
        <p>Starting with the FY2025 base FCF of {formatMillions(baseFCF)}, the table below outlines the 5-year projection discounted back to Present Value (PV) using the {formatPercent(discountRate)} WACC.</p>

        <div class="table-container">
          <table>
            <thead>
              <tr>
                <th>Period</th>
                <th>Projected FCF</th>
                <th>PV Factor ({formatPercent(discountRate)})</th>
                <th>Present Value</th>
              </tr>
            </thead>
            <tbody>
              {projections.map((p, index) => (
                <tr>
                  <td>{p.year}</td>
                  <td>{formatMillions(p.fcf)}</td>
                  <td>{(1 / Math.pow(1 + discountRate, index + 1)).toFixed(4)}</td>
                  <td>{formatMillions(p.pv)}</td>
                </tr>
              ))}
              <tr class="highlight-row">
                <td colspan="3"><strong>Sum of PV of FCFs (Years 1-5)</strong></td>
                <td><strong>{formatMillions(sumPvFcf)}</strong></td>
              </tr>
            </tbody>
          </table>
        </div>
      </section>

      <section class="content-section">
        <h2>Terminal & Final Valuation Math</h2>
        <p>The Terminal Value captures the immense ongoing cash generation of Amazon from Year 6 into perpetuity, calculated using the Gordon Growth Model.</p>

        <div class="math-card">
          <div class="math-row">
            <span>Year 5 FCF</span>
            <span>{formatMillions(year5FCF)}</span>
          </div>
          <div class="math-row">
            <span>Terminal Value (TV) Calculation</span>
            <span>({formatMillions(year5FCF)} * {1 + terminalGrowthRate}) / ({discountRate} - {terminalGrowthRate})</span>
          </div>
          <div class="math-row">
            <span>Terminal Value</span>
            <span>{formatMillions(terminalValue)}</span>
          </div>
          <div class="math-row highlight">
            <span>PV of Terminal Value</span>
            <span>{formatMillions(pvTerminalValue)}</span>
          </div>
        </div>

        <p style="margin-top: 2rem;">Consolidating the present values and adjusting for Amazon's net debt position:</p>

        <div class="math-card">
          <div class="math-row">
            <span>Sum of PV of FCFs (Years 1-5)</span>
            <span>{formatMillions(sumPvFcf)}</span>
          </div>
          <div class="math-row">
            <span>+ PV of Terminal Value</span>
            <span>{formatMillions(pvTerminalValue)}</span>
          </div>
          <div class="math-row">
            <span><strong>= Enterprise Value</strong></span>
            <span><strong>{formatMillions(enterpriseValue)}</strong></span>
          </div>
          <div class="math-row">
            <span>+ Net Cash (Cash - Debt)</span>
            <span>{formatMillions(netCash)}</span>
          </div>
          <div class="math-row highlight">
            <span><strong>= Total Equity Value</strong></span>
            <span><strong>{formatMillions(totalEquityValue)}</strong></span>
          </div>
          <div class="math-row">
            <span>÷ Shares Outstanding</span>
            <span>{sharesOut.toLocaleString()}M</span>
          </div>
          <div class="math-row result">
            <span><strong>Intrinsic Value Per Share</strong></span>
            <span><strong>{formatMoney(intrinsicValuePerShare)}</strong></span>
          </div>
        </div>
      </section>

      <section class="content-section">
        <h2>Sensitivity Matrix</h2>
        <p>Given the scale of Amazon's cash flows, small changes in the WACC or Terminal Growth Rate have massive implications. The matrix below highlights valuation variance across different assumptions.</p>

        <div class="table-container sensitivity-table">
          <table>
            <thead>
              <tr>
                <th rowspan="2" class="corner-cell">Terminal<br/>Growth</th>
                <th colspan="5" class="header-cell">Discount Rate (WACC)</th>
              </tr>
              <tr>
                {sensitivityDiscountRates.map(d => <th>{formatPercent(d)}</th>)}
              </tr>
            </thead>
            <tbody>
              {sensitivityMatrix.map(row => (
                <tr>
                  <th class="row-header">{formatPercent(row.growthRate)}</th>
                  {row.values.map(val => (
                    <td class={
                      val > currentPrice * 1.15 ? "cell-undervalued" :
                      val < currentPrice * 0.85 ? "cell-overvalued" :
                      "cell-neutral"
                    }>
                      {formatMoney(val)}
                    </td>
                  ))}
                </tr>
              ))}
            </tbody>
          </table>
          <div class="matrix-legend">
            <span class="legend-item"><span class="color-box cell-undervalued"></span> Undervalued (>15% Margin)</span>
            <span class="legend-item"><span class="color-box cell-neutral"></span> Fair Value</span>
            <span class="legend-item"><span class="color-box cell-overvalued"></span> Overvalued (&lt;-15% Margin)</span>
          </div>
        </div>
      </section>

      <section class="content-section risks-section">
        <h2>Key Risks & Bear Case</h2>
        <p>Even a dominant player like Amazon is exposed to systemic and operational risks that could derail this valuation:</p>
        <div class="risk-grid">
          <div class="risk-card">
            <h3>1. AWS Growth Deceleration</h3>
            <p>If Microsoft Azure or Google Cloud aggressively undercut AWS on pricing, or if the anticipated AI workload boom fails to materialize at the projected scale, Amazon's highest-margin engine will sputter, radically altering the FCF trajectory.</p>
          </div>
          <div class="risk-card">
            <h3>2. Regulatory and Antitrust Action</h3>
            <p>Amazon faces persistent scrutiny regarding monopolistic practices in its e-commerce marketplace. Significant regulatory intervention could force structural changes or breakups, damaging its integrated business model.</p>
          </div>
          <div class="risk-card">
            <h3>3. Consumer Spending Contraction</h3>
            <p>A prolonged macroeconomic downturn or recession would directly impact retail sales. While AWS provides a buffer, Amazon's vast fulfillment infrastructure still requires massive volume to maintain profitability.</p>
          </div>
        </div>
      </section>

      <section class="content-section faq-section">
        <h2>Frequently Asked Questions</h2>

        <div class="faq-item">
          <h3>Why did Gemini pick an 18% growth rate for Amazon?</h3>
          <p>Gemini projects an 18% Free Cash Flow growth rate because Amazon's high-margin AWS business is scaling massively with AI workloads, and its massive investments in regionalizing its fulfillment network are significantly reducing cost-to-serve, unlocking unprecedented cash generation.</p>
        </div>

        <div class="faq-item">
          <h3>What discount rate was used for Amazon's DCF?</h3>
          <p>An 8.8% discount rate was selected. This reflects Amazon's entrenched economic moat, diversified revenue streams across commerce and cloud, and a 4.18% risk-free rate.</p>
        </div>

        <div class="faq-item">
          <h3>Why is Amazon's terminal growth rate set at 4.0%?</h3>
          <p>A 4.0% terminal growth rate reflects that Amazon's cloud and logistics infrastructure are fundamentally woven into the global economy, allowing it to sustain growth slightly above standard GDP rates in perpetuity.</p>
        </div>
      </section>

      <div class="disclaimer-box">
        <p><strong>Disclaimer:</strong> The numbers presented on this page are for educational and entertainment purposes only. They are the result of a deterministic mathematical model fed with assumptions generated by an Artificial Intelligence (Gemini 2.5 Pro). This does not constitute investment advice. Always conduct your own due diligence before investing in the stock market.</p>
      </div>

    </div>
  </div>
</SiteLayout>
