---
import SiteLayout from "../layouts/SiteLayout.astro";

const schema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": "Analog Devices (ADI) Intrinsic Value: A DCF Analysis",
  "description": "A transparent, step-by-step discounted cash flow valuation of Analog Devices, Inc. Using actual financials to arrive at a single fair value estimate for ADI shares.",
  "datePublished": "2026-03-18",
  "dateModified": "2026-03-18",
  "author": {
    "@type": "Organization",
    "name": "Westmount Research",
    "url": "https://westmountfundamentals.com"
  },
  "publisher": {
    "@type": "Organization",
    "name": "Westmount Research",
    "url": "https://westmountfundamentals.com"
  },
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": "https://westmountfundamentals.com/analog-devices-intrinsic-value"
  }
};

export const meta = {
  title: "Analog Devices (ADI) Intrinsic Value: A DCF Analysis",
  description: "We ran a full discounted cash flow on Analog Devices. One number. Every assumption disclosed. Here's what ADI is really worth.",
  category: "study",
  published: "2026-03-18",
};

/* ═══════════════════════════════════════════════════════════════
   DATA FETCHING
   ═══════════════════════════════════════════════════════════════ */
let revenueHistory = [];
let fcfHistory = [];
let epsHistory = [];
let marginHistory = [];

let fcf2025 = null;
let sharesOutstanding = null;
let cashAndInvestments = null;
let totalDebt = null;
let revenueCurrent = null;
let epsCurrent = null;
let operatingMarginCurrent = null;

try {
  const headers = { 'User-Agent': 'Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36' };

  const [finHtml, bsHtml] = await Promise.all([
    fetch('https://stockanalysis.com/stocks/adi/financials/', { headers }).then(r => r.text()),
    fetch('https://stockanalysis.com/stocks/adi/financials/balance-sheet/', { headers }).then(r => r.text())
  ]);

  const matchFin = finHtml.match(/financialData:(\{.*?\})/);
  if (matchFin) {
    const data = eval('(' + matchFin[1] + ')');
    fcf2025 = data.fcf[0];
    sharesOutstanding = data.sharesDiluted[0];
    revenueCurrent = data.revenue[0];
    epsCurrent = data.epsDiluted[0];
    operatingMarginCurrent = data.operatingMargin[0] * 100;

    // Reverse arrays to get chronological order for charts
    for (let i = 4; i >= 0; i--) {
      if (data.fiscalYear[i]) {
        revenueHistory.push({ year: data.fiscalYear[i], value: data.revenue[i] });
        fcfHistory.push({ year: data.fiscalYear[i], value: data.fcf[i] });
        epsHistory.push({ year: data.fiscalYear[i], value: data.epsDiluted[i] });
        marginHistory.push({
          year: data.fiscalYear[i],
          operating: (data.operatingMargin[i] * 100).toFixed(1),
          profit: (data.profitMargin[i] * 100).toFixed(1),
          fcfMargin: (data.fcfMargin[i] * 100).toFixed(1)
        });
      }
    }
  }

  const matchBs = bsHtml.match(/financialData:(\{.*?\})/);
  if (matchBs) {
    const bsData = eval('(' + matchBs[1] + ')');
    cashAndInvestments = bsData.totalcash[0];
    totalDebt = bsData.debt[0];
  }

} catch (e) {
  console.error("Error fetching ADI data:", e);
}


if (sharesOutstanding !== null && sharesOutstanding > 100000) {
  sharesOutstanding = sharesOutstanding / 1000000;
}
if (cashAndInvestments !== null) cashAndInvestments = cashAndInvestments / 1000000;
if (totalDebt !== null) totalDebt = totalDebt / 1000000;
if (revenueCurrent !== null) revenueCurrent = revenueCurrent / 1000000;
if (fcf2025 !== null) fcf2025 = fcf2025 / 1000000;



const netCash = (cashAndInvestments !== null && totalDebt !== null) ? cashAndInvestments - totalDebt : null;

/* ═══════════════════════════════════════════════════════════════
   DCF MODEL — ALL INPUTS AND CALCULATIONS
   ═══════════════════════════════════════════════════════════════ */
// --- ASSUMPTIONS ---
const growthRatePhase1 = 0.08;         // 8% FCF growth, Years 1-5
const growthRateTerminal = 0.03;       // 3% perpetuity growth (terminal)
const discountRate = 0.09;             // 9% WACC / required return

let projectedFCF = [];
let fcfYear6 = null;
let terminalValue = null;
let pvTerminalValue = null;
let enterpriseValue = null;
let pvPhase1 = null;
let equityValue = null;
let intrinsicValuePerShare = null;
let roundedIV = null;
let marginOfSafety = null;

const currentPrice = 185.00;

if (fcf2025 !== null && sharesOutstanding !== null && netCash !== null) {
  // --- PHASE 1: PROJECT FCF FOR YEARS 1-5 ---
  let fcf = fcf2025;
  for (let yr = 1; yr <= 5; yr++) {
    fcf = fcf * (1 + growthRatePhase1);
    projectedFCF.push({ year: yr, fcf: Math.round(fcf), pvFactor: 1 / Math.pow(1 + discountRate, yr) });
  }
  projectedFCF.forEach(p => { p.pvFCF = Math.round(p.fcf * p.pvFactor); });

  // --- PHASE 2: TERMINAL VALUE (Gordon Growth Model) ---
  fcfYear6 = projectedFCF[4].fcf * (1 + growthRateTerminal);
  terminalValue = Math.round(fcfYear6 / (discountRate - growthRateTerminal));
  pvTerminalValue = Math.round(terminalValue * projectedFCF[4].pvFactor);

  // --- ENTERPRISE VALUE ---
  pvPhase1 = projectedFCF.reduce((sum, p) => sum + p.pvFCF, 0);
  enterpriseValue = pvPhase1 + pvTerminalValue;

  // --- EQUITY VALUE ---
  equityValue = enterpriseValue + netCash;
  intrinsicValuePerShare = equityValue / sharesOutstanding;
  roundedIV = Math.round(intrinsicValuePerShare * 100) / 100;

  // Market comparison
  marginOfSafety = ((roundedIV - currentPrice) / currentPrice * 100).toFixed(1);
}
const verdictText = roundedIV > currentPrice ? "Undervalued" : "Overvalued";
const verdictColor = roundedIV > currentPrice ? "#10b981" : "#ef4444";

// Sensitivity analysis
const sensitivityRates = [0.07, 0.08, 0.09, 0.10, 0.11];
const sensitivityGrowth = [0.04, 0.06, 0.08, 0.10, 0.12];
const sensitivityTable = sensitivityRates.map(dr => {
  return {
    dr,
    values: sensitivityGrowth.map(gr => {
      let f = fcf2025;
      let pvSum = 0;
      for (let y = 1; y <= 5; y++) {
        f = f * (1 + gr);
        pvSum += f / Math.pow(1 + dr, y);
      }
      const f6 = f * (1 + growthRateTerminal);
      const tv = f6 / (dr - growthRateTerminal);
      const pvTV = tv / Math.pow(1 + dr, 5);
      return Math.round((pvSum + pvTV + netCash) / sharesOutstanding);
    })
  };
});
