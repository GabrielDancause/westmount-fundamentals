    .strat-card.bear-strat h3 { color:#ef4444; }

    /* Insights */
    .insight-list { list-style:none; padding:0; }
    .insight-list li { background:rgba(74,143,231,0.06); border-left:3px solid #4a8fe7; padding:0.75rem 1rem; margin-bottom:0.75rem; border-radius:0 8px 8px 0; }

    /* FAQ */
    .faq-item { border:1px solid #30363d; border-radius:10px; margin-bottom:0.75rem; overflow:hidden; }
    .faq-q { background:rgba(255,255,255,0.03); padding:1rem 1.25rem; cursor:pointer; color:#e8eaed; font-weight:600; font-size:1rem; display:flex; justify-content:space-between; align-items:center; }
    .faq-q::after { content:'+'; font-size:1.3rem; color:#4a8fe7; transition:transform 0.2s; }
    .faq-q.open::after { content:'\2212'; }
