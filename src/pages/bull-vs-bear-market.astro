        <!-- Yellow zone: 10-20% (middle) -->
        <path d="M 60 32 A 80 80 0 0 1 140 32" fill="none" stroke="#eab308" stroke-width="14" opacity="0.3"/>
        <!-- Red zone: 20%+ (right) -->
