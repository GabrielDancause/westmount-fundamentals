    }
    .has-prefix input { padding-left: 28px; }
    .has-suffix input { padding-right: 28px; }
    input:focus {
      outline: none;
      border-color: var(--accent-color);
    }

    button {
      width: 100%;
      background: var(--accent-color);
      color: #fff;
      border: none;
      padding: 12px;
      border-radius: 6px;
      font-weight: 700;
      font-size: 1rem;
