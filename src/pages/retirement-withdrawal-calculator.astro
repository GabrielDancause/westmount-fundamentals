      transition: background 0.2s;
      margin-top: 8px;
    }
    button:hover { background: #3a7bc2; }

    /* Stats Cards Row */
    .stats-row {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 16px;
      margin-bottom: 24px;
    }
