<script is:inline>
  document.addEventListener("DOMContentLoaded", () => {
    function calculateDRIP() {
      const initialInvestmentInput = document.getElementById("initialInvestment");
      const annualContributionInput = document.getElementById("annualContribution");
      const dividendYieldInput = document.getElementById("dividendYield");
      const stockGrowthInput = document.getElementById("stockGrowth");
      const yearsInput = document.getElementById("years");

      if (!initialInvestmentInput || !annualContributionInput || !dividendYieldInput || !stockGrowthInput || !yearsInput) {
        return;
      }

      const initialInvestment = parseFloat(initialInvestmentInput.value) || 0;
      const annualContribution = parseFloat(annualContributionInput.value) || 0;
      const dividendYield = (parseFloat(dividendYieldInput.value) || 0) / 100;
      const stockGrowth = (parseFloat(stockGrowthInput.value) || 0) / 100;
      const years = parseInt(yearsInput.value) || 0;

      if (initialInvestment < 0 || annualContribution < 0 || years < 0) {
        return;
      }

      function simulate(reinvest) {
        let stockPrice = 100.0;
        let shares = initialInvestment / stockPrice;
        let cash = 0.0;
        let totalInvested = initialInvestment;
        let totalDividends = 0.0;

        const monthlyContribution = annualContribution / 12.0;

        for (let y = 1; y <= years; y++) {
          for (let m = 1; m <= 12; m++) {
            // End of month contributions
            if (monthlyContribution > 0) {
              shares += monthlyContribution / stockPrice;
              totalInvested += monthlyContribution;
            }

            // Quarterly dividends (months 3, 6, 9, 12)
            if (m % 3 === 0) {
              // Yield is annual, so divide by 4 for quarterly
              const dividendPayout = shares * stockPrice * (dividendYield / 4);
              totalDividends += dividendPayout;

              if (reinvest) {
                shares += dividendPayout / stockPrice;
              } else {
                cash += dividendPayout;
              }
            }

            // Monthly stock price appreciation
            // stockPrice *= (1 + stockGrowth / 12) would approximate it.
            // Using exact equivalent monthly rate:
            stockPrice *= Math.pow(1 + stockGrowth, 1 / 12);
          }
        }

        const totalValue = (shares * stockPrice) + cash;
        // Total Profit includes the cash retained if not DRIPped, plus capital appreciation.
        const totalProfit = totalValue - totalInvested;

        return { totalValue, totalProfit, totalDividends, totalInvested };
      }

      const dripData = simulate(true);
      const noDripData = simulate(false);

      const formatCurrency = (val) => {
        return new Intl.NumberFormat('en-US', {
          style: 'currency',
          currency: 'USD',
          maximumFractionDigits: 0
        }).format(val);
      };

      // Update Cards
      document.getElementById("cardTotalValue").textContent = formatCurrency(dripData.totalValue);
      document.getElementById("cardTotalInvested").textContent = formatCurrency(dripData.totalInvested);
      document.getElementById("cardTotalDividends").textContent = formatCurrency(dripData.totalDividends);
      document.getElementById("cardTotalProfit").textContent = formatCurrency(dripData.totalProfit);

      // Update Table DRIP
      document.getElementById("dripTotalValue").textContent = formatCurrency(dripData.totalValue);
      document.getElementById("dripTotalDividends").textContent = formatCurrency(dripData.totalDividends);
      document.getElementById("dripTotalProfit").textContent = formatCurrency(dripData.totalProfit);

      // Update Table Non-DRIP
      document.getElementById("noDripTotalValue").textContent = formatCurrency(noDripData.totalValue);
      document.getElementById("noDripTotalDividends").textContent = formatCurrency(noDripData.totalDividends);
      document.getElementById("noDripTotalProfit").textContent = formatCurrency(noDripData.totalProfit);
    }

    const inputs = document.querySelectorAll(".calc-input");
    inputs.forEach(input => {
      input.addEventListener("input", calculateDRIP);
    });

    // Run initial calculation
    calculateDRIP();
  });
</script>
