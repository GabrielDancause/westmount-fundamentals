---
import SiteLayout from "../layouts/SiteLayout.astro";

const schema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "how to build emergency fund",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "To build an emergency fund, start by calculating your essential monthly expenses. Aim to save enough to cover 3 to 6 months of these expenses. Set up automated transfers from your checking account to a separate, high-yield savings account or money market fund to build your balance over time."
      }
    },
    {
      "@type": "Question",
      "name": "emergency fund how much",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Most financial experts recommend saving an emergency fund equal to 3 to 6 months of essential living expenses. If your income is highly stable, 3 months may suffice. If you have dependents, variable income, or work in a volatile industry, lean towards 6 months or more."
      }
    },
    {
      "@type": "Question",
      "name": "where to keep emergency fund",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Keep your emergency fund in highly liquid, low-risk accounts. The best options are High-Yield Savings Accounts (HYSAs), Money Market Accounts, short-term Certificates of Deposit (CDs), or short-term Treasury ETFs (like T-bills), which offer safety and a competitive yield."
      }
    },
    {
      "@type": "Question",
      "name": "3 vs 6 months emergency fund",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "A 3-month emergency fund is ideal for single renters with highly stable jobs. A 6-month fund is better for homeowners, parents, business owners, or those with single-income households to protect against extended periods of unemployment or major unexpected expenses."
      }
    },
    {
      "@type": "Question",
      "name": "emergency fund calculator",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "An emergency fund calculator helps you determine your target savings amount by multiplying your monthly 'needs' (housing, utilities, food, debt minimums, insurance) by your target number of months (typically 3 to 6), excluding discretionary spending."
      }
    }
  ]
};

export const meta = {
  title: "Emergency Fund Guide: How Much to Save & Where",
  description: "Learn how to build a 3-6 month emergency fund, compare high-yield savings accounts (HYSA) vs. T-bills, and find the best place to keep your cash safe.",
  category: "guide",
  published: "2026-03-15",
};
