---
import SiteLayout from "../layouts/SiteLayout.astro";
import * as cheerio from 'cheerio';

const schema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": "Welltower (WELL) Intrinsic Value: A DCF Analysis",
  "description": "A transparent, step-by-step discounted cash flow valuation of Welltower Inc. Using actual FY2025 financials to arrive at a single fair value estimate for WELL shares.",
  "datePublished": "2026-03-18",
  "dateModified": "2026-03-18",
  "author": {
    "@type": "Organization",
    "name": "Westmount Research",
    "url": "https://westmountfundamentals.com"
  },
  "publisher": {
    "@type": "Organization",
    "name": "Westmount Research",
    "url": "https://westmountfundamentals.com"
  },
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": "https://westmountfundamentals.com/welltower-intrinsic-value"
  }
};

export const meta = {
  title: "Welltower (WELL) Intrinsic Value: A DCF Analysis",
  description: "We ran a full discounted cash flow on Welltower using FY2025 actuals. One number. Every assumption disclosed. Here's what Welltower is really worth.",
  category: "study",
  published: "2026-03-18",
};

// --- FETCH DATA FROM STOCKANALYSIS.COM ---
const ticker = 'well';
const baseUrl = `https://stockanalysis.com/stocks/${ticker}`;
const headers = { 'User-Agent': 'Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36' };

let currentPrice = null;
let fcf2025 = null;
let sharesOutstanding = null;
let cashAndInvestments = null;
let totalDebt = null;
let rev2025 = null;
let eps2025 = null;
let opInc2025 = null;

// Historical arrays
const revenueHistory = [];
const fcfHistory = [];
const epsHistory = [];

try {
  // Fetch overview for price
  const resOverview = await fetch(baseUrl, { headers });
  if (resOverview.ok) {
    const htmlOverview = await resOverview.text();
    const $o = cheerio.load(htmlOverview);
    const priceText = $o('div.text-4xl').first().text().trim().replace(/,/g, '');
    if (priceText) currentPrice = parseFloat(priceText);
  }

  // Helper to extract row from cheerio table
  const extractRowData = (html, targetTitle) => {
    const $ = cheerio.load(html);
    let rowData = null;
    $('table tbody tr').each((i, el) => {
      const title = $(el).find('td').first().text().trim();
      if (title === targetTitle) {
        rowData = [];
        $(el).find('td').each((j, td) => {
          if (j > 0) {
            const val = $(td).text().trim().replace(/,/g, '');
            rowData.push(val === '-' ? null : parseFloat(val));
          }
        });
      }
    });
    return rowData;
  };

  // Fetch Financials (Income Statement)
  const resFin = await fetch(`${baseUrl}/financials/`, { headers });
  if (resFin.ok) {
    const htmlFin = await resFin.text();
    const revRow = extractRowData(htmlFin, 'Revenue');
    if (revRow) {
      rev2025 = revRow[0];
      [2025, 2024, 2023, 2022, 2021].forEach((yr, i) => {
        if (revRow[i] !== undefined && revRow[i] !== null) revenueHistory.push({ year: yr, value: revRow[i] });
      });
      revenueHistory.reverse();
    }
    const sharesRow = extractRowData(htmlFin, 'Shares Outstanding (Basic)');
    if (sharesRow) sharesOutstanding = sharesRow[0];
    const epsRow = extractRowData(htmlFin, 'EPS (Diluted)');
    if (epsRow) {
      eps2025 = epsRow[0];
      [2025, 2024, 2023, 2022, 2021].forEach((yr, i) => {
        if (epsRow[i] !== undefined && epsRow[i] !== null) epsHistory.push({ year: yr, value: epsRow[i] });
      });
      epsHistory.reverse();
    }
    const opRow = extractRowData(htmlFin, 'Operating Income');
    if (opRow) opInc2025 = opRow[0];
  }

  // Fetch Cash Flow
  const resCF = await fetch(`${baseUrl}/financials/cash-flow-statement/`, { headers });
  if (resCF.ok) {
    const htmlCF = await resCF.text();
    const fcfRow = extractRowData(htmlCF, 'Free Cash Flow');
    if (fcfRow) {
      fcf2025 = fcfRow[0];
      [2025, 2024, 2023, 2022, 2021].forEach((yr, i) => {
        if (fcfRow[i] !== undefined && fcfRow[i] !== null) fcfHistory.push({ year: yr, value: fcfRow[i] });
      });
      fcfHistory.reverse();
    }
  }

  // Fetch Balance Sheet
  const resBS = await fetch(`${baseUrl}/financials/balance-sheet/`, { headers });
  if (resBS.ok) {
    const htmlBS = await resBS.text();
    const cashRow = extractRowData(htmlBS, 'Cash & Equivalents');
    if (cashRow) cashAndInvestments = cashRow[0];
    const debtRow = extractRowData(htmlBS, 'Total Debt');
    if (debtRow) totalDebt = debtRow[0];
  }

} catch (e) {
  console.error("Error fetching WELL data:", e);
}

// Fallback to null logic handled by variables being initialized to null
// If data is missing, we ensure computations don't break by defaulting or skipping
const netCash = (cashAndInvestments !== null && totalDebt !== null) ? (cashAndInvestments - totalDebt) : 0;

// --- ASSUMPTIONS (fully disclosed below) ---
const growthRatePhase1 = 0.15;         // 15% FCF growth, Years 1-5
const growthRateTerminal = 0.03;       // 3% perpetuity growth (terminal)
const discountRate = 0.09;             // 9% WACC / required return

// --- PHASE 1: PROJECT FCF FOR YEARS 1-5 ---
const projectedFCF = [];
let fcf = fcf2025 || 1360; // Fallback to approx if null, but ideally real
if (fcf2025 !== null) {
  for (let yr = 1; yr <= 5; yr++) {
    fcf = fcf * (1 + growthRatePhase1);
    projectedFCF.push({ year: yr, fcf: Math.round(fcf), pvFactor: 1 / Math.pow(1 + discountRate, yr) });
  }
  projectedFCF.forEach(p => { p.pvFCF = Math.round(p.fcf * p.pvFactor); });
}

// --- PHASE 2: TERMINAL VALUE (Gordon Growth Model) ---
let fcfYear6 = 0;
let terminalValue = 0;
let pvTerminalValue = 0;

if (projectedFCF.length > 0) {
  fcfYear6 = projectedFCF[4].fcf * (1 + growthRateTerminal);
  terminalValue = Math.round(fcfYear6 / (discountRate - growthRateTerminal));
  pvTerminalValue = Math.round(terminalValue * projectedFCF[4].pvFactor);
}

// --- ENTERPRISE VALUE ---
const pvPhase1 = projectedFCF.reduce((sum, p) => sum + p.pvFCF, 0);
const enterpriseValue = pvPhase1 + pvTerminalValue;

// --- EQUITY VALUE ---
const equityValue = enterpriseValue + netCash;
const shares = sharesOutstanding || 666;
const intrinsicValuePerShare = equityValue / shares;
const roundedIV = Math.round(intrinsicValuePerShare * 100) / 100;

// Market comparison
const price = currentPrice || 212.82;
const marginOfSafety = ((roundedIV - price) / price * 100).toFixed(1);
const verdictText = roundedIV > price ? "Undervalued" : "Overvalued";
const verdictColor = roundedIV > price ? "#10b981" : "#ef4444";

// Sensitivity analysis
const sensitivityRates = [0.07, 0.08, 0.09, 0.10, 0.11];
const sensitivityGrowth = [0.11, 0.13, 0.15, 0.17, 0.19];
const sensitivityTable = sensitivityRates.map(dr => {
  return {
    dr,
    values: sensitivityGrowth.map(gr => {
      let f = fcf2025;
      let pvSum = 0;
      if (fcf2025 !== null) {
        for (let y = 1; y <= 5; y++) {
          f = f * (1 + gr);
          pvSum += f / Math.pow(1 + dr, y);
        }
        const f6 = f * (1 + growthRateTerminal);
        const tv = f6 / (dr - growthRateTerminal);
        const pvTV = tv / Math.pow(1 + dr, 5);
        return Math.round((pvSum + pvTV + netCash) / shares);
      }
      return 0;
    })
  };
});
