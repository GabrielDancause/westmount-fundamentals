  <script>
    function initPositionCalculator() {
      const container = document.getElementById('pos-calc-container');
      if (!container || container.dataset.initialized) return;
      container.dataset.initialized = 'true';

      const inputs = {
        account: document.getElementById('account-size'),
        riskPct: document.getElementById('risk-percentage'),
        entry: document.getElementById('entry-price'),
        stop: document.getElementById('stop-loss')
      };

      const outputs = {
        shares: document.getElementById('position-shares'),
        capital: document.getElementById('capital-required'),
        riskAmount: document.getElementById('risk-amount'),
        riskPerShare: document.getElementById('risk-per-share'),
        distance: document.getElementById('distance-to-stop'),
        errorMsg: document.getElementById('error-message')
      };

      const formatCurrency = (val) => new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD' }).format(val);
      const formatNumber = (val) => new Intl.NumberFormat('en-US', { maximumFractionDigits: 2 }).format(val);
      const formatPct = (val) => new Intl.NumberFormat('en-US', { style: 'percent', maximumFractionDigits: 2 }).format(val / 100);

      function calculatePosition() {
        // Reset error state
        outputs.errorMsg.style.display = 'none';
        outputs.errorMsg.textContent = '';

        // Parse inputs
        const account = parseFloat(inputs.account.value) || 0;
        const riskPct = parseFloat(inputs.riskPct.value) || 0;
        const entry = parseFloat(inputs.entry.value) || 0;
        const stop = parseFloat(inputs.stop.value) || 0;

        // Validation
        if (account <= 0 || riskPct <= 0 || entry <= 0 || stop <= 0) {
          showError("All fields must be greater than zero.");
          resetOutputs();
          return;
        }

        if (stop >= entry) {
          showError("Stop loss must be lower than entry price for a long position.");
          resetOutputs();
          return;
        }

        // Calculations
        const riskAmount = account * (riskPct / 100);
        const riskPerShare = entry - stop;
        const shares = riskAmount / riskPerShare;
        const capitalRequired = shares * entry;
        const distancePct = (riskPerShare / entry) * 100;

        // Display results
        outputs.shares.textContent = formatNumber(Math.floor(shares)); // Conventionally round down shares to not exceed risk
        outputs.capital.textContent = formatCurrency(capitalRequired);
        outputs.riskAmount.textContent = formatCurrency(riskAmount);
        outputs.riskPerShare.textContent = formatCurrency(riskPerShare);
        outputs.distance.textContent = formatPct(distancePct);

        // Warning if capital required exceeds account size
        if (capitalRequired > account) {
          outputs.capital.style.color = 'var(--error-color, #ef4444)';
          showError(`Warning: Trade requires ${formatCurrency(capitalRequired)} which exceeds your account balance. You will need leverage/margin.`);
        } else {
          outputs.capital.style.color = 'var(--text-primary)';
        }
      }

      function showError(msg) {
        outputs.errorMsg.textContent = msg;
        outputs.errorMsg.style.display = 'block';
      }

      function resetOutputs() {
        outputs.shares.textContent = '0';
        outputs.capital.textContent = '$0.00';
        outputs.riskAmount.textContent = '$0.00';
        outputs.riskPerShare.textContent = '$0.00';
        outputs.distance.textContent = '0%';
      }

      // Attach event listeners
      Object.values(inputs).forEach(input => {
        if (input) {
          input.addEventListener('input', calculatePosition);
        }
      });

      // Initial calculation
      calculatePosition();
    }

    document.addEventListener('DOMContentLoaded', initPositionCalculator);
    document.addEventListener('astro:page-load', initPositionCalculator);
  </script>
