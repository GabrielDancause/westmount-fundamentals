        function escapeHTML(str) {
            if (!str) return '';
            return String(str)
                .replace(/&/g, '&amp;')
                .replace(/</g, '<')
                .replace(/>/g, '>')
                .replace(/"/g, '&quot;')
                .replace(/'/g, '&#39;');
        }

        function formatVal(val, isPct = true) {
            if (val === null || val === undefined) return '<span class="neutral">N/A</span>';
            const num = parseFloat(val);
            const str = num.toFixed(2) + (isPct ? '%' : '');
            if (isPct && num > 0) return '<span class="positive">' + escapeHTML(str) + '</span>';
            if (isPct && num < 0) return '<span class="negative">' + escapeHTML(str) + '</span>';
            return '<span class="value">' + escapeHTML(str) + '</span>';
        }

        function renderTable(dataToRender) {
            tbody.innerHTML = '';
            dataToRender.forEach(row => {
                const tr = document.createElement('tr');
                tr.innerHTML = `
                    <td class="text-left">
                        <div class="ticker">${escapeHTML(row.ticker)}</div>
                        <div class="name">${escapeHTML(row.name)}</div>
                    </td>
                    <td class="text-left"><span class="tag">${escapeHTML(row.sector)}</span></td>
                    <td class="value">${formatVal(row.yield)}</td>
                    <td class="value">${formatVal(row.payoutRatio)}</td>
                    <td class="value">${formatVal(row.divGrowth)}</td>
                    <td class="value">${formatVal(row.totalReturn)}</td>
                `;
                tbody.appendChild(tr);
            });
        }

        function sortData(column) {
            if (currentSort.column === column) {
                currentSort.dir = currentSort.dir === 'asc' ? 'desc' : 'asc';
            } else {
                currentSort.column = column;
                currentSort.dir = 'desc';
            }

            const sorted = [...window.__INITIAL_DATA__].sort((a, b) => {
                let valA = a[column];
                let valB = b[column];

                if (valA === null) valA = -Infinity;
                if (valB === null) valB = -Infinity;

                if (typeof valA === 'string') {
                    return currentSort.dir === 'asc'
                        ? valA.localeCompare(valB)
                        : valB.localeCompare(valA);
                }

                return currentSort.dir === 'asc' ? valA - valB : valB - valA;
            });

            applyFilters(sorted);
        }

        function applyFilters(dataToFilter = window.__INITIAL_DATA__) {
            const sector = sectorFilter.value;
            const search = searchInput.value.toLowerCase();

            let filtered = dataToFilter.filter(row => {
                const matchSector = sector === 'All' || row.sector === sector;
                const matchSearch = row.ticker.toLowerCase().includes(search) ||
                                  row.name.toLowerCase().includes(search);
                return matchSector && matchSearch;
            });

            // Re-apply sort
            filtered.sort((a, b) => {
                let valA = a[currentSort.column];
                let valB = b[currentSort.column];

                if (valA === null) valA = -Infinity;
                if (valB === null) valB = -Infinity;

                if (typeof valA === 'string') {
                    return currentSort.dir === 'asc'
                        ? valA.localeCompare(valB)
                        : valB.localeCompare(valA);
                }

                return currentSort.dir === 'asc' ? valA - valB : valB - valA;
            });

            renderTable(filtered);
        }

        document.querySelectorAll('th[data-sort]').forEach(th => {
            th.addEventListener('click', () => sortData(th.dataset.sort));
        });

        sectorFilter.addEventListener('change', () => applyFilters());
        searchInput.addEventListener('input', () => applyFilters());

        // Initial render
        renderTable(window.__INITIAL_DATA__);
