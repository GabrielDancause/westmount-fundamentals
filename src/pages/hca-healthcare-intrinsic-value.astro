.faq-answer { padding: 0 20px 20px; color: #a0aab8; font-size: 0.95rem; line-height: 1.6; border-top: 1px solid rgba(255,255,255,0.05); margin-top: 8px; padding-top: 16px; }

/* Cite / Source */
.cite-block { background: rgba(74,143,231,0.05); border-left: 4px solid #4a8fe7; padding: 20px; margin: 60px 0 40px; border-radius: 0 12px 12px 0; }
.cite-block h4 { color: #fff; margin-bottom: 8px; font-size: 1rem; }
.cite-block p { margin: 0; color: #a0aab8; font-size: 0.9rem; font-family: 'JetBrains Mono', monospace; }

.sources { border-top: 1px solid #152040; padding-top: 32px; margin-top: 32px; }
.sources h4 { color: #5a6a80; text-transform: uppercase; letter-spacing: 1px; font-size: 0.8rem; margin-bottom: 16px; }
.sources ul { list-style: none; padding: 0; }
.sources li { font-size: 0.85rem; color: #7a8a9e; margin-bottom: 8px; padding-left: 16px; position: relative; }
.sources li::before { content: '•'; position: absolute; left: 0; color: #4a8fe7; }

/* Related */
.related-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 16px; margin-bottom: 60px; }
.related-card { background: #0a1020; border: 1px solid #152040; border-radius: 12px; padding: 20px; transition: all 0.2s ease; }
.related-card:hover { transform: translateY(-3px); border-color: #4a8fe7; box-shadow: 0 10px 20px rgba(0,0,0,0.2); }
.rc-title { font-weight: 700; color: #e0e6f0; margin-bottom: 8px; }
.rc-desc { font-size: 0.85rem; color: #7a8a9e; line-height: 1.5; }

.disclaimer { border-top: 1px solid #152040; padding-top: 32px; margin: 60px 0; }
.disclaimer h4 { color: #5a6a80; text-transform: uppercase; letter-spacing: 1px; font-size: 0.8rem; margin-bottom: 12px; }
.disclaimer p { font-size: 0.8rem; color: #5a6a80; }
</style>

<div class="header">
  <div class="header-content">
    <div class="tag">Compiled by Gemini 3.1</div>
    <h1>HCA Healthcare Intrinsic Value</h1>
    <p class="subtitle">A full discounted cash flow (DCF) analysis on HCA Healthcare (HCA). One number. Every assumption disclosed. Here is what the hospital operator is really worth.</p>
    <div class="date">Updated {meta.published}</div>
  </div>
</div>

<div class="container">
  <!-- ═══ VERDICT CARD ═══ -->
  <div class="verdict-card">
    <div class="verdict-label">Intrinsic Value Estimate</div>
    <div class="verdict-price">
      {roundedIV !== null ? `$${roundedIV.toFixed(2)}` : 'N/A'}
    </div>
    <div class="verdict-vs">
      Current Price: <strong>{currentPrice !== null ? `$${currentPrice.toFixed(2)}` : 'N/A'}</strong>
    </div>
    {roundedIV !== null && currentPrice !== null && (
      <div class="verdict-badge" style={`background: ${verdictColor}20; color: ${verdictColor}; border: 1px solid ${verdictColor}50;`}>
        {marginOfSafety}% {verdictText}
      </div>
    )}
    {roundedIV === null && (
      <div class="verdict-badge" style="background: #3a4a6020; color: #7a8a9e; border: 1px solid #3a4a6050;">
        Data Unavailable
      </div>
    )}
  </div>

  <div class="stats-row">
    <div class="stat-card">
      <div class="stat-value">{fcf2025 !== null ? `$${(fcf2025 / 1000).toFixed(1)}B` : 'N/A'}</div>
      <div class="stat-label">Starting FCF</div>
    </div>
    <div class="stat-card">
      <div class="stat-value">{totalDebt !== null ? `$${(totalDebt / 1000).toFixed(1)}B` : 'N/A'}</div>
      <div class="stat-label">Total Debt</div>
    </div>
    <div class="stat-card">
      <div class="stat-value">{sharesOutstandingRaw !== null ? `${sharesOutstandingRaw.toFixed(0)}M` : 'N/A'}</div>
      <div class="stat-label">Shares Out</div>
    </div>
    <div class="stat-card">
      <div class="stat-value">{beta !== null ? beta.toFixed(2) : 'N/A'}</div>
      <div class="stat-label">Beta</div>
    </div>
  </div>

  <!-- ═══ METHODOLOGY ═══ -->
  <h2>Methodology & Assumptions</h2>
  <p>We use a standard two-stage Discounted Cash Flow (DCF) model to value HCA. This approach calculates the present value of all future free cash flows to determine the true worth of the underlying business, adjusted for net debt.</p>

  <div class="assumption-grid">
    <div class="assumption-card">
      <div class="label">Discount Rate (WACC)</div>
      <div class="value">{(discountRate * 100).toFixed(1)}%</div>
      <div class="rationale">Based on a 4.18% 10Y Treasury yield, a 5.5% equity risk premium, and HCA's beta. Weighted average cost of capital incorporates their substantial debt load.</div>
    </div>
    <div class="assumption-card">
      <div class="label">Phase 1 Growth</div>
      <div class="value">{(growthRatePhase1 * 100).toFixed(1)}%</div>
      <div class="rationale">Projected free cash flow growth for the next 5 years, reflecting pricing power, steady volume growth, and ongoing facility expansion.</div>
    </div>
    <div class="assumption-card">
      <div class="label">Terminal Growth</div>
      <div class="value">{(growthRateTerminal * 100).toFixed(1)}%</div>
      <div class="rationale">Assumed perpetual growth rate after year 5. Set at 2.5%, slightly below historical GDP growth, representing a mature, stable state.</div>
    </div>
  </div>

  <!-- ═══ FCF PROJECTIONS ═══ -->
  <h2>Cash Flow Projections</h2>
  <p>Here is the year-by-year breakdown of projected Free Cash Flow and its Present Value (PV) discounted at {(discountRate * 100).toFixed(1)}%.</p>

  <div class="table-wrap">
    <table>
      <thead>
        <tr>
          <th style="text-align:left">Year</th>
          <th>Growth</th>
          <th>Projected FCF ($M)</th>
          <th>Discount Factor</th>
          <th>Present Value ($M)</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td>Current (Base)</td>
          <td>-</td>
          <td>{fcf2025 !== null ? `$${fcf2025.toLocaleString()}` : 'N/A'}</td>
          <td>1.000</td>
          <td>-</td>
        </tr>
        {projectedFCF.length > 0 ? projectedFCF.map(p => (
          <tr>
            <td>Year {p.year}</td>
            <td>{(growthRatePhase1 * 100).toFixed(1)}%</td>
            <td>${p.fcf.toLocaleString()}</td>
            <td>{p.pvFactor.toFixed(3)}</td>
            <td>${p.pvFCF.toLocaleString()}</td>
          </tr>
        )) : (
          <tr><td colspan="5" style="text-align:center;">Projection data unavailable</td></tr>
        )}
      </tbody>
    </table>
  </div>

  <!-- ═══ TERMINAL VALUE ═══ -->
  <h3>Terminal Value Calculation</h3>
  <p>The terminal value accounts for all cash flows generated after the initial 5-year period. We use the Gordon Growth Model.</p>

  {projectedFCF.length > 0 ? (
    <div class="table-wrap">
      <table>
        <tbody>
          <tr>
            <td>Year 6 FCF</td>
            <td>${Math.round(projectedFCF[4].fcf * (1 + growthRateTerminal)).toLocaleString()}</td>
          </tr>
          <tr>
            <td>Terminal Value</td>
            <td>${Math.round((projectedFCF[4].fcf * (1 + growthRateTerminal)) / (discountRate - growthRateTerminal)).toLocaleString()}</td>
          </tr>
          <tr>
            <td>PV of Terminal Value</td>
            <td>${Math.round(((projectedFCF[4].fcf * (1 + growthRateTerminal)) / (discountRate - growthRateTerminal)) * projectedFCF[4].pvFactor).toLocaleString()}</td>
          </tr>
        </tbody>
      </table>
    </div>
  ) : (
    <p><em>Data unavailable</em></p>
  )}

  <!-- ═══ VALUATION SUMMARY ═══ -->
  <h3>Valuation Summary</h3>
  {projectedFCF.length > 0 && cashAndEquivalents !== null && totalDebt !== null ? (
    <div class="table-wrap">
      <table>
        <tbody>
          <tr>
            <td>PV of Free Cash Flows (Years 1-5)</td>
            <td>${projectedFCF.reduce((sum, p) => sum + p.pvFCF, 0).toLocaleString()}</td>
          </tr>
          <tr>
            <td>PV of Terminal Value</td>
            <td>${Math.round(((projectedFCF[4].fcf * (1 + growthRateTerminal)) / (discountRate - growthRateTerminal)) * projectedFCF[4].pvFactor).toLocaleString()}</td>
          </tr>
          <tr class="row-total">
            <td>Enterprise Value</td>
            <td>${(projectedFCF.reduce((sum, p) => sum + p.pvFCF, 0) + Math.round(((projectedFCF[4].fcf * (1 + growthRateTerminal)) / (discountRate - growthRateTerminal)) * projectedFCF[4].pvFactor)).toLocaleString()}</td>
          </tr>
          <tr>
            <td>Plus: Cash & Equivalents</td>
            <td>${cashAndEquivalents.toLocaleString()}</td>
          </tr>
          <tr>
            <td>Less: Total Debt</td>
            <td style="color: #ef4444">-${totalDebt.toLocaleString()}</td>
          </tr>
          <tr class="row-total">
            <td>Implied Equity Value</td>
            <td>${((projectedFCF.reduce((sum, p) => sum + p.pvFCF, 0) + Math.round(((projectedFCF[4].fcf * (1 + growthRateTerminal)) / (discountRate - growthRateTerminal)) * projectedFCF[4].pvFactor)) + (cashAndEquivalents - totalDebt)).toLocaleString()}</td>
          </tr>
          <tr>
            <td>Shares Outstanding</td>
            <td>{sharesOutstandingRaw.toFixed(1)} million</td>
          </tr>
          <tr class="row-total">
            <td>Intrinsic Value Per Share</td>
            <td class="highlight-cell">${roundedIV.toFixed(2)}</td>
          </tr>
        </tbody>
      </table>
    </div>
  ) : (
    <p><em>Valuation summary unavailable due to missing data.</em></p>
  )}

  <!-- ═══ SENSITIVITY ANALYSIS ═══ -->
  <h2>Sensitivity Analysis</h2>
  <p>Valuations are highly sensitive to assumptions. The matrix below shows the intrinsic value per share under different discount rates and growth rate scenarios.</p>

  {sensitivityTable.length > 0 ? (
    <div class="table-wrap">
      <table class="sensitivity-table">
        <thead>
          <tr>
            <th style="text-align:left">WACC ↓ / Growth →</th>
            {sensitivityGrowth.map(g => (
              <th class={g === growthRatePhase1 ? 'current' : ''}>{(g * 100).toFixed(1)}%</th>
            ))}
          </tr>
        </thead>
        <tbody>
          {sensitivityTable.map(row => (
            <tr>
              <td>{(row.dr * 100).toFixed(1)}%</td>
              {row.values.map((v, i) => (
