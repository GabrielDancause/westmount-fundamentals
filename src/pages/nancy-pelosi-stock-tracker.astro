---
import SiteLayout from "../layouts/SiteLayout.astro";

export const meta = {
  title: "Nancy Pelosi Stock Tracker: Congressional Copy-Trade Calculator",
  description: "Curious if mirroring the most famous Congressional portfolio actually pays off? Calculate the real-time returns of notable political trades.",
  category: "tool",
  published: "2026-03-15",
};

// Fetch real-time stock prices for notable Pelosi trades
const tickers = ['NVDA', 'AAPL', 'MSFT', 'GOOGL', 'AMZN', 'PANW', 'AVGO'];
const livePrices: Record<string, number | null> = {};

for (const ticker of tickers) {
  try {
    const response = await fetch(`https://query1.finance.yahoo.com/v8/finance/chart/${ticker}?interval=1d&range=1d`, {
      headers: { 'User-Agent': 'Mozilla/5.0' }
    });
    if (response.ok) {
      const data = await response.json();
      livePrices[ticker] = data.chart.result[0].meta.regularMarketPrice;
    } else {
      livePrices[ticker] = null;
    }
  } catch (error) {
    console.error(`Error fetching data for ${ticker}:`, error);
    livePrices[ticker] = null;
  }
}

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": meta.title,
    "description": meta.description,
    "author": {
      "@type": "Organization",
      "name": "SiliconBased",
      "url": "https://westmountfundamentals.com"
    },
    "publisher": {
      "@type": "Organization",
      "name": "SiliconBased",
      "logo": {
        "@type": "ImageObject",
        "url": "https://westmountfundamentals.com/logo.png"
      }
    },
    "datePublished": meta.published,
    "mainEntityOfPage": {
      "@type": "WebPage",
      "@id": "https://westmountfundamentals.com/nancy-pelosi-stock-tracker"
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "What is the STOCK Act?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "The Stop Trading on Congressional Knowledge (STOCK) Act of 2012 is a law designed to combat insider trading by members of Congress and other government employees. It prohibits lawmakers from using non-public information derived from their official duties for personal financial gain and requires public disclosure of their financial transactions."
        }
      },
      {
        "@type": "Question",
        "name": "How long do Congress members have to disclose trades?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Under the STOCK Act, members of Congress are required to file a Periodic Transaction Report (PTR) within 30 days of becoming aware of a transaction, and no later than 45 days after the transaction date."
        }
      },
      {
        "@type": "Question",
        "name": "Why is Nancy Pelosi's stock portfolio heavily tracked?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Nancy Pelosi's portfolio, managed primarily by her husband, venture capitalist Paul Pelosi, is heavily tracked because it has historically achieved significant returns, particularly through leveraged options trading in large-cap technology stocks like Nvidia and Apple. The scale and timing of these trades have drawn intense public and media scrutiny."
        }
      },
      {
        "@type": "Question",
        "name": "Is it legal to copy-trade politicians?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes, it is entirely legal to execute trades based on the public disclosures made by politicians. However, because disclosures are delayed by up to 45 days, retail investors cannot mirror the trades in real-time, meaning the market may have already moved significantly by the time the public learns of the transaction."
        }
      },
      {
        "@type": "Question",
        "name": "What are the penalties for violating the STOCK Act?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "The standard penalty for failing to file a disclosure report on time is relatively minor—typically a $200 fine. While serious insider trading violations can theoretically lead to criminal charges, the routine penalty for mere late reporting is often viewed by critics as an insufficient deterrent."
        }
      }
    ]
  }
];
---
<SiteLayout site="westmount" title={meta.title} description={meta.description} canonical="https://westmountfundamentals.com/nancy-pelosi-stock-tracker" schema={schema}>
  <div class="page-content">
    <div class="hero">
      <h1>Nancy Pelosi Stock Tracker</h1>
      <p class="subtitle">Calculate the real-time hypothetical returns of notable Congressional copy-trades.</p>
    </div>

    <div class="calculator-container">
      <div class="input-grid">
        <div class="input-group">
          <label for="trade-select">Notable Disclosed Trade</label>
          <select id="trade-select">
            <option value="nvda-2023" data-ticker="NVDA" data-price="40.00">Nvidia (NVDA) - Nov 2023 Purchase</option>
            <option value="avgo-2024" data-ticker="AVGO" data-price="160.00">Broadcom (AVGO) - Jun 2024 Purchase</option>
            <option value="panw-2024" data-ticker="PANW" data-price="290.00">Palo Alto (PANW) - Feb 2024 Purchase</option>
            <option value="aapl-2022" data-ticker="AAPL" data-price="150.00">Apple (AAPL) - May 2022 Purchase</option>
            <option value="msft-2021" data-ticker="MSFT" data-price="250.00">Microsoft (MSFT) - Mar 2021 Purchase</option>
          </select>
        </div>
        <div class="input-group">
          <label for="investment-amount">Your Hypothetical Investment ($)</label>
          <input type="number" id="investment-amount" min="100" step="100" value="10000">
        </div>
      </div>

      <div class="trade-details" style="background: var(--bg-color); padding: 1rem; border-radius: 8px; border: 1px solid var(--border-color); margin-bottom: 2rem; font-size: 0.95rem;">
        <div style="display: flex; justify-content: space-between; margin-bottom: 0.5rem;">
          <span style="color: var(--text-secondary)">Estimated Purchase Price:</span>
          <strong id="purchase-price-display">$0.00</strong>
        </div>
        <div style="display: flex; justify-content: space-between;">
          <span style="color: var(--text-secondary)">Current Live Price:</span>
          <strong id="live-price-display">$0.00</strong>
        </div>
      </div>

      <div class="results-grid">
        <div class="result-card">
          <h3>Current Value</h3>
          <p class="result-label">of your investment today</p>
          <div class="result-value" id="current-value-display">$0.00</div>
        </div>
        <div class="result-card">
          <h3>Total Return</h3>
          <p class="result-label">Return on Investment (ROI)</p>
          <div class="result-value" id="roi-display">0.00%</div>
        </div>
      </div>
      <div class="error-message" id="calc-error" style="display: none; color: #ef4444; margin-top: 1rem; text-align: center; font-weight: 500;"></div>
    </div>

    <div class="explainer">
      <h2>The Mechanics of Congressional Trading</h2>
      <p>
        The intersection of politics and the stock market has become a focal point of intense public scrutiny. At the center of this debate is the trading activity of high-profile legislators, most notably former Speaker of the House Nancy Pelosi. While the trades are technically executed by her husband, venture capitalist Paul Pelosi, the consistent, market-beating returns of the Pelosi portfolio have sparked widespread interest—and a burgeoning "copy-trading" movement among retail investors. This tool, much like our HELOC Payment Calculator helps you model financial outcomes, allows you to calculate the hypothetical returns of mirroring these notable disclosed trades.
      </p>

      <h3>The STOCK Act and Disclosure Timelines</h3>
      <p>
        To understand how retail investors track these trades, you must understand the regulatory framework. The Stop Trading on Congressional Knowledge (STOCK) Act, signed into law in 2012, explicitly prohibits members of Congress and other government employees from using non-public information for private profit. It was designed to prevent insider trading based on legislative knowledge.
      </p>
      <p>
        Crucially, the STOCK Act mandates transparency. Legislators must file Periodic Transaction Reports (PTRs) detailing their financial transactions. However, there is a built-in delay. Lawmakers have up to 45 days from the date of the transaction to file the disclosure. This reporting window is the fundamental barrier to true, real-time copy-trading.
      </p>
      <div style="background: var(--card-bg); padding: 1.5rem; border-radius: 8px; border: 1px solid var(--border-color); margin: 1.5rem 0;">
        <strong>The Copy-Trade Lag:</strong> Because the public only learns about a trade up to 45 days after it happens, the market often prices in the asset's movement before a retail investor can react. If a politician buys a stock just before a major positive earnings report, the public won't see the disclosure until well after the stock has already surged.
      </div>

      <h3>Analyzing the Strategy: Big Tech and LEAPS</h3>
      <p>
        The Pelosi portfolio is not characterized by high-frequency day trading or speculative penny stocks. Instead, it is heavily concentrated in large-cap technology companies—the "Magnificent Seven"—such as Nvidia, Apple, Microsoft, and Alphabet.
      </p>
      <p>
        A defining feature of the strategy is the extensive use of Long-Term Equity Anticipation Securities (LEAPS). LEAPS are options contracts with expiration dates longer than one year. By purchasing deep-in-the-money call options, the portfolio achieves significant leverage. It controls a large amount of underlying stock for a fraction of the cost of buying the shares outright, amplifying returns during prolonged bull markets in the tech sector. While this calculator models standard share purchases for simplicity, the actual returns of the Pelosi portfolio are often much higher (or lower, during downturns) due to this options leverage.
      </p>

      <h3>The Calculation Methodology</h3>
      <p>
        This calculator operates by comparing historical execution estimates against live market data. The methodology is as follows:
      </p>
      <ol>
        <li><strong>Historical Baseline:</strong> When a PTR is filed, it provides a transaction date and a value range (e.g., "$1,000,001 - $5,000,000") rather than an exact execution price. The calculator uses a reasonable estimated entry price based on the asset's closing price or VWAP (Volume-Weighted Average Price) on the disclosed date, adjusted for any subsequent stock splits.</li>
        <li><strong>Live Data Ingestion:</strong> The tool fetches the current, real-time price of the selected ticker (e.g., NVDA) at build time, ensuring calculations reflect the current market environment.</li>
        <li><strong>Return Calculation:</strong> The simple Return on Investment (ROI) is calculated using the formula: <br><code>ROI = ((Current Price - Purchase Price) / Purchase Price) × 100</code></li>
      </ol>
      <p>
        For example, if the estimated split-adjusted purchase price of Nvidia in November 2023 was $40, and the current live price is $120, the ROI is mathematically calculated as ((120 - 40) / 40) * 100 = 200%. If you input a hypothetical investment of $10,000, the tool multiplies that initial capital by the growth factor (1 + 2.00) to yield a current value of $30,000.
      </p>

      <h3>The Ethical Debate and Market Impact</h3>
      <p>
        The phenomenon of tracking the "Pelosi Portfolio" highlights a broader debate regarding institutional fairness. Critics argue that lawmakers possess inherent informational advantages—ranging from advance knowledge of regulatory shifts to closed-door briefings on defense contracts—that render any trading inherently unfair. Proponents of the current system argue that the STOCK Act's disclosure requirements are sufficient and that barring legislators from trading entirely would discourage financially literate individuals from pursuing public office.
      </p>
      <p>
        Regardless of the ethical stance, the market impact is tangible. Retail trading volume occasionally spikes on the tickers of companies mentioned in high-profile disclosures, creating temporary momentum anomalies. For the retail investor, attempting to blindly follow these delayed filings remains a high-risk strategy, heavily dependent on broader macroeconomic trends continuing in the direction established 45 days prior.
      </p>
    </div>

    <section class="faq-section">
      <h2>Frequently Asked Questions</h2>
      <details>
        <summary>What is the STOCK Act?</summary>
        <p>The Stop Trading on Congressional Knowledge (STOCK) Act of 2012 is a law designed to combat insider trading by members of Congress and other government employees. It prohibits lawmakers from using non-public information derived from their official duties for personal financial gain and requires public disclosure of their financial transactions.</p>
      </details>
      <details>
        <summary>How long do Congress members have to disclose trades?</summary>
        <p>Under the STOCK Act, members of Congress are required to file a Periodic Transaction Report (PTR) within 30 days of becoming aware of a transaction, and no later than 45 days after the transaction date.</p>
      </details>
      <details>
        <summary>Why is Nancy Pelosi's stock portfolio heavily tracked?</summary>
        <p>Nancy Pelosi's portfolio, managed primarily by her husband, venture capitalist Paul Pelosi, is heavily tracked because it has historically achieved significant returns, particularly through leveraged options trading in large-cap technology stocks like Nvidia and Apple. The scale and timing of these trades have drawn intense public and media scrutiny.</p>
      </details>
      <details>
        <summary>Is it legal to copy-trade politicians?</summary>
        <p>Yes, it is entirely legal to execute trades based on the public disclosures made by politicians. However, because disclosures are delayed by up to 45 days, retail investors cannot mirror the trades in real-time, meaning the market may have already moved significantly by the time the public learns of the transaction.</p>
      </details>
      <details>
        <summary>What are the penalties for violating the STOCK Act?</summary>
        <p>The standard penalty for failing to file a disclosure report on time is relatively minor—typically a $200 fine. While serious insider trading violations can theoretically lead to criminal charges, the routine penalty for mere late reporting is often viewed by critics as an insufficient deterrent.</p>
      </details>
    </section>
  </div>

  <script id="price-data" type="application/json" set:html={JSON.stringify(livePrices)}></script>

  <script is:inline>
    document.addEventListener('DOMContentLoaded', () => {
      const tradeSelect = document.getElementById('trade-select');
      const investmentInput = document.getElementById('investment-amount');

      const purchasePriceDisplay = document.getElementById('purchase-price-display');
      const livePriceDisplay = document.getElementById('live-price-display');
      const currentValueDisplay = document.getElementById('current-value-display');
      const roiDisplay = document.getElementById('roi-display');
      const errorDisplay = document.getElementById('calc-error');

      // Load live prices injected from build time
      let prices = {};
      try {
        const dataElement = document.getElementById('price-data');
        if (dataElement) {
          prices = JSON.parse(dataElement.textContent);
        }
      } catch (e) {
        console.error("Failed to parse price data", e);
      }

      const currencyFormatter = new Intl.NumberFormat('en-US', {
        style: 'currency',
        currency: 'USD',
        minimumFractionDigits: 2,
        maximumFractionDigits: 2
      });

      const percentFormatter = new Intl.NumberFormat('en-US', {
        style: 'percent',
        minimumFractionDigits: 2,
        maximumFractionDigits: 2
      });

      function calculateReturns() {
        errorDisplay.style.display = 'none';

        const selectedOption = tradeSelect.options[tradeSelect.selectedIndex];
        const ticker = selectedOption.getAttribute('data-ticker');
        const purchasePrice = parseFloat(selectedOption.getAttribute('data-price'));
        const investment = parseFloat(investmentInput.value);

        const livePrice = prices[ticker];

        purchasePriceDisplay.textContent = currencyFormatter.format(purchasePrice);

        if (isNaN(investment) || investment <= 0) {
          errorDisplay.textContent = 'Please enter a valid investment amount greater than zero.';
          errorDisplay.style.display = 'block';
          livePriceDisplay.textContent = '---';
          currentValueDisplay.textContent = '$0.00';
          roiDisplay.textContent = '0.00%';
          return;
        }

        if (!livePrice) {
          errorDisplay.textContent = `Live price data for ${ticker} is currently unavailable. Try again later.`;
          errorDisplay.style.display = 'block';
          livePriceDisplay.textContent = 'Unavailable';
          currentValueDisplay.textContent = '---';
          roiDisplay.textContent = '---';
          return;
        }

        livePriceDisplay.textContent = currencyFormatter.format(livePrice);

        // Calculate ROI and Current Value
        // Note: The formatter multiplies by 100, so we just calculate the decimal ROI
        const decimalRoi = (livePrice - purchasePrice) / purchasePrice;
        const currentValue = investment * (1 + decimalRoi);

        currentValueDisplay.textContent = currencyFormatter.format(currentValue);

        // Color coding for ROI
        roiDisplay.textContent = percentFormatter.format(decimalRoi);
        if (decimalRoi > 0) {
          roiDisplay.style.color = '#10b981'; // green
        } else if (decimalRoi < 0) {
          roiDisplay.style.color = '#ef4444'; // red
        } else {
          roiDisplay.style.color = 'var(--accent-color)';
        }
      }

      tradeSelect.addEventListener('change', calculateReturns);
      investmentInput.addEventListener('input', calculateReturns);

      // Initial calculation
      calculateReturns();
    });
  </script>

  <style is:inline>
    .page-content { max-width: 900px; margin: 0 auto; padding: 2rem 1.5rem; }
    .hero { text-align: center; padding: 3rem 0 2rem; }
    .hero h1 { font-size: 2.2rem; font-weight: 800; margin-bottom: 0.5rem; }
    .subtitle { color: var(--text-secondary); font-size: 1.1rem; }
    .calculator-container { background: var(--card-bg); border: 1px solid var(--border-color); border-radius: 12px; padding: 2rem; margin: 2rem 0; }

    .input-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1.5rem;
      margin-bottom: 1.5rem;
    }

    @media (max-width: 600px) {
      .input-grid {
        grid-template-columns: 1fr;
      }
    }

    .input-group {
      display: flex;
      flex-direction: column;
      gap: 0.5rem;
    }

    .input-group label {
      font-weight: 600;
      font-size: 0.95rem;
    }

    input, select { background: var(--bg-color); color: var(--text-primary); border: 1px solid var(--border-color); padding: 0.75rem 1rem; border-radius: 8px; width: 100%; font-size: 1rem; }
    input:focus, select:focus { outline: none; border-color: var(--accent-color); box-shadow: 0 0 0 3px color-mix(in srgb, var(--accent-color) 20%, transparent); }
    button { background: var(--accent-color); color: white; border: none; padding: 0.75rem 2rem; border-radius: 8px; font-weight: 600; cursor: pointer; font-size: 1rem; }
    button:hover { opacity: 0.9; }

    .results-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1.5rem;
    }

    @media (max-width: 600px) {
      .results-grid {
        grid-template-columns: 1fr;
      }
    }

    .result-card { background: color-mix(in srgb, var(--accent-color) 10%, transparent); border: 1px solid var(--accent-color); border-radius: 12px; padding: 1.5rem; text-align: center; display: flex; flex-direction: column; justify-content: center; }
    .result-card h3 { margin: 0 0 0.25rem 0; font-size: 1.1rem; }
    .result-label { color: var(--text-secondary); font-size: 0.9rem; margin: 0 0 1rem 0; }
    .result-value { font-size: 2.5rem; font-weight: 800; color: var(--accent-color); line-height: 1; }

    .explainer {
      margin-top: 3rem;
      line-height: 1.7;
    }
    .explainer h2 {
      font-size: 1.8rem;
      margin-top: 2rem;
      margin-bottom: 1rem;
    }
    .explainer h3 {
      font-size: 1.4rem;
      margin-top: 1.5rem;
      margin-bottom: 0.75rem;
    }
    .explainer p {
      margin-bottom: 1.25rem;
      color: var(--text-primary);
    }
    .explainer a {
      color: var(--accent-color);
      text-decoration: underline;
    }

    .faq-section {
      margin-top: 3rem;
    }
    .faq-section h2 {
      margin-bottom: 1.5rem;
      font-size: 1.8rem;
    }
    .faq-section details { margin: 1rem 0; padding: 1rem; background: var(--card-bg); border-radius: 8px; border: 1px solid var(--border-color); }
    .faq-section summary { font-weight: 600; cursor: pointer; font-size: 1.1rem; }
    .faq-section p { margin-top: 1rem; color: var(--text-secondary); line-height: 1.6; }
  </style>

  <section style="max-width:800px;margin:40px auto;padding:0 24px">
    <h2 style="font-size:20px;color:var(--text-bright,#fff);margin-bottom:16px">Related Pages</h2>
    <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:12px">
      <a href="/stock-split-calculator/" style="display:block;padding:16px;background:var(--card-bg,#0a1020);border:1px solid var(--border-color,#152040);border-radius:8px;text-decoration:none;color:var(--text-primary,#c8d0de);transition:transform 0.2s" onmouseover="this.style.transform='translateY(-2px)'" onmouseout="this.style.transform='none'">Stock Split Calculator & Guide: How Forward and Reverse Spli</a>
      <a href="/stock-screener/" style="display:block;padding:16px;background:var(--card-bg,#0a1020);border:1px solid var(--border-color,#152040);border-radius:8px;text-decoration:none;color:var(--text-primary,#c8d0de);transition:transform 0.2s" onmouseover="this.style.transform='translateY(-2px)'" onmouseout="this.style.transform='none'">S&P 500 Stock Screener Tool</a>
      <a href="/stock-comparison-tool/" style="display:block;padding:16px;background:var(--card-bg,#0a1020);border:1px solid var(--border-color,#152040);border-radius:8px;text-decoration:none;color:var(--text-primary,#c8d0de);transition:transform 0.2s" onmouseover="this.style.transform='translateY(-2px)'" onmouseout="this.style.transform='none'">Stock Comparison Tool: Compare Any Two Stocks</a>
      <a href="/insider-buying-tracker-2026/" style="display:block;padding:16px;background:var(--card-bg,#0a1020);border:1px solid var(--border-color,#152040);border-radius:8px;text-decoration:none;color:var(--text-primary,#c8d0de);transition:transform 0.2s" onmouseover="this.style.transform='translateY(-2px)'" onmouseout="this.style.transform='none'">S&P 500 Insider Buying Tracker (2026)</a>
    </div>
  </section>
</SiteLayout>
