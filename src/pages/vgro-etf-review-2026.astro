---
import SiteLayout from "../layouts/SiteLayout.astro";
import registry from "../data/pages-registry.json";

const page = (registry as any)["vgro-etf-review-2026"];
export const meta = { title: "VGRO ETF Review 2026: 80/20 Portfolio Canada", description: "Complete 2026 review of the Vanguard Growth ETF Portfolio (VGRO). Explore the 80/20 allocation, MER, performance, and how it compares to XGRO and ZGRO.", category: "tool", published: "2026-03-15" };

const schema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What is the VGRO expense ratio?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "The Vanguard Growth ETF Portfolio (VGRO) has an expense ratio of 0.24%. This means for every $10,000 invested, you pay $24 per year in management fees."
      }
    },
    {
      "@type": "Question",
      "name": "Is VGRO better than XGRO?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Both VGRO and XGRO offer similar 80/20 asset allocations. XGRO has a slightly lower MER at 0.20% compared to VGRO's 0.24%. The best choice depends on your brokerage's free ETF purchase list and minor preference differences in underlying holdings."
      }
    },
    {
      "@type": "Question",
      "name": "What is the dividend yield of VGRO?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "As of 2026, VGRO has a trailing 12-month dividend yield of approximately 1.80%. Yields fluctuate based on the distributions of the underlying Vanguard index funds."
      }
    },
    {
      "@type": "Question",
      "name": "What does an 80/20 portfolio mean?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "An 80/20 portfolio like VGRO allocates roughly 80% of its assets to equities (stocks) for growth, and 20% to fixed income (bonds) to reduce volatility and provide stability."
      }
    },
    {
      "@type": "Question",
      "name": "How often does VGRO rebalance?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Vanguard automatically rebalances VGRO's underlying holdings on an ongoing basis to maintain the target 80% equity and 20% fixed income allocation, saving investors the time and trading fees of manual rebalancing."
      }
    }
  ]
};

---

<SiteLayout
  site="westmount"
  title={page.title}
  description={page.description}
  canonical={`https://westmountfundamentals.com/${page.slug}/`} schema={schema}
>
  <style is:global>
:root {
      --positive: #10b981;
      --negative: #ef4444;
      --radius: 12px;

}

    * { margin: 0; padding: 0; box-sizing: border-box; }

    body {
      font-family: 'Inter', sans-serif;
      background-color: var(--bg-color);
      color: var(--text-primary);
      line-height: 1.6;
      -webkit-font-smoothing: antialiased;
    }

    /* Navigation */
    .site-nav {
      position: sticky; top: 0; z-index: 1000;
      background: rgba(6, 10, 18, 0.85);
      backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px);
      border-bottom: 1px solid var(--border-color);
    }
    .nav-inner {
      max-width: 1200px; margin: 0 auto;
      display: flex; align-items: center; justify-content: space-between;
      padding: 0 24px; height: 60px;
    }
    .nav-brand {
      font-weight: 800; color: #fff; text-decoration: none;
      font-size: 1.1rem; letter-spacing: -0.5px;
    }
    .nav-links { display: flex; gap: 24px; }
    .nav-link {
      color: var(--text-muted); text-decoration: none;
      font-weight: 500; font-size: 0.9rem; transition: color 0.2s;
    }
    .nav-link:hover { color: #fff; }

    /* Layout */
    .container {
      max-width: 1200px; margin: 0 auto;
      padding: 40px 24px;
    }

    /* Header */
    .hero { text-align: center; margin-bottom: 60px; }
    h1 {
      font-size: 3rem; font-weight: 900;
      background: linear-gradient(135deg, #fff 0%, #a5b4fc 100%);
      -webkit-background-clip: text; -webkit-text-fill-color: transparent;
      margin-bottom: 16px; letter-spacing: -1px;
    }
    .hero-subtitle {
      color: var(--text-muted); font-size: 1.2rem;
      max-width: 600px; margin: 0 auto;
    }

    /* Stats Grid */
    .stats-grid {
      display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
      gap: 20px; margin-bottom: 40px;
    }
    .stat-card {
      background: var(--card-bg); border: 1px solid var(--border-color);
      border-radius: var(--radius); padding: 24px;
      text-align: center;
    }
    .stat-label { color: var(--text-muted); font-size: 0.85rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 8px; }
    .stat-value { font-family: 'JetBrains Mono', monospace; font-size: 2rem; font-weight: 700; color: #fff; }

    /* Interactive Section */
    .section-title { font-size: 1.5rem; font-weight: 700; margin-bottom: 20px; border-bottom: 1px solid var(--border-color); padding-bottom: 10px; }

    .controls { display: flex; justify-content: space-between; margin-bottom: 16px; align-items: center; }
    .search-input {
      background: rgba(255,255,255,0.05); border: 1px solid var(--border-color);
      color: #fff; padding: 10px 16px; border-radius: 8px;
      font-family: 'Inter', sans-serif; width: 100%; max-width: 300px;
    }
    .search-input:focus { outline: none; border-color: var(--accent-color); }

    .table-container {
      overflow-x: auto; background: var(--card-bg);
      border: 1px solid var(--border-color); border-radius: var(--radius);
      margin-bottom: 40px;
    }
    table { width: 100%; border-collapse: collapse; text-align: left; }
    th {
      background: rgba(255,255,255,0.02); padding: 16px;
      font-size: 0.85rem; font-weight: 600; color: var(--text-muted);
      cursor: pointer; user-select: none; border-bottom: 1px solid var(--border-color);
      white-space: nowrap; transition: background 0.2s;
    }
    th:hover { background: rgba(255,255,255,0.05); color: #fff; }
    td { padding: 16px; border-bottom: 1px solid var(--border-color); font-family: 'JetBrains Mono', monospace; font-size: 0.95rem; }
    tr:last-child td { border-bottom: none; }
    .highlight-row { background: rgba(74, 143, 231, 0.05); }
    .ticker-col { font-weight: 700; color: #fff; display: flex; align-items: center; gap: 8px; }

    .winner-badge {
      background: rgba(16, 185, 129, 0.2); color: var(--positive);
      font-size: 0.7rem; padding: 2px 6px; border-radius: 4px;
      font-family: 'Inter', sans-serif; font-weight: 700; text-transform: uppercase;
    }

    /* Chart Section */
    .chart-container {
      background: var(--card-bg); border: 1px solid var(--border-color);
      border-radius: var(--radius); padding: 24px;
      margin-bottom: 60px; height: 400px;
    }

    /* Content & FAQ */
    .content-box {
      background: var(--card-bg); border: 1px solid var(--border-color);
      border-radius: var(--radius); padding: 32px; margin-bottom: 40px;
    }
    .content-box p { margin-bottom: 16px; color: var(--text-muted); }
    .content-box p:last-child { margin-bottom: 0; }
    .content-box strong { color: #fff; }

    .faq-item { border-bottom: 1px solid var(--border-color); padding: 20px 0; }
    .faq-item:last-child { border-bottom: none; }
    .faq-q { font-weight: 600; font-size: 1.1rem; margin-bottom: 8px; color: #fff; }
    .faq-a { color: var(--text-muted); }

    /* Footer */
    footer {
      text-align: center; padding: 40px 24px;
      border-top: 1px solid var(--border-color);
      color: var(--text-muted); font-size: 0.85rem;
    }

    @media (max-width: 768px) {
      h1 { font-size: 2.2rem; }
      .nav-links { display: none; }
      .stats-grid { grid-template-columns: 1fr 1fr; }
    }
    @media (max-width: 480px) {
      .stats-grid { grid-template-columns: 1fr; }
    }
  </style>

<div class="container">
  <div style="max-width:1280px;margin:0 auto;padding:16px 24px 0;display:flex;justify-content:space-between;align-items:center;font-size:13px;color:var(--text-dim,#94a3b8)">
    <nav aria-label="Breadcrumb"><a href="/" style="color:var(--text-dim,#94a3b8);text-decoration:none">Home</a> <span style="margin:0 6px;opacity:0.5">›</span> <a href="/tools/" style="color:var(--text-dim,#94a3b8);text-decoration:none">Tools</a> <span style="margin:0 6px;opacity:0.5">›</span> <span style="color:var(--text-primary,#c8d0de)">VGRO ETF Review 2026: 80/20 Portfolio Canada</span></nav>
    <span>4 min read</span>
  </div>
    <h1>{page.h1}</h1>


    <div class="stats-grid">
      <div class="stat-card">
        <div class="stat-label">Expense Ratio (MER)</div>
        <div class="stat-value">0.24%</div>
      </div>
      <div class="stat-card">
        <div class="stat-label">5-Year Ann. Return</div>
        <div class="stat-value" style="color: var(--positive)">+9.13%</div>
      </div>
      <div class="stat-card">
        <div class="stat-label">Dividend Yield</div>
        <div class="stat-value">1.80%</div>
      </div>
      <div class="stat-card">
        <div class="stat-label">Assets Under Mgt</div>
        <div class="stat-value">$9.22B</div>
      </div>
    </div>

    <div class="content-box">
      <h2 class="section-title">What is VGRO?</h2>
      <p>The <strong>Vanguard Growth ETF Portfolio (VGRO)</strong> is an all-in-one asset allocation ETF traded on the Toronto Stock Exchange. It holds a basket of underlying Vanguard index funds to create a broadly diversified global portfolio consisting of roughly 80% equities (stocks) and 20% fixed income (bonds).</p>
      <p>VGRO is designed for investors seeking long-term capital growth who are comfortable with the higher volatility associated with an 80% stock allocation. By holding this single ETF, you gain exposure to thousands of companies worldwide and government/corporate bonds, while Vanguard handles the automatic rebalancing for you.</p>
    </div>

    <h2 class="section-title">80/20 ETF Comparison (VGRO vs XGRO vs ZGRO)</h2>
    <div class="controls">
      <input type="text" id="table-search" class="search-input" placeholder="Search ETFs by ticker or name...">
    </div>
    <div class="table-container">
      <table id="comparison-table">
        <thead>
          <tr>
            <th data-sort="ticker">Ticker ↕</th>
            <th data-sort="name">Fund Name ↕</th>
            <th data-sort="expense">MER ↕</th>
            <th data-sort="aum">AUM (CAD) ↕</th>
            <th data-sort="return">5Y Ann. Return ↕</th>
          </tr>
        </thead>
        <tbody>
          <!-- Populated by JS -->
        </tbody>
      </table>
    </div>

    <h2 class="section-title">Multi-Year Performance</h2>
    <div class="chart-container">
      <canvas id="performanceChart"></canvas>
    </div>

    <div class="content-box">
      <h2 class="section-title">Methodology</h2>
      <p>Financial data for this review was sourced via the Yahoo Finance API on 2026-03-13. Performance metrics represent trailing total returns (including dividend reinvestment) as of the analysis date. Total returns over multi-year periods are annualized. AUM figures are presented in Billions (CAD). While effort is made to ensure accuracy, investors should verify current metrics (including the latest MER) directly through the fund provider's official documentation before investing.</p>
    </div>

    <div class="content-box">
      <h2 class="section-title">Frequently Asked Questions</h2>
      <div class="faq-item">
        <div class="faq-q">What is the VGRO expense ratio?</div>
        <div class="faq-a">The Vanguard Growth ETF Portfolio (VGRO) has a Management Expense Ratio (MER) of 0.24%. This means for every $10,000 invested, you pay $24 per year in fees.</div>
      </div>
      <div class="faq-item">
        <div class="faq-q">Is VGRO better than XGRO?</div>
        <div class="faq-a">Both VGRO and XGRO offer similar 80/20 asset allocations. XGRO has a slightly lower MER at 0.20% compared to VGRO's 0.24%. The "best" choice depends on your brokerage's free ETF purchase list and minor preference differences in underlying holdings.</div>
      </div>
      <div class="faq-item">
        <div class="faq-q">What is the dividend yield of VGRO?</div>
        <div class="faq-a">As of 2026, VGRO has a trailing 12-month dividend yield of approximately 1.80%. Yields fluctuate based on the distributions of the underlying Vanguard index funds.</div>
      </div>
      <div class="faq-item">
        <div class="faq-q">What does an 80/20 portfolio mean?</div>
        <div class="faq-a">An 80/20 portfolio like VGRO allocates roughly 80% of its assets to equities (stocks) for growth, and 20% to fixed income (bonds) to reduce volatility and provide stability.</div>
      </div>
      <div class="faq-item">
        <div class="faq-q">How often does VGRO rebalance?</div>
        <div class="faq-a">Vanguard automatically rebalances VGRO's underlying holdings on an ongoing basis to maintain the target 80% equity and 20% fixed income allocation, saving investors the time and trading fees of manual rebalancing.</div>
      </div>
    </div>

  </div>
  <script is:inline>
const etfData = {"vgro":{"name":"Vanguard Growth ETF Portfolio","price":42.97,"expenseRatio":"0.24","aum":"9.22","yield":"1.80","ytdReturn":"1.19","yr1Return":"19.25","yr3Return":"14.18","yr5Return":"9.13"},"xgro":{"name":"iShares Core Growth ETF Portfolio","price":34.86,"expenseRatio":"0.20","aum":"4.39","yield":"1.83","ytdReturn":"1.09","yr1Return":"17.44","yr3Return":"13.92","yr5Return":"9.02"},"zgro":{"name":"BMO Growth ETF","price":17.49,"expenseRatio":"0.20","aum":"0.69","yield":"1.63","ytdReturn":"1.09","yr1Return":"18.14","yr3Return":"14.14","yr5Return":"9.49"},"vbal":{"name":"Vanguard Balanced ETF Portfolio","price":36.86,"expenseRatio":"0.24","aum":"4.92","yield":"2.12","ytdReturn":"0.95","yr1Return":"13.95","yr3Return":"10.88","yr5Return":"6.56"}};

    // Populate Comparison Table
    const tableBody = document.querySelector('#comparison-table tbody');
    let tableData = ['VGRO', 'XGRO', 'ZGRO', 'VBAL'].map(sym => ({
      sym,
      ...etfData[sym.toLowerCase()]
    })).filter(d => d && d.name);

    function renderTable(data) {
      tableBody.innerHTML = '';
      data.forEach(d => {
        const isWinner = parseFloat(d.expenseRatio) <= 0.20;
        const rowClass = d.sym === 'VGRO' ? 'highlight-row' : '';
        tableBody.innerHTML += `
          <tr class="${rowClass}">
            <td class="ticker-col">${d.sym} ${d.sym === 'VGRO' ? '<span class="winner-badge">Review</span>' : ''}</td>
            <td style="font-family: 'Inter', sans-serif;">${d.name}</td>
            <td style="color: ${isWinner ? 'var(--positive)' : 'inherit'}; font-weight: ${isWinner ? 'bold' : 'normal'}">${d.expenseRatio}%</td>
            <td>$${d.aum}B</td>
            <td style="color: var(--positive)">+${d.yr5Return}%</td>
          </tr>
        `;
      });
    }

    renderTable(tableData);

    // Search functionality
    document.getElementById('table-search').addEventListener('input', (e) => {
      const term = e.target.value.toLowerCase();
      const filtered = tableData.filter(d =>
        d.sym.toLowerCase().includes(term) || d.name.toLowerCase().includes(term)
      );
      renderTable(filtered);
    });

    // Sort functionality
    let sortCol = '';
    let sortAsc = true;
    document.querySelectorAll('#comparison-table th').forEach(th => {
      th.addEventListener('click', () => {
        const col = th.dataset.sort;
        if (sortCol === col) {
          sortAsc = !sortAsc;
        } else {
          sortCol = col;
          sortAsc = true;
        }

        const sorted = [...tableData].sort((a, b) => {
          let valA, valB;
          if (col === 'ticker') { valA = a.sym; valB = b.sym; }
          else if (col === 'name') { valA = a.name; valB = b.name; }
          else if (col === 'expense') { valA = parseFloat(a.expenseRatio); valB = parseFloat(b.expenseRatio); }
          else if (col === 'aum') { valA = parseFloat(a.aum); valB = parseFloat(b.aum); }
          else if (col === 'return') { valA = parseFloat(a.yr5Return); valB = parseFloat(b.yr5Return); }

          if (valA < valB) return sortAsc ? -1 : 1;
          if (valA > valB) return sortAsc ? 1 : -1;
          return 0;
        });

        // Update headers visual
        document.querySelectorAll('#comparison-table th').forEach(h => {
          h.innerText = h.innerText.replace(' ↑', '').replace(' ↓', '').replace(' ↕', '') + ' ↕';
        });
        th.innerText = th.innerText.replace(' ↕', '') + (sortAsc ? ' ↑' : ' ↓');

        // Render sorted data but respect search term if any
        const term = document.getElementById('table-search').value.toLowerCase();
        const filtered = sorted.filter(d =>
          d.sym.toLowerCase().includes(term) || d.name.toLowerCase().includes(term)
        );
        renderTable(filtered);
      });
    });

    // Chart
    const ctx = document.getElementById('performanceChart').getContext('2d');
    const vgroData = etfData.vgro;
    new Chart(ctx, {
      type: 'bar',
      data: {
        labels: ['1 Year', '3 Year (Ann.)', '5 Year (Ann.)'],
        datasets: [{
          label: 'VGRO Total Return',
          data: [vgroData.yr1Return, vgroData.yr3Return, vgroData.yr5Return],
          backgroundColor: '#4a8fe7',
          borderRadius: 6
        }]
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        plugins: {
          legend: { display: false },
          tooltip: {
            callbacks: {
              label: function(context) { return context.parsed.y + '%'; }
            }
          }
        },
        scales: {
          y: {
            beginAtZero: true,
            grid: { color: '#152040' },
            ticks: { color: '#8b9bb4', callback: function(value) { return value + '%' } }
          },
          x: {
            grid: { display: false },
            ticks: { color: '#8b9bb4' }
          }
        }
      }
    });
  </script>

  <section style="max-width:800px;margin:40px auto;padding:0 24px">
    <h2 style="font-size:20px;color:var(--text-bright,#fff);margin-bottom:16px">Related Pages</h2>
    <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:12px">
      <a href="/xeqt-etf-review-2026/" style="display:block;padding:16px;background:var(--card-bg,#0a1020);border:1px solid var(--border-color,#152040);border-radius:8px;text-decoration:none;color:var(--text-primary,#c8d0de);transition:transform 0.2s" onmouseover="this.style.transform='translateY(-2px)'" onmouseout="this.style.transform='none'">XEQT ETF Review 2026: iShares All Equity ETF vs VEQT</a>
      <a href="/vti-etf-review-2026/" style="display:block;padding:16px;background:var(--card-bg,#0a1020);border:1px solid var(--border-color,#152040);border-radius:8px;text-decoration:none;color:var(--text-primary,#c8d0de);transition:transform 0.2s" onmouseover="this.style.transform='translateY(-2px)'" onmouseout="this.style.transform='none'">VTI ETF Review 2026: Vanguard Total Stock Market Analysis</a>
      <a href="/voo-etf-review-2026/" style="display:block;padding:16px;background:var(--card-bg,#0a1020);border:1px solid var(--border-color,#152040);border-radius:8px;text-decoration:none;color:var(--text-primary,#c8d0de);transition:transform 0.2s" onmouseover="this.style.transform='translateY(-2px)'" onmouseout="this.style.transform='none'">VOO ETF Review (2026): Vanguard S&P 500 Fees & Performance</a>
      <a href="/vea-etf-review-2026/" style="display:block;padding:16px;background:var(--card-bg,#0a1020);border:1px solid var(--border-color,#152040);border-radius:8px;text-decoration:none;color:var(--text-primary,#c8d0de);transition:transform 0.2s" onmouseover="this.style.transform='translateY(-2px)'" onmouseout="this.style.transform='none'">VEA ETF Review: Vanguard Developed Markets (2026)</a>
    </div>
  </section>
</SiteLayout>
