---
import SiteLayout from "../layouts/SiteLayout.astro";

// --- METADATA ---
export const meta = {
  title: "NVIDIA Corporation (NVDA) Intrinsic Value",
  description: "An independent discounted cash flow (DCF) intrinsic value analysis of NVIDIA Corporation (NVDA) compiled entirely by Gemini 3.1.",
  category: "study",
  published: "2026-03-18",
};

// --- DATA & ASSUMPTIONS (Most Recent Fiscal Year) ---
// The prompt requires me to make bold assumptions as Gemini.
// FCF Growth (Y1-Y5): 25%. NVIDIA's dominance in AI compute, networking, and software stacks, alongside massive continuous hyperscaler spend, will drive phenomenal cash generation for the foreseeable future.
// Discount Rate (WACC): 10.5%. While the risk-free rate is 4.18%, a semiconductor company naturally carries cyclicality and geopolitical risk (Taiwan exposure), warranting a slightly higher premium.
// Terminal Growth: 4.0%. Higher than standard GDP, acknowledging AI compute becoming a fundamental utility for the global economy.

const baseFCF = 58129; // in Millions (from $58.128B)
const sharesOut = 24300; // in Millions
const currentPrice = 182.69;
const netCash = 51144; // Total Cash (62.55B) - Total Debt (11.41B) in Millions

const fcfGrowthRate = 0.25;
const discountRate = 0.105;
const terminalGrowthRate = 0.040;

// --- YEAR 1 TO 5 PROJECTIONS ---
const projections = [];
let prevFCF = baseFCF;

for (let i = 1; i <= 5; i++) {
  const projectedFCF = prevFCF * (1 + fcfGrowthRate);
  const discountFactor = Math.pow(1 + discountRate, i);
  const pvOfFCF = projectedFCF / discountFactor;

  projections.push({
    year: `Year ${i}`,
    fcf: projectedFCF,
    pv: pvOfFCF
  });

  prevFCF = projectedFCF;
}

const sumPvFcf = projections.reduce((sum, p) => sum + p.pv, 0);

// --- TERMINAL VALUE ---
const year5FCF = projections[4].fcf;
const terminalValue = (year5FCF * (1 + terminalGrowthRate)) / (discountRate - terminalGrowthRate);
const pvTerminalValue = terminalValue / Math.pow(1 + discountRate, 5);

// --- INTRINSIC VALUE CALCULATION ---
const enterpriseValue = sumPvFcf + pvTerminalValue;
const totalEquityValue = enterpriseValue + netCash;
const intrinsicValuePerShare = totalEquityValue / sharesOut;

// Value vs Current Price
const marginOfSafety = ((intrinsicValuePerShare - currentPrice) / currentPrice) * 100;
const isUndervalued = intrinsicValuePerShare > currentPrice;

// --- SENSITIVITY MATRIX ---
const sensitivityDiscountRates = [0.095, 0.100, 0.105, 0.110, 0.115];
const sensitivityGrowthRates = [0.030, 0.035, 0.040, 0.045, 0.050];

const sensitivityMatrix = sensitivityGrowthRates.map(g => {
  return {
    growthRate: g,
    values: sensitivityDiscountRates.map(d => {
      // Re-calculate TV and PV with new rates
      const currentTerminalValue = (year5FCF * (1 + g)) / (d - g);
      const currentPvTerminalValue = currentTerminalValue / Math.pow(1 + d, 5);

      // Re-calculate PV of FCFs with new discount rate
      let currentSumPvFcf = 0;
      let tempFcf = baseFCF;
      for (let i = 1; i <= 5; i++) {
        tempFcf = tempFcf * (1 + fcfGrowthRate);
        currentSumPvFcf += tempFcf / Math.pow(1 + d, i);
      }

      const currentEV = currentSumPvFcf + currentPvTerminalValue;
      const currentEquity = currentEV + netCash;
      const currentIV = currentEquity / sharesOut;

      return currentIV;
    })
  };
});

// Formatting helpers
const formatMoney = (val) => new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD', minimumFractionDigits: 2, maximumFractionDigits: 2 }).format(val);
const formatMillions = (val) => '$' + new Intl.NumberFormat('en-US', { maximumFractionDigits: 0 }).format(val) + 'M';
const formatPercent = (val) => (val * 100).toFixed(1) + '%';

// --- SCHEMA ---
const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Article",
      "headline": meta.title,
      "description": meta.description,
      "author": {
        "@type": "Organization",
        "name": "Gemini 3.1"
      },
      "publisher": {
        "@type": "Organization",
        "name": "Westmount Fundamentals",
        "logo": {
          "@type": "ImageObject",
          "url": "https://westmountfundamentals.com/logo.png"
        }
      },
      "mainEntityOfPage": {
        "@type": "WebPage",
        "@id": "https://westmountfundamentals.com/nvidia-intrinsic-value"
      }
    },
    {
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "Why did Gemini project a 25% FCF growth rate for NVIDIA?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Gemini projects 25% growth because NVIDIA dominates the AI hardware and software ecosystem. Ongoing multi-billion dollar capex plans from major hyperscalers (Microsoft, Meta, Google, Amazon) ensure robust demand for next-generation architectures like Blackwell and Rubin."
          }
        },
        {
          "@type": "Question",
          "name": "What discount rate was used for NVIDIA's valuation?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "A 10.5% discount rate was used. This balances the 4.18% 10-year treasury rate with NVIDIA's relatively high beta, factoring in cyclical semiconductor demand and geopolitical risks surrounding Taiwan semiconductor manufacturing."
          }
        },
        {
          "@type": "Question",
          "name": "What is the terminal growth rate assumption for NVDA?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "The model uses a 4% terminal growth rate, slightly above standard historical GDP growth. This reflects the premise that AI computation will become an underlying, permanently growing utility for the broader digital economy."
          }
        }
      ]
    }
  ]
};
---
<SiteLayout site="westmount" title={meta.title} description={meta.description} canonical="https://westmountfundamentals.com/nvidia-intrinsic-value" schema={schema}>
  <div class="page-content">
    <div class="container">

      <div class="gemini-header">
        <div class="gemini-badge">COMPILED BY GEMINI 2.5 PRO</div>
        <h1>NVIDIA (NVDA) Intrinsic Value</h1>
        <p class="subtitle">An independent two-stage DCF analysis by a frontier AI model.</p>
      </div>

      <div class="verdict-card">
        <div class="verdict-header">
          <h2>Fair Value Estimate</h2>
        </div>
        <div class="verdict-body">
          <div class="verdict-main">
            <span class="iv-value">{formatMoney(intrinsicValuePerShare)}</span>
            <span class="iv-label">per share</span>
          </div>
          <div class="verdict-stats">
            <div class="stat">
              <span class="stat-label">Current Price</span>
              <span class="stat-value">{formatMoney(currentPrice)}</span>
            </div>
            <div class="stat">
              <span class="stat-label">Margin of Safety</span>
              <span class={`stat-value ${isUndervalued ? 'positive' : 'negative'}`}>
                {isUndervalued ? '+' : ''}{marginOfSafety.toFixed(2)}%
              </span>
            </div>
            <div class="stat">
              <span class="stat-label">Verdict</span>
              <span class={`badge ${isUndervalued ? 'positive' : 'negative'}`}>
                {isUndervalued ? 'UNDERVALUED' : 'OVERVALUED'}
              </span>
            </div>
          </div>
        </div>
        <div class="verdict-footer">
          <p>Based on most recent financials. Data via S&P Global (Mar 18, 2026).</p>
        </div>
      </div>

      <section class="content-section">
        <h2>The AI Thesis: Defining the Next Computation Era</h2>
        <p>NVIDIA Corporation is currently executing at a level previously unseen in the semiconductor industry, fundamentally reshaping the economics of computation. The rapid adoption of Generative AI across thousands of enterprises is not a transient trend, but a structural platform shift. NVIDIA's full-stack approach—combining world-class silicon architectures (Hopper, Blackwell, Rubin) with its ubiquitous CUDA software ecosystem—has created a nearly impenetrable moat.</p>
        <p>While some analysts argue that massive capital expenditures from cloud service providers (CSPs) cannot continue indefinitely, they underestimate the ROI these investments generate in software, reasoning systems, and autonomous robotics. My valuation model heavily factors in the sustained, high-margin cash flows stemming from NVIDIA's undisputed leadership in accelerated computing, projecting robust growth as inference workloads scale alongside model training.</p>
      </section>

      <section class="content-section">
        <h2>My Assumptions & Rationale</h2>

        <div class="assumption-grid">
          <div class="assumption-card">
            <div class="card-title">FCF Growth Rate (Y1-Y5)</div>
            <div class="card-value">{formatPercent(fcfGrowthRate)}</div>
            <p><strong>Rationale:</strong> A 25% growth rate is extraordinary for a company of this scale, yet justified. NVIDIA's datacenter revenue is supported by continuous, multi-billion dollar capex plans from Microsoft, Meta, Google, and Amazon. The transition from Hopper to Blackwell architectures alone represents a massive upgrade cycle, sustaining high margins and expanding free cash flow aggressively.</p>
          </div>

          <div class="assumption-card">
            <div class="card-title">Discount Rate (WACC)</div>
            <div class="card-value">{formatPercent(discountRate)}</div>
            <p><strong>Rationale:</strong> The 10.5% discount rate accounts for the inherent cyclicality of the semiconductor industry. While the 10-year treasury rate sits at 4.18%, NVIDIA's historical beta remains above the market average. Furthermore, the reliance on TSMC introduces geopolitical risk (Taiwan exposure), warranting a higher risk premium to discount future cash flows.</p>
          </div>

          <div class="assumption-card">
            <div class="card-title">Terminal Growth Rate</div>
            <div class="card-value">{formatPercent(terminalGrowthRate)}</div>
            <p><strong>Rationale:</strong> 4.0% sits slightly above long-term global GDP forecasts. This assumes that AI computing transitions from a hyper-growth phase into a foundational utility—similar to electricity or cloud storage—with deeply embedded structural growth outperforming the broader economy indefinitely.</p>
          </div>
        </div>
      </section>

      <section class="content-section">
        <h2>Discounted Cash Flow (DCF) Projections</h2>
        <p>Starting with the current base FCF of {formatMillions(baseFCF)}, the table below outlines the 5-year projection discounted back to Present Value (PV) using the {formatPercent(discountRate)} WACC.</p>

        <div class="table-container">
          <table>
            <thead>
              <tr>
                <th>Period</th>
                <th>Projected FCF</th>
                <th>PV Factor ({formatPercent(discountRate)})</th>
                <th>Present Value</th>
              </tr>
            </thead>
            <tbody>
              {projections.map((p, index) => (
                <tr>
                  <td>{p.year}</td>
                  <td>{formatMillions(p.fcf)}</td>
                  <td>{(1 / Math.pow(1 + discountRate, index + 1)).toFixed(4)}</td>
                  <td>{formatMillions(p.pv)}</td>
                </tr>
              ))}
              <tr class="highlight-row">
                <td colspan="3"><strong>Sum of PV of FCFs (Years 1-5)</strong></td>
                <td><strong>{formatMillions(sumPvFcf)}</strong></td>
              </tr>
            </tbody>
          </table>
        </div>
      </section>

      <section class="content-section">
        <h2>Terminal & Final Valuation Math</h2>
        <p>The Terminal Value accounts for all cash flows from Year 6 into perpetuity, calculated using the Gordon Growth Model.</p>

        <div class="math-card">
          <div class="math-row">
            <span>Year 5 FCF</span>
            <span>{formatMillions(year5FCF)}</span>
          </div>
          <div class="math-row">
            <span>Terminal Value (TV) Calculation</span>
            <span>({formatMillions(year5FCF)} * {1 + terminalGrowthRate}) / ({discountRate} - {terminalGrowthRate})</span>
          </div>
          <div class="math-row">
            <span>Terminal Value</span>
            <span>{formatMillions(terminalValue)}</span>
          </div>
          <div class="math-row highlight">
            <span>PV of Terminal Value</span>
            <span>{formatMillions(pvTerminalValue)}</span>
          </div>
        </div>

        <p style="margin-top: 2rem;">Adding it all together with Net Cash:</p>

        <div class="math-card">
          <div class="math-row">
            <span>Sum of PV of FCFs (Years 1-5)</span>
            <span>{formatMillions(sumPvFcf)}</span>
          </div>
          <div class="math-row">
            <span>+ PV of Terminal Value</span>
            <span>{formatMillions(pvTerminalValue)}</span>
          </div>
          <div class="math-row">
            <span><strong>= Enterprise Value</strong></span>
            <span><strong>{formatMillions(enterpriseValue)}</strong></span>
          </div>
          <div class="math-row">
            <span>+ Net Cash (Cash - Debt)</span>
            <span>{formatMillions(netCash)}</span>
          </div>
          <div class="math-row highlight">
            <span><strong>= Total Equity Value</strong></span>
            <span><strong>{formatMillions(totalEquityValue)}</strong></span>
          </div>
          <div class="math-row">
            <span>÷ Shares Outstanding</span>
            <span>{sharesOut.toLocaleString()}M</span>
          </div>
          <div class="math-row result">
            <span><strong>Intrinsic Value Per Share</strong></span>
            <span><strong>{formatMoney(intrinsicValuePerShare)}</strong></span>
          </div>
        </div>
      </section>

      <section class="content-section">
        <h2>Sensitivity Matrix</h2>
        <p>A single intrinsic value relies on rigid assumptions. The sensitivity matrix below demonstrates how the intrinsic value changes when we adjust the Discount Rate (WACC) and the Terminal Growth Rate.</p>

        <div class="table-container sensitivity-table">
          <table>
            <thead>
              <tr>
                <th rowspan="2" class="corner-cell">Terminal<br/>Growth</th>
                <th colspan="5" class="header-cell">Discount Rate (WACC)</th>
              </tr>
              <tr>
                {sensitivityDiscountRates.map(d => <th>{formatPercent(d)}</th>)}
              </tr>
            </thead>
            <tbody>
              {sensitivityMatrix.map(row => (
                <tr>
                  <th class="row-header">{formatPercent(row.growthRate)}</th>
                  {row.values.map(val => (
                    <td class={
                      val > currentPrice * 1.15 ? "cell-undervalued" :
                      val < currentPrice * 0.85 ? "cell-overvalued" :
                      "cell-neutral"
                    }>
                      {formatMoney(val)}
                    </td>
                  ))}
                </tr>
              ))}
            </tbody>
          </table>
          <div class="matrix-legend">
            <span class="legend-item"><span class="color-box cell-undervalued"></span> Undervalued (>15% Margin)</span>
            <span class="legend-item"><span class="color-box cell-neutral"></span> Fair Value</span>
            <span class="legend-item"><span class="color-box cell-overvalued"></span> Overvalued (&lt;-15% Margin)</span>
          </div>
        </div>
      </section>

      <section class="content-section risks-section">
        <h2>Risks & Bear Case</h2>
        <p>While my valuation is bullish, a balanced analysis requires identifying the key vectors that could disrupt these assumptions:</p>
        <div class="risk-grid">
          <div class="risk-card">
            <h3>1. Hyperscaler CapEx Digestion</h3>
            <p>The primary risk is a slowdown in spending by major cloud providers. If the economic return on AI inference fails to materialize as rapidly as projected, tech giants may temporarily pause infrastructure orders to digest existing capacity, severely impacting NVIDIA's revenue growth.</p>
          </div>
          <div class="risk-card">
            <h3>2. Geopolitical & Supply Chain Disruption</h3>
            <p>NVIDIA relies heavily on TSMC for manufacturing its most advanced chips. Any escalation of tensions in the Taiwan Strait or disruptions to the complex global semiconductor supply chain would immediately jeopardize NVIDIA's ability to fulfill its massive backlog.</p>
          </div>
          <div class="risk-card">
            <h3>3. Emergence of Custom Silicon (ASICs)</h3>
            <p>While CUDA provides a massive software advantage, major customers like Google (TPU), Amazon (Trainium/Inferentia), and Meta (MTIA) are aggressively investing in their own custom AI accelerators. A shift away from general-purpose GPUs toward specialized ASICs for inference could compress NVIDIA's margins over the long term.</p>
          </div>
        </div>
      </section>

      <section class="content-section faq-section">
        <h2>Frequently Asked Questions</h2>

        <div class="faq-item">
          <h3>Why did Gemini project a 25% FCF growth rate for NVIDIA?</h3>
          <p>Gemini projects 25% growth because NVIDIA dominates the AI hardware and software ecosystem. Ongoing multi-billion dollar capex plans from major hyperscalers (Microsoft, Meta, Google, Amazon) ensure robust demand for next-generation architectures like Blackwell and Rubin.</p>
        </div>

        <div class="faq-item">
          <h3>What discount rate was used for NVIDIA's valuation?</h3>
          <p>A 10.5% discount rate was used. This balances the 4.18% 10-year treasury rate with NVIDIA's relatively high beta, factoring in cyclical semiconductor demand and geopolitical risks surrounding Taiwan semiconductor manufacturing.</p>
        </div>

        <div class="faq-item">
          <h3>What is the terminal growth rate assumption for NVDA?</h3>
          <p>The model uses a 4% terminal growth rate, slightly above standard historical GDP growth. This reflects the premise that AI computation will become an underlying, permanently growing utility for the broader digital economy.</p>
        </div>
      </section>

      <div class="disclaimer-box">
        <p><strong>Disclaimer:</strong> The numbers presented on this page are for educational and entertainment purposes only. They are the result of a deterministic mathematical model fed with assumptions generated by an Artificial Intelligence (Gemini 3.1). This does not constitute investment advice. Always conduct your own due diligence before investing in the stock market.</p>
      </div>

    </div>
  </div>
</SiteLayout>
