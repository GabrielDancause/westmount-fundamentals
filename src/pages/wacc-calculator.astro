  <script is:inline src="https://cdn.jsdelivr.net/npm/chart.js"></script>
  <script is:inline>
  (function() {
    function initWACCPage() {
      var form = document.getElementById('wacc-form');
      if (!form || form.dataset.initialized) return;
      form.dataset.initialized = 'true';

      // ============ UTILITY ============
      function fmt(v, d) { return (v * 100).toFixed(d || 2) + '%'; }
      function fmtNum(v) { return v.toFixed(2) + '%'; }

      // ============ WACC CALCULATOR ============
      var eqVal = document.getElementById('equity-value');
      var debtVal = document.getElementById('debt-value');
      var costEq = document.getElementById('cost-equity');
      var costDebt = document.getElementById('cost-debt');
      var taxRate = document.getElementById('tax-rate');

      var structureChart = null;

      function calcWACC() {
        var E = parseFloat(eqVal.value) || 0;
        var D = parseFloat(debtVal.value) || 0;
        var Re = parseFloat(costEq.value) / 100 || 0;
        var Rd = parseFloat(costDebt.value) / 100 || 0;
        var T = parseFloat(taxRate.value) / 100 || 0;
        var V = E + D;
        if (V === 0) return;

        var wE = E / V;
        var wD = D / V;
        var afterTaxRd = Rd * (1 - T);
        var wacc = (wE * Re) + (wD * afterTaxRd);

        document.getElementById('wacc-result').textContent = fmtNum(wacc * 100);
        document.getElementById('equity-weight').textContent = fmt(wE);
        document.getElementById('debt-weight').textContent = fmt(wD);
        document.getElementById('after-tax-debt').textContent = fmt(afterTaxRd);
        document.getElementById('equity-contribution').textContent = fmt(wE * Re);

        // Update doughnut
        if (structureChart) {
          structureChart.data.datasets[0].data = [E, D];
          structureChart.update();
        }
      }

      [eqVal, debtVal, costEq, costDebt, taxRate].forEach(function(el) {
        el.addEventListener('input', calcWACC);
      });

      // Doughnut chart
      var ctx1 = document.getElementById('structure-chart');
      if (ctx1) {
        structureChart = new Chart(ctx1.getContext('2d'), {
          type: 'doughnut',
          data: {
            labels: ['Equity', 'Debt'],
            datasets: [{
              data: [800000000, 200000000],
              backgroundColor: ['#4a8fe7', '#ef4444'],
              borderColor: ['#4a8fe7', '#ef4444'],
              borderWidth: 1
            }]
          },
          options: {
            responsive: true,
            plugins: {
              legend: { position: 'bottom', labels: { color: '#c8d0de', padding: 16 } },
              tooltip: {
                callbacks: {
                  label: function(ctx) {
                    var total = ctx.dataset.data[0] + ctx.dataset.data[1];
                    var pct = total > 0 ? ((ctx.raw / total) * 100).toFixed(1) : '0';
                    return ctx.label + ': ' + pct + '%';
                  }
                }
              }
            }
          }
        });
      }

      calcWACC();

      // ============ CAPM ============
      var rfInput = document.getElementById('risk-free');
      var betaInput = document.getElementById('beta');
      var mrInput = document.getElementById('market-return');

      function calcCAPM() {
        var rf = parseFloat(rfInput.value) / 100 || 0;
        var beta = parseFloat(betaInput.value) || 0;
        var rm = parseFloat(mrInput.value) / 100 || 0;
        var erp = rm - rf;
        var re = rf + beta * erp;
        document.getElementById('capm-result').textContent = fmtNum(re * 100);
        document.getElementById('erp-value').textContent = fmt(erp);
        document.getElementById('beta-premium').textContent = fmt(beta * erp);
      }

      [rfInput, betaInput, mrInput].forEach(function(el) {
        el.addEventListener('input', calcCAPM);
      });
      calcCAPM();

      // Use CAPM result in WACC
      var useCAPMBtn = document.getElementById('use-capm-btn');
      if (useCAPMBtn) {
        useCAPMBtn.addEventListener('click', function() {
          var rf = parseFloat(rfInput.value) / 100 || 0;
          var beta = parseFloat(betaInput.value) || 0;
          var rm = parseFloat(mrInput.value) / 100 || 0;
          var re = rf + beta * (rm - rf);
          costEq.value = (re * 100).toFixed(2);
          calcWACC();
          eqVal.scrollIntoView({ behavior: 'smooth', block: 'center' });
        });
      }

      // ============ AFTER-TAX COST OF DEBT ============
      var pretaxDebt = document.getElementById('pretax-debt');
      var debtTaxRate = document.getElementById('debt-tax-rate');

      function calcAfterTaxDebt() {
        var rd = parseFloat(pretaxDebt.value) / 100 || 0;
        var t = parseFloat(debtTaxRate.value) / 100 || 0;
        var afterTax = rd * (1 - t);
        var shield = rd * t;
        document.getElementById('aftertax-result').textContent = fmtNum(afterTax * 100);
        document.getElementById('tax-shield-value').textContent = fmt(shield);
        document.getElementById('rate-reduction').textContent = fmt(t);
      }

      [pretaxDebt, debtTaxRate].forEach(function(el) {
        el.addEventListener('input', calcAfterTaxDebt);
      });
      calcAfterTaxDebt();

      // ============ SENSITIVITY TABLE ============
      var sensBody = document.getElementById('sensitivity-body');
      if (sensBody) {
        var debtPcts = [0, 10, 20, 30, 40, 50, 60, 70, 80];
        var reAssumptions = [0.08, 0.10, 0.12, 0.14];
        var rdBase = 0.05;
        var tBase = 0.21;

        debtPcts.forEach(function(dp) {
          var row = document.createElement('tr');
          var cell0 = document.createElement('td');
          cell0.textContent = dp + '%';
          row.appendChild(cell0);

          reAssumptions.forEach(function(re) {
            var wD = dp / 100;
            var wE = 1 - wD;
            var wacc = (wE * re) + (wD * rdBase * (1 - tBase));
            var cell = document.createElement('td');
            cell.textContent = (wacc * 100).toFixed(2) + '%';
            if (dp === 20 || dp === 30) cell.style.color = '#10b981';
            row.appendChild(cell);
          });
          sensBody.appendChild(row);
        });
      }

      // ============ WACC CURVE CHART ============
      var ctx2 = document.getElementById('wacc-curve-chart');
      if (ctx2) {
        var labels2 = [];
        var dataPoints = [];
        var baseRe = 0.10;
        var baseRd = 0.04;
        for (var i = 0; i <= 90; i += 5) {
          labels2.push(i + '%');
          var wD2 = i / 100;
          var wE2 = 1 - wD2;
          // Cost of equity rises with leverage, cost of debt rises at high leverage
          var leveragedRe = baseRe + (wD2 * 0.04); // equity risk increases with debt
          var leveragedRd = baseRd + Math.max(0, (wD2 - 0.4) * 0.08); // debt cost spikes after 40%
          var waccVal = (wE2 * leveragedRe) + (wD2 * leveragedRd * (1 - 0.21));
          dataPoints.push((waccVal * 100).toFixed(2));
        }

        new Chart(ctx2.getContext('2d'), {
          type: 'line',
          data: {
            labels: labels2,
            datasets: [{
              label: 'WACC (%)',
              data: dataPoints,
              borderColor: '#4a8fe7',
              backgroundColor: 'rgba(74,143,231,0.1)',
              fill: true,
              tension: 0.4,
              pointBackgroundColor: '#4a8fe7',
              pointRadius: 4,
              pointHoverRadius: 6
            }]
          },
          options: {
            responsive: true,
            scales: {
              x: {
                title: { display: true, text: 'Debt as % of Total Capital', color: '#94a3b8' },
                ticks: { color: '#94a3b8' },
                grid: { color: 'rgba(48,54,61,0.5)' }
              },
              y: {
                title: { display: true, text: 'WACC (%)', color: '#94a3b8' },
                ticks: { color: '#94a3b8', callback: function(v) { return v + '%'; } },
                grid: { color: 'rgba(48,54,61,0.5)' }
              }
            },
            plugins: {
              legend: { labels: { color: '#c8d0de' } },
              tooltip: { callbacks: { label: function(ctx) { return 'WACC: ' + ctx.raw + '%'; } } }
            }
          }
        });
      }

      // ============ INDUSTRY CHART ============
      var ctx3 = document.getElementById('industry-chart');
      if (ctx3) {
        var industries = ['Utilities', 'REITs', 'Consumer Staples', 'Telecom', 'Industrials', 'Energy', 'Healthcare', 'Financials', 'Technology', 'Biotech'];
        var lowVals = [5.0, 5.5, 6.0, 6.0, 7.5, 7.0, 8.0, 8.0, 8.0, 9.0];
        var highVals = [7.0, 8.0, 8.0, 8.5, 9.5, 10.0, 10.0, 11.0, 12.0, 13.0];
        var rangeData = highVals.map(function(h, idx) { return h - lowVals[idx]; });

        new Chart(ctx3.getContext('2d'), {
          type: 'bar',
          data: {
            labels: industries,
            datasets: [
              {
                label: 'Min WACC',
                data: lowVals,
                backgroundColor: 'rgba(74,143,231,0.15)',
                borderColor: 'transparent',
                borderWidth: 0
              },
              {
                label: 'Range',
                data: rangeData,
                backgroundColor: 'rgba(74,143,231,0.7)',
                borderColor: '#4a8fe7',
                borderWidth: 1
              }
            ]
          },
          options: {
            indexAxis: 'y',
            responsive: true,
            scales: {
              x: {
                stacked: true,
                title: { display: true, text: 'WACC (%)', color: '#94a3b8' },
                ticks: { color: '#94a3b8', callback: function(v) { return v + '%'; } },
                grid: { color: 'rgba(48,54,61,0.5)' },
                min: 0,
                max: 16
              },
              y: {
                stacked: true,
                ticks: { color: '#c8d0de' },
                grid: { display: false }
              }
            },
            plugins: {
              legend: { display: false },
              tooltip: {
                callbacks: {
                  label: function(ctx) {
                    var idx = ctx.dataIndex;
                    return industries[idx] + ': ' + lowVals[idx] + '% – ' + highVals[idx] + '%';
                  }
                }
              }
            }
          }
        });
      }
    }

    document.addEventListener('DOMContentLoaded', initWACCPage);
    document.addEventListener('astro:page-load', initWACCPage);
  })();
  </script>

