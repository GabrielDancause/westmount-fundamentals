      const rect = canvas.getBoundingClientRect();
      const x = e.clientX - rect.left;
      const y = e.clientY - rect.top;

      let hovered = false;
      for (let bar of chartBars) {
        if (x >= bar.x && x <= bar.x + bar.w) {
          tooltip.style.opacity = '1';
          const sign = bar.return > 0 ? '+' : '';
          tooltip.innerHTML = `<strong>${bar.year}</strong><br><span style="color: ${bar.color}">${sign}${bar.return.toFixed(2)}%</span>`;

