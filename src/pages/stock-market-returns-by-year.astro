      ctx.lineWidth = 1;
      ctx.moveTo(padding.left, zeroY);
      ctx.lineTo(width - padding.right, zeroY);
      ctx.stroke();

      const barWidth = chartWidth / chartData.length;
      chartBars.length = 0; // Clear previous bars

      chartData.forEach((d, i) => {
        const x = padding.left + i * barWidth;
        const barHeight = Math.abs((d.return / yRange) * chartHeight);
        const y = d.return >= 0 ? zeroY - barHeight : zeroY;

        ctx.fillStyle = d.return >= 0 ? '#10b981' : '#ef4444';

        const rectW = Math.max(barWidth - 1, 1);
        ctx.fillRect(x, y, rectW, barHeight);

        chartBars.push({
          year: d.year,
          return: d.return,
          x: x,
          y: d.return >= 0 ? y : zeroY,
          w: rectW,
          h: barHeight,
          color: d.return >= 0 ? '#10b981' : '#ef4444'
        });

        if (i % 10 === 0 && i !== 0) {
          ctx.fillStyle = '#8892b0';
          ctx.textAlign = 'center';
          ctx.textBaseline = 'top';
          ctx.fillText(d.year, x + barWidth / 2, padding.top + chartHeight + 10);
        }
      });
