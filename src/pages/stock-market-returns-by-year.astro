      const yMax = Math.ceil(maxReturn / 10) * 10;
      const yMin = Math.floor(minReturn / 10) * 10;
      const yRange = yMax - yMin;

      const zeroY = padding.top + chartHeight - ((0 - yMin) / yRange) * chartHeight;

      ctx.beginPath();
      ctx.strokeStyle = '#152040';
      ctx.lineWidth = 1;
      for (let i = yMin; i <= yMax; i += 20) {
        const y = padding.top + chartHeight - ((i - yMin) / yRange) * chartHeight;
        ctx.moveTo(padding.left, y);
        ctx.lineTo(width - padding.right, y);
      }
      ctx.stroke();

      ctx.fillStyle = '#8892b0';
      ctx.font = '12px "JetBrains Mono", monospace';
      ctx.textAlign = 'right';
