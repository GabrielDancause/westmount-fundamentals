---
import SiteLayout from "../layouts/SiteLayout.astro";
import * as cheerio from 'cheerio';

const schema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": "S&P Global (SPGI) Intrinsic Value: A DCF Analysis",
  "description": "A transparent, step-by-step discounted cash flow valuation of S&P Global Inc. Using actual financials to arrive at a single fair value estimate for SPGI shares.",
  "datePublished": "2026-03-18",
  "dateModified": "2026-03-18",
  "author": {
    "@type": "Organization",
    "name": "Westmount Research",
    "url": "https://westmountfundamentals.com"
  },
  "publisher": {
    "@type": "Organization",
    "name": "Westmount Research",
    "url": "https://westmountfundamentals.com"
  },
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": "https://westmountfundamentals.com/sp-global-intrinsic-value"
  }
};

export const meta = {
  title: "S&P Global (SPGI) Intrinsic Value: A DCF Analysis",
  description: "We ran a full discounted cash flow on S&P Global using actuals. One number. Every assumption disclosed. Here's what SPGI is really worth.",
  category: "study",
  published: "2026-03-18",
};

/* ═══════════════════════════════════════════════════════════════
   DATA FETCHING
   Fetch from https://stockanalysis.com/stocks/spgi/financials/
   and /cash-flow-statement/ and /balance-sheet/
   ═══════════════════════════════════════════════════════════════ */

async function fetchHTML(url: string) {
  try {
    const res = await fetch(url, { headers: { 'User-Agent': 'Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/91.0.4472.124 Safari/537.36' } });
    if (!res.ok) return null;
    return await res.text();
  } catch (e) {
    return null;
  }
}

const [financialsHTML, cfsHTML, bsHTML, profileHTML] = await Promise.all([
  fetchHTML('https://stockanalysis.com/stocks/spgi/financials/'),
  fetchHTML('https://stockanalysis.com/stocks/spgi/financials/cash-flow-statement/'),
  fetchHTML('https://stockanalysis.com/stocks/spgi/financials/balance-sheet/'),
  fetchHTML('https://stockanalysis.com/stocks/spgi/')
]);

let currentPrice: number | null = null;
let rawRevenue: string[] = [];
let rawEPS: string[] = [];
let rawShares: string[] = [];
let rawFCF: string[] = [];
let rawCash: string[] = [];
let rawDebt: string[] = [];
let rawOperatingIncome: string[] = [];
let rawNetIncome: string[] = [];
let years: string[] = [];

if (financialsHTML && cfsHTML && bsHTML && profileHTML) {
  const $fin = cheerio.load(financialsHTML);
  const $cfs = cheerio.load(cfsHTML);
  const $bs = cheerio.load(bsHTML);
  const $prof = cheerio.load(profileHTML);

  const priceText = $prof('.text-4xl.font-bold').first().text().trim();
  currentPrice = parseFloat(priceText.replace(/,/g, ''));

  const getRowData = ($: any, rowName: string) => {
    let data: string[] = [];
    $('table tbody tr').each((i: number, el: any) => {
      const firstTd = $(el).find('td').first().text().trim();
      if (firstTd === rowName) {
        $(el).find('td').each((j: number, td: any) => {
          if (j > 0) data.push($(td).text().trim());
        });
      }
    });
    return data;
  };

  const getHeaderYears = ($: any) => {
    let data: string[] = [];
    $('table thead tr th').each((i: number, el: any) => {
      if (i > 0) {
          const text = $(el).text().trim();
          data.push(text.split(' ')[1] || text);
      }
    });
    return data;
  };

  years = getHeaderYears($fin).slice(0, 5);
  rawRevenue = getRowData($fin, 'Revenue');
  rawEPS = getRowData($fin, 'EPS (Diluted)');
  rawShares = getRowData($fin, 'Shares Outstanding (Diluted)');
  rawFCF = getRowData($cfs, 'Free Cash Flow');
  rawCash = getRowData($bs, 'Cash & Equivalents');
  rawDebt = getRowData($bs, 'Total Debt');
  rawOperatingIncome = getRowData($fin, 'Operating Income');
  rawNetIncome = getRowData($fin, 'Net Income');
}

const parseNum = (arr: string[], idx: number) => {
  if (!arr || arr.length <= idx) return null;
  const val = arr[idx];
  if (val === '-' || val === '') return null;
  return parseFloat(val.replace(/,/g, ''));
};

const revCurrent = parseNum(rawRevenue, 0);
const epsCurrent = parseNum(rawEPS, 0);
const fcfCurrent = parseNum(rawFCF, 0);
const sharesCurrent = parseNum(rawShares, 0);
const cashCurrent = parseNum(rawCash, 0);
const debtCurrent = parseNum(rawDebt, 0);

/* ═══════════════════════════════════════════════════════════════
   DCF MODEL — ALL INPUTS AND CALCULATIONS
   We use a two-stage DCF: high-growth phase (Years 1-5) then terminal value.
   ═══════════════════════════════════════════════════════════════ */

// Ensure all inputs exist before calculating
const hasData = fcfCurrent !== null && sharesCurrent !== null && cashCurrent !== null && debtCurrent !== null && currentPrice !== null;

const fcfBase = fcfCurrent || 0; // $M
const sharesOutstanding = sharesCurrent || 0; // $M
const cashAndInvestments = cashCurrent || 0; // $M
const totalDebt = debtCurrent || 0; // $M
const netCash = cashAndInvestments - totalDebt;

// --- ASSUMPTIONS (fully disclosed below) ---
// Rationale: S&P Global operates oligopoly businesses (ratings, index, analytics).
// Has consistent pricing power. Moderate growth but very high margins.
const growthRatePhase1 = 0.08;         // 8% FCF growth, Years 1-5
const growthRateTerminal = 0.035;      // 3.5% perpetuity growth (terminal)
// WACC logic: 10Y Treasury = 4.18%. Beta ~ 1.0. Equity Risk Premium ~ 5%.
// WACC around 9%. Using 9% as discount rate.
const discountRate = 0.09;             // 9% WACC / required return

// --- PHASE 1: PROJECT FCF FOR YEARS 1-5 ---
const projectedFCF: { year: number; fcf: number; pvFactor: number; pvFCF: number; }[] = [];
let fcf = fcfBase;
let pvPhase1 = 0;
for (let yr = 1; yr <= 5; yr++) {
  fcf = fcf * (1 + growthRatePhase1);
  const pvFactor = 1 / Math.pow(1 + discountRate, yr);
  const pvFCF = Math.round(fcf * pvFactor);
  projectedFCF.push({ year: yr, fcf: Math.round(fcf), pvFactor, pvFCF });
  pvPhase1 += pvFCF;
}

// --- PHASE 2: TERMINAL VALUE (Gordon Growth Model) ---
const fcfYear6 = projectedFCF.length > 0 ? projectedFCF[4].fcf * (1 + growthRateTerminal) : 0;
const terminalValue = Math.round(fcfYear6 / (discountRate - growthRateTerminal));
const pvTerminalValue = projectedFCF.length > 0 ? Math.round(terminalValue * projectedFCF[4].pvFactor) : 0;

// --- ENTERPRISE VALUE ---
const enterpriseValue = pvPhase1 + pvTerminalValue;

// --- EQUITY VALUE ---
const equityValue = enterpriseValue + netCash;
const intrinsicValuePerShare = sharesOutstanding > 0 ? equityValue / sharesOutstanding : 0;
const roundedIV = Math.round(intrinsicValuePerShare * 100) / 100;

// Market comparison
let marginOfSafety: string | null = null;
let verdictText = "N/A";
let verdictColor = "#7a8a9e";

if (hasData && currentPrice) {
    marginOfSafety = (((roundedIV - currentPrice) / currentPrice) * 100).toFixed(1);
    verdictText = roundedIV > currentPrice ? "Undervalued" : "Overvalued";
    verdictColor = roundedIV > currentPrice ? "#10b981" : "#ef4444";
}

// --- HISTORICAL DATA for charts ---
const revenueHistory: { year: string; value: number }[] = [];
const fcfHistory: { year: string; value: number }[] = [];
const epsHistory: { year: string; value: number }[] = [];
const marginHistory: { year: string; operating: string; profit: string; fcfMargin: string }[] = [];

for (let i = 4; i >= 0; i--) {
    const yrText = years[i] || `Y${5-i}`;
    const rev = parseNum(rawRevenue, i);
    const f = parseNum(rawFCF, i);
    const eps = parseNum(rawEPS, i);
    const opInc = parseNum(rawOperatingIncome, i);
    const netInc = parseNum(rawNetIncome, i);

    if (rev !== null) revenueHistory.push({ year: yrText, value: rev });
    if (f !== null) fcfHistory.push({ year: yrText, value: f });
    if (eps !== null) epsHistory.push({ year: yrText, value: eps });

    if (rev !== null && opInc !== null && netInc !== null && f !== null && rev > 0) {
        marginHistory.push({
            year: yrText,
            operating: ((opInc / rev) * 100).toFixed(1),
            profit: ((netInc / rev) * 100).toFixed(1),
            fcfMargin: ((f / rev) * 100).toFixed(1)
        });
    }
}

// Sensitivity analysis
const sensitivityRates = [0.07, 0.08, 0.09, 0.10, 0.11];
const sensitivityGrowth = [0.04, 0.06, 0.08, 0.10, 0.12];
const sensitivityTable = sensitivityRates.map(dr => {
  return {
    dr,
    values: sensitivityGrowth.map(gr => {
      if (!hasData) return null;
      let tempFcf = fcfBase;
      let pvSum = 0;
      for (let y = 1; y <= 5; y++) {
        tempFcf = tempFcf * (1 + gr);
        pvSum += tempFcf / Math.pow(1 + dr, y);
      }
      const f6 = tempFcf * (1 + growthRateTerminal);
      const tv = f6 / (dr - growthRateTerminal);
      const pvTV = tv / Math.pow(1 + dr, 5);
      return Math.round((pvSum + pvTV + netCash) / sharesOutstanding);
    })
  };
});
---

<SiteLayout
  site="westmount"
  title={meta.title}
  description={meta.description}
  canonical="https://westmountfundamentals.com/sp-global-intrinsic-value"
