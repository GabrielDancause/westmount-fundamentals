---
import SiteLayout from "../layouts/SiteLayout.astro";
import * as cheerio from 'cheerio';

const schema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": "Thermo Fisher Scientific (TMO) Intrinsic Value: A DCF Analysis",
  "description": "A transparent, step-by-step discounted cash flow valuation of Thermo Fisher Scientific Inc. Using recent financials to arrive at a single fair value estimate for TMO shares.",
  "datePublished": new Date().toISOString().split('T')[0],
  "dateModified": new Date().toISOString().split('T')[0],
  "author": {
    "@type": "Organization",
    "name": "Westmount Research",
    "url": "https://westmountfundamentals.com"
  },
  "publisher": {
    "@type": "Organization",
    "name": "Westmount Research",
    "url": "https://westmountfundamentals.com"
  },
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": "https://westmountfundamentals.com/thermo-fisher-intrinsic-value"
  }
};

export const meta = {
  title: "Thermo Fisher Scientific (TMO) Intrinsic Value: A DCF Analysis",
  description: "We ran a full discounted cash flow on Thermo Fisher Scientific. One number. Every assumption disclosed. Here's what TMO is really worth.",
  category: "study",
  published: new Date().toISOString().split('T')[0],
};

// --- DATA FETCHING (stockanalysis.com) ---
async function fetchHTML(url) {
  try {
    const response = await fetch(url, {
      headers: {
        'User-Agent': 'Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36',
        'Accept': 'text/html,application/xhtml+xml,application/xml;q=0.9,image/avif,image/webp,*/*;q=0.8',
        'Accept-Language': 'en-US,en;q=0.5',
      }
    });
    if (!response.ok) return null;
    return await response.text();
  } catch (e) {
    console.error(`Failed to fetch ${url}:`, e);
    return null;
  }
}

function extractTableData(html, rowNames) {
  if (!html) return {};
  const $ = cheerio.load(html);
  const data = {};

  $('table tbody tr').each((i, tr) => {
    const rowName = $(tr).find('td').first().text().trim();
    if (rowNames.includes(rowName)) {
      const values = [];
      $(tr).find('td').each((j, td) => {
        if (j > 0) { // skip row header
          let val = $(td).text().trim().replace(/,/g, '');
          if (val === '-' || val === '') {
            values.push(null);
          } else {
            values.push(parseFloat(val));
          }
        }
      });
      data[rowName] = values;
    }
  });

  // Get years from headers
  const years = [];
  $('table thead tr th').each((i, el) => {
    if (i > 0) {
      let thText = $(el).text().trim();
      years.push(thText);
    }
  });
  data['_years'] = years;

  return data;
}

const [htmlIncome, htmlCashflow, htmlBalanceSheet] = await Promise.all([
  fetchHTML('https://stockanalysis.com/stocks/tmo/financials/'),
  fetchHTML('https://stockanalysis.com/stocks/tmo/financials/cash-flow-statement/'),
  fetchHTML('https://stockanalysis.com/stocks/tmo/financials/balance-sheet/')
]);

const incData = extractTableData(htmlIncome, ['Revenue', 'EPS (Diluted)', 'Shares Outstanding (Diluted)', 'Operating Margin', 'Profit Margin']);
const cfData = extractTableData(htmlCashflow, ['Free Cash Flow', 'FCF Margin']);
const bsData = extractTableData(htmlBalanceSheet, ['Cash & Equivalents', 'Short-Term Investments', 'Total Debt']);

// Safely get the most recent valid value from an array
function getRecentValue(arr) {
  if (!arr || !Array.isArray(arr)) return null;
  for (let val of arr) {
    if (val !== null && !isNaN(val)) return val;
  }
  return null;
}

// Get array of valid values for historical charts (up to 5 years, reverse order so oldest is first)
function getHistoricalValues(arr) {
  if (!arr || !Array.isArray(arr)) return [];
  // Take first 5, reverse them. Filter out nulls if possible, or leave them.
  return arr.slice(0, 5).reverse();
}

function getYears(arr) {
  if (!arr || !Array.isArray(arr)) return [];
  return arr.slice(0, 5).map(y => y.replace(/FY /, '')).reverse();
}


// Extract the inputs
const latestShares = getRecentValue(incData['Shares Outstanding (Diluted)']); // in millions
const latestFCF = getRecentValue(cfData['Free Cash Flow']); // in millions
const cashEq = getRecentValue(bsData['Cash & Equivalents']) || 0;
const stInv = getRecentValue(bsData['Short-Term Investments']) || 0;
const totalDebt = getRecentValue(bsData['Total Debt']) || 0;

const profileHtml = await fetchHTML('https://stockanalysis.com/stocks/tmo/');
let fetchedPrice = 580.00; // fallback
if (profileHtml) {
  const $ = cheerio.load(profileHtml);
  const priceText = $('.text-4xl.font-bold.inline-block').first().text().trim().replace(/,/g, '');
  if (priceText) {
    fetchedPrice = parseFloat(priceText);
  }
}


/* ═══════════════════════════════════════════════════════════════
   DCF MODEL — ALL INPUTS AND CALCULATIONS
   ═══════════════════════════════════════════════════════════════ */

// --- INPUTS ---
const fcfBase = latestFCF;
const sharesOutstanding = latestShares;
const cashAndInvestments = cashEq + stInv;
const netCash = cashAndInvestments - totalDebt;

// --- ASSUMPTIONS ---
const growthRatePhase1 = 0.08;         // 8% FCF growth, Years 1-5 (Life sciences tool normalization)
const growthRateTerminal = 0.03;       // 3% perpetuity growth (terminal)
const discountRate = 0.08;             // 8% WACC / required return (10Y Treasury 4.18% + ERP)

// --- PHASE 1: PROJECT FCF FOR YEARS 1-5 ---
const projectedFCF = [];
let fcf = fcfBase;
let pvPhase1 = 0;

if (fcfBase && sharesOutstanding) {
  for (let yr = 1; yr <= 5; yr++) {
    fcf = fcf * (1 + growthRatePhase1);
    const pvFactor = 1 / Math.pow(1 + discountRate, yr);
    const pvFCF = fcf * pvFactor;
    projectedFCF.push({ year: yr, fcf: fcf, pvFactor: pvFactor, pvFCF: pvFCF });
    pvPhase1 += pvFCF;
  }
}

// --- PHASE 2: TERMINAL VALUE (Gordon Growth Model) ---
let fcfYear6 = 0;
let terminalValue = 0;
let pvTerminalValue = 0;
let enterpriseValue = 0;
let equityValue = 0;
let intrinsicValuePerShare = null;
let marginOfSafety = 0;
let verdictText = "N/A";
let verdictColor = "#7a8a9e";

if (projectedFCF.length === 5) {
  fcfYear6 = projectedFCF[4].fcf * (1 + growthRateTerminal);
  terminalValue = fcfYear6 / (discountRate - growthRateTerminal);
  pvTerminalValue = terminalValue * projectedFCF[4].pvFactor;

  // --- ENTERPRISE VALUE ---
  enterpriseValue = pvPhase1 + pvTerminalValue;

  // --- EQUITY VALUE ---
  equityValue = enterpriseValue + netCash;
  intrinsicValuePerShare = equityValue / sharesOutstanding;

  marginOfSafety = ((intrinsicValuePerShare - fetchedPrice) / fetchedPrice * 100).toFixed(1);
  verdictText = intrinsicValuePerShare > fetchedPrice ? "Undervalued" : "Overvalued";
  verdictColor = intrinsicValuePerShare > fetchedPrice ? "#10b981" : "#ef4444";
}

const roundedIV = intrinsicValuePerShare ? Math.round(intrinsicValuePerShare * 100) / 100 : 0;

// --- HISTORICAL DATA for charts ---
const histYears = getYears(incData['_years']);
const revenueHistory = getHistoricalValues(incData['Revenue']);
const fcfHistory = getHistoricalValues(cfData['Free Cash Flow']);
const epsHistory = getHistoricalValues(incData['EPS (Diluted)']);
const opMarginHistory = getHistoricalValues(incData['Operating Margin']);
const profitMarginHistory = getHistoricalValues(incData['Profit Margin']);
const fcfMarginHistory = getHistoricalValues(cfData['FCF Margin']);

const maxRev = Math.max(...revenueHistory.filter(v => v !== null), 1);
const maxFcf = Math.max(...fcfHistory.filter(v => v !== null), 1);
const maxEps = Math.max(...epsHistory.filter(v => v !== null), 1);

// Sensitivity analysis
const sensitivityRates = [0.06, 0.07, 0.08, 0.09, 0.10];
const sensitivityGrowth = [0.04, 0.06, 0.08, 0.10, 0.12];
const sensitivityTable = sensitivityRates.map(dr => {
  return {
    dr,
    values: sensitivityGrowth.map(gr => {
      if (!fcfBase || !sharesOutstanding) return null;
      let f = fcfBase;
      let pvSum = 0;
      for (let y = 1; y <= 5; y++) {
        f = f * (1 + gr);
        pvSum += f / Math.pow(1 + dr, y);
      }
      const f6 = f * (1 + growthRateTerminal);
      const tv = f6 / (dr - growthRateTerminal);
      const pvTV = tv / Math.pow(1 + dr, 5);
      return Math.round((pvSum + pvTV + netCash) / sharesOutstanding);
    })
  };
});
---

<SiteLayout
  site="westmount"
  title="Thermo Fisher Scientific (TMO) Intrinsic Value: A DCF Analysis"
  description="We ran a full discounted cash flow on Thermo Fisher Scientific. One number. Every assumption disclosed. Here's what TMO is really worth."
