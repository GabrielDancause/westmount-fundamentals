---
import SiteLayout from "../layouts/SiteLayout.astro";
import * as cheerio from 'cheerio';

const schema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": "O'Reilly Automotive (ORLY) Intrinsic Value: A DCF Analysis",
  "description": "A transparent, step-by-step discounted cash flow valuation of O'Reilly Automotive. Using FY2025 financials to arrive at a single fair value estimate for ORLY shares.",
  "datePublished": "2026-03-18",
  "dateModified": "2026-03-18",
  "author": {
    "@type": "Organization",
    "name": "Westmount Research",
    "url": "https://westmountfundamentals.com"
  },
  "publisher": {
    "@type": "Organization",
    "name": "Westmount Research",
    "url": "https://westmountfundamentals.com"
  },
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": "https://westmountfundamentals.com/oreilly-auto-intrinsic-value"
  }
};

export const meta = {
  title: "O'Reilly Auto (ORLY) Intrinsic Value: A DCF Analysis",
  description: "We ran a full discounted cash flow on O'Reilly Automotive using FY2025 actuals. One number. Every assumption disclosed. Here's what ORLY is really worth.",
  category: "study",
  published: "2026-03-18",
};

/* ═══════════════════════════════════════════════════════════════
   SCRAPE FINANCIAL DATA FROM STOCKANALYSIS
   ═══════════════════════════════════════════════════════════════ */
async function fetchRow(url, rowName) {
  try {
    const res = await fetch(url, { headers: { 'User-Agent': 'Mozilla/5.0' } });
    if (!res.ok) return [];
    const html = await res.text();
    const $ = cheerio.load(html);
    let rowData = [];
    $('tr').each((i, row) => {
      const rowText = $(row).find('td:first-child').text().trim();
      if (rowText === rowName) {
        $(row).find('td').each((j, col) => {
          if (j > 0) rowData.push($(col).text().trim().replace(/,/g, ''));
        });
      }
    });
    return rowData;
  } catch (e) {
    console.error("Scraping error:", e);
    return [];
  }
}

// Fetch in parallel
const [
  revenueData,
  opIncomeData,
  netIncomeData,
  epsData,
  sharesData,
  fcfData,
  cashData,
  debtData
] = await Promise.all([
  fetchRow('https://stockanalysis.com/stocks/orly/financials/', 'Revenue'),
  fetchRow('https://stockanalysis.com/stocks/orly/financials/', 'Operating Income'),
  fetchRow('https://stockanalysis.com/stocks/orly/financials/', 'Net Income'),
  fetchRow('https://stockanalysis.com/stocks/orly/financials/', 'EPS (Diluted)'),
  fetchRow('https://stockanalysis.com/stocks/orly/financials/', 'Shares Outstanding (Diluted)'),
  fetchRow('https://stockanalysis.com/stocks/orly/financials/cash-flow-statement/', 'Free Cash Flow'),
  fetchRow('https://stockanalysis.com/stocks/orly/financials/balance-sheet/', 'Cash & Equivalents'),
  fetchRow('https://stockanalysis.com/stocks/orly/financials/balance-sheet/', 'Total Debt')
]);

const parseVal = (arr, idx, fallback) => (arr && arr[idx] ? parseFloat(arr[idx]) : fallback);

const fcf2025 = parseVal(fcfData, 0, 1593);
const sharesOutstanding = parseVal(sharesData, 0, 856);
const cashAndInvestments = parseVal(cashData, 0, 194);
const totalDebt = parseVal(debtData, 0, 8491);
const netCash = cashAndInvestments - totalDebt;

/* ═══════════════════════════════════════════════════════════════
   DCF MODEL — ALL INPUTS AND CALCULATIONS
   ═══════════════════════════════════════════════════════════════ */
const growthRatePhase1 = 0.08;
const growthRateTerminal = 0.03;
const discountRate = 0.09;

// 1. PROJECT FUTURE CASH FLOWS (Years 1-5)
const projections = [];
let currentFCF = fcf2025;
let pvOfFCF = 0;

for (let year = 1; year <= 5; year++) {
  const fcf = currentFCF * (1 + growthRatePhase1);
  const discountFactor = Math.pow(1 + discountRate, year);
  const pv = fcf / discountFactor;

  projections.push({
    year: `Year ${year}`,
    fcf: fcf,
    pv: pv
  });

  pvOfFCF += pv;
  currentFCF = fcf;
}

// 2. TERMINAL VALUE (Gordon Growth Model)
const terminalYearFCF = currentFCF * (1 + growthRateTerminal);
const terminalValue = terminalYearFCF / (discountRate - growthRateTerminal);
const pvOfTerminalValue = terminalValue / Math.pow(1 + discountRate, 5);

// 3. ENTERPRISE VALUE TO EQUITY VALUE
const enterpriseValue = pvOfFCF + pvOfTerminalValue;
const equityValue = enterpriseValue + netCash;
const intrinsicValuePerShare = equityValue / sharesOutstanding;

// Math for display strings
const roundedIV = intrinsicValuePerShare;
const impliedMarketCap = equityValue;
const currentPrice = 88.31; // As of market close (hardcoded or scraped fallback)
const currentMarketCap = currentPrice * sharesOutstanding;
const marginOfSafety = ((roundedIV - currentPrice) / roundedIV) * 100;

// Determine Verdict
let verdict = "";
let verdictColor = "";
if (currentPrice < roundedIV * 0.8) {
  verdict = "Undervalued";
  verdictColor = "#10b981"; // green
} else if (currentPrice > roundedIV * 1.2) {
  verdict = "Overvalued";
  verdictColor = "#ef4444"; // red
} else {
  verdict = "Fairly Valued";
  verdictColor = "#f59e0b"; // amber
}

/* ═══════════════════════════════════════════════════════════════
   SENSITIVITY MATRIX (5x5)
   ═══════════════════════════════════════════════════════════════ */
const sensitivityDiscountRates = [
  discountRate - 0.02,
  discountRate - 0.01,
  discountRate,
  discountRate + 0.01,
  discountRate + 0.02
];

const sensitivityGrowth = [
  growthRatePhase1 - 0.04,
  growthRatePhase1 - 0.02,
  growthRatePhase1,
  growthRatePhase1 + 0.02,
  growthRatePhase1 + 0.04
];

const sensitivityTable = sensitivityDiscountRates.map(dr => {
  const rowVals = sensitivityGrowth.map(gr => {
    let p_currentFCF = fcf2025;
    let p_pvOfFCF = 0;

    for (let year = 1; year <= 5; year++) {
      const fcf = p_currentFCF * (1 + gr);
      p_pvOfFCF += fcf / Math.pow(1 + dr, year);
      p_currentFCF = fcf;
    }

    const p_terminalValue = (p_currentFCF * (1 + growthRateTerminal)) / (dr - growthRateTerminal);
    const p_pvOfTerminalValue = p_terminalValue / Math.pow(1 + dr, 5);
    const p_equityValue = p_pvOfFCF + p_pvOfTerminalValue + netCash;

    return (p_equityValue / sharesOutstanding).toFixed(2);
  });

  return { dr, values: rowVals };
});

/* ═══════════════════════════════════════════════════════════════
   HISTORICAL CHARTS DATA
   ═══════════════════════════════════════════════════════════════ */
const revenueHistory = [
  { year: '2021', value: parseVal(revenueData, 4, 13328) },
  { year: '2022', value: parseVal(revenueData, 3, 14410) },
  { year: '2023', value: parseVal(revenueData, 2, 15812) },
  { year: '2024', value: parseVal(revenueData, 1, 16708) },
  { year: '2025', value: parseVal(revenueData, 0, 17782) }
];

const fcfHistory = [
  { year: '2021', value: parseVal(fcfData, 4, 2764) },
  { year: '2022', value: parseVal(fcfData, 3, 2585) },
  { year: '2023', value: parseVal(fcfData, 2, 2028) },
  { year: '2024', value: parseVal(fcfData, 1, 2026) },
  { year: '2025', value: parseVal(fcfData, 0, 1593) }
];

const epsHistory = [
  { year: '2021', value: parseVal(epsData, 4, 2.07) },
  { year: '2022', value: parseVal(epsData, 3, 2.23) },
  { year: '2023', value: parseVal(epsData, 2, 2.56) },
  { year: '2024', value: parseVal(epsData, 1, 2.71) },
  { year: '2025', value: parseVal(epsData, 0, 2.97) }
];

const marginHistory = [
  { year: '2021', opInc: parseVal(opIncomeData, 4, 2917), netInc: parseVal(netIncomeData, 4, 2165) },
  { year: '2022', opInc: parseVal(opIncomeData, 3, 2954), netInc: parseVal(netIncomeData, 3, 2173) },
  { year: '2023', opInc: parseVal(opIncomeData, 2, 3186), netInc: parseVal(netIncomeData, 2, 2347) },
  { year: '2024', opInc: parseVal(opIncomeData, 1, 3251), netInc: parseVal(netIncomeData, 1, 2387) },
  { year: '2025', opInc: parseVal(opIncomeData, 0, 3461), netInc: parseVal(netIncomeData, 0, 2538) }
].map((m, i) => {
  const rev = revenueHistory[i].value;
  const fcf = fcfHistory[i].value;
  return {
    year: m.year,
    operating: ((m.opInc / rev) * 100).toFixed(1),
    profit: ((m.netInc / rev) * 100).toFixed(1),
    fcfMargin: ((fcf / rev) * 100).toFixed(1)
  };
});
