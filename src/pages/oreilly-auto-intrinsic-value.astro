---
import SiteLayout from "../layouts/SiteLayout.astro";
import { execSync } from "child_process";

const schema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": "O'Reilly Automotive (ORLY) Intrinsic Value: A DCF Analysis",
  "description": "A transparent, step-by-step discounted cash flow valuation of O'Reilly Automotive. Using actual recent financials to arrive at a single fair value estimate for ORLY shares.",
  "datePublished": "2026-03-24",
  "dateModified": "2026-03-24",
  "author": {
    "@type": "Organization",
    "name": "Westmount Research",
    "url": "https://westmountfundamentals.com"
  },
  "publisher": {
    "@type": "Organization",
    "name": "Westmount Research",
    "url": "https://westmountfundamentals.com"
  },
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": "https://westmountfundamentals.com/oreilly-auto-intrinsic-value"
  }
};

export const meta = {
  title: "O'Reilly Automotive (ORLY) Intrinsic Value: A DCF Analysis",
  description: "We ran a full discounted cash flow on O'Reilly Automotive using real actuals. One number. Every assumption disclosed. Here's what ORLY is really worth.",
  category: "study",
  published: "2026-03-24",
};

/* ═══════════════════════════════════════════════════════════════
   DATA FETCHING (via Python yfinance to bypass bot protection)
   ═══════════════════════════════════════════════════════════════ */
const pyScript = `
import yfinance as yf
import json
import math

ticker = yf.Ticker('ORLY')
info = ticker.info

def clean_nan(val):
    if val is None or math.isnan(val): return None
    return float(val)

def extract_row(df, row_name, num_years=5):
    if row_name in df.index:
        row = df.loc[row_name].values
        arr = [clean_nan(x) for x in row]
        arr.reverse()
        return arr[-num_years:]
    return []

fin = ticker.financials
cf = ticker.cashflow
bs = ticker.balance_sheet

data = {
    'price': info.get('currentPrice', None),
    'shares': info.get('sharesOutstanding', None),
    'debt': info.get('totalDebt', None),
    'cash': info.get('totalCash', None),
    'beta': info.get('beta', None),
    'revenue': extract_row(fin, 'Total Revenue'),
    'opInc': extract_row(fin, 'Operating Income'),
    'netInc': extract_row(fin, 'Net Income'),
    'eps': extract_row(fin, 'Diluted EPS'),
    'fcf': extract_row(cf, 'Free Cash Flow'),
    'ocf': extract_row(cf, 'Operating Cash Flow'),
    'capex': extract_row(cf, 'Capital Expenditure')
}
print(json.dumps(data))
`;

let rawData = null;
try {
  const out = execSync('python3 -c "' + pyScript.replace(/\"/g, '\\"') + '"');
  rawData = JSON.parse(out.toString());
} catch (e) {
  console.error("Failed to fetch yfinance data:", e.message);
  rawData = {}; // Provide an empty object so optional chaining doesn't hit null
}

// Fallbacks if data fails
const currentPrice = rawData?.price ?? null;
const sharesOutstanding = rawData?.shares ? rawData.shares / 1e6 : null; // Millions
const totalDebt = rawData?.debt ? rawData.debt / 1e6 : null;
const cashAndInvestments = rawData?.cash ? rawData.cash / 1e6 : null;
const netCash = (cashAndInvestments !== null && totalDebt !== null) ? cashAndInvestments - totalDebt : 0;
const beta = rawData?.beta ?? 1.0;

const fcfHistoryRaw = rawData?.fcf || [];
const fcf2024Raw = fcfHistoryRaw.length > 0 ? fcfHistoryRaw[fcfHistoryRaw.length - 1] : 0;
const fcf2024 = fcf2024Raw !== null ? fcf2024Raw / 1e6 : 0;

const revHistoryRaw = rawData?.revenue || [];
const rev2024Raw = revHistoryRaw.length > 0 ? revHistoryRaw[revHistoryRaw.length - 1] : 0;
const rev2024 = rev2024Raw !== null ? rev2024Raw / 1e6 : 0;

const epsHistoryRaw = rawData?.eps || [];
const eps2024 = epsHistoryRaw.length > 0 ? epsHistoryRaw[epsHistoryRaw.length - 1] : 0;

const opIncHistoryRaw = rawData?.opInc || [];
const opInc2024Raw = opIncHistoryRaw.length > 0 ? opIncHistoryRaw[opIncHistoryRaw.length - 1] : 0;
const opInc2024 = opInc2024Raw !== null ? opInc2024Raw / 1e6 : 0;
const opMargin2024 = rev2024 > 0 ? (opInc2024 / rev2024) * 100 : 0;

// --- ASSUMPTIONS (Derived mathematically) ---
const treasuryRate = 0.0418; // 10Y Treasury: 4.18%
const erp = 0.055; // Standard historical ERP
const discountRate = treasuryRate + (beta * erp); // CAPM WACC

// Calculate Historical FCF CAGR (Phase 1 Growth)
let growthRatePhase1 = 0;
let fcfYearsCount = 0;
for (let i = 0; i < fcfHistoryRaw.length; i++) {
  if (fcfHistoryRaw[i] !== null) fcfYearsCount++;
}
if (fcfYearsCount >= 2) {
    const firstValidFcf = fcfHistoryRaw.find(val => val !== null) / 1e6;
    if (firstValidFcf > 0 && fcf2024 > 0) {
        growthRatePhase1 = Math.pow(fcf2024 / firstValidFcf, 1 / (fcfYearsCount - 1)) - 1;
    }
}
if (growthRatePhase1 <= 0 || growthRatePhase1 > 0.15) {
    // If erratic or too high, cap it to a reasonable historical average proxy or use 0
    growthRatePhase1 = 0.08;
}

// Terminal Growth Rate mathematically tied to risk-free rate
const growthRateTerminal = Math.min(treasuryRate * 0.8, 0.035); // usually slightly below long-term GDP/Treasury

// --- PHASE 1: PROJECT FCF FOR YEARS 1-5 ---
const projectedFCF = [];
let fcf = fcf2024;
for (let yr = 1; yr <= 5; yr++) {
  fcf = fcf * (1 + growthRatePhase1);
  projectedFCF.push({ year: yr, fcf: Math.round(fcf), pvFactor: 1 / Math.pow(1 + discountRate, yr) });
}
projectedFCF.forEach(p => { p.pvFCF = Math.round(p.fcf * p.pvFactor); });

// --- PHASE 2: TERMINAL VALUE (Gordon Growth Model) ---
const fcfYear6 = projectedFCF[4].fcf * (1 + growthRateTerminal);
const terminalValue = Math.round(fcfYear6 / (discountRate - growthRateTerminal));
const pvTerminalValue = Math.round(terminalValue * projectedFCF[4].pvFactor);

// --- ENTERPRISE VALUE ---
const pvPhase1 = projectedFCF.reduce((sum, p) => sum + p.pvFCF, 0);
const enterpriseValue = pvPhase1 + pvTerminalValue;

// --- EQUITY VALUE ---
const equityValue = enterpriseValue + netCash;
const intrinsicValuePerShare = sharesOutstanding > 0 ? equityValue / sharesOutstanding : 0;
const roundedIV = Math.round(intrinsicValuePerShare * 100) / 100;

// Market comparison
const marginOfSafety = currentPrice > 0 ? ((roundedIV - currentPrice) / currentPrice * 100).toFixed(1) : "0.0";
const verdictText = roundedIV > currentPrice ? "Undervalued" : "Overvalued";
const verdictColor = roundedIV > currentPrice ? "#10b981" : "#ef4444";

// Extract historical arrays for charts, mapping nulls appropriately
function mapHistory(rawArr, divider = 1e6) {
    const startYear = 2025 - rawArr.length;
    return rawArr.map((val, idx) => ({
        year: startYear + idx,
        value: val !== null ? val / divider : null
    })).filter(item => item.value !== null);
}

const revenueHistory = mapHistory(revHistoryRaw);
const fcfHistoryChart = mapHistory(fcfHistoryRaw);
const epsHistoryChart = mapHistory(epsHistoryRaw, 1);

// Sensitivity analysis
const drStep = 0.01;
const sensitivityRates = [discountRate - 2*drStep, discountRate - drStep, discountRate, discountRate + drStep, discountRate + 2*drStep];
const grStep = 0.02;
const sensitivityGrowth = [growthRatePhase1 - 2*grStep, growthRatePhase1 - grStep, growthRatePhase1, growthRatePhase1 + grStep, growthRatePhase1 + 2*grStep];

const sensitivityTable = sensitivityRates.map(dr => {
  return {
    dr,
    values: sensitivityGrowth.map(gr => {
      let f = fcf2024;
      let pvSum = 0;
      for (let y = 1; y <= 5; y++) {
        f = f * (1 + gr);
        pvSum += f / Math.pow(1 + dr, y);
      }
      const f6 = f * (1 + growthRateTerminal);
      const tv = f6 / (dr - growthRateTerminal);
      const pvTV = tv / Math.pow(1 + dr, 5);
      return sharesOutstanding > 0 ? Math.round((pvSum + pvTV + netCash) / sharesOutstanding) : 0;
    })
  };
});
