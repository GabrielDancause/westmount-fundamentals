    font-size: 1.125rem;
    font-weight: 600;
    color: #f8fafc;
  }

  /* Assumptions Grid */
  .assumptions-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 1.5rem;
    margin-top: 1.5rem;
  }

  .assumption-card {
    background: #0f172a;
    border: 1px solid #1e293b;
    border-radius: 8px;
    padding: 1.5rem;
  }

  .assumption-card h3 {
    color: #4a8fe7;
    margin-top: 0;
    margin-bottom: 1rem;
    font-size: 1.25rem;
  }

  .assumption-card p {
    font-size: 0.95rem;
    margin: 0;
  }

  /* Tables */
  .tables-section {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .table-container {
    overflow-x: auto;
  }

  table {
    width: 100%;
    border-collapse: collapse;
    background: #0f172a;
    border-radius: 8px;
    overflow: hidden;
  }

  th, td {
    padding: 1rem;
    text-align: left;
    border-bottom: 1px solid #1e293b;
