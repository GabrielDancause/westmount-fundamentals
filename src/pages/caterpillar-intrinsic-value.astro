    font-size: 2.5rem;
    margin-bottom: 0.5rem;
  }

  .subtitle {
    font-size: 1.2rem;
    color: #8b9bb4;
    margin-bottom: 2rem;
  }

  .ai-badge {
    display: inline-block;
    background: #4a8fe7;
    color: #000;
    padding: 0.25rem 0.75rem;
    border-radius: 4px;
    font-weight: bold;
    font-size: 0.875rem;
    margin-bottom: 1rem;
  }

  .num {
    font-family: 'JetBrains Mono', monospace;
  }

  .bold {
    font-weight: bold;
  }

  .highlight-text {
    color: #4a8fe7;
    font-size: 1.25rem;
    font-weight: bold;
  }

  .text-green { color: #10b981; }
  .text-red { color: #ef4444; }

  /* Cards */
  .verdict-card {
    background: #0f172a;
    border: 1px solid #1e293b;
    border-radius: 8px;
    padding: 2rem;
    margin-bottom: 3rem;
  }

  .verdict-prices {
    display: flex;
