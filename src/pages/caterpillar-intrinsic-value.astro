    border: 2px solid #4a8fe7;
    background: rgba(74, 143, 231, 0.1);
  }

  .price-box .label {
    font-size: 0.875rem;
    color: #8b9bb4;
    margin-bottom: 0.5rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .price-box .value {
    font-family: 'JetBrains Mono', monospace;
    font-size: 2rem;
    font-weight: bold;
