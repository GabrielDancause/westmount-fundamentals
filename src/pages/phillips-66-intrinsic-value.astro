        </tr>
        <tr>
          <td>Plus: Cash & Equivalents</td>
          <td>${cashAndInvestments.toLocaleString()}</td>
        </tr>
        <tr>
          <td>Less: Total Debt</td>
          <td>$({totalDebt.toLocaleString()})</td>
        </tr>
        <tr class="row-total">
          <td>Total Equity Value</td>
          <td class="highlight-cell">${equityValue.toLocaleString()}</td>
        </tr>
        <tr>
          <td>Divided by Shares Outstanding</td>
