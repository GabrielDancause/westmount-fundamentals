        {projectedFCF.map(p => (
          <tr>
            <td>Year {p.year}</td>
            <td>${p.fcf.toLocaleString()}</td>
            <td>{p.pvFactor.toFixed(3)}</td>
            <td>${p.pvFCF.toLocaleString()}</td>
          </tr>
        ))}
        <tr class="row-total">
          <td colspan="3">Sum of Phase 1 Present Value</td>
          <td class="highlight-cell">${pvPhase1.toLocaleString()}</td>
        </tr>
      </tbody>
    </table>
  </div>

  <!-- TERMINAL VALUE -->
  <h2>Terminal Value Calculation</h2>
  <p>A company's value isn't just its next five years. The Terminal Value captures all cash flows from Year 6 to infinity, assuming steady-state growth.</p>

  <div class="table-wrap">
    <table>
      <tbody>
        <tr>
          <td>Year 6 FCF</td>
          <td>${Math.round(fcfYear6).toLocaleString()}</td>
        </tr>
