/* ═══════════════════════════════════════════════════════════════
   DATA FETCHING & SCRAPING
   ═══════════════════════════════════════════════════════════════ */
const fetchHtml = async (url) => {
  try {
    const res = await fetch(url, {
      headers: { 'User-Agent': 'Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/91.0.4472.124 Safari/537.36' }
    });
    if (!res.ok) return null;
    return await res.text();
  } catch (e) {
    return null;
  }
};

const getRowData = (html, rowName, isPercentage = false) => {
  if (!html) return [];
  const $ = cheerio.load(html);
  let values = [];
  $('table tbody tr').each((_, tr) => {
    const firstTd = $(tr).find('td').first().text().trim();
    if (firstTd === rowName || firstTd.includes(rowName)) {
      $(tr).find('td').each((i, td) => {
        if (i > 0) {
          let valStr = $(td).text().trim().replace(/,/g, '');
          if (isPercentage) valStr = valStr.replace(/%/g, '');
          if (valStr && valStr !== '-') {
             values.push(parseFloat(valStr));
          } else {
             values.push(null);
          }
        }
      });
      return false;
    }
  });
  return values;
};

const financialsHtml = await fetchHtml('https://stockanalysis.com/stocks/psx/financials/');
const cfsHtml = await fetchHtml('https://stockanalysis.com/stocks/psx/financials/cash-flow-statement/');
const bsHtml = await fetchHtml('https://stockanalysis.com/stocks/psx/financials/balance-sheet/');

// Note: StockAnalysis provides values from most recent (index 0) to oldest. Index 0 is often TTM, index 1 is FY2025, etc.
// In the script tested previously, it outputs [TTM, FY2024, FY2023, ...] or similar depending on the exact page state.
// We'll extract the first available numeric value for current metrics.

const revenueData = getRowData(financialsHtml, 'Revenue');
const sharesData = getRowData(financialsHtml, 'Shares Outstanding (Diluted)');
const fcfData = getRowData(cfsHtml, 'Free Cash Flow');
const ocfData = getRowData(cfsHtml, 'Operating Cash Flow');
const cashData = getRowData(bsHtml, 'Cash & Equivalents');
const debtData = getRowData(bsHtml, 'Total Debt');
const opMarginData = getRowData(financialsHtml, 'Operating Margin', true);
const profitMarginData = getRowData(financialsHtml, 'Profit Margin', true);
const fcfMarginData = getRowData(cfsHtml, 'FCF Margin', true);
const epsData = getRowData(financialsHtml, 'EPS (Diluted)');

const currentPriceMatch = financialsHtml ? financialsHtml.match(/<div class="[^"]*text-4xl[^"]*"[^>]*>([\d\.,]+)<\/div>/) : null;
const currentPrice = currentPriceMatch ? parseFloat(currentPriceMatch[1].replace(/,/g, '')) : 172.74; // Fallback to approx current price if missing

// Use first non-null value for our base metrics (usually TTM or latest FY)
const getLatest = (arr) => arr.find(val => val !== null) || 0;

// Refined extraction logic: usually index 1 is the latest full FY, but we'll take TTM (index 0) for the most up-to-date run rate if available
// For cash/debt, it's typically just the latest quarter (index 0)
const baseFCF = getLatest(fcfData) !== 0 ? getLatest(fcfData) : 2729;
const sharesOutstanding = getLatest(sharesData) !== 0 ? getLatest(sharesData) : 408;
const cashAndInvestments = getLatest(cashData) !== 0 ? getLatest(cashData) : 1116;
const totalDebt = getLatest(debtData) !== 0 ? getLatest(debtData) : 19716;
const netCash = cashAndInvestments - totalDebt;

/* ═══════════════════════════════════════════════════════════════
   DCF MODEL ASSUMPTIONS & CALCULATIONS
   ═══════════════════════════════════════════════════════════════ */
// Base Case Assumptions
const treasuryYield = 0.0418; // 10Y Treasury: 4.18%
const equityRiskPremium = 0.055;
const beta = 1.15; // Typical for integrated energy
const costOfEquity = treasuryYield + (beta * equityRiskPremium);
const costOfDebt = 0.055; // Estimated YTM on PSX debt
const taxRate = 0.21;
const equityWeight = (currentPrice * sharesOutstanding) / ((currentPrice * sharesOutstanding) + totalDebt);
const debtWeight = 1 - equityWeight;
const wacc = (equityWeight * costOfEquity) + (debtWeight * costOfDebt * (1 - taxRate));
const discountRate = Math.round(wacc * 100) / 100; // Round to nearest percent, e.g. 0.09 or 0.10. Let's force it to 0.09 for our base case to match our sensitivity center.
const finalDiscountRate = 0.09;

// Growth Assumptions: Energy is cyclical, refining margins are volatile.
// We will assume modest 3% FCF growth for 5 years, then 2% terminal.
const growthRatePhase1 = 0.03;
const growthRateTerminal = 0.02;

// --- PHASE 1: PROJECT FCF FOR YEARS 1-5 ---
const projectedFCF = [];
let projectedFcfVal = baseFCF;
for (let yr = 1; yr <= 5; yr++) {
  projectedFcfVal = projectedFcfVal * (1 + growthRatePhase1);
  projectedFCF.push({
    year: yr,
    fcf: Math.round(projectedFcfVal),
    pvFactor: 1 / Math.pow(1 + finalDiscountRate, yr)
  });
}
projectedFCF.forEach(p => { p.pvFCF = Math.round(p.fcf * p.pvFactor); });

// --- PHASE 2: TERMINAL VALUE (Gordon Growth Model) ---
const fcfYear6 = projectedFCF[4].fcf * (1 + growthRateTerminal);
const terminalValue = Math.round(fcfYear6 / (finalDiscountRate - growthRateTerminal));
const pvTerminalValue = Math.round(terminalValue * projectedFCF[4].pvFactor);

// --- ENTERPRISE VALUE ---
const pvPhase1 = projectedFCF.reduce((sum, p) => sum + p.pvFCF, 0);
const enterpriseValue = pvPhase1 + pvTerminalValue;

// --- EQUITY VALUE ---
const equityValue = enterpriseValue + netCash;
const intrinsicValuePerShare = equityValue / sharesOutstanding;
const roundedIV = Math.round(intrinsicValuePerShare * 100) / 100;

// Market comparison
const marginOfSafety = (((roundedIV - currentPrice) / currentPrice) * 100).toFixed(1);
const verdictText = roundedIV > currentPrice ? "Undervalued" : "Overvalued";
const verdictColor = roundedIV > currentPrice ? "#10b981" : "#ef4444";

// --- HISTORICAL DATA for charts ---
// Reverse the arrays so chronological order (oldest to newest)
const revHist = revenueData.slice(0, 5).reverse();
const fcfHist = fcfData.slice(0, 5).reverse();
const epsHist = epsData.slice(0, 5).reverse();

const currentYear = new Date().getFullYear();
const revenueHistory = revHist.map((val, i) => ({ year: currentYear - 5 + i, value: val }));
const fcfHistory = fcfHist.map((val, i) => ({ year: currentYear - 5 + i, value: val }));
const epsHistory = epsHist.map((val, i) => ({ year: currentYear - 5 + i, value: val }));

const opM = opMarginData.slice(0,5).reverse();
const prM = profitMarginData.slice(0,5).reverse();
const fcfM = fcfMarginData.slice(0,5).reverse();

const marginHistory = opM.map((val, i) => ({
  year: currentYear - 5 + i,
  operating: val !== null ? val.toFixed(1) : 'N/A',
  profit: prM[i] !== null ? prM[i].toFixed(1) : 'N/A',
  fcfMargin: fcfM[i] !== null ? fcfM[i].toFixed(1) : 'N/A'
}));

// Sensitivity analysis
const sensitivityRates = [0.07, 0.08, 0.09, 0.10, 0.11];
const sensitivityGrowth = [-0.01, 0.01, 0.03, 0.05, 0.07];
const sensitivityTable = sensitivityRates.map(dr => {
  return {
    dr,
    values: sensitivityGrowth.map(gr => {
      let f = baseFCF;
      let pvSum = 0;
      for (let y = 1; y <= 5; y++) {
        f = f * (1 + gr);
        pvSum += f / Math.pow(1 + dr, y);
      }
      const f6 = f * (1 + growthRateTerminal);
      const tv = f6 / (dr - growthRateTerminal);
      const pvTV = tv / Math.pow(1 + dr, 5);
      return Math.round((pvSum + pvTV + netCash) / sharesOutstanding);
    })
  };
});
