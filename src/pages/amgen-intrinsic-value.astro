---
import SiteLayout from "../layouts/SiteLayout.astro";

const schema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": "Amgen (AMGN) Intrinsic Value: A DCF Analysis",
  "description": "A transparent, step-by-step discounted cash flow valuation of Amgen Inc. Using actual financials to arrive at a single fair value estimate for AMGN shares.",
  "datePublished": "2026-03-24",
  "dateModified": "2026-03-24",
  "author": {
    "@type": "Organization",
    "name": "Westmount Research",
    "url": "https://westmountfundamentals.com"
  },
  "publisher": {
    "@type": "Organization",
    "name": "Westmount Research",
    "url": "https://westmountfundamentals.com"
  },
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": "https://westmountfundamentals.com/amgen-intrinsic-value"
  }
};

export const meta = {
  title: "Amgen (AMGN) Intrinsic Value: A DCF Analysis",
  description: "We ran a full discounted cash flow on Amgen. One number. Every assumption disclosed. Here's what AMGN is really worth.",
  category: "study",
  published: "2026-03-24",
};

/* ═══════════════════════════════════════════════════════════════
   DATA FETCHING FROM STOCKANALYSIS.COM (Null over fake data)
   ═══════════════════════════════════════════════════════════════ */
const headers = {
  'User-Agent': 'Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36'
};

async function fetchPage(url) {
  try {
    const res = await fetch(url, { headers });
    const html = await res.text();
    const match = html.match(/financialData:(\{.*?\})/);
    if (match) {
      return eval('(' + match[1] + ')');
    }
  } catch (e) {
    console.error(`Failed to fetch ${url}`, e);
  }
  return null;
}

const inc = await fetchPage('https://stockanalysis.com/stocks/amgn/financials/');
const bs = await fetchPage('https://stockanalysis.com/stocks/amgn/financials/balance-sheet/');

let currentPrice = null;
try {
  const priceRes = await fetch('https://stockanalysis.com/stocks/amgn/', { headers });
  const priceHtml = await priceRes.text();
  const m = priceHtml.match(/class="text-4xl font-bold[^>]*>([0-9.]+)</) || priceHtml.match(/class="text-5xl font-bold[^>]*>([0-9.]+)</) || priceHtml.match(/class="ts-5xl font-bold[^>]*>([0-9.]+)</);
  if (m) {
    currentPrice = parseFloat(m[1]);
  }
} catch (e) {
  console.error("Failed to fetch price", e);
}

// Fallbacks (null over fake data)
const fcf2025 = inc?.fcf?.[1] ? inc.fcf[1] / 1e6 : null; // FY2025 or TTM equivalent (index 1 is latest annual)
const sharesOutstanding = inc?.sharesDiluted?.[1] ? inc.sharesDiluted[1] / 1e6 : null;
const cashAndInvestments = bs?.cashneq?.[1] ? bs.cashneq[1] / 1e6 : null;
const totalDebt = bs?.debt?.[1] ? bs.debt[1] / 1e6 : null;

const netCash = (cashAndInvestments !== null && totalDebt !== null) ? cashAndInvestments - totalDebt : null;

/* ═══════════════════════════════════════════════════════════════
   DCF MODEL — ALL INPUTS AND CALCULATIONS
   ═══════════════════════════════════════════════════════════════ */

// --- ASSUMPTIONS (fully disclosed below) ---
const growthRatePhase1 = 0.05;         // 5% FCF growth, Years 1-5 (mature biotech)
const growthRateTerminal = 0.02;       // 2% perpetuity growth (terminal)
const discountRate = 0.08;             // 8% WACC / required return
const treasury10Y = 4.18;              // 10Y Treasury

// --- PHASE 1: PROJECT FCF FOR YEARS 1-5 ---
const projectedFCF = [];
let pvPhase1 = 0;

if (fcf2025 !== null) {
  let fcf = fcf2025;
  for (let yr = 1; yr <= 5; yr++) {
    fcf = fcf * (1 + growthRatePhase1);
    const pvFactor = 1 / Math.pow(1 + discountRate, yr);
    const pvFCF = Math.round(fcf * pvFactor);
    projectedFCF.push({ year: yr, fcf: Math.round(fcf), pvFactor, pvFCF });
    pvPhase1 += pvFCF;
  }
}

// --- PHASE 2: TERMINAL VALUE (Gordon Growth Model) ---
let fcfYear6 = null;
let terminalValue = null;
let pvTerminalValue = null;
let enterpriseValue = null;
let equityValue = null;
let intrinsicValuePerShare = null;
let roundedIV = null;

if (projectedFCF.length === 5) {
  fcfYear6 = projectedFCF[4].fcf * (1 + growthRateTerminal);
  terminalValue = Math.round(fcfYear6 / (discountRate - growthRateTerminal));
  pvTerminalValue = Math.round(terminalValue * projectedFCF[4].pvFactor);
  enterpriseValue = pvPhase1 + pvTerminalValue;

  if (netCash !== null && sharesOutstanding !== null) {
    equityValue = enterpriseValue + netCash;
    intrinsicValuePerShare = equityValue / sharesOutstanding;
    roundedIV = Math.round(intrinsicValuePerShare * 100) / 100;
  }
}

// Market comparison
let marginOfSafety = null;
let verdictText = "N/A";
let verdictColor = "#7a8a9e";

if (roundedIV !== null && currentPrice !== null) {
  marginOfSafety = (((roundedIV - currentPrice) / currentPrice) * 100).toFixed(1);
  verdictText = roundedIV > currentPrice ? "Undervalued" : "Overvalued";
  verdictColor = roundedIV > currentPrice ? "#10b981" : "#ef4444";
}

// --- HISTORICAL DATA for charts ---
// Map index 1-5 to years 2025 down to 2021
const rev = inc?.revenue || [];
const fcf_hist = inc?.fcf || [];
const eps_hist = inc?.epsDiluted || [];
const op_margin = inc?.operatingMargin || [];
const prof_margin = inc?.profitMargin || [];
const fcf_margin = inc?.fcfMargin || [];

const years = [2025, 2024, 2023, 2022, 2021];
const revenueHistory = [];
const fcfHistory = [];
const epsHistory = [];
const marginHistory = [];

for (let i = 0; i < 5; i++) {
  const dataIdx = i + 1; // 1 to 5 (assuming 1 is 2025, 2 is 2024 etc based on stockanalysis)
  if (rev[dataIdx]) revenueHistory.push({ year: years[i], value: rev[dataIdx] / 1e6 });
  if (fcf_hist[dataIdx]) fcfHistory.push({ year: years[i], value: fcf_hist[dataIdx] / 1e6 });
  if (eps_hist[dataIdx]) epsHistory.push({ year: years[i], value: eps_hist[dataIdx] });
  if (op_margin[dataIdx] !== undefined) {
    marginHistory.push({
      year: years[i],
      operating: (op_margin[dataIdx] * 100).toFixed(1),
      profit: (prof_margin[dataIdx] * 100).toFixed(1),
      fcfMargin: (fcf_margin[dataIdx] * 100).toFixed(1)
    });
  }
}
// Reverse to chronological
revenueHistory.reverse();
fcfHistory.reverse();
epsHistory.reverse();
marginHistory.reverse();

const maxRev = Math.max(...revenueHistory.map(r => r.value), 1);
const maxFcf = Math.max(...fcfHistory.map(r => r.value), 1);
const maxEps = Math.max(...epsHistory.map(r => r.value), 1);

// Sensitivity analysis
const sensitivityRates = [0.06, 0.07, 0.08, 0.09, 0.10];
const sensitivityGrowth = [0.03, 0.04, 0.05, 0.06, 0.07];
const sensitivityTable = fcf2025 !== null && netCash !== null && sharesOutstanding !== null ? sensitivityRates.map(dr => {
  return {
    dr,
    values: sensitivityGrowth.map(gr => {
      let f = fcf2025;
      let pvSum = 0;
      for (let y = 1; y <= 5; y++) {
        f = f * (1 + gr);
        pvSum += f / Math.pow(1 + dr, y);
      }
      const f6 = f * (1 + growthRateTerminal);
      const tv = f6 / (dr - growthRateTerminal);
      const pvTV = tv / Math.pow(1 + dr, 5);
      return Math.round((pvSum + pvTV + netCash) / sharesOutstanding);
    })
  };
}) : [];

