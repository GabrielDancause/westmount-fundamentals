---
import SiteLayout from "../layouts/SiteLayout.astro";

// --- METADATA ---
export const meta = {
  title: "Meta Platforms, Inc. (META) Intrinsic Value - Gemini's DCF Analysis",
  description: "An independent discounted cash flow (DCF) intrinsic value analysis of Meta Platforms, Inc. (META) compiled entirely by Gemini 3.1.",
  category: "study",
  published: "2026-03-18",
};

// --- DATA & ASSUMPTIONS (FY2025 Actuals) ---
// Data fetched securely using S&P Global via yfinance integration
// Base FCF: $46,109M. OCF was robust, but CapEx was substantial due to AI/Metaverse.
// Shares Outstanding: 2,187M.
// Current Price: $621.50 (Approximate current trading price)
// Net Cash: -$2,305M. ($81,592M in Cash/STI - $83,897M in Total Debt)
// 10-Year US Treasury Rate: 4.18%

// The prompt requires bold assumptions as Gemini.
// FCF Growth (Y1-Y5): 16%. Meta is proving the ROI of its AI investments through hyper-targeted ads and increased engagement (Llama integration, Reels). As Reality Labs losses stabilize and core Family of Apps margins expand with AI efficiency, FCF will grow rapidly.
// Discount Rate (WACC): 9.2%. With a 4.18% risk-free rate, Meta's slightly higher beta than GOOGL is offset by its incredible cash-generation engine. 9.2% demands a high return while acknowledging their monopolistic ad positioning.
// Terminal Growth: 3.5%. Perpetual growth slightly above GDP, reflecting Meta's entrenched position in global communication and emerging AI utility.

const baseFCF = 46109; // in Millions
const sharesOut = 2187; // in Millions
const currentPrice = 621.50;
const netCash = -2305; // Cash & ST investments - Total Debt

const fcfGrowthRate = 0.16;
const discountRate = 0.092;
const terminalGrowthRate = 0.035;

// --- YEAR 1 TO 5 PROJECTIONS ---
const projections = [];
let prevFCF = baseFCF;

for (let i = 1; i <= 5; i++) {
  const projectedFCF = prevFCF * (1 + fcfGrowthRate);
  const discountFactor = Math.pow(1 + discountRate, i);
  const pvOfFCF = projectedFCF / discountFactor;

  projections.push({
    year: `Year ${i}`,
    fcf: projectedFCF,
    pv: pvOfFCF
  });

  prevFCF = projectedFCF;
}

const sumPvFcf = projections.reduce((sum, p) => sum + p.pv, 0);

// --- TERMINAL VALUE ---
const year5FCF = projections[4].fcf;
const terminalValue = (year5FCF * (1 + terminalGrowthRate)) / (discountRate - terminalGrowthRate);
const pvTerminalValue = terminalValue / Math.pow(1 + discountRate, 5);

// --- INTRINSIC VALUE CALCULATION ---
const enterpriseValue = sumPvFcf + pvTerminalValue;
const totalEquityValue = enterpriseValue + netCash;
const intrinsicValuePerShare = totalEquityValue / sharesOut;

// Value vs Current Price
const marginOfSafety = ((intrinsicValuePerShare - currentPrice) / currentPrice) * 100;
const isUndervalued = intrinsicValuePerShare > currentPrice;

// --- SENSITIVITY MATRIX ---
const sensitivityDiscountRates = [0.082, 0.087, 0.092, 0.097, 0.102];
const sensitivityGrowthRates = [0.025, 0.030, 0.035, 0.040, 0.045];

const sensitivityMatrix = sensitivityGrowthRates.map(g => {
  return {
    growthRate: g,
    values: sensitivityDiscountRates.map(d => {
      // Re-calculate TV and PV with new rates
      const currentTerminalValue = (year5FCF * (1 + g)) / (d - g);
      const currentPvTerminalValue = currentTerminalValue / Math.pow(1 + d, 5);

      // Re-calculate PV of FCFs with new discount rate
      let currentSumPvFcf = 0;
      let tempFcf = baseFCF;
      for (let i = 1; i <= 5; i++) {
        tempFcf = tempFcf * (1 + fcfGrowthRate);
        currentSumPvFcf += tempFcf / Math.pow(1 + d, i);
      }

      const currentEV = currentSumPvFcf + currentPvTerminalValue;
      const currentEquity = currentEV + netCash;
      const currentIV = currentEquity / sharesOut;

      return currentIV;
    })
  };
});

// Formatting helpers
const formatMoney = (val) => new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD', minimumFractionDigits: 2, maximumFractionDigits: 2 }).format(val);
const formatMillions = (val) => '$' + new Intl.NumberFormat('en-US', { maximumFractionDigits: 0 }).format(val) + 'M';
const formatPercent = (val) => (val * 100).toFixed(1) + '%';

// --- SCHEMA ---
const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Article",
      "headline": meta.title,
      "description": meta.description,
      "author": {
        "@type": "Organization",
        "name": "Gemini 3.1"
      },
      "publisher": {
        "@type": "Organization",
        "name": "Westmount Fundamentals",
        "logo": {
          "@type": "ImageObject",
          "url": "https://westmountfundamentals.com/logo.png"
        }
      },
      "mainEntityOfPage": {
        "@type": "WebPage",
        "@id": "https://westmountfundamentals.com/meta-intrinsic-value"
      }
    },
    {
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "Why did Gemini project a 16% Free Cash Flow growth rate for Meta?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Gemini projects 16% growth because Meta is already demonstrating massive ROI from its open-source AI models (Llama). AI integration is dramatically improving ad targeting efficiency and user engagement on Reels, expanding core margins even as Reality Labs investments continue."
          }
        },
        {
          "@type": "Question",
          "name": "What discount rate (WACC) was used in Meta's DCF analysis?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "A 9.2% discount rate was used. This reflects the 4.18% risk-free rate and Meta's slightly elevated beta compared to some big tech peers, while acknowledging its unparalleled cash-generation capabilities and global user base."
          }
        },
        {
          "@type": "Question",
          "name": "How does Meta's Metaverse investment impact its intrinsic value?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "The massive CapEx for Reality Labs is already priced into the base FCF of $46.1B. If these investments eventually yield a dominant mixed-reality platform, it acts as a call option on top of this valuation. If they fail but spending is curtailed, FCF margins will expand significantly faster than projected."
          }
        }
      ]
    }
  ]
};
---
<SiteLayout site="westmount" title={meta.title} description={meta.description} canonical="https://westmountfundamentals.com/meta-intrinsic-value" schema={schema}>
  <div class="page-content">
    <div class="container">

      <div class="gemini-header">
        <div class="gemini-badge">COMPILED BY GEMINI 2.5 PRO</div>
        <h1>Meta Platforms (META) Intrinsic Value</h1>
        <p class="subtitle">An independent two-stage DCF analysis by a frontier AI model.</p>
      </div>

      <div class="verdict-card">
        <div class="verdict-header">
          <h2>Fair Value Estimate</h2>
        </div>
        <div class="verdict-body">
          <div class="verdict-main">
            <span class="iv-value">{formatMoney(intrinsicValuePerShare)}</span>
            <span class="iv-label">per share</span>
          </div>
          <div class="verdict-stats">
            <div class="stat">
              <span class="stat-label">Current Price</span>
              <span class="stat-value">{formatMoney(currentPrice)}</span>
            </div>
            <div class="stat">
              <span class="stat-label">Margin of Safety</span>
              <span class={`stat-value ${isUndervalued ? 'positive' : 'negative'}`}>
                {isUndervalued ? '+' : ''}{marginOfSafety.toFixed(2)}%
              </span>
            </div>
            <div class="stat">
              <span class="stat-label">Verdict</span>
              <span class={`badge ${isUndervalued ? 'positive' : 'negative'}`}>
                {isUndervalued ? 'UNDERVALUED' : 'OVERVALUED'}
              </span>
            </div>
          </div>
        </div>
        <div class="verdict-footer">
          <p>Based on FY2025 actuals. Data via S&P Global (Mar 18, 2026).</p>
        </div>
      </div>

      <section class="content-section">
        <h2>The AI Thesis: Why I'm Bullish on the Efficiency Engine</h2>
        <p>Meta Platforms is no longer just a social media company. It is a massive, hyper-efficient AI advertising engine that happens to interface through apps. The narrative of 2022—burning cash on the Metaverse—has completely flipped. Meta’s massive CapEx spending on Nvidia GPUs (Llama infrastructure) is showing immediate, powerful returns. The algorithm for Reels and the core feed is driving unparalleled engagement, while automated ad suites (Advantage+) are dramatically lowering acquisition costs for advertisers.</p>
        <p>My valuation model recognizes this dual engine: Meta is simultaneously securing its dominance as the premier global ad platform using AI while investing deeply into the next compute paradigm (Reality Labs). This creates an incredibly wide moat and justifies strong free cash flow expansion.</p>
      </section>

      <section class="content-section">
        <h2>My Assumptions & Rationale</h2>

        <div class="assumption-grid">
          <div class="assumption-card">
            <div class="card-title">FCF Growth Rate (Y1-Y5)</div>
            <div class="card-value">{formatPercent(fcfGrowthRate)}</div>
            <p><strong>Rationale:</strong> 16% growth acknowledges Meta’s undeniable operating leverage. With over 3 billion daily active users across the Family of Apps, the marginal cost of deploying new AI-driven ad features is near zero. Even as Reality Labs burns billions, the core business generates such massive cash flows that a 16% CAGR is highly attainable as AI efficiencies compound.</p>
          </div>

          <div class="assumption-card">
            <div class="card-title">Discount Rate (WACC)</div>
            <div class="card-value">{formatPercent(discountRate)}</div>
            <p><strong>Rationale:</strong> A 9.2% discount rate perfectly positions the risk profile. Given the 10-year treasury at 4.18% and Meta’s slightly higher beta compared to some big tech peers, the CAPM model requires a robust return. While Meta has regulatory scrutiny, its fortress balance sheet and unrivaled cash engine act as massive stabilizers, justifying 9.2%.</p>
          </div>

          <div class="assumption-card">
            <div class="card-title">Terminal Growth Rate</div>
            <div class="card-value">{formatPercent(terminalGrowthRate)}</div>
            <p><strong>Rationale:</strong> 3.5% implies Meta will grow slightly faster than global GDP into perpetuity. In an AI-augmented world where communication and attention are paramount, Meta controls the ultimate distribution channels. Its infrastructure serves as a global economic utility.</p>
          </div>
        </div>
      </section>

      <section class="content-section">
        <h2>Discounted Cash Flow (DCF) Projections</h2>
        <p>Starting with the FY2025 base FCF of {formatMillions(baseFCF)}, the table below outlines the 5-year projection discounted back to Present Value (PV) using the {formatPercent(discountRate)} WACC.</p>

        <div class="table-container">
          <table>
            <thead>
              <tr>
                <th>Period</th>
                <th>Projected FCF</th>
                <th>PV Factor ({formatPercent(discountRate)})</th>
                <th>Present Value</th>
              </tr>
            </thead>
            <tbody>
              {projections.map((p, index) => (
                <tr>
                  <td>{p.year}</td>
                  <td>{formatMillions(p.fcf)}</td>
                  <td>{(1 / Math.pow(1 + discountRate, index + 1)).toFixed(4)}</td>
                  <td>{formatMillions(p.pv)}</td>
                </tr>
              ))}
              <tr class="highlight-row">
                <td colspan="3"><strong>Sum of PV of FCFs (Years 1-5)</strong></td>
                <td><strong>{formatMillions(sumPvFcf)}</strong></td>
              </tr>
            </tbody>
          </table>
        </div>
      </section>

      <section class="content-section">
        <h2>Terminal & Final Valuation Math</h2>
        <p>The Terminal Value accounts for all cash flows from Year 6 into perpetuity, calculated using the Gordon Growth Model.</p>

        <div class="math-card">
          <div class="math-row">
            <span>Year 5 FCF</span>
            <span>{formatMillions(year5FCF)}</span>
          </div>
          <div class="math-row">
            <span>Terminal Value (TV) Calculation</span>
            <span>({formatMillions(year5FCF)} * {1 + terminalGrowthRate}) / ({discountRate} - {terminalGrowthRate})</span>
          </div>
          <div class="math-row">
            <span>Terminal Value</span>
            <span>{formatMillions(terminalValue)}</span>
          </div>
          <div class="math-row highlight">
            <span>PV of Terminal Value</span>
            <span>{formatMillions(pvTerminalValue)}</span>
          </div>
        </div>

        <p style="margin-top: 2rem;">Adding it all together with Net Cash:</p>

        <div class="math-card">
          <div class="math-row">
            <span>Sum of PV of FCFs (Years 1-5)</span>
            <span>{formatMillions(sumPvFcf)}</span>
          </div>
          <div class="math-row">
            <span>+ PV of Terminal Value</span>
            <span>{formatMillions(pvTerminalValue)}</span>
          </div>
          <div class="math-row">
            <span><strong>= Enterprise Value</strong></span>
            <span><strong>{formatMillions(enterpriseValue)}</strong></span>
          </div>
          <div class="math-row">
            <span>+ Net Cash (Cash - Debt)</span>
            <span>{formatMillions(netCash)}</span>
          </div>
          <div class="math-row highlight">
            <span><strong>= Total Equity Value</strong></span>
            <span><strong>{formatMillions(totalEquityValue)}</strong></span>
          </div>
          <div class="math-row">
            <span>÷ Shares Outstanding</span>
            <span>{sharesOut.toLocaleString()}M</span>
          </div>
          <div class="math-row result">
            <span><strong>Intrinsic Value Per Share</strong></span>
            <span><strong>{formatMoney(intrinsicValuePerShare)}</strong></span>
          </div>
        </div>
      </section>

      <section class="content-section">
        <h2>Sensitivity Matrix</h2>
        <p>A static valuation is inherently flawed. The sensitivity matrix below visualizes how the intrinsic value fluctuates across different Discount Rate (WACC) and Terminal Growth Rate assumptions.</p>

        <div class="table-container sensitivity-table">
          <table>
            <thead>
              <tr>
                <th rowspan="2" class="corner-cell">Terminal<br/>Growth</th>
                <th colspan="5" class="header-cell">Discount Rate (WACC)</th>
              </tr>
              <tr>
                {sensitivityDiscountRates.map(d => <th>{formatPercent(d)}</th>)}
              </tr>
            </thead>
            <tbody>
              {sensitivityMatrix.map(row => (
                <tr>
                  <th class="row-header">{formatPercent(row.growthRate)}</th>
                  {row.values.map(val => (
                    <td class={
                      val > currentPrice * 1.15 ? "cell-undervalued" :
                      val < currentPrice * 0.85 ? "cell-overvalued" :
                      "cell-neutral"
                    }>
                      {formatMoney(val)}
                    </td>
                  ))}
                </tr>
              ))}
            </tbody>
          </table>
          <div class="matrix-legend">
            <span class="legend-item"><span class="color-box cell-undervalued"></span> Undervalued (>15% Margin)</span>
            <span class="legend-item"><span class="color-box cell-neutral"></span> Fair Value</span>
            <span class="legend-item"><span class="color-box cell-overvalued"></span> Overvalued (&lt;-15% Margin)</span>
          </div>
        </div>
      </section>

      <section class="content-section risks-section">
        <h2>Risks & Bear Case</h2>
        <p>Despite the incredibly strong core business and AI tailwinds, we must consider the structural risks that could derail this valuation:</p>
        <div class="risk-grid">
          <div class="risk-card">
            <h3>1. Reality Labs Financial Black Hole</h3>
            <p>Meta is investing aggressively in AR/VR and the Metaverse. If these investments fail to yield a mass-market consumer platform, billions of dollars of capital expenditure will have been effectively burned without generating any long-term cash flow return.</p>
          </div>
          <div class="risk-card">
            <h3>2. Regulatory Headwinds (FTC/EU)</h3>
            <p>The European Union's Digital Markets Act and the FTC's ongoing antitrust scrutiny remain significant risks. Any ruling that fundamentally alters how Meta can share data across its Family of Apps or acquire competitors would structurally compress its profit margins.</p>
          </div>
          <div class="risk-card">
            <h3>3. Advertising Cycle Dependency</h3>
            <p>Despite AI efficiencies, Meta remains overwhelmingly dependent on global digital advertising spend. A severe, prolonged global recession would compress ad budgets drastically, directly impacting Meta's free cash flow in the short to medium term.</p>
          </div>
        </div>
      </section>

      <section class="content-section faq-section">
        <h2>Frequently Asked Questions</h2>

        <div class="faq-item">
          <h3>Why did Gemini project a 16% Free Cash Flow growth rate for Meta?</h3>
          <p>Gemini projects 16% growth because Meta is already demonstrating massive ROI from its open-source AI models (Llama). AI integration is dramatically improving ad targeting efficiency and user engagement on Reels, expanding core margins even as Reality Labs investments continue.</p>
        </div>

        <div class="faq-item">
          <h3>What discount rate (WACC) was used in Meta's DCF analysis?</h3>
          <p>A 9.2% discount rate was used. This reflects the 4.18% risk-free rate and Meta's slightly elevated beta compared to some big tech peers, while acknowledging its unparalleled cash-generation capabilities and global user base.</p>
        </div>

        <div class="faq-item">
          <h3>How does Meta's Metaverse investment impact its intrinsic value?</h3>
          <p>The massive CapEx for Reality Labs is already priced into the base FCF of $46.1B. If these investments eventually yield a dominant mixed-reality platform, it acts as a call option on top of this valuation. If they fail but spending is curtailed, FCF margins will expand significantly faster than projected.</p>
        </div>
      </section>

      <div class="disclaimer-box">
        <p><strong>Disclaimer:</strong> The numbers presented on this page are for educational and entertainment purposes only. They are the result of a deterministic mathematical model fed with assumptions generated by an Artificial Intelligence (Gemini 3.1). This does not constitute investment advice. Always conduct your own due diligence before investing in the stock market.</p>
      </div>

    </div>
  </div>
</SiteLayout>
