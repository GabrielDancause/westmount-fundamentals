const holdingsData = [{"symbol":"NVDA","holdingName":"NVIDIA Corp","holdingPercent":0.0661532},{"symbol":"AAPL","holdingName":"Apple Inc","holdingPercent":0.057487402},{"symbol":"MSFT","holdingName":"Microsoft Corp","holdingPercent":0.0479509},{"symbol":"AMZN","holdingName":"Amazon.com Inc","holdingPercent":0.034518298},{"symbol":"GOOGL","holdingName":"Alphabet Inc Class A","holdingPercent":0.0294768},{"symbol":"AVGO","holdingName":"Broadcom Inc","holdingPercent":0.0234558},{"symbol":"META","holdingName":"Meta Platforms Inc Class A","holdingPercent":0.023395099},{"symbol":"GOOG","holdingName":"Alphabet Inc Class C","holdingPercent":0.023333099},{"symbol":"TSLA","holdingName":"Tesla Inc","holdingPercent":0.0182412},{"symbol":"LLY","holdingName":"Eli Lilly and Co","holdingPercent":0.0132287005}];
        const sectorDataRaw = [{"realestate":0.023599999},{"consumer_cyclical":0.105},{"basic_materials":0.0202},{"consumer_defensive":0.0473},{"technology":0.32119998},{"communication_services":0.1035},{"financial_services":0.1285},{"utilities":0.0223},{"industrials":0.0943},{"energy":0.0332},{"healthcare":0.1009}];

        // Interactive Table Logic
        const tbody = document.getElementById('tableBody');
        const searchInput = document.getElementById('searchInput');

        function renderTable(data) {
            tbody.innerHTML = '';
            if(!data || data.length === 0) {
                tbody.innerHTML = '<tr><td colspan="3" style="text-align:center">No data available</td></tr>';
                return;
            }

            data.forEach(item => {
                const tr = document.createElement('tr');
                // Use actual backticks with escaped variables for the client-side JS template literal!
                tr.innerHTML = `
                    <td>${item.symbol || 'N/A'}</td>
                    <td>${item.holdingName || 'N/A'}</td>
                    <td class="text-right">${item.holdingPercent != null ? (item.holdingPercent * 100).toFixed(2) + '%' : 'N/A'}</td>
                `;
                tbody.appendChild(tr);
            });
        }

        renderTable(holdingsData.slice(0, 10)); // Display top 10 initially

        searchInput.addEventListener('input', (e) => {
            const term = e.target.value.toLowerCase();
            const filtered = holdingsData.filter(h =>
                (h.symbol && h.symbol.toLowerCase().includes(term)) ||
                (h.holdingName && h.holdingName.toLowerCase().includes(term))
            );
            renderTable(term ? filtered : holdingsData.slice(0, 10));
        });

        // Expose to window for Playwright tests
        window.dispatchEvent = function(event) {
            if(event && event.type === 'keyup') {
                searchInput.dispatchEvent(new Event('input'));
            }
        };

        // Chart.js Logic
        if (sectorDataRaw && sectorDataRaw.length > 0) {
            const ctx = document.getElementById('sectorChart').getContext('2d');

            // Format sector data
            const labels = [];
            const data = [];

            sectorDataRaw.forEach(obj => {
                const key = Object.keys(obj)[0];
                const value = obj[key];
                if (value != null && value > 0) {
                    // Format key (e.g. 'consumer_cyclical' -> 'Consumer Cyclical')
                    const formattedKey = key.split('_').map(word => word.charAt(0).toUpperCase() + word.slice(1)).join(' ');
                    labels.push(formattedKey);
                    data.push(value * 100);
                }
            });

            new Chart(ctx, {
                type: 'doughnut',
                data: {
                    labels: labels,
                    datasets: [{
                        data: data,
                        backgroundColor: [
                            '#4a8fe7', '#3b82f6', '#60a5fa', '#93c5fd', '#bfdbfe',
                            '#10b981', '#34d399', '#6ee7b7', '#a7f3d0', '#8b5cf6', '#a78bfa'
                        ],
                        borderColor: '#060a12',
                        borderWidth: 2
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: {
                            position: 'right',
                            labels: {
                                color: '#e2e8f0',
                                font: {
                                    family: "'Inter', sans-serif"
                                }
                            }
                        },
                        tooltip: {
                            callbacks: {
                                label: function(context) {
                                    return context.label + ': ' + context.parsed.toFixed(2) + '%';
                                }
                            }
                        }
                    }
                }
            });
        }
  </script>
