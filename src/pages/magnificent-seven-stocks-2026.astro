  <script is:inline>
// Native HTML5 Canvas Chart Drawing
        window.addEventListener('DOMContentLoaded', () => {
            const canvas = document.getElementById('weightChart');
            if (!canvas) return;
            const ctx = canvas.getContext('2d');

            // Handle resizing
            function resizeCanvas() {
                const parent = canvas.parentElement;
                // Subtract padding
                canvas.width = parent.clientWidth - 48;
                canvas.height = parent.clientHeight - 48;
                drawChart();
            }

            window.addEventListener('resize', resizeCanvas);

            const rawStocksData = [{"symbol":"AAPL","name":"Apple Inc.","price":261.05,"marketCap":3836893200384,"pe":33.0443,"revenueGrowth":0.157,"ytdReturn":-0.036751446096912097,"weightInSp500":0.066321105},{"symbol":"MSFT","name":"Microsoft Corp.","price":403.68,"marketCap":3000302305280,"pe":25.245779,"revenueGrowth":0.167,"ytdReturn":-0.1464456423306824,"weightInSp500":0.049592398},{"symbol":"GOOGL","name":"Alphabet Inc.","price":309.04,"marketCap":3738457079808,"pe":28.588345,"revenueGrowth":0.18,"ytdReturn":-0.019387574218044476,"weightInSp500":0.055417498},{"symbol":"AMZN","name":"Amazon.com Inc.","price":212.885,"marketCap":2285303496704,"pe":29.649721,"revenueGrowth":0.136,"ytdReturn":-0.06011037527593823,"weightInSp500":0.0347072},{"symbol":"NVDA","name":"NVIDIA Corp.","price":185.8785,"marketCap":4517777113088,"pe":37.933674,"revenueGrowth":0.732,"ytdReturn":-0.015734741898217525,"weightInSp500":0.0731529},{"symbol":"META","name":"Meta Platforms Inc.","price":652.4234,"marketCap":1650341183488,"pe":27.786346,"revenueGrowth":0.238,"ytdReturn":0.003095627279105928,"weightInSp500":0.0239825},{"symbol":"TSLA","name":"Tesla Inc.","price":408.02,"marketCap":1531067236352,"pe":377.79626,"revenueGrowth":-0.031,"ytdReturn":-0.06859635862260377,"weightInSp500":0.0192144}];
            const combinedWeight = 0.3223880010000001;

            // Sort by weight
            const chartData = [...rawStocksData].sort((a, b) => (b.weightInSp500 || 0) - (a.weightInSp500 || 0));

            function drawChart() {
                ctx.clearRect(0, 0, canvas.width, canvas.height);

                const width = canvas.width;
                const height = canvas.height;
                const padding = 40;

                const labels = [...chartData.map(d => d.symbol), 'Rest of S&P 500'];
                const weights = [...chartData.map(d => d.weightInSp500 || 0), 1 - combinedWeight];

                // Draw pie chart
                const centerX = width / 2;
                const centerY = height / 2;
                const radius = Math.min(centerX, centerY) - padding;

                let startAngle = -0.5 * Math.PI; // Start at top

                const colors = [
                    '#4a8fe7', '#3b82f6', '#2563eb', '#1d4ed8',
                    '#1e40af', '#1e3a8a', '#172554', '#1f2937'
                ];

                for (let i = 0; i < weights.length; i++) {
                    const sliceAngle = 2 * Math.PI * weights[i];
                    const endAngle = startAngle + sliceAngle;

                    ctx.beginPath();
                    ctx.moveTo(centerX, centerY);
                    ctx.arc(centerX, centerY, radius, startAngle, endAngle);
                    ctx.closePath();

                    ctx.fillStyle = colors[i % colors.length];
                    ctx.fill();
                    ctx.lineWidth = 1;
                    ctx.strokeStyle = '#0a1020';
                    ctx.stroke();

                    // Labels for larger slices
                    if (weights[i] > 0.02) {
                        const midAngle = startAngle + sliceAngle / 2;
                        const labelRadius = radius * 0.7;
                        const labelX = centerX + Math.cos(midAngle) * labelRadius;
                        const labelY = centerY + Math.sin(midAngle) * labelRadius;

                        ctx.fillStyle = '#ffffff';
                        ctx.font = 'bold 12px "JetBrains Mono", monospace';
                        ctx.textAlign = 'center';
                        ctx.textBaseline = 'middle';
                        ctx.fillText(labels[i], labelX, labelY - 8);
                        ctx.font = '10px "JetBrains Mono", monospace';
                        ctx.fillText((weights[i] * 100).toFixed(1) + '%', labelX, labelY + 8);
                    }

                    startAngle = endAngle;
                }
            }

            resizeCanvas();
        });
  </script>

  
