---
import SiteLayout from "../layouts/SiteLayout.astro";

const schema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": "Marsh & McLennan (MMC) Intrinsic Value: A DCF Analysis",
  "description": "A transparent, step-by-step discounted cash flow valuation of Marsh & McLennan Companies. Using actual FY2025 financials to arrive at a single fair value estimate for MMC shares.",
  "datePublished": "2026-03-18",
  "dateModified": "2026-03-18",
  "author": {
    "@type": "Organization",
    "name": "Westmount Research",
    "url": "https://westmountfundamentals.com"
  },
  "publisher": {
    "@type": "Organization",
    "name": "Westmount Research",
    "url": "https://westmountfundamentals.com"
  },
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": "https://westmountfundamentals.com/marsh-mclennan-intrinsic-value"
  }
};

export const meta = {
  title: "Marsh & McLennan (MMC) Intrinsic Value: A DCF Analysis",
  description: "We ran a full discounted cash flow on Marsh & McLennan using FY2025 actuals. One number. Every assumption disclosed. Here's what MMC is really worth.",
  category: "study",
  published: "2026-03-18",
};

/* ═══════════════════════════════════════════════════════════════
   DCF MODEL — ALL INPUTS AND CALCULATIONS
   We use a two-stage DCF: steady growth phase (Years 1-5) then terminal value.
   ═══════════════════════════════════════════════════════════════ */

import * as cheerio from 'cheerio';

async function fetchFinancials() {
  const getRowData = ($, title) => {
    let vals = [];
    $('table tbody tr').each((i, el) => {
      if ($(el).find('td').first().text().trim() === title) {
        $(el).find('td').each((j, td) => { if (j > 0) vals.push($(td).text().trim().replace(/,/g, '')); });
      }
    });
    return vals;
  };

  const incRes = await fetch('https://stockanalysis.com/stocks/mrsh/financials/');
  const incHtml = await incRes.text();
  const $inc = cheerio.load(incHtml);

  const cfRes = await fetch('https://stockanalysis.com/stocks/mrsh/financials/cash-flow-statement/');
  const cfHtml = await cfRes.text();
  const $cf = cheerio.load(cfHtml);

  const bsRes = await fetch('https://stockanalysis.com/stocks/mrsh/financials/balance-sheet/');
  const bsHtml = await bsRes.text();
  const $bs = cheerio.load(bsHtml);

  const fcfHist = getRowData($cf, 'Free Cash Flow').slice(0, 5).map(v => parseInt(v) || 0);
  const revHist = getRowData($inc, 'Revenue').slice(0, 5).map(v => parseInt(v) || 0);
  const epsHist = getRowData($inc, 'EPS (Diluted)').slice(0, 5).map(v => parseFloat(v) || 0);
  const shares = parseInt(getRowData($inc, 'Shares Outstanding (Basic)')[0] || 491);
  const cash = parseInt(getRowData($bs, 'Cash & Equivalents')[0] || 2687);
  const debt = parseInt(getRowData($bs, 'Total Debt')[0] || 21449);

  return {
    fcf2025: fcfHist[0] || 5001,
    sharesOutstanding: shares,
    cashAndInvestments: cash,
    totalDebt: debt,
    fcfHist, revHist, epsHist
  };
}

const data = await fetchFinancials();

// --- INPUTS (all in millions USD unless noted) ---
const fcf2025 = data.fcf2025;                // FY2025 Free Cash Flow ($M)
const sharesOutstanding = data.sharesOutstanding;       // Basic shares outstanding ($M) — FY2025
const cashAndInvestments = data.cashAndInvestments;     // Cash + short-term investments ($M)
const totalDebt = data.totalDebt;              // Total debt ($M)
const netCash = cashAndInvestments - totalDebt; // -$18,762M

// --- ASSUMPTIONS (fully disclosed below) ---
const growthRatePhase1 = 0.08;         // 8% FCF growth, Years 1-5
const growthRateTerminal = 0.03;       // 3% perpetuity growth (terminal)
const discountRate = 0.09;             // 9% WACC / required return

// --- PHASE 1: PROJECT FCF FOR YEARS 1-5 ---
const projectedFCF = [];
let fcf = fcf2025;
for (let yr = 1; yr <= 5; yr++) {
  fcf = fcf * (1 + growthRatePhase1);
  projectedFCF.push({ year: yr, fcf: Math.round(fcf), pvFactor: 1 / Math.pow(1 + discountRate, yr) });
}
projectedFCF.forEach(p => { p.pvFCF = Math.round(p.fcf * p.pvFactor); });

// --- PHASE 2: TERMINAL VALUE (Gordon Growth Model) ---
const fcfYear6 = projectedFCF[4].fcf * (1 + growthRateTerminal);
const terminalValue = Math.round(fcfYear6 / (discountRate - growthRateTerminal));
const pvTerminalValue = Math.round(terminalValue * projectedFCF[4].pvFactor);

// --- ENTERPRISE VALUE ---
const pvPhase1 = projectedFCF.reduce((sum, p) => sum + p.pvFCF, 0);
const enterpriseValue = pvPhase1 + pvTerminalValue;

// --- EQUITY VALUE ---
const equityValue = enterpriseValue + netCash;
const intrinsicValuePerShare = equityValue / sharesOutstanding;
const roundedIV = Math.round(intrinsicValuePerShare * 100) / 100;

// Market comparison
const currentPrice = 206.00;
const marginOfSafety = ((roundedIV - currentPrice) / currentPrice * 100).toFixed(1);
const verdictText = roundedIV > currentPrice ? "Undervalued" : "Overvalued";
const verdictColor = roundedIV > currentPrice ? "#10b981" : "#ef4444";

// --- HISTORICAL DATA for charts ---
const revenueHistory = [
  { year: 2021, value: data.revHist[4] || 19820 },
  { year: 2022, value: data.revHist[3] || 20720 },
  { year: 2023, value: data.revHist[2] || 22736 },
  { year: 2024, value: data.revHist[1] || 24458 },
  { year: 2025, value: data.revHist[0] || 26981 },
];
const fcfHistory = [
  { year: 2021, value: data.fcfHist[4] || 3110 },
  { year: 2022, value: data.fcfHist[3] || 2995 },
  { year: 2023, value: data.fcfHist[2] || 3842 },
  { year: 2024, value: data.fcfHist[1] || 3986 },
  { year: 2025, value: data.fcfHist[0] || 5001 },
];
const epsHistory = [
  { year: 2021, value: data.epsHist[4] || 6.13 },
  { year: 2022, value: data.epsHist[3] || 6.04 },
  { year: 2023, value: data.epsHist[2] || 7.53 },
  { year: 2024, value: data.epsHist[1] || 7.58 },
  { year: 2025, value: data.epsHist[0] || 8.43 },
];

const marginHistory = [
  { year: 2021, operating: 21.6, profit: 15.8, fcfMargin: 15.7 },
  { year: 2022, operating: 20.8, profit: 14.7, fcfMargin: 14.5 },
  { year: 2023, operating: 22.4, profit: 16.6, fcfMargin: 16.9 },
  { year: 2024, operating: 23.3, profit: 15.4, fcfMargin: 16.3 },
  { year: 2025, operating: 23.1, profit: 15.4, fcfMargin: 18.5 },
];

// --- SENSITIVITY TABLE GENERATION (5x5 matrix) ---
const sensitivityGrowth = [0.04, 0.06, 0.08, 0.10, 0.12]; // +/- 2% from base
const sensitivityDR = [0.07, 0.08, 0.09, 0.10, 0.11];     // +/- 1% from base
const sensitivityTable = [];

sensitivityDR.forEach(dr => {
  const row = { dr, values: [] };
  sensitivityGrowth.forEach(g => {
    let pFCF = [];
    let cf = fcf2025;
    for (let i = 1; i <= 5; i++) {
      cf = cf * (1 + g);
      pFCF.push(cf / Math.pow(1 + dr, i));
    }
    const pvP1 = pFCF.reduce((a, b) => a + b, 0);
    const cf6 = (fcf2025 * Math.pow(1 + g, 5)) * (1 + growthRateTerminal);
    const tv = cf6 / (dr - growthRateTerminal);
    const pvTV = tv / Math.pow(1 + dr, 5);
    const ev = pvP1 + pvTV;
    const eq = ev + netCash;
    let iv = Math.round((eq / sharesOutstanding) * 100) / 100;
    // Cap absurd values if they arise due to dr <= terminal rate
    if (dr <= growthRateTerminal) iv = "N/A";
    row.values.push(iv.toFixed(2));
  });
  sensitivityTable.push(row);
});
