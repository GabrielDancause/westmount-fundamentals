---
import SiteLayout from "../layouts/SiteLayout.astro";
import https from 'https';

export const meta = {
  title: "Marsh & McLennan (MRSH) Intrinsic Value: A DCF Analysis",
  description: "A transparent, step-by-step discounted cash flow valuation of Marsh & McLennan using latest financials. Compiled by Gemini 3.1.",
  category: "study",
  published: "2024-05-01",
};

const schema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": "Marsh & McLennan (MRSH) Intrinsic Value: A DCF Analysis",
  "description": "A transparent, step-by-step discounted cash flow valuation of Marsh & McLennan using latest financials.",
  "datePublished": "2024-05-01",
  "dateModified": "2024-05-01",
  "author": {
    "@type": "Organization",
    "name": "Westmount Research",
    "url": "https://westmountfundamentals.com"
  },
  "publisher": {
    "@type": "Organization",
    "name": "Westmount Research",
    "url": "https://westmountfundamentals.com"
  },
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": "https://westmountfundamentals.com/marsh-mclennan-intrinsic-value"
  }
};

/* ═══════════════════════════════════════════════════════════════
   DATA FETCHING FROM STOCKANALYSIS.COM
   ═══════════════════════════════════════════════════════════════ */
async function fetchHTML(url) {
  return new Promise((resolve, reject) => {
    https.get(url, {
      headers: {
        'User-Agent': 'Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36'
      }
    }, (res) => {
      let data = '';
      res.on('data', chunk => data += chunk);
      res.on('end', () => resolve(data));
    }).on('error', reject);
  });
}

function extractFinancialData(html) {
  const startIdx = html.indexOf('financialData:');
  if (startIdx !== -1) {
    const startBrace = html.indexOf('{', startIdx);
    let braceCount = 0;
    let endIdx = -1;
    for (let i = startBrace; i < html.length; i++) {
      if (html[i] === '{') braceCount++;
      else if (html[i] === '}') braceCount--;
      if (braceCount === 0) {
        endIdx = i;
        break;
      }
    }
    if (endIdx !== -1) {
      const objStr = html.substring(startBrace, endIdx + 1);
      try {
        return eval(`(${objStr})`);
      } catch (e) {
        return null;
      }
    }
  }
  return null;
}

let isData, cfsData, bsData, tickerHtml;

try {
  const isHtml = await fetchHTML('https://stockanalysis.com/stocks/mrsh/financials/');
  const cfsHtml = await fetchHTML('https://stockanalysis.com/stocks/mrsh/financials/cash-flow-statement/');
  const bsHtml = await fetchHTML('https://stockanalysis.com/stocks/mrsh/financials/balance-sheet/');
  tickerHtml = await fetchHTML('https://stockanalysis.com/stocks/mrsh/');

  isData = extractFinancialData(isHtml) || {};
  cfsData = extractFinancialData(cfsHtml) || {};
  bsData = extractFinancialData(bsHtml) || {};
} catch (e) {
  console.error("Fetch failed", e);
  isData = {};
  cfsData = {};
  bsData = {};
  tickerHtml = '';
}

// Extract base arrays
const revArr = isData.revenue || [];
const opIncArr = isData.operatingIncome || [];
const niArr = isData.netIncome || [];
const epsArr = isData.epsDiluted || [];
const sharesArr = isData.sharesDiluted || [];
const fcfArr = cfsData.fcf || [];
const cashArr = bsData.totalcash || bsData.cashneq || [];
const debtArr = bsData.debt || [];
const yearArr = isData.fiscalYear || [];

// Fallback to null if empty
const currentYear = yearArr.length > 0 ? yearArr[0] : null;
const fcfBase = fcfArr.length > 0 ? fcfArr[0] : null;
const sharesOutstanding = sharesArr.length > 0 ? sharesArr[0] / 1e6 : null; // in millions
const totalCash = cashArr.length > 0 ? cashArr[0] : null;
const totalDebt = debtArr.length > 0 ? debtArr[0] : null;
const netCash = totalCash !== null && totalDebt !== null ? totalCash - totalDebt : null;
const revenueBase = revArr.length > 0 ? revArr[0] : null;
const epsBase = epsArr.length > 0 ? epsArr[0] : null;

// Ticker price
let currentPrice = null;
const priceMatch = tickerHtml ? tickerHtml.match(/<div class="[^"]*text-4xl[^"]*"[^>]*>([\d\.,]+)<\/div>/) : null;
if (priceMatch) {
  currentPrice = Number(priceMatch[1].replace(/,/g, ''));
}

/* ═══════════════════════════════════════════════════════════════
   DCF MODEL — ALL INPUTS AND CALCULATIONS
   ═══════════════════════════════════════════════════════════════ */

// --- DERIVED ASSUMPTIONS ---
let growthRatePhase1 = 0;
let discountRate = 0;
let growthRateTerminal = 0.03; // Base nominal GDP
const treasury10Y = 0.0418;

// Math derivation: Average 5-year historical FCF growth
if (fcfArr.length >= 6 && fcfArr[5] !== null && fcfArr[0] !== null && fcfArr[5] > 0 && fcfArr[0] > 0) {
  const cagr = Math.pow(fcfArr[0] / fcfArr[5], 1 / 5) - 1;
  growthRatePhase1 = Math.max(0, Math.min(cagr, 0.15)); // Cap at 15% to be conservative
} else if (revArr.length >= 6 && revArr[5] !== null && revArr[0] !== null && revArr[5] > 0 && revArr[0] > 0) {
    const cagr = Math.pow(revArr[0] / revArr[5], 1 / 5) - 1;
    growthRatePhase1 = Math.max(0, Math.min(cagr, 0.15));
} else {
    // Failsafe derived from recent revenue growth
    if (revArr.length >= 2 && revArr[1] !== null && revArr[0] !== null && revArr[1] > 0) {
        growthRatePhase1 = Math.max(0, Math.min((revArr[0] - revArr[1]) / revArr[1], 0.15));
    } else {
        growthRatePhase1 = 0.05;
    }
}

// Discount rate derivation:
// Marsh & McLennan is a stable professional services/insurance brokerage firm.
// Beta is typically low (around 0.9). Using 4.18% Treasury + (0.9 * 5.5% ERP) = ~9.13%
// Let's derive it precisely: 4.18% + 5.0%
discountRate = treasury10Y + 0.05;

// --- PHASE 1: PROJECT FCF FOR YEARS 1-5 ---
const projectedFCF = [];
let fcf = fcfBase !== null ? fcfBase / 1e6 : 0; // Convert to millions
for (let yr = 1; yr <= 5; yr++) {
  fcf = fcf * (1 + growthRatePhase1);
  projectedFCF.push({ year: yr, fcf: Math.round(fcf), pvFactor: 1 / Math.pow(1 + discountRate, yr) });
}
projectedFCF.forEach(p => { p.pvFCF = Math.round(p.fcf * p.pvFactor); });

// --- PHASE 2: TERMINAL VALUE (Gordon Growth Model) ---
const fcfYear6 = projectedFCF.length > 0 ? projectedFCF[4].fcf * (1 + growthRateTerminal) : 0;
const terminalValue = (discountRate > growthRateTerminal) ? Math.round(fcfYear6 / (discountRate - growthRateTerminal)) : 0;
const pvTerminalValue = projectedFCF.length > 0 ? Math.round(terminalValue * projectedFCF[4].pvFactor) : 0;

// --- ENTERPRISE VALUE ---
const pvPhase1 = projectedFCF.reduce((sum, p) => sum + p.pvFCF, 0);
const enterpriseValue = pvPhase1 + pvTerminalValue;

// --- EQUITY VALUE ---
const netCashM = netCash !== null ? netCash / 1e6 : 0;
const equityValue = enterpriseValue + netCashM;
const intrinsicValuePerShare = sharesOutstanding && sharesOutstanding > 0 ? equityValue / sharesOutstanding : 0;
const roundedIV = Math.round(intrinsicValuePerShare * 100) / 100;

// Market comparison
let marginOfSafety = null;
let verdictText = "Unknown";
let verdictColor = "#888";

if (currentPrice !== null && roundedIV > 0) {
  marginOfSafety = ((roundedIV - currentPrice) / currentPrice * 100).toFixed(1);
  verdictText = roundedIV > currentPrice ? "Undervalued" : "Overvalued";
  verdictColor = roundedIV > currentPrice ? "#10b981" : "#ef4444";
} else if (currentPrice === null && roundedIV > 0) {
    verdictText = "Calculated";
    verdictColor = "#4a8fe7";
}

// --- HISTORICAL DATA for charts ---
// Reverse the arrays so oldest is first
const rRev = [...revArr].reverse();
const rFcf = [...fcfArr].reverse();
const rEps = [...epsArr].reverse();
const rYear = [...yearArr].reverse();
const rOp = [...opIncArr].reverse();
const rNi = [...niArr].reverse();

const revenueHistory = rYear.map((y, i) => ({ year: y, value: rRev[i] })).filter(d => d.value !== undefined && d.value !== null);
const fcfHistory = rYear.map((y, i) => ({ year: y, value: rFcf[i] })).filter(d => d.value !== undefined && d.value !== null);
const epsHistory = rYear.map((y, i) => ({ year: y, value: rEps[i] })).filter(d => d.value !== undefined && d.value !== null);
const marginHistory = rYear.map((y, i) => {
    if (rOp[i] === null || rRev[i] === null || rNi[i] === null || rFcf[i] === null) return null;
    return {
        year: y,
        operating: ((rOp[i] / rRev[i]) * 100).toFixed(1),
        profit: ((rNi[i] / rRev[i]) * 100).toFixed(1),
        fcfMargin: ((rFcf[i] / rRev[i]) * 100).toFixed(1)
    };
}).filter(m => m !== null);

const maxRev = Math.max(...revenueHistory.map(d => d.value || 0), 1);
const maxFcf = Math.max(...fcfHistory.map(d => d.value || 0), 1);
const maxEps = Math.max(...epsHistory.map(d => d.value || 0), 1);

// Sensitivity analysis
const sensitivityRates = [
    discountRate - 0.02,
    discountRate - 0.01,
    discountRate,
    discountRate + 0.01,
    discountRate + 0.02
];
const sensitivityGrowth = [
    Math.max(0, growthRatePhase1 - 0.04),
    Math.max(0, growthRatePhase1 - 0.02),
    growthRatePhase1,
    growthRatePhase1 + 0.02,
    growthRatePhase1 + 0.04
];
const sensitivityTable = sensitivityRates.map(dr => {
  return {
    dr,
    values: sensitivityGrowth.map(gr => {
      let f = fcfBase !== null ? fcfBase / 1e6 : 0;
      let pvSum = 0;
      for (let y = 1; y <= 5; y++) {
        f = f * (1 + gr);
        pvSum += f / Math.pow(1 + dr, y);
      }
      const f6 = f * (1 + growthRateTerminal);
      const tv = dr > growthRateTerminal ? f6 / (dr - growthRateTerminal) : 0;
      const pvTV = tv / Math.pow(1 + dr, 5);
      return sharesOutstanding && sharesOutstanding > 0 ? Math.round((pvSum + pvTV + netCashM) / sharesOutstanding) : 0;
    })
  };
});
---

<SiteLayout
  site="westmount"
  title="Marsh & McLennan (MRSH) Intrinsic Value: A DCF Analysis"
  description="A transparent, step-by-step discounted cash flow valuation of Marsh & McLennan using latest financials."
  canonical="https://westmountfundamentals.com/marsh-mclennan-intrinsic-value"
  schema={schema}
>
<style is:global>
  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800;900&family=JetBrains+Mono:wght@400;700;800&display=swap');
  *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
  body { font-family: 'Inter', -apple-system, sans-serif; background: #060a12; color: #c8d0de; line-height: 1.7; }
</style>
<style>
.dcf-wrapper { padding-bottom: 60px; }
a { color: #4a8fe7; text-decoration: none; }
a:hover { text-decoration: underline; }
.container { max-width: 900px; margin: 0 auto; padding: 0 24px; }

/* Header */
.header { text-align: center; padding: 80px 24px 60px; background: linear-gradient(180deg, #0a1628 0%, #060a12 100%); position: relative; border-bottom: 1px solid #152040; }
