---
import SiteLayout from "../layouts/SiteLayout.astro";

// --- METADATA ---
export const meta = {
  title: "IBM Corporation (IBM) Intrinsic Value - Gemini's DCF Analysis",
  description: "An independent discounted cash flow (DCF) intrinsic value analysis of IBM Corporation (IBM) compiled entirely by Gemini 3.1.",
  category: "study",
  published: "2026-03-18",
};

// --- DATA & ASSUMPTIONS (FY2025 Actuals) ---
// FCF Growth (Y1-Y5): 4.5%. IBM is no longer a declining legacy business. Hybrid cloud and watsonx are stabilizing revenues and driving margin expansion. A 4.5% FCF growth reflects a realistic but constructive turnaround.
// Discount Rate (WACC): 7.5%. With a lower beta, predictable recurring revenues, and a strong dividend, IBM commands a lower risk premium than high-growth tech peers.
// Terminal Growth: 2.0%. A standard GDP/inflation anchor, recognizing that IBM is a mature, stable enterprise moving forward.

const baseFCF = 12102; // in Millions
const sharesOut = 949; // in Millions (Diluted)
const currentPrice = 254.68;
const netCash = 13587 - 64607; // Cash (13587) - Total Debt (64607) = -51020 (Net Debt)

const fcfGrowthRate = 0.045;
const discountRate = 0.075;
const terminalGrowthRate = 0.020;

// --- YEAR 1 TO 5 PROJECTIONS ---
const projections = [];
let prevFCF = baseFCF;

for (let i = 1; i <= 5; i++) {
  const projectedFCF = prevFCF * (1 + fcfGrowthRate);
  const discountFactor = Math.pow(1 + discountRate, i);
  const pvOfFCF = projectedFCF / discountFactor;

  projections.push({
    year: `Year ${i}`,
    fcf: projectedFCF,
    pv: pvOfFCF
  });

  prevFCF = projectedFCF;
}

const sumPvFcf = projections.reduce((sum, p) => sum + p.pv, 0);

// --- TERMINAL VALUE ---
const year5FCF = projections[4].fcf;
const terminalValue = (year5FCF * (1 + terminalGrowthRate)) / (discountRate - terminalGrowthRate);
const pvTerminalValue = terminalValue / Math.pow(1 + discountRate, 5);

// --- INTRINSIC VALUE CALCULATION ---
const enterpriseValue = sumPvFcf + pvTerminalValue;
const totalEquityValue = enterpriseValue + netCash; // netCash is negative, so this correctly subtracts net debt
const intrinsicValuePerShare = totalEquityValue / sharesOut;

// Value vs Current Price
const marginOfSafety = ((intrinsicValuePerShare - currentPrice) / currentPrice) * 100;
const isUndervalued = intrinsicValuePerShare > currentPrice;

// --- SENSITIVITY MATRIX ---
const sensitivityDiscountRates = [0.065, 0.070, 0.075, 0.080, 0.085];
const sensitivityGrowthRates = [0.010, 0.015, 0.020, 0.025, 0.030];

const sensitivityMatrix = sensitivityGrowthRates.map(g => {
  return {
    growthRate: g,
    values: sensitivityDiscountRates.map(d => {
      // Re-calculate TV and PV with new rates
      const currentTerminalValue = (year5FCF * (1 + g)) / (d - g);
      const currentPvTerminalValue = currentTerminalValue / Math.pow(1 + d, 5);

      // Re-calculate PV of FCFs with new discount rate
      let currentSumPvFcf = 0;
      let tempFcf = baseFCF;
      for (let i = 1; i <= 5; i++) {
        tempFcf = tempFcf * (1 + fcfGrowthRate);
        currentSumPvFcf += tempFcf / Math.pow(1 + d, i);
      }

      const currentEV = currentSumPvFcf + currentPvTerminalValue;
      const currentEquity = currentEV + netCash;
      const currentIV = currentEquity / sharesOut;

      return currentIV;
    })
  };
});

// Formatting helpers
const formatMoney = (val) => new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD', minimumFractionDigits: 2, maximumFractionDigits: 2 }).format(val);
const formatMillions = (val) => '$' + new Intl.NumberFormat('en-US', { maximumFractionDigits: 0 }).format(val) + 'M';
const formatPercent = (val) => (val * 100).toFixed(1) + '%';

// --- SCHEMA ---
const schema = [
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": meta.title,
    "description": meta.description,
    "author": {
      "@type": "Organization",
      "name": "Gemini 3.1"
    },
    "publisher": {
      "@type": "Organization",
      "name": "Westmount Fundamentals",
      "logo": {
        "@type": "ImageObject",
        "url": "https://westmountfundamentals.com/logo.png"
      }
    },
    "mainEntityOfPage": {
      "@type": "WebPage",
      "@id": "https://westmountfundamentals.com/ibm-intrinsic-value"
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "Why did Gemini pick a 4.5% FCF growth rate for IBM?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Gemini projects that while IBM is a mature enterprise, its strategic pivot towards hybrid cloud and AI (watsonx) is creating high-margin, recurring revenue streams. A 4.5% growth rate acknowledges this successful turnaround and expected margin expansion without being overly aggressive."
        }
      },
      {
        "@type": "Question",
        "name": "What discount rate was used for IBM's DCF?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "A 7.5% discount rate was selected. This reflects IBM's stable, dividend-paying nature and lower beta compared to broader tech, balanced against its significant debt load and the current 4.18% risk-free rate."
        }
      },
      {
        "@type": "Question",
        "name": "How does IBM's debt impact its intrinsic value?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "IBM carries a substantial debt load of $64.6B compared to $13.5B in cash. This $51B net debt is subtracted directly from the Enterprise Value in the DCF model, significantly lowering the final equity value available to shareholders."
        }
      }
    ]
  }
];
---
<SiteLayout site="westmount" title={meta.title} description={meta.description} canonical="https://westmountfundamentals.com/ibm-intrinsic-value" schema={schema}>
  <div class="page-content">
    <div class="container">

      <div class="gemini-header">
        <div class="gemini-badge">COMPILED BY GEMINI 3.1</div>
        <h1>IBM Corporation (IBM) Intrinsic Value</h1>
        <p class="subtitle">An independent two-stage DCF analysis by a frontier AI model.</p>
      </div>

      <div class="verdict-card">
        <div class="verdict-header">
          <h2>Fair Value Estimate</h2>
        </div>
        <div class="verdict-body">
          <div class="verdict-main">
            <span class="iv-value">{formatMoney(intrinsicValuePerShare)}</span>
            <span class="iv-label">per share</span>
          </div>
          <div class="verdict-stats">
            <div class="stat">
              <span class="stat-label">Current Price</span>
              <span class="stat-value">{formatMoney(currentPrice)}</span>
            </div>
            <div class="stat">
              <span class="stat-label">Margin of Safety</span>
              <span class={`stat-value ${isUndervalued ? 'positive' : 'negative'}`}>
                {isUndervalued ? '+' : ''}{marginOfSafety.toFixed(2)}%
              </span>
            </div>
            <div class="stat">
              <span class="stat-label">Verdict</span>
              <span class={`badge ${isUndervalued ? 'positive' : 'negative'}`}>
                {isUndervalued ? 'UNDERVALUED' : 'OVERVALUED'}
              </span>
            </div>
          </div>
        </div>
        <div class="verdict-footer">
          <p>Based on FY2025 actuals. Data via S&P Global (Mar 17, 2026).</p>
        </div>
      </div>

      <section class="content-section">
        <h2>The AI Thesis: Why the Turnaround is Real</h2>
        <p>For over a decade, IBM has been widely perceived as a lumbering legacy tech dinosaur. However, underneath the hood, a structural shift has taken place. The spin-off of Kyndryl effectively offloaded stagnant, low-margin infrastructure services, allowing IBM to pivot aggressively toward a hybrid cloud computing and enterprise AI model.</p>
        <p>The enterprise adoption of the <strong>watsonx</strong> platform for managing AI workloads securely on-premise and in the cloud marks a return to high-margin recurring revenue. While IBM's absolute top-line growth may not match the hyperscalers (AWS, Azure, Google Cloud), its profitability profile is expanding rapidly. I see this turnaround continuing to compound.</p>
      </section>

      <section class="content-section">
        <h2>My Assumptions & Rationale</h2>

        <div class="assumption-grid">
          <div class="assumption-card">
            <div class="card-title">FCF Growth Rate (Y1-Y5)</div>
            <div class="card-value">{formatPercent(fcfGrowthRate)}</div>
            <p><strong>Rationale:</strong> 4.5% strikes a balance between IBM's mature nature and its high-growth hybrid cloud segment. The company has demonstrated consecutive years of strong operating cash flow. We project that software sales and AI consulting will drive continued, steady free cash flow expansion over the next five years.</p>
          </div>

          <div class="assumption-card">
            <div class="card-title">Discount Rate (WACC)</div>
            <div class="card-value">{formatPercent(discountRate)}</div>
            <p><strong>Rationale:</strong> A 7.5% discount rate is utilized. Despite a substantial debt load, IBM maintains an investment-grade rating and a famously low beta (~0.7). Its robust, deeply ingrained enterprise relationships yield highly predictable cash flows, thereby reducing the required equity risk premium relative to volatile high-growth software peers.</p>
          </div>

          <div class="assumption-card">
            <div class="card-title">Terminal Growth Rate</div>
            <div class="card-value">{formatPercent(terminalGrowthRate)}</div>
            <p><strong>Rationale:</strong> 2.0% aligns roughly with long-term inflation and GDP expectations. I am acknowledging that while the turnaround is successful, IBM is fundamentally a mature enterprise transitioning out of a legacy slump, not a perpetual hyper-growth engine.</p>
          </div>
        </div>
      </section>

      <section class="content-section">
        <h2>Discounted Cash Flow (DCF) Projections</h2>
        <p>Starting with the FY2025 base FCF of {formatMillions(baseFCF)}, the table below outlines the 5-year projection discounted back to Present Value (PV) using the {formatPercent(discountRate)} WACC.</p>

        <div class="table-container">
          <table>
            <thead>
              <tr>
                <th>Period</th>
                <th>Projected FCF</th>
                <th>PV Factor ({formatPercent(discountRate)})</th>
                <th>Present Value</th>
              </tr>
            </thead>
            <tbody>
              {projections.map((p, index) => (
                <tr>
                  <td>{p.year}</td>
                  <td>{formatMillions(p.fcf)}</td>
                  <td>{(1 / Math.pow(1 + discountRate, index + 1)).toFixed(4)}</td>
                  <td>{formatMillions(p.pv)}</td>
                </tr>
              ))}
              <tr class="highlight-row">
                <td colspan="3"><strong>Sum of PV of FCFs (Years 1-5)</strong></td>
                <td><strong>{formatMillions(sumPvFcf)}</strong></td>
              </tr>
            </tbody>
          </table>
        </div>
      </section>

      <section class="content-section">
        <h2>Terminal & Final Valuation Math</h2>
        <p>The Terminal Value accounts for all cash flows from Year 6 into perpetuity, calculated using the Gordon Growth Model.</p>

        <div class="math-card">
          <div class="math-row">
            <span>Year 5 FCF</span>
            <span>{formatMillions(year5FCF)}</span>
          </div>
          <div class="math-row">
            <span>Terminal Value (TV) Calculation</span>
            <span>({formatMillions(year5FCF)} * {1 + terminalGrowthRate}) / ({discountRate} - {terminalGrowthRate})</span>
          </div>
          <div class="math-row">
            <span>Terminal Value</span>
            <span>{formatMillions(terminalValue)}</span>
          </div>
          <div class="math-row highlight">
            <span>PV of Terminal Value</span>
            <span>{formatMillions(pvTerminalValue)}</span>
          </div>
        </div>

        <p style="margin-top: 2rem;">Adding it all together with Net Debt:</p>

        <div class="math-card">
          <div class="math-row">
            <span>Sum of PV of FCFs (Years 1-5)</span>
            <span>{formatMillions(sumPvFcf)}</span>
          </div>
          <div class="math-row">
            <span>+ PV of Terminal Value</span>
            <span>{formatMillions(pvTerminalValue)}</span>
          </div>
          <div class="math-row">
            <span><strong>= Enterprise Value</strong></span>
            <span><strong>{formatMillions(enterpriseValue)}</strong></span>
          </div>
          <div class="math-row">
            <span>- Net Debt (Debt - Cash)</span>
            <span>{formatMillions(Math.abs(netCash))}</span>
          </div>
          <div class="math-row highlight">
            <span><strong>= Total Equity Value</strong></span>
            <span><strong>{formatMillions(totalEquityValue)}</strong></span>
          </div>
          <div class="math-row">
            <span>÷ Shares Outstanding</span>
            <span>{sharesOut.toLocaleString()}M</span>
          </div>
          <div class="math-row result">
            <span><strong>Intrinsic Value Per Share</strong></span>
            <span><strong>{formatMoney(intrinsicValuePerShare)}</strong></span>
          </div>
        </div>
      </section>

      <section class="content-section">
        <h2>Sensitivity Matrix</h2>
        <p>The matrix below demonstrates how the intrinsic value fluctuates when adjusting the Discount Rate (WACC) and the Terminal Growth Rate.</p>

        <div class="table-container sensitivity-table">
          <table>
            <thead>
              <tr>
                <th rowspan="2" class="corner-cell">Terminal<br/>Growth</th>
                <th colspan="5" class="header-cell">Discount Rate (WACC)</th>
              </tr>
              <tr>
                {sensitivityDiscountRates.map(d => <th>{formatPercent(d)}</th>)}
              </tr>
            </thead>
            <tbody>
              {sensitivityMatrix.map(row => (
                <tr>
                  <th class="row-header">{formatPercent(row.growthRate)}</th>
                  {row.values.map(val => (
                    <td class={
                      val > currentPrice * 1.15 ? "cell-undervalued" :
                      val < currentPrice * 0.85 ? "cell-overvalued" :
                      "cell-neutral"
                    }>
                      {formatMoney(val)}
                    </td>
                  ))}
                </tr>
              ))}
            </tbody>
          </table>
          <div class="matrix-legend">
            <span class="legend-item"><span class="color-box cell-undervalued"></span> Undervalued (>15% Margin)</span>
            <span class="legend-item"><span class="color-box cell-neutral"></span> Fair Value</span>
            <span class="legend-item"><span class="color-box cell-overvalued"></span> Overvalued (&lt;-15% Margin)</span>
          </div>
        </div>
      </section>

      <section class="content-section">
        <h2>Historical FCF Context (2021-2025)</h2>
        <p>IBM's cash flow stability is a central pillar of this model. Even during its complex transition away from legacy infrastructure, the company consistently generated significant free cash flow to support its massive dividend.</p>

        <div class="bar-chart-container">
          <div class="bar-chart">
            <div class="bar-group">
              <div class="bar" style="height: 60%;"><span class="bar-label">$10.7B</span></div>
              <div class="bar-year">2021</div>
            </div>
            <div class="bar-group">
              <div class="bar" style="height: 50%;"><span class="bar-label">$9.1B</span></div>
              <div class="bar-year">2022</div>
            </div>
            <div class="bar-group">
              <div class="bar" style="height: 71%;"><span class="bar-label">$12.7B</span></div>
              <div class="bar-year">2023</div>
            </div>
            <div class="bar-group">
              <div class="bar" style="height: 69%;"><span class="bar-label">$12.4B</span></div>
              <div class="bar-year">2024</div>
            </div>
            <div class="bar-group">
              <div class="bar highlight" style="height: 67%;"><span class="bar-label">$12.1B</span></div>
              <div class="bar-year">2025</div>
            </div>
          </div>
        </div>
      </section>

      <section class="content-section risks-section">
        <h2>Risks & Bear Case</h2>
        <p>A balanced evaluation of IBM must incorporate these significant headwinds:</p>
        <div class="risk-grid">
          <div class="risk-card">
            <h3>1. Massive Debt Load</h3>
            <p>IBM carries nearly $65 billion in total debt. While interest coverage is currently manageable, an extended period of high interest rates combined with any operational stumbles could squeeze cash flow and threaten its dividend payout.</p>
          </div>
          <div class="risk-card">
            <h3>2. Intense AI & Cloud Competition</h3>
            <p>While the hybrid cloud and watsonx are strong offerings, IBM faces ferocious competition from Microsoft, Amazon, and Google. If enterprises consolidate their AI workloads entirely onto public hyperscale clouds, IBM's hybrid thesis could unravel.</p>
          </div>
          <div class="risk-card">
            <h3>3. Consulting Drag</h3>
            <p>IBM's consulting segment is highly cyclical. If the broader macroeconomic environment experiences a sustained downturn, enterprise IT spending and large-scale transformation projects will be delayed, directly impacting IBM's top-line revenue.</p>
          </div>
        </div>
      </section>

      <section class="content-section faq-section">
        <h2>Frequently Asked Questions</h2>

        <div class="faq-item">
          <h3>Why did Gemini pick a 4.5% FCF growth rate for IBM?</h3>
          <p>Gemini projects that while IBM is a mature enterprise, its strategic pivot towards hybrid cloud and AI (watsonx) is creating high-margin, recurring revenue streams. A 4.5% growth rate acknowledges this successful turnaround and expected margin expansion without being overly aggressive.</p>
        </div>

        <div class="faq-item">
          <h3>What discount rate was used for IBM's DCF?</h3>
          <p>A 7.5% discount rate was selected. This reflects IBM's stable, dividend-paying nature and lower beta compared to broader tech, balanced against its significant debt load and the current 4.18% risk-free rate.</p>
        </div>

        <div class="faq-item">
          <h3>How does IBM's debt impact its intrinsic value?</h3>
          <p>IBM carries a substantial debt load of $64.6B compared to $13.5B in cash. This $51B net debt is subtracted directly from the Enterprise Value in the DCF model, significantly lowering the final equity value available to shareholders.</p>
        </div>
      </section>

      <div class="disclaimer-box">
        <p><strong>Disclaimer:</strong> The numbers presented on this page are for educational and entertainment purposes only. They are the result of a deterministic mathematical model fed with assumptions generated by an Artificial Intelligence (Gemini 3.1). This does not constitute investment advice. Always conduct your own due diligence before investing in the stock market.</p>
      </div>

    </div>
  </div>
</SiteLayout><style>
