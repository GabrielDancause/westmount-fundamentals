        const lostValue = finalNominal - finalReal;

        // Update DOM
        document.getElementById('val-nominal').innerText = formatCurrency(finalNominal);

        const elReal = document.getElementById('val-real');
        elReal.innerText = formatCurrency(finalReal);
        elReal.className = 'stat-value ' + (finalReal >= principal ? 'positive' : 'negative');

        const elRate = document.getElementById('val-real-rate');
        elRate.innerText = formatPercent(realRate * 100);
        elRate.className = 'stat-value ' + (realRate >= 0 ? 'positive' : 'negative');

        document.getElementById('val-lost').innerText = formatCurrency(lostValue);

        updateGrowthChart(labels, nominalData, realData, principalData);
    }

    function updateGrowthChart(labels, nominal, real, principal) {
        const ctx = document.getElementById('growthChart').getContext('2d');

        if(growthChartInstance) {
            growthChartInstance.destroy();
        }

        growthChartInstance = new Chart(ctx, {
            type: 'line',
            data: {
                labels: labels,
                datasets: [
                    {
                        label: 'Nominal Balance',
                        data: nominal,
                        borderColor: '#94a3b8',
                        backgroundColor: 'transparent',
                        borderWidth: 2,
                        tension: 0.1,
                        pointRadius: 0
                    },
                    {
                        label: 'Real Balance (Purchasing Power)',
                        data: real,
                        borderColor: '#4a8fe7',
                        backgroundColor: 'rgba(74,143,231,0.1)',
                        borderWidth: 3,
                        tension: 0.1,
                        fill: true,
                        pointRadius: 0
                    },
                    {
                        label: 'Initial Principal',
                        data: principal,
                        borderColor: '#ef4444',
                        borderDash: [5, 5],
                        borderWidth: 1,
                        pointRadius: 0
                    }
                ]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                interaction: {
                    mode: 'index',
                    intersect: false,
                },
                plugins: {
                    legend: {
                        labels: { color: '#c8d0de', font: { family: 'Inter' } }
                    },
                    tooltip: {
                        callbacks: {
                            label: function(context) {
                                return context.dataset.label + ': ' + formatCurrency(context.raw);
                            }
                        }
                    }
                },
                scales: {
                    x: {
                        grid: { color: '#152040' },
                        ticks: { color: '#5a6a80' }
                    },
                    y: {
                        grid: { color: '#152040' },
                        ticks: {
                            color: '#5a6a80',
                            callback: function(value) {
                                return '$' + (value / 1000) + 'k';
                            }
                        }
                    }
                }
            }
        });
    }

    function initHistoricalData() {
        const tbody = document.getElementById('tableBody');
        let html = '';

        let years = [];
        let sp500Data = [];
        let cpiData = [];
        let realReturnsData = [];

        marketData.forEach(row => {
            const sp500 = row.sp500;
            const cpi = row.cpi;

            // Fisher equation for historical real return
            const realReturn = (((1 + (sp500/100)) / (1 + (cpi/100))) - 1) * 100;

            years.push(row.year);
            sp500Data.push(sp500);
            cpiData.push(cpi);
            realReturnsData.push(realReturn);

            const realClass = realReturn >= 0 ? 'color: var(--success)' : 'color: var(--danger)';

            html += `
                <tr>
                    <td style="text-align: left;">${row.year}</td>
                    <td>${formatPercent(sp500)}</td>
                    <td>${formatPercent(cpi)}</td>
                    <td style="${realClass}; font-weight:600;">${formatPercent(realReturn)}</td>
                </tr>
            `;
        });

        tbody.innerHTML = html;

        // Render History Chart
        const ctx = document.getElementById('historyChart').getContext('2d');
        historyChartInstance = new Chart(ctx, {
            type: 'bar',
            data: {
                labels: years,
                datasets: [
                    {
                        label: 'S&P 500 Nominal',
                        data: sp500Data,
                        backgroundColor: '#4a8fe7',
                        order: 2
                    },
                    {
                        label: 'Inflation (CPI)',
                        data: cpiData,
                        type: 'line',
                        borderColor: '#ef4444',
                        borderWidth: 2,
                        pointRadius: 1,
                        tension: 0.1,
                        order: 1
                    }
                ]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                interaction: {
                    mode: 'index',
                    intersect: false,
                },
                plugins: {
                    legend: { labels: { color: '#c8d0de' } },
                    tooltip: {
                        callbacks: {
                            label: function(context) {
                                return context.dataset.label + ': ' + formatPercent(context.raw);
                            }
                        }
                    }
                },
                scales: {
                    x: { grid: { display: false }, ticks: { color: '#5a6a80', maxTicksLimit: 15 } },
                    y: { grid: { color: '#152040' }, ticks: { color: '#5a6a80', callback: function(v) { return v + '%'; } } }
                }
            }
        });
    }

    // Table sorting and filtering
    function filterTable() {
        const input = document.getElementById('searchInput');
        const filter = input.value.toUpperCase();
        const tbody = document.getElementById('tableBody');
        const tr = tbody.getElementsByTagName('tr');

        for (let i = 0; i < tr.length; i++) {
            const td = tr[i].getElementsByTagName('td')[0]; // Filter by year
            if (td) {
                const txtValue = td.textContent || td.innerText;
                if (txtValue.toUpperCase().indexOf(filter) > -1) {
                    tr[i].style.display = "";
                } else {
                    tr[i].style.display = "none";
                }
            }
        }
    }

    let sortDir = false;
    function sortTable(n) {
        const table = document.getElementById("dataTable");
        let rows, switching, i, x, y, shouldSwitch, switchcount = 0;
        switching = true;
        sortDir = !sortDir;

        while (switching) {
            switching = false;
            rows = table.rows;
            for (i = 1; i < (rows.length - 1); i++) {
                shouldSwitch = false;
                x = rows[i].getElementsByTagName("TD")[n];
                y = rows[i + 1].getElementsByTagName("TD")[n];

                let valX = parseFloat(x.innerHTML.replace(/[^0-9.-]+/g,""));
                let valY = parseFloat(y.innerHTML.replace(/[^0-9.-]+/g,""));

                if(isNaN(valX)) valX = x.innerHTML.toLowerCase();
                if(isNaN(valY)) valY = y.innerHTML.toLowerCase();

                if (sortDir) {
                    if (valX > valY) { shouldSwitch = true; break; }
                } else {
                    if (valX < valY) { shouldSwitch = true; break; }
                }
            }
            if (shouldSwitch) {
                rows[i].parentNode.insertBefore(rows[i + 1], rows[i]);
                switching = true;
                switchcount ++;
            }
        }
    }

    // Initialize
    document.addEventListener('DOMContentLoaded', () => {
        initHistoricalData();
        calculate();
    });
  </script>

  
