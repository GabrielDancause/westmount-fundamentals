    function calculate() {
        const principal = parseFloat(document.getElementById('input-principal').value);
        const nominalRate = parseFloat(document.getElementById('input-return').value) / 100;
        const inflationRate = parseFloat(document.getElementById('input-inflation').value) / 100;
        const years = parseInt(document.getElementById('input-years').value);

        if(isNaN(principal) || isNaN(nominalRate) || isNaN(inflationRate) || isNaN(years)) return;

        // Calculate Real Rate using Fisher Equation
        const realRate = ((1 + nominalRate) / (1 + inflationRate)) - 1;

        let labels = [];
        let nominalData = [];
        let realData = [];
