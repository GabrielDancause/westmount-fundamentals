---
import SiteLayout from "../layouts/SiteLayout.astro";
import registry from "../data/pages-registry.json";

const page = (registry as any)["real-return-calculator"];
export const meta = { title: "Real Return Calculator: Inflation-Adjusted Returns", description: "Calculate your true investment return after inflation. See how purchasing power erodes over time with our real vs nominal return calculator.", category: "tool", published: "2026-03-15" };

const schema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": "Real Return Calculator: Inflation-Adjusted Returns",
  "description": "Calculate your true investment return after inflation. See how purchasing power erodes over time with our real vs nominal return calculator.",
  "datePublished": "2026-03-13",
  "publisher": {
    "@type": "Organization",
    "name": "Westmount Research",
    "logo": {
      "@type": "ImageObject",
      "url": "https://westmountfundamentals.com/favicon.svg"
    }
  }
};

