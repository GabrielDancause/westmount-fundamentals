---
import SiteLayout from "../layouts/SiteLayout.astro";
import registry from "../data/pages-registry.json";

const page = (registry as any)["sp500-historical-returns-by-year"];
export const meta = { title: "S&P 500 Annual Returns by Year (1928-2026)", description: "Complete S&P 500 returns by year (1928-2026). Analyze historical stock market performance, inflation-adjusted returns, and decade averages.", category: "guide", published: "2026-03-15" };

const schema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": "S&P 500 Annual Returns by Year (1928-2026)",
  "description": "Complete S&P 500 returns by year (1928-2026). Analyze historical stock market performance, inflation-adjusted returns, and decade averages.",
  "datePublished": "2024-03-01T08:00:00+00:00",
  "publisher": {
    "@type": "Organization",
    "name": "Westmount Research"
  }
};

---

 · Updated March 2026<SiteLayout
  site="westmount"
  title={page.title}
  description={page.description}
  canonical={`https://westmountfundamentals.com/${page.slug}/`} schema={schema}
>
  <style is:global>
:root {
      --green: #10b981;
      --red: #ef4444;

}
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      font-family: 'Inter', sans-serif;
      background-color: var(--bg-color);
      color: var(--text-primary);
      line-height: 1.6;
    }
    nav {
      position: sticky;
      top: 0;
      z-index: 1000;
      background: rgba(6, 10, 18, 0.85);
      backdrop-filter: blur(12px);
      border-bottom: 1px solid var(--border-color);
      padding: 1rem 2rem;
      display: flex;
      justify-content: space-between;
      align-items: center;
    }
    .brand { font-weight: 700; color: white; text-decoration: none; font-size: 1.25rem; }
    .nav-links a { color: var(--text-muted); text-decoration: none; margin-left: 1.5rem; font-weight: 500; transition: color 0.2s; }
    .nav-links a:hover { color: var(--accent-color); }

    .container { max-width: 1200px; margin: 0 auto; padding: 3rem 1.5rem; }

    h1 {
      font-size: 2.5rem;
      font-weight: 700;
      margin-bottom: 1rem;
