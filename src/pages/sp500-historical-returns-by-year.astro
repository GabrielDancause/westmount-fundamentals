    .neg { color: var(--red); }

    .content-section { background: var(--card-bg); border: 1px solid var(--border-color); border-radius: 0.75rem; padding: 2rem; margin-bottom: 3rem; }
    h2 { font-size: 1.5rem; margin-bottom: 1rem; color: white; }
    h3 { font-size: 1.25rem; margin-top: 1.5rem; margin-bottom: 0.75rem; color: white; }
