    function formatPct(val) {
      if (val === null || val === undefined) return '--';
      return val.toFixed(2) + '%';
    }

    function getColorClass(val) {
      if (val === null || val === undefined) return '';
      return val > 0 ? 'pos' : (val < 0 ? 'neg' : '');
    }

    function formatCurrency(val) {
      if (val >= 1000000) return '$' + (val / 1000000).toFixed(2) + 'M';
      if (val >= 1000) return '$' + val.toLocaleString('en-US', { maximumFractionDigits: 0 });
      return '$' + val.toFixed(2);
    }

    function renderApp() {
      if (!window.SP500_DATA) return;

      const data = window.SP500_DATA;
      const sorted = [...data].sort((a, b) => a.year - b.year);

      // Build lookup by year
      const byYear = {};
      sorted.forEach(d => { byYear[d.year] = d; });

      // Calculate Stats
      let sumReturns = 0;
      let posYears = 0;
      let bestYear = data[0];
      let worstYear = data[0];
      let validReturnsCount = 0;

      data.forEach(d => {
        if (d.totalReturn !== null) {
          sumReturns += d.totalReturn;
          validReturnsCount++;
          if (d.totalReturn > 0) posYears++;
          if (d.totalReturn > bestYear.totalReturn) bestYear = d;
          if (d.totalReturn < worstYear.totalReturn) worstYear = d;
        }
      });

      const avgReturn = sumReturns / validReturnsCount;
      const posPct = (posYears / validReturnsCount) * 100;

      document.getElementById('stat-avg-return').textContent = formatPct(avgReturn);
      document.getElementById('stat-positive').textContent = posPct.toFixed(0) + '%';

      const bestEl = document.getElementById('stat-best');
      bestEl.textContent = formatPct(bestYear.totalReturn);
      document.getElementById('stat-best-desc').textContent = 'Occurred in ' + bestYear.year;

      const worstEl = document.getElementById('stat-worst');
      worstEl.textContent = formatPct(worstYear.totalReturn);
      document.getElementById('stat-worst-desc').textContent = 'Occurred in ' + worstYear.year;

      // ===== GROWTH CALCULATOR =====
      var startSelect = document.getElementById('calcStart');
      var endSelect = document.getElementById('calcEnd');
      var years = sorted.map(function(d) { return d.year; });

      years.forEach(function(y) {
        var opt1 = document.createElement('option');
        opt1.value = y; opt1.textContent = y;
        if (y === 1990) opt1.selected = true;
        startSelect.appendChild(opt1);

        var opt2 = document.createElement('option');
        opt2.value = y; opt2.textContent = y;
        if (y === 2026) opt2.selected = true;
        endSelect.appendChild(opt2);
      });

      function calculateGrowth(startYr, endYr) {
        var nominal = 10000;
        var real = 10000;
        for (var y = startYr + 1; y <= endYr; y++) {
          var d = byYear[y];
          if (d) {
            nominal *= (1 + d.totalReturn / 100);
            real *= (1 + d.realReturn / 100);
          }
        }
        var totalReturnPct = ((nominal - 10000) / 10000) * 100;
        var numYears = endYr - startYr;
        var cagr = numYears > 0 ? (Math.pow(nominal / 10000, 1 / numYears) - 1) * 100 : 0;
        return { nominal: nominal, real: real, totalReturn: totalReturnPct, cagr: cagr, years: numYears };
      }

      function runCalc() {
        var s = parseInt(startSelect.value);
        var e = parseInt(endSelect.value);
        if (s >= e) { alert('Start year must be before end year.'); return; }
        var r = calculateGrowth(s, e);
        document.getElementById('calcValue').textContent = formatCurrency(r.nominal);
        document.getElementById('calcDesc').textContent = '$10,000 invested in ' + s + ' would be worth ' + formatCurrency(r.nominal) + ' by ' + e;
        document.getElementById('calcTotalReturn').textContent = r.totalReturn.toFixed(1) + '%';
        document.getElementById('calcTotalReturn').className = 'calc-stat-value ' + (r.totalReturn >= 0 ? 'pos' : 'neg');
        document.getElementById('calcCAGR').textContent = r.cagr.toFixed(2) + '%';
        document.getElementById('calcCAGR').className = 'calc-stat-value ' + (r.cagr >= 0 ? 'pos' : 'neg');
        document.getElementById('calcYears').textContent = r.years;
        document.getElementById('calcRealValue').textContent = formatCurrency(r.real);
        document.getElementById('calcResult').classList.add('visible');
      }

      document.getElementById('calcBtn').addEventListener('click', runCalc);
      // Auto-calculate on load
      runCalc();

      // ===== BAR CHART WITH TOGGLE =====
      var chartData = sorted;
      var labels = chartData.map(function(d) { return d.year; });
      var totalReturns = chartData.map(function(d) { return d.totalReturn; });
      var realReturns = chartData.map(function(d) { return d.realReturn; });

      var ctx = document.getElementById('returnsChart').getContext('2d');
      var currentMode = 'nominal';

      function getBarColors(values) {
        return values.map(function(v) { return v >= 0 ? 'rgba(16, 185, 129, 0.8)' : 'rgba(239, 68, 68, 0.8)'; });
      }

      var barChart = new Chart(ctx, {
        type: 'bar',
        data: {
          labels: labels,
          datasets: [{
            label: 'Total Return (%)',
            data: totalReturns,
            backgroundColor: getBarColors(totalReturns),
            borderWidth: 0,
            borderRadius: 2
          }]
        },
        options: {
          responsive: true,
          maintainAspectRatio: false,
          plugins: {
            legend: { display: false },
            tooltip: {
              mode: 'index',
              intersect: false,
              callbacks: {
                label: function(context) { return context.parsed.y.toFixed(2) + '%'; }
              }
            }
          },
          scales: {
            y: {
              grid: { color: 'rgba(255, 255, 255, 0.05)' },
              ticks: { color: '#94a3b8', callback: function(value) { return value + '%'; } }
            },
            x: {
              grid: { display: false },
              ticks: { color: '#94a3b8', maxTicksLimit: 20 }
            }
          }
        }
      });

      // Toggle nominal/real
      document.querySelectorAll('#barChartToggle button').forEach(function(btn) {
        btn.addEventListener('click', function() {
          document.querySelectorAll('#barChartToggle button').forEach(function(b) { b.classList.remove('active'); });
          btn.classList.add('active');
          var mode = btn.getAttribute('data-mode');
          var vals = mode === 'real' ? realReturns : totalReturns;
          barChart.data.datasets[0].data = vals;
          barChart.data.datasets[0].label = mode === 'real' ? 'Real Return (%)' : 'Total Return (%)';
          barChart.data.datasets[0].backgroundColor = getBarColors(vals);
          barChart.update();
        });
      });

      // ===== CUMULATIVE GROWTH CHART =====
      var growthLabels = [sorted[0].year];
      var growthValues = [10000];
      var cumVal = 10000;
      for (var i = 1; i < sorted.length; i++) {
        cumVal *= (1 + sorted[i].totalReturn / 100);
        growthLabels.push(sorted[i].year);
        growthValues.push(cumVal);
      }

      var growthCtx = document.getElementById('growthChart').getContext('2d');
      var useLogScale = false;

      var growthChart = new Chart(growthCtx, {
        type: 'line',
        data: {
          labels: growthLabels,
          datasets: [{
            label: 'Portfolio Value ($)',
            data: growthValues,
            borderColor: '#10b981',
            backgroundColor: 'rgba(16, 185, 129, 0.1)',
            fill: true,
            pointRadius: 0,
            pointHoverRadius: 5,
            pointHoverBackgroundColor: '#10b981',
            borderWidth: 2,
            tension: 0.1
          }]
        },
        options: {
          responsive: true,
          maintainAspectRatio: false,
          plugins: {
            legend: { display: false },
            tooltip: {
              mode: 'index',
              intersect: false,
              callbacks: {
                label: function(context) {
                  return '$' + Math.round(context.parsed.y).toLocaleString();
                }
              }
            }
          },
          scales: {
            y: {
              type: 'linear',
              grid: { color: 'rgba(255, 255, 255, 0.05)' },
              ticks: {
                color: '#94a3b8',
                callback: function(value) {
                  if (value >= 1000000) return '$' + (value / 1000000).toFixed(1) + 'M';
                  if (value >= 1000) return '$' + (value / 1000).toFixed(0) + 'K';
                  return '$' + value;
                }
              }
            },
            x: {
              grid: { display: false },
              ticks: { color: '#94a3b8', maxTicksLimit: 20 }
            }
          }
        }
      });

      document.getElementById('logScaleBtn').addEventListener('click', function() {
        useLogScale = !useLogScale;
        growthChart.options.scales.y.type = useLogScale ? 'logarithmic' : 'linear';
        this.textContent = useLogScale ? 'Switch to Linear' : 'Toggle Log Scale';
        this.style.background = useLogScale ? 'var(--green)' : 'var(--card-bg)';
        this.style.color = useLogScale ? '#fff' : 'var(--text-muted)';
        this.style.borderColor = useLogScale ? 'var(--green)' : 'var(--border-color)';
        growthChart.update();
      });

      // ===== ROLLING 10-YEAR RETURNS =====
      var rollingLabels = [];
      var rollingValues = [];
      var rollingMin = { val: Infinity, year: 0 };
      var rollingMax = { val: -Infinity, year: 0 };

      for (var end = 10; end < sorted.length; end++) {
        var product = 1;
        for (var j = end - 9; j <= end; j++) {
          product *= (1 + sorted[j].totalReturn / 100);
        }
        var annualized = (Math.pow(product, 1 / 10) - 1) * 100;
        rollingLabels.push(sorted[end].year);
        rollingValues.push(annualized);
        if (annualized < rollingMin.val) { rollingMin.val = annualized; rollingMin.year = sorted[end].year; }
        if (annualized > rollingMax.val) { rollingMax.val = annualized; rollingMax.year = sorted[end].year; }
      }

      var rollingBg = rollingValues.map(function(v) {
        return v >= 0 ? 'rgba(16, 185, 129, 0.7)' : 'rgba(239, 68, 68, 0.7)';
      });
      var rollingBorder = rollingValues.map(function(v) {
        return v >= 0 ? '#10b981' : '#ef4444';
      });

      var rollingCtx = document.getElementById('rollingChart').getContext('2d');
      new Chart(rollingCtx, {
        type: 'line',
        data: {
          labels: rollingLabels,
          datasets: [{
            label: 'Rolling 10-Year Annualized Return (%)',
            data: rollingValues,
            borderColor: '#60a5fa',
            backgroundColor: 'rgba(96, 165, 250, 0.1)',
            fill: true,
            pointRadius: 0,
            pointHoverRadius: 5,
            pointHoverBackgroundColor: '#60a5fa',
            borderWidth: 2,
            tension: 0.2
          }]
        },
        options: {
          responsive: true,
          maintainAspectRatio: false,
          plugins: {
            legend: { display: false },
            tooltip: {
              mode: 'index',
              intersect: false,
              callbacks: {
                title: function(items) { return 'Decade ending ' + items[0].label; },
                label: function(context) { return context.parsed.y.toFixed(2) + '% annualized'; }
              }
            },
            annotation: undefined
          },
          scales: {
            y: {
              grid: { color: 'rgba(255, 255, 255, 0.05)' },
              ticks: { color: '#94a3b8', callback: function(v) { return v + '%'; } }
            },
            x: {
              grid: { display: false },
              ticks: { color: '#94a3b8', maxTicksLimit: 20 }
            }
          }
        }
      });

      // ===== TABLE (existing) =====
      var tbody = document.getElementById('tableBody');
      var searchInput = document.getElementById('searchInput');
      var currentSort = { col: 'year', asc: false };

      function renderTable() {
        var query = searchInput.value.toLowerCase();
        var filtered = data.filter(function(d) { return d.year.toString().includes(query); });

        filtered.sort(function(a, b) {
          var valA = a[currentSort.col];
          var valB = b[currentSort.col];
          if (valA === null) valA = -999999;
          if (valB === null) valB = -999999;
          return currentSort.asc ? valA - valB : valB - valA;
        });

        tbody.innerHTML = '';
        filtered.forEach(function(d) {
          var tr = document.createElement('tr');
          tr.innerHTML =
            '<td>' + d.year + '</td>' +
            '<td class="' + getColorClass(d.totalReturn) + '">' + formatPct(d.totalReturn) + '</td>' +
            '<td class="' + getColorClass(d.priceReturn) + '">' + formatPct(d.priceReturn) + '</td>' +
            '<td class="' + getColorClass(d.inflation) + '">' + formatPct(d.inflation) + '</td>' +
            '<td class="' + getColorClass(d.realReturn) + '">' + formatPct(d.realReturn) + '</td>';
          tbody.appendChild(tr);
        });
      }

      document.querySelectorAll('th[data-sort]').forEach(function(th) {
        th.addEventListener('click', function() {
          var col = th.getAttribute('data-sort');
          if (currentSort.col === col) {
            currentSort.asc = !currentSort.asc;
          } else {
            currentSort.col = col;
            currentSort.asc = false;
          }
          renderTable();
        });
      });

      searchInput.addEventListener('keyup', renderTable);
      renderTable();

      // ===== DECADE PERFORMANCE CARDS =====
      var decades = {};
      sorted.forEach(function(d) {
        var dec = Math.floor(d.year / 10) * 10;
        var label = dec + 's';
        if (!decades[label]) decades[label] = { label: label, start: dec, years: [] };
        decades[label].years.push(d);
      });

      var decadeGrid = document.getElementById('decadeGrid');
      // Only show full decades (1930s onward) + partial 2020s
      var decadeKeys = Object.keys(decades).sort();

      decadeKeys.forEach(function(key) {
        var dec = decades[key];
        if (dec.years.length < 2) return; // skip 1920s with only 1928

        var sum = 0;
        var best = dec.years[0];
        var worst = dec.years[0];
        var cumulative = 1;

        dec.years.forEach(function(d) {
          sum += d.totalReturn;
          cumulative *= (1 + d.totalReturn / 100);
          if (d.totalReturn > best.totalReturn) best = d;
          if (d.totalReturn < worst.totalReturn) worst = d;
        });

        var avg = sum / dec.years.length;
        var cumPct = (cumulative - 1) * 100;
        var isPositive = avg >= 0;

        var card = document.createElement('div');
        card.className = 'decade-card ' + (isPositive ? 'positive' : 'negative');
        card.innerHTML =
          '<div class="decade-name">' + dec.label + '</div>' +
          '<div class="decade-stat"><span class="decade-stat-label">Avg Annual</span><span class="decade-stat-value ' + (avg >= 0 ? 'pos' : 'neg') + '">' + avg.toFixed(1) + '%</span></div>' +
          '<div class="decade-stat"><span class="decade-stat-label">Cumulative</span><span class="decade-stat-value ' + (cumPct >= 0 ? 'pos' : 'neg') + '">' + cumPct.toFixed(0) + '%</span></div>' +
          '<div class="decade-stat"><span class="decade-stat-label">Best Year</span><span class="decade-stat-value pos">' + best.year + ' (' + best.totalReturn.toFixed(1) + '%)</span></div>' +
          '<div class="decade-stat"><span class="decade-stat-label">Worst Year</span><span class="decade-stat-value neg">' + worst.year + ' (' + worst.totalReturn.toFixed(1) + '%)</span></div>';
        decadeGrid.appendChild(card);
      });

      // ===== KEY INSIGHTS =====
      // Calculate insights from data
      var positiveCount = 0;
      sorted.forEach(function(d) { if (d.totalReturn > 0) positiveCount++; });
      var positivePct = ((positiveCount / sorted.length) * 100).toFixed(0);

      // Growth of $10K since 1928
      var growthSince1928 = calculateGrowth(1928, sorted[sorted.length - 1].year);

      // Best decade
      var bestDecade = { label: '', avg: -Infinity };
      decadeKeys.forEach(function(key) {
        var dec = decades[key];
        if (dec.years.length < 5) return;
        var s = 0;
        dec.years.forEach(function(d) { s += d.totalReturn; });
        var a = s / dec.years.length;
        if (a > bestDecade.avg) { bestDecade = { label: key, avg: a }; }
      });

      // Crashes and recoveries
      var crashes = [];
      sorted.forEach(function(d) {
        if (d.totalReturn <= -30) crashes.push(d.year);
      });

      // Recovery years after crashes
      var recoveryYears = [];
      crashes.forEach(function(crashYear) {
        var cumLoss = 1;
        // find the consecutive decline
        var idx = sorted.findIndex(function(d) { return d.year === crashYear; });
        cumLoss *= (1 + sorted[idx].totalReturn / 100);
        for (var r = idx + 1; r < sorted.length; r++) {
          cumLoss *= (1 + sorted[r].totalReturn / 100);
          if (cumLoss >= 1) {
            recoveryYears.push(sorted[r].year - crashYear);
            break;
          }
        }
      });
      var avgRecovery = recoveryYears.length > 0
        ? (recoveryYears.reduce(function(a, b) { return a + b; }, 0) / recoveryYears.length).toFixed(0)
        : 'N/A';

      // Rolling 10-year: negative periods count
      var negativeRolling = 0;
      rollingValues.forEach(function(v) { if (v < 0) negativeRolling++; });
      var alwaysPositive10yr = negativeRolling === 0;

      var insightsGrid = document.getElementById('insightsGrid');
      var insights = [
        {
          icon: '📊',
          text: 'The S&P 500 has delivered <span class="insight-highlight">positive returns in ' + positivePct + '%</span> of all years since 1928. The odds have historically favored the patient investor.'
        },
        {
          icon: '💰',
          text: '$10,000 invested in 1928 would be worth <span class="insight-highlight">' + formatCurrency(growthSince1928.nominal) + '</span> today — a testament to the extraordinary power of compound returns over nearly a century.'
        },
        {
          icon: '🏆',
          text: 'The best decade was the <span class="insight-highlight">' + bestDecade.label + '</span> with an average annual return of <span class="insight-highlight">' + bestDecade.avg.toFixed(1) + '%</span>.'
        },
        {
          icon: '🔄',
          text: 'After every major crash (>30% decline), the market recovered within <span class="insight-highlight">' + avgRecovery + ' years</span> on average. Markets have always bounced back.'
        },
        {
          icon: '📈',
          text: (alwaysPositive10yr
            ? 'Every rolling 10-year period since 1928 delivered <span class="insight-highlight">positive returns</span>. Time in the market beats timing the market.'
            : 'Only <span class="insight-highlight">' + negativeRolling + '</span> of ' + rollingValues.length + ' rolling 10-year periods were negative. The worst was <span class="insight-highlight">' + rollingMin.val.toFixed(1) + '%</span> annualized (ending ' + rollingMin.year + '), and the best was <span class="insight-highlight">' + rollingMax.val.toFixed(1) + '%</span> (ending ' + rollingMax.year + ').')
        }
      ];

      insights.forEach(function(ins) {
        var card = document.createElement('div');
        card.className = 'insight-card';
        card.innerHTML = '<div class="insight-icon">' + ins.icon + '</div><div class="insight-text">' + ins.text + '</div>';
        insightsGrid.appendChild(card);
      });
    }

    document.addEventListener('DOMContentLoaded', function() {
      if (window.SP500_DATA) renderApp();
    });
  </script>
</SiteLayout>
