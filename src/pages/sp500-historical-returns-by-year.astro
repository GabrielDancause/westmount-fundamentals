---
import SiteLayout from "../layouts/SiteLayout.astro";

const schema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": "S&P 500 Annual Returns by Year (1928-2026)",
  "description": "Complete S&P 500 returns by year (1928-2026). Analyze historical stock market performance, inflation-adjusted returns, and decade averages.",
  "datePublished": "2024-03-01T08:00:00+00:00",
  "publisher": {
    "@type": "Organization",
    "name": "Westmount Research"
  }
};

export const meta = {
  title: "S&P 500 Annual Returns by Year (1928-2026)",
  description: "Complete S&P 500 returns by year (1928-2026). Analyze historical stock market performance, inflation-adjusted returns, and decade averages.",
  category: "guide",
  published: "2026-03-15",
};
---

<SiteLayout
  site="westmount"
  title="S&P 500 Annual Returns by Year (1928-2026)"
  description="Complete S&P 500 returns by year (1928-2026). Analyze historical stock market performance, inflation-adjusted returns, and decade averages."
  canonical="https://westmountfundamentals.com/sp500-historical-returns-by-year" schema={schema}
>
  <style>
:root {
      --green: #10b981;
      --red: #ef4444;

}
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      font-family: 'Inter', sans-serif;
      background-color: var(--bg-color);
      color: var(--text-primary);
      line-height: 1.6;
    }
    nav {
      position: sticky;
      top: 0;
      z-index: 1000;
      background: rgba(6, 10, 18, 0.85);
      backdrop-filter: blur(12px);
      border-bottom: 1px solid var(--border-color);
      padding: 1rem 2rem;
      display: flex;
      justify-content: space-between;
      align-items: center;
    }
    .brand { font-weight: 700; color: white; text-decoration: none; font-size: 1.25rem; }
    .nav-links a { color: var(--text-muted); text-decoration: none; margin-left: 1.5rem; font-weight: 500; transition: color 0.2s; }
    .nav-links a:hover { color: var(--accent-color); }

    .container { max-width: 1200px; margin: 0 auto; padding: 3rem 1.5rem; }

    h1 {
      font-size: 2.5rem;
      font-weight: 700;
      margin-bottom: 1rem;
      background: linear-gradient(to right, #60a5fa, #a78bfa);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      line-height: 1.2;
    }
    .subtitle { color: var(--text-muted); font-size: 1.125rem; margin-bottom: 2.5rem; }

    .stats-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: 1.5rem; margin-bottom: 3rem; }
    .stat-card { background: var(--card-bg); border: 1px solid var(--border-color); border-radius: 0.75rem; padding: 1.5rem; }
    .stat-label { color: var(--text-muted); font-size: 0.875rem; font-weight: 500; margin-bottom: 0.5rem; text-transform: uppercase; letter-spacing: 0.05em; }
    .stat-value { font-size: 2rem; font-weight: 700; font-family: 'JetBrains Mono', monospace; }
    .stat-desc { color: var(--text-muted); font-size: 0.875rem; margin-top: 0.5rem; }

    .chart-container { background: var(--card-bg); border: 1px solid var(--border-color); border-radius: 0.75rem; padding: 1.5rem; margin-bottom: 3rem; height: 500px; }

    .table-controls { display: flex; justify-content: space-between; align-items: center; margin-bottom: 1rem; flex-wrap: wrap; gap: 1rem; }
    input[type="text"] { background: var(--card-bg); border: 1px solid var(--border-color); color: var(--text-primary); padding: 0.5rem 1rem; border-radius: 0.375rem; font-family: 'Inter', sans-serif; }
    input[type="text"]:focus { outline: none; border-color: var(--accent-color); }

    .table-wrapper { overflow-x: auto; background: var(--card-bg); border: 1px solid var(--border-color); border-radius: 0.75rem; margin-bottom: 3rem; }
    table { width: 100%; border-collapse: collapse; text-align: left; }
    th { background: rgba(255,255,255,0.02); padding: 1rem; font-weight: 600; color: var(--text-muted); border-bottom: 1px solid var(--border-color); cursor: pointer; user-select: none; }
    th:hover { color: var(--text-primary); }
    td { padding: 1rem; border-bottom: 1px solid var(--border-color); font-family: 'JetBrains Mono', monospace; }
    tr:last-child td { border-bottom: none; }
    .pos { color: var(--green); }
    .neg { color: var(--red); }

    .content-section { background: var(--card-bg); border: 1px solid var(--border-color); border-radius: 0.75rem; padding: 2rem; margin-bottom: 3rem; }
    h2 { font-size: 1.5rem; margin-bottom: 1rem; color: white; }
    h3 { font-size: 1.25rem; margin-top: 1.5rem; margin-bottom: 0.75rem; color: white; }
    p { margin-bottom: 1rem; color: var(--text-muted); }

    .faq-item { border-bottom: 1px solid var(--border-color); padding: 1.5rem 0; }
    .faq-item:last-child { border-bottom: none; }
    .faq-q { font-weight: 600; font-size: 1.125rem; margin-bottom: 0.5rem; color: white; }
    .faq-a { color: var(--text-muted); }

    footer { text-align: center; padding: 3rem 1.5rem; border-top: 1px solid var(--border-color); color: var(--text-muted); font-size: 0.875rem; margin-top: 3rem; }

    @media (max-width: 768px) {
      .nav-links { display: none; }
      h1 { font-size: 2rem; }
      .stats-grid { grid-template-columns: 1fr; }
      .chart-container { height: 350px; }
    }
  </style>

<main class="container">
    <h1>S&P 500 Annual Returns by Year</h1>
    <p class="subtitle">Comprehensive historical performance data including total returns, price returns, and inflation adjustments since 1928.</p>

    <div class="stats-grid">
      <div class="stat-card">
        <div class="stat-label">Avg Annual Return</div>
        <div class="stat-value" id="stat-avg-return">--</div>
        <div class="stat-desc">Historical nominal total return</div>
      </div>
      <div class="stat-card">
        <div class="stat-label">Positive Years</div>
        <div class="stat-value" id="stat-positive">--</div>
        <div class="stat-desc">Percentage of years with gains</div>
      </div>
      <div class="stat-card">
        <div class="stat-label">Best Year</div>
        <div class="stat-value pos" id="stat-best">--</div>
        <div class="stat-desc" id="stat-best-desc">--</div>
      </div>
      <div class="stat-card">
        <div class="stat-label">Worst Year</div>
        <div class="stat-value neg" id="stat-worst">--</div>
        <div class="stat-desc" id="stat-worst-desc">--</div>
      </div>
    </div>

    <div class="chart-container">
      <canvas id="returnsChart"></canvas>
    </div>

    <div class="table-controls">
      <h2>Complete Year-by-Year History</h2>
      <input type="text" id="searchInput" placeholder="Filter by decade (e.g., 1990)...">
    </div>

    <div class="table-wrapper">
      <table id="dataTable">
        <thead>
          <tr>
            <th data-sort="year">Year ↕</th>
            <th data-sort="sp500Total">Total Return ↕</th>
            <th data-sort="sp500Price">Price Return ↕</th>
            <th data-sort="inflation">Inflation ↕</th>
            <th data-sort="realReturn">Real Return ↕</th>
          </tr>
        </thead>
        <tbody id="tableBody">
          <!-- Rows injected via JS -->
        </tbody>
      </table>
    </div>

    <div class="content-section">
      <h2>Methodology & Data Sources</h2>
      <p>This historical dataset compiles S&P 500 performance metrics from multiple authoritative sources to provide a complete picture of market returns since 1928. The data represents calendar year performance (January 1 to December 31).</p>

      <h3>Data Sources</h3>
      <ul>
        <li><strong style="color:var(--text-primary)">S&P 500 Total Returns:</strong> Sourced from Aswath Damodaran's NYU Stern historical dataset, which includes reinvested dividends.</li>
        <li><strong style="color:var(--text-primary)">Price Returns & Inflation:</strong> Compiled using data from the Robert Shiller / Cowles Commission dataset (via public GitHub datasets) and recent data from Yahoo Finance.</li>
        <li><strong style="color:var(--text-primary)">Inflation Rate:</strong> Calculated based on Consumer Price Index (CPI) changes from December of the prior year to December of the current year.</li>
      </ul>

      <h3>Calculations</h3>
      <p>The <strong>Real Return</strong> is calculated using the exact formula: <code>((1 + Total Return) / (1 + Inflation)) - 1</code>, rather than simply subtracting inflation from the total return, to ensure mathematical accuracy over time.</p>
    </div>

    <div class="content-section">
      <h2>Frequently Asked Questions</h2>
      <div class="faq-item">
        <div class="faq-q">What is the average S&P 500 return per year?</div>
        <div class="faq-a">The historical average annual return of the S&P 500 is approximately 10% before inflation, and around 7% when adjusted for inflation, assuming dividends are reinvested.</div>
      </div>
      <div class="faq-item">
        <div class="faq-q">What was the worst year for the S&P 500?</div>
        <div class="faq-a">The worst year for the S&P 500 was 1931, when the market fell 43.34% during the Great Depression. In recent history, 2008 was the worst year with a decline of 38.49%.</div>
      </div>
      <div class="faq-item">
        <div class="faq-q">How often does the S&P 500 have a negative year?</div>
        <div class="faq-a">Historically, the S&P 500 has a negative annual return roughly once every four years, meaning it is positive about 73% of the time.</div>
      </div>
      <div class="faq-item">
        <div class="faq-q">Does the S&P 500 return include dividends?</div>
        <div class="faq-a">The standard quoted S&P 500 price return does not include dividends. However, the S&P 500 Total Return index, which is often cited for long-term performance, includes the reinvestment of all dividends.</div>
      </div>
      <div class="faq-item">
        <div class="faq-q">What is the inflation-adjusted return of the S&P 500?</div>
        <div class="faq-a">The inflation-adjusted (or real) return of the S&P 500 is the total return minus the inflation rate. Over the long term, the real return of the S&P 500 has averaged around 6.5% to 7% annualized.</div>
      </div>
    </div>
  </main>
  <script is:inline src="https://cdn.jsdelivr.net/npm/chart.js"></script>
  <script is:inline>
// App Logic will go here.
    function formatPct(val) {
      if (val === null || val === undefined) return '--';
      return val.toFixed(2) + '%';
    }

    function getColorClass(val) {
      if (val === null || val === undefined) return '';
      return val > 0 ? 'pos' : (val < 0 ? 'neg' : '');
    }

    function renderApp() {
      if (!window.SP500_DATA) return;

      const data = window.SP500_DATA;

      // Calculate Stats
      let sumReturns = 0;
      let posYears = 0;
      let bestYear = data[0];
      let worstYear = data[0];

      let validReturnsCount = 0;

      data.forEach(d => {
        if (d.sp500Total !== null) {
          sumReturns += d.sp500Total;
          validReturnsCount++;
          if (d.sp500Total > 0) posYears++;
          if (d.sp500Total > bestYear.sp500Total) bestYear = d;
          if (d.sp500Total < worstYear.sp500Total) worstYear = d;
        }
      });

      const avgReturn = sumReturns / validReturnsCount;
      const posPct = (posYears / validReturnsCount) * 100;

      document.getElementById('stat-avg-return').textContent = formatPct(avgReturn);
      document.getElementById('stat-positive').textContent = posPct.toFixed(0) + '%';

      const bestEl = document.getElementById('stat-best');
      bestEl.textContent = formatPct(bestYear.sp500Total);
      document.getElementById('stat-best-desc').textContent = `Occurred in ${bestYear.year}`;

      const worstEl = document.getElementById('stat-worst');
      worstEl.textContent = formatPct(worstYear.sp500Total);
      document.getElementById('stat-worst-desc').textContent = `Occurred in ${worstYear.year}`;

      // Table Rendering
      const tbody = document.getElementById('tableBody');
      const searchInput = document.getElementById('searchInput');

      let currentSort = { col: 'year', asc: false };

      function renderTable() {
        const query = searchInput.value.toLowerCase();

        let filtered = data.filter(d => d.year.toString().includes(query));

        filtered.sort((a, b) => {
          let valA = a[currentSort.col];
          let valB = b[currentSort.col];
          if (valA === null) valA = -999999;
          if (valB === null) valB = -999999;
          return currentSort.asc ? valA - valB : valB - valA;
        });

        tbody.innerHTML = '';
        filtered.forEach(d => {
          const tr = document.createElement('tr');
          tr.innerHTML = `
            <td>${d.year}</td>
            <td class="${getColorClass(d.sp500Total)}">${formatPct(d.sp500Total)}</td>
            <td class="${getColorClass(d.sp500Price)}">${formatPct(d.sp500Price)}</td>
            <td class="${getColorClass(d.inflation)}">${formatPct(d.inflation)}</td>
            <td class="${getColorClass(d.realReturn)}">${formatPct(d.realReturn)}</td>
          `;
          tbody.appendChild(tr);
        });
      }

      document.querySelectorAll('th[data-sort]').forEach(th => {
        th.addEventListener('click', () => {
          const col = th.getAttribute('data-sort');
          if (currentSort.col === col) {
            currentSort.asc = !currentSort.asc;
          } else {
            currentSort.col = col;
            currentSort.asc = false;
          }
          renderTable();
        });
      });

      searchInput.addEventListener('keyup', renderTable);
      renderTable();

      // Chart Rendering
      const ctx = document.getElementById('returnsChart').getContext('2d');

      // We'll chart from oldest to newest
      const chartData = [...data].sort((a,b) => a.year - b.year);
      const labels = chartData.map(d => d.year);
      const totalReturns = chartData.map(d => d.sp500Total);

      const bgColors = totalReturns.map(v => v >= 0 ? 'rgba(16, 185, 129, 0.8)' : 'rgba(239, 68, 68, 0.8)');

      new Chart(ctx, {
        type: 'bar',
        data: {
          labels: labels,
          datasets: [{
            label: 'Total Return (%)',
            data: totalReturns,
            backgroundColor: bgColors,
            borderWidth: 0,
            borderRadius: 2
          }]
        },
        options: {
          responsive: true,
          maintainAspectRatio: false,
          plugins: {
            legend: { display: false },
            tooltip: {
              mode: 'index',
              intersect: false,
              callbacks: {
                label: function(context) {
                  return context.parsed.y.toFixed(2) + '%';
                }
              }
            }
          },
          scales: {
            y: {
              grid: { color: 'rgba(255, 255, 255, 0.05)' },
              ticks: { color: '#94a3b8', callback: function(value) { return value + '%'; } }
            },
            x: {
              grid: { display: false },
              ticks: { color: '#94a3b8', maxTicksLimit: 20 }
            }
          }
        }
      });
    }

    // Call after DOM is fully loaded or data injected
    document.addEventListener('DOMContentLoaded', () => {
      // The injected script will call renderApp() directly or provide window.SP500_DATA
      if (window.SP500_DATA) renderApp();
    });
  </script>
</SiteLayout>
