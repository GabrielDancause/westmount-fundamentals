---
import SiteLayout from "../layouts/SiteLayout.astro";
import registry from "../data/pages-registry.json";

const page = (registry as any)["sp500-historical-returns-by-year"];
export const meta = { title: "S&P 500 Annual Returns by Year (1928-2026)", description: "Complete S&P 500 returns by year (1928-2026). Analyze historical stock market performance, inflation-adjusted returns, and decade averages.", category: "study", published: "2026-03-15" };

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Article",
      "headline": "S&P 500 Annual Returns by Year (1928-2026)",
      "description": "Complete S&P 500 returns by year (1928-2026). Analyze historical stock market performance, inflation-adjusted returns, and decade averages.",
      "author": {
        "@type": "Organization",
        "name": "Westmount Research"
      },
      "publisher": {
        "@type": "Organization",
        "name": "Westmount Research",
        "logo": {
          "@type": "ImageObject",
          "url": "https://westmountfundamentals.com/favicon.svg"
        }
      },
      "datePublished": "2024-03-01T08:00:00+00:00",
      "dateModified": "2026-03-20"
    },
    {
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "What is the average S&P 500 return per year?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "The historical average annual return of the S&P 500 is approximately 10% before inflation, and around 7% when adjusted for inflation, assuming dividends are reinvested."
          }
        },
        {
          "@type": "Question",
          "name": "What was the worst year for the S&P 500?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "The worst year for the S&P 500 was 1931, when the market fell 43.34% during the Great Depression. In recent history, 2008 was the worst year with a decline of 38.49%."
          }
        },
        {
          "@type": "Question",
          "name": "How often does the S&P 500 have a negative year?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Historically, the S&P 500 has a negative annual return roughly once every four years, meaning it is positive about 73% of the time."
          }
        },
        {
          "@type": "Question",
          "name": "Does the S&P 500 return include dividends?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "The standard quoted S&P 500 price return does not include dividends. However, the S&P 500 Total Return index, which is often cited for long-term performance, includes the reinvestment of all dividends."
          }
        },
        {
          "@type": "Question",
          "name": "What is the inflation-adjusted return of the S&P 500?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "The inflation-adjusted (or real) return of the S&P 500 is the total return minus the inflation rate. Over the long term, the real return of the S&P 500 has averaged around 6.5% to 7% annualized."
          }
        }
      ]
    }
  ]
};

