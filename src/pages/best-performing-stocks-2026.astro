document.addEventListener('DOMContentLoaded', () => {
  const data = window.__INITIAL_DATA__;
  const allStocks = [...data.top50, ...data.bottom50];

  // ── Compute key metrics ──
  // Sort top50 by perfYtd descending to find true #1
  const top50Sorted = [...data.top50].sort((a, b) => b.perfYtd - a.perfYtd);
  const topPerformer = top50Sorted[0];
  const avgTop50 = data.top50.reduce((s, x) => s + x.perfYtd, 0) / data.top50.length;

  // S&P 500 YTD — chain monthly returns
  let spyYtd = 1;
  data.spyMonthly.forEach(m => { spyYtd *= (1 + m.returnPct / 100); });
  spyYtd = (spyYtd - 1) * 100;

  // Sector stats (from ALL stocks)
  const sectorMap = {};
  allStocks.forEach(s => {
    if (!sectorMap[s.sector]) sectorMap[s.sector] = { sum: 0, count: 0, stocks: [] };
    sectorMap[s.sector].sum += s.perfYtd;
    sectorMap[s.sector].count++;
    sectorMap[s.sector].stocks.push(s);
  });
  const sectorArr = Object.entries(sectorMap).map(([name, d]) => ({
    name, avg: d.sum / d.count, count: d.count, stocks: d.stocks
  })).sort((a, b) => b.avg - a.avg);

  const topSector = sectorArr[0];

  // Sector stats for top50 only
  const top50SectorMap = {};
  data.top50.forEach(s => {
    if (!top50SectorMap[s.sector]) top50SectorMap[s.sector] = { count: 0 };
    top50SectorMap[s.sector].count++;
  });

  // ── 1. Stats Grid ──
  document.getElementById('stat-top-return').textContent = '+' + topPerformer.perfYtd.toLocaleString() + '%';
  document.getElementById('stat-top-ticker').textContent = topPerformer.ticker + ' — ' + topPerformer.company;
  document.getElementById('stat-avg-return').textContent = '+' + avgTop50.toFixed(1) + '%';
  document.getElementById('stat-top-sector').textContent = topSector.name;
  document.getElementById('stat-top-sector-return').textContent = '+' + topSector.avg.toFixed(1) + '% avg return';
  const spyEl = document.getElementById('stat-spy-ytd');
  spyEl.textContent = (spyYtd >= 0 ? '+' : '') + spyYtd.toFixed(2) + '%';
  spyEl.className = 'stat-value ' + (spyYtd >= 0 ? 'positive' : 'negative');

  // ── 2. Monthly Timeline ──
  const monthNames = ['January', 'February', 'March', 'April', 'May', 'June', 'July', 'August', 'September', 'October', 'November', 'December'];
  const timelineEl = document.getElementById('monthly-timeline');
  data.spyMonthly.forEach(m => {
    const d = new Date(m.date);
    const card = document.createElement('div');
    card.className = 'month-card';
    const isPos = m.returnPct >= 0;
    const barWidth = Math.min(Math.abs(m.returnPct) * 30, 100);
    card.innerHTML = `
      <div class="month-name">${monthNames[d.getUTCMonth()]} ${d.getUTCFullYear()}</div>
      <div class="month-return ${isPos ? 'positive' : 'negative'}">${isPos ? '+' : ''}${m.returnPct.toFixed(2)}%</div>
      <div class="month-bar-container">
        <div class="month-bar" style="width:${barWidth}%;background:${isPos ? 'var(--green)' : 'var(--red)'}"></div>
      </div>
    `;
    timelineEl.appendChild(card);
  });

  // ── 3. Sector Heatmap ──
  const heatmapEl = document.getElementById('heatmap-grid');
  const totalStocks = allStocks.length;
  const minAvg = Math.min(...sectorArr.map(s => s.avg));
  const maxAvg = Math.max(...sectorArr.map(s => s.avg));

  sectorArr.forEach(sec => {
    const cell = document.createElement('div');
    cell.className = 'heatmap-cell';
    // Size proportional to stock count
    const widthPct = Math.max((sec.count / totalStocks) * 100, 12);
    cell.style.flexBasis = `calc(${widthPct}% - 4px)`;
    cell.style.flexGrow = sec.count;

    // Color: green gradient based on performance
    const norm = maxAvg !== minAvg ? (sec.avg - minAvg) / (maxAvg - minAvg) : 0.5;
    const r = Math.round(20 + (1 - norm) * 100);
    const g = Math.round(80 + norm * 120);
    const b = Math.round(40 + (1 - norm) * 30);
    cell.style.background = `rgba(${r}, ${g}, ${b}, 0.85)`;

    cell.innerHTML = `
      <div class="hm-sector">${sec.name}</div>
      <div class="hm-return">+${sec.avg.toFixed(1)}%</div>
      <div class="hm-count">${sec.count} stock${sec.count > 1 ? 's' : ''}</div>
    `;
    heatmapEl.appendChild(cell);
  });

  // ── 4. Performance Distribution Chart ──
  const buckets = [
    { label: '0–50%', min: 0, max: 50 },
    { label: '50–100%', min: 50, max: 100 },
    { label: '100–200%', min: 100, max: 200 },
    { label: '200–500%', min: 200, max: 500 },
    { label: '500%+', min: 500, max: Infinity }
  ];
  const bucketCounts = buckets.map(b => data.top50.filter(s => s.perfYtd >= b.min && s.perfYtd < b.max).length);

  const ctx = document.getElementById('dist-chart').getContext('2d');
  new Chart(ctx, {
    type: 'bar',
    data: {
      labels: buckets.map(b => b.label),
      datasets: [{
        label: 'Number of Stocks',
        data: bucketCounts,
        backgroundColor: ['#065f46', '#047857', '#059669', '#10b981', '#34d399'],
        borderColor: 'rgba(16, 185, 129, 0.3)',
        borderWidth: 1,
        borderRadius: 6
      }]
    },
    options: {
      responsive: true,
      maintainAspectRatio: true,
      plugins: {
        legend: { display: false },
        tooltip: {
          callbacks: {
            label: (c) => c.raw + ' stocks'
          }
        },
        annotation: undefined
      },
      scales: {
        x: {
          grid: { color: 'rgba(255,255,255,0.05)' },
          ticks: { color: '#94a3b8' },
          title: { display: true, text: 'YTD Return Range', color: '#94a3b8' }
        },
        y: {
          grid: { color: 'rgba(255,255,255,0.05)' },
          ticks: { color: '#94a3b8', stepSize: 5 },
          title: { display: true, text: 'Number of Stocks', color: '#94a3b8' },
          beginAtZero: true
        }
      }
    },
    plugins: [{
      id: 'spyLine',
      afterDraw: (chart) => {
        const xScale = chart.scales.x;
        const yScale = chart.scales.y;
        const ctxDraw = chart.ctx;
        // Find which bucket S&P 500 falls into and draw line
        let spyBucketIdx = buckets.findIndex(b => spyYtd >= b.min && spyYtd < b.max);
        if (spyBucketIdx === -1) spyBucketIdx = 0;
        // Position within the first bucket
        const frac = Math.max(0, Math.min(1, (spyYtd - buckets[0].min) / (buckets[0].max - buckets[0].min)));
        const barMeta = chart.getDatasetMeta(0).data[0];
        const xPos = barMeta.x - barMeta.width/2 + frac * barMeta.width;

        ctxDraw.save();
        ctxDraw.beginPath();
        ctxDraw.setLineDash([5, 5]);
        ctxDraw.strokeStyle = '#f59e0b';
        ctxDraw.lineWidth = 2;
        ctxDraw.moveTo(xPos, yScale.top);
        ctxDraw.lineTo(xPos, yScale.bottom);
        ctxDraw.stroke();

        ctxDraw.fillStyle = '#f59e0b';
        ctxDraw.font = '11px Inter, sans-serif';
        ctxDraw.textAlign = 'left';
        ctxDraw.fillText('S&P 500 YTD: ' + spyYtd.toFixed(2) + '%', xPos + 4, yScale.top + 14);
        ctxDraw.restore();
      }
    }]
  });

  // ── 5. Portfolio Calculator ──
  function calcPortfolio(n) {
    const topN = top50Sorted.slice(0, n);
    const perStock = 10000 / n;
    let total = 0;
    topN.forEach(s => { total += perStock * (1 + s.perfYtd / 100); });
    const spyTotal = 10000 * (1 + spyYtd / 100);
    const portfolioGain = ((total - 10000) / 10000) * 100;
    const spyGainPct = spyYtd;

    document.getElementById('calc-portfolio').textContent = '$' + Math.round(total).toLocaleString();
    document.getElementById('calc-portfolio-gain').textContent = '+' + portfolioGain.toFixed(1) + '% return';
    document.getElementById('calc-spy').textContent = '$' + Math.round(spyTotal).toLocaleString();
    document.getElementById('calc-spy-gain').textContent = (spyGainPct >= 0 ? '+' : '') + spyGainPct.toFixed(2) + '% return';
  }

  calcPortfolio(10);

  document.getElementById('portfolio-toggle').addEventListener('click', (e) => {
    const btn = e.target.closest('button');
    if (!btn) return;
    document.querySelectorAll('#portfolio-toggle button').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
    calcPortfolio(parseInt(btn.dataset.n));
  });

  // ── 6. Existing: Sector filter, sector table, monthly table, stock tables ──
  const sectors = new Set();
  allStocks.forEach(s => sectors.add(s.sector));
  const sectorFilter = document.getElementById('sector-filter');
  Array.from(sectors).sort().forEach(sector => {
    const option = document.createElement('option');
    option.value = sector;
    option.textContent = sector;
    sectorFilter.appendChild(option);
  });

  // Sector table
  const sectorTbody = document.getElementById('sector-tbody');
  sectorArr.forEach(s => {
    const tr = document.createElement('tr');
    const tdSector = document.createElement('td');
    tdSector.textContent = s.name;
    const tdAvg = document.createElement('td');
    tdAvg.className = 'mono ' + (s.avg >= 0 ? 'positive' : 'negative');
    tdAvg.textContent = (s.avg > 0 ? '+' : '') + s.avg.toFixed(2) + '%';
    tr.appendChild(tdSector);
    tr.appendChild(tdAvg);
    sectorTbody.appendChild(tr);
  });

  // Monthly table
  const monthlyTbody = document.getElementById('monthly-tbody');
  const months = ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec'];
  data.spyMonthly.forEach(m => {
    const date = new Date(m.date);
    const tr = document.createElement('tr');
    const tdMonth = document.createElement('td');
    tdMonth.textContent = months[date.getUTCMonth()] + ' ' + date.getUTCFullYear();
    const tdRet = document.createElement('td');
    tdRet.className = 'mono ' + (m.returnPct >= 0 ? 'positive' : 'negative');
    tdRet.textContent = (m.returnPct > 0 ? '+' : '') + m.returnPct.toFixed(2) + '%';
    tr.appendChild(tdMonth);
    tr.appendChild(tdRet);
    monthlyTbody.appendChild(tr);
  });

  // Render stock tables
  function renderTables(filterSector) {
    const topTbody = document.getElementById('top-tbody');
    const botTbody = document.getElementById('bottom-tbody');
    topTbody.innerHTML = '';
    botTbody.innerHTML = '';

    const renderRow = (tbody, stock) => {
      if (filterSector !== 'all' && stock.sector !== filterSector) return;
      const tr = document.createElement('tr');
      const tdTicker = document.createElement('td');
      tdTicker.className = 'ticker mono';
      tdTicker.textContent = stock.ticker;
      const tdName = document.createElement('td');
      tdName.textContent = stock.company;
      const tdSector = document.createElement('td');
      const span = document.createElement('span');
      span.className = 'sector-tag';
      span.textContent = stock.sector;
      tdSector.appendChild(span);
      const tdCap = document.createElement('td');
      tdCap.className = 'mono';
      tdCap.textContent = stock.marketCap;
      const tdPe = document.createElement('td');
      tdPe.className = 'mono';
      tdPe.textContent = stock.pe !== null ? stock.pe : 'N/A';
      const tdRet = document.createElement('td');
      tdRet.className = 'mono ' + (stock.perfYtd >= 0 ? 'positive' : 'negative');
      tdRet.textContent = stock.perfYtd !== null ? ((stock.perfYtd > 0 ? '+' : '') + stock.perfYtd + '%') : 'N/A';
      tr.append(tdTicker, tdName, tdSector, tdCap, tdPe, tdRet);
      tbody.appendChild(tr);
    };

    data.top50.forEach(s => renderRow(topTbody, s));
    data.bottom50.forEach(s => renderRow(botTbody, s));
  }

  renderTables('all');
  sectorFilter.addEventListener('change', (e) => { renderTables(e.target.value); });

  // ── 7. Key Insights ──
  const insightsEl = document.getElementById('insights-grid');
  const techCount = top50SectorMap['Technology'] ? top50SectorMap['Technology'].count : 0;
  const energyCount = top50SectorMap['Energy'] ? top50SectorMap['Energy'].count : 0;
  const noPeCount = data.top50.filter(s => s.pe === null).length;
  const last = top50Sorted[top50Sorted.length - 1];
  const gap = topPerformer.perfYtd - last.perfYtd;

  // Find top energy stock
  const energyStocks = data.top50.filter(s => s.sector === 'Energy').sort((a, b) => b.perfYtd - a.perfYtd);
  const topEnergy = energyStocks.length > 0 ? energyStocks[0] : null;

  const insights = [
    { icon: '💻', text: `<strong>Technology dominates</strong> with ${techCount} stocks in the top 50 performers, making it the most represented sector among the biggest gainers.` },
    { icon: '📈', text: `The <strong>average top 50 stock gained +${avgTop50.toFixed(1)}%</strong> vs the S&P 500's ${spyYtd >= 0 ? '+' : ''}${spyYtd.toFixed(2)}% — a staggering ${(avgTop50 / Math.abs(spyYtd)).toFixed(0)}x outperformance.` },
    { icon: '⚠️', text: `<strong>${noPeCount} stocks</strong> in the top 50 have no P/E ratio (unprofitable companies), showing that speculative names are leading parts of the 2026 rally.` },
    { icon: '⛽', text: `Energy stocks occupy <strong>${energyCount} spots</strong> in the top 50${topEnergy ? ', led by ' + topEnergy.ticker + ' (+' + topEnergy.perfYtd.toFixed(1) + '%)' : ''}.` },
    { icon: '🎯', text: `The gap between #1 (${topPerformer.ticker} at +${topPerformer.perfYtd.toLocaleString()}%) and #50 (${last.ticker} at +${last.perfYtd}%) is <strong>${gap.toFixed(0)} percentage points</strong>.` }
  ];

  insights.forEach(ins => {
    const card = document.createElement('div');
    card.className = 'insight-card';
    card.innerHTML = `<div class="insight-icon">${ins.icon}</div><div class="insight-text">${ins.text}</div>`;
    insightsEl.appendChild(card);
  });
});
  </script>

