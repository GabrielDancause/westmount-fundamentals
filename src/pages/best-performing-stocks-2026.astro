        document.addEventListener('DOMContentLoaded', () => {
            const data = window.__INITIAL_DATA__;

            // Extract unique sectors
            const sectors = new Set();
            data.top50.forEach(s => sectors.add(s.sector));
            data.bottom50.forEach(s => sectors.add(s.sector));

            const sectorFilter = document.getElementById('sector-filter');
            Array.from(sectors).sort().forEach(sector => {
                const option = document.createElement('option');
                option.value = sector;
                option.textContent = sector;
                sectorFilter.appendChild(option);
            });

            // Calculate sector averages
            const sectorStats = {};
            [...data.top50, ...data.bottom50].forEach(stock => {
                if (!sectorStats[stock.sector]) {
                    sectorStats[stock.sector] = { sum: 0, count: 0 };
                }
                if (stock.perfYtd !== null) {
                    sectorStats[stock.sector].sum += stock.perfYtd;
                    sectorStats[stock.sector].count += 1;
                }
            });

            const sectorAverages = Object.keys(sectorStats).map(sector => ({
                sector,
                avg: sectorStats[sector].count > 0 ? (sectorStats[sector].sum / sectorStats[sector].count) : 0
            })).sort((a, b) => b.avg - a.avg);

            const sectorTbody = document.getElementById('sector-tbody');
            sectorAverages.forEach(s => {
                const tr = document.createElement('tr');
                const tdSector = document.createElement('td');
                tdSector.textContent = s.sector;
                const tdAvg = document.createElement('td');
                tdAvg.className = 'mono ' + (s.avg >= 0 ? 'positive' : 'negative');
                tdAvg.textContent = (s.avg > 0 ? '+' : '') + s.avg.toFixed(2) + '%';
                tr.appendChild(tdSector);
                tr.appendChild(tdAvg);
                sectorTbody.appendChild(tr);
            });

            // Render SPY monthly
            const monthlyTbody = document.getElementById('monthly-tbody');
            if (data.spyMonthly && data.spyMonthly.length > 0) {
                const months = ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec'];
                data.spyMonthly.forEach(m => {
                    const date = new Date(m.date);
                    const monthName = months[date.getUTCMonth()];
                    const tr = document.createElement('tr');

                    const tdMonth = document.createElement('td');
                    tdMonth.textContent = monthName + ' ' + date.getUTCFullYear();

                    const tdRet = document.createElement('td');
                    tdRet.className = 'mono ' + (m.returnPct >= 0 ? 'positive' : 'negative');
                    tdRet.textContent = (m.returnPct > 0 ? '+' : '') + m.returnPct.toFixed(2) + '%';

                    tr.appendChild(tdMonth);
                    tr.appendChild(tdRet);
                    monthlyTbody.appendChild(tr);
                });
            } else {
                monthlyTbody.innerHTML = '<tr><td colspan="2">Data unavailable</td></tr>';
            }

            // Render tables
            function renderTables(filterSector) {
                const topTbody = document.getElementById('top-tbody');
                const botTbody = document.getElementById('bottom-tbody');
                topTbody.innerHTML = '';
                botTbody.innerHTML = '';

                const renderRow = (tbody, stock) => {
                    if (filterSector !== 'all' && stock.sector !== filterSector) return;

                    const tr = document.createElement('tr');

                    const tdTicker = document.createElement('td');
                    tdTicker.className = 'ticker mono';
                    tdTicker.textContent = stock.ticker;

                    const tdName = document.createElement('td');
                    tdName.textContent = stock.company;

                    const tdSector = document.createElement('td');
                    const span = document.createElement('span');
                    span.className = 'sector-tag';
                    span.textContent = stock.sector;
                    tdSector.appendChild(span);

                    const tdCap = document.createElement('td');
                    tdCap.className = 'mono';
                    tdCap.textContent = stock.marketCap;

                    const tdPe = document.createElement('td');
                    tdPe.className = 'mono';
                    tdPe.textContent = stock.pe !== null ? stock.pe : 'N/A';

                    const tdRet = document.createElement('td');
                    tdRet.className = 'mono ' + (stock.perfYtd >= 0 ? 'positive' : 'negative');
                    tdRet.textContent = stock.perfYtd !== null ? ((stock.perfYtd > 0 ? '+' : '') + stock.perfYtd + '%') : 'N/A';

                    tr.append(tdTicker, tdName, tdSector, tdCap, tdPe, tdRet);
                    tbody.appendChild(tr);
                };

                data.top50.forEach(s => renderRow(topTbody, s));
                data.bottom50.forEach(s => renderRow(botTbody, s));
            }

            renderTables('all');

            sectorFilter.addEventListener('change', (e) => {
                renderTables(e.target.value);
            });
        });
  </script>

  
