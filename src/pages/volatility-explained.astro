            <div class="comp-val" id="compHV">—</div>
            <div class="comp-label">Historical Volatility</div>
          </div>
          <div class="comp-card">
            <div class="comp-val" id="compIV">—</div>
            <div class="comp-label">Implied Volatility</div>
          </div>
          <div class="comp-card">
            <div class="comp-val" id="compDiff">—</div>
            <div class="comp-label">IV Premium/Discount</div>
          </div>
          <div class="comp-card">
            <div class="comp-val" id="compSignal">—</div>
