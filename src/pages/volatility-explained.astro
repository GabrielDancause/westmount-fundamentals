---
import SiteLayout from "../layouts/SiteLayout.astro";

export const meta = {
  title: "Volatility Explained — VIX, Implied & Historical Volatility Calculator | Westmount Fundamentals",
  description: "Understand market volatility with interactive calculators, VIX fear gauge, historical charts, and expert guides on implied volatility, historical volatility, and the VIX index.",
  category: "study",
  published: "2026-03-20",
};

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": meta.title,
    "description": meta.description,
    "datePublished": meta.published,
    "author": { "@type": "Organization", "name": "Westmount Fundamentals", "url": "https://westmountfundamentals.com" },
    "publisher": { "@type": "Organization", "name": "Westmount Fundamentals", "url": "https://westmountfundamentals.com" },
    "mainEntityOfPage": "https://westmountfundamentals.com/volatility-explained/"
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "What is volatility in the stock market?",
        "acceptedAnswer": { "@type": "Answer", "text": "Volatility measures how much a stock's price fluctuates over time, expressed as a percentage. Higher volatility means larger price swings. It is typically calculated as the annualized standard deviation of returns and helps investors assess risk." }
      },
      {
        "@type": "Question",
        "name": "What is the difference between implied volatility and historical volatility?",
        "acceptedAnswer": { "@type": "Answer", "text": "Historical volatility (HV) measures actual past price movements using standard deviation of returns. Implied volatility (IV) is forward-looking, derived from options prices, reflecting what the market expects future volatility to be. When IV exceeds HV, options are considered expensive." }
      },
      {
        "@type": "Question",
        "name": "What is the VIX and how does it work?",
        "acceptedAnswer": { "@type": "Answer", "text": "The VIX (CBOE Volatility Index) measures the market's expectation of 30-day volatility on the S&P 500, derived from options prices. Often called the 'fear gauge,' a VIX below 20 suggests calm markets while readings above 30 indicate significant fear and uncertainty." }
      },
      {
        "@type": "Question",
        "name": "How do you use a volatility calculator?",
        "acceptedAnswer": { "@type": "Answer", "text": "Enter the current stock price and the expected annualized volatility percentage. The calculator converts this into expected price ranges over 1-day, 1-week, and 1-month periods using the square root of time rule, showing the one-standard-deviation move in each timeframe." }
      },
      {
        "@type": "Question",
        "name": "Is high volatility good or bad for investors?",
        "acceptedAnswer": { "@type": "Answer", "text": "High volatility is neither inherently good nor bad — it depends on your strategy. For long-term investors, volatility creates buying opportunities in quality stocks. For options traders, high implied volatility means richer premiums. However, high volatility also increases short-term risk and requires careful position sizing." }
      }
    ]
  }
];
---
<SiteLayout
  title={meta.title}
  description={meta.description}
  site="westmount"
  canonical="https://westmountfundamentals.com/volatility-explained/"
  schema={schema}
>

<style>
  :root {
    --accent: #4a8fe7;
    --positive: #10b981;
    --negative: #ef4444;
    --bg-card: #0d1117;
    --border: #30363d;
  }
  .vol-hero {
    text-align: center;
    padding: 3rem 1rem 2rem;
    background: linear-gradient(135deg, rgba(74,143,231,0.1), rgba(74,143,231,0.02));
    border-bottom: 1px solid rgba(74,143,231,0.15);
  }
  .vol-hero h1 { font-size: 2.2rem; margin-bottom: 0.5rem; color: #e8eaed; }
  .vol-hero .subtitle { color: #9aa0a6; font-size: 1.1rem; max-width: 750px; margin: 0 auto 1.5rem; }

  .stat-row { display: flex; gap: 1.2rem; justify-content: center; flex-wrap: wrap; margin: 1.5rem 0; }
  .stat-card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 1.2rem 1.5rem;
    min-width: 160px;
    text-align: center;
    flex: 1;
    max-width: 220px;
  }
  .stat-card .stat-value { font-size: 1.8rem; font-weight: 700; color: var(--accent); }
  .stat-card .stat-label { font-size: 0.75rem; color: #9aa0a6; text-transform: uppercase; letter-spacing: 0.05em; margin-top: 0.25rem; }

  .container { max-width: 1100px; margin: 0 auto; padding: 2rem 1.5rem; }
  .section { margin-bottom: 3rem; }
  .section h2 { font-size: 1.6rem; color: #e8eaed; margin-bottom: 1rem; border-bottom: 2px solid var(--accent); padding-bottom: 0.5rem; display: inline-block; }
  .section h3 { font-size: 1.2rem; color: #c9d1d9; margin: 1.5rem 0 0.75rem; }
  .section p, .section li { color: #9aa0a6; line-height: 1.7; }
