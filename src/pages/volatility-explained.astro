    padding: 0.6rem 1rem;
    color: #e8eaed;
    font-size: 1rem;
    width: 160px;
  }
  .btn-calc {
    background: var(--accent);
    color: #fff;
    border: none;
    border-radius: 8px;
    padding: 0.65rem 1.5rem;
    font-size: 0.95rem;
    cursor: pointer;
    font-weight: 600;
    transition: opacity 0.2s;
  }
  .btn-calc:hover { opacity: 0.85; }
  .result-box {
    background: rgba(74,143,231,0.08);
    border: 1px solid rgba(74,143,231,0.2);
    border-radius: 8px;
    padding: 1rem 1.5rem;
    margin-top: 1rem;
