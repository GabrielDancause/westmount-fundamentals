  .result-box .result-row { display: flex; justify-content: space-between; padding: 0.4rem 0; border-bottom: 1px solid rgba(255,255,255,0.05); color: #c9d1d9; }
  .result-box .result-row:last-child { border-bottom: none; }
  .result-box .result-label { color: #9aa0a6; }
  .result-box .result-val { font-weight: 600; color: var(--accent); }

  /* VIX Gauge */
  .gauge-wrap { display: flex; flex-direction: column; align-items: center; margin: 1.5rem 0; }
  .gauge-bar {
    width: 100%;
