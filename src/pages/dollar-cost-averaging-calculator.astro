---
import SiteLayout from "../layouts/SiteLayout.astro";

const schema = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": "Dollar Cost Averaging Calculator",
  "operatingSystem": "Web",
  "applicationCategory": "FinanceApplication",
  "description": "Interactive Dollar Cost Averaging (DCA) calculator to estimate portfolio growth from regular investments.",
  "publisher": {
    "@type": "Organization",
    "name": "Westmount Research",
    "url": "https://westmountfundamentals.com"
  }
};

export const meta = {
  title: "Dollar Cost Averaging Calculator | Westmount Research",
  description: "Calculate your investment returns over time with our interactive Dollar Cost Averaging (DCA) calculator. See how regular contributions impact your portfolio.",
  category: "tool",
  published: "2026-03-15",
};
---

<SiteLayout
  site="westmount"
  title="Dollar Cost Averaging Calculator | Westmount Research"
  description="Calculate your investment returns over time with our interactive Dollar Cost Averaging (DCA) calculator. See how regular contributions impact your portfolio."
  canonical="https://westmountfundamentals.com/dollar-cost-averaging-calculator" schema={schema}
>
  <style>
:root {
    --chart-principal: rgba(90, 106, 128, 0.5);
    --chart-returns: rgba(74, 143, 231, 0.5);
    --chart-principal-border: rgba(90, 106, 128, 1);
    --chart-returns-border: rgba(74, 143, 231, 1);

}

  * { box-sizing: border-box; margin: 0; padding: 0; }
  body {
    font-family: 'Inter', -apple-system, sans-serif;
    background: var(--bg-color);
    color: var(--text-main);
    line-height: 1.6;
    padding-bottom: 40px;
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 24px;
  }

  header {
    margin: 40px 0;
    text-align: center;
  }
  h1 {
    font-size: 2.5rem;
    font-weight: 700;
    color: #ffffff;
    margin-bottom: 12px;
    letter-spacing: -0.5px;
  }
  .subtitle {
    font-size: 1.1rem;
    color: var(--text-muted);
    max-width: 600px;
    margin: 0 auto;
  }

  .calculator-grid {
    display: grid;
    grid-template-columns: 320px 1fr;
    gap: 24px;
    margin-bottom: 40px;
  }

  @media (max-width: 800px) {
    .calculator-grid {
      grid-template-columns: 1fr;
    }
  }

  .panel {
    background: var(--card-bg);
    border: 1px solid var(--border-color);
    border-radius: 12px;
    padding: 24px;
  }

  .input-group {
    margin-bottom: 20px;
  }
  .input-group label {
    display: block;
    font-size: 0.9rem;
    font-weight: 600;
    margin-bottom: 8px;
    color: #fff;
  }
  .input-wrapper {
    position: relative;
    display: flex;
    align-items: center;
  }
  .input-prefix, .input-suffix {
    position: absolute;
    color: var(--text-muted);
    font-size: 0.95rem;
  }
  .input-prefix { left: 12px; }
  .input-suffix { right: 12px; }

  input, select {
    width: 100%;
    background: rgba(0,0,0,0.2);
    border: 1px solid var(--border-color);
    color: #fff;
    font-family: 'JetBrains Mono', monospace;
    font-size: 1rem;
    padding: 10px 12px;
    border-radius: 6px;
    transition: border-color 0.2s;
  }
  input:focus, select:focus {
    outline: none;
    border-color: var(--accent-color);
  }
  input.has-prefix { padding-left: 28px; }
  input.has-suffix { padding-right: 28px; }

  .summary-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
    margin-bottom: 24px;
  }
  @media (max-width: 600px) {
    .summary-grid { grid-template-columns: 1fr; }
  }

  .summary-card {
    background: rgba(0,0,0,0.2);
    border: 1px solid var(--border-color);
    padding: 16px;
    border-radius: 8px;
    text-align: center;
  }
  .summary-label {
    font-size: 0.85rem;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.5px;
    margin-bottom: 8px;
  }
  .summary-value {
    font-size: 1.5rem;
    font-weight: 700;
    color: #fff;
    font-family: 'JetBrains Mono', monospace;
  }
  .summary-value.accent {
    color: var(--accent-color);
  }

  .chart-container {
    position: relative;
    height: 400px;
    width: 100%;
    margin-top: 24px;
  }

  .table-container {
    overflow-x: auto;
    margin-top: 40px;
  }
  table {
    width: 100%;
    border-collapse: collapse;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.9rem;
  }
  th, td {
    padding: 12px;
    text-align: right;
    border-bottom: 1px solid var(--border-color);
  }
  th {
    color: var(--text-muted);
    font-family: 'Inter', sans-serif;
    font-weight: 600;
    font-size: 0.85rem;
    text-transform: uppercase;
  }
  th:first-child, td:first-child { text-align: left; }
  tr:hover td { background: rgba(255,255,255,0.02); }

  .faq-section {
    margin-top: 60px;
    max-width: 800px;
    margin-left: auto;
    margin-right: auto;
  }
  .faq-section h2 {
    font-size: 1.8rem;
    color: #fff;
    margin-bottom: 24px;
    text-align: center;
  }
  .faq-item {
    background: var(--card-bg);
    border: 1px solid var(--border-color);
    border-radius: 8px;
    margin-bottom: 16px;
    padding: 20px;
  }
  .faq-question {
    font-weight: 600;
    color: #fff;
    font-size: 1.1rem;
    margin-bottom: 10px;
  }
  .faq-answer {
    color: var(--text-muted);
    font-size: 0.95rem;
    line-height: 1.6;
  }

  footer {
    text-align: center;
    margin-top: 60px;
    padding-top: 24px;
    border-top: 1px solid var(--border-color);
    color: var(--text-muted);
    font-size: 0.85rem;
  }
  .disclaimer {
    margin-top: 8px;
    font-size: 0.75rem;
  }
  </style>

<div class="container">
  <h1>Dollar Cost Averaging Calculator</h1>

  <div class="calculator-grid">
    <!-- Controls Panel -->
    <div class="panel">
      <div class="input-group">
        <label for="initialAmount">Initial Investment</label>
        <div class="input-wrapper">
          <span class="input-prefix">$</span>
          <input type="number" id="initialAmount" class="has-prefix" value="1000" min="0" step="100">
        </div>
      </div>

      <div class="input-group">
        <label for="contributionAmount">Regular Contribution</label>
        <div class="input-wrapper">
          <span class="input-prefix">$</span>
          <input type="number" id="contributionAmount" class="has-prefix" value="500" min="0" step="50">
        </div>
      </div>

      <div class="input-group">
        <label for="contributionFreq">Contribution Frequency</label>
        <select id="contributionFreq">
          <option value="12" selected>Monthly</option>
          <option value="26">Bi-Weekly</option>
          <option value="52">Weekly</option>
          <option value="4">Quarterly</option>
          <option value="1">Annually</option>
        </select>
      </div>

      <div class="input-group">
        <label for="returnRate">Expected Annual Return</label>
        <div class="input-wrapper">
          <input type="number" id="returnRate" class="has-suffix" value="8" min="0" max="100" step="0.1">
          <span class="input-suffix">%</span>
        </div>
      </div>

      <div class="input-group">
        <label for="years">Investment Duration</label>
        <div class="input-wrapper">
          <input type="number" id="years" class="has-suffix" value="10" min="1" max="50" step="1">
          <span class="input-suffix">Years</span>
        </div>
      </div>
    </div>

    <!-- Results Panel -->
    <div class="panel">
      <div class="summary-grid">
        <div class="summary-card">
          <div class="summary-label">Total Principal</div>
          <div class="summary-value" id="valPrincipal">$0</div>
        </div>
        <div class="summary-card">
          <div class="summary-label">Total Return</div>
          <div class="summary-value" id="valReturn">$0</div>
        </div>
        <div class="summary-card">
          <div class="summary-label">Final Balance</div>
          <div class="summary-value accent" id="valFinal">$0</div>
        </div>
      </div>

      <div class="chart-container">
        <canvas id="growthChart"></canvas>
      </div>
    </div>
  </div>

  <div class="panel table-container">
    <table id="dataTable">
      <thead>
        <tr>
          <th>Year</th>
          <th>Total Principal</th>
          <th>Total Returns</th>
          <th>End Balance</th>
        </tr>
      </thead>
      <tbody>
        <!-- Populated via JS -->
      </tbody>
    </table>
  </div>

  <section class="faq-section">
    <h2>Frequently Asked Questions</h2>

    <div class="faq-item">
      <div class="faq-question">What is Dollar Cost Averaging (DCA)?</div>
      <div class="faq-answer">Dollar Cost Averaging (DCA) is an investment strategy where you invest a fixed amount of money at regular intervals, regardless of market conditions. This approach helps reduce the impact of volatility on the overall purchase.</div>
    </div>

    <div class="faq-item">
      <div class="faq-question">How does Dollar Cost Averaging reduce risk?</div>
      <div class="faq-answer">By investing the same dollar amount regularly, you automatically buy more shares when prices are low and fewer shares when prices are high. This averages out your cost per share over time and reduces the risk of making a single large investment at a market peak.</div>
    </div>

    <div class="faq-item">
      <div class="faq-question">Is DCA better than lump-sum investing?</div>
      <div class="faq-answer">Statistically, lump-sum investing tends to outperform DCA in rising markets because your money is invested longer. However, DCA is often preferred for its psychological benefits, as it reduces the stress of timing the market and mitigates the risk of a market drop immediately after a large investment.</div>
    </div>

    <div class="faq-item">
      <div class="faq-question">How often should I invest when using DCA?</div>
      <div class="faq-answer">The frequency of your investments should align with your cash flow and financial goals. Most investors align their DCA strategy with their paychecks, such as investing monthly or bi-weekly.</div>
    </div>

    <div class="faq-item">
      <div class="faq-question">Can I use DCA for any type of investment?</div>
      <div class="faq-answer">Yes, DCA can be applied to almost any asset class, including individual stocks, mutual funds, ETFs, and cryptocurrencies. It is particularly effective for long-term investments in diversified index funds.</div>
    </div>
  </section>

</div>
  <script is:inline>
// Setup Chart
  let chartInstance = null;
  const ctx = document.getElementById('growthChart').getContext('2d');

  function initChart() {
    chartInstance = new Chart(ctx, {
      type: 'line',
      data: {
        labels: [],
        datasets: [
          {
            label: 'Total Principal',
            data: [],
            borderColor: 'rgba(90, 106, 128, 1)',
            backgroundColor: 'rgba(90, 106, 128, 0.2)',
            borderWidth: 2,
            fill: true,
            pointRadius: 0,
            pointHoverRadius: 4,
            tension: 0.1
          },
          {
            label: 'Final Balance',
            data: [],
            borderColor: 'rgba(74, 143, 231, 1)',
            backgroundColor: 'rgba(74, 143, 231, 0.2)',
            borderWidth: 2,
            fill: true,
            pointRadius: 0,
            pointHoverRadius: 4,
            tension: 0.1
          }
        ]
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        interaction: {
          mode: 'index',
          intersect: false,
        },
        plugins: {
          legend: {
            position: 'top',
            labels: { color: '#c8d0de', font: { family: "'Inter', sans-serif" } }
          },
          tooltip: {
            backgroundColor: 'rgba(10, 16, 32, 0.9)',
            titleColor: '#fff',
            bodyColor: '#c8d0de',
            borderColor: '#152040',
            borderWidth: 1,
            padding: 12,
            callbacks: {
              label: function(context) {
                let label = context.dataset.label || '';
                if (label) { label += ': '; }
                if (context.parsed.y !== null) {
                  label += new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD', maximumFractionDigits: 0 }).format(context.parsed.y);
                }
                return label;
              }
            }
          }
        },
        scales: {
          x: {
            grid: { color: '#152040' },
            ticks: { color: '#5a6a80', font: { family: "'JetBrains Mono', monospace" } }
          },
          y: {
            grid: { color: '#152040' },
            beginAtZero: true,
            ticks: {
              color: '#5a6a80',
              font: { family: "'JetBrains Mono', monospace" },
              callback: function(value) {
                if (value >= 1000000) return '$' + (value / 1000000).toFixed(1) + 'M';
                if (value >= 1000) return '$' + (value / 1000).toFixed(0) + 'k';
                return '$' + value;
              }
            }
          }
        }
      }
    });
  }

  function formatCurrency(val) {
    return new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD', maximumFractionDigits: 0 }).format(val);
  }

  function calculate() {
    const initialAmount = parseFloat(document.getElementById('initialAmount').value) || 0;
    const contributionAmount = parseFloat(document.getElementById('contributionAmount').value) || 0;
    const contributionFreq = parseInt(document.getElementById('contributionFreq').value) || 12;
    const returnRate = parseFloat(document.getElementById('returnRate').value) || 0;
    const years = parseInt(document.getElementById('years').value) || 0;

    const ratePerPeriod = (returnRate / 100) / contributionFreq;
    const totalPeriods = years * contributionFreq;

    let balance = initialAmount;
    let principal = initialAmount;

    const yearlyData = [];
    yearlyData.push({ year: 0, principal: principal, balance: balance, returns: 0 });

    for (let y = 1; y <= years; y++) {
      for (let p = 1; p <= contributionFreq; p++) {
        balance += contributionAmount;
        balance *= (1 + ratePerPeriod);
        principal += contributionAmount;
      }
      yearlyData.push({
        year: y,
        principal: principal,
        balance: balance,
        returns: balance - principal
      });
    }

    const finalData = yearlyData[yearlyData.length - 1];

    // Update Summary
    document.getElementById('valPrincipal').textContent = formatCurrency(finalData.principal);
    document.getElementById('valReturn').textContent = formatCurrency(finalData.returns);
    document.getElementById('valFinal').textContent = formatCurrency(finalData.balance);

    // Update Chart
    const labels = yearlyData.map(d => `Year ${d.year}`);
    const principalData = yearlyData.map(d => d.principal);
    const balanceData = yearlyData.map(d => d.balance);

    chartInstance.data.labels = labels;
    chartInstance.data.datasets[0].data = principalData;
    chartInstance.data.datasets[1].data = balanceData;
    chartInstance.update();

    // Update Table
    const tbody = document.querySelector('#dataTable tbody');
    tbody.innerHTML = '';

    // Skip year 0 if it clutters, but let's include it for completeness
    yearlyData.forEach(d => {
      const tr = document.createElement('tr');
      tr.innerHTML = `
        <td>${d.year}</td>
        <td>${formatCurrency(d.principal)}</td>
        <td style="color: var(--accent-color)">${formatCurrency(d.returns)}</td>
        <td style="font-weight: 700; color: #fff">${formatCurrency(d.balance)}</td>
      `;
      tbody.appendChild(tr);
    });
  }

  // Event Listeners
  const inputs = document.querySelectorAll('input, select');
  inputs.forEach(input => {
    input.addEventListener('input', calculate);
  });

  // Init
  document.addEventListener('DOMContentLoaded', () => {
    initChart();
    calculate();
  });
  </script>

  
  <section style="max-width:800px;margin:40px auto;padding:0 24px">
    <div style="background:var(--card-bg,#0a1020);border:1px solid var(--border-color,#152040);border-radius:12px;padding:24px">
      <h3 style="font-size:16px;color:var(--text-bright,#fff);margin-bottom:12px">Data Sources & Methodology</h3>
      <p style="font-size:14px;color:var(--text-dim,#94a3b8);line-height:1.7;margin:0">Calculations use standard financial formulas. Results are estimates for educational purposes and should not be used as the sole basis for financial decisions.</p>
    </div>
  </section>

  <section style="max-width:800px;margin:40px auto;padding:0 24px">
    <h2 style="font-size:20px;color:var(--text-bright,#fff);margin-bottom:16px">Related Pages</h2>
    <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:12px">
      <a href="/what-is-dollar-cost-averaging/" style="display:block;padding:16px;background:var(--card-bg,#0a1020);border:1px solid var(--border-color,#152040);border-radius:8px;text-decoration:none;color:var(--text-primary,#c8d0de);transition:transform 0.2s" onmouseover="this.style.transform='translateY(-2px)'" onmouseout="this.style.transform='none'">What is Dollar Cost Averaging (DCA)? The Ultimate Guide</a>
      <a href="/guide-dollar-cost-averaging/" style="display:block;padding:16px;background:var(--card-bg,#0a1020);border:1px solid var(--border-color,#152040);border-radius:8px;text-decoration:none;color:var(--text-primary,#c8d0de);transition:transform 0.2s" onmouseover="this.style.transform='translateY(-2px)'" onmouseout="this.style.transform='none'">Dollar-Cost Averaging: Does It Actually Beat Lump Sum Inv...</a>
      <a href="/cost-basis-calculator/" style="display:block;padding:16px;background:var(--card-bg,#0a1020);border:1px solid var(--border-color,#152040);border-radius:8px;text-decoration:none;color:var(--text-primary,#c8d0de);transition:transform 0.2s" onmouseover="this.style.transform='translateY(-2px)'" onmouseout="this.style.transform='none'">Cost Basis Calculator: Track Stock & Crypto Purchase Lots (2</a>
      <a href="/stock-split-calculator/" style="display:block;padding:16px;background:var(--card-bg,#0a1020);border:1px solid var(--border-color,#152040);border-radius:8px;text-decoration:none;color:var(--text-primary,#c8d0de);transition:transform 0.2s" onmouseover="this.style.transform='translateY(-2px)'" onmouseout="this.style.transform='none'">Stock Split Calculator & Guide: How Forward and Reverse Spli</a>
    </div>
  </section>
</SiteLayout>
