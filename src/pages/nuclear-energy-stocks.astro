const page = (registry as any)["nuclear-energy-stocks"];
export const meta = { title: "Nuclear Energy Stocks: The Complete Investment Guide", description: "Discover why the world is turning back to uranium. Explore the top nuclear energy stocks, the rise of SMRs, and why baseload power is driving the next...", category: "guide", published: "2026-03-15" };

