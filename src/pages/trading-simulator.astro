---
import SiteLayout from "../layouts/SiteLayout.astro";

export const meta = {
  title: "Free Trading Simulator & Stock Market Practice Game",
  description: "Practice trading stocks with virtual money in real-time. Our free trading simulator helps beginners learn market mechanics without risking capital.",
  category: "tool",
};

const schema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What is a trading simulator?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "A trading simulator, often called paper trading, is a tool that allows you to practice buying and selling stocks, options, or other financial instruments using virtual money rather than real capital. It mimics live market conditions so you can test strategies safely."
      }
    },
    {
      "@type": "Question",
      "name": "Why should I use a trading simulator before investing real money?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Using a simulator helps you understand market mechanics, test different trading strategies, learn how to execute various order types, and manage emotional reactions to price swings—all without the financial risk of losing actual money."
      }
    },
    {
      "@type": "Question",
      "name": "How realistic is paper trading compared to live trading?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Paper trading is mechanically identical to live trading, simulating real-time prices and order execution. However, it lacks the psychological pressure of risking real money, which is often the biggest hurdle for new traders to overcome when transitioning to live markets."
      }
    },
    {
      "@type": "Question",
      "name": "Can I test day trading strategies on a simulator?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes, a good trading simulator allows you to practice day trading, swing trading, and long-term investing. You can practice entering and exiting positions quickly to see how your day trading strategies would perform in real market conditions."
      }
    },
    {
      "@type": "Question",
      "name": "How long should I practice on a trading simulator?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Most experts recommend paper trading until you achieve consistent profitability over several months. A common benchmark is maintaining a net positive return across 3 to 6 months of simulated trading before committing real capital."
      }
    }
  ]
});
---

<SiteLayout site="westmount" title={meta.title} description={meta.description} canonical="https://westmountfundamentals.com/trading-simulator" schema={schema}>
  <div style="max-width:1280px;margin:0 auto;padding:16px 24px 0;display:flex;justify-content:space-between;align-items:center;font-size:13px;color:var(--text-dim,#94a3b8)">
    <nav aria-label="Breadcrumb"><a href="/" style="color:var(--text-dim,#94a3b8);text-decoration:none">Home</a> <span style="margin:0 6px;opacity:0.5">›</span> <a href="/tools/" style="color:var(--text-dim,#94a3b8);text-decoration:none">Tools</a> <span style="margin:0 6px;opacity:0.5">›</span> <span style="color:var(--text-primary,#c8d0de)">Free Trading Simulator & Stock Market Practice ...</span></nav>
    <span>3 min read</span>
  </div>
  <div class="page-content">

    <header class="page-header">
      <h1>Trading Simulator</h1>
      <p class="subtitle">Practice trading in a risk-free environment with our real-time virtual portfolio tracker.</p>
    </header>

    <section class="calculator-container">
      <div class="calculator-layout">
        <!-- Input Section -->
        <div class="input-panel">
          <h2>Trade Setup</h2>

          <div class="form-group">
            <label for="initial-balance">Starting Balance ($)</label>
            <input type="number" id="initial-balance" value="100000" min="1000" step="1000" aria-label="Starting Account Balance">
          </div>

          <div class="form-group">
            <label for="trade-type">Trade Type</label>
            <select id="trade-type" aria-label="Select Trade Type">
              <option value="buy">Buy (Long)</option>
              <option value="sell">Sell (Short)</option>
            </select>
          </div>

          <div class="form-group">
            <label for="entry-price">Entry Price ($)</label>
            <input type="number" id="entry-price" value="150.00" min="0.01" step="0.01" aria-label="Entry Price">
          </div>

          <div class="form-group">
            <label for="shares">Number of Shares</label>
            <input type="number" id="shares" value="100" min="1" step="1" aria-label="Number of Shares">
          </div>

          <div class="form-group">
            <label for="exit-price">Current / Exit Price ($)</label>
            <input type="number" id="exit-price" value="155.00" min="0.01" step="0.01" aria-label="Exit Price">
          </div>

          <div class="form-group">
            <label for="commission">Commission per Trade ($)</label>
            <input type="number" id="commission" value="0.00" min="0" step="0.01" aria-label="Commission per Trade">
          </div>
        </div>

        <!-- Results Section -->
        <div class="results-panel">
          <h2>Trade Results</h2>

          <div class="result-card primary-result">
            <span class="result-label">Net Profit/Loss</span>
            <span id="net-pl" class="result-value positive">$500.00</span>
          </div>

          <div class="result-grid">
            <div class="result-box">
              <span class="box-label">Gross P/L</span>
              <span id="gross-pl" class="box-value">$500.00</span>
            </div>
            <div class="result-box">
              <span class="box-label">Return on Investment (ROI)</span>
              <span id="roi" class="box-value">3.33%</span>
            </div>
            <div class="result-box">
              <span class="box-label">Total Trade Cost</span>
              <span id="trade-cost" class="box-value">$15,000.00</span>
            </div>
            <div class="result-box">
              <span class="box-label">Total Commission Paid</span>
              <span id="total-commission" class="box-value">$0.00</span>
            </div>
          </div>

          <div class="portfolio-status">
            <h3>Portfolio Impact</h3>
            <div class="status-row">
              <span>New Account Balance:</span>
              <span id="new-balance" class="status-value">$100,500.00</span>
            </div>
            <div class="status-row">
              <span>Available Buying Power:</span>
              <span id="buying-power" class="status-value">$85,500.00</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="educational-content">
      <h2>Why Use a Trading Simulator?</h2>
      <p>A trading simulator, commonly known as a paper trading account, allows you to build confidence and test trading strategies without risking real capital. It provides a sandboxed environment where you can experience real market mechanics.</p>

      <h3>How the Math Works</h3>
      <p>Understanding the exact formulas used in trading is crucial for managing risk and setting realistic expectations. Here's how the simulator calculates your results:</p>

      <div class="formula-box">
        <h4>1. Gross Profit/Loss (Long Position)</h4>
        <code>Gross P/L = (Exit Price - Entry Price) × Number of Shares</code>
        <p class="formula-desc">For a short position, the formula flips: <code>(Entry Price - Exit Price) × Shares</code></p>
      </div>

      <div class="formula-box">
        <h4>2. Total Trade Cost</h4>
        <code>Trade Cost = Entry Price × Number of Shares</code>
        <p class="formula-desc">This represents the capital tied up in the trade (excluding margin leverage).</p>
      </div>

      <div class="formula-box">
        <h4>3. Net Profit/Loss</h4>
        <code>Net P/L = Gross P/L - (Commission × 2)</code>
        <p class="formula-desc">Commissions are typically paid on both entry and exit, so the fee is multiplied by two.</p>
      </div>

      <div class="formula-box">
        <h4>4. Return on Investment (ROI)</h4>
        <code>ROI = (Net P/L ÷ Total Trade Cost) × 100</code>
        <p class="formula-desc">This gives you the percentage return relative to the capital risked on the trade.</p>
      </div>

      <h3>Common Simulation Strategies</h3>
      <ul>
        <li><strong>Day Trading:</strong> Practice opening and closing positions within the same trading day to capture short-term momentum.</li>
        <li><strong>Swing Trading:</strong> Hold simulated positions for several days or weeks to profit from anticipated price swings.</li>
        <li><strong>Risk Management:</strong> Use the simulator to calculate exact position sizes so that a single loss doesn't exceed 1-2% of your total account balance.</li>
      </ul>

      <p>By treating the virtual money as if it were real and strictly following your rules, a simulator becomes the most valuable tool for transitioning into a consistently profitable trader.</p>
    </section>
  </div>

  
  <section style="max-width:800px;margin:40px auto;padding:0 24px">
    <div style="background:var(--card-bg,#0a1020);border:1px solid var(--border-color,#152040);border-radius:12px;padding:24px">
      <h3 style="font-size:16px;color:var(--text-bright,#fff);margin-bottom:12px">Data Sources & Methodology</h3>
      <p style="font-size:14px;color:var(--text-dim,#94a3b8);line-height:1.7;margin:0">Data compiled from publicly available financial sources including SEC filings, Federal Reserve Economic Data (FRED), and reputable financial data providers. All figures are for informational purposes only.</p>
    </div>
  </section>

  <section style="max-width:800px;margin:40px auto;padding:0 24px">
    <h2 style="font-size:20px;color:var(--text-bright,#fff);margin-bottom:16px">Related Pages</h2>
    <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:12px">
      <a href="/options-trading-simulator/" style="display:block;padding:16px;background:var(--card-bg,#0a1020);border:1px solid var(--border-color,#152040);border-radius:8px;text-decoration:none;color:var(--text-primary,#c8d0de);transition:transform 0.2s" onmouseover="this.style.transform='translateY(-2px)'" onmouseout="this.style.transform='none'">Options Trading Simulator: Free Practice Calculator</a>
      <a href="/stock-trading-simulator/" style="display:block;padding:16px;background:var(--card-bg,#0a1020);border:1px solid var(--border-color,#152040);border-radius:8px;text-decoration:none;color:var(--text-primary,#c8d0de);transition:transform 0.2s" onmouseover="this.style.transform='translateY(-2px)'" onmouseout="this.style.transform='none'">Free Stock Trading Simulator: Practice Paper Trading</a>
      <a href="/paper-trading-simulator/" style="display:block;padding:16px;background:var(--card-bg,#0a1020);border:1px solid var(--border-color,#152040);border-radius:8px;text-decoration:none;color:var(--text-primary,#c8d0de);transition:transform 0.2s" onmouseover="this.style.transform='translateY(-2px)'" onmouseout="this.style.transform='none'">Free Paper Trading Simulator & Virtual Portfolio Manager</a>
      <a href="/day-trading-simulator/" style="display:block;padding:16px;background:var(--card-bg,#0a1020);border:1px solid var(--border-color,#152040);border-radius:8px;text-decoration:none;color:var(--text-primary,#c8d0de);transition:transform 0.2s" onmouseover="this.style.transform='translateY(-2px)'" onmouseout="this.style.transform='none'">Day Trading Simulator: Test Your Strategy Risk-Free</a>
    </div>
  </section>
</SiteLayout>

<style>
  .page-header {
    margin-bottom: 2rem;
    text-align: center;
  }

  .page-header h1 {
    color: var(--text-primary);
    font-size: 2.5rem;
    margin-bottom: 0.5rem;
  }

  .subtitle {
    color: var(--text-secondary);
    font-size: 1.1rem;
    max-width: 600px;
    margin: 0 auto;
  }

  .calculator-container {
    background: var(--card-bg);
    border: 1px solid var(--border-color);
    border-radius: 12px;
    padding: 2rem;
    margin-bottom: 3rem;
    box-shadow: 0 4px 6px rgba(0, 0, 0, 0.05);
  }

  .calculator-layout {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
  }

  @media (min-width: 768px) {
    .calculator-layout {
      grid-template-columns: 1fr 1fr;
    }
  }

  h2 {
    color: var(--text-primary);
    margin-bottom: 1.5rem;
    font-size: 1.5rem;
    border-bottom: 2px solid var(--border-color);
    padding-bottom: 0.5rem;
  }

  .form-group {
    margin-bottom: 1.25rem;
  }

  label {
    display: block;
    color: var(--text-secondary);
    margin-bottom: 0.5rem;
    font-weight: 500;
  }

  input, select {
    width: 100%;
    padding: 0.75rem;
    background: var(--bg-color);
    border: 1px solid var(--border-color);
    border-radius: 6px;
    color: var(--text-primary);
    font-size: 1rem;
    transition: border-color 0.2s;
  }

  input:focus, select:focus {
    outline: none;
    border-color: var(--accent-color);
  }

  .results-panel {
    background: var(--bg-color);
    padding: 1.5rem;
    border-radius: 8px;
    border: 1px solid var(--border-color);
  }

  .primary-result {
    text-align: center;
    padding: 1.5rem;
    background: var(--card-bg);
    border-radius: 8px;
    margin-bottom: 1.5rem;
    border: 1px solid var(--border-color);
  }

  .result-label {
    display: block;
    color: var(--text-secondary);
    font-size: 1.1rem;
    margin-bottom: 0.5rem;
  }

  .result-value {
    display: block;
    font-size: 2.5rem;
    font-weight: bold;
  }

  .positive {
    color: var(--buy-color, #22c55e);
  }

  .negative {
    color: var(--sell-color, #ef4444);
  }

  .result-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
    margin-bottom: 1.5rem;
  }

  .result-box {
    background: var(--card-bg);
    padding: 1rem;
    border-radius: 6px;
    border: 1px solid var(--border-color);
  }

  .box-label {
    display: block;
    color: var(--text-secondary);
    font-size: 0.875rem;
    margin-bottom: 0.25rem;
  }

  .box-value {
    display: block;
    color: var(--text-primary);
    font-size: 1.125rem;
    font-weight: 600;
  }

  .portfolio-status {
    background: var(--card-bg);
    padding: 1.25rem;
    border-radius: 8px;
    border: 1px solid var(--border-color);
  }

  .portfolio-status h3 {
    margin-top: 0;
    margin-bottom: 1rem;
    font-size: 1.1rem;
    color: var(--text-primary);
  }

  .status-row {
    display: flex;
    justify-content: space-between;
    margin-bottom: 0.5rem;
    color: var(--text-secondary);
  }

  .status-value {
    font-weight: 600;
    color: var(--text-primary);
  }

  .educational-content {
    margin-top: 3rem;
  }

  .educational-content p {
    color: var(--text-secondary);
    line-height: 1.6;
    margin-bottom: 1.5rem;
  }

  .educational-content h3 {
    color: var(--text-primary);
    margin-top: 2rem;
    margin-bottom: 1rem;
  }

  .educational-content ul {
    color: var(--text-secondary);
    line-height: 1.6;
    margin-bottom: 1.5rem;
    padding-left: 1.5rem;
  }

  .educational-content li {
    margin-bottom: 0.5rem;
  }

  .formula-box {
    background: var(--card-bg);
    border-left: 4px solid var(--accent-color);
    padding: 1.25rem;
    margin-bottom: 1rem;
    border-radius: 0 6px 6px 0;
  }

  .formula-box h4 {
    margin: 0 0 0.5rem 0;
    color: var(--text-primary);
  }

  .formula-box code {
    display: block;
    background: var(--bg-color);
    padding: 0.75rem;
    border-radius: 4px;
    font-family: monospace;
    color: var(--text-primary);
    margin-bottom: 0.5rem;
  }

  .formula-desc {
    margin: 0 !important;
    font-size: 0.9rem;
  }
</style>

<script is:inline>
  document.addEventListener("DOMContentLoaded", () => {
    // Inputs
    const initialBalanceInput = document.getElementById("initial-balance");
    const tradeTypeSelect = document.getElementById("trade-type");
    const entryPriceInput = document.getElementById("entry-price");
    const sharesInput = document.getElementById("shares");
    const exitPriceInput = document.getElementById("exit-price");
    const commissionInput = document.getElementById("commission");

    // Outputs
    const netPlOutput = document.getElementById("net-pl");
    const grossPlOutput = document.getElementById("gross-pl");
    const roiOutput = document.getElementById("roi");
    const tradeCostOutput = document.getElementById("trade-cost");
    const totalCommissionOutput = document.getElementById("total-commission");
    const newBalanceOutput = document.getElementById("new-balance");
    const buyingPowerOutput = document.getElementById("buying-power");

    function formatCurrency(value) {
      return new Intl.NumberFormat("en-US", {
        style: "currency",
        currency: "USD",
        minimumFractionDigits: 2,
        maximumFractionDigits: 2
      }).format(value);
    }

    function formatPercent(value) {
      return new Intl.NumberFormat("en-US", {
        style: "percent",
        minimumFractionDigits: 2,
        maximumFractionDigits: 2
      }).format(value / 100);
    }

    function updateCalculator() {
      // Parse inputs safely
      const initialBalance = parseFloat(initialBalanceInput.value) || 0;
      const tradeType = tradeTypeSelect.value;
      const entryPrice = parseFloat(entryPriceInput.value) || 0;
      const shares = parseInt(sharesInput.value, 10) || 0;
      const exitPrice = parseFloat(exitPriceInput.value) || 0;
      const commission = parseFloat(commissionInput.value) || 0;

      // Ensure no negative inputs for pure costs/shares
      const safeShares = Math.max(0, shares);
      const safeEntry = Math.max(0, entryPrice);
      const safeExit = Math.max(0, exitPrice);
      const safeCommission = Math.max(0, commission);
      const safeInitialBalance = Math.max(0, initialBalance);

      // Calculations
      const totalTradeCost = safeEntry * safeShares;
      const totalCommission = safeCommission * 2; // entry and exit

      let grossPl = 0;
      if (tradeType === "buy") {
        grossPl = (safeExit - safeEntry) * safeShares;
      } else {
        grossPl = (safeEntry - safeExit) * safeShares;
      }

      const netPl = grossPl - totalCommission;

      let roi = 0;
      if (totalTradeCost > 0) {
        roi = (netPl / totalTradeCost) * 100;
      }

      const newBalance = safeInitialBalance + netPl;
      const buyingPower = newBalance - totalTradeCost; // Simplified BP calculation

      // Fixing floating point artifacts
      const fixedNetPl = parseFloat(netPl.toPrecision(14));
      const finalNetPl = Math.abs(fixedNetPl - Math.round(fixedNetPl)) < 1e-14 ? Math.round(fixedNetPl) : fixedNetPl;

      // Update DOM
      netPlOutput.textContent = formatCurrency(finalNetPl);
      grossPlOutput.textContent = formatCurrency(grossPl);
      roiOutput.textContent = formatPercent(roi);
      tradeCostOutput.textContent = formatCurrency(totalTradeCost);
      totalCommissionOutput.textContent = formatCurrency(totalCommission);
      newBalanceOutput.textContent = formatCurrency(newBalance);
      buyingPowerOutput.textContent = formatCurrency(buyingPower);

      // Apply positive/negative styling for Net P/L
      if (finalNetPl > 0) {
        netPlOutput.className = "result-value positive";
        netPlOutput.textContent = "+" + formatCurrency(finalNetPl);
      } else if (finalNetPl < 0) {
        netPlOutput.className = "result-value negative";
      } else {
        netPlOutput.className = "result-value"; // Neutral
      }
    }

    // Bind event listeners using input event for real-time reactivity
    const inputs = [
      initialBalanceInput,
      tradeTypeSelect,
      entryPriceInput,
      sharesInput,
      exitPriceInput,
      commissionInput
    ];

    inputs.forEach(input => {
      input.addEventListener("input", updateCalculator);
    });

    // Global exposure for Playwright testing if needed
    window.updateCalculator = updateCalculator;

    // Initial calculation
    updateCalculator();
  });
</script>
