</style>

<script>
  function initCalculator() {
    const sharePriceInput = document.getElementById('sharePrice');
    const annualDividendInput = document.getElementById('annualDividend');
    const sharesOwnedInput = document.getElementById('sharesOwned');

    const calcYield = document.getElementById('calcYield');
    const calcAnnual = document.getElementById('calcAnnual');
    const calcMonthly = document.getElementById('calcMonthly');
    const calcQuarterly = document.getElementById('calcQuarterly');

    if (!sharePriceInput || !annualDividendInput || !sharesOwnedInput) return;

    function formatCurrency(value) {
      return new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD' }).format(value);
    }

    function calculate() {
      const price = parseFloat(sharePriceInput.value) || 0;
      const dividend = parseFloat(annualDividendInput.value) || 0;
      const shares = parseInt(sharesOwnedInput.value, 10) || 0;

      let yieldPct = 0;
      if (price > 0) {
        yieldPct = (dividend / price) * 100;
      }

      const annualIncome = dividend * shares;
      const monthlyIncome = annualIncome / 12;
      const quarterlyIncome = annualIncome / 4;

      if (calcYield) calcYield.textContent = yieldPct.toFixed(2) + '%';
      if (calcAnnual) calcAnnual.textContent = formatCurrency(annualIncome);
      if (calcMonthly) calcMonthly.textContent = formatCurrency(monthlyIncome);
      if (calcQuarterly) calcQuarterly.textContent = formatCurrency(quarterlyIncome);
    }

    sharePriceInput.addEventListener('input', calculate);
    annualDividendInput.addEventListener('input', calculate);
    sharesOwnedInput.addEventListener('input', calculate);

    // Initial calculation
    calculate();
  }

  // Support for Astro View Transitions
  document.addEventListener('astro:page-load', initCalculator);

  // Fallback for standard load
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initCalculator);
  } else {
    initCalculator();
  }
</script>
